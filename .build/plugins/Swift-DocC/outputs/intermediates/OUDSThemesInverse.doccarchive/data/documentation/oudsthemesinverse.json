{"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"text":"This is an override of the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","isActive":true,"type":"reference"},{"text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make ","type":"text"},{"identifier":"doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"text":" derivable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode."}],"type":"paragraph"},{"level":2,"type":"heading","text":"How to use the theme","anchor":"How-to-use-the-theme"},{"inlineContent":[{"text":"You can use ","type":"text"},{"identifier":"doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"text":" directly. You will have to use the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" for your root view and give it an instance of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"text":". Keep in mind the themes are ","type":"text"},{"inlineContent":[{"text":"Swift class objects","type":"text"}],"type":"emphasis"},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""]}],"kind":"content"}],"abstract":[{"type":"text","text":"This theme overrides the "},{"type":"emphasis","inlineContent":[{"text":"Orange theme","type":"text"}]},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesinverse"]}],"hierarchy":{"paths":[[]]},"topicSections":[{"identifiers":["doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"anchor":"Group","title":"Group"}],"metadata":{"roleHeading":"Framework","role":"collection","modules":[{"name":"OUDSThemesInverse"}],"title":"OUDSThemesInverse","externalID":"OUDSThemesInverse","symbolKind":"module"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse"},"sections":[],"references":{"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"type":"link","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","title":"Orange theme","titleInlineContent":[{"type":"text","text":"Orange theme"}],"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/"},"doc://OUDSThemesInverse/documentation/OUDSThemesInverse":{"type":"topic","abstract":[{"type":"text","text":"This theme overrides the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange theme"}]},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"title":"OUDSThemesInverse","url":"\/documentation\/oudsthemesinverse","role":"collection","identifier":"doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse","kind":"symbol"},"doc://OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"abstract":[{"type":"text","text":"This is an override of the default basic "},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":" with some inverted colors."},{"type":"text","text":" "},{"type":"text","text":"It can overrides any properties from its superclass, but is not derivable."}],"kind":"symbol","title":"InverseTheme","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"InverseTheme"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InverseTheme"}],"url":"\/documentation\/oudsthemesinverse\/inversetheme","identifier":"doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"}}}