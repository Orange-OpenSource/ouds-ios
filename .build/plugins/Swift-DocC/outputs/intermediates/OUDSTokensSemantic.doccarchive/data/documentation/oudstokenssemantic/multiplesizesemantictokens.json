rsion as it is less error-prone."],"type":"codeListing"},{"name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"style":"note","type":"aside"}]}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleSizeSemanticTokens","kind":"identifier"}],"navigatorTitle":[{"text":"MultipleSizeSemanticTokens","kind":"identifier"}],"modules":[{"name":"OUDSTokensSemantic"}],"symbolKind":"class","role":"symbol","externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleSizeSemanticTokens","title":"MultipleSizeSemanticTokens","roleHeading":"Class"},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticTokens"},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(cs)NSObject"],"title":"Inherits From","type":"inheritsFrom"},{"kind":"relationships","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(pl)NSObject","doc:\/\/OUDSTokensSemantic\/s7CVarArgP","doc:\/\/OUDSTokensSemantic\/s28CustomDebugStringConvertibleP","doc:\/\/OUDSTokensSemantic\/s23CustomStringConvertibleP","doc:\/\/OUDSTokensSemantic\/SQ","doc:\/\/OUDSTokensSemantic\/SH","doc:\/\/OUDSTokensSemantic\/s8SendableP"],"title":"Conforms To","type":"conformsTo"}],"references":{"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic","type":"topic","role":"collection","title":"OUDSTokensSemantic","url":"\/documentation\/oudstokenssemantic","kind":"symbol","abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" can be used mainly for "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" to apply some style and configuration values ; today "},{"type":"em