iteRawToken","kind":"identifier"}],"role":"symbol","type":"topic","abstract":[{"type":"text","text":"In the "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" global design system, composite tokens are defined for font-related things."},{"type":"text","text":" "},{"type":"text","text":"Composite tokens are tokens defined in "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here a "},{"inlineContent":[{"text":"font","type":"text"}],"type":"emphasis"},{"type":"text","text":" thing is caracterized by a "},{"inlineContent":[{"text":"font size","type":"text"}],"type":"emphasis"},{"type":"text","text":", a "},{"inlineContent":[{"type":"text","text":"line height"}],"type":"emphasis"},{"type":"text","text":", a "},{"inlineContent":[{"text":"font weight","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"letter spacing"}],"type":"emphasis"},{"type":"text","text":" values."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":", and together define a "},{"inlineContent":[{"type":"text","text":"composite raw token"}],"type":"emphasis"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"font"}],"type":"emphasis"},{"type":"text","text":" thing."}],"title":"FontCompositeRawToken","url":"\/documentation\/oudstokensraw\/fontcompositerawtoken","kind":"symbol"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleFontCompositeRawTokens":{"kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens","navigatorTitle":[{"kind":"identifier","text":"MultipleFontCompositeRawTokens"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontCompositeRawTokens"}],"abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"code":"FontCompositeRawToken","type":"codeVoice"},{"type":"text","text":" depending to size classes."},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a font token exists with its value depending to the size class, it must be packed in such "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens"},{"type":"text","text":"."}],"title":"MultipleFontCompositeRawTokens"}}}