sSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens","navigatorTitle":[{"kind":"identifier","text":"MultipleFontCompositeRawTokens"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontCompositeRawTokens"}],"abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"code":"FontCompositeRawToken","type":"codeVoice"},{"type":"text","text":" depending to size classes."},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a font token exists with its value depending to the size class, it must be packed in such "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens"},{"type":"text","text":"."}],"title":"MultipleFontCompositeRawTokens"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/FontCompositeSemanticTokens/typeCodeSmall":{"abstract":[],"role":"symbol","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontCompositeSemanticTokens\/typeCodeSmall","kind":"symbol","type":"topic","title":"typeCodeSmall","url":"\/documentation\/oudstokenssemantic\/fontcompositesemantictokens\/typecodesmall","required":true,"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"typeCodeSmall","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@M@OUDSTokensSemantic@objc(cs)MultipleFontCompositeRawTokens","text":"MultipleFontCompositeRawTokens","kind":"typeIdentifier"}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/FontSemanticTokens":{"type":"topic","title":"FontSemanticTokens","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FontSemanticTokens","kind":"identifier"}],"abstract":[{"type":"text","text":"This is a group of semantic tokens for "},{"type":"strong","inlineContent":[{"type":"text","text":"font"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It defines all font semantic tokens a theme must have"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontFamilySemanticToken","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontWeightSemanticToken","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontSizeSemanticToken","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontLineHeightSemanticToken","isActive":true},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"However the composite tokens (here the ones gathering each type of semantic token here) are defined in "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontCompositeSemanticTokens","isActive":true},{"type":"text","text":" because the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokenator"}]},{"type":"text","text":" "},{"type":"text","text":"is not able to generate them yet, and they must be defined elsewhere to not be deleted."},{"type":"text","text":" "},{"type":"text","text":"Any font semantic token must be declared there (except "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontCompositeSemanticTokens","isActive":true},{"type":"text","text":")."}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontSemanticTokens","navigatorTitle":[{"text":"FontSemanticTokens","kind":"identifier"}],"role":"symbol","kind":"symbol","url":"\/documentation\/oudstokenssemantic\/fontsemantictokens"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/FontCompositeSemanticTokens":{"url":"\/documentation\/oudstokenssemantic\/fontcompositesemantictokens","kind":"symbol","type":"topic","title":"FontCompositeSemanticTokens","abstract":[{"type":"text","text":"This is a group of semantic tokens for "},{"type":"strong","inlineContent":[{"type":"text","text":"fonts"}]},{"type":"text","text":", but only "},{"type":"strong","inlineContent":[{"text":"composite tokens","type":"text"}]},{"type":"text","text":" in the end."},{"type":"text","text":" "},{"type":"text","text":"There are splitted and not declared in "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontSemanticTokens","isActive":true},{"type":"text","text":" as the "},{"type":"emphasis","inlineContent":[{"text":"tokenator","type":"text"}]},{"type":"text","text":" tool parsing "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" JSON to Swift code is not able to manage them."},{"type":"text","text":" "},{"type":"text","text":"Thus we need to declare them in another file to prevent them to be erased."}],"navigatorTitle":[{"kind":"identifier","text":"FontCompositeSemanticTokens"}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontCompositeSemanticTokens","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"FontCompositeSemanticTokens"}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic","type":"topic","role":"collection","title":