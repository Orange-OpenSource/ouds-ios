hout having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDS\/documentation\/OUDS\/OUDSTheme","isActive":true,"type":"reference"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"role":"symbol","kind":"symbol"}}}