que value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen value through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"url":"\/documentation\/oudscomponents\/oudsradiopicker","role":"symbol","type":"topic"},"https://unified-design-system.orange.com/472794e18/p/90c467-radio-button":{"title":"unified-design-system.orange.com","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button","titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button","type":"link"}}}