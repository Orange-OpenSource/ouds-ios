{"relationshipsSections":[{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:label:additionalLabel:helper:icon:flipIcon:isOutlined:isReversed:isError:isReadOnly:hasDivider:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:tag:label:additionalLabel:helper:icon:flipIcon:isOutlined:isReversed:isError:isReadOnly:hasDivider:action:)"],"generated":true,"title":"Initializers"},{"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/body"],"generated":true,"title":"Instance Properties"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations"],"generated":true,"title":"Default Implementations"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},"kind":"symbol","metadata":{"externalID":"s:14OUDSComponents13OUDSRadioItemV","navigatorTitle":[{"text":"OUDSRadioItem","kind":"identifier"}],"symbolKind":"struct","role":"symbol","roleHeading":"Structure","modules":[{"name":"OUDSComponents"}],"title":"OUDSRadioItem","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsradioitem"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"text":" proposes layouts to add in your views some radios components.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a radio with only an indicator, prefer instead ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio"},{"text":".","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Tag","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Tag","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Hashable","preciseIdentifier":"s:SH","kind":"typeIdentifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Layouts","level":2,"anchor":"Layouts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"reversed","type":"text"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"text":" layout but with a trailing radio indicator and a leading optional decorative icon","type":"text"}]}]}]},{"type":"heading","text":"Indicator states","level":2,"anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The radio indicator has two available states:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"type":"text","text":": the radio is filled with a filled circle, the user has made the action to select the radio"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"text":": the radio is empty, does not contain anything, the user has made the action to unselect or did not select yet the radio","type":"text"}]}]}]},{"type":"heading","text":"Generic typed","level":2,"anchor":"Generic-typed"},{"type":"paragraph","inlineContent":[{"text":"The radio button can be associated to a specifc type for its ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"tag"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Indeed a radio button alone with this layout is not that much usefull, and should be associated to a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tag","type":"text"}]},{"text":" which will permit a ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"to provide the selected value for a group of radio buttons.","type":"text"}]},{"level":2,"type":"heading","anchor":"Particular-cases","text":"Particular cases"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"},{"text":" ","type":"text"},{"text":"The radio can be also outlined in some cases.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Accessibility-considerations","text":"Accessibility considerations","type":"heading"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom radio trait."}],"type":"paragraph"},{"level":2,"anchor":"Forbidden-by-design","text":"Forbidden by design","type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}],"type":"paragraph"},{"level":2,"anchor":"Code-samples","text":"Code samples","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":"can be used outside a dedicated picker, thus it does not need any tag and associated type."}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A leading radio with a label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\")","","    \/\/ A leading radio with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\", isReadOnly: true)","","    \/\/ A leading radio with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\", helper: \"The Beatles\")","","    \/\/ A leading radio with an additional label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\", additionalLabel: \"The Beatles\", helper: \"1967\")","","    \/\/ A trailing radio with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The reversed layout will be used here.","    OUDSRadioItem(isOn: $selection,","                  label: \"Rescue from this world!\",","                  helper: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isReversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ A leading radio with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Rescue from this world!\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related radio as it will crash","    \/\/ This is forbidden by design!","    OUDSRadioItem(isOn: $selection, label: \"Kaboom!\", isError: true).disabled(true) \/\/ fatal error","    OUDSRadioItem(isOn: $selection, label: \"Kaboom!\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing"},{"inlineContent":[{"text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSRadioItem(isOn: $selection,","                  labelText: \"Cocorico !\",","                  icon: Image(systemName: \"figure.handball\"),","                  flipIcon: layoutDirection == .rightToLeft,","                  isInversed: layoutDirection == .rightToLeft)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"However if the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" should be used inside a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker"},{"type":"text","text":" for example, it must contain a tag and an associated type."},{"type":"text","text":" "},{"type":"text","text":"The tag will be the value returned by the picked, and must be an "},{"code":"Hashable","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["    OUDSRadioItem<String>(isOn: $selection,","                          tag: \"Choice_1\",","                          label: \"Virgin Holy Lava\",","                          additionalLabel: \"Very spicy\",","                          helper: \"No alcohol, only tasty flavors\",","                          icon: Image(systemName: \"flame\")"],"type":"codeListing"},{"level":2,"anchor":"Design-documentation","text":"Design documentation","type":"heading"},{"inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"0.12.0","type":"text"}]}],"name":"Since","style":"note","type":"aside"}],"kind":"content"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem/init(isOn:tag:label:additionalLabel:helper:icon:flipIcon:isOutlined:isReversed:isError:isReadOnly:hasDivider:action:)":{"title":"init(isOn:tag:label:additionalLabel:helper:icon:flipIcon:isOutlined:isReversed:isError:isReadOnly:hasDivider:action:)","kind":"symbol","abstract":[{"type":"text","text":"Creates a radio with label and optional helper text, icon, divider."},{"type":"text","text":" "},{"text":"Supposed to be integrated inside a ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","isActive":true,"type":"reference"},{"text":".","type":"text"}],"url":"\/documentation\/oudscomponents\/oudsradioitem\/init(ison:tag:label:additionallabel:helper:icon:flipicon:isoutlined:isreversed:iserror:isreadonly:hasdivider:action:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:tag:label:additionalLabel:helper:icon:flipIcon:isOutlined:isReversed:isError:isReadOnly:hasDivider:action:)","type":"topic","role":"symbol","fragments":[{"k