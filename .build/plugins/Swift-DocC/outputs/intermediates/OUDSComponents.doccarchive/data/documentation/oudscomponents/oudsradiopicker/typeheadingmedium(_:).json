:"OUDSRadioPicker"}],"url":"\/documentation\/oudscomponents\/oudsradiopicker","abstract":[{"type":"text","text":"A picker allowing to expose several radio buttons and choose only one within the others."},{"type":"text","text":" "},{"type":"text","text":"Each radio button contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen value through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSRadioPicker"}],"kind":"symbol","title":"OUDSRadioPicker","type":"topic"},"doc://OUDS/documentation/OUDS/OUDSTheme":{"identifier":"doc:\/\/OUDS\/documentation\/OUDS\/OUDSTheme","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"title":"OUDSTheme","url":"\/documentation\/ouds\/oudstheme","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDS\/documentation\/OUDS\/OUDSTheme","isActive":true,"type":"reference"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"role":"symbol","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem":{"role":"symbol","kind":"symbol","url":"\/documentation\/oudscomponents\/oudsradioitem","navigatorTitle":[{"text":"OUDSRadioItem","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" proposes layouts to add in your views some radios components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a radio with only an indicator, prefer instead "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio"},{"type":"text","text":"."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"topic","title":"OUDSRadioItem"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioPicker/typeHeadingMedium(_:)":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{