{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"kind":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" proposes layouts to add in your views some checkboxes components with labels and icons."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with only an indicator prefer instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}]}]},{"kind":"content","content":[{"type":"heading","text":"Layouts","anchor":"Layouts","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"reversed","type":"text"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}]}]}]},{"type":"heading","text":"Indicator states","anchor":"Indicator-states","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"If you are looking for a checkbox component with three states, use instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"heading","text":"Particular cases","anchor":"Particular-cases","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In addition, the "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."}]},{"type":"paragraph","inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}]},{"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"}]},{"type":"heading","text":"Forbidden by design","anchor":"Forbidden-by-design","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}]},{"type":"heading","text":"Code samples","anchor":"Code-samples","level":2},{"type":"codeListing","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Bazinga!\", helper: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(isOn: $isOn,","                     label: \"We live in a fabled world\",","                     helper: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):"}]},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(isOn: $selection,","                     labelText: \"Cocorico !\",","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"type":"heading","text":"Design documentation","anchor":"Design-documentation","level":2},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","isActive":true}]},{"style":"note","type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"]}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To"}],"sections":[],"topicSections":[{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:label:helper:icon:flipIcon:isReversed:isError:isReadOnly:hasDivider:)"],"title":"Initializers"},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"],"title":"Instance Properties"},{"generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"],"title":"Default Implementations"}],"metadata":{"navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"externalID":"s:14OUDSComponents16OUDSCheckboxItemV","symbolKind":"struct","modules":[{"name":"OUDSComponents"}],"roleHeading":"Structure","fragments":[{"kind":"keyword",