{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"modules":[{"name":"OUDSComponents"}],"roleHeading":"Article","role":"article","title":"Layouts"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/layouts"]}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"level":3,"text":"Colored Surface","anchor":"Colored-Surface","type":"heading"},{"inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":") are automatically adjusted if they are placed on "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Mono"}]},{"type":"text","text":" suffix (for instance "},{"type":"emphasis","inlineContent":[{"text":"buttonColorBgDefaultEnabledMono","type":"text"}]},{"type":"text","text":" of "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}]},{"type":"text","text":")."}],"type":"paragraph"},{"level":4,"text":"How it works","anchor":"How-it-works","type":"heading"},{"inlineContent":[{"type":"text","text":"According to the color, the "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"oudsUseMonochrome","type":"codeVoice"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":4,"text":"How to use","anchor":"How-to-use","type":"heading"},{"code":["    \/\/ The folowing view has a colored background \"modeOnStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.modeOnStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .oudsForegroundColor(theme.colors.colorContentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .oudsForegroundColor(theme.colors.colorContentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .oudsColoredSurface(theme.colorModes.modeOnStatusPositiveEmphasized)"],"syntax":"swift","type":"codeListing"},{"level":3,"text":"Divider","anchor":"Divider","type":"heading"},{"level":4,"text":"How it works","anchor":"How-it-works","type":"heading"},{"inlineContent":[{"text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" To separate elements stacked vertivally (VStask)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"OUDSVerticalDivider"},{"type":"text","text":" To separate elements stacked Horizontally (HStask)."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"type":"codeVoice","code":"OUDSDividerColor"},{"type":"text","text":"."}],"type":"paragraph"},{"level":4,"text":"How to use","anchor":"How-to-use","type":"heading"},{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello wolrd!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello wolrd!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts"},"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"layouts"}]},{"type":"text","text":"."}],"kind":"article","references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"navigatorTitle":[{"kind":"identifier","text":"OUDSButton"}],"title":"OUDSButton","role":"symbol","url":"\/documentation\/oudscomponents\/oudsbutton","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" proposes layout with text only, icon only or text with icon."}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":" proposes layout with text only or text with icon."},{"type":"text","text":" "},{"type":"text","text":"It also proposes layout to navigate forward or backward. The link can be displayed in "},{"type":"codeVoice","code":"small"},{"type":"text","text":" or "},{"type":"codeVoice","code":"default"},{"type":"text","text":" size."}],"title":"OUDSLink","url":"\/documentation\/oudscomponents\/oudslink","navigatorTitle":[{"kind":"identifier","text":"OUDSLink"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSLink"}],"kind":"symbol","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"abstract":[{"type":"text","text":"Used to define if a content is used on a colored surface."}],"kind":"symbol","role":"symbol","url":"\/documentation\/oudscomponents\/oudscoloredsurface","navigatorTitle":[{"kind":"identifier","text":"OUDSColoredSurface"}],"title":"OUDSColoredSurface","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSColoredSurface"}],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","role":"collection","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"title":"OUDSComponents"}}}