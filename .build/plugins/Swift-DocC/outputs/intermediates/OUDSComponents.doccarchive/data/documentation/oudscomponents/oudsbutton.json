{"schemaVersion":{"major":0,"minor":3,"patch":0},"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"text":" proposes layout with text only, icon only or text with icon.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbutton"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"Hierarchies","text":"Hierarchies"},{"type":"paragraph","inlineContent":[{"text":"Four hierarchies are proposed for all layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default (by default)"}],"type":"strong"},{"text":": Default buttons are used for actions which are not mandatory or essential for the user.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"strong"}],"type":"strong"},{"text":": The Strong “call for action” on the page should be singular and prominent, limited to one per view.","type":"text"},{"text":" ","type":"text"},{"text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"minimal","type":"text"}]},{"type":"text","text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"negative"}],"type":"strong"},{"text":": Negative buttons should be used sparingly to warn of a destructive action,","type":"text"},{"text":" ","type":"text"},{"text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog.","type":"text"},{"text":" ","type":"text"},{"text":"A button with ","type":"text"},{"type":"codeVoice","code":"OUDSButton.Hierarchy.Negative"},{"text":" hierarchy is not allowed as a direct or indirect child of an ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":".","type":"text"}]}]}]},{"type":"heading","level":2,"anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Icon only with default hierarchy","    OUDSButton(icon: Image(\"ic_heart\"), hierarchy: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\")) { \/* the action to process *\/ }","","    \/\/ Text only with negative hierarchy","    OUDSButton(text: \"Delete\", hierarchy: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", hierarchy: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong hierarchy","    OUDSButton(icon: Image(\"ic_heart\"), text: \"Validate\", hierarchy: .strong) { \/* the action to process *\/ }"]},{"type":"heading","level":2,"anchor":"Styles","text":"Styles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two style are available:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default (by default)","type":"text"}]},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for following states disabled, pressed, hovered or normal (i.e. enabled)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"loading"}]},{"text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data.","type":"text"}]}]}]},{"type":"heading","level":2,"anchor":"Colored-Surface","text":"Colored Surface"},{"type":"paragraph","inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Remark: Today it is not allowed to place a Negative button on a colored surface.","type":"text"}],"type":"strong"}]},{"type":"heading","level":2,"anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/48a788-button"}]},{"type":"aside","name":"Since","style":"note","content":[{"inlineContent":[{"type":"text","text":"0.10.0"}],"type":"paragraph"}]}],"kind":"content"}],"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"symbolKind":"struct","modules":[{"name":"OUDSComponents"}],"roleHeading":"Structure","navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"title":"OUDSButton","externalID":"s:14OUDSComponents10OUDSButtonV","role":"symbol"},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:hierarchy:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/ini