ElevationCompositeRawToken","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationCompositeRawToken"}],"abstract":[{"text":"In the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"text":" global design system, composite tokens are defined for elevation effects.","type":"text"},{"text":" ","type":"text"},{"text":"Composite tokens are tokens defined in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"text":" by other tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Here an ","type":"text"},{"inlineContent":[{"text":"elevation","type":"text"}],"type":"emphasis"},{"text":" is caracterized by ","type":"text"},{"inlineContent":[{"type":"text","text":"X and Y offsets"}],"type":"emphasis"},{"text":", a ","type":"text"},{"inlineContent":[{"text":"radius","type":"text"}],"type":"emphasis"},{"type":"text","text":" for the shadow and a "},{"type":"emphasis","inlineContent":[{"text":"color","type":"text"}]},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":", and together define a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite raw token"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation"}]},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"code":"final class","type":"codeVoice"},{"type":"text","text":" and "},{"code":"NSObject","type":"codeVoice"},{"type":"text","text":" so as to be shared through "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" with extensions and protocols within modules."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"ElevationCompositeRawToken"}],"role":"symbol"},"doc://OUDSTokens