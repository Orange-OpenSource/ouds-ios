,{"type":"emphasis","inlineContent":[{"text":"elevations","type":"text"}]},{"type":"text","text":" , i.e. in the end box shadow effects."},{"type":"text","text":" "},{"type":"text","text":"These tokens are used to define these effects thanks to several types: the "},{"type":"emphasis","inlineContent":[{"text":"blur","type":"text"}]},{"type":"text","text":", the "},{"type":"emphasis","inlineContent":[{"text":"X offset","type":"text"}]},{"type":"text","text":" and the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Y offset"}]},{"type":"text","text":", all of them being "},{"type":"reference","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawToken","isActive":true},{"type":"text","text":" type."},{"type":"text","text":" "},{"type":"text","text":"Combinations of these three values can be defined inside "},{"type":"reference","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","isActive":true},{"type":"text","text":" i.e. "},{"type":"emphasis","inlineContent":[{"text":"composite tokens","type":"text"}]},{"type":"text","text":" defining a whil box shadow to use for elevation effect."}]},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationRawTokens/elevationBottom_4_300":{"type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"elevationBottom_4_300"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@M@OUDSTokensRaw@objc(cs)ElevationCompositeRawToken","text":"ElevationCompositeRawToken"}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawTokens\/elevationBottom_4_300","url":"\/documentation\/oudstokensraw\/elevationrawtokens\/elevationbottom_4_300","abstract":[],"title":"elevationBottom_4_300","kind":"symbol","role":"symbol"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationRawToken":{"type":"topic"