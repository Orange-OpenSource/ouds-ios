e theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","kind":"symbol","type":"topic","title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeCheckboxComponentTokensProvider":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeCheckboxComponentTokensProvider","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of checkbox"}]},{"type":"text","text":" for  "},{"type":"emphasis","inlineContent":[{"text":"checkboxes","type":"text"}]},{"type":"text","text":" objects"},{"type":"text","text":" "},{"type":"text","text":"like "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllCheckboxComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide all tokens to the users."},{"type":"text","text":" "},{"type":"text","text":"It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeCheckboxComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"CheckboxComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"checkboxes","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Checkboxes","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"SizeSemanticToken"},{"type":"text","text":") and"},{"type":"text","text":" "},{"type":"text","text":"borders ("},{"type":"codeVoice","code":"BorderRadiusSemanticToken"},{"type":"text","text":", "},{"type":"codeVoice","code":"BorderWidthSemanticToken"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"These components share the same type of tokens which are all gather edhere."}],"title":"OrangeThemeCheckboxComponentTokensProvider","type":"topic","navigatorTitle":[{"text":"OrangeThemeCheckboxComponentTokensProvider","kind":"identifier"}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemecheckboxcomponenttokensprovider","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeCheckboxComponentTokensProvider","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeCheckboxComponentTokensProvider/checkboxSizeIndicator":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"checkboxSizeIndicator"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","text":"SizeSemanticToken"}],"type":"topic","title":"checkboxSizeIndicator","abstract