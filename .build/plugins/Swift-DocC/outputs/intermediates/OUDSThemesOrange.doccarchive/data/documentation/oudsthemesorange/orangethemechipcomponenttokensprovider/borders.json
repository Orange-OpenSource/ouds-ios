ts also the protocol "},{"type":"codeVoice","code":"ChipComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"chip","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Chip"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") , spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and border  (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeChipComponentTokensProvider"}],"role":"symbol"},"doc://OUDS/documentation/OUDS/AllBorderSemanticTokensProvider":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AllBorderSemanticTokensProvider"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:4OUDS14TokensProviderP","kind":"typeIdentifier","text":"TokensProvider"},{"kind":"text","text":", "},{"preciseIdentifier":"s:18OUDSTokensSemantic06BorderB6TokensP","kind":"typeIdentifier","text":"BorderSemanticTokens"}],"identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllBorderSemanticTokensProvider","type":"topic","abstract":[{"text":"Something which provides all semantic tokens of border","type":"text"}],"title":"AllBorderSemanticTokensProvider","url":"\/documentation\/ouds\/allbordersemantictoke