xt","text":" "},{"type":"emphasis","inlineContent":[{"text":"Checkboxes","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"SizeSemanticToken"},{"type":"text","text":") and"},{"type":"text","text":" "},{"type":"text","text":"borders ("},{"type":"codeVoice","code":"BorderRadiusSemanticToken"},{"type":"text","text":", "},{"type":"codeVoice","code":"BorderWidthSemanticToken"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"These components share the same type of tokens which are all gather edhere."}],"title":"OrangeThemeCheckboxComponentTokensProvider","type":"topic","navigatorTitle":[{"text":"OrangeThemeCheckboxComponentTokensProvider","kind":"identifier"}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemecheckboxcomponenttokensprovider","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeCheckboxComponentTokensProvider","kind":"identifier"}]}}}