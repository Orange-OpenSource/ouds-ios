chComponentTokensProvider/switchBorderRadius":{"title":"switchBorderRadius","url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/switchborderradius","abstract":[],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/switchBorderRadius","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"switchBorderRadius"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"BorderRadiusSemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic012BorderRadiusB5Tokena"}],"kind":"symbol","role":"symbol","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/switchColorTrackSelected":{"kind":"symbol","type":"topic","title":"switchColorTrackSelected","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"switchColorTrackSelected","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MultipleColorSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticTokens"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/switchColorTrackSelected","abstract":[],"url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/switchcolortrackselected"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/switchColorCursor":{"kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/switchcolorcursor","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/switchColorCursor","abstract":[],"role":"symbol","title":"switchColorCursor","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"switchColorCursor","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MultipleColorSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticTokens"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider":{"role":"symbol","abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component  tokens of switch"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"switch \/ toggle"}],"type":"emphasis"},{"type":"text","text":" objects like "},{"code":"OUDSSwitch","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllSwitchComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"SwitchComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"switch \/ toggle","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Switch","type":"text"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpacesSemanticTokensProvider"},{"type":"text","text":") , sizes ("},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":") and opacities ("},{"type":"codeVoice","code":"AllOpacitiySemanticTokensProvider"},{"type":"text","text":")."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","type":"topic","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider","title":"OrangeThemeSwitchComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeSwitchComponentTokensProvider"}],"navigatorTitle":[{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}]}}}