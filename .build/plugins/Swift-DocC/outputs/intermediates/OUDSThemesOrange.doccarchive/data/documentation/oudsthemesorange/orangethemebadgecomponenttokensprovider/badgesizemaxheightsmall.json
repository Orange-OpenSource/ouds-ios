ode":"DimensionRawToken"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"and sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")."}],"title":"OrangeThemeBadgeComponentTokensProvider","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeBadgeComponentTokensProvider"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeBadgeComponentTokensProvider"}],"role":"symbol","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBadgeComponentTokensProvider/badgeSizeMaxHeightSmall":{"title":"badgeSizeMaxHeightSmall","kind":"symbol","type":"topic","role":"symbol","abstract":[],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"badgeSizeMaxHeightSmall"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"SizeSemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena"}],"url":"\/documentation\/oudsthemesorange\/orangethemebadgecomponenttokensprovider\/badgesizemaxheightsmall","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider\/badgeSizeMaxHeightSmall"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","kind":"symbol","type":"topic","title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange"}}}