{"metadata":{"title":"spaces","externalID":"s:16OUDSThemesOrange0B36ThemeListItemComponentTokensProviderC6spaces4OUDS016AllSpaceSemanticgH0_pvp","modules":[{"name":"OUDSThemesOrange"}],"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"spaces"},{"kind":"text","text":": any "},{"preciseIdentifier":"s:4OUDS30AllSpaceSemanticTokensProviderP","kind":"typeIdentifier","text":"AllSpaceSemanticTokensProvider"}],"symbolKind":"property","role":"symbol","roleHeading":"Instance Property"},"abstract":[{"text":"Provider of spaces semantic tokens to use for button spaces","type":"text"}],"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider\/spaces","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider\/spaces"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spaces","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllSpaceSemanticTokensProvider","kind":"typeIdentifier","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllSpaceSemanticTokensProvider","preciseIdentifier":"s:4OUDS30AllSpaceSemanticTokensProviderP"}],"platforms":["macOS"],"languages":["swift"]}]}],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeListItemComponentTokensProvider":{"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeListItemComponentTokensProvider"}],"type":"topic","title":"OrangeThemeListItemComponentTokensProvider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of list item"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"list item"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSListItem"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllListItemComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ListItemComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"list item"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"List item"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpacesSemanticTokensProvider"},{"type":"text","text":") and sizes ("},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeListItemComponentTokensProvider"}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider","kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeListItemComponentTokensProvider/spaces":{"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"spaces"},{"kind":"text","text":": any "},{"preciseIdentifier":"s:4OUDS30AllSpaceSemanticTokensProviderP","kind":"typeIdentifier","text":"AllSpaceSemanticTokensProvider"}],"url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider\/spaces","role":"symbol","type":"topic","title":"spaces","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider\/spaces","abstract":[{"text":"Provider of spaces semantic tokens to use for button spaces","type":"text"}],"kind":"symbol"},"doc://OUDS/documentation/OUDS/AllSpaceSemanticTokensProvider":{"identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllSpaceSemanticTokensProvider","abstract":[{"text":"Something which provides all semantic tokens of space","type":"text"}],"title":"AllSpaceSemanticTokensProvider","kind":"symbol","url":"\/documentation\/ouds\/allspacesemantictokensprovider","type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AllSpaceSemanticTokensProvider"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"TokensProvider","preciseIdentifier":"s:4OUDS14TokensProviderP"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"SpaceMultipleSemanticTokens","preciseIdentifier":"s:18OUDSTokensSemantic013SpaceMultipleB6TokensP"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"SpaceSemanticTokens","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB6TokensP"}],"role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","role":"collection","kind":"symbol","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"type":"topic"}}}