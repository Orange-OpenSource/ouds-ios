{"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"abstract":[{"text":"This is an override of the default basic ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"code":"InverseTheme","type":"codeVoice"},{"text":" inherits from this ","type":"text"},{"code":"OrangeTheme","type":"codeVoice"},{"text":".","type":"text"}],"seeAlsoSections":[{"title":"Group","generated":true,"anchor":"Group","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens"]}],"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:elevations:fonts:grids:opacities:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:inputText:listItem:link:radioButton:select:skeleton:switch:tag:fontFamily:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"To use this theme, inject it to your view using ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" and get it through environment variable.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    import OUDS                 \/\/ To get OUDSThemeableView","    import OUDSThemeOrange      \/\/ To get OrangeTheme","    import SwiftUI","","    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"For example:"}]},{"syntax":"swift","type":"codeListing","code":["","   \/\/ Use some already defined providers","   let borders = OrangeThemeBorderSemanticTokensProvider()","   let sizes = OrangeThemeSizeSemanticTokensProvider()","   let spaces = OrangeThemeSpaceSemanticTokensProvider()","","   \/\/ For example, use your own provider of color semantic tokens","   \/\/ It must inherit from OrangeThemeBorderSemanticTokensProvider (which is instance of AllColorSemanticTokensProvider) or directly implement AllColorSemanticTokensProvider","   let colors = YourOwnColorSemanticTokensProvider()","","   \/\/ Some providers need other providers to use their tokens","   let button = OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces)","","   \/\/ But you can also use the providers as they are without assigning semantic tokens providers","   \/\/ and just use the default ones","   let badge = OrangeThemeBadgeComponentTokensProvider()","","   \/\/ Define in the end your theme by overriding some providers.","   \/\/ YOu can override all providers, or only some, or just keep the theme as is.","   let yourOwnOrangeTheme = OrangeTheme(colors: colors, borders: borders, sizes: sizes, spaces: spaces, button: button, badge: badge)",""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then get it:"}]},{"syntax":"swift","type":"codeListing","code":["    import OUDS","","    @Environment(\\.theme) var theme"]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}],"name":"Since"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangetheme"]}],"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"title":"OrangeTheme","symbolKind":"class","externalID":"s:16OUDSThemesOrange0B5ThemeC","modules":[{"name":"OUDSThemesOrange"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"roleHeading":"Class"},"sections":[],"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/OUDS\/documentation\/OUDS\/OUDSTheme"]},{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSThemesOrange\/s8SendableP"]}],"references":{"doc://OUDSThemesOrange/s8SendableP":{"title":"Swift.Sendable","identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP","type":"unresolvable"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"abstract":[{"text":"This enum helps to add new ","type":"text"},{"inlineContent":[{"text":"color raw tokens","type":"text"}],"type":"strong"},{"text":" exclusive to this ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"inlineContent":[{"text":"Swift enum","type":"text"}],"type":"emphasis"},{"text":" so as to g