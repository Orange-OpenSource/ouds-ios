ifier":"s:4OUDS32AllSwitchComponentTokensProviderP"},{"text":")?, ","kind":"text"},{"text":"tag","kind":"externalParam"},{"text":": (any ","kind":"text"},{"text":"AllTagComponentTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:4OUDS29AllTagComponentTokensProviderP"},{"text":")?, ","kind":"text"},{"text":"fontFamily","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FontFamilySemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena"},{"text":"?)","kind":"text"}],"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:elevations:fonts:grids:opacities:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:inputText:listItem:link:radioButton:select:skeleton:switch:tag:fontFamily:)","title":"init(borders:colors:colorModes:elevations:fonts:grids:opacities:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:inputText:listItem:link:radioButton:select:skeleton:switch:tag:fontFamily:)","url":"\/documentation\/oudsthemesorange\/orangetheme\/init(borders:colors:colormodes:elevations:fonts:grids:opacities:sizes:spaces:badge:bulletlist:button:checkbox:chip:controlitem:divider:inputtext:listitem:link:radiobutton:select:skeleton:switch:tag:fontfamily:)","abstract":[{"type":"text","text":"Constructor of the Orange theme."},{"type":"text","text":" "},{"type":"text","text":"It needs several tokens providers for semantic tokens and component tokens."},{"type":"text","text":" "},{"type":"text","text":"If a nil token provider is given, the default version associated fo the theme is used."}],"role":"symbol","kind":"symbol"},"doc://OUDS/documentation/OUDS/OUDSTheme":{"identifier":"doc:\/\/OUDS\/documentation\/OUDS\/OUDSTheme","title":"OUDSTheme","url":"\/documentation\/ouds\/oudstheme","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"type":"topic","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}]},"doc://OUDSThemesOrange/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"type":"topic","abstract":[{"text":"This enum helps to add new ","type":"text"},{"inlineContent":[{"type":"text","text":"color raw tokens"}],"type":"strong"},{"text":" exclusive to this ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift enum"}],"type":"emphasis"},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"text":"(i.e. publicly accessible from everywhere). More optimized than ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"struct","type":"text"}]},{"type":"text","text":"."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeBrandColorRawTokens"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","title":"OrangeBrandColorRawTokens","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrandColorRawTokens"}]}}}