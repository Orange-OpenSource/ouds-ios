{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"abstract":[{"type":"text","text":"This is an override of the default basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It can override any properties from its superclass, and can be derived too."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"InverseTheme"},{"type":"text","text":" inherits from this "},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":"."}],"metadata":{"title":"OrangeTheme","symbolKind":"class","roleHeading":"Class","role":"symbol","externalID":"s:16OUDSThemesOrange0B5ThemeC","modules":[{"name":"OUDSThemesOrange"}],"navigatorTitle":[{"text":"OrangeTheme","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","title":"Inherits From","identifiers":["doc:\/\/OUDS\/documentation\/OUDS\/OUDSTheme"]},{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSThemesOrange\/s8SendableP"]}],"seeAlsoSections":[{"anchor":"Group","title":"Group","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" and get it through environment variable."}],"type":"paragraph"},{"syntax":"swift","code":["    import OUDS                 \/\/ To get OUDSThemeableView","    import OUDSThemeOrange      \/\/ To get OrangeTheme","    import SwiftUI","","    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"For example:"}],"type":"paragraph"},{"syntax":"swift","code":["","   \/\/ Use some already defined providers","   let borders = OrangeThemeBorderSemanticTokensProvider()","   let sizes = OrangeThemeSizeSemanticTokensProvider()","   let spaces = OrangeThemeSpaceSemanticTokensProvider()","","   \/\/ For example, use your own provider of color semantic tokens","   \/\/ It must inherit from OrangeThemeBorderSemanticTokensProvider (which is instance of AllColorSemanticTokensProvider) or directly implement AllColorSemanticTokensProvider","   let colors = YourOwnColorSemanticTokensProvider()","","   \/\/ Some providers need other providers to use their tokens","   let button = OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces)","","   \/\/ But you can also use the providers as they are without assigning semantic tokens providers","   \/\/ and just use the default ones","   let badge = OrangeThemeBadgeComponentTokensProvider()","","   \/\/ Define in the end your theme by overriding some providers.","   \/\/ YOu can override all providers, or only some, or just keep the theme as is.","   let yourOwnOrangeTheme = OrangeTheme(colors: colors, borders: borders, sizes: sizes, spaces: spaces, button: button, badge: badge)",""],"type":"codeListing"},{"inlineContent":[{"text":"Then get it:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    import OUDS","","    @Environment(\\.theme) var theme"],"type":"codeListing"},{"name":"Since","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"type":"aside"}]}],"topicSections":[{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:elevations:fonts:grids:opacities:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:inputText:listItem:link:radioButton:select:skeleton:switch:tag:fontFamily:)"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangetheme"]}],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"abstract":[{"text":"This is an override of the default basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"type":"codeVoice","code":"InverseTheme"},{"text":" inherits from this ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"text":".","type":"text"}],"fragments":[{"text":"class",