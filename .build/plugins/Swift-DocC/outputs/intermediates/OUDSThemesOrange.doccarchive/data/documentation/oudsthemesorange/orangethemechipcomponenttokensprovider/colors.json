{"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider"]]},"metadata":{"symbolKind":"property","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"colors"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP","text":"AllColorSemanticTokensProvider"}],"role":"symbol","roleHeading":"Instance Property","externalID":"s:16OUDSThemesOrange0B32ThemeChipComponentTokensProviderC6colors4OUDS016AllColorSemanticfG0_pvp","title":"colors","modules":[{"name":"OUDSThemesOrange"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"colors"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllColorSemanticTokensProvider","text":"AllColorSemanticTokensProvider","preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP"}],"platforms":["macOS"],"languages":["swift"]}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider\/colors"]}],"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider\/colors","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"type":"text","text":"Provider of color semantic tokens to use for chip colors"}],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeChipComponentTokensProvider/colors":{"abstract":[{"type":"text","text":"Provider of color semantic tokens to use for chip colors"}],"title":"colors","url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider\/colors","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider\/colors","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"colors"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","text":"AllColorSemanticTokensProvider","preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","kind":"symbol","type":"topic","title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeChipComponentTokensProvider":{"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeChipComponentTokensProvider"}],"type":"topic","title":"OrangeThemeChipComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of chip"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"text":"chip","type":"text"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSChip"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllChipComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ChipComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"chip","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Chip"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") , spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and border  (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeChipComponentTokensProvider"}],"role":"symbol"},"doc://OUDS/documentation/OUDS/AllColorSemanticTokensProvider":{"url":"\/documentation\/ouds\/allcolorsemantictokensprovider","type":"topic","title":"AllColorSemanticTokensProvider","kind":"symbol","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllColorSemanticTokensProvider","abstract":[{"type":"text","text":"Something which provides all semantic tokens of colors"}],"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"AllColorSemanticTokensProvider","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:4OUDS14TokensProviderP","text":"TokensProvider","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic013ColorMultipleB6TokensP","text":"ColorMultipleSemanticTokens","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic05ColorB6TokensP","text":"ColorSemanticTokens","kind":"typeIdentifier"}]}}}