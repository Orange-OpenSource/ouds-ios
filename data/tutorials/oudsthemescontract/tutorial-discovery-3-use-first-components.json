{"hierarchy":{"modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"}]}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)"},"sections":[{"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}]}],"projectFiles":"OUDS-Discovery-Tutorial.zip","chapter":"Use of first components provided by OUDS","kind":"hero","estimatedTimeInMinutes":30,"xcodeRequirement":"Xcode 26.4","backgroundImage":"ic_component_intro.png","image":"ic_component_intro.png","title":"Use your first OUDS components"},{"tasks":[{"stepsSection":[{"code":"tutorial-discovery-3-1.swift","type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"First, prepare the ","type":"text"},{"type":"codeVoice","code":"ContentView"},{"text":" by adding inside it a ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":".","type":"text"}]}],"caption":[],"media":null,"runtimePreview":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Now, let’s add radio buttons to let the user choose its gender.","type":"text"},{"text":" ","type":"text"},{"text":"The official components are ","type":"text"},{"type":"codeVoice","code":"OUDSRadio"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSRadioItem"},{"text":", but the package has also a ","type":"text"},{"type":"codeVoice","code":"OUDSRadioPicker"},{"text":" to implement quicky a group of radios.","type":"text"},{"text":" ","type":"text"},{"text":"This component can be replaced by your own.","type":"text"},{"text":" ","type":"text"},{"text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an ","type":"text"},{"type":"codeVoice","code":"Hashable"},{"text":" thing shared through a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Inside a picker the user can select only one value, not zero.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add such picker with three items inside."}]}],"media":null,"code":"tutorial-discovery-3-2.swift","runtimePreview":"tutorial-discovery-3-2.png"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"code":"OUDSCheckbox","type":"codeVoice"},{"text":" which is a simple checkbox, and ","type":"text"},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"type":"codeVoice","code":"State"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In some cases you may need to use "},{"type":"codeVoice","code":"OUDSCheckboxIndeterminate"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSCheckboxItemIndeterminate"},{"type":"text","text":" if you want a three-states checkbox."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add a checkbox item with only two states.","type":"text"}]}],"media":null,"code":"tutorial-discovery-3-3.swift","runtimePreview":"tutorial-discovery-3-3.png"},{"runtimePreview":"tutorial-discovery-3-4.png","code":"tutorial-discovery-3-4.swift","content":[{"type":"paragraph","inlineContent":[{"text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical.","type":"text"},{"text":" ","type":"text"},{"text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not.","type":"text"}]}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Choose to add an instance of "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"text":".","type":"text"}]}],"media":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone (","type":"text"},{"code":"OUDSSwitch","type":"codeVoice"},{"text":") or with texts (","type":"text"},{"code":"OUDSSwitchItem","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"Just like the checkbox, the switch exposes its state through a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations.","type":"text"},{"text":" ","type":"text"},{"text":"You will then be able to see the automatic changes of colors when you switch the color scheme.","type":"text"}]}],"media":null,"code":"tutorial-discovery-3-5.swift","runtimePreview":"tutorial-discovery-3-5.png"},{"caption":[{"inlineContent":[{"text":"Add an ","type":"text"},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" in the app and make it open the iOS documentation OUDS website."}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the "},{"type":"codeVoice","code":"OUDSLink"},{"text":" component can be integrated. It can be only with a text or also a chevron indicator.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-3-6.swift","runtimePreview":"tutorial-discovery-3-6.png","media":null,"type":"step"},{"type":"step","content":[{"inlineContent":[{"text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand.","type":"text"},{"text":" ","type":"text"},{"text":"You can find it with the ","type":"text"},{"code":"OUDSButton","type":"codeVoice"},{"text":". Such button has an appearance changing its colors, and also a style (loading or not).","type":"text"},{"text":" ","type":"text"},{"text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed.","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds.","type":"text"}],"type":"paragraph"}],"media":null,"code":"tutorial-discovery-3-7.swift","runtimePreview":"tutorial-discovery-3-7.png"}],"anchor":"Add-basic-components","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"We will work on a kind of formular using main OUDS components.","type":"text"},{"text":" ","type":"text"},{"text":"Feel free to style and design things as you want.","type":"text"}]}]}],"title":"Add basic components"}],"kind":"tasks"},{"assessments":[{"title":[{"inlineContent":[{"text":"Does the developer using OUDS component need to manage the look and feel of the components?","type":"text"}],"type":"paragraph"}],"content":[],"choices":[{"isCorrect":false,"content":[{"inlineContent":[{"text":"Yes","type":"text"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases.","type":"text"}],"type":"paragraph"}]},{"isCorrect":true,"content":[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"That is the reason why the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" is so important: it injects the theme as environment variable so that any component can get it to define its style.","type":"text"}],"type":"paragraph"}]}],"type":"multiple-choice"}],"anchor":"Check-Your-Understanding","kind":"assessments"},{"featuredEyebrow":"Tutorial","action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","type":"reference","isActive":true},"kind":"callToAction","title":"Add more OUDS components","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}]}],"metadata":{"category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)","title":"Use your first OUDS components","role":"project"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"},"kind":"project","references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Want-to-be-an-artist":{"abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"title":"Want to be an artist?","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","type":"section","kind":"section"},"ic_component_intro.png":{"type":"image","identifier":"ic_component_intro.png","variants":[{"url":"\/images\/OUDSThemesContract\/ic_component_intro.png","traits":["1x","light"]}],"alt":"OUDS components logo"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Add-basic-components":{"abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"title":"Add basic components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Add-basic-components","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components","type":"section","kind":"section"},"Xcode 26.4":{"type":"xcodeRequirement","identifier":"Xcode 26.4","title":"Xcode 26.4","url":"https:\/\/developer.apple.com\/download\/"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Check-Your-Understanding":{"type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"title":"Check Your Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Import-of-the-Swift-Package-and-choose-its-librairies":{"abstract":[],"title":"Import of the Swift Package and choose its librairies","url":"\/tutorials\/table-of-contents-(discovery)\/import-of-the-swift-package-and-choose-its-librairies","role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","type":"topic","kind":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Check-Your-Understanding":{"type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"title":"Check Your Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding":{"title":"Check Your Understanding","type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding"},"tutorial-discovery-3-5.png":{"type":"image","identifier":"tutorial-discovery-3-5.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-5.png"}],"alt":"A radio picker, an horizontal divider, a checkbox item and a switch item"},"OUDS-Discovery-Tutorial.zip":{"type":"download","identifier":"OUDS-Discovery-Tutorial.zip","checksum":"7523223957580058fdd46ea5746a632dd1535930af99d24fc734aa73e2561dc038051975e28002a208604e799deb7346bcc95b3a1c6e7fe8f032f439fef38bf1","url":"\/downloads\/OUDSThemesContract\/OUDS-Discovery-Tutorial.zip"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components":{"abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"title":"Use your first OUDS components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components","estimatedTime":"30min","role":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","type":"topic","kind":"project"},"tutorial-discovery-3-2.swift":{"fileName":"Content.swift","syntax":"swift","fileType":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","","    var body: some View {","        OUDSRadioPicker(selection: $selectedGender,","                        radios: genderRadioValues(),","                        placement: .horizontal(false))","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"identifier":"tutorial-discovery-3-2.swift","highlights":[],"type":"file"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Use-of-first-components-provided-by-OUDS":{"kind":"article","title":"Use of first components provided by OUDS","url":"\/tutorials\/table-of-contents-(discovery)\/use-of-first-components-provided-by-ouds","role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","type":"topic","abstract":[]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components":{"title":"Add more OUDS components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","kind":"project","role":"project","estimatedTime":"30min","type":"topic","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components"},"tutorial-discovery-3-1.swift":{"fileName":"Tutorial.swift","syntax":"swift","fileType":"swift","content":["import OUDSSwiftUI","import SwiftUI","","\/\/ MARK: - App","","@main","struct OUDSTutorialSandboxApp: App {","    ","    let myTheme = OrangeTheme()","    ","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: myTheme) {","                ContentView()","            }","        }","    }","}","","\/\/ MARK: - Tutorial Content View","","struct ContentView: View {","    ","    var body: some View {","        ScrollView {","            Text(\"Hello OUDSThemesContract!\")","        }","    }"],"identifier":"tutorial-discovery-3-1.swift","highlights":[{"line":25},{"line":26},{"line":27}],"type":"file"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Typography,-view-modifiers-and-tokens":{"abstract":[],"title":"Typography, view modifiers and tokens","url":"\/tutorials\/table-of-contents-(discovery)\/typography,-view-modifiers-and-tokens","role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","type":"topic","kind":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app":{"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","title":"Basic structure for the app","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"text":" ","type":"text"},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Use-of-view-modifiers":{"title":"Use of view modifiers","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","kind":"section","role":"pseudoSymbol","type":"section","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Check-Your-Understanding":{"title":"Check Your Understanding","type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding"},"tutorial-discovery-3-6.swift":{"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"syntax":"swift","highlights":[{"line":23},{"line":24},{"line":36},{"line":37},{"line":38},{"line":39}],"fileType":"swift","type":"file","fileName":"Content.swift","identifier":"tutorial-discovery-3-6.swift"},"tutorial-discovery-3-7.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-7.png"}],"type":"image","alt":"A radio picker, an horizontal divider, a checkbox item, a switch item, a link and a button","identifier":"tutorial-discovery-3-7.png"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding":{"title":"Check Your Understanding","type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme":{"abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"estimatedTime":"15min","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme","role":"project","title":"Instanciate and inject a theme"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"text":" ","type":"text"},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"text":" ","type":"text"},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","type":"secti