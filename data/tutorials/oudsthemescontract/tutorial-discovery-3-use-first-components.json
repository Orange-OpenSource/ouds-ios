{"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components"]}],"kind":"project","metadata":{"role":"project","categoryPathComponent":"Table-Of-Contents-(discovery)","title":"Use your first OUDS components","category":"Orange Unified Design System"},"sections":[{"projectFiles":"OUDS-Discovery-Tutorial.zip","xcodeRequirement":"Xcode 26.3","estimatedTimeInMinutes":30,"image":"ic_component_intro.png","backgroundImage":"ic_component_intro.png","chapter":"Use of first components provided by OUDS","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}]}],"title":"Use your first OUDS components","kind":"hero"},{"tasks":[{"title":"Add basic components","contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"type":"text","text":" "},{"type":"text","text":"Feel free to style and design things as you want."}],"type":"paragraph"}],"kind":"contentAndMedia"}],"anchor":"Add-basic-components","stepsSection":[{"runtimePreview":null,"type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"First, prepare the "},{"code":"ContentView","type":"codeVoice"},{"type":"text","text":" by adding inside it a "},{"code":"ScrollView","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"code":"tutorial-discovery-3-1.swift","caption":[]},{"runtimePreview":"tutorial-discovery-3-2.png","type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"Now, let’s add radio buttons to let the user choose its gender."},{"type":"text","text":" "},{"type":"text","text":"The official components are "},{"code":"OUDSRadio","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSRadioItem","type":"codeVoice"},{"type":"text","text":", but the package has also a "},{"code":"OUDSRadioPicker","type":"codeVoice"},{"type":"text","text":" to implement quicky a group of radios."},{"type":"text","text":" "},{"type":"text","text":"This component can be replaced by your own."},{"type":"text","text":" "},{"type":"text","text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an "},{"code":"Hashable","type":"codeVoice"},{"type":"text","text":" thing shared through a "},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Inside a picker the user can select only one value, not zero."}],"type":"paragraph"}],"code":"tutorial-discovery-3-2.swift","caption":[{"inlineContent":[{"type":"text","text":"Add such picker with three items inside."}],"type":"paragraph"}]},{"runtimePreview":"tutorial-discovery-3-3.png","type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"code":"OUDSCheckbox","type":"codeVoice"},{"type":"text","text":" which is a simple checkbox, and "},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"code":"State","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In some cases you may need to use "},{"code":"OUDSCheckboxIndeterminate","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSCheckboxItemIndeterminate","type":"codeVoice"},{"type":"text","text":" if you want a three-states checkbox."}],"type":"paragraph"}],"code":"tutorial-discovery-3-3.swift","caption":[{"inlineContent":[{"text":"Add a checkbox item with only two states.","type":"text"}],"type":"paragraph"}]},{"runtimePreview":"tutorial-discovery-3-4.png","type":"step","media":null,"content":[{"inlineContent":[{"text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical.","type":"text"},{"text":" ","type":"text"},{"text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-3-4.swift","caption":[{"inlineContent":[{"text":"Choose to add an instance of ","type":"text"},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"text":".","type":"text"}],"type":"paragraph"}]},{"runtimePreview":"tutorial-discovery-3-5.png","type":"step","media":null,"content":[{"inlineContent":[{"text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone (","type":"text"},{"type":"codeVoice","code":"OUDSSwitch"},{"text":") or with texts (","type":"text"},{"type":"codeVoice","code":"OUDSSwitchItem"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"Just like the checkbox, the switch exposes its state through a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-3-5.swift","caption":[{"inlineContent":[{"text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations.","type":"text"},{"text":" ","type":"text"},{"text":"You will then be able to see the automatic changes of colors when you switch the color scheme.","type":"text"}],"type":"paragraph"}]},{"runtimePreview":"tutorial-discovery-3-6.png","type":"step","media":null,"content":[{"inlineContent":[{"text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the ","type":"text"},{"type":"codeVoice","code":"OUDSLink"},{"text":" component can be integrated. It can be only with a text or also a chevron indicator.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-3-6.swift","caption":[{"inlineContent":[{"text":"Add an ","type":"text"},{"type":"codeVoice","code":"OUDSLink"},{"text":" in the app and make it open the iOS documentation OUDS website.","type":"text"}],"type":"paragraph"}]},{"runtimePreview":"tutorial-discovery-3-7.png","type":"step","media":null,"content":[{"inlineContent":[{"text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand.","type":"text"},{"text":" ","type":"text"},{"text":"You can find it with the ","type":"text"},{"type":"codeVoice","code":"OUDSButton"},{"text":". Such button has an appearance changing its colors, and also a style (loading or not).","type":"text"},{"text":" ","type":"text"},{"text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-3-7.swift","caption":[{"inlineContent":[{"text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds.","type":"text"}],"type":"paragraph"}]}]}],"kind":"tasks"},{"anchor":"Check-Your-Understanding","assessments":[{"title":[{"type":"paragraph","inlineContent":[{"text":"Does the developer using OUDS component need to manage the look and feel of the components?","type":"text"}]}],"choices":[{"justification":[{"inlineContent":[{"text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases.","type":"text"}],"type":"paragraph"}],"isCorrect":false,"content":[{"inlineContent":[{"text":"Yes","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"That is the reason why the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" is so important: it injects the theme as environment variable so that any component can get it to define its style.","type":"text"}]}],"isCorrect":true}],"type":"multiple-choice","content":[]}],"kind":"assessments"},{"abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"action":{"overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"isActive":true,"type":"reference"},"kind":"callToAction","title":"Add more OUDS components","featuredEyebrow":"Tutorial"}],"hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"}]},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","kind":"assessment"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","kind":"assessment"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","kind":"assessment"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"}]}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"]]},"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Use-of-view-modifiers":{"role":"pseudoSymbol","title":"Use of view modifiers","kind":"section","type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}]},"tutorial-discovery-3-3.swift":{"fileName":"Content.swift","highlights":[{"line":20},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29}],"fileType":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"syntax":"swift","type":"file","identifier":"tutorial-discovery-3-3.swift"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","type":"section","title":"Import the Swift Package and the libraries","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"text":" ","type":"text"},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Add-basic-components":{"kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","type":"section","title":"Add basic components","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Add-basic-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Add-basic-components":{"role":"pseudoSymbol","title":"Add basic components","kind":"section","type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Add-basic-components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme":{"role":"project","title":"Instanciate and inject a theme","kind":"project","type":"topic","estimatedTime":"15min","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}]},"ic_component_intro.png":{"alt":"OUDS components logo","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_component_intro.png"}],"type":"image","identifier":"ic_component_intro.png"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Use-of-first-components-provided-by-OUDS":{"kind":"article","role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","type":"topic","title":"Use of first components provided by OUDS","abstract":[],"url":"\/tutorials\/table-of-contents-(discovery)\/use-of-first-components-provided-by-ouds"},"tutorial-discovery-3-4.swift":{"fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-4.swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[{"line":28},{"line":29}]},"tutorial-discovery-3-2.png":{"alt":"A radio picker","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-2.png"}],"type":"image","identifier":"tutorial-discovery-3-2.png"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"title":"Going further with more resources","type":"topic","kind":"project","abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}],"role":"project","estimatedTime":"10min","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Use-of-tokens":{"kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens","type":"section","title":"Use of tokens","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Use-of-tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"type":"link","title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"type":"link","title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Go-further-with-more-ressources":{"role":"article","title":"Go further with more ressources","kind":"article","type":"topic","url":"\/tutorials\/table-of-contents-(discovery)\/go-further-with-more-ressources","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","abstract":[]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link","title":"Check Your Understanding"},"tutorial-discovery-3-3.png":{"alt":"A radio picker and a checkbox item","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-3.png","traits":["1x","light"]}],"type":"image","identifier":"tutorial-discovery-3-3.png"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Import-of-the-Swift-Package-and-choose-its-librairies":{"role":"article","title":"Import of the Swift Package and choose its librairies","kind":"article","type":"topic","url":"\/tutorials\/table-of-contents-(discovery)\/import-of-the-swift-package-and-choose-its-librairies","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","abstract":[]},"tutorial-discovery-3-5.swift":{"syntax":"swift","fileType":"swift","type":"file","identifier":"tutorial-discovery-3-5.swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[{"line":21},{"line":32},{"line":33},{"line":34}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app":{"kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","type":"section","title":"Basic structure for the app","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things":{"role":"project","title":"Styling things","kind":"project","type":"topic","estimatedTime":"30min","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","abstract":[{"text":"Even if compo