{"hierarchy":{"modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources","kind":"task"}]}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"]]},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"Use your first OUDS components","categoryPathComponent":"Table-Of-Contents-(discovery)","role":"project","category":"Orange Unified Design System"},"sections":[{"content":[{"inlineContent":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}],"type":"paragraph"}],"image":"ic_component_intro.png","kind":"hero","xcodeRequirement":"Xcode 26.3","estimatedTimeInMinutes":30,"title":"Use your first OUDS components","chapter":"Use of first components provided by OUDS","projectFiles":"OUDS-Discovery-Tutorial.zip","backgroundImage":"ic_component_intro.png"},{"tasks":[{"stepsSection":[{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"First, prepare the ","type":"text"},{"code":"ContentView","type":"codeVoice"},{"text":" by adding inside it a ","type":"text"},{"code":"ScrollView","type":"codeVoice"},{"text":".","type":"text"}]}],"caption":[],"code":"tutorial-discovery-3-1.swift","runtimePreview":null,"media":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Now, let’s add radio buttons to let the user choose its gender.","type":"text"},{"text":" ","type":"text"},{"text":"The official components are ","type":"text"},{"code":"OUDSRadio","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSRadioItem","type":"codeVoice"},{"text":", but the package has also a ","type":"text"},{"code":"OUDSRadioPicker","type":"codeVoice"},{"text":" to implement quicky a group of radios.","type":"text"},{"text":" ","type":"text"},{"text":"This component can be replaced by your own.","type":"text"},{"text":" ","type":"text"},{"text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":" thing shared through a ","type":"text"},{"code":"Binding","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Inside a picker the user can select only one value, not zero.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add such picker with three items inside.","type":"text"}]}],"code":"tutorial-discovery-3-2.swift","runtimePreview":"tutorial-discovery-3-2.png","media":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: ","type":"text"},{"code":"OUDSCheckbox","type":"codeVoice"},{"text":" which is a simple checkbox, and ","type":"text"},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"text":" which is a checkbox (duh!) with additional texts and icons.","type":"text"},{"text":" ","type":"text"},{"text":"The state of the checkbox is shared through a boolean ","type":"text"},{"code":"State","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In some cases you may need to use ","type":"text"},{"code":"OUDSCheckboxIndeterminate","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSCheckboxItemIndeterminate","type":"codeVoice"},{"text":" if you want a three-states checkbox.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add a checkbox item with only two states.","type":"text"}]}],"code":"tutorial-discovery-3-3.swift","runtimePreview":"tutorial-discovery-3-3.png","media":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical.","type":"text"},{"text":" ","type":"text"},{"text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Choose to add an instance of ","type":"text"},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"text":".","type":"text"}]}],"code":"tutorial-discovery-3-4.swift","runtimePreview":"tutorial-discovery-3-4.png","media":null},{"code":"tutorial-discovery-3-5.swift","runtimePreview":"tutorial-discovery-3-5.png","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone ("},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":") or with texts ("},{"type":"codeVoice","code":"OUDSSwitchItem"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"Just like the checkbox, the switch exposes its state through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."}]}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations."},{"type":"text","text":" "},{"type":"text","text":"You will then be able to see the automatic changes of colors when you switch the color scheme."}]}]},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the ","type":"text"},{"code":"OUDSLink","type":"codeVoice"},{"text":" component can be integrated. It can be only with a text or also a chevron indicator.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add an ","type":"text"},{"code":"OUDSLink","type":"codeVoice"},{"text":" in the app and make it open the iOS documentation OUDS website.","type":"text"}]}],"code":"tutorial-discovery-3-6.swift","runtimePreview":"tutorial-discovery-3-6.png","media":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand.","type":"text"},{"text":" ","type":"text"},{"text":"You can find it with the ","type":"text"},{"code":"OUDSButton","type":"codeVoice"},{"text":". Such button has an appearance changing its colors, and also a style (loading or not).","type":"text"},{"text":" ","type":"text"},{"text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds."}]}],"code":"tutorial-discovery-3-7.swift","runtimePreview":"tutorial-discovery-3-7.png","media":null}],"title":"Add basic components","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"We will work on a kind of formular using main OUDS components.","type":"text"},{"text":" ","type":"text"},{"text":"Feel free to style and design things as you want.","type":"text"}]}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"anchor":"Add-basic-components"}],"kind":"tasks"},{"anchor":"Check-Your-Understanding","assessments":[{"content":[],"title":[{"type":"paragraph","inlineContent":[{"text":"Does the developer using OUDS component need to manage the look and feel of the components?","type":"text"}]}],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"That is the reason why the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}]}]}],"type":"multiple-choice"}],"kind":"assessments"},{"title":"Add more OUDS components","featuredEyebrow":"Tutorial","action":{"overridingTitle":"Get started","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference"},"abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"kind":"callToAction"}],"kind":"project","references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Check-Your-Understanding":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"title":"Check Your Understanding","type":"link"},"ic_component_intro.png":{"alt":"OUDS components logo","variants":[{"url":"\/images\/OUDSThemesContract\/ic_component_intro.png","traits":["1x","light"]}],"type":"image","identifier":"ic_component_intro.png"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Use-of-first-components-provided-by-OUDS":{"role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","type":"topic","abstract":[],"kind":"article","url":"\/tutorials\/table-of-contents-(discovery)\/use-of-first-components-provided-by-ouds","title":"Use of first components provided by OUDS"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Final-result":{"abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"type":"section","kind":"section","title":"Final result","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Final-result"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Preparation-of-the-theme":{"role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","abstract":[],"type":"topic","kind":"article","url":"\/tutorials\/table-of-contents-(discovery)\/preparation-of-the-theme","title":"Preparation of the theme"},"tutorial-discovery-3-3.png":{"identifier":"tutorial-discovery-3-3.png","alt":"A radio picker and a checkbox item","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-3.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Add-basic-components":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Add-basic-components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components","role":"pseudoSymbol","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"title":"Add basic components","kind":"section","type":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Use-of-view-modifiers":{"abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"type":"section","kind":"section","title":"Use of view modifiers","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Want-to-be-an-artist":{"role":"pseudoSymbol","type":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","title":"Want to be an artist?"},"tutorial-discovery-3-3.swift":{"fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileType":"swift","type":"file","identifier":"tutorial-discovery-3-3.swift","syntax":"swift","highlights":[{"line":20},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"type":"section","kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","title":"Import the Swift Package and the libraries"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components":{"abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"type":"topic","kind":"project","estimatedTime":"30min","title":"Add more OUDS components","role":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Add-basic-components":{"abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"type":"section","kind":"section","title":"Add basic components","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Add-basic-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme":{"abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"type":"topic","kind":"project","estimatedTime":"15min","title":"Instanciate and inject a theme","role":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme"},"tutorial-discovery-3-5.swift":{"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileName":"Content.swift","fileType":"swift","type":"file","identifier":"tutorial-discovery-3-5.swift","syntax":"swift","highlights":[{"line":21},{"line":32},{"line":33},{"line":34}]},"tutorial-discovery-3-2.swift":{"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","","    var body: some View {","        OUDSRadioPicker(selection: $selectedGender,","                        radios: genderRadioValues(),","                        placement: .horizontal(false))","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileName":"Content.swift","fileType":"swift","type":"file","identifier":"tutorial-discovery-3-2.swift","syntax":"swift","highlights":[]},"OUDS-Discovery-Tutorial.zip":{"identifier":"OUDS-Discovery-Tutorial.zip","url":"\/downloads\/OUDSThemesContract\/OUDS-Discovery-Tutorial.zip","checksum":"6cbe692f20ec50d6df4e53413a1e7e2692771bf4a7d05fe9486a4702ec9b0ef870e479060bba30047b0c26700df37dd8e5db8ed499e88670fcaa801d9e477a8f","type":"download"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Typography,-view-modifiers-and-tokens":{"role":"article","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","kind":"article","abstract":[],"url":"\/tutorials\/table-of-contents-(discovery)\/typography,-view-modifiers-and-tokens","title":"Typography, view modifiers and tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app":{"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"type":"section","kind":"section","title":"Basic structure for the app","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app"},"Xcode 26.3":{"identifier":"Xcode 26.3","url":"https:\/\/developer.apple.com\/download\/","title":"Xcode 26.3","type":"xcodeRequirement"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components":{"abstract":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"topic","kind":"project","estimatedTime":"30min","title":"Use your first OUDS components","role":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components"},"tutorial-discovery-3-1.swift":{"content":["import OUDSSwiftUI","import SwiftUI","","\/\/ MARK: - App","","@main","struct OUDSTutorialSandboxApp: App {","    ","    let myTheme = OrangeTheme()","    ","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme