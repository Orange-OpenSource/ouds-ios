{"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"},"hierarchy":{"modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"}]}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)"},"kind":"project","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components"]}],"sections":[{"content":[{"inlineContent":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"paragraph"}],"title":"Use your first OUDS components","image":"ic_component_intro.png","projectFiles":"OUDS-Discovery-Tutorial.zip","xcodeRequirement":"Xcode 26.4","backgroundImage":"ic_component_intro.png","chapter":"Use of first components provided by OUDS","estimatedTimeInMinutes":30,"kind":"hero"},{"kind":"tasks","tasks":[{"anchor":"Add-basic-components","title":"Add basic components","stepsSection":[{"type":"step","runtimePreview":null,"media":null,"content":[{"inlineContent":[{"text":"First, prepare the ","type":"text"},{"code":"ContentView","type":"codeVoice"},{"text":" by adding inside it a ","type":"text"},{"code":"ScrollView","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[],"code":"tutorial-discovery-3-1.swift"},{"runtimePreview":"tutorial-discovery-3-2.png","code":"tutorial-discovery-3-2.swift","type":"step","content":[{"inlineContent":[{"text":"Now, let’s add radio buttons to let the user choose its gender.","type":"text"},{"text":" ","type":"text"},{"text":"The official components are ","type":"text"},{"type":"codeVoice","code":"OUDSRadio"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSRadioItem"},{"text":", but the package has also a ","type":"text"},{"type":"codeVoice","code":"OUDSRadioPicker"},{"text":" to implement quicky a group of radios.","type":"text"},{"text":" ","type":"text"},{"text":"This component can be replaced by your own.","type":"text"},{"text":" ","type":"text"},{"text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":" thing shared through a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Inside a picker the user can select only one value, not zero.","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"text":"Add such picker with three items inside.","type":"text"}],"type":"paragraph"}],"media":null},{"content":[{"inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" which is a simple checkbox, and "},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"text":" which is a checkbox (duh!) with additional texts and icons.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"code":"State","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In some cases you may need to use ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxIndeterminate"},{"type":"text","text":" and "},{"code":"OUDSCheckboxItemIndeterminate","type":"codeVoice"},{"text":" if you want a three-states checkbox.","type":"text"}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-3.png","code":"tutorial-discovery-3-3.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a checkbox item with only two states."}]}],"media":null},{"caption":[{"inlineContent":[{"text":"Choose to add an instance of ","type":"text"},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}]}],"code":"tutorial-discovery-3-4.swift","runtimePreview":"tutorial-discovery-3-4.png"},{"type":"step","code":"tutorial-discovery-3-5.swift","content":[{"inlineContent":[{"type":"text","text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone ("},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":") or with texts ("},{"type":"codeVoice","code":"OUDSSwitchItem"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"Just like the checkbox, the switch exposes its state through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."}],"type":"paragraph"}],"media":null,"runtimePreview":"tutorial-discovery-3-5.png","caption":[{"inlineContent":[{"type":"text","text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations."},{"type":"text","text":" "},{"type":"text","text":"You will then be able to see the automatic changes of colors when you switch the color scheme."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the "},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" component can be integrated. It can be only with a text or also a chevron indicator."}]}],"type":"step","caption":[{"inlineContent":[{"type":"text","text":"Add an "},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" in the app and make it open the iOS documentation OUDS website."}],"type":"paragraph"}],"media":null,"code":"tutorial-discovery-3-6.swift","runtimePreview":"tutorial-discovery-3-6.png"},{"code":"tutorial-discovery-3-7.swift","runtimePreview":"tutorial-discovery-3-7.png","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand."},{"type":"text","text":" "},{"type":"text","text":"You can find it with the "},{"type":"codeVoice","code":"OUDSButton"},{"type":"text","text":". Such button has an appearance changing its colors, and also a style (loading or not)."},{"type":"text","text":" "},{"type":"text","text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed."}]}],"caption":[{"inlineContent":[{"text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds.","type":"text"}],"type":"paragraph"}],"type":"step"}],"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"type":"text","text":" "},{"type":"text","text":"Feel free to style and design things as you want."}]}]}]}]},{"assessments":[{"content":[],"choices":[{"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases."}]}],"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}]},{"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"That is the reason why the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}],"type":"paragraph"}],"content":[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}]}],"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"text":"Does the developer using OUDS component need to manage the look and feel of the components?","type":"text"}]}]}],"anchor":"Check-Your-Understanding","kind":"assessments"},{"featuredEyebrow":"Tutorial","title":"Add more OUDS components","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"kind":"callToAction","action":{"isActive":true,"overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"}}],"metadata":{"title":"Use your first OUDS components","categoryPathComponent":"Table-Of-Contents-(discovery)","category":"Orange Unified Design System","role":"project"},"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further","type":"topic","kind":"project","title":"Going further with more resources","estimatedTime":"10min","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further","role":"project","abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Check-Your-Understanding":{"titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","type":"link","title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)":{"url":"\/tutorials\/table-of-contents-(discovery)","type":"topic","kind":"overview","title":"Swift Package Discovery Tutorial","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","role":"overview","abstract":[{"type":"text","text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package."},{"type":"text","text":" "},{"type":"text","text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework."},{"type":"text","text":" "},{"type":"text","text":"Theme, components, tokens… everything will be introduced!"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Want-to-be-an-artist":{"kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","title":"Want to be an artist?","role":"pseudoSymbol","type":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Check-Your-Understanding":{"titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"title":"Check Your Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Use-of-first-components-provided-by-OUDS":{"kind":"article","url":"\/tutorials\/table-of-contents-(discovery)\/use-of-first-components-provided-by-ouds","abstract":[],"title":"Use of first components provided by OUDS","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","role":"article","type":"topic"},"tutorial-discovery-3-1.swift":{"identifier":"tutorial-discovery-3-1.swift","fileName":"Tutorial.swift","content":["import OUDSSwiftUI","import SwiftUI","","\/\/ MARK: - App","","@main","struct OUDSTutorialSandboxApp: App {","    ","    let myTheme = OrangeTheme()","    ","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: myTheme) {","                ContentView()","            }","        }","    }","}","","\/\/ MARK: - Tutorial Content View","","struct ContentView: View {","    ","    var body: some View {","        ScrollView {","            Text(\"Hello OUDSThemesContract!\")","        }","    }"],"fileType":"swift","syntax":"swift","highlights":[{"line":25},{"line":26},{"line":27}],"type":"file"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Import-of-the-Swift-Package-and-choose-its-librairies":{"url":"\/tutorials\/table-of-contents-(discovery)\/import-of-the-swift-package-and-choose-its-librairies","type":"topic","kind":"article","title":"Import of the Swift Package and choose its librairies","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","role":"article","abstract":[]},"Xcode 26.4":{"identifier":"Xcode 26.4","url":"https:\/\/developer.apple.com\/download\/","title":"Xcode 26.4","type":"xcodeRequirement"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Use-of-view-modifiers":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","title":"Use of view modifiers","role":"pseudoSymbol","type":"section"},"tutorial-discovery-3-4.swift":{"fileType":"swift","highlights":[{"line":28},{"line":29}],"type":"file","syntax":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"identifier":"tutorial-discovery-3-4.swift","fileName":"Content.swift"},"ic_component_intro.png":{"alt":"OUDS components logo","type":"image","identifier":"ic_component_intro.png","variants":[{"url":"\/images\/OUDSThemesContract\/ic_component_intro.png","traits":["1x","light"]}]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Typography,-view-modifiers-and-tokens":{"url":"\/tutorials\/table-of-contents-(discovery)\/typography,-view-modifiers-and-tokens","type":"topic","kind":"article","title":"Typography, view modifiers and tokens","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","role":"article","abstract":[]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","title":"Import the Swift Package and the libraries","role":"pseudoSymbol","type":"section"},"tutorial-discovery-3-2.swift":{"fileName":"Content.swift","fileType":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","","    var body: some View {","        OUDSRadioPicker(selection: $selectedGender,","                        radios: genderRadioValues(),","                        placement: .horizontal(false))","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"type":"file","highlights":[],"syntax":"swift","identifier":"tutorial-discovery-3-2.swift"},"tutorial-discovery-3-3.png":{"identifier":"tutorial-discovery-3-3.png","alt":"A radio picker and a checkbox item","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-3.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Final-result":{"kind":"section","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Final-result","iden