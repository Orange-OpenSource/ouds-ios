{"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","interfaceLanguage":"swift"},"sections":[{"chapter":"Use of first components provided by OUDS","estimatedTimeInMinutes":30,"image":"ic_component_intro.png","backgroundImage":"ic_component_intro.png","projectFiles":"OUDS-Discovery-Tutorial.zip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}]}],"title":"Use your first OUDS components","xcodeRequirement":"Xcode 26.4","kind":"hero"},{"kind":"tasks","tasks":[{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"text":"We will work on a kind of formular using main OUDS components.","type":"text"},{"text":" ","type":"text"},{"text":"Feel free to style and design things as you want.","type":"text"}],"type":"paragraph"}]}],"title":"Add basic components","anchor":"Add-basic-components","stepsSection":[{"runtimePreview":null,"caption":[],"media":null,"type":"step","content":[{"inlineContent":[{"text":"First, prepare the ","type":"text"},{"type":"codeVoice","code":"ContentView"},{"text":" by adding inside it a ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":".","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-3-1.swift"},{"runtimePreview":"tutorial-discovery-3-2.png","caption":[{"inlineContent":[{"text":"Add such picker with three items inside.","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"text":"Now, let’s add radio buttons to let the user choose its gender.","type":"text"},{"text":" ","type":"text"},{"text":"The official components are ","type":"text"},{"type":"codeVoice","code":"OUDSRadio"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSRadioItem"},{"text":", but the package has also a ","type":"text"},{"type":"codeVoice","code":"OUDSRadioPicker"},{"text":" to implement quicky a group of radios.","type":"text"},{"text":" ","type":"text"},{"text":"This component can be replaced by your own.","type":"text"},{"text":" ","type":"text"},{"text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an ","type":"text"},{"type":"codeVoice","code":"Hashable"},{"text":" thing shared through a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Inside a picker the user can select only one value, not zero.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-3-2.swift"},{"runtimePreview":"tutorial-discovery-3-3.png","caption":[{"inlineContent":[{"type":"text","text":"Add a checkbox item with only two states."}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: ","type":"text"},{"type":"codeVoice","code":"OUDSCheckbox"},{"text":" which is a simple checkbox, and ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"text":" which is a checkbox (duh!) with additional texts and icons.","type":"text"},{"text":" ","type":"text"},{"text":"The state of the checkbox is shared through a boolean ","type":"text"},{"type":"codeVoice","code":"State"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In some cases you may need to use ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxIndeterminate"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxItemIndeterminate"},{"text":" if you want a three-states checkbox.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-3-3.swift"},{"runtimePreview":"tutorial-discovery-3-4.png","caption":[{"inlineContent":[{"type":"text","text":"Choose to add an instance of "},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}],"type":"paragraph"}],"code":"tutorial-discovery-3-4.swift"},{"runtimePreview":"tutorial-discovery-3-5.png","caption":[{"inlineContent":[{"type":"text","text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations."},{"type":"text","text":" "},{"type":"text","text":"You will then be able to see the automatic changes of colors when you switch the color scheme."}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone ("},{"code":"OUDSSwitch","type":"codeVoice"},{"type":"text","text":") or with texts ("},{"code":"OUDSSwitchItem","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"Just like the checkbox, the switch exposes its state through a "},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"code":"tutorial-discovery-3-5.swift"},{"runtimePreview":"tutorial-discovery-3-6.png","caption":[{"inlineContent":[{"type":"text","text":"Add an "},{"code":"OUDSLink","type":"codeVoice"},{"type":"text","text":" in the app and make it open the iOS documentation OUDS website."}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the "},{"code":"OUDSLink","type":"codeVoice"},{"type":"text","text":" component can be integrated. It can be only with a text or also a chevron indicator."}],"type":"paragraph"}],"code":"tutorial-discovery-3-6.swift"},{"runtimePreview":"tutorial-discovery-3-7.png","caption":[{"inlineContent":[{"type":"text","text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds."}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand."},{"type":"text","text":" "},{"type":"text","text":"You can find it with the "},{"code":"OUDSButton","type":"codeVoice"},{"type":"text","text":". Such button has an appearance changing its colors, and also a style (loading or not)."},{"type":"text","text":" "},{"type":"text","text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed."}],"type":"paragraph"}],"code":"tutorial-discovery-3-7.swift"}]}]},{"kind":"assessments","assessments":[{"type":"multiple-choice","content":[],"title":[{"inlineContent":[{"text":"Does the developer using OUDS component need to manage the look and feel of the components?","type":"text"}],"type":"paragraph"}],"choices":[{"content":[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"That is the reason why the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}],"type":"paragraph"}]}]}],"anchor":"Check-Your-Understanding"},{"kind":"callToAction","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"featuredEyebrow":"Tutorial","action":{"type":"reference","overridingTitle":"Get started","isActive":true,"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"},"title":"Add more OUDS components"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract