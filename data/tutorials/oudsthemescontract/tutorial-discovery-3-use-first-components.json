ence":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources","kind":"task"}]}]}]},"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"categoryPathComponent":"Table-Of-Contents-(discovery)","role":"project","title":"Use your first OUDS components","category":"Orange Unified Design System"},"sections":[{"image":"ic_component_intro.png","xcodeRequirement":"Xcode 26.3","backgroundImage":"ic_component_intro.png","chapter":"Use of first components provided by OUDS","kind":"hero","estimatedTimeInMinutes":30,"title":"Use your first OUDS components","projectFiles":"OUDS-Discovery-Tutorial.zip","content":[{"inlineContent":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"paragraph"}]},{"kind":"tasks","tasks":[{"anchor":"Add-basic-components","stepsSection":[{"runtimePreview":null,"type":"step","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"First, prepare the "},{"code":"ContentView","type":"codeVoice"},{"type":"text","text":" by adding inside it a "},{"code":"ScrollView","type":"codeVoice"},{"type":"text","text":"."}]}],"caption":[],"code":"tutorial-discovery-3-1.swift"},{"code":"tutorial-discovery-3-2.swift","type":"step","caption":[{"inlineContent":[{"type":"text","text":"Add such picker with three items inside."}],"type":"paragraph"}],"media":null,"runtimePreview":"tutorial-discovery-3-2.png","content":[{"inlineContent":[{"type":"text","text":"Now, let’s add radio buttons to let the user choose its gender."},{"type":"text","text":" "},{"type":"text","text":"The official components are "},{"type":"codeVoice","code":"OUDSRadio"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioItem"},{"type":"text","text":", but the package has also a "},{"type":"codeVoice","code":"OUDSRadioPicker"},{"type":"text","text":" to implement quicky a group of radios."},{"type":"text","text":" "},{"type":"text","text":"This component can be replaced by your own."},{"type":"text","text":" "},{"type":"text","text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":" thing shared through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Inside a picker the user can select only one value, not zero."}],"type":"paragraph"}]},{"code":"tutorial-discovery-3-3.swift","type":"step","caption":[{"inlineContent":[{"type":"text","text":"Add a checkbox item with only two states."}],"type":"paragraph"}],"media":null,"runtimePreview":"tutorial-discovery-3-3.png","content":[{"inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" which is a simple checkbox, and "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"type":"codeVoice","code":"State"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In some cases you may need to use "},{"type":"codeVoice","code":"OUDSCheckboxIndeterminate"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSCheckboxItemIndeterminate"},{"type":"text","text":" if you want a three-states checkbox."}],"type":"paragraph"}]},{"code":"tutorial-discovery-3-4.swift","type":"step","caption":[{"inlineContent":[{"type":"text","text":"Choose to add an instance of "},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"media":null,"runtimePreview":"tutorial-discovery-3-4.png","content":[{"inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}],"type":"paragraph"}]},{"code":"tutorial-discovery-3-5.swift","type":"step","caption":[{"inlineContent":[{"type":"text","text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations."},{"type":"text","text":" "},{"type":"text","text":"You will then be able to see the automatic changes of colors when you switch the color scheme."}],"type":"paragraph"}],"media":null,"runtimePreview":"tutorial-discovery-3-5.png","content":[{"inlineContent":[{"type":"text","text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone ("},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":") or with texts ("},{"type":"codeVoice","code":"OUDSSwitchItem"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"Just like the checkbox, the switch exposes its state through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."}],"type":"paragraph"}]},{"code":"tutorial-discovery-3-6.swift","type":"step","caption":[{"inlineContent":[{"type":"text","text":"Add an "},{"code":"OUDSLink","type":"codeVoice"},{"type":"text","text":" in the app and make it open the iOS documentation OUDS website."}],"type":"paragraph"}],"media":null,"runtimePreview":"tutorial-discovery-3-6.png","content":[{"inlineContent":[{"type":"text","text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the "},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" component can be integrated. It can be only with a text or also a chevron indicator."}],"type":"paragraph"}]},{"code":"tutorial-discovery-3-7.swift","type":"step","caption":[{"inlineContent":[{"type":"text","text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds."}],"type":"paragraph"}],"media":null,"runtimePreview":"tutorial-discovery-3-7.png","content":[{"inlineContent":[{"type":"text","text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand."},{"type":"text","text":" "},{"type":"text","text":"You can find it with the "},{"type":"codeVoice","code":"OUDSButton"},{"type":"text","text":". Such button has an appearance changing its colors, and also a style (loading or not)."},{"type":"text","text":" "},{"type":"text","text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed."}],"type":"paragraph"}]}],"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"type":"text","text":" "},{"type":"text","text":"Feel free to style and design things as you want."}],"type":"paragraph"}]}],"title":"Add basic components"}]},{"kind":"assessments","anchor":"Check-Your-Understanding","assessments":[{"content":[],"type":"multiple-choice","choices":[{"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases."}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}]},{"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"That is the reason why the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}]}],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Does the developer using OUDS component need to manage the look and feel of the components?"}]}]}]},{"kind":"callToAction","title":"Add more OUDS components","action":{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"overridingTitle":"Get started"},"featuredEyebrow":"Tutorial","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}]}],"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","interfaceLanguage":"swift"},"kind":"project","schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"tutorial-discovery-3-4.swift":{"highlights":[{"line":28},{"line":29}],"fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-4.swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme":{"kind":"project","title":"Instanciate and inject a theme","estimatedTime":"15min","role":"project","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme"},"tutorial-discovery-3-1.swift":{"highlights":[{"line":25},{"line":26},{"line":27}],"fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-1.swift","fileName":"Tutorial.swift","content":["import OUDSSwiftUI","import SwiftUI","","\/\/ MARK: - App","","@main","struct OUDSTutorialSandboxApp: App {","    ","    let myTheme = OrangeTheme()","    ","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: myTheme) {","                ContentView()","            }","        }","    }","}","","\/\/ MARK: - Tutorial Content View","","struct ContentView: View {","    ","    var body: some View {","        ScrollView {","            Text(\"Hello OUDSThemesContract!\")","        }","    }"]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies":{"abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"type":"topic","title":"Swift Package integration","kind":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","role":"project","estimatedTime":"10min"},"tutorial-discovery-3-2.swift":{"highlights":[],"fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-2.swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","","    var body: some View {","        OUDSRadioPicker(selection: $selectedGender,","                        radios: genderRadioValues(),","                        placement: .horizontal(false))","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"]},"tutorial-discovery-3-3.png":{"type":"image","identifier":"tutorial-discovery-3-3.png","alt":"A radio picker and a checkbox item","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-3.png","traits":["1x","light"]}]},"Xcode 26.3":{"url":"https:\/\/developer.apple.com\/download\/","title":"Xcode 26.3","identifier":"Xcode 26.3","type":"xcodeRequirement"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","type":"link","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","type":"link","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}],"type":"topic","title":"Going further with more resources","kind":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further","role":"project","estimatedTime":"10min"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","type":"link","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","type":"section","kind":"section","role":"pseudoSymbol","title":"Basic structure for the app","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app"},"tutorial-discovery-3-6.swift":{"highlights":[{"line":23},{"line":24},{"line":36},{"line":37},{"line":38},{"line":39}],"fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-6.swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Use-of-first-components-provided-by-OUDS":{"type":"topic","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","kind":"article","url":"\/tutorials\/table-of-contents-(discovery)\/use-of-first-components-provided-by-ouds","title":"Use of first components provided by OUDS","role":"article"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Import-of-the-Swift-Package-and-choose-its-librairies":{"url":"\/tutorials\/table-of-contents-(discovery)\/import-of-the-swift-package-and-choose-its-librairies","kind":"article","type":"topic","role":"article","title":"Import of the Swift Package and choose its librairies","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Go-further-with-more-ressources":{"abstract":[],"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","kind":"article","url":"\/tutorials\/table-of-contents-(discovery)\/go-further-with-more-ressources","title":"Go further with more ressources","role":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Add-basic-components":{"type":"section","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Add-basic-components","title":"Add 