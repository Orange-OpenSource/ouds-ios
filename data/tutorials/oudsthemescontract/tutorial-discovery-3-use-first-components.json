{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components"]}],"hierarchy":{"modules":[{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"}]},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","kind":"task"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"}]}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)"},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","interfaceLanguage":"swift"},"kind":"project","sections":[{"kind":"hero","estimatedTimeInMinutes":30,"xcodeRequirement":"Xcode 26.4","title":"Use your first OUDS components","projectFiles":"OUDS-Discovery-Tutorial.zip","backgroundImage":"ic_component_intro.png","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}]}],"image":"ic_component_intro.png","chapter":"Use of first components provided by OUDS"},{"kind":"tasks","tasks":[{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"type":"text","text":" "},{"type":"text","text":"Feel free to style and design things as you want."}]}]}],"title":"Add basic components","anchor":"Add-basic-components","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"First, prepare the "},{"type":"codeVoice","code":"ContentView"},{"type":"text","text":" by adding inside it a "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":"."}]}],"code":"tutorial-discovery-3-1.swift","media":null,"runtimePreview":null,"caption":[],"type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now, let’s add radio buttons to let the user choose its gender."},{"type":"text","text":" "},{"type":"text","text":"The official components are "},{"type":"codeVoice","code":"OUDSRadio"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioItem"},{"type":"text","text":", but the package has also a "},{"type":"codeVoice","code":"OUDSRadioPicker"},{"type":"text","text":" to implement quicky a group of radios."},{"type":"text","text":" "},{"type":"text","text":"This component can be replaced by your own."},{"type":"text","text":" "},{"type":"text","text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an "},{"code":"Hashable","type":"codeVoice"},{"type":"text","text":" thing shared through a "},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Inside a picker the user can select only one value, not zero."}]}],"code":"tutorial-discovery-3-2.swift","media":null,"runtimePreview":"tutorial-discovery-3-2.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add such picker with three items inside."}]}],"type":"step"},{"type":"step","runtimePreview":"tutorial-discovery-3-3.png","media":null,"code":"tutorial-discovery-3-3.swift","content":[{"inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" which is a simple checkbox, and "},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"type":"codeVoice","code":"State"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In some cases you may need to use "},{"code":"OUDSCheckboxIndeterminate","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSCheckboxItemIndeterminate","type":"codeVoice"},{"type":"text","text":" if you want a three-states checkbox."}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"Add a checkbox item with only two states."}],"type":"paragraph"}]},{"type":"step","runtimePreview":"tutorial-discovery-3-4.png","media":null,"code":"tutorial-discovery-3-4.swift","content":[{"inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"Choose to add an instance of "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone ("},{"code":"OUDSSwitch","type":"codeVoice"},{"type":"text","text":") or with texts ("},{"code":"OUDSSwitchItem","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"Just like the checkbox, the switch exposes its state through a "},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."}]}],"code":"tutorial-discovery-3-5.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations."},{"type":"text","text":" "},{"type":"text","text":"You will then be able to see the automatic changes of colors when you switch the color scheme."}]}],"media":null,"runtimePreview":"tutorial-discovery-3-5.png"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the "},{"code":"OUDSLink","type":"codeVoice"},{"type":"text","text":" component can be integrated. It can be only with a text or also a chevron indicator."}]}],"code":"tutorial-discovery-3-6.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add an "},{"code":"OUDSLink","type":"codeVoice"},{"type":"text","text":" in the app and make it open the iOS documentation OUDS website."}]}],"media":null,"runtimePreview":"tutorial-discovery-3-6.png"},{"type":"step","runtimePreview":"tutorial-discovery-3-7.png","media":null,"code":"tutorial-discovery-3-7.swift","content":[{"type":"paragraph","inlineContent":[{"text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand.","type":"text"},{"text":" ","type":"text"},{"text":"You can find it with the ","type":"text"},{"code":"OUDSButton","type":"codeVoice"},{"text":". Such button has an appearance changing its colors, and also a style (loading or not).","type":"text"},{"text":" ","type":"text"},{"text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds.","type":"text"}]}]}]}]},{"assessments":[{"choices":[{"justification":[{"inlineContent":[{"type":"text","text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases."}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],"isCorrect":false},{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"That is the reason why the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}]}]}],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Does the developer using OUDS component need to manage the look and feel of the components?"}]}],"content":[],"type":"multiple-choice"}],"kind":"assessments","anchor":"Check-Your-Understanding"},{"featuredEyebrow":"Tutorial","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"kind":"callToAction","title":"Add more OUDS components","action":{"isActive":true,"overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference"}}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"category":"Orange Unified Design System","role":"project","title":"Use your first OUDS components","categoryPathComponent":"Table-Of-Contents-(discovery)"},"references":{"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Go-further-with-more-ressources":{"kind":"article","title":"Go further with more ressources","role":"article","type":"topic","url":"\/tutorials\/table-of-contents-(discovery)\/go-further-with-more-ressources","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Final-result":{"title":"Final result","role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Final-result","kind":"section","type":"section","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app":{"kind":"section","title":"Basic structure for the app","role":"pseudoSymbol","type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Preparation-of-the-theme":{"title":"Preparation of the theme","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/preparation-of-the-theme","kind":"article","type":"topic","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme"},"tutorial-discovery-3-2.swift":{"fileName":"Content.swift","fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-2.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","","    var body: some View {","        OUDSRadioPicker(selection: $selectedGender,","                        radios: genderRadioValues(),","                        placement: .horizontal(false))","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Typography,-view-modifiers-and-tokens":{"title":"Typography, view modifiers and tokens","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/typography,-view-modifiers-and-tokens","kind":"article","type":"topic","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens"},"Xcode 26.4":{"url":"https:\/\/developer.apple.com\/download\/","title":"Xcode 26.4","type":"xcodeRequirement","identifier":"Xcode 26.4"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Use-of-view-modifiers":{"title":"Use of view modifiers","role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","kind":"section","type":"section","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Use-of-first-components-provided-by-OUDS":{"title":"Use of first components provided by OUDS","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/use-of-first-components-provided-by-ouds","kind":"article","type":"topic","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"},"tutorial-discovery-3-7.swift":{"fileName":"Content.swift","fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-7.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","","            OUDSButton(text: \"Create my profile\",","                       appearance: .strong,","                       style: creatingProfile ? .loading : .default)","            {","                creatingProfile = true","                DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                    creatingProfile = false","                }","            }.disabled(!termsAccepted)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[{"line":22},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further","title":"Going further with more resources","abstract":[{"text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources.","type":"text"}],"type":"topic","role":"project","kind":"project","estimatedTime":"10min"},"tutorial-discovery-3-7.png":{"alt":"A radio picker, an horizontal divider, a checkbox item, a switch item, a link and a button","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-7.png"}],"type":"image","identifier":"tutorial-discovery-3-7.png"},"tutorial-discovery-3-6.png":{"alt":"A radio picker, an horizontal divider, a checkbox item, a switch item and a link","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-6.png"}],"type":"image","identifier":"tutorial-discovery-3-6.png"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding":{"titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","title":"Check Your Understanding","type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding":{"titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","title":"Check Your Understanding","type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding"},"tutorial-discovery-3-3.png":{"alt":"A radio picker and a checkbox item","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-3.png"}],"type":"image","identifier":"tutorial-discovery-3-3.png"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","url":"\/tutorials\/table-of-contents-(discovery)","title":"Swift Package Discovery Tutorial","abstract":[{"text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package.","type":"text"},{"text":" ","type":"text"},{"text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework.","type":"text"},{"text":" ","type":"text"},{"text":"Theme, components, tokens… everything will be introduced!","type":"text"}],"type":"topic","role":"overview","kind":"overview"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Check-Your-Understanding":{"titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","title":"Check Your Understanding","type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components","title":"Use your first OUDS components","abstract":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}],"type":"topic","role":"project","kind":"project","estimatedTime":"30min"},"tutorial-discovery-3-4.png":{"alt":"A radio picker, an horizontal divider and a checkbox item","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-4.png"}],"type":"image","identifier":"tutorial-discovery-3-4.png"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Use-of-tokens":{"title":"Use of tokens","role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Use-of-tokens","kind":"section","type":"section","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things","title":"Styling things","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"type":"topic","role":"project","kind":"project","estimatedTime":"30min"},"tutorial-discovery-3-6.swift":{"fileName":"Content.swift","fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-6.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","          