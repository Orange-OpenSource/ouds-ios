{"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"}]}]},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","interfaceLanguage":"swift"},"metadata":{"category":"Orange Unified Design System","role":"project","title":"Use your first OUDS components","categoryPathComponent":"Table-Of-Contents-(discovery)"},"sections":[{"image":"ic_component_intro.png","content":[{"inlineContent":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"paragraph"}],"chapter":"Use of first components provided by OUDS","backgroundImage":"ic_component_intro.png","estimatedTimeInMinutes":30,"kind":"hero","title":"Use your first OUDS components","xcodeRequirement":"Xcode 26.4","projectFiles":"OUDS-Discovery-Tutorial.zip"},{"tasks":[{"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"First, prepare the "},{"type":"codeVoice","code":"ContentView"},{"type":"text","text":" by adding inside it a "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":"."}],"type":"paragraph"}],"media":null,"caption":[],"type":"step","code":"tutorial-discovery-3-1.swift","runtimePreview":null},{"code":"tutorial-discovery-3-2.swift","content":[{"inlineContent":[{"type":"text","text":"Now, let’s add radio buttons to let the user choose its gender."},{"type":"text","text":" "},{"type":"text","text":"The official components are "},{"type":"codeVoice","code":"OUDSRadio"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioItem"},{"type":"text","text":", but the package has also a "},{"type":"codeVoice","code":"OUDSRadioPicker"},{"type":"text","text":" to implement quicky a group of radios."},{"type":"text","text":" "},{"type":"text","text":"This component can be replaced by your own."},{"type":"text","text":" "},{"type":"text","text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":" thing shared through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Inside a picker the user can select only one value, not zero."}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-2.png","media":null,"caption":[{"inlineContent":[{"type":"text","text":"Add such picker with three items inside."}],"type":"paragraph"}],"type":"step"},{"code":"tutorial-discovery-3-3.swift","content":[{"inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" which is a simple checkbox, and "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"type":"codeVoice","code":"State"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In some cases you may need to use "},{"type":"codeVoice","code":"OUDSCheckboxIndeterminate"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSCheckboxItemIndeterminate"},{"type":"text","text":" if you want a three-states checkbox."}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-3.png","media":null,"caption":[{"inlineContent":[{"type":"text","text":"Add a checkbox item with only two states."}],"type":"paragraph"}],"type":"step"},{"code":"tutorial-discovery-3-4.swift","content":[{"inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-4.png","media":null,"caption":[{"inlineContent":[{"type":"text","text":"Choose to add an instance of "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"step"},{"code":"tutorial-discovery-3-5.swift","content":[{"inlineContent":[{"type":"text","text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone ("},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":") or with texts ("},{"type":"codeVoice","code":"OUDSSwitchItem"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"Just like the checkbox, the switch exposes its state through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-5.png","media":null,"caption":[{"inlineContent":[{"type":"text","text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations."},{"type":"text","text":" "},{"type":"text","text":"You will then be able to see the automatic changes of colors when you switch the color scheme."}],"type":"paragraph"}],"type":"step"},{"code":"tutorial-discovery-3-6.swift","content":[{"inlineContent":[{"type":"text","text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the "},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" component can be integrated. It can be only with a text or also a chevron indicator."}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-6.png","media":null,"caption":[{"inlineContent":[{"type":"text","text":"Add an "},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" in the app and make it open the iOS documentation OUDS website."}],"type":"paragraph"}],"type":"step"},{"code":"tutorial-discovery-3-7.swift","content":[{"inlineContent":[{"type":"text","text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand."},{"type":"text","text":" "},{"type":"text","text":"You can find it with the "},{"type":"codeVoice","code":"OUDSButton"},{"type":"text","text":". Such button has an appearance changing its colors, and also a style (loading or not)."},{"type":"text","text":" "},{"type":"text","text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed."}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-7.png","media":null,"caption":[{"inlineContent":[{"type":"text","text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds."}],"type":"paragraph"}],"type":"step"}],"anchor":"Add-basic-components","title":"Add basic components","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"type":"text","text":" "},{"type":"text","text":"Feel free to style and design things as you want."}],"type":"paragraph"}]}]}],"kind":"tasks"},{"kind":"assessments","anchor":"Check-Your-Understanding","assessments":[{"choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases."}]}],"isCorrect":false},{"isCorrect":true,"content":[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"That is the reason why the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}],"type":"paragraph"}]}],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Does the developer using OUDS component need to manage the look and feel of the components?"}]}],"content":[],"type":"multiple-choice"}]},{"abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"kind":"callToAction","title":"Add more OUDS components","featuredEyebrow":"Tutorial","action":{"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","isActive":true,"overridingTitle":"Get started"}}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components"]}],"kind":"project","references":{"tutorial-discovery-3-2.swift":{"syntax":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","","    var body: some View {","        OUDSRadioPicker(selection: $selectedGender,","                        radios: genderRadioValues(),","                        placement: .horizontal(false))","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileName":"Content.swift","identifier":"tutorial-discovery-3-2.swift","highlights":[],"type":"file","fileType":"swift"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Import-of-the-Swift-Package-and-choose-its-librairies":{"role":"article","abstract":[],"url":"\/tutorials\/table-of-contents-(discovery)\/import-of-the-swift-package-and-choose-its-librairies","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","kind":"article","type":"topic","title":"Import of the Swift Package and choose its librairies"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Add-basic-components":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Add-basic-components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components","kind":"section","type":"section","title":"Add basic components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components":{"role":"project","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","estimatedTime":"30min","kind":"project","type":"topic","title":"Add more OUDS components"},"tutorial-discovery-3-6.swift":{"fileType":"swift","identifier":"tutorial-discovery-3-6.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"syntax":"swift","type":"file","fileName":"Content.swift","highlights":[{"line":23},{"line":24},{"line":36},{"line":37},{"line":38},{"line":39}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things":{"role":"project","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","estimatedTime":"30min","kind":"project","type":"topic","title":"Styling things"},"tutorial-discovery-3-2.png":{"identifier":"tutorial-discovery-3-2.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-2.png"}],"type":"image","alt":"A radio picker"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link","title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Go-further-with-more-ressources":{"kind":"article","title":"Go further with more ressources","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/go-further-with-more-ressources","type":"topic","abstract":[]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies":{"kind":"project","title":"Swift Package integration","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","role":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies","type":"topic","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"estimatedTime":"10min"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","kind":"section","type":"section","title":"Basic structure for the app"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"role":"project","abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further","estimatedTime":"10min","kind":"project","type":"topic","title":"Going further with more resources"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Preparation-of-the-theme":{"type":"topic","url":"\/tutorials\/table-of-contents-(discovery)\/preparation-of-the-theme","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","role":"article","title":"Preparation of the theme","kind":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"kind":"section","title":"Import the Swift Package and the libraries","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","type":"section","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Final-result":{"type":"section","url":"\/tutorials\/oudsthemescont