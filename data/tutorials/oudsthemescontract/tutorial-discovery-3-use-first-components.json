{"kind":"project","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"}]},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"}]}]},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","interfaceLanguage":"swift"},"sections":[{"content":[{"inlineContent":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}],"type":"paragraph"}],"image":"ic_component_intro.png","chapter":"Use of first components provided by OUDS","backgroundImage":"ic_component_intro.png","kind":"hero","projectFiles":"OUDS-Discovery-Tutorial.zip","title":"Use your first OUDS components","xcodeRequirement":"Xcode 26.4","estimatedTimeInMinutes":30},{"kind":"tasks","tasks":[{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"type":"text","text":" "},{"type":"text","text":"Feel free to style and design things as you want."}]}]}],"title":"Add basic components","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"First, prepare the "},{"type":"codeVoice","code":"ContentView"},{"type":"text","text":" by adding inside it a "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":"."}]}],"runtimePreview":null,"caption":[],"media":null,"code":"tutorial-discovery-3-1.swift","type":"step"},{"content":[{"inlineContent":[{"type":"text","text":"Now, let’s add radio buttons to let the user choose its gender."},{"type":"text","text":" "},{"type":"text","text":"The official components are "},{"code":"OUDSRadio","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioItem"},{"type":"text","text":", but the package has also a "},{"type":"codeVoice","code":"OUDSRadioPicker"},{"type":"text","text":" to implement quicky a group of radios."},{"type":"text","text":" "},{"type":"text","text":"This component can be replaced by your own."},{"type":"text","text":" "},{"type":"text","text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":" thing shared through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Inside a picker the user can select only one value, not zero."}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-2.png","caption":[{"inlineContent":[{"type":"text","text":"Add such picker with three items inside."}],"type":"paragraph"}],"media":null,"code":"tutorial-discovery-3-2.swift","type":"step"},{"caption":[{"inlineContent":[{"text":"Add a checkbox item with only two states.","type":"text"}],"type":"paragraph"}],"type":"step","media":null,"code":"tutorial-discovery-3-3.swift","content":[{"inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" which is a simple checkbox, and "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"type":"codeVoice","code":"State"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In some cases you may need to use "},{"code":"OUDSCheckboxIndeterminate","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSCheckboxItemIndeterminate","type":"codeVoice"},{"type":"text","text":" if you want a three-states checkbox."}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-3.png"},{"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"text":" ","type":"text"},{"text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-3-4.swift","caption":[{"inlineContent":[{"text":"Choose to add an instance of ","type":"text"},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"text":".","type":"text"}],"type":"paragraph"}],"runtimePreview":"tutorial-discovery-3-4.png"},{"media":null,"runtimePreview":"tutorial-discovery-3-5.png","code":"tutorial-discovery-3-5.swift","caption":[{"inlineContent":[{"text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations.","type":"text"},{"text":" ","type":"text"},{"text":"You will then be able to see the automatic changes of colors when you switch the color scheme.","type":"text"}],"type":"paragraph"}],"type":"step","content":[{"inlineContent":[{"text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone (","type":"text"},{"type":"codeVoice","code":"OUDSSwitch"},{"text":") or with texts (","type":"text"},{"type":"codeVoice","code":"OUDSSwitchItem"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"Just like the checkbox, the switch exposes its state through a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"}],"type":"paragraph"}]},{"media":null,"runtimePreview":"tutorial-discovery-3-6.png","code":"tutorial-discovery-3-6.swift","caption":[{"type":"paragraph","inlineContent":[{"text":"Add an ","type":"text"},{"type":"codeVoice","code":"OUDSLink"},{"text":" in the app and make it open the iOS documentation OUDS website.","type":"text"}]}],"type":"step","content":[{"inlineContent":[{"type":"text","text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the "},{"type":"codeVoice","code":"OUDSLink"},{"text":" component can be integrated. It can be only with a text or also a chevron indicator.","type":"text"}],"type":"paragraph"}]},{"media":null,"runtimePreview":"tutorial-discovery-3-7.png","code":"tutorial-discovery-3-7.swift","caption":[{"inlineContent":[{"type":"text","text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds."}],"type":"paragraph"}],"type":"step","content":[{"inlineContent":[{"type":"text","text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand."},{"type":"text","text":" "},{"type":"text","text":"You can find it with the "},{"type":"codeVoice","code":"OUDSButton"},{"type":"text","text":". Such button has an appearance changing its colors, and also a style (loading or not)."},{"type":"text","text":" "},{"type":"text","text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed."}],"type":"paragraph"}]}],"anchor":"Add-basic-components"}]},{"kind":"assessments","assessments":[{"type":"multiple-choice","content":[],"title":[{"inlineContent":[{"type":"text","text":"Does the developer using OUDS component need to manage the look and feel of the components?"}],"type":"paragraph"}],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"That is the reason why the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}]}]}]}],"anchor":"Check-Your-Understanding"},{"kind":"callToAction","featuredEyebrow":"Tutorial","title":"Add more OUDS components","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"action":{"type":"reference","overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"}}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components"]}],"metadata":{"role":"project","title":"Use your first OUDS components","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)"},"references":{"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Use-of-first-components-provided-by-OUDS":{"abstract":[],"url":"\/tutorials\/table-of-contents-(discovery)\/use-of-first-components-provided-by-ouds","kind":"article","role":"article","title":"Use of first components provided by OUDS","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Richer-and-more-original-components-of-OUDS":{"url":"\/tutorials\/table-of-contents-(discovery)\/richer-and-more-original-components-of-ouds","type":"topic","kind":"article","title":"Richer and more original components of OUDS","role":"article","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Preparation-of-the-theme":{"kind":"article","url":"\/tutorials\/table-of-contents-(discovery)\/preparation-of-the-theme","title":"Preparation of the theme","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","abstract":[],"role":"article","type":"topic"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Add-basic-components":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Add-basic-components","type":"section","kind":"section","title":"Add basic components","role":"pseudoSymbol","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Go-further-with-more-ressources":{"kind":"article","url":"\/tutorials\/table-of-contents-(discovery)\/go-further-with-more-ressources","title":"Go further with more ressources","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","abstract":[],"role":"article","type":"topic"},"tutorial-discovery-3-2.swift":{"fileType":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","","    var body: some View {","        OUDSRadioPicker(selection: $selectedGender,","                        radios: genderRadioValues(),","                        placement: .horizontal(false))","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileName":"Content.swift","syntax":"swift","type":"file","highlights":[],"identifier":"tutorial-discovery-3-2.swift"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Typography,-view-modifiers-and-tokens":{"title":"Typography, view modifiers and tokens","type":"topic","role":"article","abstract":[],"url":"\/tutorials\/table-of-contents-(discovery)\/typography,-view-modifiers-and-tokens","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","kind":"article"},"tutorial-discovery-3-4.swift":{"fileType":"swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"type":"file","syntax":"swift","highlights":[{"line":28},{"line":29}],"identifier":"tutorial-discovery-3-4.swift"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components":{"estimatedTime":"30min","kind":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components","title":"Add more OUDS components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"role":"project","type":"topic"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","type":"section","kind":"section","title":"Basic structure for the app","role":"pseudoSymbol","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app"},"ic_component_intro.png":{"type":"image","identifier":"ic_component_intro.png","variants":[{"url":"\/images\/OUDSThemesContract\/ic_component_intro.png","traits":["1x","light"]}],"alt":"OUDS components logo"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further#More-resources":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further#More-resources","type":"section","kind":"section","title":"More resources","role":"pseudoSymbol","abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources"},"tutorial-discovery-3-6.png":{"alt":"A radio picker, an horizontal divider, a checkbox item, a switch item and a link","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-6.png","traits":["1x","light"]}],"type":"image","identifier":"tutorial-discovery-3-6.png"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"title":"Check Your Understanding","type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things":{"estimatedTime":"30min","kind":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things","title":"Styling things","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"role":"project","type":"topic"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Add-basic-components":{"abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Add-basic-components","kind":"section","role":"pseudoSymbol","title":"Add basic components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components","type":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding":{"type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","title":"Check Your Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}]},"tutorial-discovery-3-5.swift":{"syntax":"swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileType":"swift","highlights":[{"line":21},{"line":32},{"line":33},{"line":34}],"type":"file","identifier":"tutorial-discovery-3-5.swift"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Final-result":{"kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Final-result","title":"Final result","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"role":"pseudoSymbol","type":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components","type":"topic","kind":"project","title":"Use your first OUDS components","role":"project","estimatedTime":"30min","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding":{"type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","title":"Check Your Understanding"},"tutorial-discovery-3-4.png":{"type":"image","identifier":"tutorial-discovery-3-4.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-3-4.png"}],"alt":"A radio picker, an horizontal divider and a checkbox item"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"title":"Going further with more resources","type":"topic","estimatedTime":"10min","role":"project","abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, c