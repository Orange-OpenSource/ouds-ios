ials\/table-of-contents-(discovery)","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Preparation-of-the-theme":{"role":"article","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","kind":"article","title":"Preparation of the theme","url":"\/tutorials\/table-of-contents-(discovery)\/preparation-of-the-theme","abstract":[]},"tutorial-discovery-3-5.swift":{"highlights":[{"line":21},{"line":32},{"line":33},{"line":34}],"fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-5.swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"]},"tutorial-discovery-3-7.swift":{"highlights":[{"line":22},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50}],"fileType":"swift","syntax":"swift","type":"file","identifier":"tutorial-discovery-3-7.swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","","            OUDSButton(text: \"Create my profile\",","                       appearance: .strong,","                       style: creatingProfile ? .loading : .default)","            {","                creatingProfile = true","                DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                    creatingProfile = false","                }","            }.disabled(!termsAccepted)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Richer-and-more-original-components-of-OUDS":{"role":"article","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS","kind":"article","title":"Richer and more original components of OUDS","url":"\/tutorials\/table-of-contents-(discovery)\/richer-and-more-original-components-of-ouds","abstract":[]}}}