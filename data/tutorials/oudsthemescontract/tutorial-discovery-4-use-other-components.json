{"kind":"project","hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"}]}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[{"backgroundImage":"ic_component_intro.png","kind":"hero","estimatedTimeInMinutes":30,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}]}],"image":"ic_component_intro.png","title":"Add more OUDS components","xcodeRequirement":"Xcode 26.4","projectFiles":"OUDS-Discovery-Tutorial.zip","chapter":"Richer and more original components of OUDS"},{"tasks":[{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"text":"Some components like tags are original, and others like text input are richer. Let’s play with them!","type":"text"}],"type":"paragraph"}]}],"title":"Add basic components","anchor":"Add-basic-components","stepsSection":[{"runtimePreview":"tutorial-discovery-4-1.png","caption":[{"inlineContent":[{"text":"Add three tags thanks to ","type":"text"},{"type":"codeVoice","code":"OUDSTag"},{"text":" object.","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"text":"The tags are small labels bringing pieces of information so as to give more context to the users. They are very simple to use.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-4-1.swift"},{"runtimePreview":"tutorial-discovery-4-2.png","caption":[{"inlineContent":[{"text":"Add a group of chips for some topics the user must select. The picker is populated by an array of data, and the one we use as a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":" of array.","type":"text"},{"text":" ","type":"text"},{"text":"The user can select all of the items.","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"text":"Chips can be considered as interactive tags. OUDS provides ","type":"text"},{"type":"codeVoice","code":"OUDSSuggestionChip"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSFilterChip"},{"text":" depending to the needs of the users.","type":"text"},{"text":" ","type":"text"},{"text":"Just like the radio buttons and the checkboxes, OUDS package provides a ","type":"text"},{"type":"codeVoice","code":"OUDSChipPicker"},{"text":" to add quickly a group of chips and select some of them using specific rule.","type":"text"},{"text":" ","type":"text"},{"text":"This component is not official but can be helpful.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-4-2.swift"},{"runtimePreview":"tutorial-discovery-4-3.png","caption":[{"inlineContent":[{"text":"Add two text inputs: one to get the user name with a delete action, and one for an email address.","type":"text"},{"text":" ","type":"text"},{"text":"Their values are exposed through ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":" of ","type":"text"},{"type":"codeVoice","code":"String"},{"text":".","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"text":"Formulars without input text are not formulars. OUDS provide an ","type":"text"},{"type":"codeVoice","code":"OUDSTextInput"},{"text":" to let use write some text.","type":"text"},{"text":" ","type":"text"},{"text":"This component is very rich: preffix and suffix can be defined, and also helper text and links. An icon can be added and a trailing action.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-4-3.swift"},{"runtimePreview":"tutorial-discovery-4-4.png","caption":[{"inlineContent":[{"text":"Add a ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":" gathering the link, the button and the switch item. You will need to get the theme object for your first time so as to choose the color of the surface! The import of ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}],"type":"emphasis"},{"text":" is also necessary. Once your code is updated, compare the difference for the switch, the link and the button. Their style has changed!","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","content":[{"inlineContent":[{"text":"In some conditions, components need to be placed on colored surface. Indeed such colored surfaces make their components strongs and increase the efficiency and the onboarding of the users.","type":"text"},{"text":" ","type":"text"},{"text":"However some components like text, button and link must act differently if they are in such surfaces. For example they must use the monochrome colors.","type":"text"},{"text":" ","type":"text"},{"text":"In addition the colored surface brings a small set of colors so as to be sure contrasts and rendering of components are acceptable and all combinations tested.","type":"text"},{"text":" ","type":"text"},{"text":"Nevertheless some components with particular appearances must not be added in such surface, it is forbidden by design. Developers must check the documentation of the component and also apply the specifications of their designers who know these rules thanks to the Figma OUDS assets.","type":"text"}],"type":"paragraph"}],"code":"tutorial-discovery-4-4.swift"}]}],"kind":"tasks"},{"anchor":"Check-Your-Understanding","assessments":[{"type":"multiple-choice","content":[],"title":[{"inlineContent":[{"text":"In which case should I use the colored surface?","type":"text"}],"type":"paragraph"}],"choices":[{"content":[{"inlineContent":[{"text":"Never, I can just change the background","type":"text"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"text":"Even if you apply the color you want on the background, it will not be enough because some components can have accessibility issues with bad WCAG ratios. Colored surface provides small set of colors for which components are ready.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Always, thus my components feel good","type":"text"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"text":"No, you should see with your designer so as to know when a colored surface must be used.","type":"text"},{"text":" ","type":"text"},{"text":"Or if you do not have designers, be an artist and test what is pleasant for you!","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Sometimes, it depends to the context","type":"text"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"text":"In most of cases components should not be in monochrome mode and colored surface used. See with your designers the cases when you will have to use the ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":". Or be an artist and test what is pleasant for you!","type":"text"}],"type":"paragraph"}]}]}],"kind":"assessments"},{"featuredEyebrow":"Tutorial","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"action":{"type":"reference","overridingTitle":"Get started","isActive":true,"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"},"kind":"callToAction","title":"Styling things"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components"]}],"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","interfaceLanguage":"swift"},"metadata":{"title":"Add more OUDS components","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)","role":"project"},"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components":{"abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"title":"Add more OUDS components","estimatedTime":"30min","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components","role":"project","type":"topic"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Richer-and-more-original-components-of-OUDS":{"abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/richer-and-more-original-components-of-ouds","type":"topic","kind":"article","title":"Richer and more original components of OUDS"},"tutorial-discovery-4-2.swift":{"type":"file","syntax":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","    @State var selectedTopics: [Topics] = []","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            HStack {","                OUDSTag(label: \"Welcome\")","                OUDSTag(label: \"OUDS\")","                OUDSTag(label: \"Tutorial\")","            }","","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSChipPicker(selections: $selectedTopics, chips: topicsChipsValues())","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","","            OUDSButton(text: \"Create my profile\",","                       appearance: .strong,","                       style: creatingProfile ? .loading : .default)","            {","                creatingProfile = true","                DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                    creatingProfile = false","                }","            }.disabled(!termsAccepted)","","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Topics: String, Hashable {","        case food","        case music","        case gardening","        case sport","    }","","    func topicsChipsValues() -> [OUDSChipPickerData<Topics>] {","        [","            OUDSChipPickerData(tag: Topics.food, layout: .text(text: \"Food\")),","            OUDSChipPickerData(tag: Topics.music, layout: .text(text: \"Music\")),","            OUDSChipPickerData(tag: Topics.gardening, layout: .text(text: \"Gardening\")),","            OUDSChipPickerData(tag: Topics.sport, layout: .text(text: \"Sport\")),","        ]","    }","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileName":"Content.swift","highlights":[{"line":23},{"line":39},{"line":40},{"line":66},{"line":67},{"line":68},{"line":69},{"line":70},{"line":71},{"line":72},{"line":73},{"line":74},{"line":75},{"line":76},{"line":77},{"line":78},{"line":79},{"line":80},{"line":81}],"identifier":"tutorial-discovery-4-2.swift","fileType":"swift"},"tutorial-discovery-4-3.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-4-3.png"}],"identifier":"tutorial-discovery-4-3.png","alt":"Texts inputs are very rich and available in lot of apps and formulars"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Add-basic-components":{"abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Add-basic-components","role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Add-basic-components","type":"section","kind":"section","title":"Add basic components"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Preparation-of-the-theme":{"abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Preparation-of-the-theme","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/preparation-of-the-theme","type":"topic","kind":"article","title":"Preparation of the theme"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further#More-resources":{"role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further#More-resources","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources","kind":"section","title":"More resources","abstract":[{"text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources.","type":"text"}],"type":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things":{"title":"Styling things","kind":"project","role":"project","estimatedTime":"30min","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things","type":"topic"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Go-further-with-more-ressources":{"abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/go-further-with-more-ressources","type":"topic","kind":"article","title":"Go further with more ressources"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Use-of-first-components-provided-by-OUDS":{"abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-components-provided-by-OUDS","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/use-of-first-components-provided-by-ouds","type":"topic","kind":"article","title":"Use of first components provided by OUDS"},"tutorial-discovery-4-1.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-4-1.png"}],"identifier":"tutorial-discovery-4-1.png","alt":"Tags in top of formular"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components#Check-Your-Understanding":{"type":"link","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components#Check-Your-Understanding","title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Import-of-the-Swift-Package-and-choose-its-librairies":{"role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/import-of-the-swift-package-and-choose-its-librairies","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","kind":"article","title":"Import of the Swift Package and choose its librairies","abstract":[],"type":"topic"},"Xcode 26.4":{"type":"xcodeRequirement","url":"https:\/\/developer.apple.com\/download\/","identifier":"Xcode 26.4","title":"Xcode 26.4"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components#Check-Your-Understanding":{"type":"link","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding","title":"Check Your Understanding"},"tutorial-discovery-4-2.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-4-2.png"}],"identifier":"tutorial-discovery-4-2.png","alt":"Chips are now integrated inside a picker"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Typography,-view-modifiers-and-tokens":{"abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/typography,-view-modifiers-and-tokens","type":"topic","kind":"article","title":"Typography, view modifiers and tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Use-of-view-modifiers":{"abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers","type":"section","kind":"section","title":"Use of view modifiers"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding":{"type":"link","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme#Check-Your-Understanding","title":"Check Your Understanding"},"tutorial-discovery-4-4.swift":{"type":"file","syntax":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","    @State var selectedTopics: [Topics] = []","    @State var identity: String = \"\"","    @State var email: String = \"\"","","    @Environment(\\.theme) var theme","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            HStack {","                OUDSTag(label: \"Welcome\")","                OUDSTag(label: \"OUDS\")","                OUDSTag(label: \"Tutorial\")","            }","","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            let identityDeleteAction = OUDSTextInput.TrailingAction(icon: Image(systemName: \"trash\"), actionHint: \"Delete\") { identity = \"\" }","            OUDSTextInput(label: \"Identity\", text: $identity, placeholder: \"Firstname and lastname\", trailingAction: identityDeleteAction)","","            OUDSTextInput(label: \"Email\", text: $email,","                          placeholder: \"Email address\",","                          suffix: \".com\",","                          leadingIcon: Image(systemName: \"envelope\"),","                          helperText: \"The email will be automatically completed with @orange.com\")","","            OUDSChipPicker(selections: $selectedTopics, chips: topicsChipsValues())","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(\"I accept the terms of use\", isOn: $termsAccepted)","","            OUDSColoredSurface(color: theme.colorModes.onStatusInfoEmphasized) {","                VStack(alignment: .center, spacing: theme.spaces.fixedXsmall) {","                    OUDSLink(text: \"Go to the website\", indicator: .next) {","                        openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","                    }","","                    OUDSButton(text: \"Create my profile\",","                               appearance: .strong,","                               style: creatingProfile ? .loading : .default)","                    {","                        creatingProfile = true","                        DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                            creatingProfile = false","                        }","                    }.disabled(!termsAccepted)","","                    OUDSSwitchItem(\"Switch to dark mode\",","                                   isOn: $switchToDarkMode)","                        .padding(.horizontal, theme.spaces.fixed3xlarge)","                }","                .frame(maxWidth: .infinity)","                .padding(.bottom, theme.spaces.fixedLarge)","            }","","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Topics: String, Hashable {","        case food","        case music","        case gardening","        case sport","    }","","    func topicsChipsValues() -> [OUDSChipPickerData<Topics>] {","        [","            OUDSChipPickerData(tag: Topics.food, layout: .text(text: \"Food\")),","            OUDSChipPickerData(tag: Topics.music, layout: .text(text: \"Music\")),","            OUDSChipPickerData(tag: Topics.gardening, layout: .text(text: \"Gardening\")),","            OUDSChipPickerData(tag: Topics.sport, layout: .text(text: \"Sport\")),","        ]","    }","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileName":"Content.swift","highlights":[{"line":27},{"line":57},{"line":58},{"line":59},{"line":60},{"line":61},{"line":63},{"line":64},{"line":65},{"line":66},{"line":67},{"line":68},{"line":69},{"line":70},{"line":71},{"line":73},{"line":74},{"line":75},{"line":77},{"line":78},{"line":79}],"identifier":"tutorial-discovery-4-4.swift","fileType":"swift"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Use-of-tokens":{"abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens","role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Use-of-tokens","type":"section","kind":"section","title":"Use of tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Final-result":{"role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Final-result","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result","kind":"section","title":"Final result","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"type":"section"},"tutorial-discovery-4-4.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-4-4.png"}],"identifier":"tutorial-discovery-4-4.png","alt":"The colored surfce changes the sty