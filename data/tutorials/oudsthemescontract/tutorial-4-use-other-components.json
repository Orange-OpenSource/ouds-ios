-instanciate-theme#Basic-structure-for-the-app","kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Add-basic-components":{"kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components","role":"pseudoSymbol","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Add-basic-components","title":"Add basic components"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Richer-and-more-original-components-of-OUDS":{"role":"article","type":"topic","abstract":[],"title":"Richer and more original components of OUDS","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS","kind":"article","url":"\/tutorials\/table-of-contents\/richer-and-more-original-components-of-ouds"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","role":"pseudoSymbol","abstract":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework.","type":"text"}],"type":"section","title":"Import the Swift Package and the libraries","url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further#More-resources":{"role":"pseudoSymbol","type":"section","abstract":[{"type":"text","text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources."}],"title":"More resources","url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further#More-resources","kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme":{"role":"project","title":"Instanciate and inject a theme","type":"topic","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme","estimatedTime":"15min","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"role":"project","title":"Add more OUDS components","type":"topic","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","estimatedTime":"30min","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components":{"title":"Use your first OUDS components","type":"topic","kind":"project","estimatedTime":"30min","role":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Use-of-view-modifiers":{"kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers","role":"pseudoSymbol","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Use-of-view-modifiers","title":"Use of view modifiers"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies":{"role":"project","title":"Swift Package integration","type":"topic","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies","estimatedTime":"10min","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Check-Your-Understanding":{"type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"title":"Check Your Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Check-Your-Understanding"},"tutorial-4-1.png":{"type":"image","alt":"Tags in top of formular","identifier":"tutorial-4-1.png","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-4-1.png","traits":["1x","light"]}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further":{"title":"Going further with more resources","kind":"project","type":"topic","estimatedTime":"10min","role":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further","abstract":[{"type":"text","text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Check-Your-Understanding":{"type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Check-Your-Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Check-Your-Understanding":{"type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"title":"Check Your Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Final-result":{"role":"pseudoSymbol","type":"section","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"title":"Final result","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Final-result","kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things":{"role":"project","title":"Styling things","type":"topic","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things","estimatedTime":"30min","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things"},"tutorial-4-1.swift":{"highlights":[{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":57}],"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            HStack {","                OUDSTag(label: \"Welcome\")","                OUDSTag(label: \"OUDS\")","                OUDSTag(label: \"Tutorial\")","            }","","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","","            OUDSButton(text: \"Create my profile\",","                       appearance: .strong,","                       style: creatingProfile ? .loading : .default)","            {","                creatingProfile = true","                DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                    creatingProfile = false","                }","            }.disabled(!termsAccepted)","","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"identifier":"tutorial-4-1.swift","fileName":"Content.swift","syntax":"swift","fileType":"swift","type":"file"},"doc://OUDSThemesContract/tutorials/Table-Of-C