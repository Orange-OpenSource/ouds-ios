nough. Typography, fonts and tokens are here to improve that."}]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Preparation-of-the-theme":{"abstract":[],"title":"Preparation of the theme","role":"article","kind":"article","type":"topic","url":"\/tutorials\/table-of-contents\/preparation-of-the-theme","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Preparation-of-the-theme"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Import-of-the-Swift-Package-and-choose-its-librairies":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies","url":"\/tutorials\/table-of-contents\/import-of-the-swift-package-and-choose-its-librairies","kind":"article","type":"topic","title":"Import of the Swift Package and choose its librairies","role":"article","abstract":[]},"tutorial-4-3.swift":{"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","    @State var selectedTopics: [Topics] = []","    @State var identity: String = \"\"","    @State var email: String = \"\"","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            HStack {","                OUDSTag(label: \"Welcome\")","                OUDSTag(label: \"OUDS\")","                OUDSTag(label: \"Tutorial\")","            }","","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            let identityDeleteAction = OUDSTextInput.TrailingAction(icon: Image(systemName: \"trash\"), actionHint: \"Delete\") { identity = \"\" }","            OUDSTextInput(label: \"Identity\", text: $identity, placeholder: \"Firstname and lastname\", trailingAction: identityDeleteAction)","","            OUDSTextInput(label: \"Email\", text: $email,","                          placeholder: \"Email address\",","                          suffix: \".com\",","                          leadingIcon: Image(systemName: \"envelope\"),","                          helperText: \"The email will be automatically completed with @orange.com\")","","            OUDSChipPicker(selections: $selectedTopics, chips: topicsChipsValues())","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","","            OUDSButton(text: \"Create my profile\",","                       appearance: .strong,","                       style: creatingProfile ? .loading : .default)","            {","                creatingProfile = true","                DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                    creatingProfile = false","                }","            }.disabled(!termsAccepted)","","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Topics: String, Hashable {","        case food","        case music","        case gardening","        case sport","    }","","    func topicsChipsValues() -> [OUDSChipPickerData<Topics>] {","        [","            OUDSChipPickerData(tag: Topics.food, layout: .text(text: \"Food\")),","            OUDSChipPickerData(tag: Topics.music, layout: .text(text: \"Music\")),","            OUDSChipPickerData(tag: Topics.gardening, layout: .text(text: \"Gardening\")),","            OUDSChipPickerData(tag: Topics.sport, layout: .text(text: \"Sport\")),","        ]","    }","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"type":"file","identifier":"tutorial-4-3.swift","fileName":"Content.swift","highlights":[{"line":24},{"line":25},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49}],"fileType":"swift","syntax":"swift"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Add-basic-components":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Add-basic-components","role":"pseudoSymbol","title":"Add basic components","kind":"section","type":"section","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}]},"tutorial-4-3.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-4-3.png"}],"alt":"Texts inputs are very rich and available in lot of apps and formulars","type":"image","identifier":"tutorial-4-3.png"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Check-Your-Understanding":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Check-Your-Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"type":"link","title":"Check Your Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"title":"Add more OUDS components","role":"project","estimatedTime":"30min","kind":"project","type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents":{"kind":"overview","type":"topic","role":"overview","url":"\/tutorials\/table-of-contents","title":"Swift Package iOS Tutorial","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","abstract":[{"type":"text","text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package."},{"type":"text","text":" "},{"type":"text","text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework."},{"type":"text","text":" "},{"type":"text","text":"Theme, components, tokens… everything will be introduced!"}]},"tutorial-4-4.swift":{"highlights":[{"line":27},{"line":57},{"line":58},{"line":59},{"line":60},{"line":61},{"line":63},{"line":64},{"line":65},{"line":66},{"line":67},{"line":68},{"line":69},{"line":70},{"line":71},{"line":73},{"line":74},{"line":75},{"line":77},{"line":78},{"line":79}],"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","    @State var selectedTopics: [Topics] = []","    @State var identity: String = \"\"","    @State var email: String = \"\"","","    @Environment(\\.theme) var theme","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            HStack {","                OUDSTag(label: \"Welcome\")","                OUDSTag(label: \"OUDS\")","                OUDSTag(label: \"Tutorial\")","            }","","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            let identityDeleteAction = OUDSTextInput.TrailingAction(icon: Image(systemName: \"trash\"), actionHint: \"Delete\") { identity = \"\" }","            OUDSTextInput(label: \"Identity\", text: $identity, placeholder: \"Firstname and lastname\", trailingAction: identityDeleteAction)","","            OUDSTextInput(label: \"Email\", text: $email,","                          placeholder: \"Email address\",","                          suffix: \".com\",","                          leadingIcon: Image(systemName: \"envelope\"),","                          helperText: \"The email will be automatically completed with @orange.com\")","","            OUDSChipPicker(selections: $selectedTopics, chips: topicsChipsValues())","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSColoredSurface(color: theme.colorModes.onStatusInfoEmphasized) {","                VStack(alignment: .center, spacing: theme.spaces.fixedXsmall) {","                    OUDSLink(text: \"Go to the website\", indicator: .next) {","                        openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","                    }","","                    OUDSButton(text: \"Create my profile\",","                               appearance: .strong,","                               style: creatingProfile ? .loading : .default)","                    {","                        creatingProfile = true","                        DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                            creatingProfile = false","                        }","                    }.disabled(!termsAccepted)","","                    OUDSSwitchItem(\"Switch to dark mode\",","                                   isOn: $switchToDarkMode)","                        .padding(.horizontal, theme.spaces.fixed3xlarge)","                }","                .frame(maxWidth: .infinity)","                .padding(.bottom, theme.spaces.fixedLarge)","            }","","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Topics: String, Hashable {","        case food","        case music","        case gardening","        case sport","    }","","    func topicsChipsValues() -> [OUDSChipPickerData<Topics>] {","        [","            OUDSChipPickerData(tag: Topics.food, layout: .text(text: \"Food\")),","            OUDSChipPickerData(tag: Topics.music, layout: .text(text: \"Music\")),","            OUDSChipPickerData(tag: Topics.gardening, layout: .text(text: \"Gardening\")),","            OUDSChipPickerData(tag: Topics.sport, layout: .text(text: \"Sport\")),","        ]","    }","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileType":"swift","identifier":"tutorial-4-4.swift","fileName":"Content.swift","syntax":"swift","type":"file"},"Xcode 26":{"url":"https:\/\/developer.apple.com\/download\/","title":"Xcode 26","type":"xcodeRequirement","identifier":"Xcode 26"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Use-of-first-components-provided-by-OUDS":{"kind":"article","title":"Use of first components provided by OUDS","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS","abstract":[],"url":"\/tutorials\/table-of-contents\/use-of-first-components-provided-by-ouds","type":"topic","role":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framew