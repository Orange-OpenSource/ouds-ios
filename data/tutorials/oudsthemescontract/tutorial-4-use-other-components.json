{"metadata":{"category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents","role":"project","title":"Add more OUDS components"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components"]}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS"]],"modules":[{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Check-Your-Understanding"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies"},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Preparation-of-the-theme"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding"}]}]},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources"}]}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents"},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","interfaceLanguage":"swift"},"kind":"project","sections":[{"xcodeRequirement":"Xcode 26","kind":"hero","image":"ic_component_intro.png","title":"Add more OUDS components","backgroundImage":"ic_component_intro.png","content":[{"inlineContent":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"type":"paragraph"}],"chapter":"Richer and more original components of OUDS","estimatedTimeInMinutes":30},{"tasks":[{"stepsSection":[{"media":null,"code":"tutorial-4-1.swift","type":"step","runtimePreview":"tutorial-4-1.png","caption":[{"type":"paragraph","inlineContent":[{"text":"Add three tags thanks to ","type":"text"},{"type":"codeVoice","code":"OUDSTag"},{"text":" object.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"The tags are small labels bringing pieces of information so as to give more context to the users. They are very simple to use.","type":"text"}]}]},{"media":null,"code":"tutorial-4-2.swift","type":"step","runtimePreview":"tutorial-4-2.png","caption":[{"inlineContent":[{"text":"Add a group of chips for some topics the user must select. The picker is populated by an array of data, and the one we use as a ","type":"text"},{"code":"Binding","type":"codeVoice"},{"text":" of array.","type":"text"},{"text":" ","type":"text"},{"text":"The user can select all of the items.","type":"text"}],"type":"paragraph"}],"content":[{"inlineContent":[{"text":"Chips can be considered as interactive tags. OUDS provides ","type":"text"},{"code":"OUDSSuggestionChip","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSFilterChip","type":"codeVoice"},{"text":" depending to the needs of the users.","type":"text"},{"text":" ","type":"text"},{"text":"Just like the radio buttons and the checkboxes, OUDS package provides a ","type":"text"},{"code":"OUDSChipPicker","type":"codeVoice"},{"text":" to add quickly a group of chips and select some of them using specific rule.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This component is not official but can be helpful."}],"type":"paragraph"}]},{"media":null,"runtimePreview":"tutorial-4-3.png","content":[{"inlineContent":[{"type":"text","text":"Formulars without input text are not formulars. OUDS provide an "},{"code":"OUDSTextInput","type":"codeVoice"},{"type":"text","text":" to let use write some text."},{"type":"text","text":" "},{"text":"This component is very rich: preffix and suffix can be defined, and also helper text and links. An icon can be added and a trailing action.","type":"text"}],"type":"paragraph"}],"code":"tutorial-4-3.swift","caption":[{"inlineContent":[{"text":"Add two text inputs: one to get the user name with a delete action, and one for an email address.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Their values are exposed through "},{"code":"Binding","type":"codeVoice"},{"text":" of ","type":"text"},{"code":"String","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"step"},{"media":null,"runtimePreview":"tutorial-4-4.png","content":[{"inlineContent":[{"text":"In some conditions, components need to be placed on colored surface. Indeed such colored surfaces make their components strongs and increase the efficiency and the onboarding of the users.","type":"text"},{"text":" ","type":"text"},{"text":"However some components like text, button and link must act differently if they are in such surfaces. For example they must use the monochrome colors.","type":"text"},{"text":" ","type":"text"},{"text":"In addition the colored surface brings a small set of colors so as to be sure contrasts and rendering of components are acceptable and all combinations tested.","type":"text"},{"text":" ","type":"text"},{"text":"Nevertheless some components with particular appearances must not be added in such surface, it is forbidden by design. Developers must check the documentation of the component and also apply the specifications of their designers who know these rules thanks to the Figma OUDS assets.","type":"text"}],"type":"paragraph"}],"code":"tutorial-4-4.swift","caption":[{"inlineContent":[{"text":"Add a ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":" gathering the link, the button and the switch item. You will need to get the theme object for your first time so as to choose the color of the surface! The import of ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}]},{"text":" is also necessary. Once your code is updated, compare the difference for the switch, the link and the button. Their style has changed!","type":"text"}],"type":"paragraph"}],"type":"step"}],"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Some components like tags are original, and others like text input are richer. Let’s play with them!"}],"type":"paragraph"}],"mediaPosition":"trailing"}],"anchor":"Add-basic-components","title":"Add basic components"}],"kind":"tasks"},{"assessments":[{"title":[{"inlineContent":[{"text":"In which case should I use the colored surface?","type":"text"}],"type":"paragraph"}],"choices":[{"isCorrect":false,"content":[{"inlineContent":[{"type":"text","text":"Never, I can just change the background"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"Even if you apply the color you want on the background, it will not be enough because some components can have accessibility issues with bad WCAG ratios. Colored surface provides small set of colors for which components are ready.","type":"text"}],"type":"paragraph"}]},{"isCorrect":false,"content":[{"inlineContent":[{"type":"text","text":"Always, thus my components feel good"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"No, you should see with your designer so as to know when a colored surface must be used.","type":"text"},{"text":" ","type":"text"},{"text":"Or if you do not have designers, be an artist and test what is pleasant for you!","type":"text"}],"type":"paragraph"}]},{"isCorrect":true,"content":[{"inlineContent":[{"type":"text","text":"Sometimes, it depends to the context"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"In most of cases components should not be in monochrome mode and colored surface used. See with your designers the cases when you will have to use the ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":". Or be an artist and test what is pleasant for you!","type":"text"}],"type":"paragraph"}]}],"content":[],"type":"multiple-choice"}],"anchor":"Check-Your-Understanding","kind":"assessments"},{"action":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things","isActive":true,"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"type":"reference","overridingTitle":"Get started"},"title":"Styling things","kind":"callToAction","featuredEyebrow":"Tutorial","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"tutorial-4-4.swift":{"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","    @State var selectedTopics: [Topics] = []","    @State var identity: String = \"\"","    @State var email: String = \"\"","","    @Environment(\\.theme) var theme","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            HStack {","                OUDSTag(label: \"Welcome\")","                OUDSTag(label: \"OUDSThemesContract\")","                OUDSTag(label: \"Tutorial\")","            }","","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            let identityDeleteAction = OUDSTextInput.TrailingAction(icon: Image(systemName: \"trash\"), actionHint: \"Delete\") { identity = \"\" }","            OUDSTextInput(label: \"Identity\", text: $identity, placeholder: \"Firstname and lastname\", trailingAction: identityDeleteAction)","","            OUDSTextInput(label: \"Email\", text: $email,","                          placeholder: \"Email address\",","                          suffix: \".com\",","                          leadingIcon: Image(systemName: \"envelope\"),","                          helperText: \"The email will be automatically completed with @orange.com\")","","            OUDSChipPicker(selections: $selectedTopics, chips: topicsChipsValues())","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSColoredSurface(color: theme.colorModes.onStatusInfoEmphasized) {","                VStack(alignment: .center, spacing: theme.spaces.fixedXsmall) {","                    OUDSLink(text: \"Go to the website\", indicator: .next) {","                        openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","                    }","","                    OUDSButton(text: \"Create my profile\",","                               appearance: .strong,","                               style: creatingProfile ? .loading : .default)","                    {","                        creatingProfile = true","                        DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                            creatingProfile = false","                        }","                    }.disabled(!termsAccepted)","","                    OUDSSwitchItem(\"Switch to dark mode\",","                                   isOn: $switchToDarkMode)","                        .padding(.horizontal, theme.spaces.fixed3xlarge)","                }","                .frame(maxWidth: .infinity)","                .padding(.bottom, theme.spaces.fixedLarge)","            }","","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Topics: String, Hashable {","        case food","        case music","        case gardening","        case sport","    }","","    func topicsChipsValues() -> [OUDSChipPickerData<Topics>] {","        [","            OUDSChipPickerData(tag: Topics.food, layout: .text(text: \"Food\")),","            OUDSChipPickerData(tag: Topics.music, layout: .text(text: \"Music\")),","            OUDSChipPickerData(tag: Topics.gardening, layout: .text(text: \"Gardening\")),","            OUDSChipPickerData(tag: Topics.sport, layout: .text(text: \"Sport\")),","        ]","    }","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"identifier":"tutorial-4-4.swift","syntax":"swift","type":"file","fileType":"swift","fileName":"Content.swift","highlights":[{"line":27},{"line":57},{"line":58},{"line":59},{"line":60},{"line":61},{"line":63},{"line":64},{"line":65},{"line":66},{"line":67},{"line":68},{"line":69},{"line":70},{"line":71},{"line":73},{"line":74},{"line":75},{"line":77},{"line":78},{"line":79}]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Typography,-view-modifiers-and-tokens":{"role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","abstract":[],"kind":"article","type":"topic","title":"Typography, view modifiers and tokens","url":"\/tutorials\/table-of-contents\/typography,-view-modifiers-and-tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Final-result":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","type":"section","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"title":"Final result","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Final-result","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Add-basic-components":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","kind":"section","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"type":"section","title":"Add basic components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Add-basic-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Check-Your-Understanding":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","title":"Check Your Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further":{"title":"Going further with more resources","role":"project","abstract":[{"text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources.","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further","estimatedTime":"10min","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further","kind":"project"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents":{"title":"Swift Package iOS Tutorial","role":"overview","abstract":[{"text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package.","type":"text"},{"text":" ","type":"text"},{"text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework.","type":"text"},{"text":" ","type":"text"},{"text":"Theme, components, tokens… everything will be introduced!","type":"text"}],"url":"\/tutorials\/table-of-contents","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","kind":"overview"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies":{"title":"Swift Package integration","role":"project","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies","estimatedTime":"10min","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies","kind":"project"},"tutorial-4-1.png":{"identifier":"tutorial-4-1.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-4-1.png"}],"type":"image","alt":"Tags in top of formular"},"tutorial-4-4.png":{"identifier":"tutorial-4-4.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-4-4.png"}],"type":"image","alt":"The colored surfce changes the styles of some components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Basic-structure-for-the-app":{"kind":"section","title":"Basic structure for the app","type":"section","role":"pseudoSymbol","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Go-further-with-more-ressources":{"role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","type":"topic","abstract":[],"title":"Go further with more ressources","url":"\/tutorials\/table-of-contents\/go-further-with-more-ressources","kind":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Check-Your-Understanding":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","title":"Check Your Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Add-basic-components":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components","abstract":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}],"kind":"section","title":"Add basic components","type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Add-basic-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"type":"topic","title":"Add more OUDS components","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components","role":"project","estimatedTime":"30min","kind":"project"},"tutorial-4-1.swift":{"fileName":"Content.swift","highlights":[{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":57}],"fileType":"swift","syntax":"swift","identifier":"tutorial-4-1.swift","type":"file","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under t