{"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"Swift Package integration","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)","role":"project"},"sections":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}]}],"estimatedTimeInMinutes":10,"kind":"hero","chapter":"Import of the Swift Package and choose its librairies","image":"ic_unified_ds.png","backgroundImage":"ic_unified_ds.png","xcodeRequirement":"Xcode 26.3","title":"Swift Package integration","projectFiles":"OUDS-Discovery-Tutorial.zip"},{"kind":"tasks","tasks":[{"anchor":"Import-the-Swift-Package-and-the-libraries","contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}],"type":"paragraph"}],"mediaPosition":"trailing"}],"stepsSection":[{"caption":[],"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"inlineContent":[{"type":"text","text":"project package dependencies"}],"type":"strong"},{"type":"text","text":", add a new "},{"inlineContent":[{"type":"text","text":"dependency"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"inlineContent":[{"type":"text","text":"ouds-ios"}],"type":"emphasis"},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"inlineContent":[{"type":"text","text":"dependency rule"}],"type":"strong"},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2"}],"type":"paragraph"}],"type":"step","media":"tutorial-discovery-1-ouds-swift-package.png","code":null},{"caption":[{"inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"inlineContent":[{"type":"text","text":"OUDSSwiftUI"}],"type":"emphasis"}],"type":"paragraph"}],"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"inlineContent":[{"type":"text","text":"target"}],"type":"strong"},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"inlineContent":[{"type":"text","text":"OUDSThemesContract"}],"type":"emphasis"},{"type":"text","text":" library provides the main elements like the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesOrange"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesSosh"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSComponents"}],"type":"emphasis"},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSTokensRaw"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"OUDSTokensComponents"}],"type":"emphasis"},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSModules"}],"type":"emphasis"},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSFoundations"}],"type":"emphasis"},{"type":"text","text":" is dedicated to some utilities and shared logic."}],"type":"paragraph"}],"type":"step","media":"tutorial-discovery-1-ouds-libraries.png","code":null}],"title":"Import the Swift Package and the libraries"}]},{"kind":"assessments","assessments":[{"title":[{"inlineContent":[{"type":"text","text":"Which of these choices is correct?"}],"type":"paragraph"}],"choices":[{"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}]}],"isCorrect":true},{"justification":[{"type":"paragraph","inlineContent":[{"text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS.","type":"text"},{"text":" ","type":"text"},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay.","type":"text"}]}],"isCorrect":false},{"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS supports only SwiftUI.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}]}],"isCorrect":false}],"content":[],"type":"multiple-choice"},{"type":"multiple-choice","title":[{"inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}],"type":"paragraph"}],"content":[],"choices":[{"justification":[{"inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" product wraps all of them."}],"type":"paragraph"}],"content":[{"inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" if I am very lazy and don’t care about my app size.","type":"text"}],"type":"paragraph"}],"isCorrect":true},{"justification":[{"inlineContent":[{"text":"You need to chose the products the Swift package provides.","type":"text"}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}],"type":"paragraph"}],"isCorrect":false}]}],"anchor":"Check-Your-Understanding"},{"kind":"callToAction","action":{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]},"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"featuredEyebrow":"Tutorial","title":"Instanciate and inject a theme"}],"hierarchy":{"modules":[{"projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package