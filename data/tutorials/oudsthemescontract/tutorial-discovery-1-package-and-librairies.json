es","kind":"task"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources"}]},"sections":[{"title":"Swift Package integration","projectFiles":"OUDS-Discovery-Tutorial.zip","estimatedTimeInMinutes":10,"kind":"hero","image":"ic_unified_ds.png","chapter":"Import of the Swift Package and choose its librairies","backgroundImage":"ic_unified_ds.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}]}],"xcodeRequirement":"Xcode 26.4"},{"kind":"tasks","tasks":[{"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"type":"strong","inlineContent":[{"text":"project package dependencies","type":"text"}]},{"text":", add a new ","type":"text"},{"type":"strong","inlineContent":[{"text":"dependency","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"ouds-ios","type":"text"}]},{"text":" dependency.","type":"text"},{"text":" ","type":"text"},{"text":"You can then choose the ","type":"text"},{"type":"strong","inlineContent":[{"text":"dependency rule","type":"text"}]},{"text":" you want.","type":"text"},{"text":" ","type":"text"},{"text":"To know which version you need, you can have a look on the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"and also the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","type":"reference","isActive":true},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2"}]}],"caption":[],"media":"tutorial-discovery-1-ouds-swift-package.png","type":"step","code":null,"runtimePreview":null},{"runtimePreview":null,"type":"step","media":"tutorial-discovery-1-ouds-libraries.png","content":[{"inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"inlineContent":[{"text":"target","type":"text"}],"type":"strong"},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"inlineContent":[{"text":"OUDSThemesContract","type":"text"}],"type":"emphasis"},{"type":"text","text":" library provides the main elements like the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSThemesOrange","type":"text"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesSosh"}],"type":"emphasis"},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSThemesWireframe","type":"text"}],"type":"emphasis"},{"text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesOrangeCompact","type":"text"}]},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSComponents"}]},{"text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensRaw"}]},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OUDSTokensSemantic","type":"text"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OUDSTokensComponents","type":"text"}]},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"text":"middle level (semantic) or component levels (high level).","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSModules"}],"type":"emphasis"},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSFoundations"}]},{"text":" is dedicated to some utilities and shared logic.","type":"text"}],"type":"paragraph"}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add for example only the umbrella product merging all products mentioned above: ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]}]}],"code":null}],"title":"Import the Swift Package and the libraries","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"text":" ","type":"text"},{"text":"The package and the librairies must be added through Xcode.","type":"text"}]}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"anchor":"Import-the-Swift-Package-and-the-libraries"}]},{"kind":"assessments","assessments":[{"title":[{"type":"paragraph","inlineContent":[{"text":"Which of these choices is correct?","type":"text"}]}],"type":"multiple-choice","choices":[{"content":[{"inlineContent":[{"type":"text","text":"I can contribute to OUDS using pull request"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}]}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}],"type":"paragraph"}]},{"isCorrect":false,"content":[{"inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}],"type":"paragraph"}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}]}]}],"content":[]},{"title":[{"type":"paragraph","inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}]}],"content":[],"choices":[{"justification":[{"type":"paragraph","inlineContent":[{"text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" product wraps all of them."}]}],"content":[{"inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" if I am very lazy and don’t care about my app size.","type":"text"}],"type":"paragraph"}],"isCorrect":true},{"justification":[{"inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}],"type":"paragraph"}],"isCorrect":false}],"type":"multiple-choice"}],"anchor":"Check-Your-Understanding"},{"action":{"overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true},"featuredEyebrow":"Tutorial","kind":"callToAction","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"title":"Instanciate and inject a theme"}],"kind":"project","metadata":{"role":"project","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)","title":"Swift Package integration"},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"]}],"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further","type":"topic","kind":"project","title":"Going further with more resources","es