{"sections":[{"backgroundImage":"ic_unified_ds.png","estimatedTimeInMinutes":10,"chapter":"Import of the Swift Package and choose its librairies","kind":"hero","content":[{"inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"type":"paragraph"}],"projectFiles":"OUDS-Discovery-Tutorial.zip","xcodeRequirement":"Xcode 26.2","title":"Swift Package integration","image":"ic_unified_ds.png"},{"kind":"tasks","tasks":[{"anchor":"Import-the-Swift-Package-and-the-libraries","stepsSection":[{"code":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"type":"strong","inlineContent":[{"text":"project package dependencies","type":"text"}]},{"text":", add a new ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"dependency"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ouds-ios"}]},{"type":"text","text":" dependency."},{"text":" ","type":"text"},{"type":"text","text":"You can then choose the "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency rule"}]},{"type":"text","text":" you want."},{"type":"text","text":" "},{"text":"To know which version you need, you can have a look on the ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"and also the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2"}]}],"media":"tutorial-discovery-1-ouds-swift-package.png","runtimePreview":null,"type":"step","caption":[]},{"code":null,"content":[{"inlineContent":[{"text":"Once you downloaded the package, you will see several librairies are available.","type":"text"},{"text":" ","type":"text"},{"text":"They can be embeded inside your ","type":"text"},{"inlineContent":[{"text":"target","type":"text"}],"type":"strong"},{"text":" librairies.","type":"text"},{"text":" ","type":"text"},{"text":"Things are separated to let users integrate only what they need and embed the abre minimum of content.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesContract"}],"type":"emphasis"},{"text":" library provides the main elements like the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":". The theme contract is defined inside it.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesOrange"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesSosh"}],"type":"emphasis"},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSThemesWireframe","type":"text"}],"type":"emphasis"},{"text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSThemesOrangeCompact","type":"text"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSComponents","type":"text"}],"type":"emphasis"},{"text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensRaw"}]},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensComponents"}]},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"text":" ","type":"text"},{"text":"middle level (semantic) or component levels (high level).","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSModules"}]},{"text":" is for modules or rich components with extra logic.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSFoundations"}]},{"text":" is dedicated to some utilities and shared logic.","type":"text"}],"type":"paragraph"}],"media":"tutorial-discovery-1-ouds-libraries.png","runtimePreview":null,"type":"step","caption":[{"inlineContent":[{"text":"Add for example only the umbrella product merging all products mentioned above: ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]}],"type":"paragraph"}]}],"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"text":" ","type":"text"},{"text":"The package and the librairies must be added through Xcode.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing"}],"title":"Import the Swift Package and the libraries"}]},{"anchor":"Check-Your-Understanding","kind":"assessments","assessments":[{"type":"multiple-choice","choices":[{"content":[{"inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay.","type":"text"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS.","type":"text"},{"text":" ","type":"text"},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"text":"OUDS supports only SwiftUI.","type":"text"}],"type":"paragraph"}]}],"content":[],"title":[{"inlineContent":[{"text":"Which of these choices is correct?","type":"text"}],"type":"paragraph"}]},{"type":"multiple-choice","choices":[{"content":[{"inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"type":"codeVoice","code":"OUDSSwiftUI"},{"text":" if I am very lazy and don’t care about my app size.","type":"text"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed.","type":"text"},{"text":" ","type":"text"},{"text":"Even if we recommend to choose only the atomic products you need, the ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" product wraps all of them.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}],"type":"paragraph"}]}],"content":[],"title":[{"inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}],"type":"paragraph"}]}]},{"action":{"overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","isActive":true,"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"type":"reference"},"featuredEyebrow":"Tutorial","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"text":" ","type":"text"},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"kind":"callToAction","title":"Instanciate and inject a theme"}],"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"project","categoryPathComponent":"Table-Of-Contents-(discovery)","category":"Orange Unified Design System","title":"Swift Package integration"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"project","hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies"]],"modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutor