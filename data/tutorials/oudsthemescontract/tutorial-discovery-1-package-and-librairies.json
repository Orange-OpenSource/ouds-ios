{"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"project","sections":[{"estimatedTimeInMinutes":10,"chapter":"Import of the Swift Package and choose its librairies","backgroundImage":"ic_unified_ds.png","kind":"hero","title":"Swift Package integration","projectFiles":"OUDS-Discovery-Tutorial.zip","xcodeRequirement":"Xcode 26.4","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}]}],"image":"ic_unified_ds.png"},{"tasks":[{"contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}]}],"kind":"contentAndMedia"}],"title":"Import the Swift Package and the libraries","anchor":"Import-the-Swift-Package-and-the-libraries","stepsSection":[{"type":"step","caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"inlineContent":[{"text":"project package dependencies","type":"text"}],"type":"strong"},{"type":"text","text":", add a new "},{"inlineContent":[{"text":"dependency","type":"text"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"inlineContent":[{"text":"ouds-ios","type":"text"}],"type":"emphasis"},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"inlineContent":[{"text":"dependency rule","type":"text"}],"type":"strong"},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2"}]}],"code":null,"media":"tutorial-discovery-1-ouds-swift-package.png"},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"inlineContent":[{"text":"OUDSSwiftUI","type":"text"}],"type":"emphasis"}]}],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"inlineContent":[{"text":"target","type":"text"}],"type":"strong"},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"inlineContent":[{"text":"OUDSThemesContract","type":"text"}],"type":"emphasis"},{"type":"text","text":" library provides the main elements like the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSThemesOrange","type":"text"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSThemesSosh","type":"text"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSThemesWireframe","type":"text"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSThemesOrangeCompact","type":"text"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSComponents","type":"text"}],"type":"emphasis"},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSTokensRaw","type":"text"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"text":"OUDSTokensSemantic","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"text":"OUDSTokensComponents","type":"text"}],"type":"emphasis"},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSModules","type":"text"}],"type":"emphasis"},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSFoundations","type":"text"}],"type":"emphasis"},{"type":"text","text":" is dedicated to some utilities and shared logic."}]}],"code":null,"media":"tutorial-discovery-1-ouds-libraries.png"}]}],"kind":"tasks"},{"assessments":[{"title":[{"type":"paragraph","inlineContent":[{"text":"Which of these choices is correct?","type":"text"}]}],"type":"multiple-choice","choices":[{"isCorrect":true,"content":[{"inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}],"type":"paragraph"}]},{"isCorrect":false,"content":[{"inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"type":"text","text":"CarPlay specific cases are not scoped yet."}],"type":"paragraph"}]},{"isCorrect":false,"content":[{"inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"OUDS supports only SwiftUI.","type":"text"}],"type":"paragraph"}]}],"content":[]},{"title":[{"type":"paragraph","inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}]}],"type":"multiple-choice","choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" product wraps all of them."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}]}]}],"content":[]}],"kind":"assessments","anchor":"Check-Your-Understanding"},{"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"kind":"callToAction","action":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","type":"reference","overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"isActive":true},"featuredEyebrow":"Tutorial","title":"Instanciate and inject a theme"}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies"]],"modules":[{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discov