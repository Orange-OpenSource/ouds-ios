reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS"},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-tokens"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Use-of-view-modifiers"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Final-result"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Want-to-be-an-artist"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Typography,-view-modifiers-and-tokens"},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"]}],"metadata":{"title":"Swift Package integration","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)","role":"project"},"sections":[{"image":"ic_unified_ds.png","xcodeRequirement":"Xcode 26.3","backgroundImage":"ic_unified_ds.png","chapter":"Import of the Swift Package and choose its librairies","kind":"hero","estimatedTimeInMinutes":10,"title":"Swift Package integration","projectFiles":"OUDS-Discovery-Tutorial.zip","content":[{"inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"type":"paragraph"}]},{"kind":"tasks","tasks":[{"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"caption":[],"content":[{"inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"type":"strong","inlineContent":[{"type":"text","text":"project package dependencies"}]},{"type":"text","text":", add a new "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ouds-ios"}]},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency rule"}]},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API"},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2"}],"type":"paragraph"}],"type":"step","media":"tutorial-discovery-1-ouds-swift-package.png","runtimePreview":null,"code":null},{"caption":[{"inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"type":"strong","inlineContent":[{"type":"text","text":"target"}]},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesContract"}]},{"type":"text","text":" library provides the main elements like the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrange"}]},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesSosh"}]},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}]},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}]},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSComponents"}]},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensRaw"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensComponents"}]},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSModules"}]},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSFoundations"}]},{"type":"text","text":" is dedicated to some utilities and shared logic."}],"type":"paragraph"}],"type":"step","media":"tutorial-discovery-1-ouds-libraries.png","runtimePreview":null,"code":null}],"anchor":"Import-the-Swift-Package-and-the-libraries","title":"Import the Swift Package and the libraries"}]},{"kind":"assessments","assessments":[{"choices":[{"content":[{"inlineContent":[{"type":"text","text":"I can contribute to OUDS using pull request"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}],"type":"paragraph"}],"isCorrect":true},{"content":[{"inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"type":"text","text":"CarPlay specific cases are not scoped yet."}],"type":"paragraph"}],"isCorrect":false},{"content":[{"inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}],"type":"paragraph"}],"isCorrect":false}],"content":[],"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"text":"Which of these choices is correct?","type":"text"}]}]},{"choices":[{"content":[{"inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" product wraps all of them."}],"type":"paragraph"}],"isCorrect":true},{"content":[{"inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}],"type":"paragraph"}],"isCorrect":false}],"content":[],"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}]}]}],"anchor":"Check-Your-Understanding"},{"kind":"callToAction","featuredEyebrow":"Tutorial","action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","isActive":true,"overridingTitle":"Get started"},"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"title":"Instanciate and inject a theme"}],"kind":"project","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"OUDS-Discovery-Tutorial.zip":{"type":"download","checksum":"6cbe692f20ec50d6df4e53413a1e7e2692771bf4a7d05fe9486a4702ec9b0ef870e479060bba30047b0c26700df37dd8e5db8ed499e88670fcaa801d9e477a8f","url":"\/downloads\/OUDSThemesContract\/OUDS-Discovery-T