SThemesContract\/tutorial-discovery-6-going-further"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)"},"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"},"sections":[{"title":"Swift Package integration","image":"ic_unified_ds.png","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}]}],"backgroundImage":"ic_unified_ds.png","projectFiles":"OUDS-Discovery-Tutorial.zip","estimatedTimeInMinutes":10,"chapter":"Import of the Swift Package and choose its librairies","xcodeRequirement":"Xcode 26.4","kind":"hero"},{"tasks":[{"anchor":"Import-the-Swift-Package-and-the-libraries","stepsSection":[{"media":"tutorial-discovery-1-ouds-swift-package.png","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"type":"strong","inlineContent":[{"type":"text","text":"project package dependencies"}]},{"type":"text","text":", add a new "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ouds-ios"}]},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency rule"}]},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2"}]}],"caption":[],"type":"step","code":null},{"media":"tutorial-discovery-1-ouds-libraries.png","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"type":"strong","inlineContent":[{"type":"text","text":"target"}]},{"type":"text","text":" librairies."},{"text":" ","type":"text"},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesContract"}]},{"type":"text","text":" library provides the main elements like the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrange"}]},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesSosh"}]},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}]},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}]},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSComponents","type":"text"}]},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensRaw"}]},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OUDSTokensSemantic","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensComponents"}]},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"type":"text","text":" "},{"text":"middle level (semantic) or component levels (high level).","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSModules"}]},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSFoundations","type":"text"}]},{"type":"text","text":" is dedicated to some utilities and shared logic."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]}]}],"type":"step","code":null}],"title":"Import the Swift Package and the libraries","contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}]}],"kind":"contentAndMedia"}]}],"kind":"tasks"},{"assessments":[{"title":[{"inlineContent":[{"text":"Which of these choices is correct?","type":"text"}],"type":"paragraph"}],"content":[],"type":"multiple-choice","choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"I can contribute to OUDS using pull request"}]}],"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"type":"text","text":"CarPlay specific cases are not scoped yet."}]}],"isCorrect":false},{"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}]}],"justification":[{"inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}],"type":"paragraph"}]}]},{"content":[],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Which imports of the OUDS Swift Package products can I choose?"}]}],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" product wraps all of them."}]}]},{"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}]}]}],"type":"multiple-choice"}],"kind":"assessments","anchor":"Check-Your-Understanding"},{"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"title":"Instanciate and inject a theme","kind":"callToAction","featuredEyebrow":"Tutorial","action":{"type":"reference","overridingTitle":"Get started","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]}}],"metadata":{"category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)","title":"Swift Package integration","role":"project"},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"project","references":{"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Import-of-the-Swift-Package-and-choose-its-librairies":{"kind":"article","title":"Import of the Swift Package and choose its librairies","role":"article","type":"topic","url":"\/tut