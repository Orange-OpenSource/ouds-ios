{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)","role":"project","title":"Swift Package integration"},"sections":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}]}],"projectFiles":"OUDS-Discovery-Tutorial.zip","chapter":"Import of the Swift Package and choose its librairies","kind":"hero","estimatedTimeInMinutes":10,"backgroundImage":"ic_unified_ds.png","xcodeRequirement":"Xcode 26.4","image":"ic_unified_ds.png","title":"Swift Package integration"},{"tasks":[{"title":"Import the Swift Package and the libraries","contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"text":" ","type":"text"},{"text":"The package and the librairies must be added through Xcode.","type":"text"}]}],"kind":"contentAndMedia"}],"anchor":"Import-the-Swift-Package-and-the-libraries","stepsSection":[{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"inlineContent":[{"text":"project package dependencies","type":"text"}],"type":"strong"},{"text":", add a new ","type":"text"},{"inlineContent":[{"text":"dependency","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"inlineContent":[{"text":"ouds-ios","type":"text"}],"type":"emphasis"},{"text":" dependency.","type":"text"},{"text":" ","type":"text"},{"text":"You can then choose the ","type":"text"},{"inlineContent":[{"text":"dependency rule","type":"text"}],"type":"strong"},{"text":" you want.","type":"text"},{"text":" ","type":"text"},{"text":"To know which version you need, you can have a look on the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"and also the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2","type":"text"}]}],"caption":[],"media":"tutorial-discovery-1-ouds-swift-package.png","code":null,"runtimePreview":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Once you downloaded the package, you will see several librairies are available.","type":"text"},{"text":" ","type":"text"},{"text":"They can be embeded inside your ","type":"text"},{"inlineContent":[{"text":"target","type":"text"}],"type":"strong"},{"text":" librairies.","type":"text"},{"text":" ","type":"text"},{"text":"Things are separated to let users integrate only what they need and embed the abre minimum of content.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"inlineContent":[{"text":"OUDSThemesContract","type":"text"}],"type":"emphasis"},{"text":" library provides the main elements like the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":". The theme contract is defined inside it.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSThemesOrange","type":"text"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSThemesSosh","type":"text"}],"type":"emphasis"},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSThemesWireframe","type":"text"}],"type":"emphasis"},{"text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSThemesOrangeCompact","type":"text"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSComponents","type":"text"}],"type":"emphasis"},{"text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSTokensRaw","type":"text"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"text":"OUDSTokensSemantic","type":"text"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"OUDSTokensComponents","type":"text"}],"type":"emphasis"},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"text":" ","type":"text"},{"text":"middle level (semantic) or component levels (high level).","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSModules","type":"text"}],"type":"emphasis"},{"text":" is for modules or rich components with extra logic.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSFoundations","type":"text"}],"type":"emphasis"},{"text":" is dedicated to some utilities and shared logic.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add for example only the umbrella product merging all products mentioned above: ","type":"text"},{"inlineContent":[{"text":"OUDSSwiftUI","type":"text"}],"type":"emphasis"}]}],"media":"tutorial-discovery-1-ouds-libraries.png","code":null,"runtimePreview":null}]}],"kind":"tasks"},{"assessments":[{"title":[{"type":"paragraph","inlineContent":[{"text":"Which of these choices is correct?","type":"text"}]}],"type":"multiple-choice","content":[],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay.","type":"text"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS.","type":"text"},{"text":" ","type":"text"},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS supports only SwiftUI.","type":"text"}]}]}]},{"title":[{"type":"paragraph","inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}]}],"type":"multiple-choice","content":[],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" if I am very lazy and don’t care about my app size.","type":"text"}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed.","type":"text"},{"text":" ","type":"text"},{"text":"Even if we recommend to choose only the atomic products you need, the ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" product wraps all of them.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"None, only the Swift package dependency matter.","type":"text"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"text":"You need to chose the products the Swift package provides.","type":"text"}]}]}]}],"anchor":"Check-Your-Understanding","kind":"assessments"},{"title":"Instanciate and inject a theme","featuredEyebrow":"Tutorial","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"action":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","type":"reference","overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true},"kind":"callToAction"}],"kind":"project","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"},"hierarchy":{"modules":[{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies#Check-Your-Understanding"}],"reference