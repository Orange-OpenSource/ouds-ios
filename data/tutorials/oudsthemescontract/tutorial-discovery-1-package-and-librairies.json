s\/OUDSThemesContract\/tutorial-discovery-6-going-further#More-resources"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Go-further-with-more-ressources"}]},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"]}],"sections":[{"estimatedTimeInMinutes":10,"kind":"hero","xcodeRequirement":"Xcode 26.3","backgroundImage":"ic_unified_ds.png","chapter":"Import of the Swift Package and choose its librairies","projectFiles":"OUDS-Discovery-Tutorial.zip","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}]}],"image":"ic_unified_ds.png","title":"Swift Package integration"},{"tasks":[{"stepsSection":[{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"inlineContent":[{"type":"text","text":"project package dependencies"}],"type":"strong"},{"type":"text","text":", add a new "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency"}]},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"type":"emphasis","inlineContent":[{"text":"ouds-ios","type":"text"}]},{"text":" dependency.","type":"text"},{"text":" ","type":"text"},{"text":"You can then choose the ","type":"text"},{"inlineContent":[{"type":"text","text":"dependency rule"}],"type":"strong"},{"text":" you want.","type":"text"},{"text":" ","type":"text"},{"text":"To know which version you need, you can have a look on the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"and also the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","type":"reference","isActive":true},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2","type":"text"}]}],"caption":[],"media":"tutorial-discovery-1-ouds-swift-package.png","code":null,"runtimePreview":null},{"media":"tutorial-discovery-1-ouds-libraries.png","code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Once you downloaded the package, you will see several librairies are available.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"type":"strong","inlineContent":[{"text":"target","type":"text"}]},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesContract"}]},{"text":" library provides the main elements like the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":". The theme contract is defined inside it.","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrange"}]},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesSosh"}]},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}],"type":"emphasis"},{"text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}]},{"text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSComponents"}]},{"text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSTokensRaw","type":"text"}],"type":"emphasis"},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"OUDSTokensComponents","type":"text"}]},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSModules"}]},{"text":" is for modules or rich components with extra logic.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OUDSFoundations","type":"text"}]},{"text":" is dedicated to some utilities and shared logic.","type":"text"}]}],"caption":[{"inlineContent":[{"text":"Add for example only the umbrella product merging all products mentioned above: ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OUDSSwiftUI","type":"text"}]}],"type":"paragraph"}],"type":"step"}],"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"text":"The package and the librairies must be added through Xcode.","type":"text"}]}]}],"title":"Import the Swift Package and the libraries","anchor":"Import-the-Swift-Package-and-the-libraries"}],"kind":"tasks"},{"anchor":"Check-Your-Understanding","kind":"assessments","assessments":[{"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Which of these choices is correct?"}]}],"content":[],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}]}],"isCorrect":true},{"content":[{"inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS.","type":"text"},{"text":" ","type":"text"},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}],"type":"paragraph"}],"isCorrect":false},{"content":[{"inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}],"type":"paragraph"}],"isCorrect":false}]},{"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Which imports of the OUDS Swift Package products can I choose?"}]}],"content":[],"choices":[{"content":[{"inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" if I am very lazy and don’t care about my app size.","type":"text"}],"type":"paragraph"}],"justification":[{"type":"paragraph","inlineContent":[{"text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed.","type":"text"},{"text":" ","type":"text"},{"text":"Even if we recommend to choose only the atomic products you need, the ","type":"text"},{"type":"codeVoice","code":"OUDSSwiftUI"},{"text":" product wraps all of them.","type":"text"}]}],"isCorrect":true},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"You need to chose the products the Swift package provides.","type":"text"}]}],"isCorrect":false}]}]},{"featuredEyebrow":"Tutorial","title":"Instanciate and inject a theme","kind":"callToAction","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"action":{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true}}],"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","interfaceLanguage":"swift"},"kind":"project","references":{"OUDS-Discovery-Tutorial.zip":{"type":"download","identifier":"OUDS-Discovery-Tutorial.zip","url":"\/downloads\/OUDSThemesContract\/OUDS-Discovery-Tutorial.zip","checksum":"6cbe692f20ec50d6df4e53413a1e7e2692771bf4a7d05fe9486a4702ec9b0ef870e479060b