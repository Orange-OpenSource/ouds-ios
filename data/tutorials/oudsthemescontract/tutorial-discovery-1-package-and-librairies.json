ontract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies"]]},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","interfaceLanguage":"swift"},"sections":[{"projectFiles":"OUDS-Discovery-Tutorial.zip","image":"ic_unified_ds.png","xcodeRequirement":"Xcode 26.4","backgroundImage":"ic_unified_ds.png","kind":"hero","chapter":"Import of the Swift Package and choose its librairies","content":[{"inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"type":"paragraph"}],"estimatedTimeInMinutes":10,"title":"Swift Package integration"},{"kind":"tasks","tasks":[{"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"type":"strong","inlineContent":[{"text":"project package dependencies","type":"text"}]},{"type":"text","text":", add a new "},{"type":"strong","inlineContent":[{"text":"dependency","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"inlineContent":[{"type":"text","text":"ouds-ios"}],"type":"emphasis"},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"inlineContent":[{"type":"text","text":"dependency rule"}],"type":"strong"},{"type":"text","text":" you want."},{"text":" ","type":"text"},{"type":"text","text":"To know which version you need, you can have a look on the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true},{"text":" ","type":"text"},{"text":"and also the ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2","type":"text"}],"type":"paragraph"}],"media":"tutorial-discovery-1-ouds-swift-package.png","caption":[],"type":"step","code":null,"runtimePreview":null},{"content":[{"inlineContent":[{"text":"Once you downloaded the package, you will see several librairies are available.","type":"text"},{"type":"text","text":" "},{"text":"They can be embeded inside your ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"target"}]},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesContract"}]},{"type":"text","text":" library provides the main elements like the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrange"}]},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesSosh"}]},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}]},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}]},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSComponents"}]},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensRaw"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensComponents"}]},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSModules"}]},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSFoundations"}]},{"type":"text","text":" is dedicated to some utilities and shared logic."}],"type":"paragraph"}],"media":"tutorial-discovery-1-ouds-libraries.png","caption":[{"inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]}],"type":"paragraph"}],"type":"step","code":null,"runtimePreview":null}],"anchor":"Import-the-Swift-Package-and-the-libraries","title":"Import the Swift Package and the libraries","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"type":"text","text":" "},{"text":"The package and the librairies must be added through Xcode.","type":"text"}]}]}]}]},{"assessments":[{"content":[],"choices":[{"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}]}]},{"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS.","type":"text"},{"text":" ","type":"text"},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay.","type":"text"}]}]},{"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS supports only SwiftUI.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}]}]}],"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"text":"Which of these choices is correct?","type":"text"}]}]},{"content":[],"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}]}],"choices":[{"content":[{"inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" product wraps all of them."}],"type":"paragraph"}],"isCorrect":true},{"content":[{"inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}],"type":"paragraph"}],"isCorrect":false}]}],"kind":"assessments","anchor":"Check-Your-Understanding"},{"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"featuredEyebrow":"Tutorial","kind":"callToAction","action":{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"isActive":true},"title":"Instanciate and inject a theme"}],"metadata":{"category":"Orange Unified Design System","role":"project","title":"Swift Package integration","categoryPathComponent":"Table-Of-Contents-(discovery)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"]}],"kind":"project","references":{"https://github.com/Orange-OpenSource/ouds-ios/wiki/01-%E2%80%90-Available-API":{"titleInlineContent":[{"type":"text","text":"available API list"}],"url":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","type":