{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"},"sections":[{"title":"Swift Package integration","image":"ic_unified_ds.png","projectFiles":"OUDS-Discovery-Tutorial.zip","kind":"hero","estimatedTimeInMinutes":10,"backgroundImage":"ic_unified_ds.png","chapter":"Import of the Swift Package and choose its librairies","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}]}],"xcodeRequirement":"Xcode 26.4"},{"tasks":[{"contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"text":" ","type":"text"},{"text":"The package and the librairies must be added through Xcode.","type":"text"}]}],"mediaPosition":"trailing"}],"stepsSection":[{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"project package dependencies"}]},{"type":"text","text":", add a new "},{"inlineContent":[{"type":"text","text":"dependency"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"inlineContent":[{"text":"ouds-ios","type":"text"}],"type":"emphasis"},{"text":" dependency.","type":"text"},{"type":"text","text":" "},{"text":"You can then choose the ","type":"text"},{"type":"strong","inlineContent":[{"text":"dependency rule","type":"text"}]},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"and also the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true,"type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2"}]}],"media":"tutorial-discovery-1-ouds-swift-package.png","runtimePreview":null,"type":"step","code":null},{"caption":[{"inlineContent":[{"text":"Add for example only the umbrella product merging all products mentioned above: ","type":"text"},{"inlineContent":[{"text":"OUDSSwiftUI","type":"text"}],"type":"emphasis"}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"type":"strong","inlineContent":[{"type":"text","text":"target"}]},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesContract"}]},{"type":"text","text":" library provides the main elements like the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":". The theme contract is defined inside it.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesOrange"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSThemesSosh","type":"text"}],"type":"emphasis"},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}],"type":"emphasis"},{"text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSComponents"}]},{"text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensRaw"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensComponents"}]},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSModules","type":"text"}]},{"type":"text","text":" is for modules or rich components with extra logic."},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSFoundations"}]},{"type":"text","text":" is dedicated to some utilities and shared logic."}],"type":"paragraph"}],"media":"tutorial-discovery-1-ouds-libraries.png","runtimePreview":null,"type":"step","code":null}],"anchor":"Import-the-Swift-Package-and-the-libraries","title":"Import the Swift Package and the libraries"}],"kind":"tasks"},{"assessments":[{"content":[],"type":"multiple-choice","choices":[{"isCorrect":true,"content":[{"inlineContent":[{"type":"text","text":"I can contribute to OUDS using pull request"}],"type":"paragraph"}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"text":" ","type":"text"},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}]}],"isCorrect":false},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}]}],"isCorrect":false}],"title":[{"type":"paragraph","inlineContent":[{"text":"Which of these choices is correct?","type":"text"}]}]},{"content":[],"type":"multiple-choice","choices":[{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" product wraps all of them."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}],"type":"paragraph"}],"isCorrect":false}],"title":[{"type":"paragraph","inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}]}]}],"anchor":"Check-Your-Understanding","kind":"assessments"},{"title":"Instanciate and inject a theme","action":{"overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Get started"}]},"featuredEyebrow":"Tutorial","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"kind":"callToAction"}],"kind":"project","metadata":{"role":"project","title":"Swift Package integration","categoryPathComponent":"Table-Of-Contents-(discovery)","category":"Orange Unified Design System"},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"]}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","modules":[{"ref