{"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","interfaceLanguage":"swift"},"sections":[{"title":"Swift Package integration","xcodeRequirement":"Xcode 26.3","estimatedTimeInMinutes":10,"image":"ic_unified_ds.png","kind":"hero","backgroundImage":"ic_unified_ds.png","chapter":"Import of the Swift Package and choose its librairies","projectFiles":"OUDS-Discovery-Tutorial.zip","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"type":"text","text":" "},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}]}]},{"tasks":[{"stepsSection":[{"type":"step","code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"inlineContent":[{"type":"text","text":"project package dependencies"}],"type":"strong"},{"type":"text","text":", add a new "},{"inlineContent":[{"type":"text","text":"dependency"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"ouds-ios"}]},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency rule"}]},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true,"type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Let’s say you will use some beta version today, e.g. the version1.3.0-beta.2"}]}],"caption":[],"media":"tutorial-discovery-1-ouds-swift-package.png"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"inlineContent":[{"type":"text","text":"target"}],"type":"strong"},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"inlineContent":[{"text":"OUDSThemesContract","type":"text"}],"type":"emphasis"},{"type":"text","text":" library provides the main elements like the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesOrange"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesSosh"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSComponents"}],"type":"emphasis"},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSTokensRaw"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"OUDSTokensComponents"}],"type":"emphasis"},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSModules"}],"type":"emphasis"},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSFoundations"}],"type":"emphasis"},{"type":"text","text":" is dedicated to some utilities and shared logic."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"inlineContent":[{"type":"text","text":"OUDSSwiftUI"}],"type":"emphasis"}]}],"code":null,"runtimePreview":null,"type":"step","media":"tutorial-discovery-1-ouds-libraries.png"}],"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}]}]}],"title":"Import the Swift Package and the libraries","anchor":"Import-the-Swift-Package-and-the-libraries"}],"kind":"tasks"},{"assessments":[{"type":"multiple-choice","choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"I can contribute to OUDS using pull request"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}]}],"isCorrect":true},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"type":"text","text":"CarPlay specific cases are not scoped yet."}]}],"isCorrect":false},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}]}],"isCorrect":false}],"title":[{"inlineContent":[{"type":"text","text":"Which of these choices is correct?"}],"type":"paragraph"}],"content":[]},{"type":"multiple-choice","choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" product wraps all of them."}]}],"isCorrect":true},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}]}],"isCorrect":false}],"title":[{"inlineContent":[{"type":"text","text":"Which imports of the OUDS Swift Package products can I choose?"}],"type":"paragraph"}],"content":[]}],"anchor":"Check-Your-Understanding","kind":"assessments"},{"action":{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true,"overridingTitle":"Get started"},"featuredEyebrow":"Tutorial","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"title":"Instanciate and inject a theme","kind":"callToAction"}],"kind":"project","variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies"]],"modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/t