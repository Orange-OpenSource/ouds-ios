tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further"}]}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents"},"metadata":{"categoryPathComponent":"Table-Of-Contents","title":"Use your first OUDS components","category":"Orange Unified Design System","role":"project"},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"project","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components"},"sections":[{"xcodeRequirement":"Xcode 26","image":"ic_component_intro.png","kind":"hero","estimatedTimeInMinutes":30,"title":"Use your first OUDS components","chapter":"Use of first components provided by OUDS","content":[{"inlineContent":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"paragraph"}],"backgroundImage":"ic_component_intro.png"},{"kind":"tasks","tasks":[{"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"type":"text","text":" "},{"type":"text","text":"Feel free to style and design things as you want."}]}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"stepsSection":[{"media":null,"type":"step","code":"tutorial-3-1.swift","runtimePreview":null,"caption":[],"content":[{"inlineContent":[{"text":"First, prepare the ","type":"text"},{"code":"ContentView","type":"codeVoice"},{"text":" by adding inside it a ","type":"text"},{"code":"ScrollView","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now, let’s add radio buttons to let the user choose its gender."},{"type":"text","text":" "},{"type":"text","text":"The official components are "},{"code":"OUDSRadio","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSRadioItem","type":"codeVoice"},{"type":"text","text":", but the package has also a "},{"code":"OUDSRadioPicker","type":"codeVoice"},{"type":"text","text":" to implement quicky a group of radios."},{"type":"text","text":" "},{"type":"text","text":"This component can be replaced by your own."},{"type":"text","text":" "},{"type":"text","text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an "},{"code":"Hashable","type":"codeVoice"},{"type":"text","text":" thing shared through a "},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Inside a picker the user can select only one value, not zero."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add such picker with three items inside.","type":"text"}]}],"runtimePreview":"tutorial-3-2.png","code":"tutorial-3-2.swift","type":"step","media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"code":"OUDSCheckbox","type":"codeVoice"},{"type":"text","text":" which is a simple checkbox, and "},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"code":"State","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In some cases you may need to use "},{"code":"OUDSCheckboxIndeterminate","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSCheckboxItemIndeterminate","type":"codeVoice"},{"type":"text","text":" if you want a three-states checkbox."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add a checkbox item with only two states.","type":"text"}]}],"runtimePreview":"tutorial-3-3.png","code":"tutorial-3-3.swift","type":"step","media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Choose to add an instance of ","type":"text"},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"text":".","type":"text"}]}],"runtimePreview":"tutorial-3-4.png","code":"tutorial-3-4.swift","type":"step","media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone ("},{"code":"OUDSSwitch","type":"codeVoice"},{"type":"text","text":") or with texts ("},{"code":"OUDSSwitchItem","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"Just like the checkbox, the switch exposes its state through a "},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations.","type":"text"},{"text":" ","type":"text"},{"text":"You will then be able to see the automatic changes of colors when you switch the color scheme.","type":"text"}]}],"runtimePreview":"tutorial-3-5.png","code":"tutorial-3-5.swift","type":"step","media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the "},{"code":"OUDSLink","type":"codeVoice"},{"type":"text","text":" component can be integrated. It can be only with a text or also a chevron indicator."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add an ","type":"text"},{"code":"OUDSLink","type":"codeVoice"},{"text":" in the app and make it open the iOS documentation OUDS website.","type":"text"}]}],"runtimePreview":"tutorial-3-6.png","code":"tutorial-3-6.swift","type":"step","media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand."},{"type":"text","text":" "},{"type":"text","text":"You can find it with the "},{"code":"OUDSButton","type":"codeVoice"},{"type":"text","text":". Such button has an appearance changing its colors, and also a style (loading or not)."},{"type":"text","text":" "},{"type":"text","text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds.","type":"text"}]}],"runtimePreview":"tutorial-3-7.png","code":"tutorial-3-7.swift","type":"step","media":null}],"title":"Add basic components","anchor":"Add-basic-components"}]},{"anchor":"Check-Your-Understanding","kind":"assessments","assessments":[{"choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"text":"That is the reason why the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" is so important: it injects the theme as environment variable so that any component can get it to define its style.","type":"text"}]}]}],"type":"multiple-choice","title":[{"inlineContent":[{"text":"Does the developer using OUDS component need to manage the look and feel of the components?","type":"text"}],"type":"paragraph"}],"content":[]}]},{"kind":"callToAction","title":"Add more OUDS components","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"action":{"isActive":true,"type":"reference","overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components"},"featuredEyebrow":"Tutorial"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components"]}],"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Check-Your-Understanding","title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link"},"tutorial-3-1.swift":{"identifier":"tutorial-3-1.swift","content":["import OUDSSwiftUI","import SwiftUI","","\/\/ MARK: - App","","@main","struct OUDSTutorialSandboxApp: App {","    ","    let myTheme = OrangeTheme()","    ","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: myTheme) {","                ContentView()","            }","        }","    }","}","","\/\/ MARK: - Tutorial Content View","","struct ContentView: View {","    ","    var body: some View {","        ScrollView {","            Text(\"Hello OUDSThemesContract!\")","        }","    }"],"highlights":[{"line":25},{"line":26},{"line":27}],"syntax":"swift","fileName":"Tutorial.swift","fileType":"swift","type":"file"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Basic-structure-for-the-app":{"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","title":"Basic structure for the app","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","role":"pseudoSymbol","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components":{"estimatedTime":"30min","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components","title":"Use your first OUDS components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","role":"project","kind":"project"},"tutorial-3-6.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-6.png"}],"identifier":"tutorial-3-6.png","alt":"A radio picker, an horizontal divider, a checkbox item, a switch item and a link","type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further":{"estimatedTime":"10min","abstract":[{"type":"text","text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources."}],"type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further","title":"Going further with more resources","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further","role":"project","kind":"project"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Add-basic-components":{"abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Add-basic-components","title":"Add basic components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","role":"pseudoSymbol","kind":"section"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Typography,-view-modifiers-and-tokens":{"abstract":[],"type":"topic","url":"\/tutorials\/table-of-contents\/typography,-view-modifiers-and-tokens","title":"Typography, view modifiers and tokens","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","role":"article","kind":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework."}],"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","title":"Import the Swift Package and the libraries","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","role":"pseudoSymbol","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme":{"estimatedTime":"15min","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme","title":"Instanciate and inject a theme","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme","role":"project","kind":"project"},"tutorial-3-2.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-2.png"}],"identifier":"tutorial-3-2.png","alt":"A radio picker","type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies#Check-Your-Understanding","title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Use-of-view-modifiers":{"abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Use-of-view-modifiers","title":"Use of view modifiers","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers","role":"pseudoSymbol","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Check-Your-Understanding","title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Use-of-tokens":{"abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Use-of-tokens","title":"Use of tokens","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens","role":"pseudoSymbol","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"estimatedTime":"30min","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components","title":"Add more OUDS components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","role":"project","kind":"project"},"tutorial-3-7.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-7.png"}],"identifier":"tutorial-3-7.png","alt":"A radio picker, an horizontal divider, a checkbox item, a switch item, a link and a button","type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Check-Your-Understanding","title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link"},"tutorial-3-2.swift":{"highlights":[],"type":"file","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","","    var body: some View {","        OUDSRadioPicker(selection: $selectedGender,","                        radios: genderRadioValues(),","                        placement: .horizontal(false))","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"identifier":"tutorial-3-2.swift","fileType":"swift","fileName":"Content.swift","syntax":"swift"},"tutorial-3-4.swift":{"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selected