{"metadata":{"categoryPathComponent":"Table-Of-Contents","role":"project","category":"Orange Unified Design System","title":"Use your first OUDS components"},"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","interfaceLanguage":"swift"},"hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","modules":[{"projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies"},{"projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Preparation-of-the-theme"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","kind":"assessment"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS"},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS"},{"projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens","kind":"task"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens"},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources"}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS"]]},"sections":[{"image":"ic_component_intro.png","content":[{"inlineContent":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}],"type":"paragraph"}],"chapter":"Use of first components provided by OUDS","title":"Use your first OUDS components","backgroundImage":"ic_component_intro.png","kind":"hero","xcodeRequirement":"Xcode 26","estimatedTimeInMinutes":30},{"tasks":[{"stepsSection":[{"caption":[],"runtimePreview":null,"type":"step","content":[{"inlineContent":[{"text":"First, prepare the ","type":"text"},{"code":"ContentView","type":"codeVoice"},{"text":" by adding inside it a ","type":"text"},{"code":"ScrollView","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"code":"tutorial-3-1.swift","media":null},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Now, let’s add radio buttons to let the user choose its gender.","type":"text"},{"text":" ","type":"text"},{"text":"The official components are ","type":"text"},{"code":"OUDSRadio","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSRadioItem","type":"codeVoice"},{"text":", but the package has also a ","type":"text"},{"code":"OUDSRadioPicker","type":"codeVoice"},{"text":" to implement quicky a group of radios.","type":"text"},{"text":" ","type":"text"},{"text":"This component can be replaced by your own.","type":"text"},{"text":" ","type":"text"},{"text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":" thing shared through a ","type":"text"},{"code":"Binding","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Inside a picker the user can select only one value, not zero.","type":"text"}]}],"runtimePreview":"tutorial-3-2.png","code":"tutorial-3-2.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Add such picker with three items inside.","type":"text"}]}]},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: ","type":"text"},{"type":"codeVoice","code":"OUDSCheckbox"},{"text":" which is a simple checkbox, and ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"text":" which is a checkbox (duh!) with additional texts and icons.","type":"text"},{"text":" ","type":"text"},{"text":"The state of the checkbox is shared through a boolean ","type":"text"},{"type":"codeVoice","code":"State"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In some cases you may need to use ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxIndeterminate"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxItemIndeterminate"},{"text":" if you want a three-states checkbox.","type":"text"}]}],"runtimePreview":"tutorial-3-3.png","code":"tutorial-3-3.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Add a checkbox item with only two states.","type":"text"}]}]},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical.","type":"text"},{"text":" ","type":"text"},{"text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not.","type":"text"}]}],"runtimePreview":"tutorial-3-4.png","code":"tutorial-3-4.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Choose to add an instance of ","type":"text"},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"text":".","type":"text"}]}]},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone (","type":"text"},{"type":"codeVoice","code":"OUDSSwitch"},{"text":") or with texts (","type":"text"},{"type":"codeVoice","code":"OUDSSwitchItem"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"Just like the checkbox, the switch exposes its state through a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"}]}],"runtimePreview":"tutorial-3-5.png","code":"tutorial-3-5.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations.","type":"text"},{"text":" ","type":"text"},{"text":"You will then be able to see the automatic changes of colors when you switch the color scheme.","type":"text"}]}]},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the ","type":"text"},{"type":"codeVoice","code":"OUDSLink"},{"text":" component can be integrated. It can be only with a text or also a chevron indicator.","type":"text"}]}],"runtimePreview":"tutorial-3-6.png","code":"tutorial-3-6.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Add an ","type":"text"},{"type":"codeVoice","code":"OUDSLink"},{"text":" in the app and make it open the iOS documentation OUDS website.","type":"text"}]}]},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand.","type":"text"},{"text":" ","type":"text"},{"text":"You can find it with the ","type":"text"},{"type":"codeVoice","code":"OUDSButton"},{"text":". Such button has an appearance changing its colors, and also a style (loading or not).","type":"text"},{"text":" ","type":"text"},{"text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed.","type":"text"}]}],"runtimePreview":"tutorial-3-7.png","code":"tutorial-3-7.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds.","type":"text"}]}]}],"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"text":" ","type":"text"},{"type":"text","text":"Feel free to style and design things as you want."}]}]}],"anchor":"Add-basic-components","title":"Add basic components"}],"kind":"tasks"},{"kind":"assessments","assessments":[{"content":[],"choices":[{"content":[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases.","type":"text"}],"type":"paragraph"}]},{"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"That is the reason why the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}],"type":"paragraph"}],"content":[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}]}],"title":[{"inlineContent":[{"text":"Does the developer using OUDS component need to manage the look and feel of the components?","type":"text"}],"type":"paragraph"}],"type":"multiple-choice"}],"anchor":"Check-Your-Understanding"},{"kind":"callToAction","featuredEyebrow":"Tutorial","action":{"isActive":true,"overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","type":"reference"},"title":"Add more OUDS components","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}]}],"kind":"project","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components"]}],"references":{"tutorial-3-3.swift":{"syntax":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[{"line":20},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29}],"identifier":"tutorial-3-3.swift","fileType":"swift","fileName":"Content.swift","type":"file"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Typography,-view-modifiers-and-tokens":{"role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","abstract":[],"kind":"article","type":"topic","title":"Typography, view modifiers and tokens","url":"\/tutorials\/table-of-contents\/typography,-view-modifiers-and-tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Final-result":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","type":"section","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"title":"Final result","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Final-result","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Add-basic-components":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","kind":"section","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"type":"section","title":"Add basic components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Add-basic-components"},"tutorial-3-1.swift":{"type":"file","fileName":"Tutorial.swift","identifier":"tutorial-3-1.swift","syntax":"swift","content":["import OUDSSwiftUI","import SwiftUI","","\/\/ MARK: - App","","@main","struct OUDSTutorialSandboxApp: App {","    ","    let myTheme = OrangeTheme()","    ","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: myTheme) {","                ContentView()","            }","        }","    }","}","","\/\/ MARK: - Tutorial Content View","","struct ContentView: View {","    ","    var body: some View {","        ScrollView {","            Text(\"Hello OUDSThemesContract!\")","        }","    }"],"fileType":"swift","highlights":[{"line":25},{"line":26},{"line":27}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further":{"title":"Going further with more resources","role":"project","abstract":[{"text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources.","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further","estimatedTime":"10min","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further","kind":"project"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Check-Your-Understanding":{"titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Check-Your-Understanding","title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents":{"title":"Swift Package iOS Tutorial","role":"overview","abstract":[{"text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package.","type":"text"},{"text":" ","type":"text"},{"text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework.","type":"text"},{"text":" ","type":"text"},{"text":"Theme, components, tokens… everything will be introduced!","type":"text"}],"url":"\/tutorials\/table-of-contents","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","kind":"overview"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies":{"title":"Swift Package integration","role":"project","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies","estimatedTime":"10min","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies","kind":"project"},"tutorial-3-3.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-3.png"}],"identifier":"tutorial-3-3.png","type":"image","alt":"A radio picker and a checkbox item"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Basic-structure-for-the-app":{"kind":"section","title":"Basic structure for the app","type":"section","role":"pseudoSymbol","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Go-further-with-more-ressources":{"role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","type":"topic","abstract":[],"title":"Go further with more ressources","url":"\/tutorials\/table-of-contents\/go-further-with-more-ressources","kind":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Check-Your-Understanding":{"titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Check-Your-Understanding","title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Add-basic-components":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components","abstract":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}],"kind":"section","title":"Add basic components","type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Add-basic-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"type":"topic","title":"Add more OUDS components","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components","role":"project","estimatedTime":"30min","kind":"project"},"tutorial-3-6.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-6.png"}],"identifier":"tutorial-3-6.png","type":"image","alt":"A radio picker, an horizontal divider, a checkbox item, a switch item and a link"},"tutorial-3-5.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-5.png"}],"identifier":"tutorial-3-5.png","type":"image","alt":"A radio picker, an horizontal divider, a checkbox item and a switch item"},"tutorial-3-7.swift":{"type":"file","fileName":"Content.swift","identifier":"tutorial-3-7.swift","syntax":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","","            OUDSButton(text: \"Create my profile\",","                       appearance: .strong,","                       style: creatingProfile ? .loading : .default)","            {","                creatingProfile = true","                DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                    creatingProfile = false","                }","            }.disabled(!termsAccepted)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileType":"swift","highlights":[{"line":22},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Check-Your-Understanding":{"titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding","type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Check-Your-Understanding","title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Check-Your-Understanding":{"titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Check-Your-Understanding","type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies#Check-Your-Understanding","title":"Check Your Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Use-of-tokens":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"kind":"section","title":"Use of tokens","type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Use-of-tokens"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Richer-and-more-original-components-of-OUDS":{"role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS","abstract":[],"kind":"article","title":"Richer and more original components of OUDS","type":"topic","url":"\/tutorials\/table-of-contents\/richer-and-more-original-components-of-ouds"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Preparation-of-the-theme":{"role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Preparation-of-the-theme","abstract":[],"kind":"article","title":"Preparation of the theme","type":"topic","url":"\/tutorials\/table-of-contents\/preparation-of-the-theme"},"tutorial-3-4.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-4.png"}],"identifier":"tutorial-3-4.png","type":"image","alt":"A radio picker, an horizontal divider and a checkbox item"},"tutorial-3-2.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-2.png"}],"identifier":"tutorial-3-2.png","type":"image","alt":"A radio picker"},"tutorial-3-4.swift":{"type":"file","fileName":"Content.swift","identifier":"tutorial-3-4.swift","syntax":"swift","content":["\/\/","\/\/ Software