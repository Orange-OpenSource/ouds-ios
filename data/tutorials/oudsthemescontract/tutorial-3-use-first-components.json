{"metadata":{"category":"Orange Unified Design System","title":"Use your first OUDS components","role":"project","categoryPathComponent":"Table-Of-Contents"},"sections":[{"image":"ic_component_intro.png","title":"Use your first OUDS components","backgroundImage":"ic_component_intro.png","chapter":"Use of first components provided by OUDS","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}]}],"estimatedTimeInMinutes":30,"xcodeRequirement":"Xcode 26","kind":"hero"},{"kind":"tasks","tasks":[{"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"First, prepare the "},{"type":"codeVoice","code":"ContentView"},{"type":"text","text":" by adding inside it a "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":"."}]}],"caption":[],"code":"tutorial-3-1.swift","media":null,"runtimePreview":null,"type":"step"},{"runtimePreview":"tutorial-3-2.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now, let’s add radio buttons to let the user choose its gender."},{"type":"text","text":" "},{"type":"text","text":"The official components are "},{"type":"codeVoice","code":"OUDSRadio"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioItem"},{"type":"text","text":", but the package has also a "},{"type":"codeVoice","code":"OUDSRadioPicker"},{"type":"text","text":" to implement quicky a group of radios."},{"type":"text","text":" "},{"type":"text","text":"This component can be replaced by your own."},{"text":" ","type":"text"},{"text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":" thing shared through a ","type":"text"},{"code":"Binding","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Inside a picker the user can select only one value, not zero.","type":"text"}]}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add such picker with three items inside."}]}],"media":null,"code":"tutorial-3-2.swift"},{"runtimePreview":"tutorial-3-3.png","content":[{"inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" which is a simple checkbox, and "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"type":"codeVoice","code":"State"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In some cases you may need to use "},{"type":"codeVoice","code":"OUDSCheckboxIndeterminate"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSCheckboxItemIndeterminate"},{"type":"text","text":" if you want a three-states checkbox."}],"type":"paragraph"}],"type":"step","caption":[{"inlineContent":[{"type":"text","text":"Add a checkbox item with only two states."}],"type":"paragraph"}],"media":null,"code":"tutorial-3-3.swift"},{"runtimePreview":"tutorial-3-4.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}]}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Choose to add an instance of ","type":"text"},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"text":".","type":"text"}]}],"media":null,"code":"tutorial-3-4.swift"},{"runtimePreview":"tutorial-3-5.png","content":[{"type":"paragraph","inlineContent":[{"text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone (","type":"text"},{"type":"codeVoice","code":"OUDSSwitch"},{"text":") or with texts (","type":"text"},{"type":"codeVoice","code":"OUDSSwitchItem"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"Just like the checkbox, the switch exposes its state through a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"}]}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations."},{"type":"text","text":" "},{"type":"text","text":"You will then be able to see the automatic changes of colors when you switch the color scheme."}]}],"media":null,"code":"tutorial-3-5.swift"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the ","type":"text"},{"type":"codeVoice","code":"OUDSLink"},{"text":" component can be integrated. It can be only with a text or also a chevron indicator.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add an ","type":"text"},{"code":"OUDSLink","type":"codeVoice"},{"text":" in the app and make it open the iOS documentation OUDS website.","type":"text"}]}],"media":null,"runtimePreview":"tutorial-3-6.png","code":"tutorial-3-6.swift"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand."},{"type":"text","text":" "},{"type":"text","text":"You can find it with the "},{"type":"codeVoice","code":"OUDSButton"},{"type":"text","text":". Such button has an appearance changing its colors, and also a style (loading or not)."},{"type":"text","text":" "},{"type":"text","text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds.","type":"text"}]}],"media":null,"runtimePreview":"tutorial-3-7.png","code":"tutorial-3-7.swift"}],"title":"Add basic components","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"type":"text","text":" "},{"type":"text","text":"Feel free to style and design things as you want."}],"type":"paragraph"}]}],"anchor":"Add-basic-components"}]},{"assessments":[{"content":[],"title":[{"type":"paragraph","inlineContent":[{"text":"Does the developer using OUDS component need to manage the look and feel of the components?","type":"text"}]}],"choices":[{"justification":[{"type":"paragraph","inlineContent":[{"text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases.","type":"text"}]}],"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}]},{"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"That is the reason why the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}]}],"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}]}],"type":"multiple-choice"}],"kind":"assessments","anchor":"Check-Your-Understanding"},{"abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"kind":"callToAction","action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true,"overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","type":"reference"},"title":"Add more OUDS components","featuredEyebrow":"Tutorial"}],"kind":"project","hierarchy":{"modules":[{"projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies"},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Preparation-of-the-theme"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","kind":"assessment"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS"},{"projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding","kind":"assessment"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources","kind":"task"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components"]}],"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"tutorial-3-7.png":{"variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-3-7.png","traits":["1x","light"]}],"identifier":"tutorial-3-7.png","alt":"A radio picker, an horizontal divider, a checkbox item, a switch item, a link and a button","type":"image"},"tutorial-3-7.swift":{"fileName":"Content.swift","syntax":"swift","fileType":"swift","identifier":"tutorial-3-7.swift","type":"file","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","","            OUDSButton(text: \"Create my profile\",","                       appearance: .strong,","                       style: creatingProfile ? .loading : .default)","            {","                creatingProfile = true","                DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                    creatingProfile = false","                }","            }.disabled(!termsAccepted)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[{"line":22},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Check-Your-Understanding":{"title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Check-Your-Understanding","type":"link"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things":{"title":"Styling things","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things","estimatedTime":"30min","role":"project","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Typography,-view-modifiers-and-tokens":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","type":"topic","url":"\/tutorials\/table-of-contents\/typography,-view-modifiers-and-tokens","kind":"article","abstract":[],"role":"article","title":"Typography, view modifiers and tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Use-of-tokens":{"abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Use-of-tokens","kind":"section","title":"Use of tokens","type":"section","role":"pseudoSymbol"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme":{"type":"topic","title":"Instanciate and inject a theme","role":"project","kind":"project","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme","estimatedTime":"15min","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Add-basic-components":{"role":"pseudoSymbol","title":"Add basic components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"section","kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Add-basic-components"},"tutorial-3-6.png":{"identifier":"tutorial-3-6.png","type":"image","alt":"A radio picker, an horizontal divider, a checkbox item, a switch item and a link","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-3-6.png","traits":["1x","light"]}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"role":"project","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"type":"topic","title":"Add more OUDS components","estimatedTime":"30min","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Add-basic-components":{"title":"Add basic components","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"kind":"section","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Add-basic-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Basic-structure-for-the-app":{"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"role":"pseudoSymbol","type":"section","title":"Basic structure for the app","kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app"},"tutorial-3-6.swift":{"identifier":"tutorial-3-6.swift","fileName":"Content.swift","fileType":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"syntax":"swift","type":"file","highlights":[{"line":23},{"line":24},{"line":36},{"line":37},{"line":38},{"line":39}]},"tutorial-3-4.swift":{"syntax":"swift","type":"file","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))",""," 