{"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Preparation-of-the-theme","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further"}]}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents"},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","interfaceLanguage":"swift"},"sections":[{"backgroundImage":"ic_component_intro.png","xcodeRequirement":"Xcode 26","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}]}],"chapter":"Use of first components provided by OUDS","image":"ic_component_intro.png","kind":"hero","estimatedTimeInMinutes":30,"title":"Use your first OUDS components"},{"tasks":[{"contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We will work on a kind of formular using main OUDS components."},{"text":" ","type":"text"},{"text":"Feel free to style and design things as you want.","type":"text"}]}],"kind":"contentAndMedia"}],"anchor":"Add-basic-components","stepsSection":[{"media":null,"type":"step","caption":[],"code":"tutorial-3-1.swift","content":[{"inlineContent":[{"type":"text","text":"First, prepare the "},{"type":"codeVoice","code":"ContentView"},{"text":" by adding inside it a ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":".","type":"text"}],"type":"paragraph"}],"runtimePreview":null},{"content":[{"inlineContent":[{"text":"Now, let’s add radio buttons to let the user choose its gender.","type":"text"},{"text":" ","type":"text"},{"text":"The official components are ","type":"text"},{"type":"codeVoice","code":"OUDSRadio"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSRadioItem"},{"type":"text","text":", but the package has also a "},{"type":"codeVoice","code":"OUDSRadioPicker"},{"type":"text","text":" to implement quicky a group of radios."},{"text":" ","type":"text"},{"text":"This component can be replaced by your own.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":" thing shared through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Inside a picker the user can select only one value, not zero."}],"type":"paragraph"}],"type":"step","media":null,"caption":[{"inlineContent":[{"text":"Add such picker with three items inside.","type":"text"}],"type":"paragraph"}],"code":"tutorial-3-2.swift","runtimePreview":"tutorial-3-2.png"},{"content":[{"inlineContent":[{"type":"text","text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" which is a simple checkbox, and "},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"code":"State","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In some cases you may need to use "},{"code":"OUDSCheckboxIndeterminate","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSCheckboxItemIndeterminate","type":"codeVoice"},{"type":"text","text":" if you want a three-states checkbox."}],"type":"paragraph"}],"type":"step","media":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"Add a checkbox item with only two states.","type":"text"}]}],"code":"tutorial-3-3.swift","runtimePreview":"tutorial-3-3.png"},{"media":null,"runtimePreview":"tutorial-3-4.png","code":"tutorial-3-4.swift","caption":[{"type":"paragraph","inlineContent":[{"text":"Choose to add an instance of ","type":"text"},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"text":".","type":"text"}]}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}]}]},{"media":null,"runtimePreview":"tutorial-3-5.png","code":"tutorial-3-5.swift","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations."},{"type":"text","text":" "},{"type":"text","text":"You will then be able to see the automatic changes of colors when you switch the color scheme."}]}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone ("},{"code":"OUDSSwitch","type":"codeVoice"},{"type":"text","text":") or with texts ("},{"type":"codeVoice","code":"OUDSSwitchItem"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"Just like the checkbox, the switch exposes its state through a "},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."}]}]},{"type":"step","code":"tutorial-3-6.swift","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add an "},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" in the app and make it open the iOS documentation OUDS website."}]}],"media":null,"runtimePreview":"tutorial-3-6.png","content":[{"type":"paragraph","inlineContent":[{"text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the ","type":"text"},{"code":"OUDSLink","type":"codeVoice"},{"text":" component can be integrated. It can be only with a text or also a chevron indicator.","type":"text"}]}]},{"type":"step","code":"tutorial-3-7.swift","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds."}]}],"media":null,"runtimePreview":"tutorial-3-7.png","content":[{"type":"paragraph","inlineContent":[{"text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand.","type":"text"},{"text":" ","type":"text"},{"text":"You can find it with the ","type":"text"},{"type":"codeVoice","code":"OUDSButton"},{"text":". Such button has an appearance changing its colors, and also a style (loading or not).","type":"text"},{"text":" ","type":"text"},{"text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed.","type":"text"}]}]}],"title":"Add basic components"}],"kind":"tasks"},{"kind":"assessments","assessments":[{"content":[],"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Does the developer using OUDS component need to manage the look and feel of the components?"}]}],"choices":[{"justification":[{"inlineContent":[{"text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases.","type":"text"}],"type":"paragraph"}],"isCorrect":false,"content":[{"inlineContent":[{"type":"text","text":"Yes"}],"type":"paragraph"}]},{"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"That is the reason why the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}]}],"isCorrect":true,"content":[{"inlineContent":[{"text":"No","type":"text"}],"type":"paragraph"}]}]}],"anchor":"Check-Your-Understanding"},{"kind":"callToAction","featuredEyebrow":"Tutorial","action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference","overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","isActive":true},"abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"title":"Add more OUDS components"}],"kind":"project","metadata":{"categoryPathComponent":"Table-Of-Contents","role":"project","category":"Orange Unified Design System","title":"Use your first OUDS components"},"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Add-basic-components":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Add-basic-components","role":"pseudoSymbol","title":"Add basic components","kind":"section","type":"section","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components":{"estimatedTime":"30min","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components","role":"project","title":"Use your first OUDS components","kind":"project","type":"topic","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Go-further-with-more-ressources":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","url":"\/tutorials\/table-of-contents\/go-further-with-more-ressources","role":"article","title":"Go further with more ressources","kind":"article","type":"topic","abstract":[]},"tutorial-3-1.swift":{"fileName":"Tutorial.swift","fileType":"swift","identifier":"tutorial-3-1.swift","syntax":"swift","content":["import OUDSSwiftUI","import SwiftUI","","\/\/ MARK: - App","","@main","struct OUDSTutorialSandboxApp: App {","    ","    let myTheme = OrangeTheme()","    ","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: myTheme) {","                ContentView()","            }","        }","    }","}","","\/\/ MARK: - Tutorial Content View","","struct ContentView: View {","    ","    var body: some View {","        ScrollView {","            Text(\"Hello OUDSThemesContract!\")","        }","    }"],"highlights":[{"line":25},{"line":26},{"line":27}],"type":"file"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies","url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies","kind":"project","type":"topic","title":"Swift Package integration","role":"project","estimatedTime":"10min","abstract":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"type":"text","text":" "},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework.","type":"text"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Check-Your-Understanding":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Check-Your-Understanding","title":"Check Your Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}]},"tutorial-3-5.swift":{"fileName":"Content.swift","fileType":"swift","identifier":"tutorial-3-5.swift","syntax":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[{"line":21},{"line":32},{"line":33},{"line":34}],"type":"file"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further#More-resources":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources","url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further#More-resources","kind":"section","type":"section","title":"More resources","role":"pseudoSymbol","abstract":[{"type":"text","text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Check-Your-Understanding":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Check-Your-Understanding","type":"link","title":"Check Your Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Check-Your-Understanding":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Check-Your-Understanding","title":"Check Your Understanding"},"Xcode 26":{"type":"xcodeRequirement","title":"Xcode 26","identifier":"Xcode 26","url":"https:\/\/developer.apple.com\/download\/"},"tutorial-3-2.png":{"identifier":"tutorial-3-2.png","type":"image","alt":"A radio picker","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-2.png"}]},"tutorial-3-6.swift":{"identifier":"tutorial-3-6.swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[{"line":23},{"line":24},{"line":36},{"line":37},{"line":38},{"line":39}],"syntax":"swift","fileType":"swift","type":"file"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Richer-and-more-original-components-of-OUDS":{"type":"topic","title":"Richer and more original components of OUDS","role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS","abstract":[],"kind":"article","url":"\/tutorials\/table-of-contents\/richer-and-more-original-components-of-ouds"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Import-of-the-Swift-Package-and-choose-its-librairies":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies","url":"\/tutorials\/table-of-contents\/import-of-the-swift-package-and-choose-its-librairies","kind":"article","type":"topic","title":"Import of the Swift Package and choose its librairies","role":"article","abstract":[]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Check-Your-Understanding","title":"Check Your Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework.","type":"text"}],"kind":"section","type":"section","title":"Import the Swift Package and the libraries","url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Basic-structure-for-the-app":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","kind":"section","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"text":" ","type":"text"},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","title":"Basic structure for the app"},"tutorial-3-7.png":{"alt":"A radio picker, an horizontal divider, a checkbox item, a switch item, a link and a button","type":"image","identifier":"tutorial-3-7.png","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-3-7.png","traits":["1x","light"]}]},"tutorial-3-2.swift":{"type":"file","identifier":"tutorial-3-2.swift","fileType":"swift","syntax":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","","    var body: some View {","        OUDSRadioPicker(selection: $selectedGender,","                        radios: genderRadioValues(),","                        placement: .horizontal(false))","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[],"fileName":"Content.swift"},"tutorial-3-3.png":{"variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-3-3.png","traits":["1x","light"]}],"type":"image","identifier":"tutorial-3-3.png","alt":"A radio picker and a checkbox item"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Typography,-view-modifiers-and-tokens":{"type":"topic","title":"Typography, view modifiers and tokens","role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","abstract":[],"kind":"article","url":"\/tutorials\/table-of-contents\/typography,-view-modifiers-and-tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further":{"kind":"project","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further","url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further","estimatedTime":"10min","role":"project","abstract":[{"type":"text","text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources."}],"title":"Going further with more resources"},"tutorial-3-7.swift":{"type":"file","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyright