{"hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","modules":[{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies"},{"projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Preparation-of-the-theme"},{"projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","kind":"task"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Want-to-be-an-artist"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further"}]}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS"]]},"metadata":{"role":"project","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents","title":"Use your first OUDS components"},"sections":[{"chapter":"Use of first components provided by OUDS","kind":"hero","backgroundImage":"ic_component_intro.png","estimatedTimeInMinutes":30,"xcodeRequirement":"Xcode 26","title":"Use your first OUDS components","content":[{"inlineContent":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"paragraph"}],"image":"ic_component_intro.png"},{"kind":"tasks","tasks":[{"anchor":"Add-basic-components","stepsSection":[{"runtimePreview":null,"code":"tutorial-3-1.swift","caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"First, prepare the "},{"type":"codeVoice","code":"ContentView"},{"type":"text","text":" by adding inside it a "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":"."}]}],"media":null},{"runtimePreview":"tutorial-3-2.png","caption":[{"inlineContent":[{"type":"text","text":"Add such picker with three items inside."}],"type":"paragraph"}],"code":"tutorial-3-2.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now, let’s add radio buttons to let the user choose its gender."},{"type":"text","text":" "},{"type":"text","text":"The official components are "},{"code":"OUDSRadio","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSRadioItem","type":"codeVoice"},{"text":", but the package has also a ","type":"text"},{"code":"OUDSRadioPicker","type":"codeVoice"},{"type":"text","text":" to implement quicky a group of radios."},{"type":"text","text":" "},{"text":"This component can be replaced by your own.","type":"text"},{"text":" ","type":"text"},{"text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":" thing shared through a ","type":"text"},{"code":"Binding","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Inside a picker the user can select only one value, not zero.","type":"text"}]}],"media":null,"type":"step"},{"runtimePreview":"tutorial-3-3.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a checkbox item with only two states."}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: ","type":"text"},{"type":"codeVoice","code":"OUDSCheckbox"},{"text":" which is a simple checkbox, and ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":" which is a checkbox (duh!) with additional texts and icons."},{"type":"text","text":" "},{"type":"text","text":"The state of the checkbox is shared through a boolean "},{"code":"State","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In some cases you may need to use ","type":"text"},{"code":"OUDSCheckboxIndeterminate","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxItemIndeterminate"},{"type":"text","text":" if you want a three-states checkbox."}]}],"code":"tutorial-3-3.swift","type":"step","media":null},{"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Choose to add an instance of "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":"."}]}],"type":"step","media":null,"code":"tutorial-3-4.swift","runtimePreview":"tutorial-3-4.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}]}]},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone (","type":"text"},{"code":"OUDSSwitch","type":"codeVoice"},{"text":") or with texts (","type":"text"},{"code":"OUDSSwitchItem","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"Just like the checkbox, the switch exposes its state through a ","type":"text"},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations."},{"type":"text","text":" "},{"type":"text","text":"You will then be able to see the automatic changes of colors when you switch the color scheme."}]}],"code":"tutorial-3-5.swift","runtimePreview":"tutorial-3-5.png","media":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the ","type":"text"},{"code":"OUDSLink","type":"codeVoice"},{"type":"text","text":" component can be integrated. It can be only with a text or also a chevron indicator."}]}],"runtimePreview":"tutorial-3-6.png","code":"tutorial-3-6.swift","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add an "},{"code":"OUDSLink","type":"codeVoice"},{"text":" in the app and make it open the iOS documentation OUDS website.","type":"text"}]}],"media":null},{"caption":[{"inlineContent":[{"type":"text","text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds."}],"type":"paragraph"}],"media":null,"content":[{"inlineContent":[{"text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand.","type":"text"},{"text":" ","type":"text"},{"text":"You can find it with the ","type":"text"},{"type":"codeVoice","code":"OUDSButton"},{"text":". Such button has an appearance changing its colors, and also a style (loading or not).","type":"text"},{"text":" ","type":"text"},{"text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed.","type":"text"}],"type":"paragraph"}],"code":"tutorial-3-7.swift","runtimePreview":"tutorial-3-7.png","type":"step"}],"title":"Add basic components","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"We will work on a kind of formular using main OUDS components.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Feel free to style and design things as you want."}]}],"mediaPosition":"trailing"}]}]},{"kind":"assessments","assessments":[{"type":"multiple-choice","content":[],"choices":[{"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],"justification":[{"inlineContent":[{"text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases.","type":"text"}],"type":"paragraph"}]},{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"text":"No","type":"text"}]}],"justification":[{"inlineContent":[{"text":"That is the reason why the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" is so important: it injects the theme as environment variable so that any component can get it to define its style.","type":"text"}],"type":"paragraph"}]}],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Does the developer using OUDS component need to manage the look and feel of the components?"}]}]}],"anchor":"Check-Your-Understanding"},{"title":"Add more OUDS components","kind":"callToAction","featuredEyebrow":"Tutorial","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"action":{"isActive":true,"type":"reference","overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","overridingTitleInlineContent":[{"type":"text","text":"Get started"}]}}],"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"project","schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components"},"references":{"doc://OUDSThemesContract/tutorials/Table-Of-Contents":{"title":"Swift Package iOS Tutorial","url":"\/tutorials\/table-of-contents","role":"overview","abstract":[{"text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework."},{"type":"text","text":" "},{"type":"text","text":"Theme, components, tokens… everything will be introduced!"}],"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","kind":"overview"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Final-result":{"kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Final-result","title":"Final result","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","role":"pseudoSymbol","type":"section"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Preparation-of-the-theme":{"url":"\/tutorials\/table-of-contents\/preparation-of-the-theme","type":"topic","role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Preparation-of-the-theme","abstract":[],"title":"Preparation of the theme","kind":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components":{"kind":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components","title":"Use your first OUDS components","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","role":"project","type":"topic","estimatedTime":"30min"},"tutorial-3-4.swift":{"identifier":"tutorial-3-4.swift","type":"file","highlights":[{"line":28},{"line":29}],"fileType":"swift","syntax":"swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"]},"tutorial-3-1.swift":{"identifier":"tutorial-3-1.swift","type":"file","highlights":[{"line":25},{"line":26},{"line":27}],"fileType":"swift","syntax":"swift","fileName":"Tutorial.swift","content":["import OUDSSwiftUI","import SwiftUI","","\/\/ MARK: - App","","@main","struct OUDSTutorialSandboxApp: App {","    ","    let myTheme = OrangeTheme()","    ","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: myTheme) {","                ContentView()","            }","        }","    }","}","","\/\/ MARK: - Tutorial Content View","","struct ContentView: View {","    ","    var body: some View {","        ScrollView {","            Text(\"Hello OUDSThemesContract!\")","        }","    }"]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Import-of-the-Swift-Package-and-choose-its-librairies":{"title":"Import of the Swift Package and choose its librairies","url":"\/tutorials\/table-of-contents\/import-of-the-swift-package-and-choose-its-librairies","role":"article","abstract":[],"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies","kind":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Use-of-view-modifiers":{"kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Use-of-view-modifiers","title":"Use of view modifiers","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers","role":"pseudoSymbol","type":"section"},"tutorial-3-7.png":{"alt":"A radio picker, an horizontal divider, a checkbox item, a switch item, a link and a button","identifier":"tutorial-3-7.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-7.png"}],"type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Add-basic-components":{"title":"Add basic components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Add-basic-components","role":"pseudoSymbol","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"type":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","kind":"section"},"tutorial-3-5.png":{"alt":"A radio picker, an horizontal divider, a checkbox item and a switch item","identifier":"tutorial-3-5.png","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-3-5.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Richer-and-more-original-components-of-OUDS":{"kind":"article","url":"\/tutorials\/table-of-contents\/richer-and-more-original-components-of-ouds","title":"Richer and more original components of OUDS","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS","role":"article","type":"topic"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further#More-resources":{"title":"More resources","url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further#More-resources","role":"pseudoSymbol","abstract":[{"type":"text","text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources."}],"type":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"estimatedTime":"30min","title":"Add more OUDS components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components","role":"project","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","kind":"project"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Basic-structure-for-the-app":{"kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","title":"Basic structure for the app","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","role":"pseudoSymbol","type":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework."}],"type":"section","title":"Import the Swift Package and the libraries"},"tutorial-3-3.swift":{"fileName":"Content.swift","fileType":"swift","syntax":"swift","identifier":"tutorial-3-3.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","     