nders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"identifier":"tutorial-3-2.swift","syntax":"swift"},"tutorial-3-5.png":{"type":"image","identifier":"tutorial-3-5.png","alt":"A radio picker, an horizontal divider, a checkbox item and a switch item","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-5.png"}]},"tutorial-3-7.png":{"type":"image","identifier":"tutorial-3-7.png","alt":"A radio picker, an horizontal divider, a checkbox item, a switch item, a link and a button","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-3-7.png"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further","abstract":[{"text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources.","type":"text"}],"type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further","role":"project","estimatedTime":"10min","kind":"project","title":"Going further with more resources"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Go-further-with-more-ressources":{"url":"\/tutorials\/table-of-contents\/go-further-with-more-ressources","role":"article","title":"Go further with more ressources","type":"topic","kind":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","abstract":[]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Typography,-view-modifiers-and-tokens":{"kind":"article","role":"article","abstract":[],"type":"topic","title":"Typography, view modifiers and tokens","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","url":"\/tutorials\/table-of-contents\/typography,-view-modifiers-and-tokens"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components":{"title":"Use your first OUDS components","type":"topic","kind":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","estimatedTime":"30min","role":"project","abstract":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}]},"tutorial-3-4.swift":{"fileName":"Content.swift","fileType":"swift","syntax":"swift","type":"file","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"identifier":"tutorial-3-4.swift","highlights":[{"line":28},{"line":29}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme":{"title":"Instanciate and inject a theme","kind":"project","estimatedTime":"15min","type":"topic","role":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Add-basic-components":{"url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Add-basic-components","kind":"section","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","type":"section","role":"pseudoSymbol","title":"Add basic components"},"tutorial-3-2.png":{"type":"image","identifier":"tutorial-3-2.png","alt":"A radio picker","variants":[{"traits":["1x","light"