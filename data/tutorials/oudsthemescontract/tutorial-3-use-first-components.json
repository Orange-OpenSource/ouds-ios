anding"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding","kind":"assessment"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources","kind":"task"}]}]}]},"metadata":{"category":"Orange Unified Design System","role":"project","title":"Use your first OUDS components","categoryPathComponent":"Table-Of-Contents"},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components"},"kind":"project","sections":[{"backgroundImage":"ic_component_intro.png","title":"Use your first OUDS components","content":[{"inlineContent":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"type":"paragraph"}],"xcodeRequirement":"Xcode 26","kind":"hero","chapter":"Use of first components provided by OUDS","estimatedTimeInMinutes":30,"image":"ic_component_intro.png"},{"kind":"tasks","tasks":[{"title":"Add basic components","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"We will work on a kind of formular using main OUDS components.","type":"text"},{"text":" ","type":"text"},{"text":"Feel free to style and design things as you want.","type":"text"}],"type":"paragraph"}]}],"stepsSection":[{"caption":[],"media":null,"code":"tutorial-3-1.swift","runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"First, prepare the ","type":"text"},{"type":"codeVoice","code":"ContentView"},{"text":" by adding inside it a ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":".","type":"text"}]}]},{"caption":[{"inlineContent":[{"text":"Add such picker with three items inside.","type":"text"}],"type":"paragraph"}],"media":null,"code":"tutorial-3-2.swift","runtimePreview":"tutorial-3-2.png","type":"step","content":[{"inlineContent":[{"type":"text","text":"Now, let’s add radio buttons to let the user choose its gender."},{"type":"text","text":" "},{"type":"text","text":"The official components are "},{"type":"codeVoice","code":"OUDSRadio"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioItem"},{"type":"text","text":", but the package has also a "},{"type":"codeVoice","code":"OUDSRadioPicker"},{"type":"text","text":" to implement quicky a group of radios."},{"type":"text","text":" "},{"type":"text","text":"This component can be replaced by your own."},{"type":"text","text":" "},{"type":"text","text":"The radio picker is defined by an array of values to display radio items associated to a tag, i.e. an "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":" thing shared through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Inside a picker the user can select only one value, not zero."}],"type":"paragraph"}]},{"caption":[{"inlineContent":[{"type":"text","text":"Add a checkbox item with only two states."}],"type":"paragraph"}],"media":null,"code":"tutorial-3-3.swift","runtimePreview":"tutorial-3-3.png","type":"step","content":[{"inlineContent":[{"text":"The radio picker is alone, it is the time to add below a checkbox. OUDS provides two components: ","type":"text"},{"code":"OUDSCheckbox","type":"codeVoice"},{"text":" which is a simple checkbox, and ","type":"text"},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"text":" which is a checkbox (duh!) with additional texts and icons.","type":"text"},{"text":" ","type":"text"},{"text":"The state of the checkbox is shared through a boolean ","type":"text"},{"code":"State","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In some cases you may need to use ","type":"text"},{"code":"OUDSCheckboxIndeterminate","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSCheckboxItemIndeterminate","type":"codeVoice"},{"text":" if you want a three-states checkbox.","type":"text"}],"type":"paragraph"}]},{"caption":[{"type":"paragraph","inlineContent":[{"text":"Choose to add an instance of ","type":"text"},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"text":".","type":"text"}]}],"media":null,"code":"tutorial-3-4.swift","runtimePreview":"tutorial-3-4.png","type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There are also components who do not have any behaviors and are here only for visual rendering, for example dividers which can be horizontal or vertical."},{"type":"text","text":" "},{"type":"text","text":"A divider is, in the end, a stroke with a color. You will see later, colors in OUDS have two values: a light mode value, and a dark mode value. Here the divider can have a color which can change, or not."}]}]},{"caption":[{"inlineContent":[{"text":"Add a switch item, it will be used as a trick to force the change of the color scheme for the view for our future operations.","type":"text"},{"text":" ","type":"text"},{"text":"You will then be able to see the automatic changes of colors when you switch the color scheme.","type":"text"}],"type":"paragraph"}],"media":null,"code":"tutorial-3-5.swift","runtimePreview":"tutorial-3-5.png","type":"step","content":[{"inlineContent":[{"type":"text","text":"With radio and checkbox, OUDS provides also switch elements (toggles). They can be alone ("},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":") or with texts ("},{"type":"codeVoice","code":"OUDSSwitchItem"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"Just like the checkbox, the switch exposes its state through a "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."}],"type":"paragraph"}]},{"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add an "},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" in the app and make it open the iOS documentation OUDS website."}]}],"media":null,"code":"tutorial-3-6.swift","runtimePreview":"tutorial-3-6.png","type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Users may need to navigate outside the app, like, for example, opening a website. Thus the ","type":"text"},{"code":"OUDSLink","type":"codeVoice"},{"text":" component can be integrated. It can be only with a text or also a chevron indicator.","type":"text"}]}]},{"caption":[{"type":"paragraph","inlineContent":[{"text":"Let’s add a button with some rules: if checkbox is not checked it is disabled. When tapped, change the style of the button during 5 seconds.","type":"text"}]}],"media":null,"code":"tutorial-3-7.swift","runtimePreview":"tutorial-3-7.png","type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the end, we can also add a button. Button are one of the most used components in an app and bring a lof of the power and the style of the brand."},{"type":"text","text":" "},{"type":"text","text":"You can find it with the "},{"type":"codeVoice","code":"OUDSButton"},{"type":"text","text":". Such button has an appearance changing its colors, and also a style (loading or not)."},{"type":"text","text":" "},{"type":"text","text":"Thanks to the theme, the enabled, disabled, hover, focus or pressed states are managed."}]}]}],"anchor":"Add-basic-components"}]},{"anchor":"Check-Your-Understanding","assessments":[{"choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No! The components use the design specifications, i.e. tokens, thanks to the theme, to define the style they must have in all cases."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"No"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"That is the reason why the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" is so important: it injects the theme as environment variable so that any component can get it to define its style."}],"type":"paragraph"}]}],"content":[],"type":"multiple-choice","title":[{"inlineContent":[{"type":"text","text":"Does the developer using OUDS component need to manage the look and feel of the components?"}],"type":"paragraph"}]}],"kind":"assessments"},{"action":{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]},"title":"Add more OUDS components","featuredEyebrow":"Tutorial","kind":"callToAction","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}]}],"references":{"tutorial-3-3.swift":{"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"fileType":"swift","syntax":"swift","highlights":[{"line":20},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29}],"type":"file","identifier":"tutorial-3-3.swift","fileName":"Content.swift"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Use-of-view-modifiers":{"url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Use-of-view-modifiers","role":"pseudoSymbol","title":"Use of view modifiers","type":"section","kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further#More-resources":{"kind":"section","abstract":[{"type":"text","text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further#More-resources","type":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources","title":"More resources","role":"pseudoSymbol"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Check-Your-Understanding":{"url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Check-Your-Understanding","type":"link","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","title":"Check Your Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Check-