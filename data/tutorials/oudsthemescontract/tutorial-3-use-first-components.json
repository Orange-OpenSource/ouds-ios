eName":"Content.swift"},"tutorial-3-2.png":{"identifier":"tutorial-3-2.png","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-3-2.png","traits":["1x","light"]}],"alt":"A radio picker","type":"image"},"tutorial-3-6.png":{"identifier":"tutorial-3-6.png","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-3-6.png","traits":["1x","light"]}],"alt":"A radio picker, an horizontal divider, a checkbox item, a switch item and a link","type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components":{"abstract":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}],"estimatedTime":"30min","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","title":"Use your first OUDS components","type":"topic","role":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components","kind":"project"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"role":"project","estimatedTime":"30min","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"kind":"project","title":"Add more OUDS components"},"Xcode 26":{"identifier":"Xcode 26","title":"Xcode 26","url":"https:\/\/developer.apple.com\/download\/","type":"xcodeRequirement"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Check-Your-Understanding":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","title":"Check Your Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Final-result":{"kind":"section","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Final-result","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"title":"Final result"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents":{"type":"topic","url":"\/tutorials\/table-of-contents","role":"overview","title":"Swift Package iOS Tutorial","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","abstract":[{"text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package.","type":"text"},{"text":" ","type":"text"},{"text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework.","type":"text"},{"text":" ","type":"text"},{"text":"Theme, components, tokens… everything will be introduced!","type":"text"}],"kind":"overview"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies":{"title":"Swift Package integration","estimatedTime":"10min","role":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies","kind":"project","abstract":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies","type":"topic"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-6-going-further#More-resources":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources","url":"\/tutorials\/oudsthemescontract\/tutorial-6-going-further#More-resources","title":"More resources","role":"pseudoSymbol","type":"section","abstract":[{"text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources.","type":"text"}],"kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Add-basic-components":{"url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Add-basic-components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Add-basic-components","title":"Add basic components","type":"section","abstract":[{"text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They are rendered thanks to the theme in use.","type":"text"}],"role":"pseudoSymbol","kind":"section"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Use-of-first-components-provided-by-OUDS":{"title":"Use of first components provided by OUDS","role":"article","type":"topic","kind":"article","abstract":[],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Use-of-first-components-provided-by-OUDS","url":"\/tutorials\/table-of-contents\/use-of-first-components-provided-by-ouds"},"tutorial-3-3.swift":{"fileName":"Content.swift","fileType":"swift","highlights":[{"line":20},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29}],"content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","        }","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"type":"file","syntax":"swift","identifier":"tutorial-3-3.swift"},"tutorial-3-7.png":{"identifier":"tutorial-3-7.png","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-3-7.png","traits":["1x","light"]}],"alt":"A radio picker, an horizontal divider, a checkbox item, a switch item, a link and a button","type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries":{"url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","abstract":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries","type":"section","role":"pseudoSymbol","title":"Import the Swift Package and the libraries","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Check-Your-Understanding":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding","title":"Check Your Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}],"type":"link"},"tutorial-3-5.png":{"identifier":"tutorial-3-5.png","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-3-5.png","traits":["1x","light"]}],"alt":"A radio picker, an horizontal divider, a checkbox item and a switch item","type":"image"},"tutorial-3-7.swift":{"fileType":"swift","type":"file","syntax":"swift","fileName":"Content.swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of which is available at https:\/\/opensource.org\/license\/MIT\/","\/\/ or see the \"LICENSE\" file for more details.","\/\/","\/\/ Authors: See CONTRIBUTORS.txt","\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct ContentView: View {","","    @State var selectedGender: Genders = .male","    @State var termsAccepted: Bool = false","    @State var switchToDarkMode: Bool = false","    @State var creatingProfile: Bool = false","","    @Environment(\\.openURL) var openUrl","","    var body: some View {","        VStack {","            OUDSRadioPicker(selection: $selectedGender,","                            radios: genderRadioValues(),","                            placement: .horizontal(false))","","            OUDSHorizontalDivider(color: .brandPrimary)","","            OUDSCheckboxItem(isOn: $termsAccepted, label: \"I accept the terms of use\")","","            OUDSSwitchItem(\"Switch to dark mode\", isOn: $switchToDarkMode)","","            OUDSLink(text: \"Go to the website\", indicator: .next) {","                openUrl.callAsFunction(URL(string: \"https:\/\/ios.unified-design-system.orange.com\")!)","            }","","            OUDSButton(text: \"Create my profile\",","                       appearance: .strong,","                       style: creatingProfile ? .loading : .default)","            {","                creatingProfile = true","                DispatchQueue.main.asyncAfter(deadline: .now() + 5) {","                    creatingProfile = false","                }","            }.disabled(!termsAccepted)","        }.preferredColorScheme(switchToDarkMode ? .dark : .light)","    }","","    \/\/ MARK: - Utils","","    enum Genders: String, Hashable {","        case male","        case female","        case nonBinary","    }","","    func genderRadioValues() -> [OUDSRadioPickerData<Genders>] {","        [","            OUDSRadioPickerData(tag: Genders.male, label: \"Mr\"),","            OUDSRadioPickerData(tag: Genders.female, label: \"Ms\"),","            OUDSRadioPickerData(tag: Genders.nonBinary, label: \"Other\"),","        ]","    }","}"],"highlights":[{"line":22},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50}],"identifier":"tutorial-3-7.swift"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Import-of-the-Swift-Package-and-choose-its-librairies":{"role":"article","abstract":[],"type":"topic","title":"Import of the Swift Package and choose its librairies","url":"\/tutorials\/table-of-contents\/import-of-the-swift-package-and-choose-its-librairies","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies","kind":"article"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Richer-and-more-original-components-of-OUDS":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Richer-and-more-original-components-of-OUDS","url":"\/tutorials\/table-of-contents\/richer-and-more-original-components-of-ouds","title":"Richer and more original components of OUDS","abstract":[],"type":"topic","kind":"article","role":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Use-of-tokens":{"type":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"kind":"section","title":"Use of tokens","role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Use-of-tokens"},"tutorial-3-4.swift":{"type":"file","identifier":"tutorial-3-4.swift","highlights":[{"line":28},{"line":29}],"fileType":"swift","syntax":"swift","content":["\/\/","\/\/ Software Name: OUDS iOS","\/\/ SPDX-FileCopyrightText: Copyright (c) Orange SA","\/\/ SPDX-License-Identifier: MIT","\/\/","\/\/ This software is distributed under the MIT license,","\/\/ the text of whi