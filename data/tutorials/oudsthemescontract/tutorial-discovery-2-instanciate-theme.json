ew","type":"codeVoice"},{"type":"text","text":" and give it the new theme object."}]}],"runtimePreview":"tutorial-discovery-2-2.png","media":null,"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Project must compile then. This is until today (API 0.20.0) the only way to instanciated and inject a theme."}]}]}],"title":"Basic structure for the app","anchor":"Basic-structure-for-the-app","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS must be used in SwiftUI projects."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"We suppose you already have an app or a freshly created new one, with OUDS Swift Package integrated and the librairies added to the target."},{"type":"text","text":" "},{"type":"text","text":"We supposed also you have Xcode 26.3 at least, and for example an iPhone 17 Pro Max simulator."},{"type":"text","text":" "},{"type":"text","text":"Source code and tokens here are the ones of version 0.20.0 ; things can change in the future."}]}],"kind":"contentAndMedia","mediaPosition":"trailing"}]}],"kind":"tasks"},{"assessments":[{"content":[],"type":"multiple-choice","title":[{"inlineContent":[{"type":"text","text":"Is it mandatory to use today the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":"?"}],"type":"paragraph"}],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes"}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It is! Otherwise the theme won’t be defined and available as environment variable."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" is mandatory to inject as environment variable the theme and expose it in every view inside."}]}]}]}],"anc