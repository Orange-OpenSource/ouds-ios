m\/","isActive":true,"type":"reference"}]}],"code":null},{"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"The whole design system is documented and available online. You can find everything about components, tokens, guidelines and principles of OUDS.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"icon finder"}]},{"type":"text","text":" is also available there to get icons for your projects."}]}],"media":"tutorial-discovery-6-2.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Go to the website and learn things at "},{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/","isActive":true}]}],"code":null},{"code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS iOS provides also a wiki attached to its GitHub repository. The wiki is a public base of knowledge with plenty of things: available API, technicala architecture, tips about processes, tests, conventions and toolings."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Have a look "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki"},{"type":"text","text":" to discover how OUDS works."}]}],"media":"tutorial-discovery-6-3.png","runtimePreview":null},{"code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For technical reasons the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios"},{"type":"text","text":" GitHub repository does not embed the source code of the "},{"type":"emphasis","inlineContent":[{"text":"design system toolbox","type":"text"}]},{"type":"text","text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the source code of this showcase app, go to its dedicated GitHub repository at "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox"}]}],"media":"tutorial-discovery-6-4.png","runtimePreview":null},{"code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios"},{"type":"text","text":" GitHub repository."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not hesitate to "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions"},{"type":"text","text":"!"}]}],"media":"tutorial-discovery-6-5.png","runtimePreview":null}],"anchor":"More-resources","title":"More resources","contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"Xcode can use the Swift DocC documentation of OUDS, and this documentation is used to build a static web site."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"But there are also other resources which can be useful for you.","type":"text"}]}],"mediaPosition":"trailing","kind":"contentAndMedia"}]}]}],"metadata":{"title":"Going further with more resources","categoryPathComponent":"Table-Of-Contents-(onboarding)","role":"project","category":"Orange Unified Design System"},"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboarding-4-going-further"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-furt