{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboarding-4-going-further"]}],"metadata":{"role":"project","categoryPathComponent":"Table-Of-Contents-(onboarding)","title":"Going further with more resources","category":"Orange Unified Design System"},"kind":"project","sections":[{"kind":"hero","title":"Going further with more resources","chapter":"Go further with more ressources","estimatedTimeInMinutes":10,"content":[{"inlineContent":[{"text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources.","type":"text"}],"type":"paragraph"}],"image":"ic_theme_intro.png","backgroundImage":"ic_theme_intro.png"},{"tasks":[{"title":"More resources","anchor":"More-resources","contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"text":"Xcode can use the Swift DocC documentation of OUDS, and this documentation is used to build a static web site.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"But there are also other resources which can be useful for you.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia"}],"stepsSection":[{"caption":[{"inlineContent":[{"text":"You can get it at ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/"}],"type":"paragraph"}],"media":"tutorial-discovery-6-1.png","type":"step","code":null,"runtimePreview":null,"content":[{"inlineContent":[{"text":"The iOS technical documentation is available online. It has been generated from all the Swift DocC documentation written in the Swift Package.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You will find several catalogs (as many as librairies) with details about everyhting: components, tokens, themes, providers, etc."}],"type":"paragraph"}]},{"caption":[{"inlineContent":[{"type":"text","text":"Go to the website and learn things at "},{"isActive":true,"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/"}],"type":"paragraph"}],"media":"tutorial-discovery-6-2.png","type":"step","code":null,"runtimePreview":null,"content":[{"inlineContent":[{"text":"The whole design system is documented and available online. You can find everything about components, tokens, guidelines and principles of OUDS.","type":"text"},{"type":"text","text":" "},{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"icon finder"}],"type":"emphasis"},{"type":"text","text":" is also available there to get icons for your projects."}],"type":"paragraph"}]},{"caption":[{"inlineContent":[{"text":"Have a look ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki"},{"text":" to discover how OUDS works.","type":"text"}],"type":"paragraph"}],"media":"tutorial-discovery-6-3.png","type":"step","code":null,"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"OUDS iOS provides also a wiki attached to its GitHub repository. The wiki is a public base of knowledge with plenty of things: available API, technicala architecture, tips about processes, tests, conventions and toolings."}],"type":"paragraph"}]},{"caption":[{"inlineContent":[{"text":"To get the source code of this showcase app, go to its dedicated GitHub repository at ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox","type":"reference"}],"type":"paragraph"}],"media":"tutorial-discovery-6-4.png","type":"step","code":null,"runtimePreview":null,"content":[{"inlineContent":[{"text":"For technical reasons the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios"},{"text":" GitHub repository does not embed the source code of the ","type":"text"},{"inlineContent":[{"text":"design system toolbox","type":"text"}],"type":"emphasis"},{"text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository.","type":"text"}],"type":"paragraph"}]},{"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","type":"reference","isActive":true},{"type":"text","text":" GitHub repository."}]}],"runtimePreview":null,"type":"step","caption":[{"inlineContent":[{"type":"text","text":"Do not hesitate to "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","type":"reference","isActive":true},{"text":" or ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","type":"reference","isActive":true},{"text":"!","type":"text"}],"type":"paragraph"}],"media":"tutorial-discovery-6-5.png"}]}],"kind":"tasks"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further","interfaceLanguage":"swift"},"hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","modules":[{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies#Check-Your-Understanding","kind":"assessment"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Import-of-the-Swift-Package-and-choose-its-librairies"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onbo