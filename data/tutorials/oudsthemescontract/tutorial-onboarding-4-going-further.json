[{"inlineContent":[{"text":"The iOS technical documentation is available online. It has been generated from all the Swift DocC documentation written in the Swift Package.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You will find several catalogs (as many as librairies) with details about everyhting: components, tokens, themes, providers, etc."}],"type":"paragraph"}]},{"caption":[{"inlineContent":[{"text":"Go to the website and learn things at ","type":"text"},{"identifier":"https:\/\/unified-design-system.orange.com\/","isActive":true,"type":"reference"}],"type":"paragraph"}],"media":"tutorial-discovery-6-2.png","runtimePreview":null,"code":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"The whole design system is documented and available online. You can find everything about components, tokens, guidelines and principles of OUDS."},{"type":"text","text":" "},{"type":"text","text":"The "},{"inlineContent":[{"type":"text","text":"icon finder"}],"type":"emphasis"},{"text":" is also available there to get icons for your projects.","type":"text"}],"type":"paragraph"}]},{"code":null,"runtimePreview":null,"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Have a look "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki","isActive":true},{"type":"text","text":" to discover how OUDS works."}]}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS iOS provides also a wiki attached to its GitHub repository. The wiki is a public base of knowledge with plenty of things: available API, technicala architecture, tips about processes, tests, conventions and toolings."}]}],"media":"tutorial-discovery-6-3.png","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"text":"For technical reasons the ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","isActive":true},{"text":" GitHub repository does not embed the source code of the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"design system toolbox","type":"text"}]},{"text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the source code of this showcase app, go to its dedicated GitHub repository at "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox"}]}],"type":"step","media":"tutorial-discovery-6-4.png","runtimePreview":null,"code":null},{"content":[{"inlineContent":[{"text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","isActive":true},{"text":" GitHub repository.","type":"text"}],"type":"paragraph"}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Do not hesitate to ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","type":"reference"},{"text":"!","type":"text"}]}],"type":"step","media":"tutorial-discovery-6-5.png","runtimePreview":null,"code":null}],"anchor":"More-resources","contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"Xcode can use the Swift DocC documentation of OUDS, and this documentation is used to build a static web site."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"But there are also other resources which can be useful for you.","type":"text"}]}],"kind":"contentAndMedia","mediaPosition":"trailing"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further"},"kind":"projec