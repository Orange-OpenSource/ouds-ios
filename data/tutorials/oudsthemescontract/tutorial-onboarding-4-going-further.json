":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Discover-main-components","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Merge-components-in-a-richer-view","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Navigations-and-themeable-view-a-step-further","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Components-showcases"},{"projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Go-further-with-more-ressources"}]},"sections":[{"kind":"hero","estimatedTimeInMinutes":10,"title":"Going further with more resources","chapter":"Go further with more ressources","backgroundImage":"ic_theme_intro.png","image":"ic_theme_intro.png","content":[{"inlineContent":[{"text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources.","type":"text"}],"type":"paragraph"}]},{"kind":"tasks","tasks":[{"anchor":"More-resources","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The iOS technical documentation is available online. It has been generated from all the Swift DocC documentation written in the Swift Package.","type":"text"},{"text":" ","type":"text"},{"text":"You will find several catalogs (as many as librairies) with details about everyhting: components, tokens, themes, providers, etc.","type":"text"}]}],"code":null,"media":"tutorial-discovery-6-1.png","caption":[{"inlineContent":[{"type":"text","text":"You can get it at "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/","isActive":true}],"type":"paragraph"}],"type":"step","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"The whole design system is documented and available online. You can find everything about components, tokens, guidelines and principles of OUDS."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"text":"icon finder","type":"text"}]},{"type":"text","text":" is also available there to get icons for your projects."}],"type":"paragraph"}],"code":null,"media":"tutorial-discovery-6-2.png","caption":[{"inlineContent":[{"type":"text","text":"Go to the website and learn things at "},{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/","isActive":true}],"type":"paragraph"}],"type":"step","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"OUDS iOS provides also a wiki attached to its GitHub repository. The wiki is a public base of knowledge with plenty of things: available API, technicala architecture, tips about processes, tests, conventions and toolings."}],"type":"paragraph"}],"code":null,"media":"tutorial-discovery-6-3.png","caption":[{"inlineContent":[{"type":"text","text":"Have a look "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki","isActive":true},{"type":"text","text":" to discover how OUDS works."}],"type":"paragraph"}],"type":"step","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"For technical reasons the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","isActive":true},{"type":"text","text":" GitHub repository does not embed the source code of the "},{"type":"emphasis","inlineContent":[{"text":"design system toolbox","type":"text"}]},{"type":"text","text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository."}],"type":"paragraph"}],"code":null,"media":"tutorial-discovery-6-4.png","caption":[{"inlineContent":[{"type":"text","text":"To get the source code of this showcase app, go to its dedicated GitHub repository at "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox","isActive":true}],"type":"paragraph"}],"type":"step","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","isActive":true},{"type":"text","text":" GitHub repository."}],"type":"paragraph"}],"code":null,"media":"tutorial-discovery-6-5.png","caption":[{"inlineContent":[{"type":"text","text":"Do not hesitate to "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","isActive":true},{"type":"text","text":"!"}],"type":"paragraph"}],"type":"step","runtimePreview":null}],"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"text":"Xcode can use the Swift DocC documentation of OUDS, and this documentation is used to build a static web site.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"But there are also other resources which can be useful for you.","type":"text"}],"type":"paragraph"}]}],"title":"More resources"}]}],"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboarding-4-going-further"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-1-package-and-librairies":{"estimatedTime":"10min","role":"project","title":"Swift Package integration","url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-1-package-and-librairies","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies","type":"topic","kind":"project"},"tutorial-discovery-6-2.png":{"identifier":"tutorial-discovery-6-2.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/tutorial-discovery-6-2.png"}],"alt":"OUDS official web site"},"tutorial-discovery-6-1.png":{"type":"image","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-discovery-6-1.png","traits":["1x","light"]}],"alt":"Apple-fashioned technical user documentation","identifier":"tutorial-discovery-6-1.png"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-3-components-showcase#Discover-main-components":{"abstract":[{"text":"Now you are ready to use more components than a simple button!","type":"text"}],"role":"pseudoSymbol","url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-3-components-showcase#Discover-main-components","type":"section","title":"Discover main components","kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Discover-main-components"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tut