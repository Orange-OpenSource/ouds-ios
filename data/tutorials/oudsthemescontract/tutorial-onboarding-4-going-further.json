t"}]},{"type":"paragraph","inlineContent":[{"text":"But there are also other resources which can be useful for you.","type":"text"}]}]}],"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"The iOS technical documentation is available online. It has been generated from all the Swift DocC documentation written in the Swift Package."},{"type":"text","text":" "},{"type":"text","text":"You will find several catalogs (as many as librairies) with details about everyhting: components, tokens, themes, providers, etc."}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"You can get it at "},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/"}],"type":"paragraph"}],"code":null,"runtimePreview":null,"media":"tutorial-discovery-6-1.png","type":"step"},{"runtimePreview":null,"code":null,"content":[{"inlineContent":[{"type":"text","text":"The whole design system is documented and available online. You can find everything about components, tokens, guidelines and principles of OUDS."},{"type":"text","text":" "},{"text":"The ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"icon finder","type":"text"}]},{"type":"text","text":" is also available there to get icons for your projects."}],"type":"paragraph"}],"type":"step","media":"tutorial-discovery-6-2.png","caption":[{"type":"paragraph","inlineContent":[{"text":"Go to the website and learn things at ","type":"text"},{"isActive":true,"identifier":"https:\/\/unified-design-system.orange.com\/","type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS iOS provides also a wiki attached to its GitHub repository. The wiki is a public base of knowledge with plenty of things: available API, technicala architecture, tips about processes, tests, conventions and toolings.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Have a look ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki","type":"reference","isActive":true},{"text":" to discover how OUDS works.","type":"text"}]}],"code":null,"runtimePreview":null,"media":"tutorial-discovery-6-3.png","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For technical reasons the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios"},{"type":"text","text":" GitHub repository does not embed the source code of the "},{"type":"emphasis","inlineContent":[{"text":"design system toolbox","type":"text"}]},{"type":"text","text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the source code of this showcase app, go to its dedicated GitHub repository at "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox","isActive":true}]}],"code":null,"runtimePreview":null,"media":"tutorial-discovery-6-4.png","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","isActive":true},{"type":"text","text":" GitHub repository."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not hesitate to "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions"},{"text":"!","type":"text"}]}],"code":null,"runtimePreview":null,"media":"tutorial-discovery-6-5.png","type":"step"}],"anchor":"More-resources"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutori