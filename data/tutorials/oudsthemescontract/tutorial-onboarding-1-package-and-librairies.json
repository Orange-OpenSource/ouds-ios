{"kind":"project","hierarchy":{"modules":[{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies#Check-Your-Understanding"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Import-of-the-Swift-Package-and-choose-its-librairies"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view#Define-the-view-basics"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view#Check-Your-Understanding"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Define-information-cards"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Discover-main-components"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Merge-components-in-a-richer-view"},{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Navigations-and-themeable-view-a-step-further"},{"kind":"assessment","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Check-Your-Understanding"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Components-showcases"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further#More-resources"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Go-further-with-more-ressources"}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Import-of-the-Swift-Package-and-choose-its-librairies"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboarding-1-package-and-librairies"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies"},"metadata":{"category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(onboarding)","role":"project","title":"Swift Package integration"},"sections":[{"image":"ic_unified_ds.png","xcodeRequirement":"Xcode 26.3","backgroundImage":"ic_unified_ds.png","chapter":"Import of the Swift Package and choose its librairies","kind":"hero","estimatedTimeInMinutes":10,"title":"Swift Package integration","projectFiles":"OUDS-Onboarding-Tutorial.zip","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}]}]},{"kind":"tasks","tasks":[{"anchor":"Import-the-Swift-Package-and-the-libraries","title":"Import the Swift Package and the libraries","contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}],"type":"paragraph"}],"mediaPosition":"trailing"}],"stepsSection":[{"caption":[{"inlineContent":[{"type":"text","text":"Let’s say you will use the some beta version, here 1.3.0-beta.2"}],"type":"paragraph"}],"runtimePreview":null,"code":null,"content":[{"inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"type":"strong","inlineContent":[{"type":"text","text":"project package dependencies"}]},{"type":"text","text":", add a new "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ouds-ios"}]},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency rule"}]},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}],"media":"tutorial-onboarding-1-ouds-swift-package.png","type":"step"},{"caption":[{"inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"inlineContent":[{"type":"text","text":"OUDSSwiftUI"}],"type":"emphasis"}],"type":"paragraph"}],"runtimePreview":null,"code":null,"content":[{"inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"inlineContent":[{"type":"text","text":"target"}],"type":"strong"},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"inlineContent":[{"type":"text","text":"OUDSThemesContract"}],"type":"emphasis"},{"type":"text","text":" library provides the main elements like the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesOrange"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesSosh"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSComponents"}],"type":"emphasis"},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSTokensRaw"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"OUDSTokensComponents"}],"type":"emphasis"},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSModules"}],"type":"emphasis"},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSFoundations"}],"type":"emphasis"},{"type":"text","text":" is dedicated to some utilities and shared logic."}],"type":"paragraph"}],"media":"tutorial-onboarding-1-ouds-libraries.png","type":"step"}]}]},{"kind":"assessments","anchor":"Check-Your-Understanding","assessments":[{"content":[],"choices":[{"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}]}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"I can contribute to OUDS using pull request"}]}],"isCorrect":true},{"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"type":"text","text":"CarPlay specific cases are not scoped yet."}]}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}]}],"isCorrect":false},{"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS supports only SwiftUI.","type":"text"}]}]}],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Which of these choices is correct?"}]}],"type":"multiple-choice"},{"type":"multiple-choice","content":[],"title":[{"inlineContent":[{"type":"text","text":"Which imports of the OUDS Swift Package products can I choose?"}],"type":"paragraph"}],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" if I am very lazy and don’t care about my app size.","type":"text"}]}],"justification":[{"inlineContent":[{"text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" product wraps all of them."}],"type":"paragraph"}],"isCorrect":true},{"content":[{"type":"paragraph","inlineContent":[{"text":"None, only the Swift package dependency matter.","type":"text"}]}],"justification":[{"inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}],"type":"paragraph"}],"isCorrect":false}]}]},{"kind":"callToAction","action":{"type":"reference","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"overridingTitle":"Get started","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view"},"abstract":[{"text":"Let’s suppose we want to define a view for corporate apps with headings, texts, buttons and images.","type":"text"},{"type":"text","text":" "},{"text":"How can we do that?","type":"text"}],"featuredEyebrow":"Tutorial","title":"Define information cards"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-1-package-and-librairies":{"abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"role":"project","title":"Swift Package integration","url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-1-package-and-librairies","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies","estimatedTime":"10min","type":"topic","kind":"project"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-4-going-further":{"abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}],"role":"project","title":"Going further with more resources","url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-4-going-further","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further","estimatedTime":"10min","type":"topic","kind":"project"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(onboarding)":{"abstract":[{"type":"t