e":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Check-Your-Understanding"}]}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Go-further-with-more-ressources","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further#More-resources"}]}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Import-of-the-Swift-Package-and-choose-its-librairies"]]},"kind":"project","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboarding-1-package-and-librairies"]}],"metadata":{"category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(onboarding)","title":"Swift Package integration","role":"project"},"sections":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}]}],"image":"ic_unified_ds.png","backgroundImage":"ic_unified_ds.png","title":"Swift Package integration","chapter":"Import of the Swift Package and choose its librairies","projectFiles":"OUDS-Onboarding-Tutorial.zip","estimatedTimeInMinutes":10,"xcodeRequirement":"Xcode 26.4","kind":"hero"},{"kind":"tasks","tasks":[{"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}],"type":"paragraph"}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"type":"strong","inlineContent":[{"type":"text","text":"project package dependencies"}]},{"type":"text","text":", add a new "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ouds-ios"}]},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency rule"}]},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API"},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases"},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"Let’s say you will use the some beta version, here 1.3.0-beta.2"}],"type":"paragraph"}],"type":"step","code":null,"media":"tutorial-onboarding-1-ouds-swift-package.png","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"type":"strong","inlineContent":[{"type":"text","text":"target"}]},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesContract"}]},{"type":"text","text":" library provides the main elements like the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrange"}]},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesSosh"}]},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}]},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}]},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSComponents"}]},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensRaw"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensComponents"}]},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSModules"}]},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSFoundations"}]},{"type":"text","text":" is dedicated to some utilities and shared logic."}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]}],"type":"paragraph"}],"type":"step","code":null,"media":"tutorial-onboarding-1-ouds-libraries.png","runtimePreview":null}],"anchor":"Import-the-Swift-Package-and-the-libraries","title":"Import the Swift Package and the libraries"}]},{"kind":"assessments","anchor":"Check-Your-Understanding","assessments":[{"type":"multiple-choice","choices":[{"content":[{"inlineContent":[{"type":"text","text":"I can contribute to OUDS using pull request"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"type":"text","text":"CarPlay specific cases are not scoped yet."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}],"type":"paragraph"}]}],"content":[],"title":[{"type":"paragraph","inlineContent":[{"text":"Which of these choices is correct?","type":"text"}]}]},{"type":"multiple-choice","choices":[{"content":[{"inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" product wraps all of them."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}],"type":"paragraph"}]}],"content":[],"title":[{"type":"paragraph","inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}]}]}]},{"kind":"callToAction","action":{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"overridingTitle":"Get started"},"title":"Define in