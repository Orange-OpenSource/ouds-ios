{"kind":"project","variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboarding-1-package-and-librairies"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[{"title":"Swift Package integration","kind":"hero","estimatedTimeInMinutes":10,"image":"ic_unified_ds.png","xcodeRequirement":"Xcode 26.2","content":[{"inlineContent":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}],"type":"paragraph"}],"chapter":"Import of the Swift Package and choose its librairies","backgroundImage":"ic_unified_ds.png","projectFiles":"OUDS-Onboarding-Tutorial.zip"},{"kind":"tasks","tasks":[{"title":"Import the Swift Package and the libraries","anchor":"Import-the-Swift-Package-and-the-libraries","contentSection":[{"content":[{"inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"text":" ","type":"text"},{"text":"The package and the librairies must be added through Xcode.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"runtimePreview":null,"content":[{"inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"inlineContent":[{"type":"text","text":"project package dependencies"}],"type":"strong"},{"text":", add a new ","type":"text"},{"inlineContent":[{"type":"text","text":"dependency"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"inlineContent":[{"type":"text","text":"ouds-ios"}],"type":"emphasis"},{"text":" dependency.","type":"text"},{"text":" ","type":"text"},{"text":"You can then choose the ","type":"text"},{"inlineContent":[{"type":"text","text":"dependency rule"}],"type":"strong"},{"text":" you want.","type":"text"},{"text":" ","type":"text"},{"text":"To know which version you need, you can have a look on the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API"},{"text":" ","type":"text"},{"text":"and also the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases"},{"text":".","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"text":"Let’s say you will use the some beta version, here 1.3.0-beta.2","type":"text"}],"type":"paragraph"}],"type":"step","code":null,"media":"tutorial-onboarding-1-ouds-swift-package.png"},{"runtimePreview":null,"content":[{"inlineContent":[{"text":"Once you downloaded the package, you will see several librairies are available.","type":"text"},{"text":" ","type":"text"},{"text":"They can be embeded inside your ","type":"text"},{"inlineContent":[{"type":"text","text":"target"}],"type":"strong"},{"text":" librairies.","type":"text"},{"text":" ","type":"text"},{"text":"Things are separated to let users integrate only what they need and embed the abre minimum of content.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesContract"}],"type":"emphasis"},{"text":" library provides the main elements like the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":". The theme contract is defined inside it.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesOrange"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesSosh"}],"type":"emphasis"},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}],"type":"emphasis"},{"text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSComponents"}],"type":"emphasis"},{"text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensRaw"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensComponents"}],"type":"emphasis"},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"text":" ","type":"text"},{"text":"middle level (semantic) or component levels (high level).","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSModules"}],"type":"emphasis"},{"text":" is for modules or rich components with extra logic.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSFoundations"}],"type":"emphasis"},{"text":" is dedicated to some utilities and shared logic.","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"text":"Add for example only the umbrella product merging all products mentioned above: ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSSwiftUI"}],"type":"emphasis"}],"type":"paragraph"}],"type":"step","code":null,"media":"tutorial-onboarding-1-ouds-libraries.png"}]}]},{"anchor":"Check-Your-Understanding","assessments":[{"content":[],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Which of these choices is correct?"}]}],"type":"multiple-choice","choices":[{"content":[{"inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay.","type":"text"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS.","type":"text"},{"text":" ","type":"text"},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"text":"OUDS supports only SwiftUI.","type":"text"}],"type":"paragraph"}]}]},{"content":[],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Which imports of the OUDS Swift Package products can I choose?"}]}],"type":"multiple-choice","choices":[{"content":[{"inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" if I am very lazy and don’t care about my app size.","type":"text"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed.","type":"text"},{"text":" ","type":"text"},{"text":"Even if we recommend to choose only the atomic products you need, the ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" product wraps all of them.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"None, only the Swift package dependency matter.","type":"text"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"text":"You need to chose the products the Swift package provides.","type":"text"}],"type":"paragraph"}]}]}],"kind":"assessments"},{"title":"Define information cards","kind":"callToAction","abstract":[{"text":"Let’s suppose we want to define a view for corporate apps with headings, texts, buttons and images.","type":"text"},{"text":" ","type":"text"},{"text":"How can we do that?","type":"text"}],"action":{"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view","isActive":true,"type":"reference","overridingTitle":"Get started"},"featuredEyebrow":"Tutorial"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies"},"metadata":{"category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(onboarding)","role":"project","title":"Swift Package integration"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Import-of-the-Swift-Package-and-choose-its-librairies"]],"modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Import-of-the-Swift-Package-and-choose-its-libr