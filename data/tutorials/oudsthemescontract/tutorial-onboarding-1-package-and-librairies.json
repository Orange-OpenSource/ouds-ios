{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboarding-1-package-and-librairies"]}],"metadata":{"categoryPathComponent":"Table-Of-Contents-(onboarding)","title":"Swift Package integration","category":"Orange Unified Design System","role":"project"},"kind":"project","sections":[{"title":"Swift Package integration","xcodeRequirement":"Xcode 26.3","estimatedTimeInMinutes":10,"image":"ic_unified_ds.png","kind":"hero","backgroundImage":"ic_unified_ds.png","chapter":"Import of the Swift Package and choose its librairies","projectFiles":"OUDS-Onboarding-Tutorial.zip","content":[{"inlineContent":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}],"type":"paragraph"}]},{"kind":"tasks","tasks":[{"title":"Import the Swift Package and the libraries","contentSection":[{"content":[{"inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"caption":[{"type":"paragraph","inlineContent":[{"text":"Let’s say you will use the some beta version, here 1.3.0-beta.2","type":"text"}]}],"code":null,"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"inlineContent":[{"text":"project package dependencies","type":"text"}],"type":"strong"},{"text":", add a new ","type":"text"},{"inlineContent":[{"text":"dependency","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"ouds-ios"}]},{"text":" dependency.","type":"text"},{"text":" ","type":"text"},{"text":"You can then choose the ","type":"text"},{"inlineContent":[{"type":"text","text":"dependency rule"}],"type":"strong"},{"text":" you want.","type":"text"},{"text":" ","type":"text"},{"text":"To know which version you need, you can have a look on the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"and also the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true,"type":"reference"},{"text":".","type":"text"}]}],"media":"tutorial-onboarding-1-ouds-swift-package.png"},{"caption":[{"type":"paragraph","inlineContent":[{"text":"Add for example only the umbrella product merging all products mentioned above: ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]}]}],"code":null,"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Once you downloaded the package, you will see several librairies are available.","type":"text"},{"text":" ","type":"text"},{"text":"They can be embeded inside your ","type":"text"},{"inlineContent":[{"text":"target","type":"text"}],"type":"strong"},{"text":" librairies.","type":"text"},{"text":" ","type":"text"},{"text":"Things are separated to let users integrate only what they need and embed the abre minimum of content.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"inlineContent":[{"text":"OUDSThemesContract","type":"text"}],"type":"emphasis"},{"text":" library provides the main elements like the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":". The theme contract is defined inside it.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrange"}]},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesSosh"}]},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}]},{"text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}]},{"text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSComponents"}]},{"text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensRaw"}]},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensComponents"}]},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"text":" ","type":"text"},{"text":"middle level (semantic) or component levels (high level).","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSModules"}]},{"text":" is for modules or rich components with extra logic.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSFoundations"}]},{"text":" is dedicated to some utilities and shared logic.","type":"text"}]}],"media":"tutorial-onboarding-1-ouds-libraries.png"}],"anchor":"Import-the-Swift-Package-and-the-libraries"}]},{"kind":"assessments","assessments":[{"title":[{"inlineContent":[{"type":"text","text":"Which of these choices is correct?"}],"type":"paragraph"}],"choices":[{"isCorrect":true,"justification":[{"inlineContent":[{"text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!","type":"text"}],"type":"paragraph"}],"content":[{"inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay.","type":"text"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"text":" ","type":"text"},{"type":"text","text":"CarPlay specific cases are not scoped yet."}],"type":"paragraph"}],"isCorrect":false},{"isCorrect":false,"content":[{"inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}],"type":"paragraph"}]}],"type":"multiple-choice","content":[]},{"content":[],"title":[{"inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}],"type":"paragraph"}],"type":"multiple-choice","choices":[{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}],"justification":[{"inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"text":" ","type":"text"},{"text":"Even if we recommend to choose only the atomic products you need, the ","type":"text"},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" product wraps all of them."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"None, only the Swift package dependency matter.","type":"text"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"You need to chose the products the Swift package provides.","type":"text"}],"type":"paragraph"}],"isCorrect":false}]}],"anchor":"Check-Your-Understanding"},{"title":"Define information cards","featuredEyebrow":"Tutorial","kind":"callToAction","abstract":[{"type":"text","text":"Let’s suppose we want to define a view for corporate apps with headings, texts, buttons and images."},{"text":" ","type":"text"},{"type":"text","text":"How can we do that?"}],"action":{"overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view","type":"reference","isActive":true}}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies","interfaceLanguage":"swift"},"hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","modules":[{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies","sections":[{"kind":"task","reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies#Import-the-Swift-Package-and-the-libraries"},{"reference":"doc:\