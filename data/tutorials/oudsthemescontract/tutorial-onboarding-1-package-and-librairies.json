tract\/tutorial-onboarding-3-components-showcase#Navigations-and-themeable-view-a-step-further","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Go-further-with-more-ressources","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further"}]}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Import-of-the-Swift-Package-and-choose-its-librairies"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboarding-1-package-and-librairies"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"Swift Package integration","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(onboarding)","role":"project"},"sections":[{"xcodeRequirement":"Xcode 26.4","kind":"hero","content":[{"inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"type":"paragraph"}],"image":"ic_unified_ds.png","estimatedTimeInMinutes":10,"chapter":"Import of the Swift Package and choose its librairies","backgroundImage":"ic_unified_ds.png","projectFiles":"OUDS-Onboarding-Tutorial.zip","title":"Swift Package integration"},{"tasks":[{"title":"Import the Swift Package and the libraries","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}]}],"mediaPosition":"trailing"}],"anchor":"Import-the-Swift-Package-and-the-libraries","stepsSection":[{"media":"tutorial-onboarding-1-ouds-swift-package.png","code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"type":"strong","inlineContent":[{"text":"project package dependencies","type":"text"}]},{"type":"text","text":", add a new "},{"type":"strong","inlineContent":[{"text":"dependency","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"type":"emphasis","inlineContent":[{"text":"ouds-ios","type":"text"}]},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"type":"strong","inlineContent":[{"text":"dependency rule","type":"text"}]},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true},{"type":"text","text":"."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s say you will use the some beta version, here 1.3.0-beta.2"}]}],"runtimePreview":null},{"media":"tutorial-onboarding-1-ouds-libraries.png","code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"type":"strong","inlineContent":[{"text":"target","type":"text"}]},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesContract","type":"text"}]},{"type":"text","text":" library provides the main elements like the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesOrange","type":"text"}]},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesSosh","type":"text"}]},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesWireframe","type":"text"}]},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesOrangeCompact","type":"text"}]},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSComponents","type":"text"}]},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSTokensRaw","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"OUDSTokensSemantic","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"OUDSTokensComponents","type":"text"}]},{"type":"text","text":" are librairies defining and providing the tokens for low level (raw),"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSModules","type":"text"}]},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSFoundations","type":"text"}]},{"type":"text","text":" is dedicated to some utilities and shared logic."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"type":"emphasis","inlineContent":[{"text":"OUDSSwiftUI","type":"text"}]}]}],"runtimePreview":null}]}],"kind":"tasks"},{"kind":"assessments","assessments":[{"title":[{"inlineContent":[{"type":"text","text":"Which of these choices is correct?"}],"type":"paragraph"}],"type":"multiple-choice","choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"I can contribute to OUDS using pull request"}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"type":"text","text":"CarPlay specific cases are not scoped yet."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}]}]}],"content":[]},{"title":[{"inlineContent":[{"type":"text","text":"Which imports of the OUDS Swift Package products can I choose?"}],"type":"paragraph"}],"type":"multiple-choice","choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" product wraps all of them."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter."}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}]}]}],"content":[]}],"anchor":"Check-Your-Understanding"},{"title":"Define information cards","action":{"type":"reference","isActive":true,"identifier":"doc:\/\