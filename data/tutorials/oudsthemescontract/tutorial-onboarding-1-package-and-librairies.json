{"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboarding-1-package-and-librairies"]}],"metadata":{"category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(onboarding)","title":"Swift Package integration","role":"project"},"sections":[{"content":[{"inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"type":"paragraph"}],"title":"Swift Package integration","image":"ic_unified_ds.png","kind":"hero","chapter":"Import of the Swift Package and choose its librairies","estimatedTimeInMinutes":10,"xcodeRequirement":"Xcode 26.4","projectFiles":"OUDS-Onboarding-Tutorial.zip","backgroundImage":"ic_unified_ds.png"},{"kind":"tasks","tasks":[{"stepsSection":[{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"type":"strong","inlineContent":[{"text":"project package dependencies","type":"text"}]},{"text":", add a new ","type":"text"},{"type":"strong","inlineContent":[{"text":"dependency","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"ouds-ios","type":"text"}]},{"text":" dependency.","type":"text"},{"text":" ","type":"text"},{"text":"You can then choose the ","type":"text"},{"type":"strong","inlineContent":[{"text":"dependency rule","type":"text"}]},{"text":" you want.","type":"text"},{"text":" ","type":"text"},{"text":"To know which version you need, you can have a look on the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API"},{"text":" ","type":"text"},{"text":"and also the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases"},{"text":".","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Let’s say you will use the some beta version, here 1.3.0-beta.2","type":"text"}]}],"media":"tutorial-onboarding-1-ouds-swift-package.png","code":null,"runtimePreview":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Once you downloaded the package, you will see several librairies are available.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"They can be embeded inside your "},{"type":"strong","inlineContent":[{"type":"text","text":"target"}]},{"text":" librairies.","type":"text"},{"text":" ","type":"text"},{"text":"Things are separated to let users integrate only what they need and embed the abre minimum of content.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesContract","type":"text"}]},{"text":" library provides the main elements like the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":". The theme contract is defined inside it.","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesOrange","type":"text"}]},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesSosh","type":"text"}]},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}],"type":"emphasis"},{"text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSComponents"}],"type":"emphasis"},{"text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensRaw"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensComponents"}],"type":"emphasis"},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSModules","type":"text"}],"type":"emphasis"},{"text":" is for modules or rich components with extra logic.","type":"text"},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSFoundations","type":"text"}],"type":"emphasis"},{"type":"text","text":" is dedicated to some utilities and shared logic."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Add for example only the umbrella product merging all products mentioned above: ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OUDSSwiftUI","type":"text"}]}]}],"media":"tutorial-onboarding-1-ouds-libraries.png","code":null,"runtimePreview":null}],"anchor":"Import-the-Swift-Package-and-the-libraries","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}]}]}],"title":"Import the Swift Package and the libraries"}]},{"assessments":[{"type":"multiple-choice","content":[],"title":[{"type":"paragraph","inlineContent":[{"text":"Which of these choices is correct?","type":"text"}]}],"choices":[{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}]}]},{"isCorrect":false,"content":[{"inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"CarPlay specific cases are not scoped yet."}],"type":"paragraph"}]},{"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}]}],"content":[{"inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}],"type":"paragraph"}],"isCorrect":false}]},{"type":"multiple-choice","content":[],"title":[{"inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}],"type":"paragraph"}],"choices":[{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}],"justification":[{"inlineContent":[{"text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed.","type":"text"},{"text":" ","type":"text"},{"text":"Even if we recommend to choose only the atomic products you need, the ","type":"text"},{"type":"codeVoice","code":"OUDSSwiftUI"},{"text":" product wraps all of them.","type":"text"}],"type":"paragraph"}]},{"isCorrect":false,"content":[{"inlineContent":[{"text":"None, only the Swift package dependency matter.","type":"text"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"You need to chose the products the Swift package provides.","type":"text"}],"type":"paragraph"}]}]}],"anchor":"Check-Your-Understanding","kind":"assessments"},{"abstract":[{"text":"Let’s suppose we want to define a view for corporate apps with headings, texts, buttons and images.","type":"text"},{"text":" ","type":"text"},{"text":"How can we do that?","type":"text"}],"title":"Define information cards","kind":"callToAction","action":{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view","isActive":true,"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"overridingTitle":"Get started"},"featuredEyebrow":"Tutorial"}],"kind":"project","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies"},"hierarchy":{"modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies#Import-the-Swift-Packag