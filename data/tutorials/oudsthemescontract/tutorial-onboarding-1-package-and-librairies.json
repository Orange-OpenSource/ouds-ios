/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Navigations-and-themeable-view-a-step-further","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Components-showcases"},{"projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further#More-resources","kind":"task"}]}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Go-further-with-more-ressources"}]},"sections":[{"chapter":"Import of the Swift Package and choose its librairies","kind":"hero","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework for Apple platforms.","type":"text"}]}],"estimatedTimeInMinutes":10,"title":"Swift Package integration","image":"ic_unified_ds.png","xcodeRequirement":"Xcode 26.3","projectFiles":"OUDS-Onboarding-Tutorial.zip","backgroundImage":"ic_unified_ds.png"},{"kind":"tasks","tasks":[{"title":"Import the Swift Package and the libraries","stepsSection":[{"runtimePreview":null,"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s say you will use the some beta version, here 1.3.0-beta.2"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"inlineContent":[{"text":"project package dependencies","type":"text"}],"type":"strong"},{"text":", add a new ","type":"text"},{"inlineContent":[{"type":"text","text":"dependency"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"inlineContent":[{"type":"text","text":"ouds-ios"}],"type":"emphasis"},{"text":" dependency.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You can then choose the "},{"inlineContent":[{"type":"text","text":"dependency rule"}],"type":"strong"},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","type":"reference","isActive":true},{"type":"text","text":"."}]}],"media":"tutorial-onboarding-1-ouds-swift-package.png","type":"step","code":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"inlineContent":[{"type":"text","text":"target"}],"type":"strong"},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesContract"}]},{"type":"text","text":" library provides the main elements like the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrange"}]},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesSosh"}]},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}]},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesOrangeCompact"}]},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSComponents","type":"text"}]},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSTokensRaw","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensComponents"}]},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"text":" ","type":"text"},{"text":"middle level (semantic) or component levels (high level).","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSModules"}]},{"text":" is for modules or rich components with extra logic.","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSFoundations","type":"text"}]},{"text":" is dedicated to some utilities and shared logic.","type":"text"}]}],"media":"tutorial-onboarding-1-ouds-libraries.png","code":null,"caption":[{"inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"inlineContent":[{"type":"text","text":"OUDSSwiftUI"}],"type":"emphasis"}],"type":"paragraph"}],"runtimePreview":null,"type":"step"}],"anchor":"Import-the-Swift-Package-and-the-libraries","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license."},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}]}],"mediaPosition":"trailing"}]}]},{"assessments":[{"content":[],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}]}],"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}],"type":"paragraph"}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"type":"text","text":"CarPlay specific cases are not scoped yet."}]}]},{"content":[{"inlineContent":[{"text":"OUDS provides UIKit components","type":"text"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"OUDS supports only SwiftUI."}],"type":"paragraph"}]}],"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Which of these choices is correct?"}]}]},{"type":"multiple-choice","content":[],"choices":[{"justification":[{"inlineContent":[{"text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"text":" product wraps all of them.","type":"text"}],"type":"paragraph"}],"content":[{"type":"paragraph","inlineContent":[{"text":"Some of the available products depending to my needs, or only ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}],"isCorrect":true},{"content":[{"type":"paragraph","inlineContent":[{"text":"None, only the Swift package dependency matter.","type":"text"}]}],"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides."}]}]}],"title":[{"type":"paragraph","inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}]}]}],"kind":"assessments","anchor":"Check-Your-Understanding"},{"action":{"type":"reference","overridingTitle":"Get started","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]},"featuredEyebrow":"Tutorial","kind":"callToAction","title":"Define information cards","abstract":[{"type":"text","text":"Let’s suppose we want to define a view for corporate apps with headings, texts, buttons and images."},{"type":"text","text":" "},{"type":"text","text":"How can we do that?"}]}],"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-onboa