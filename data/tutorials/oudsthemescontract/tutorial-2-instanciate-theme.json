:{"title":"Instanciate and inject a theme","categoryPathComponent":"Table-Of-Contents","category":"Orange Unified Design System","role":"project"},"sections":[{"xcodeRequirement":"Xcode 26","estimatedTimeInMinutes":15,"backgroundImage":"ic_theme_intro.png","image":"ic_theme_intro.png","kind":"hero","chapter":"Preparation of the theme","title":"Instanciate and inject a theme","content":[{"inlineContent":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"type":"paragraph"}]},{"tasks":[{"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"OUDS must be used in SwiftUI projects."}],"type":"paragraph"},{"inlineContent":[{"text":"We suppose you already have an app or a freshly created new one, with OUDS Swift Package integrated and the librairies added to the target.","type":"text"},{"text":" ","type":"text"},{"text":"We supposed also you have Xcode 26 at least, and for example an iPhone 17 Pro Max simulator.","type":"text"},{"text":" ","type":"text"},{"text":"Source code and tokens here are the ones of version 0.20.0 ; things can change in the future.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"anchor":"Basic-structure-for-the-app","stepsSection":[{"runtimePreview":"tutorial-2-1.png","content":[{"inlineContent":[{"type":"text","text":"Define a basic "},{"type":"codeVoice","code":"App"},{"type":"text","text":" object using "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"type":"text","text":". Add inside a simple text"}],"type":"paragraph"}],"type":"step","media":null,"caption":[],"code":"tutorial-2-1.swift"},{"runtimePreview":"tutorial-2-2.png","content":[{"inlineContent":[{"type":"text","text":"Import the needed librairies in your file (we suppose here "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]},{"type":"text","text":" during all the tutorial)."},{"type":"text","text":" "},{"type":"text","text":"Instanciate a new object of type "},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In your app root view, add the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" and give it the new theme object."}],"type":"paragraph"}],"type":"step","media":null,"caption":[{"inlineContent":[{"text":"Project must compile then. This is until today (API 0.20.0) the only way to instanciated and inject a theme.","type":"text"}],"type":"paragraph"}],"code":"tutorial-2-2.swift"}],"title":"Basic structure for the app"}],"kind":"tasks"},{"assessments":[{"choices":[{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"text":"Yes","type":"text"}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"It is! Otherwise the theme won’t be defined and available as environment variable.","type":"text"}]}]},{"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" is mandatory to inject as environment variable the theme and expose it in every view inside."}]}]}],"type":"multiple-choice","title":[{"inlineContent":[{"type":"text","text":"Is it mandatory to use today the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":"?"}],"type":"paragraph"}],"content":[]}],"anchor":"Check-Your-Understanding","kind":"assessments"},{"title":"Use your first OUDS components","action":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"overridingTitle":"Get started"},"featuredEyeb