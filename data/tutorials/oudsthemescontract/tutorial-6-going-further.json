sections":[{"backgroundImage":"ic_theme_intro.png","title":"Going further with more resources","kind":"hero","estimatedTimeInMinutes":10,"image":"ic_theme_intro.png","content":[{"inlineContent":[{"type":"text","text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources."}],"type":"paragraph"}],"chapter":"Go further with more ressources"},{"kind":"tasks","tasks":[{"anchor":"More-resources","stepsSection":[{"type":"step","media":"tutorial-6-1.png","code":null,"caption":[{"inlineContent":[{"type":"text","text":"You can get it at "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/","isActive":true,"type":"reference"}],"type":"paragraph"}],"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"The iOS technical documentation is available online. It has been generated from all the Swift DocC documentation written in the Swift Package."},{"text":" ","type":"text"},{"type":"text","text":"You will find several catalogs (as many as librairies) with details about everyhting: components, tokens, themes, providers, etc."}],"type":"paragraph"}]},{"type":"step","media":"tutorial-6-2.png","code":null,"caption":[{"inlineContent":[{"text":"Go to the website and learn things at ","type":"text"},{"identifier":"https:\/\/unified-design-system.orange.com\/","isActive":true,"type":"reference"}],"type":"paragraph"}],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The whole design system is documented and available online. You can find everything about components, tokens, guidelines and principles of OUDS."},{"type":"text","text":" "},{"text":"The ","type":"text"},{"inlineContent":[{"text":"icon finder","type":"text"}],"type":"emphasis"},{"type":"text","text":" is also available there to get icons for your projects."}]}]},{"code":null,"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Have a look ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki","isActive":true,"type":"reference"},{"type":"text","text":" to discover how OUDS works."}]}],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS iOS provides also a wiki attached to its GitHub repository. The wiki is a public base of knowledge with plenty of things: available API, technicala architecture, tips about processes, tests, conventions and toolings."}]}],"media":"tutorial-6-3.png"},{"media":"tutorial-6-4.png","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"For technical reasons the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","type":"reference"},{"text":" GitHub repository does not embed the source code of the ","type":"text"},{"inlineContent":[{"text":"design system toolbox","type":"text"}],"type":"emphasis"},{"type":"text","text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository."}]}],"type":"step","code":null,"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the source code of this showcase app, go to its dedicated GitHub repository at "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox"}]}]},{"runtimePreview":null,"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not hesitate to "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues"},{"text":" or ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","isActive":true,"type":"reference"},{"text":"!","type":"text"}]}],"type":"step","media":"tutorial-6-5.png","content":[{"inlineContent":[{"type":"text","text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios"},{"type":"text","text":" GitHub repository."}],"type":"paragraph"}],"code":null}],"title":"More resources","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Xcode can use the Swift DocC documentation of OUDS, and this documentation is used to build a static web site."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"But there are also other resources which can be useful for you."}]}]}]}]}],"metadata":{"title":"Going further with more resources","categoryPathComponent":"Table-Of-Contents","role":"project","category":"Orange Unified Design System"},"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-6-going-further"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"https://github.com/Orange-OpenSource/ouds-ios/discussions":{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","titleInlineContent":[{"type":"text","text":"open or participate to discussions"}],"url":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","type":"link","title":"open or participate to discussions"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents":{"title":"Swift Package iOS Tutorial","url":"\/tutorials\/table-of-contents","role":"overview","abstract":[{"text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework."},{"type":"text","text":" "},{"type":"text","text":"Theme, components, tokens… everything will be introduced!"}],"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","kind":"overview"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Final-result":{"kind":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Final-result","title":"Final result","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","role":"pseudoSymbol","type":"section"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Preparation-of-the-theme":{"url":"\/tutorials\/table-of-contents\/preparation-of-the-theme","type":"topic","role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Preparation-of-the-theme","abstract":[],"title":"Preparation of the theme","kind":"article"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components":{"kind":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components","title":"Use your first OUDS components","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components","role":"project","type":"topic","estimatedTime":"30min"},"tutorial-6-3.png":{"alt":"The wiki with plenty of details about processes, releases, API and technical choices","variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-6-3.png","traits":["1x","light"]}],"identifier":"tutorial-6-3.png","type":"image"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Import-of-the-Swift-Package-and-choose-its-librairies":{"title":"Import of the Swift Package and choose its librairies","url":"\/tutorials\/table-of-contents\/import-of-the-swift-package-and-choose-its-librairies","role":"article","abstract":[],"typ