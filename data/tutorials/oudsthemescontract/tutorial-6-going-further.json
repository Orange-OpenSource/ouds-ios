faceLanguage":"swift"},"sections":[{"image":"ic_theme_intro.png","kind":"hero","estimatedTimeInMinutes":10,"chapter":"Go further with more ressources","title":"Going further with more resources","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources."}]}],"backgroundImage":"ic_theme_intro.png"},{"tasks":[{"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Xcode can use the Swift DocC documentation of OUDS, and this documentation is used to build a static web site."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"But there are also other resources which can be useful for you."}]}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"The iOS technical documentation is available online. It has been generated from all the Swift DocC documentation written in the Swift Package."},{"type":"text","text":" "},{"type":"text","text":"You will find several catalogs (as many as librairies) with details about everyhting: components, tokens, themes, providers, etc."}],"type":"paragraph"}],"caption":[{"inlineContent":[{"text":"You can get it at ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/","type":"reference"}],"type":"paragraph"}],"type":"step","media":"tutorial-6-1.png","code":null},{"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"The whole design system is documented and available online. You can find everything about components, tokens, guidelines and principles of OUDS."},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"icon finder"}],"type":"emphasis"},{"text":" is also available there to get icons for your projects.","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"text":"Go to the website and learn things at ","type":"text"},{"identifier":"https:\/\/unified-design-system.orange.com\/","type":"reference","isActive":true}],"type":"paragraph"}],"type":"step","media":"tutorial-6-2.png","code":null},{"runtimePreview":null,"content":[{"inlineContent":[{"text":"OUDS iOS provides also a wiki attached to its GitHub repository. The wiki is a public base of knowledge with plenty of things: available API, technicala architecture, tips about processes, tests, conventions and toolings.","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"text":"Have a look ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki","type":"reference"},{"text":" to discover how OUDS works.","type":"text"}],"type":"paragraph"}],"type":"step","media":"tutorial-6-3.png","code":null},{"content":[{"inlineContent":[{"text":"For technical reasons the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","type":"reference"},{"text":" GitHub repository does not embed the source code of the ","type":"text"},{"inlineContent":[{"type":"text","text":"design system toolbox"}],"type":"emphasis"},{"text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository.","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"text":"To get the source code of this showcase app, go to its dedicated GitHub repository at ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox","type":"reference"}],"type":"paragraph"}],"media":"tutorial-6-4.png","code":null,"runtimePreview":null,"type":"step"},{"code":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","isActive":true},{"text":" GitHub repository.","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"Do not hesitate to "},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","type":"reference"},{"text":" or ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","isActive":true},{"text":"!","type":"text"}],"type":"paragraph"}],"media":"tutorial-6-5.png","runtimePreview":null}],"anchor":"More-resources","title":"More resources"}],"kind":"tasks"}],"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-6-going-further"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Check-Your-Understanding":{"title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Check-Your-Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Check-Your-Understanding","type":"link"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Basic-structure-for-the-app":{"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"type":"section","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","title":"Basic structure for the app","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","role":"pseudoSymbol","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components":{"es