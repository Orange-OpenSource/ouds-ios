ent":[{"inlineContent":[{"text":"Since you have learnt how OUDS works with theme, themeable view, components, tuning and vieww modifiers, it is time now to discover some online resources.","type":"text"}],"type":"paragraph"}],"kind":"hero"},{"kind":"tasks","tasks":[{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"Xcode can use the Swift DocC documentation of OUDS, and this documentation is used to build a static web site.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"But there are also other resources which can be useful for you."}],"type":"paragraph"}]}],"stepsSection":[{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"You can get it at ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/"}]}],"media":"tutorial-6-1.png","code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"The iOS technical documentation is available online. It has been generated from all the Swift DocC documentation written in the Swift Package.","type":"text"},{"text":" ","type":"text"},{"text":"You will find several catalogs (as many as librairies) with details about everyhting: components, tokens, themes, providers, etc.","type":"text"}]}]},{"type":"step","caption":[{"inlineContent":[{"type":"text","text":"Go to the website and learn things at "},{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/","isActive":true}],"type":"paragraph"}],"media":"tutorial-6-2.png","code":null,"runtimePreview":null,"content":[{"inlineContent":[{"text":"The whole design system is documented and available online. You can find everything about components, tokens, guidelines and principles of OUDS.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"inlineContent":[{"text":"icon finder","type":"text"}],"type":"emphasis"},{"text":" is also available there to get icons for your projects.","type":"text"}],"type":"paragraph"}]},{"type":"step","caption":[{"inlineContent":[{"type":"text","text":"Have a look "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki","type":"reference","isActive":true},{"type":"text","text":" to discover how OUDS works."}],"type":"paragraph"}],"media":"tutorial-6-3.png","code":null,"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"OUDS iOS provides also a wiki attached to its GitHub repository. The wiki is a public base of knowledge with plenty of things: available API, technicala architecture, tips about processes, tests, conventions and toolings."}],"type":"paragraph"}]},{"type":"step","caption":[{"inlineContent":[{"text":"To get the source code of this showcase app, go to its dedicated GitHub repository at ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox","isActive":true}],"type":"paragraph"}],"media":"tutorial-6-4.png","code":null,"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"For technical reasons the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios"},{"type":"text","text":" GitHub repository does not embed the source code of the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"design system toolbox"}]},{"type":"text","text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository."}],"type":"paragraph"}]},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not hesitate to "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions"},{"type":"text","text":"!"}]}],"media":"tutorial-6-5.png","code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the "},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","type":"reference"},{"type":"text","text":" GitHub repository."}]}]}],"anchor":"More-resources","title":"More resources"}]}],"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-6-going-further"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"project","metadata":{"category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents","role":"project","title":"Going further with more resources"},"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"type":"topic","title":"Add more OUDS components","kind":"project","role":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","estimatedTime":"30min"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Use-of-view-modifiers":{"url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Use-of-view-modifiers","role":"pseudoSymbol","title":"Use of view modifiers","type":"section","kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things":{"abstract":[{"type":"text","text":"Even 