"    }","}","","#Preview {","    InfoCard(","        assetName: \"Picture2\",","        title: \"Orange for the sector\",","        subtitle: \"A complete offer for Institutions\",","        description: \"Our experience as a partner in the digital transformation of companies and institutions guarantees the high efficiency of the services provided.\",","        buttonLabel: \"Transmission\")","        .orangePreview()","}"],"fileName":"InfoCard.swift"},"tutorial-onboarding-2-6.png":{"variants":[{"url":"\/images\/OUDSThemesContract\/tutorial-onboarding-2-6.png","traits":["1x","light"]}],"identifier":"tutorial-onboarding-2-6.png","type":"image","alt":"A view with image, texts and a strong button"},"ic_theme_intro.png":{"variants":[{"url":"\/images\/OUDSThemesContract\/ic_theme_intro.png","traits":["1x","light"]}],"identifier":"ic_theme_intro.png","type":"image","alt":"OUDS themes logo"},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/spacesemantictokens":{"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacesemantictokens","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacesemantictokens","title":"Spacing values are defined also in tokens","type":"link","titleInlineContent":[{"type":"text","text":"Spacing values are defined also in tokens"}]},"https://www.figma.com/design/zJl6GhY2gMSMAibBJXoNPy/Reveal-and-Onboarding?node-id=2259-4970&m=dev":{"url":"https:\/\/www.figma.com\/design\/zJl6GhY2gMSMAibBJXoNPy\/Reveal-and-Onboarding?node-id=2259-4970&m=dev","identifier":"https:\/\/www.figma.com\/design\/zJl6GhY2gMSMAibBJXoNPy\/Reveal-and-Onboarding?node-id=2259-4970&m=dev","title":"the Figma specifications","type":"link","titleInlineContent":[{"type":"text","text":"the Figma specifications"}]},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/spacemultiplesemantictokens":{"url":"https:\/\/ios.unified-design-system.orange.com