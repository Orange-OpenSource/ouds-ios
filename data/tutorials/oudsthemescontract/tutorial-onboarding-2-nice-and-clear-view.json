e"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"scaled2xsmall"}],"type":"emphasis"},{"text":" as ","type":"text"},{"inlineContent":[{"type":"text","text":"vertical padding"}],"type":"emphasis"},{"text":" for the ","type":"text"},{"inlineContent":[{"type":"text","text":"subtitle"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"scaledLarge"}],"type":"emphasis"},{"text":" as minimum length for a ","type":"text"},{"code":"Spacer","type":"codeVoice"},{"text":" above the ","type":"text"},{"inlineContent":[{"type":"text","text":"button"}],"type":"emphasis"},{"text":".","type":"text"}]}],"code":"tutorial-onboarding-2-7.swift","content":[{"type":"paragraph","inlineContent":[{"text":"You agree things are stucked and spacings are missing. ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacesemantictokens","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Some of these tokens have unique value like ","type":"text"},{"code":"theme.spaces.fixedMedium","type":"codeVoice"},{"text":", but ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacemultiplesemantictokens","isActive":true,"type":"reference"},{"text":" depending to the ","type":"text"},{"inlineContent":[{"type":"text","text":"size class"}],"type":"emphasis"},{"text":" of the view like ","type":"text"},{"code":"theme.spaces.scaled2xsmall","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In addition, OUDS provides view modifiers to define ","type":"text"},{"inlineContent":[{"type":"text","text":"grid margins"}],"type":"emphasis"},{"text":" on a view depending to a ","type":"text"},{"inlineContent":[{"type":"text","text":"size class"}],"type":"emphasis"},{"text":".","type":"text"}]}],"runtimePreview":"tutorial-onboarding-2-7.png","media":null},{"