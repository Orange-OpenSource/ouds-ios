eview()"},{"text":" view modifier.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS library provides view modifiers to be used in Xcode previews macros.","type":"text"},{"text":" ","type":"text"},{"text":"It allows to apply the theme you want in the view","type":"text"}]}],"code":"tutorial-onboarding-2-2.swift","type":"step","media":null},{"runtimePreview":"tutorial-onboarding-2-3.png","caption":[{"inlineContent":[{"type":"text","text":"Use a "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" containing "},{"type":"codeVoice","code":"Image"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Text"},{"type":"text","text":" "},{"type":"codeVoice","code":"View"},{"type":"text","text":" objects."}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"Now, use the properties you defined in the Xcode preview, and display them in your "},{"type":"codeVoice","code":"InfoCard"},{"type":"text","text":" "},{"type":"codeVoice","code":"View"},{"type":"text","text":"."}],"type":"paragraph"}],"code":"tutorial-onboarding-2-3.swift","type":"step","media":null},{"runtimePreview":"tutorial-onboarding-2-4.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"title"}]},{"text":" with want a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"medium heading"}]},{"text":", an ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"XL heading","type":"text"}]},{"type":"text","text":" for the "},{"inlineContent":[{"text":"subtitle","type":"text"}],"type":"emphasis"},{"type":"text","text":" and a "},{"inlineContent":[{"type":"text","text":"large default body"}],"type":"emphasis"},{"type":"text","text":" for the "},{"inlineContent":[{"type":"text","text":"description"}],"type":"emphasis"},{"text":". You will need to get the ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emp