ified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacesemantictokens","type":"reference","isActive":true},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Some of these tokens have unique value like "},{"code":"theme.spaces.fixedMedium","type":"codeVoice"},{"text":", but ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacemultiplesemantictokens","isActive":true,"type":"reference"},{"text":" depending to the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"size class"}]},{"text":" of the view like ","type":"text"},{"type":"codeVoice","code":"theme.spaces.scaled2xsmall"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"In addition, OUDS provides view modifiers to define ","type":"text"},{"inlineContent":[{"type":"text","text":"grid margins"}],"type":"emphasis"},{"text":" on a view depending to a ","type":"text"},{"inlineContent":[{"type":"text","text":"size class"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"}],"code":"tutorial-onboarding-2-7.swift","media":null},{"runtimePreview":"tutorial-onboarding-2-8.png","caption":[{"inlineContent":[{"type":"text","text":"Define an "},{"type":"codeVoice","code":"HomeView"},{"type":"text","text":" with two "},{"type":"codeVoice","code":"InfoCard"},{"type":"text","text":" "},{"type":"codeVoice","code":"View"},{"type":"text","text":" objects. For the second view, for to "},{"type":"emphasis","inlineContent":[{"text":"dark color scheme","type":"text"}]},{"type":"text","text":" and apply "},{"type":"codeVoice","code":"theme.colors.bgInverseLow"},{"type":"text","text":" background color."}],"type":"paragraph"}],"type":"step","content":[{"inlineContent":[{"type":"text","text":"It is possible to force the "},{"inlineContent":[{"type":"text","text":"color scheme"}],"type":"emphasis"},{"type":"text","text":" of your view with "},{"inlineContent":[{"type":"text","text":"SwiftUI"}],"type":"emphasis"},{"type":"text","text":" and apply a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"color token"}]},{"type":"text","text":" as background which will vary depending to this scheme."}],"type":"paragraph"}],"code":"tutorial-onboarding-2-8.swift","media":null}]}],"kind":"tasks"},{"assessments":[{"content":[],"choices":[{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inside tokens providers exposed by the theme"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes! Get the theme through environment variable and use its providers"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Nowhere, I must define my own"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"Nope! All tokens are defined and provided through OUDS library"}],"type":"paragraph"}],"isCorrect":false}],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Where can I find tokens?"}]}],"type":"multiple-choice"},{"content":[],"choices":[{"content":[{"inlineContent":[{"type":"text","text":"I must instanciate it every time I need"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"The theme is provided through an environment object, instanciated thanks to a preview view modifier or specific view."}],"type":"paragraph"}],"isCorrect":false},{"content":[{"inlineContent":[{"type":"text","text":"Using an environment value"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"Theme is exposed as environment object, available within views for example."}],"type":"paragraph"}],"isCorrect":true}],"title":[{"type":"paragraph","inlineContent":[{"type":"text","text":"How can I get the theme to apply?"}]}],"type":"multiple-choice"}],"anchor":"Check-Your-Understanding","kind":"assessments"},{"action":{"overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesCont