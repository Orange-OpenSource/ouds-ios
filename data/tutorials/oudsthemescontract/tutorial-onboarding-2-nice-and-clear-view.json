"text"}]},{"type":"text","text":" of the view like "},{"type":"codeVoice","code":"theme.spaces.scaled2xsmall"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In addition, OUDS provides view modifiers to define "},{"type":"emphasis","inlineContent":[{"text":"grid margins","type":"text"}]},{"type":"text","text":" on a view depending to a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"size class"}]},{"type":"text","text":"."}],"type":"paragraph"}],"code":"tutorial-onboarding-2-7.swift","runtimePreview":"tutorial-onboarding-2-7.png"},{"media":null,"code":"tutorial-onboarding-2-8.swift","type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"It is possible to force the ","type":"text"},{"inlineContent":[{"type":"text","text":"color scheme"}],"type":"emphasis"},{"text":" of your view with ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"SwiftUI","type":"text"}]},{"type":"text","text":" and apply a "},{"inlineContent":[{"text":"color token","type":"text"}],"type":"emphasis"},{"text":" as background which will vary depending to this scheme.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Define an ","type":"text"},{"type":"codeVoice","code":"HomeView"},{"text":" with two ","type":"text"},{"type":"codeVoice","code":"InfoCard"},{"type":"text","text":" "},{"code":"View","type":"codeVoice"},{"type":"text","text":" objects. For the second view, for to "},{"inlineContent":[{"type":"text","text":"dark color scheme"}],"type":"emphasis"},{"text":" and apply ","type":"text"},{"type":"codeVoice","code":"theme.colors.bgInverseLow"},{"type":"text","text":" background color."}]}],"runtimePreview":"tutorial-onboarding-2-8.png"}],"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Before designing awesome SwiftUI view with OUDS, we need to write before the properties of such view."},{"type":"text","text":" "},{"type":"text","text":"You should have an access to "},{"isActive":true,"type":"reference","identifier":"https:\/\/www.figma.com\/design\/zJl6GhY2gMSMAibBJXoNPy\/Reveal-and-Onboarding?node-id=2259-4970&m=dev"},{"type":"text","text":"."}]}]}],"anchor":"Define-the-view-basics","title":"Define the view basics"}]},{"kind":"assessments","anchor":"Check-Your-Understanding","assessments":[{"type":"multiple-choice","content":[],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inside tokens providers exposed by the theme"}]}],"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"Yes! Get the theme through environment variable and use its providers"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Nowhere, I must define my own"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"Nope! All tokens are defined and provided through OUDS library"}],"type":"paragraph"}]}],"title":[{"inlineContent":[{"type":"text","text":"Where can I find tokens?"}],"type":"paragraph"}]},{"title":[{"inlineContent":[{"type":"text","text":"How can I get the theme to apply?"}],"type":"paragraph"}],"type":"multiple-choice","choices":[{"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"text":"The theme is provided through an environment object, instanciated thanks to a preview view modifier or specific view.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"I must instanciate it every time I need"}]}]},{"content":[{"inlineContent":[{"text":"Using an environment value","type":"text"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"Theme is exposed as environment object, available within views for example."}],"type":"paragraph"}]}],"content":[]}]},{"featuredEyebrow":"Tutorial","action":{"type":"reference","overridingTitle":"Get started","isActive":true,"identif