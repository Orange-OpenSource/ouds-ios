erties of such view.","type":"text"},{"text":" ","type":"text"},{"text":"You should have an access to ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.figma.com\/design\/zJl6GhY2gMSMAibBJXoNPy\/Reveal-and-Onboarding?node-id=2259-4970&m=dev"},{"text":".","type":"text"}],"type":"paragraph"}]}],"anchor":"Define-the-view-basics","stepsSection":[{"type":"step","caption":[],"code":"tutorial-onboarding-2-1.swift","media":null,"content":[{"inlineContent":[{"text":"Define a basic ","type":"text"},{"code":"InfoCard","type":"codeVoice"},{"text":" ","type":"text"},{"code":"View","type":"codeVoice"},{"text":", it must have an asset name to load as image, a title, a subtitle, a description and a label for the button.","type":"text"},{"text":" ","type":"text"},{"text":"Add also the Xcode ","type":"text"},{"code":"#Preview","type":"codeVoice"},{"text":" macro to display the view, here of course it will be empty.","type":"text"}],"type":"paragraph"}],"runtimePreview":"tutorial-onboarding-2-1.png"},{"type":"step","caption":[{"inlineContent":[{"text":"Supposing we will work with Orange theme here, apply the ","type":"text"},{"code":"orangePreview()","type":"codeVoice"},{"text":" view modifier.","type":"text"}],"type":"paragraph"}],"code":"tutorial-onboarding-2-2.swift","media":null,"content":[{"inlineContent":[{"text":"OUDS library provides view modifiers to be used in Xcode previews macros.","type":"text"},{"text":" ","type":"text"},{"text":"It allows to apply the theme you want in the view","type":"text"}],"type":"paragraph"}],"runtimePreview":"tutorial-onboarding-2-1.png"},{"type":"step","caption":[{"inlineContent":[{"text":"Use a ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":" containing ","type":"text"},{"code":"Image","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Text"},{"type":"text","text":" "},{"type":"codeVoice","code":"View"},{"type":"text","text":" objects."}],"type":"paragraph"}],"code":"tutorial-onboarding-2-3.swift","media":null,"content":[{"inlineContent":[{"text":"Now, use the properties you defined in the Xcode preview, and display them in your ","type":"text"},{"code":"InfoCard","type":"codeVoice"},{"text":" ","type":"text"},{"code":"View","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"runtimePreview":"tutorial-onboarding-2-3.png"},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"For the ","type":"text"},{"inlineContent":[{"text":"title","type":"text"}],"type":"emphasis"},{"text":" with want a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"medium heading"}]},{"text":", an ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"XL heading"}]},{"text":" for the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"subtitle"}]},{"text":" and a ","type":"text"},{"inlineContent":[{"text":"large default body","type":"text"}],"type":"emphasis"},{"text":" for the ","type":"text"},{"inlineContent":[{"text":"description","type":"text"}],"type":"emphasis"},{"text":". You will need to get the ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"text":" object throw the dedicated environment variable to give it to the view modifiers.","type":"text"}]}],"code":"tutorial-onboarding-2-4.swift","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"You may want to apply typography on texts. These effects will show most important content and bring meanings.","type":"text"},{"text":" ","type":"text"},{"text":"You can have a look on the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudscomponents\/swiftuicore\/view","type":"reference","isActive":true},{"type":"text","text":", which can be applied on "},{"code":"View","type":"codeVoice"},{"type":"text","text":" object."}]}],"runtimePreview":"tutorial-onboarding-2-4.png"},{"code":"tutorial-onboarding-2-5.swift","type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now, it’s time to apply colors on texts. "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/colorsemantictokens","isActive":true},{"type":"text","text":", i.e. small atomic elements defined in the design Figma kit. The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" object contains tokens and provides them thanks to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"providers"}]},{"type":"text","text":"."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For all texts, change the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"foreground color"}]},{"type":"text","text":": apply "},{"inlineContent":[{"text":"contentBrandPrimary","type":"text"}],"type":"emphasis"},{"text":" for the ","type":"text"},{"inlineContent":[{"text":"title","type":"text"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"text":"contentDefault","type":"text"}],"type":"emphasis"},{"type":"text","text":" for the subtitle and also the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"description"}]},{"text":".","type":"text"}]}],"media":null,"runtimePreview":"tutorial-onboarding-2-5.png"},{"runtimePreview":"tutorial-onboarding-2-6.png","code":"tutorial-onboarding-2-6.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now, it’s time to add the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudscomponents\/oudsbutton","type":"reference","isActive":true},{"type":"text","text":". OUDS provides plenty of components with properties related to notions defined in Figma kit and DSM. For example a button can have "},{"type":"emphasis","inlineContent":[{"type":"text","text":"appearance"}]},{"type":"text","text":"."}]}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a button with a "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudscomponents\/oudsbutton#Appearances","type":"reference","isActive":true},{"type":"text","text":", using the previously defined label, and no action."}]}],"media":null},{"type":"step","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You agree things are stucked and spacings are missing. "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacesemantictokens"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Some of these tokens have unique value like "},{"type":"codeVoice","code":"theme.spaces.fixedMedium"},{"type":"text","text":", but "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacemultiplesemantictokens"},{"type":"text","text":" depending to the "},{"type":"emphasis","inlineContent":[{"text":"size class","type":"text"}]},{"type":"text","text":" of the view like "},{"type":"codeVoice","code":"theme.spaces.scaled2xsmall"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In addition, OUDS provides view modifiers to define "},{"type":"emphasis","inlineContent":[{"text":"grid margins","type":"text"}]},{"type":"text","text":" on a view depending to a "},{"type":"emphasis","inlineContent":[{"text":"size class","type":"text"}]},{"type":"text","text":"."}]}],"code":"tutorial-onboarding-2-7.swift","runtimePreview":"tutorial-onboarding-2-7.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Try to apply some spacings: "},{"type":"emphasis","inlineContent":[{"text":"fixedNone","type":"text"}]},{"type":"text","text":" in the "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"fixedMedium","type":"text"}]},{"type":"text","text":" as a "},{"type":"codeVoice","code":"Spacer"},{"type":"text","text":" minimum length below the button, "},{"type":"emphasis","inlineContent":[{"text":"top grid margin","type":"text"}]},{"type":"text","text":" for the "},{"type":"emphasis","inlineContent":[{"text":"title","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"grid margin","type":"text"}]},{"type":"text","text":" for all the "},{"type":"codeVoice","code":"View"},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"scaled2xsmall","type":"text"}]},{"type":"text","text":" as "},{"type":"emphasis","inlineContent":[{"text":"vertical padding","type":"text"}]},{"type":"text","text":" for the "},{"type":"emphasis","inlineContent":[{"text":"subtitle","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"scaledLarge","type":"text"}]},{"type":"text","text":" as minimum length for a "},{"type":"codeVoice","code":"Spacer"},{"type":"text","text":" above the "},{"type":"emphasis","inlineContent":[{"text":"button","type":"text"}]},{"type":"text","text":"."}]}]},{"type":"step","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It is possible to force the "},{"type":"emphasis","inlineContent":[{"text":"color scheme","type":"text"}]},{"type":"text","text":" of your view with "},{"type":"emphasis","inlineContent":[{"text":"SwiftUI","type":"text"}]},{"type":"text","text":" and apply a "},{"type":"emphasis","inlineContent":[{"text":"color token","type":"text"}]},{"type":"text","text":" as background which will vary depending to this scheme."}]}],"code":"tutorial-onboarding-2-8.swift","runtimePreview":"tutorial-onboarding-2-8.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Define an "},{"type":"codeVoice","code":"HomeView"},{"type":"text","text":" with two "},{"type":"codeVoice","code":"InfoCard"},{"type":"text","text":" "},{"type":"codeVoice","code":"View"},{"type":"text","text":" objects. For the second view, for to "},{"type":"emphasis","inlineContent":[{"text":"dark color scheme","type":"text"}]},{"type":"text","text":" and apply "},{"type":"codeVoice","code":"theme.colors.bgInverseLow"},{"type":"text","text":" background color."}]}]}],"title":"Define the view basics"}]},{"assessments":[{"title":[{"type":"paragraph","inlineContent":[{"text":"Where can I find tokens?","type":"text"}]}],"type":"multiple-choice","content":[],"choices":[{"content":[{"inlineContent":[{"type":"text","text":"Inside tokens providers exposed by the theme"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"Yes! Get the theme through environment variable and use its providers"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Nowhere, I must define my own"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"Nope! All tokens are defined and provided through OUDS library"}],"type":"paragraph"}]}]},{"title":[{"type":"paragraph","inlineContent":[{"text":"How can I get the theme to apply?","type":"text"}]}],"type":"multiple-choice","content":[],"choices":[{"content":[{"inlineContent":[{"type":"text","text":"I must instanciate it every time I need"}],"type":"paragraph"}],"isCorrect":false,"justification":[{"inlineContent":[{"type":"text","text":"The theme is provided through an environment object, instanciated thanks to a preview view modifier or specific view."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Using an environment value"}],"type":"paragraph"}],"isCorrect":true,"justification":[{"inlineContent":[{"type":"text","text":"Theme is exposed as environment object, available within views for example."}],"type":"paragraph"}]}]}],"kind":"assessments","anchor":"Check-Your-Understanding"},{"featuredEyebrow":"Tutorial","action":{"identifier":"doc:\/\/OUDSThemesContract\/tutoria