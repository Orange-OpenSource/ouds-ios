},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" containing "},{"type":"codeVoice","code":"Image"},{"type":"text","text":" and "},{"code":"Text","type":"codeVoice"},{"type":"text","text":" "},{"code":"View","type":"codeVoice"},{"type":"text","text":" objects."}],"type":"paragraph"}],"type":"step","runtimePreview":"tutorial-onboarding-2-3.png","media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You may want to apply typography on texts. These effects will show most important content and bring meanings."},{"type":"text","text":" "},{"type":"text","text":"You can have a look on the "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudscomponents\/swiftuicore\/view"},{"type":"text","text":", which can be applied on "},{"type":"codeVoice","code":"View"},{"type":"text","text":" object."}]}],"code":"tutorial-onboarding-2-4.swift","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For the "},{"inlineContent":[{"type":"text","text":"title"}],"type":"emphasis"},{"type":"text","text":" with want a "},{"inlineContent":[{"type":"text","text":"medium heading"}],"type":"emphasis"},{"type":"text","text":", an "},{"inlineContent":[{"type":"text","text":"XL heading"}],"type":"emphasis"},{"type":"text","text":" for the "},{"inlineContent":[{"type":"text","text":"subtitle"}],"type":"emphasis"},{"type":"text","text":" and a "},{"inlineContent":[{"text":"large default body","type":"text"}],"type":"emphasis"},{"type":"text","text":" for the "},{"inlineContent":[{"type":"text","text":"description"}],"type":"emphasis"},{"text":". You will need to get the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" object throw the dedicated environment variable to give it to the view modifiers."}]}],"type":"step","runtimePreview":"tutorial-onboarding-2-4.png","media":null},{"runtimePreview":"tutorial-onboarding-2-5.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For all texts, change the "},{"type":"emphasis","inlineContent":[{"text":"foreground color","type":"text"}]},{"text":": apply ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"contentBrandPrimary","type":"text"}]},{"text":" for the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"title","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"contentDefault","type":"text"}]},{"type":"text","text":" for the subtitle and also the "},{"type":"emphasis","inlineContent":[{"text":"description","type":"text"}]},{"type":"text","text":"."}]}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now, it’s time to apply colors on texts. "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/colorsemantictokens","isActive":true,"type":"reference"},{"type":"text","text":", i.e. small atomic elements defined in the design Figma kit. The "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"text":" object contains tokens and provides them thanks to ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"providers","type":"text"}]},{"text":".","type":"text"}]}],"code":"tutorial-onboarding-2-5.swift","media":null},{"runtimePreview":"tutorial-onboarding-2-6.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a button with a "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudscomponents\/oudsbutton#Appearances","isActive":true,"type":"reference"},{"text":", using the previously defined label, and no action.","type":"text"}]}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now, it’s time to add the "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudscomponents\/oudsbutton"},{"type":"