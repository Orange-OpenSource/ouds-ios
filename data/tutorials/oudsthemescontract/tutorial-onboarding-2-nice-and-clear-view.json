,"\/\/ Software description: A SwiftUI components library with code examples for Orange Unified Design System","\/\/","","import OUDSSwiftUI","import SwiftUI","","struct InfoCard: View {","","    let assetName: String","    let title: String","    let subtitle: String","    let description: String","    let buttonLabel: String","","    var body: some View {","        VStack(alignment: .leading) {","            Image(assetName, bundle: .main)","                .resizable()","                .aspectRatio(contentMode: .fit)","","            Text(title)","","            Text(subtitle)","","            Text(description)","        }","    }","}","","#Preview {","    InfoCard(","        assetName: \"Picture2\",","        title: \"Orange for the sector\",","        subtitle: \"A complete offer for Institutions\",","        description: \"Our experience as a partner in the digital transformation of companies and institutions guarantees the high efficiency of the services provided.\",","        buttonLabel: \"Transmission\")","        .orangePreview()","}"],"identifier":"tutorial-onboarding-2-3.swift","highlights":[{"line":26},{"line":27},{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36}],"type":"file"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(onboarding)/Components-showcases":{"title":"Components showcases","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)\/Components-showcases","kind":"article","role":"article","type":"topic","abstract":[],"url":"\/tutorials\/table-of-contents-(onboarding)\/components-showcases"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-3-components-showcase#Navigations-and-themeable-view-a-step-further":{"title":"Navigations and themeable view, a step further","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase#Navigations-and-themeable-view-a-step-further"