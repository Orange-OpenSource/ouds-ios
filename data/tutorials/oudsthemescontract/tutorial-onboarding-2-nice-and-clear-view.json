 a title, a subtitle, a description and a label for the button.","type":"text"},{"text":" ","type":"text"},{"text":"Add also the Xcode ","type":"text"},{"type":"codeVoice","code":"#Preview"},{"text":" macro to display the view, here of course it will be empty.","type":"text"}]}],"runtimePreview":"tutorial-onboarding-2-1.png"},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Supposing we will work with Orange theme here, apply the ","type":"text"},{"type":"codeVoice","code":"orangePreview()"},{"text":" view modifier.","type":"text"}]}],"code":"tutorial-onboarding-2-2.swift","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS library provides view modifiers to be used in Xcode previews macros.","type":"text"},{"text":" ","type":"text"},{"text":"It allows to apply the theme you want in the view","type":"text"}]}],"runtimePreview":"tutorial-onboarding-2-1.png"},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Use a ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" containing ","type":"text"},{"type":"codeVoice","code":"Image"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" objects.","type":"text"}]}],"code":"tutorial-onboarding-2-3.swift","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Now, use the properties you defined in the Xcode preview, and display them in your ","type":"text"},{"type":"codeVoice","code":"InfoCard"},{"text":" ","type":"text"},{"type":"codeVoice","code":"View"},{"text":".","type":"text"}]}],"runtimePreview":"tutorial-onboarding-2-3.png"},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"For the ","type":"text"},{"inlineContent":[{"text":"title","type":"text"}],"type":"emphasis"},{"text":" with want a ","type":"text"},{"inlineContent":[{"text":"medium heading","type":"text"}],"type":"emphasis"},{"text":", an ","type":"text"},{"inlineContent":[{"text":"XL heading","type":"text"}],"type":"emphasis"},{"text":" for the ","type":"text"},{"inlineContent":[{"text":"subtitle","type":"text"}],"type":"emphasis"},{"text":" and a ","type":"text"},{"inlineContent":[{"text":"large default body","type":"text"}],"type":"emphasis"},{"text":" for the ","type":"text"},{"inlineContent":[{"text":"description","type":"text"}],"type":"emphasis"},{"text":". You will need to get the ","type":"text"},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"text":" object throw the dedicated environment variable to give it to the view modifiers.","type":"text"}]}],"code":"tutorial-onboarding-2-4.swift","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"You may want to apply typography on texts. These effects will show most important content and bring meanings.","type":"text"},{"text":" ","type":"text"},{"text":"You can have a look on the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudscomponents\/swiftuicore\/view","isActive":true,"type":"reference"},{"text":", which can be applied on ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" object.","type":"text"}]}],"runtimePreview":"tutorial-onboarding-2-4.png"},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"For all texts, change the ","type":"text"},{"inlineContent":[{"type":"text","text":"foreground color"}],"type":"emphasis"},{"text":": apply ","type":"text"},{"inlineContent":[{"type":"text","text":"contentBrandPrimary"}],"type":"emphasis"},{"text":" for the ","type":"text"},{"inlineContent":[{"type":"text","text":"title"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"contentDefault"}],"type":"emphasis"},{"text":" for the subtitle and also the ","type":"text"},{"inlineContent":[{"type":"text","text":"description"}],"type":"emphasis"},{"text":".","type":"text"}]}],"code":"tutorial-onboarding-2-5.swift","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Now, it’s time to apply colors on texts. ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/colorsemantictokens","type":"reference"},{"text":", i.e. small atomic elements defined in the design Figma kit. The ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"text":" object contains tokens and provides them thanks to ","type":"text"},{"inlineContent":[{"type":"text","text":"providers"}],"type":"emphasis"},{"text":".","type":"text"}]}],"runtimePreview":"tutorial-onboarding-2-5.png"},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Add a button with a ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudscomponents\/oudsbutton#Appearances","type":"reference"},{"text":", using the previously defined label, and no action.","type":"text"}]}],"code":"tutorial-onboarding-2-6.swift","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Now, it’s time to add the ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudscomponents\/oudsbutton","type":"reference"},{"text":". OUDS provides plenty of components with properties related to notions defined in Figma kit and DSM. For example a button can have ","type":"text"},{"inlineContent":[{"type":"text","text":"appearance"}],"type":"emphasis"},{"text":".","type":"text"}]}],"runtimePreview":"tutorial-onboarding-2-6.png"},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Try to apply some spacings: ","type":"text"},{"inlineContent":[{"type":"text","text":"fixedNone"}],"type":"emphasis"},{"text":" in the ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"fixedMedium"}],"type":"emphasis"},{"text":" as a ","type":"text"},{"code":"Spacer","type":"codeVoice"},{"text":" minimum length below the button, ","type":"text"},{"inlineContent":[{"type":"text","text":"top grid margin"}],"type":"emphasis"},{"text":" for the ","type":"text"},{"inlineContent":[{"type":"text","text":"title"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"grid margin"}],"type":"emphasis"},{"text":" for all the ","type":"text"},{"code":"View","type":"codeVoice"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"scaled2xsmall"}],"type":"emphasis"},{"text":" as ","type":"text"},{"inlineContent":[{"type":"text","text":"vertical padding"}],"type":"emphasis"},{"text":" for the ","type":"text"},{"inlineContent":[{"type":"text","text":"subtitle"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"scaledLarge"}],"type":"emphasis"},{"text":" as minimum length for a ","type":"text"},{"code":"Spacer","type":"codeVoice"},{"text":" above the ","type":"text"},{"inlineContent":[{"type":"text","text":"button"}],"type":"emphasis"},{"text":".","type":"text"}]}],"code":"tutorial-onboarding-2-7.swift","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"You agree things are stucked and spacings are missing. ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacesemantictokens","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Some of these tokens have unique value like ","type":"text"},{"code":"theme.spaces.fixedMedium","type":"codeVoice"},{"text":", but ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/spacemultiplesemantictokens","type":"reference"},{"text":" depending to the ","type":"text"},{"inlineContent":[{"type":"text","text":"size class"}],"type":"emphasis"},{"text":" of the view like ","type":"text"},{"code":"theme.spaces.scaled2xsmall","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In addition, OUDS provides view modifiers to define ","type":"text"},{"inlineContent":[{"type":"text","text":"grid margins"}],"type":"emphasis"},{"text":" on a view depending to a ","type":"text"},{"inlineContent":[{"type":"text","text":"size class"}],"type":"emphasis"},{"text":".","type":"text"}]}],"runtimePreview":"tutorial-onboarding-2-7.png"},{"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Define an ","type":"text"},{"code":"HomeView","type":"codeVoice"},{"text":" with two ","type":"text"},{"code":"InfoCard","type":"codeVoice"},{"text":" ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" objects. For the second view, for to ","type":"text"},{"inlineContent":[{"type":"text","text":"dark color scheme"}],"type":"emphasis"},{"text":" and apply ","type":"text"},{"code":"theme.colors.bgInverseLow","type":"codeVoice"},{"text":" background color.","type":"text"}]}],"code":"tutorial-onboarding-2-8.swift","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"It is possible to force the ","type":"text"},{"inlineContent":[{"type":"text","text":"color scheme"}],"type":"emphasis"},{"text":" of your view with ","type":"text"},{"inlineContent":[{"type":"text","text":"SwiftUI"}],"type":"emphasis"},{"text":" and apply a ","type":"text"},{"inlineContent":[{"type":"text","text":"color token"}],"type":"emphasis"},{"text":" as background which will vary depending to this scheme.","type":"text"}]}],"runtimePreview":"tutorial-onboarding-2-8.png"}],"anchor":"Define-the-view-basics","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"Before designing awesome SwiftUI view with OUDS, we need to write before the properties of such view.","type":"text"},{"text":" ","type":"text"},{"text":"You should have an access to ","type":"text"},{"identifier":"https:\/\/www.figma.com\/design\/zJl6GhY2gMSMAibBJXoNPy\/Reveal-and-Onboarding?node-id=2259-4970&m=dev","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]}]}],"kind":"tasks"},{"kind":"assessments","assessments":[{"type":"multiple-choice","title":[{"inlineContent":[{"type":"text","text":"Where can I find tokens?"}],"type":"paragraph"}],"content":[],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Inside tokens providers exposed by the theme","type":"text"}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"Yes! Get the theme through environment variable and use its providers","type":"text"}]}],"isCorrect":true},{"content":[{"type":"paragraph","inlineContent":[{"text":"Nowhere, I must define my own","type":"text"}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"Nope! All tokens are defined and provided through OUDS library","type":"text"}]}],"isCorrect":false}]},{"type":"multiple-choice","title":[{"inlineContent":[{"type":"text","text":"How can I get the theme to apply?"}],"type":"paragraph"}],"content":[],"choices":[{"content":[{"type":"paragraph","inlineContent":[{"text":"I must instanciate it every time I need","type":"text"}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"The theme is provided through an environment object, instanciated thanks to a preview view modifier or specific view.","type":"text"}]}],"isCorrect":false},{"content":[{"type":"paragraph","inlineContent":[{"text":"Using an environment value","type":"text"}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"Theme is exposed as environment object, available within views for example.","type":"text"}]}],"isCorrect":true}]}],"anchor":"Check-Your-Understanding"},{"abstract":[{"type":"text","text":"Now you are ready to use more components than a simple button!"}],"featuredEyebrow":"Tutorial","kind":"callToAction","action":{"type":"reference","overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tu