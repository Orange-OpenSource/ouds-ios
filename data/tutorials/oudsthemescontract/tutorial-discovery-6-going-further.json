{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[{"kind":"hero","estimatedTimeInMinutes":10,"content":[{"inlineContent":[{"text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources.","type":"text"}],"type":"paragraph"}],"image":"ic_theme_intro.png","backgroundImage":"ic_theme_intro.png","chapter":"Go further with more ressources","title":"Going further with more resources"},{"tasks":[{"contentSection":[{"content":[{"inlineContent":[{"text":"Xcode can use the Swift DocC documentation of OUDS, and this documentation is used to build a static web site.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"But there are also other resources which can be useful for you.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"title":"More resources","stepsSection":[{"runtimePreview":null,"type":"step","code":null,"media":"tutorial-discovery-6-1.png","content":[{"inlineContent":[{"type":"text","text":"The iOS technical documentation is available online. It has been generated from all the Swift DocC documentation written in the Swift Package."},{"type":"text","text":" "},{"type":"text","text":"You will find several catalogs (as many as librairies) with details about everyhting: components, tokens, themes, providers, etc."}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"You can get it at "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/"}],"type":"paragraph"}]},{"runtimePreview":null,"type":"step","code":null,"media":"tutorial-discovery-6-2.png","content":[{"inlineContent":[{"type":"text","text":"The whole design system is documented and available online. You can find everything about components, tokens, guidelines and principles of OUDS."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"text