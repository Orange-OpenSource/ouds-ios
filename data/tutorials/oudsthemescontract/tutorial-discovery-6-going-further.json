type":"text","text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository."}]}],"type":"step"},{"media":"tutorial-discovery-6-5.png","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not hesitate to "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions"},{"type":"text","text":"!"}]}],"code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios"},{"type":"text","text":" GitHub repository."}]}],"type":"step"}]}]}],"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further","interfaceLanguage":"swift"},"kind":"project","schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Richer-and-more-original-components-of-OUDS":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Richer-and-more-original-components-of-OUDS","role":"article","url":"\/tutorials\/table-of-contents-(discovery)\/richer-and-more-original-components-of-ouds","title":"Richer and more original components of OUDS","abstract":[],"kind":"article","type":"topic"},"https://github.com/Orange-OpenSource/ouds-ios/issues":{"titleInlineContent":[{"type":"text","text":"create issues if you spot bugs or want improvements"}],"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","url":"https:\/\/github