creases a lot the size of the repository.","type":"text"}]}],"media":"tutorial-discovery-6-4.png","code":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"To get the source code of this showcase app, go to its dedicated GitHub repository at ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox","isActive":true}]}],"runtimePreview":null},{"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","isActive":true},{"text":" GitHub repository.","type":"text"}]}],"type":"step","runtimePreview":null,"code":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"Do not hesitate to ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","type":"reference"},{"text":" or ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","isActive":true},{"text":"!","type":"text"}]}],"media":"tutorial-discovery-6-5.png"}],"anchor":"More-resources","title":"More resources"}],"kind":"tasks"}],"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things#Check-Your-Understanding":{"title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things#Check-Your-Understanding","titleInlineContent":[{"text":"Check Your Understanding","type":"text"}],"type":"link"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)/Use-of-first-components-provided-by-OUDS":{"role":"article","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)\/Use-of-first-compon