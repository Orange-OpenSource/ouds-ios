text":" app. In fact this app and all its snapshots for tests increases a lot the size of the repository.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the source code of this showcase app, go to its dedicated GitHub repository at "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios-design-system-toolbox"}]}],"media":"tutorial-discovery-6-4.png","runtimePreview":null,"type":"step"},{"code":null,"content":[{"inlineContent":[{"type":"text","text":"OUDS is open source, public and uses GitHub as forge. Thus, you will find common things inside the "},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios","type":"reference"},{"type":"text","text":" GitHub repository."}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"Do not hesitate to "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","isActive":true},{"type":"text","text":"!"}],"type":"paragraph"}],"media":"tutorial-discovery-6-5.png","runtimePreview":null,"type":"step"}]}]}],"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further","type":"topic","kind":"project","title":"Going further with more resources","estimatedTime":"10min","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further","role":"project","abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}]},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)":{"url":"\/tutorials\/table-of-contents-(discovery)",