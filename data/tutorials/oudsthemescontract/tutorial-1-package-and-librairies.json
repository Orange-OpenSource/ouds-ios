{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"project","metadata":{"title":"Swift Package integration","categoryPathComponent":"Table-Of-Contents","category":"Orange Unified Design System","role":"project"},"sections":[{"estimatedTimeInMinutes":10,"title":"Swift Package integration","chapter":"Import of the Swift Package and choose its librairies","xcodeRequirement":"Xcode 26","image":"ic_unified_ds.png","backgroundImage":"ic_unified_ds.png","kind":"hero","content":[{"inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework."}],"type":"paragraph"}]},{"kind":"tasks","tasks":[{"contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The package and the librairies must be added through Xcode."}]}],"kind":"contentAndMedia"}],"title":"Import the Swift Package and the libraries","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"project package dependencies"}]},{"text":", add a new ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"dependency"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ouds-ios"}]},{"type":"text","text":" dependency."},{"type":"text","text":" "},{"type":"text","text":"You can then choose the "},{"type":"strong","inlineContent":[{"type":"text","text":"dependency rule"}]},{"type":"text","text":" you want."},{"type":"text","text":" "},{"type":"text","text":"To know which version you need, you can have a look on the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and also the "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true},{"type":"text","text":"."}]}],"caption":[],"code":null,"runtimePreview":null,"media":"tutorial-1-ouds-swift-package.png","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"type":"strong","inlineContent":[{"text":"target","type":"text"}]},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesContract","type":"text"}]},{"type":"text","text":" library provides the main elements like the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":". The theme contract is defined inside it."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesOrange","type":"text"}]},{"type":"text","text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesSosh"}]},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}]},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesOrangeBusinessTools"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSComponents","type":"text"}],"type":"emphasis"},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSTokensRaw"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"text":"OUDSTokensSemantic","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensComponents"}]},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"middle level (semantic) or component levels (high level)."},{"type":"text","text":" "},{"inlineContent":[{"text":"OUDSModules","type":"text"}],"type":"emphasis"},{"text":" is for modules or rich components with extra logic.","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSFoundations"}]},{"text":" is dedicated to some utilities and shared logic.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]}]}],"code":null,"runtimePreview":null,"type":"step","media":"tutorial-1-ouds-libraries.png"}],"anchor":"Import-the-Swift-Package-and-the-libraries"}]},{"kind":"assessments","assessments":[{"type":"multiple-choice","title":[{"inlineContent":[{"text":"Which of these choices is correct?","type":"text"}],"type":"paragraph"}],"choices":[{"content":[{"inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}],"type":"paragraph"}],"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!","type":"text"}]}],"isCorrect":true},{"justification":[{"type":"paragraph","inlineContent":[{"text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS.","type":"text"},{"text":" ","type":"text"},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}]}],"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay.","type":"text"}]}]},{"isCorrect":false,"content":[{"inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"OUDS supports officialy only SwiftUI. UIKit is very experimental and not recommended.","type":"text"}],"type":"paragraph"}]}],"content":[]},{"content":[],"choices":[{"content":[{"inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"text":"Even if we recommend to choose only the atomic products you need, the ","type":"text"},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" product wraps all of them."}],"type":"paragraph"}],"isCorrect":true},{"content":[{"inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides"}],"type":"paragraph"}],"isCorrect":false}],"title":[{"inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}],"type":"paragraph"}],"type":"multiple-choice"}],"anchor":"Check-Your-Understanding"},{"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"kind":"callToAction","title":"Instanciate and inject a theme","featuredEyebrow":"Tutorial","action":{"isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"overridingTitle":"Get started","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme"}}],"variants":[{"paths":["\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies"]],"modules":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies","projects":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies","sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThem