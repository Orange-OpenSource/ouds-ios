torials\/Table-Of-Contents"},"sections":[{"kind":"hero","title":"Swift Package integration","content":[{"inlineContent":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"type":"text","text":" "},{"text":"SwiftUI is the only official supported framework.","type":"text"}],"type":"paragraph"}],"estimatedTimeInMinutes":10,"xcodeRequirement":"Xcode 26","chapter":"Import of the Swift Package and choose its librairies","backgroundImage":"ic_unified_ds.png","image":"ic_unified_ds.png"},{"tasks":[{"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The package and the librairies must be added through Xcode."}]}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"anchor":"Import-the-Swift-Package-and-the-libraries","stepsSection":[{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Using Xcode, in your "},{"inlineContent":[{"type":"text","text":"project package dependencies"}],"type":"strong"},{"text":", add a new ","type":"text"},{"type":"strong","inlineContent":[{"text":"dependency","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"ouds-ios"}]},{"text":" dependency.","type":"text"},{"text":" ","type":"text"},{"text":"You can then choose the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"dependency rule"}]},{"text":" you want.","type":"text"},{"text":" ","type":"text"},{"text":"To know which version you need, you can have a look on the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"and also the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","type":"reference","isActive":true},{"text":".","type":"text"}]}],"media":"tutorial-1-ouds-swift-package.png","runtimePreview":null,"caption":[],"code":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you downloaded the package, you will see several librairies are available."},{"type":"text","text":" "},{"type":"text","text":"They can be embeded inside your "},{"type":"strong","inlineContent":[{"type":"text","text":"target"}]},{"type":"text","text":" librairies."},{"type":"text","text":" "},{"type":"text","text":"Things are separated to let users integrate only what they need and embed the abre minimum of content."},{"type":"text","text":" "},{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesContract"}],"type":"emphasis"},{"text":" library provides the main elements like the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":". The theme contract is defined inside it.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesOrange"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesSosh"}],"type":"emphasis"},{"text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}],"type":"emphasis"},{"text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSThemesOrangeBusinessTools"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"OUDSComponents","type":"text"}]},{"text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensRaw"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensSemantic"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSTokensComponents"}],"type":"emphasis"},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"text":" ","type":"text"},{"text":"middle level (semantic) or component levels (high level).","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSModules"}],"type":"emphasis"},{"text":" is for modules or rich components with extra logic.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSFoundations"}],"type":"emphasis"},{"text":" is dedicated to some utilities and shared logic.","type":"text"}]}],"code":null,"runtimePreview":null,"type":"step","media":"tutorial-1-ouds-libraries.png","caption":[{"inlineContent":[{"text":"Add for example only the umbrella product merging all products mentioned above: ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSSwiftUI"}],"type":"emphasis"}],"type":"paragraph"}]}],"title":"Import the Swift Package and the libraries"}],"kind":"tasks"},{"kind":"assessments","assessments":[{"choices":[{"content":[{"inlineContent":[{"text":"I can contribute to OUDS using pull request","type":"text"}],"type":"paragraph"}],"justification":[{"inlineContent":[{"text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!","type":"text"}],"type":"paragraph"}],"isCorrect":true},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS.","type":"text"},{"text":" ","type":"text"},{"text":"CarPlay specific cases are not scoped yet.","type":"text"}]}],"isCorrect":false},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}]}],"justification":[{"type":"paragraph","inlineContent":[{"text":"OUDS supports officialy only SwiftUI. UIKit is very experimental and not recommended.","type":"text"}]}],"isCorrect":false}],"title":[{"inlineContent":[{"text":"Which of these choices is correct?","type":"text"}],"type":"paragraph"}],"type":"multiple-choice","content":[]},{"choices":[{"isCorrect":true,"justification":[{"type":"paragraph","inlineContent":[{"text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed.","type":"text"},{"text":" ","type":"text"},{"text":"Even if we recommend to choose only the atomic products you need, the ","type":"text"},{"code":"OUDSSwiftUI","type":"codeVoice"},{"text":" product wraps all of them.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}]},{"isCorrect":false,"justification":[{"type":"paragraph","inlineContent":[{"text":"You need to chose the products the Swift package provides","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"None, only the Swift package dependency matter","type":"text"}]}]}],"content":[],"type":"multiple-choice","title":[{"type":"paragraph","inlineContent":[{"text":"Which imports of the OUDS Swift Package products can I choose?","type":"text"}]}]}],"anchor":"Check-Your-Understanding"},{"kind":"callToAction","title":"Instanciate and inject a theme","featuredEyebrow":"Tutorial","action":{"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme","overridingTitle":"Get started"},"abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}]}],"metadata":{"role":"project","category":"Orange Unified Design System","title":"Swift Package integration","categoryPathComponent":"Table-Of-Contents"},"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Add-basic-components":{"kind":"section","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Add-basic-components","role":"pseudoSymbol","abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"type":"section","title":"Add basic components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Add-basic-components"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents/Use-of-first-components-provided-by-OUDS":{"role":"article","type":"topic","abstract":[],"title":"Use of first components provided by OUDS","url":"\/tutorials\/table-of-contents\/use-of-first-components-provided-by-ouds","kind":"article","identifier":"