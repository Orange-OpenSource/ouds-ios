tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Typography,-view-modifiers-and-tokens","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-tokens","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Use-of-view-modifiers","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","kind":"task"},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Check-Your-Understanding","kind":"assessment"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things"}]},{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Go-further-with-more-ressources","projects":[{"sections":[{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further#More-resources","kind":"task"}],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further"}]}],"paths":[["doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/$volume","doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents\/Import-of-the-Swift-Package-and-choose-its-librairies"]],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents"},"metadata":{"role":"project","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents","title":"Swift Package integration"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies"},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies"]}],"sections":[{"content":[{"type":"paragraph","inlineContent":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework.","type":"text"}]}],"backgroundImage":"ic_unified_ds.png","title":"Swift Package integration","chapter":"Import of the Swift Package and choose its librairies","estimatedTimeInMinutes":10,"image":"ic_unified_ds.png","xcodeRequirement":"Xcode 26","kind":"hero"},{"kind":"tasks","tasks":[{"stepsSection":[{"media":"tutorial-1-ouds-swift-package.png","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Using Xcode, in your ","type":"text"},{"inlineContent":[{"type":"text","text":"project package dependencies"}],"type":"strong"},{"text":", add a new ","type":"text"},{"inlineContent":[{"type":"text","text":"dependency"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Search with the GitHub repository URL (https:\/\/github.com\/Orange-OpenSource\/ouds-ios), and select the ","type":"text"},{"inlineContent":[{"type":"text","text":"ouds-ios"}],"type":"emphasis"},{"text":" dependency.","type":"text"},{"text":" ","type":"text"},{"text":"You can then choose the ","type":"text"},{"inlineContent":[{"type":"text","text":"dependency rule"}],"type":"strong"},{"text":" you want.","type":"text"},{"text":" ","type":"text"},{"text":"To know which version you need, you can have a look on the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/01-%E2%80%90-Available-API","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"and also the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","isActive":true,"type":"reference"},{"text":".","type":"text"}]}],"type":"step","caption":[],"code":null},{"media":"tutorial-1-ouds-libraries.png","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Once you downloaded the package, you will see several librairies are available.","type":"text"},{"text":" ","type":"text"},{"text":"They can be embeded inside your ","type":"text"},{"inlineContent":[{"type":"text","text":"target"}],"type":"strong"},{"text":" librairies.","type":"text"},{"text":" ","type":"text"},{"text":"Things are separated to let users integrate only what they need and embed the abre minimum of content.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"inlineContent":[{"text":"OUDSThemesContract","type":"text"}],"type":"emphasis"},{"text":" library provides the main elements like the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":". The theme contract is defined inside it.","type":"text"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesOrange"}],"type":"emphasis"},{"text":" provides the theme implementation for the Orange products, and contains also assets and all tokens for this theme.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"OUDSThemesSosh","type":"text"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Sosh products, and contains also assets and all tokens for this theme."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesWireframe"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Wireframe theme, which is a theme dedicated to mockups and prototypes."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSThemesOrangeBusinessTools"}],"type":"emphasis"},{"type":"text","text":" provides the theme implementation for the Orange products but with constraints of sizes and spaces."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSComponents"}],"type":"emphasis"},{"type":"text","text":" contains the SwiftUI OUDS components defined with the Figma specifications, and also useful view modifers."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSTokensRaw"}],"type":"emphasis"},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"OUDSTokensSemantic","type":"text"}]},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"OUDSTokensComponents"}],"type":"emphasis"},{"text":" are librairies defining and providing the tokens for low level (raw),","type":"text"},{"text":" ","type":"text"},{"text":"middle level (semantic) or component levels (high level).","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"OUDSModules"}],"type":"emphasis"},{"type":"text","text":" is for modules or rich components with extra logic."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"OUDSFoundations"}],"type":"emphasis"},{"type":"text","text":" is dedicated to some utilities and shared logic."}]}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add for example only the umbrella product merging all products mentioned above: "},{"type":"emphasis","inlineContent":[{"text":"OUDSSwiftUI","type":"text"}]}]}],"code":null}],"title":"Import the Swift Package and the libraries","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS for iOS is an open source Swift Package available on GitHub under MIT license.","type":"text"},{"text":" ","type":"text"},{"text":"The package and the librairies must be added through Xcode.","type":"text"}]}],"mediaPosition":"trailing"}],"anchor":"Import-the-Swift-Package-and-the-libraries"}]},{"kind":"assessments","anchor":"Check-Your-Understanding","assessments":[{"type":"multiple-choice","choices":[{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"I can contribute to OUDS using pull request"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is open source, under MIT license, and hosted on GitHub. Of course you can contribute!"}]}]},{"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports officialy all Apple OS like visionOS, tvOS, watchOS, iPadOS, iOS and also CarPlay."}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The main supported targets are iOS \/ iPadOS. However we do our best to support macOS, visionOS, tvOS and watchOS."},{"type":"text","text":" "},{"type":"text","text":"CarPlay specific cases are not scoped yet."}]}]},{"isCorrect":false,"content":[{"inlineContent":[{"type":"text","text":"OUDS provides UIKit components"}],"type":"paragraph"}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS supports officialy only SwiftUI. UIKit is very experimental and not recommended."}]}]}],"title":[{"inlineContent":[{"type":"text","text":"Which of these choices is correct?"}],"type":"paragraph"}],"content":[]},{"type":"multiple-choice","choices":[{"isCorrect":true,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Some of the available products depending to my needs, or only "},{"type":"codeVoice","code":"OUDSSwiftUI"},{"type":"text","text":" if I am very lazy and don’t care about my app size."}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can import all products provided by the Swift Package, and tailor your choice to keep only the ones needed."},{"type":"text","text":" "},{"type":"text","text":"Even if we recommend to choose only the atomic products you need, the "},{"code":"OUDSSwiftUI","type":"codeVoice"},{"type":"text","text":" product wraps all of them."}]}]},{"isCorrect":false,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"None, only the Swift package dependency matter"}]}],"justification":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You need to chose the products the Swift package provides"}]}]}],"title":[{"inlineContent":[{"type":"text","text":"Which imports of the OUDS Swift Package products can I choose?"}],"type":"paragraph"}],"content":[]}]},{"abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"text":" ","type":"text"},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"action":{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme","overridingTitle":"Get started","type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Get started"}]},"featuredEyebrow":"Tutorial","kind":"callToAction","title":"Instanciate and inject a theme"}],"kind":"project","references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components#Check-Your-Understanding":{"type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components#Check-Your-Understanding","title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"type":"topic","title":"Add more OUDS components","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components","role":"project","estimatedTime":"30min","kind":"project"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme#Basic-structure-for-the-app":{"kind":"section","title":"Basic structure for the app","type":"section","role":"pseudoSymbol","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app","url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme#Basic-structure-for-the-app"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things#Final-result":{"role":"pseudoSymbol","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things#Final-result","type":"section","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"title":"Final result","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things#Final-result","kind":"section"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components#Check-Your-Understanding":{"type":"link","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components#Check-Your-Understanding","title":"Check Your Understanding","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components#Check-Your-Understanding","titleInlineContent":[{"type":"text","text":"Check Your Understanding"}]},"https://github.com/Orange-OpenSource/ouds-ios/releases":{"type":"link","url":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/releases","title":"GitHub releases","identifier":"https