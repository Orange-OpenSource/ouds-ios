{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents"},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/tutorials\/table-of-contents"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","paths":[]},"metadata":{"categoryPathComponent":"Table-Of-Contents","role":"overview","category":"Orange Unified Design System","estimatedTime":"2hr 5min","title":"Swift Package iOS Tutorial"},"sections":[{"backgroundImage":"ic_unified_ds.png","kind":"hero","title":"Swift Package iOS Tutorial","image":"ic_unified_ds.png","content":[{"inlineContent":[{"type":"text","text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package."},{"type":"text","text":" "},{"type":"text","text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework."},{"type":"text","text":" "},{"type":"text","text":"Theme, components, tokens… everything will be introduced!"}],"type":"paragraph"}],"action":{"overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies"}},{"chapters":[{"image":"ic_unified_ds.png","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-1-package-and-librairies"],"name":"Import of the Swift Package and choose its librairies","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this chapter you will learn how to import the OUDS iOS Swift Package and which librairies it provides"},{"type":"text","text":" "},{"type":"text","text":"you should choose for your needs"}]}]},{"image":"ic_theme_intro.png","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme"],"name":"Preparation of the theme","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this chapter you will see how to instanciate a theme and inject it inside your app"}]}]},{"image":"ic_component_intro.png","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-3-use-first-components"],"name":"Use of first components provided by OUDS","content":[{"inlineContent":[{"type":"text","text":"In this chapter you will see how you can use your first components provided by OUDS Swift Package"}],"type":"paragraph"}]},{"image":"ic_component_intro.png","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components"],"name":"Richer and more original components of OUDS","content":[{"inlineContent":[{"text":"In this chapter you will use original components of OUDS and richer ones","type":"text"}],"type":"paragraph"}]},{"image":"ic_design_token_intro.png","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things"],"name":"Typography, view modifiers and tokens","content":[{"type":"paragraph","inlineContent":[{"text":"OUDS is not only about components and themes. It provides view modifiers, typographies and tokens which can be used. You will learn how.","type":"text"}]}]},{"image":"ic_unified_ds.png","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further"],"name":"Go further with more ressources","content":[{"type":"paragraph","inlineContent":[{"text":"You can have questions and issues, and there are resources online. Let’s see that together.","type":"text"}]}]}],"name":null,"kind":"volume","image":null,"content":[]}],"kind":"overview","references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-3-use-first-components":{"title":"Use your first OUDS components","type":"topic","kind":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-3-use-first-components","identifier":"doc:\/\