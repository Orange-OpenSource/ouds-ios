ontract\/tutorial-3-use-first-components"],"image":"ic_component_intro.png","name":"Use of first components provided by OUDS"},{"name":"Richer and more original components of OUDS","image":"ic_component_intro.png","content":[{"inlineContent":[{"type":"text","text":"In this chapter you will use original components of OUDS and richer ones"}],"type":"paragraph"}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components"]},{"name":"Typography, view modifiers and tokens","image":"ic_design_token_intro.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is not only about components and themes. It provides view modifiers, typographies and tokens which can be used. You will learn how."}]}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things"]},{"name":"Go further with more ressources","image":"ic_unified_ds.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can have questions and issues, and there are resources online. Let’s see that together."}]}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-6-going-further"]}],"kind":"volume"}],"metadata":{"role":"overview","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents","title":"Swift Package iOS Tutorial","estimatedTime":"2hr 5min"},"kind":"overview","hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","paths":[]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/table-of-contents"]}],"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents","interfaceLanguage":"swift"},"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"type":"topic","title":"Add more OUDS components","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related