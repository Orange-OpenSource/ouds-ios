ckage-and-librairies","abstract":[{"text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs.","type":"text"},{"text":" ","type":"text"},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI is the only official supported framework.","type":"text"}],"role":"project","title":"Swift Package integration","estimatedTime":"10min","kind":"project","url":"\/tutorials\/oudsthemescontract\/tutorial-1-package-and-librairies"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-4-use-other-components":{"role":"project","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"type":"topic","title":"Add more OUDS components","estimatedTime":"30min","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-4-use-other-components","url":"\/tutorials\/oudsthemescontract\/tutorial-4-use-other-components"},"ic_theme_intro.png":{"alt":"OUDS themes logo","variants":[{"url":"\/images\/OUDSThemesContract\/ic_theme_intro.png","traits":["1x","light"]}],"type":"image","identifier":"ic_theme_intro.png"},"ic_design_token_intro.png":{"alt":"OUDS tokens logo","type":"image","identifier":"ic_design_token_intro.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_design_token_intro.png"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme":{"type":"topic","title":"Instanciate and inject a theme","role":"project","kind":"project","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme","estimatedTime":"15min","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-5-styling-things":{"title":"Styling things","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-5-styling-things","estimatedTime":"30min","role":"project","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-5-styling-things"},"ic_component_intro.png":{"alt":"Logo of OUDS","variants":[{"url":"\/images\/OUDSThemesContract\/ic_component_intro.png","traits":["1x","light"]}],"type":"image","identifier":"ic_component_intro.png"}}}