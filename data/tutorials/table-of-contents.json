\/ic_design_token_intro.png","traits":["1x","light"]}],"type":"image"},"ic_component_intro.png":{"identifier":"ic_component_intro.png","alt":"Logo of OUDS","variants":[{"url":"\/images\/OUDSThemesContract\/ic_component_intro.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-2-instanciate-theme":{"title":"Instanciate and inject a theme","role":"project","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"url":"\/tutorials\/oudsthemescontract\/tutorial-2-instanciate-theme","estimatedTime":"15min","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-2-instanciate-theme","kind":"project"}}}