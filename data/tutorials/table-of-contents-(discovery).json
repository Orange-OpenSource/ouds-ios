{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)"},"metadata":{"estimatedTime":"2hr 5min","categoryPathComponent":"Table-Of-Contents-(discovery)","title":"Swift Package Discovery Tutorial","category":"Orange Unified Design System","role":"overview"},"variants":[{"paths":["\/tutorials\/table-of-contents-(discovery)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[{"title":"Swift Package Discovery Tutorial","action":{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference"},"content":[{"inlineContent":[{"type":"text","text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package."},{"type":"text","text":" "},{"type":"text","text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework."},{"type":"text","text":" "},{"type":"text","text":"Theme, components, tokens… everything will be introduced!"}],"type":"paragraph"}],"image":"ic_unified_ds.png","kind":"hero","backgroundImage":"ic_unified_ds.png"},{"content":[],"chapters":[{"name":"Import of the Swift Package and choose its librairies","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"],"image":"ic_unified_ds.png","content":[{"inlineContent":[{"type":"text","text":"In this chapter you will learn how to import the OUDS iOS Swift Package and which librairies it provides"},{"type":"text","text":" "},{"type":"text","text":"you should choose for your needs."}],"type":"paragraph"}]},{"name":"Preparation of the theme","image":"ic_theme_intro.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this chapter you will see how to instanciate a theme and inject it inside your app"}]}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme"]},{"name":"Use of first components provided by OUDS","image":"ic_component_intro.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this chapter you will see how you can use your first components provided by OUDS Swift Package"}]}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"]},{"name":"Richer and more original components of OUDS","image":"ic_component_intro.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this chapter you will use original components of OUDS and richer ones"}]}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"]},{"name":"Typography, view modifiers and tokens","image":"ic_design_token_intro.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is not only about components and themes. It provides view modifiers, typographies and tokens which can be used. You will learn how."}]}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"]},{"name":"Go further with more ressources","image":"ic_unified_ds.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can have questions and issues, and there are resources online. Let’s see that together."}]}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"]}],"image":null,"name":null,"kind":"volume"}],"hierarchy":{"paths":[],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)"},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"overview","references":{"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Tabl