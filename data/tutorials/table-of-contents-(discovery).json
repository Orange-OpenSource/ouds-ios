-discovery-4-use-other-components":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components","title":"Add more OUDS components","abstract":[{"text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs.","type":"text"}],"type":"topic","role":"project","kind":"project","estimatedTime":"30min"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things","title":"Styling things","abstract":[{"text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that.","type":"text"}],"type":"topic","role":"project","kind":"project","estimatedTime":"30min"},"ic_design_token_intro.png":{"variants":[{"url":"\/images\/OUDSThemesContract\/ic_design_token_intro.png","traits":["1x","light"]}],"identifier":"ic_design_token_intro.png","alt":"OUDS tokens logo","type":"image"}}}