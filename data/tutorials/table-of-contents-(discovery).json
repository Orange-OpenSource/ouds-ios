{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/table-of-contents-(discovery)"]}],"kind":"overview","schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)"},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","interfaceLanguage":"swift"},"metadata":{"title":"Swift Package Discovery Tutorial","estimatedTime":"2hr 5min","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)","role":"overview"},"sections":[{"kind":"hero","action":{"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","type":"reference","isActive":true,"overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}]},"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package."},{"text":" ","type":"text"},{"text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework.","type":"text"},{"text":" ","type":"text"},{"text":"Theme, components, tokens… everything will be introduced!","type":"text"}]}],"backgroundImage":"ic_unified_ds.png","title":"Swift Package Discovery Tutorial","image":"ic_unified_ds.png"},{"chapters":[{"image":"ic_unified_ds.png","content":[{"inlineContent":[{"type":"text","text":"In this chapter you will learn how to import the OUDS iOS Swift Package and which librairies it provides"},{"type":"text","text":" "},{"type":"text","text":"you should choose for your needs."}],"type":"paragraph"}],"name":"Import of the Swift Package and choose its librairies","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"]},{"image":"ic_theme_intro.png","content":[{"inlineContent":[{"text":"In this chapter you will see how to instanciate a theme and inject it inside your app","type":"text"}],"type":"paragraph"}],"name":"Preparation of the theme","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme"]},{"content":[{"inlineContent":[{"text":"In this chapter you will see how you can use your first components provided by OUDS Swift Package","type":"text"}],"type":"paragraph"}],"name":"Use of first components provided by OUDS","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"],"image":"ic_component_intro.png"},{"content":[{"type":"paragraph","inlineContent":[{"text":"In this chapter you will use original components of OUDS and richer ones","type":"text"}]}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"],"name":"Richer and more original components of OUDS","image":"ic_component_intro.png"},{"content":[{"inlineContent":[{"text":"OUDS is not only about components and themes. It provides view modifiers, typographies and tokens which can be used. You will learn how.","type":"text"}],"type":"paragraph"}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"],"name":"Typography, view modifiers and tokens","image":"ic_design_token_intro.png"},{"content":[{"inlineContent":[{"text":"You can have questions and issues, and there are resources online. Let’s see that together.","type":"text"}],"type":"paragraph"}],"name":"Go further with more ressources","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"],"image":"ic_unified_ds.png"}],"name":null,"content":[],"kind":"volume","image":null}],"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","title":"Swift Package integration","type":"topic","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"text":"These librairies help to split products and make users able to select only what they need.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"estimatedTime":"10min","role":"project"},"ic_design_token_intro.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_design_token_intro.png"}],"identifier":"ic_design_token_intro.png","alt":"OUDS tokens logo","type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components":{"title":"Use your first OUDS components","kind":"project","role":"project","estimatedTime":"30min","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components","type":"topic"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme":{"title":"Instanciate and inject a theme","kind":"project","role":"project","estimatedTime":"15min","abstract":[{"type":"text","text":"The theme is exposed as one object which will be injected inside your SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The theme provides all tokens which defines in the end the rendering of everything."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme","type":"topic"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-5-styling-things":{"title":"Styling things","kind":"project","role":"project","estimatedTime":"30min","abstract":[{"type":"text","text":"Even if components increase the identity of your apps, it is not enough. Typography, fonts and tokens are here to improve that."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-5-styling-things","type":"topic"},"ic_component_intro.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_component_intro.png"}],"identifier":"ic_component_intro.png","alt":"Logo of OUDS","type":"image"},"ic_unified_ds.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_unified_ds.png"}],"identifier":"ic_unified_ds.png","alt":"Logo of OUDS","type":"image"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"title":"Going further with more resources","kind":"project","role":"project","estimatedTime":"10min","abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further","type":"topic"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)":{"title":"Swift Package Discovery Tutorial","kind":"overview","role":"overview","abstract":[{"type":"text","text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package."},{"type":"text","text":" "},{"type":"text","text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework."},{"type":"text","text":" "},{"type":"text","text":"Theme, components, tokens… everything will be introduced!"}],"identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","url":"\/tutorials\/table-of-contents-(discovery)","type":"topic"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-4-use-other-components":{"abstract":[{"type":"text","text":"Components can be similar to iOS native components, or can also be original and strongly related to Orange Unified Design System needs."}],"title":"Add more OUDS components","estimatedTime":"30min","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-4-use-other-components","role":"project","type":"topic"},"ic_theme_intro.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_theme_intro.png"}],"identifier":"ic_theme_intro.png","alt":"OUDS themes logo","type":"image"}}}