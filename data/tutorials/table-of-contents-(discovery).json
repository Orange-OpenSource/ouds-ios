{"variants":[{"paths":["\/tutorials\/table-of-contents-(discovery)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"overview","hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","paths":[]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)"},"metadata":{"title":"Swift Package Discovery Tutorial","estimatedTime":"2hr 5min","role":"overview","category":"Orange Unified Design System","categoryPathComponent":"Table-Of-Contents-(discovery)"},"sections":[{"content":[{"inlineContent":[{"type":"text","text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package."},{"type":"text","text":" "},{"type":"text","text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework."},{"type":"text","text":" "},{"type":"text","text":"Theme, components, tokens… everything will be introduced!"}],"type":"paragraph"}],"title":"Swift Package Discovery Tutorial","kind":"hero","backgroundImage":"ic_unified_ds.png","image":"ic_unified_ds.png","action":{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"overridingTitle":"Get started"}},{"kind":"volume","name":null,"image":null,"content":[],"chapters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this chapter you will learn how to import the OUDS iOS Swift Package and which librairies it provides"},{"type":"text","text":" "},{"type":"text","text":"you should choose for your needs."}]}],"image":"ic_unified_ds.png","name":"Import of the Swift Package and choose its librairies","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this chapter you will see how to instanciate a theme and inject it inside your app"}]}],"image":"ic_theme_intro.png","name":"Preparation of the theme","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this chapter you will see how you can use your first components provided by OUDS Swift Package"}]}],"image":"ic_component_intro.png","name":"Use of first components provided by OUDS","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this chapter you will use original components of OUDS and richer ones"}]}],"image":"ic_component_intro.png","name":"Richer and more original components of OUDS","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-4-use-other-components"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS is not only about components and themes. It provides view modifiers, typographies and tokens which can be used. You will learn how."}]}],"image":"ic_design_token_intro.png","name":"Typography, view modifiers and tokens","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-5-styling-things"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can have questions and issues, and there are resources online. Let’s see that together."}]}],"image":"ic_unified_ds.png","name":"Go further with more ressources","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-6-going-further"]}]}],"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-1-package-and-librairies":{"role":"project","type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-1-package-and-librairies","title":"Swift Package integration","abstract":[{"type":"text","text":"OUDS iOS is exposed through an open source Swift Package hosted on GitHub, and provides several librairies for your needs."},{"type":"text","text":" "},{"type":"text","text":"These librairies help to split products and make users able to select only what they need."},{"type":"text","text":" "},{"type":"text","text":"SwiftUI is the only official supported framework for Apple platforms."}],"kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-1-package-and-librairies","estimatedTime":"10min"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-3-use-first-components":{"role":"project","estimatedTime":"30min","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-3-use-first-components","type":"topic","title":"Use your first OUDS components","url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-3-use-first-components","kind":"project","abstract":[{"type":"text","text":"OUDS provides components ready to be used, specified in Figma assets and preventing users to handle tokens."},{"type":"text","text":" "},{"type":"text","text":"They are rendered thanks to the theme in use."}]},"ic_design_token_intro.png":{"type":"image","identifier":"ic_design_token_intro.png","alt":"OUDS tokens logo","variants":[{"url":"\/images\/OUDSThemesContract\/ic_design_token_intro.png","traits":["1x","light"]}]},"ic_component_intro.png":{"type":"image","identifier":"ic_component_intro.png","alt":"Logo of OUDS","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_component_intro.png"}]},"ic_unified_ds.png":{"type":"image","identifier":"ic_unified_ds.png","alt":"Logo of OUDS","variants":[{"url":"\/images\/OUDSThemesContract\/ic_unified_ds.png","traits":["1x","light"]}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-2-instanciate-theme":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-2-instanciate-theme","title":"Instanciate and inject a theme","abstract":[{"text":"The theme is exposed as one object which will be injected inside your SwiftUI view.","type":"text"},{"type":"text","text":" "},{"text":"The theme provides all tokens which defines in the end the rendering of everything.","type":"text"}],"kind":"project","type":"topic","role":"project","estimatedTime":"15min","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-discovery-2-instanciate-theme"},"ic_theme_intro.png":{"identifier":"ic_theme_intro.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_theme_intro.png"}],"alt":"OUDS themes logo"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(discovery)":{"role":"overview","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(discovery)","type":"topic","title":"Swift Package Discovery Tutorial","url":"\/tutorials\/table-of-contents-(discovery)","kind":"overview","abstract":[{"type":"text","text":"Discovering a new framework can be exciting and scary. Learn how you can embed and use OUDS Swift Package."},{"type":"text","text":" "},{"type":"text","text":"With this tutorial you will learn fundamental concepts of Orange Unified Design System and discover the layers of this framework."},{"type":"text","text":" "},{"type":"text","text":"Theme, components, tokens… everything will be introduced!"}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-discovery-6-going-further":{"url":"\/tutorials\/oudsthemescontract\/tutorial-discovery-6-going-further","abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}],"role":"project","type":"topic","kind":"project","estimatedTime":"10min","id