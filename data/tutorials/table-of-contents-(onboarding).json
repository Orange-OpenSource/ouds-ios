Contract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view"],"content":[{"type":"paragraph","inlineContent":[{"text":"Since you prepared you Xcode project and integrated OUDS Swift Package, you can now define a nice and clear view with headings, images and button.","type":"text"}]}],"image":"ic_unified_ds.png","name":"Define information cards"},{"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase"],"content":[{"type":"paragraph","inlineContent":[{"text":"Since you discovered tokens, colors, spacings, and view modifiers, now it’s time to integrate and play with some components!","type":"text"}]}],"image":"ic_unified_ds.png","name":"Components showcases"},{"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further"],"content":[{"type":"paragraph","inlineContent":[{"text":"You can have questions and issues, and there are resources online. Let’s see that together.","type":"text"}]}],"image":"ic_unified_ds.png","name":"Go further with more ressources"}],"kind":"volume","image":null,"content":[],"name":null}],"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-2-nice-and-clear-view":{"title":"Define information cards","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view","kind":"project","role":"project","estimatedTime":"45min","type":"topic","abstract":[{"type":"text","text":"Let’s suppose we want to define a view for corporate apps with headings, texts, buttons and images."},{"type":"text","text":" "},{"type":"text","text":"How can we do that?"}],"url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-2-nice-and-clear-view"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-1-package-and-librairies":{"title":"Swift Package integration","estimatedTime":"10min","kind":"project","identifier":"doc:\/\/OUDSThemesCo