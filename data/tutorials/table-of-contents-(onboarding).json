{"hierarchy":{"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","paths":[]},"sections":[{"backgroundImage":"ic_unified_ds.png","kind":"hero","action":{"isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies","overridingTitle":"Get started"},"content":[{"inlineContent":[{"type":"text","text":"Discovering a new framework can be exciting and scary."},{"type":"text","text":" "},{"type":"text","text":"With this tutorial, you will learn how to embed OUDS Swift Package and define views tailored for your brand."},{"type":"text","text":" "},{"type":"text","text":"It has beend esigned for local events and meetups."},{"type":"text","text":" "},{"type":"text","text":"Let’s play!"}],"type":"paragraph"}],"title":"Swift Package Onboarding Tutorial","image":"ic_unified_ds.png"},{"name":null,"kind":"volume","content":[],"chapters":[{"name":"Import of the Swift Package and choose its librairies","content":[{"inlineContent":[{"type":"text","text":"In this chapter you will learn how to import the OUDS iOS Swift Package and which librairies it provides"},{"type":"text","text":" "},{"type":"text","text":"you should choose for your needs."}],"type":"paragraph"}],"image":"ic_unified_ds.png","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies"]},{"name":"Define information cards","content":[{"inlineContent":[{"type":"text","text":"Since you prepared you Xcode project and integrated OUDS Swift Package, you can now define a nice and clear view with headings, images and button."}],"type":"paragraph"}],"image":"ic_unified_ds.png","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view"]},{"name":"Components showcases","content":[{"inlineContent":[{"type":"text","text":"Since