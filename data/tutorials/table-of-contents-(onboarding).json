{"hierarchy":{"paths":[],"reference":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)"},"metadata":{"categoryPathComponent":"Table-Of-Contents-(onboarding)","category":"Orange Unified Design System","estimatedTime":"2hr 5min","role":"overview","title":"Swift Package Onboarding Tutorial"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/table-of-contents-(onboarding)"]}],"kind":"overview","sections":[{"action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies","overridingTitle":"Get started"},"backgroundImage":"ic_unified_ds.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Discovering a new framework can be exciting and scary."},{"type":"text","text":" "},{"type":"text","text":"With this tutorial, you will learn how to embed OUDS Swift Package and define views tailored for your brand."},{"text":" ","type":"text"},{"text":"It has beend esigned for local events and meetups.","type":"text"},{"text":" ","type":"text"},{"text":"Let’s play!","type":"text"}]}],"title":"Swift Package Onboarding Tutorial","kind":"hero","image":"ic_unified_ds.png"},{"name":null,"chapters":[{"content":[{"inlineContent":[{"type":"text","text":"In this chapter you will learn how to import the OUDS iOS Swift Package and which librairies it provides"},{"text":" ","type":"text"},{"type":"text","text":"you should choose for your needs."}],"type":"paragraph"}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-and-librairies"],"image":"ic_unified_ds.png","name":"Import of the Swift Package and choose its librairies"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Since you prepared you Xcode project and integrated OUDS Swift Package, you can now define a nice and clear view with headings, images and button.","type":"text"}]}],"image":"ic_unified_ds.png","tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view"],"name":"Define information cards"},{"content":[{"inlineContent":[{"type":"text","text":"Since you discovered tokens, colors, spacings, and view modifiers, now it’s time to integrate and play with some components!"}],"type":"paragraph"}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase"],"image":"ic_unified_ds.png","name":"Components showcases"},{"content":[{"inlineContent":[{"text":"You can have questions and issues, and there are resources online. Let’s see that together.","type":"text"}],"type":"paragraph"}],"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further"],"image":"ic_unified_ds.png","name":"Go further with more ressources"}],"content":[],"kind":"volume","image":null}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","interfaceLanguage":"swift"},"references":{"ic_unified_ds.png":{"identifier":"ic_unified_ds.png","alt":"Logo of OUDS","type":"image","variants":[{"url":"\/images\/OUDSThemesContract\/ic_unified_ds.png","traits":["1x","light"]}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-2-nice-and-clear-view":{"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-2-nice-and-clear-view","kind":"project","title":"Define information cards","url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-2-nice-and-clear-view","abstract":[{"text":"Let’s suppose we want to define a view for corporate apps with headings, texts, buttons and images.","type":"text"},{"text":" ","type":"text"},{"text":"How can we do that?","type":"text"}],"role":"project","estimatedTime":"45min"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-4-going-further":{"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further","kind":"project","title":"Going further with more resources","url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-4-going-further","abstract":[{"text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources.","type":"text"}],"role":"project","estimatedTime":"10min"},"doc://OUDSThemesContract/tutorials/Table-Of-Contents-(onboarding)":{"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)","kind":"overview","title":"Swift Package Onboarding Tutorial","url":"\/tutorials\/table-of-contents-(onboarding)","abstract":[{"text":"Discovering a new framework can be exciting and scary.","type":"text"},{"text":" ","type":"text"},{"text":"With this tutorial, you will learn how to embed OUDS Swift Package and define views tailored for your brand.","type":"text"},{"text":" ","type":"text"},{"text":"It has beend esigned for local events and meetups.","type":"text"},{"text":" ","type":"text"},{"text":"Let’s play!","type":"text"}],"role":"overview"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-3-components-showcase":{"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase","kind":"project","title":"Components showcase","url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-3-components-showcase","abstract":[{"text":"Now you are ready to use more components than a simple button!","type":"text"}],"role":"project","estimatedTime":"1hr 0min"},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-1-package-and-librairies":{"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboardi