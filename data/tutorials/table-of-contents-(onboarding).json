imatedTime":"10min","kind":"project","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further","type":"topic","url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-4-going-further","role":"project","abstract":[{"text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources.","type":"text"}]},"ic_unified_ds.png":{"alt":"Logo of OUDS","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_unified_ds.png"}],"identifier":"ic_unified_ds.png","type":"image"}}}