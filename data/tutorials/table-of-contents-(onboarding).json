-and-clear-view"],"name":"Define information cards","content":[{"inlineContent":[{"text":"Since you prepared you Xcode project and integrated OUDS Swift Package, you can now define a nice and clear view with headings, images and button.","type":"text"}],"type":"paragraph"}],"image":"ic_unified_ds.png"},{"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-3-components-showcase"],"name":"Components showcases","content":[{"inlineContent":[{"text":"Since you discovered tokens, colors, spacings, and view modifiers, now it’s time to integrate and play with some components!","type":"text"}],"type":"paragraph"}],"image":"ic_unified_ds.png"},{"tutorials":["doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further"],"name":"Go further with more ressources","content":[{"inlineContent":[{"text":"You can have questions and issues, and there are resources online. Let’s see that together.","type":"text"}],"type":"paragraph"}],"image":"ic_unified_ds.png"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesContract\/tutorials\/Table-Of-Contents-(onboarding)"},"references":{"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-4-going-further":{"kind":"project","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-4-going-further","url":"\/tutorials\/oudsthemescontract\/tutorial-onboarding-4-going-further","title":"Going further with more resources","role":"project","estimatedTime":"10min","abstract":[{"type":"text","text":"Since you have learned how OUDS works with theme, themeable view, components, tuning and view modifiers, it is time now to discover some online resources."}]},"doc://OUDSThemesContract/tutorials/OUDSThemesContract/tutorial-onboarding-1-package-and-librairies":{"kind":"project","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/tutorials\/OUDSThemesContract\/tutorial-onboarding-1-package-an