ions\/postscriptfontnamesmap","abstract":[{"type":"text","text":"Some font family cannot be used as they are because their “marketing” names are unknown to the OS"},{"text":" ","type":"text"},{"text":"except their PostScript names.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This dictionnary defines the expected PostScript names of font families known in iOS."},{"text":" ","type":"text"},{"text":"Depending to the font family, several rules are applied, with for example removal of whitespaces","type":"text"},{"text":" ","type":"text"},{"text":"and adding of prefixes of suffixes after the font family name or the weight.","type":"text"}],"type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/PostScriptFontNamesMap","title":"PostScriptFontNamesMap"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","title":"OUDSWCAG21Ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"H