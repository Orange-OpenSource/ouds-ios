.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"}],"kind":"symbol","title":"OUDSWCAG21Ratio","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio"},"doc://OUDSFoundations/documentation/OUDSFoundations/Foundation":{"abstract":[],"type":"topic","kind":"symbol","role":"collection","title":"Foundation","url":"\/documentation\/oudsfoundations\/foundation","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Foundation"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSUserInterfaceSizeClass":{"navigatorTitle":[{"text":"OUDSUserInterfaceSizeClass","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudsuserinterfacesizeclass","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSUserInterfaceSizeClass","title":"OUDSUserInterfaceSizeClass","abstract":[{"type":"text","text":"Enumerates the size classes defined by the design system."},{"text":" ","type":"text"},{"type":"text","text":"The "},{"type":"strong","inlineContent":[{"text":"extraCompact","type":"text"}]},{"text":" size class if for screens with width < 389.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"strong","inlineContent":[{"type":"text","text":"compact"}]},{"text":" and ","type":"text"},{"inlineContent":[{"text":"regular","type":"text"}],"type":"strong"},{"type":"text","text":" size classes are the standard Apple classes."}],"fragments":[{"kind":"keyword","te