trast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"text":" ","type":"text"},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true,"type":"reference"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"title":"OUDSWCAG21Ratio","kind":"symbol","role":"symbol"},"doc://OUDSFoundations/documentation/OUDSFoundations/kApplePostScriptFontNames":{"title":"kApplePostScriptFontNames","abstract":[{"text":"Contains the Apple PostScript name of a font given a font family name and a font weight.","type":"text"},{"text":" ","type":"text"},{"text":"Such values have been picked from the Apple Font Book.","type":"text"}],"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"kApplePostScriptFontNames"},{"kind":"text","text":": "},{"preciseIdentifier":"s:15OUDSFoundations22PostScriptFontNamesMapa","kind":"typeIdentifier","text":"PostScriptFontNamesMap"}],"role":"symbol","url":"\/documentation\/oudsfoundations\/kapplepostscriptfontnames","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/kApplePostScriptFontNames"}}}