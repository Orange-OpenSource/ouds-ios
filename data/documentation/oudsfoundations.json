xt":" "},{"type":"text","text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference","isActive":true}],"title":"OUDSWCAG21Ratio","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"type":"topic"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSLogger":{"title":"OUDSLogger","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSLogger","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLogger","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"os.Logger"},{"type":"text","text":" wrapper used in the "},{"type":"emphasis","inlineContent":[{"text":"OUDSThemesContract iOS","type":"text"}]},{"type":"text","text":" library so as to logs things in standard output or elsewhere."}],"url":"\/documentation\/oudsfoundations\/oudslogger","navigatorTitle":[{"text":"OUDSLogger","kind":"identifier"}],"kind":"symbol"},"doc://OUDSFoundations/documentation/OUDSFoundations/PSFNMK":{"url":"\/documentation\/oudsfoundations\/psfnmk","role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"PSFNMK"}],"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"PSFNMK"}],"type":"topic","title":"PSFNMK","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/PSFNMK","abstract":[{"type":"text","text":"PostScriptFontNamesMapKey in shorter"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSLowPowerModeObserver":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"OUDSLowPowerMod