t":"To keep code smaller"}],"navigatorTitle":[{"text":"OL","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OL","type":"topic","kind":"symbol"},"doc://OUDSFoundations/documentation/OUDSFoundations/PostScriptFontNamesMap":{"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"PostScriptFontNamesMap"}],"navigatorTitle":[{"kind":"identifier","text":"PostScriptFontNamesMap"}],"type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/PostScriptFontNamesMap","abstract":[{"type":"text","text":"Some font family cannot be used as they are because their “marketing” names are unknown to the OS"},{"text":" ","type":"text"},{"type":"text","text":"except their PostScript names."},{"text":" ","type":"text"},{"type":"text","text":"This dictionnary defines the expected PostScript names of font families known in iOS."},{"text":" ","type":"text"},{"text":"Depending to the font family, several rules are applied, with for example removal of whitespaces","type":"text"},{"text":" ","type":"text"},{"text":"and adding of prefixes of suffixes after the font family name or the weight.","type":"text"}],"title":"PostScriptFontNamesMap","kind":"symbol","role":"symbol","url":"\/documentation\/oudsfoundations\/postscriptfontnamesmap"},"doc://OUDSFoundations/documentation/OUDSFoundations/PostScriptFontNamesMapKey":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"PostScriptFontNamesMapKey"}],"navigatorTitle":[{"kind":"identifier","text":"PostScriptFontNamesMapKey"}],"type":"topic","abstract":[{"text":"Key of the map containing PostScript name to use for a font depending to its family name and weight.","type":"text"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/PostScriptFontNamesMapKey","title":"PostScriptFontNamesMapKey","kind":"symbol","role":"symbol","url":"\/documentation\/oudsfoundations\/postscriptfontnamesmapkey"},"doc://OUDSFoundations/documentation/OUDSFoundations/kApplePostScriptFontNames":{"kind":"symbol","url":"\/documentation\/oudsfoundations\/kapplepostscriptfontnames","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"kApplePostScriptFontNames","kind":"identifier"},{"text":": ","kind":"text"},{"text":"PostScriptFontNamesMap","kind":"typeIdentifier","preciseIdentifier":"s:15OUDSFoundations22PostScriptFontNamesMapa"}],"abstract":[{"text":"Contains the Apple PostScript name of a font given a font family name and a font weight.","type":"text"},{"text":" ","type":"text"},{"text":"Such values have been picked from the Apple Font Book.","type":"text"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/kApplePostScriptFontNames","title":"kApplePostScriptFontNames","type":"topic","role":"symbol"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","type":"link","titleInlineContent":[{"type":"text","text":"the following guidelines"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"text":" ","type":"text"},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"text":" ","type":"text"},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"title":"OUDSWCAG21Ratio","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/kMinimalTouchAreaHeight":{"abstract":[{"text":"A touch area with an height equal to 44 pt at least is preferred for accessibility reasons","type":"text"},{"type":"text","text":" "},{"type":"text","text":"See https:\/\/a11y-guidelines.orange.com\/en\/mobile\/ios\/design\/#touch-target"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"kMinimalTouchAreaHeight"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier","text":"CGFloat"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/kMinimalTouchAreaHeight","url":"\/documentation\/oudsfoundations\/kminimaltouchareaheight","title":"kMinimalTouchAreaHeight","type":"topic"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSLowPowerModeObserver":{"title":"OUDSLowPowerModeObserver","url":"\/documentation\/oudsfoundations\/oudslowpowermodeobserver","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLowPowerModeObserver","kind":"identifier"}],"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"ObservableObject"},{"type":"text","text":" providing through a published state a flag saying if the device  is in low pover mode or not."},{"type":"text","text":" "},{"type":"text","text":"This object is exposed as "},{"type":"emphasis","inlineContent":[{"text":"environement object","type":"text"}]},{"type":"text","text":" through the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":", and can be used in any view"},{"type":"text","text":" "},{"type":"text","text":"inside it to apply a specific behavior when the device is in low power mode."}],"navigatorTitle":[{"text":"OUDSLowPowerModeObserver","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSLowPowerModeObserver","type":"topic","kind":"symbol"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSLogger":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"os.Logger"},{"type":"text","text":" wrapper used in the "},{"inlineContent":[{"text":"OUDS iOS","type":"text"}],"type":"emphasis"},{"text":" library so as to logs things in standard output or elsewhere.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSLogger","kind":"identifier"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSLogger","url":"\/documentation\/oudsfoundations\/oudslogger","navigatorTitle":[{"text":"OUDSLogger","kind":"identifier"}],"title":"OUDSLogger","type":"topic"},"doc://OUDSFoundations/documentation/OUDSFoundations/WCAG21Requirements":{"abstract":[{"type":"text","text":"WCAG 2.1 AA and AAA requirements use ratio for textual and non textual components"}],"kind":"sy