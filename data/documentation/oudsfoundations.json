ven a font family name and a font weight."},{"type":"text","text":" "},{"type":"text","text":"Such values have been picked from the Apple Font Book."}],"title":"kApplePostScriptFontNames","url":"\/documentation\/oudsfoundations\/kapplepostscriptfontnames","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/kApplePostScriptFontNames"},"doc://OUDSFoundations/documentation/OUDSFoundations/iPhoneDevice":{"abstract":[{"text":"List some iPhone devices which can use OUDS, i.e. supposed to support at least iOS 15.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Helps to define some metrics like tab bar heights."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/iPhoneDevice","title":"iPhoneDevice","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"iPhoneDevice","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/iphonedevice","type":"topic","navigatorTitle":[{"text":"iPhoneDevice","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/kMinimalTouchAreaWidth":{"kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"kMinimalTouchAreaWidth","kind":"identifier"},{"text":": ","kind":"text"},{"text":"CGFloat","kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}],"abstract":[{"type":"text","text":"A touch area with a width equal to 44 pt at least is preferred for accessibility reasons"},{"type":"text","text":" "},{"type":"text","text":"See https:\/\/a11y-guidelines.orange.com\/en\/mobile\/ios\/design\/#touch-target"}],"title":"kMinimalTouchAreaWidth","url":"\/documentation\/oudsfoundations\/kminimaltouchareawidth","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/kMinimalTouchAreaWidth"},"doc://OUDSFoundations/documentation/OUDSFoundations/SwiftUICore":{"abstract":[],"kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/SwiftUICore","title":"SwiftUICore","type":"topic","url":"\/documentation\/oudsfoundations\/swiftuicore"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"abstract":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","title":"OUDSWCAG21Ratio","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSLowPowerModeObserver":{"abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"ObservableObject"},{"type":"text","text":" providing through a published state a flag saying if the device  is in low pover mode or not."},{"type":"text","text":" "},{"type":"text","text":"This object is exposed as "},{"type":"emphasis","inlineContent":[{"text":"environement object","type":"text"}]},{"type":"text","text":" through the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":", and can be used in any view"},{"type":"text","text":" "},{"type":"text","text":"inside it to apply a specific behavior when the device is in low power mode."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSLowPowerModeObserver","title":"OUDSLowPowerModeObserver","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLowPowerModeObserver","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudsfoundations\/oudslowpowermodeobserver","navigatorTitle":[{"text":"OUDSLowPowerModeObserver","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/PostScriptFontNamesMapKey":{"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/PostScriptFontNamesMapKey","title":"PostScriptFontNamesMapKey","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PostScriptFontNamesMapKey","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudsfoundations\/postscriptfontnamesmapkey","navigatorTitle":[{"text":"PostScriptFontNamesMapKey","kind":"identifier"}],"abstract":[{"type":"text","text":"Key of the map containing PostScript name to use for a font depending to its family name and weight."}],"kind":"symbol"}}}