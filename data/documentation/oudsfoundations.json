Apple Font Book."}]},"doc://OUDSFoundations/documentation/OUDSFoundations/PostScriptFontNamesMap":{"title":"PostScriptFontNamesMap","kind":"symbol","url":"\/documentation\/oudsfoundations\/postscriptfontnamesmap","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PostScriptFontNamesMap","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/PostScriptFontNamesMap","type":"topic","abstract":[{"type":"text","text":"Some font family cannot be used as they are because their “marketing” names are unknown to the OS"},{"type":"text","text":" "},{"type":"text","text":"except their PostScript names."},{"type":"text","text":" "},{"type":"text","text":"This dictionnary defines the expected PostScript names of font families known in iOS."},{"type":"text","text":" "},{"type":"text","text":"Depending to the font family, several rules are applied, with for example removal of whitespaces"},{"type":"text","text":" "},{"type":"text","text":"and adding of prefixes of suffixes after the font family name or the weight."}],"navigatorTitle":[{"text":"PostScriptFontNamesMap","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/SwiftUICore":{"kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/SwiftUICore","role":"collection","title":"SwiftUICore","abstract":[],"type":"topic","url":"\/documentation\/oudsfoundations\/swiftuicore"},"doc://OUDSFoundations/documentation/OUDSFoundations/Foundation":{"title":"Foundation","kind":"symbol","url":"\/documentation\/oudsfoundations\/foundation","role":"collection","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Foundation","type":"topic","abstract":[]},"doc://OUDSFoundations/documentation/OUDSFoundations/iPhoneDevice":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"iPhoneDevice"}],"type":"topic","url":"\/documentation\/oudsfoundations\/iphonedevice","role":"symbol","title":"iPhoneDevice","navigatorTitle":[{"text":"iPhoneDevice","kind":"identifier"}],"abstract":[{"type":"text","text":"List some iPhone devices which can use OUDS, i.e. supposed to support at least iOS 15."},{"text":" ","type":"text"},{"text":"Helps to define some metrics like tab bar heights.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/iPhoneDevice"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSUtils":{"kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSUtils","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSUtils"}],"abstract":[{"text":"A set of utilities from OUDS library shared with love ⸜(｡˃ ᵕ ˂)⸝♡♡♡","type":"text"}],"title":"OUDSUtils","type":"topic","navigatorTitle":[{"kind":"identifier","text":"OUDSUtils"}],"url":"\/documentation\/oudsfoundations\/oudsutils"},"ic_layers.png":{"identifier":"ic_layers.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"alt":null},"doc://OUDSFoundations/documentation/OUDSFoundations/PostScriptFontNamesMapKey":{"navigatorTitle":[{"text":"PostScriptFontNamesMapKey","kind":"identifier"}],"role":"symbol","title":"PostScriptFontNamesMapKey","url":"\/documentation\/oudsfoundations\/postscriptfontnamesmapkey","abstract":[{"type":"text","text":"Key of the map containing PostScript name to use for a font depending to its family name and weight."}],"type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/PostScriptFontNamesMapKey","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"PostScriptFontNamesMapKey","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"title":"OUDSWCAG21Ratio","kind":"symbol","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","type":"topic","abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSUserInterfaceSizeClass":{"kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSUserInterfaceSizeClass","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSUserInterfaceSizeClass"}],"abstract":[{"type":"text","text":"Enumerates the size classes defined by the design system."},{"text":" ","type":"text"},{"type":"text","text":"The "},{"inlineContent":[{"type":"text","text":"extraCompact"}],"type":"strong"},{"text":" size class if for screens with width < 389.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"type":"strong","inlineContent":[{"text":"compact","type":"text"}]},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"regular"}]},{"text":" size classes are the standard Apple classes.","type":"text"}],"title":"OUDSUserInterfaceSizeClass","type":"topic","navigatorTitle":[{"kind":"identifier","text":"OUDSUserInterfaceSizeClass"}],"url":"\/documentation\/oudsfoundations\/oudsuserinterfacesizeclass"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSLowPowerModeObserver":{"title":"OUDSLowPowerModeObserver","kind":"symbol","url":"\/documentation\/oudsfoundations\/oudslowpowermodeobserver","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLowPowerModeObserver","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSLowPowerModeObserver","type":"topic","abstract":[{"type":"text","text":"An "},{"type":"codeVoice","code":"ObservableObject"},{"type":"text","text":" providing through a published state a flag saying if the device  is in low pover mode or not."},{"type":"text","text":" "},{"type":"text","text":"This object is exposed as "},{"type":"emphasis","inlineContent":[{"type":"text","text":"environement object"}]},{"type":"text","text":" through the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":", and can be used in any view"},{"type":"text","text":" "},{"type":"text","text":"inside it to apply a specific behavior when the device is in low power mode."}],"navigatorTitle":[{"text":"OUDSLowPowerModeObserver","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/WCAG21Requirements":{"title"