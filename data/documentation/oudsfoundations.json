d":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"PostScriptFontNamesMap","kind":"identifier"}],"title":"PostScriptFontNamesMap","navigatorTitle":[{"kind":"identifier","text":"PostScriptFontNamesMap"}],"abstract":[{"text":"Some font family cannot be used as they are because their “marketing” names are unknown to the OS","type":"text"},{"text":" ","type":"text"},{"text":"except their PostScript names.","type":"text"},{"text":" ","type":"text"},{"text":"This dictionnary defines the expected PostScript names of font families known in iOS.","type":"text"},{"text":" ","type":"text"},{"text":"Depending to the font family, several rules are applied, with for example removal of whitespaces","type":"text"},{"text":" ","type":"text"},{"text":"and adding of prefixes of suffixes after the font family name or the weight.","type":"text"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/PostScriptFontNamesMap","url":"\/documentation\/oudsfoundations\/postscriptfontnamesmap","type":"topic","kind":"symbol"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSUtils":{"abstract":[{"text":"A set of utilities from OUDS library shared with love ⸜(｡˃ ᵕ ˂)⸝♡♡♡","type":"text"}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSUtils","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"OUDSUtils","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudsutils","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSUtils","title":"OUDSUtils"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"abstract":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"also named “RGAA”.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","title":"OUDSWCAG21Ratio"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"role":"collection","images":[{"identifier":"ic_layers.png","type":"icon"}],"kind":"symbol","url":"\/documentation\/oudsfoundations","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","title":"Foundations"},"doc://OUDSFoundations/documentation/OUDSFoundations/iPhoneDevice":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"iPhoneDevice","kind":"identifier"}],"title":"iPhoneDevice","na