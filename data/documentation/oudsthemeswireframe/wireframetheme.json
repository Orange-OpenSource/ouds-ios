ameBrandColorRawTokens"}],"type":"topic","url":"\/documentation\/oudsthemeswireframe\/wireframebrandcolorrawtokens","title":"WireframeBrandColorRawTokens","abstract":[{"type":"text","text":"This enum helps to add new "},{"type":"strong","inlineContent":[{"type":"text","text":"color raw tokens"}]},{"type":"text","text":" exclusive to this "},{"isActive":true,"identifier":"doc:\/\/OUDSThemesWireframe\/documentation\/OUDSThemesWireframe\/WireframeTheme","type":"reference"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Such tokens are packed in a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift enum"}]},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_.","type":"text"}],"kind":"symbol"},"doc://OUDSThemesWireframe/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesWireframe\/s8SendableP","title":"Swift.Sendable"},"doc://OUDSThemesWireframe/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesWireframe\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"doc://OUDSThemesWireframe/documentation/OUDSThemesWireframe/WireframeTheme":{"navigatorTitle":[{"text":"WireframeTheme","kind":"identifier"}],"kind":"symbol","title":"WireframeTheme","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"WireframeTheme","kind":"identifier"}],"url":"\/documentation\/oudsthemeswireframe\/wireframetheme","abstract":[{"text":"This Wireframe theme is a theme for some specific usages, like for prototyping and design of journeys with non-Orange charted themes.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This is an override of the default basic "},{"type":"codeVoice","code":"OUDSTheme"},{"text":" for some usages.","type":"text"},{"type":"text","text":" "},{"text":"It can override any properties from its superclass, and but cannot be derived ; this is not allowed.","type":"text"}],"role":"symbol","identifier":"doc:\/\/OUDSThemesWireframe\/documentation\/OUDSThemesWireframe\/WireframeTheme","type":"topic"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme