{"abstract":[{"text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints.","type":"text"}],"kind":"symbol","identifier":{"url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"anchor":"Group","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"],"title":"Group"},{"anchor":"Classes","generated":true,"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorChartSemanticTokensProvider"],"title":"Classes"},{"anchor":"Extended-Modules","generated":true,"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/Foundation","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/SwiftUICore"],"title":"Extended Modules"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"codeListing","syntax":null,"code":["🧬 Theme version: 2.3.0"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this theme exists."}]},{"name":"Note","type":"aside","content":[{"inlineContent":[{"text":"This theme is related to Orange theme module to use some raw tokens of colors.","type":"text"}],"type":"paragraph"}],"style":"note"},{"name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"It contains also colors dedicated to charts."}],"type":"paragraph"}],"style":"note"},{"name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The Orange Compact theme is read only: it cannot be suclassed or derivated.","type":"text"}]}],"style":"important"},{"type":"heading","anchor":"How-to-use-the-theme","level":2,"text":"How to use the theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","type":"reference"},{"type":"text","text":" directly. To use the "},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","type":"reference"},{"type":"text","text":" without further modifications, you will have to use the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" for your root view and give it an instance of "},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","type":"reference"},{"type":"text","text":". Keep in mind the themes are "},{"inlineContent":[{"type":"text","text":"Swift class objects"}],"type":"emphasis"},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeCompactTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the "},{"type":"codeVoice","code":"Orange Compact"},{"type":"text","text":" theme, you just need to use the theme object as is."}],"type":"paragraph"},{"anchor":"Tunable-theme","text":"Tunable theme","type":"heading","level":2},{"inlineContent":[{"text":"The theme can be tuned with ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object to give at init.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Some tuning object exists."}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","\/\/ Apply it to your theme","let theme = OrangeCompactTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"A default tuning is applied for this theme:","type":"text"}]},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Tunable elements","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default values","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"rounded corners buttons","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"❌ false","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"rounded corners text inputs","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ true"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"rounded corners alert messages"}]}],[{"type":"paragraph","inlineContent":[{"text":"❌ false","type":"text"}]}]]],"type":"table"},{"text":"Typography","level":2,"type":"heading","anchor":"Typography"},{"text":"Helvetica Neue","level":3,"type":"heading","anchor":"Helvetica-Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange theme uses "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":" typography. This font is already available through iOS."},{"type":"text","text":" "},{"type":"text","text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens."}]},{"syntax":"swift","type":"codeListing","code":["\/\/ The three following instanciations are the same","let theme = OrangeCompactTheme()","let theme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"]},{"text":"Other fonts","level":3,"type":"heading","anchor":"Other-fonts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init."}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeCompactTheme(family: theFontFamilyNameInPostScript)"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Specific rules to compute PostScript value are defined in "},{"type":"codeVoice","code":"PostScriptFontNamesMap.swift"}]}],"style":"note","type":"aside","name":"Note"},{"style":"tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your font family is not well managed, you can "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues"}]}],"type":"aside","name":"Tip"},{"name":"Important","style":"important","type":"aside","content":[{"inlineContent":[{"text":"For production products and official tools, ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" is preferred and should be used","type":"text"}],"type":"paragraph"}]},{"name":"Tip","style":"tip","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions"}]}]},{"name":"Caution","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps"}]}]},{"name":"Important","style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)","type":"text"}]}]},{"text":"How to enrich the theme","anchor":"How-to-enrich-the-theme","type":"heading","level":2},{"inlineContent":[{"text":"You cannot derivate the ","type":"text"},{"inlineContent":[{"text":"Orange Compact","type":"text"}],"type":"emphasis"},{"text":" theme.","type":"text"}],"type":"paragraph"},{"text":"How it looks like","anchor":"How-it-looks-like","type":"heading","level":2},{"text":"Actions","anchor":"Actions","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_OrangeCompact.png"}],"type":"paragraph"},{"text":"Content display","anchor":"Content-display","type":"heading","level":3},{"text":"Bullet list","anchor":"Bullet-list","type":"heading","level":4},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_bullet_list_OrangeCompact.png"}],"type":"paragraph"},{"text":"Controls","anchor":"Controls","type":"heading","level":3},{"text":"Checkboxes","anchor":"Checkboxes","type":"heading","level":4},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_OrangeCompact.png"}]}],"title":"Checkbox"},{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_OrangeCompac