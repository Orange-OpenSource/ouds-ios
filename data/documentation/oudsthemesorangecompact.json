{"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangecompact"]}],"hierarchy":{"paths":[[]]},"abstract":[{"type":"text","text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints."}],"metadata":{"role":"collection","modules":[{"name":"Theme Orange Compact"}],"externalID":"OUDSThemesOrangeCompact","images":[{"type":"icon","identifier":"ic_theme_orangecompact.png"}],"title":"Theme Orange Compact","roleHeading":"Library","symbolKind":"module"},"schemaVersion":{"major":0,"patch":0,"minor":3},"topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"],"anchor":"Group","title":"Group"},{"generated":true,"anchor":"Classes","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorChartSemanticTokensProvider","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorDecorativeSemanticTokensProvider"],"title":"Classes"},{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/Foundation","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/SwiftUICore"],"anchor":"Extended-Modules","generated":true,"title":"Extended Modules"}],"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"syntax":null,"type":"codeListing","code":["🧬 Theme version: 2.5.0"]},{"inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and"},{"text":" ","type":"text"},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes."},{"text":" ","type":"text"},{"text":"That is the reason why this theme exists.","type":"text"}],"type":"paragraph"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"This theme is related to Orange theme module to use some raw tokens of colors."}],"type":"paragraph"}],"type":"aside","style":"note"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"It contains also colors dedicated to charts.","type":"text"}]}],"name":"Note"},{"style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The Orange Compact theme is read only: it cannot be suclassed or derivated.","type":"text"}]}],"name":"Important"},{"anchor":"How-to-use-the-theme","type":"heading","level":2,"text":"How to use the theme"},{"inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true},{"type":"text","text":" directly. To use the "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}],"type":"paragraph"},{"code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeCompactTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This theme embeds and registers the fonts for the ","type":"text"},{"code":"Orange Compact","type":"codeVoice"},{"text":" theme, you just need to use the theme object as is.","type":"text"}],"type":"paragraph"},{"anchor":"Tunable-theme","type":"heading","level":2,"text":"Tunable theme"},{"inlineContent":[{"text":"The theme can be tuned with ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object to give at init.","type":"text"},{"text":" ","type":"text"},{"text":"Some tuning object exists.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","\/\/ Apply it to your theme","let theme = OrangeCompactTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"A default tuning is applied for this theme:","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Tunable elements"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Default values"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"rounded corners buttons"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"❌ false"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"rounded corners text inputs"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✅ true"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"rounded corners alert messages"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"❌ false"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"anchor":"Typography","type":"heading","level":2,"text":"Typography"},{"anchor":"Helvetica-Neue","type":"heading","level":3,"text":"Helvetica Neue"},{"inlineContent":[{"text":"The Orange theme uses ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" typography. This font is already available through iOS.","type":"text"},{"text":" ","type":"text"},{"text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens.","type":"text"}],"type":"paragraph"},{"code":["\/\/ The three following instanciations are the same","let theme = OrangeCompactTheme()","let theme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Other-fonts","type":"heading","level":3,"text":"Other fonts"},{"inlineContent":[{"text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeCompactTheme(family: theFontFamilyNameInPostScript)"],"syntax":"swift","type":"codeListing"},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Specific rules to compute PostScript value are defined in "},{"type":"codeVoice","code":"PostScriptFontNamesMap.swift"}],"type":"paragraph"}],"name":"Note"},{"style":"tip","type":"aside","content":[{"inlineContent":[{"type":"text","text":"If your font family is not well managed, you can "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","isActive":true}],"type":"paragraph"}],"name":"Tip"},{"style":"important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"For production products and official tools, "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":" is preferred and should be used"}],"type":"paragraph"}],"name":"Important"},{"style":"tip","type":"aside","content":[{"inlineContent":[{"type":"text","text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","isActive":true}],"type":"paragraph"}],"name":"Tip"},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps"}],"type":"paragraph"}],"name":"Caution"},{"style":"important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)"}],"type":"paragraph"}],"name":"Important"},{"anchor":"How-to-enrich-the-theme","type":"heading","level":2,"text":"How to enrich the theme"},{"inlineContent":[{"text":"You cannot derivate the ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange Compact"}],"type":"emphasis"},{"text":" theme.","type":"text"}],"type":"paragraph"},{"anchor":"How-it-looks-like","type":"heading","level":2,"text":"How it looks like"},{"anchor":"Actions","type":"heading","level":3,"text":"Actions"},{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_OrangeCompact.png","type":"image"}],"type":"paragraph"},{"anchor":"Content-display","type":"heading","level":3,"text":"Content display"},{"anchor":"Bullet-list","type":"heading","level":4,"text":"Bullet list"},{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_bullet_list_OrangeCompact.png","type":"image"}],"type":"paragraph"},{"anchor":"Controls","type":"heading","level":3,"text":"Controls"},{"anchor":"Checkboxes","type":"heading","l