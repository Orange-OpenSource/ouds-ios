{"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/oudsthemesorangecompact"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","topicSections":[{"title":"Group","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"],"anchor":"Group"},{"title":"Classes","generated":true,"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorChartSemanticTokensProvider","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorDecorativeSemanticTokensProvider"],"anchor":"Classes"},{"title":"Extended Modules","generated":true,"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/Foundation","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/SwiftUICore"],"anchor":"Extended-Modules"}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"syntax":null,"type":"codeListing","code":["🧬 Theme version: 2.5.0"]},{"inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this theme exists.","type":"text"}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"This theme is related to Orange theme module to use some raw tokens of colors.","type":"text"}],"type":"paragraph"}],"style":"note"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"It contains also colors dedicated to charts.","type":"text"}],"type":"paragraph"}],"style":"note"},{"type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange Compact theme is read only: it cannot be suclassed or derivated."}]}],"style":"important"},{"level":2,"type":"heading","anchor":"How-to-use-the-theme","text":"How to use the theme"},{"inlineContent":[{"text":"You can use ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","type":"reference","isActive":true},{"text":" directly. To use the ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","type":"reference","isActive":true},{"text":" without further modifications, you will have to use the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" for your root view and give it an instance of ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true},{"text":". Keep in mind the themes are ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}],"type":"paragraph"},{"code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeCompactTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}],"type":"paragraph"},{"code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"This theme embeds and registers the fonts for the ","type":"text"},{"type":"codeVoice","code":"Orange Compact"},{"text":" theme, you just need to use the theme object as is.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Tunable-theme","text":"Tunable theme","type":"heading"},{"inlineContent":[{"type":"text","text":"The theme can be tuned with "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object to give at init."},{"type":"text","text":" "},{"type":"text","text":"Some tuning object exists."}],"type":"paragraph"},{"code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","\/\/ Apply it to your theme","let theme = OrangeCompactTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"A default tuning is applied for this theme:"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Tunable elements"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default values"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"rounded corners buttons"}]}],[{"type":"paragraph","inlineContent":[{"text":"❌ false","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"rounded corners text inputs"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ true"}]}]],[[{"inlineContent":[{"text":"rounded corners alert messages","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"❌ false","type":"text"}],"type":"paragraph"}]]]},{"anchor":"Typography","level":2,"text":"Typography","type":"heading"},{"anchor":"Helvetica-Neue","level":3,"text":"Helvetica Neue","type":"heading"},{"inlineContent":[{"type":"text","text":"The Orange theme uses "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" typography. This font is already available through iOS."},{"type":"text","text":" "},{"type":"text","text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ The three following instanciations are the same","let theme = OrangeCompactTheme()","let theme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"type":"codeListing"},{"anchor":"Other-fonts","level":3,"text":"Other fonts","type":"heading"},{"inlineContent":[{"text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeCompactTheme(family: theFontFamilyNameInPostScript)"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Specific rules to compute PostScript value are defined in "},{"code":"PostScriptFontNamesMap.swift","type":"codeVoice"}]}],"name":"Note","style":"note","type":"aside"},{"content":[{"inlineContent":[{"text":"If your font family is not well managed, you can ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","isActive":true}],"type":"paragraph"}],"name":"Tip","style":"tip","type":"aside"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For production products and official tools, "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" is preferred and should be used"}]}],"name":"Important","style":"important","type":"aside"},{"content":[{"inlineContent":[{"type":"text","text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","isActive":true}],"type":"paragraph"}],"name":"Tip","style":"tip","type":"aside"},{"name":"Caution","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps","type":"text"}]}],"style":"note"},{"name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)","type":"text"}]}],"style":"important"},{"level":2,"type":"heading","text":"How to enrich the theme","anchor":"How-to-enrich-the-theme"},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the ","type":"text"},{"inlineContent":[{"text":"Orange Compact","type":"text"}],"type":"emphasis"},{"text":" theme.","type":"text"}]},{"level":2,"type":"heading","text":"How it looks like","anchor":"How-it-looks-like"},{"level":3,"type":"heading","text":"Actions","anchor":"Actions"},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_OrangeCompact.png"}],"type":"paragraph"},{"text":"Content display","type":"heading","level":3,"anchor":"Content-display"},{"text":"Bullet list","type":"heading","level":4,"anchor":"Bullet-list"},{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_bullet_list_OrangeCompact.png","type":"image"}],"type":"paragraph"},{"text":"Controls","type":"heading","level":3,"anchor":"Controls"},{"anchor":"Checkboxes","level":4,"type":"heading","text":"Checkboxes"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_OrangeCompact.png","type":"image"}]}],"title":"Checkbox"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem