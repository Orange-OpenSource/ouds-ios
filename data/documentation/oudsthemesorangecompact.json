{"topicSections":[{"title":"Group","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"],"anchor":"Group"},{"title":"Classes","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorChartSemanticTokensProvider","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorDecorativeSemanticTokensProvider"],"generated":true,"anchor":"Classes"},{"title":"Extended Modules","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/Foundation","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/SwiftUICore"],"generated":true,"anchor":"Extended-Modules"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"code":["🧬 Theme version: 2.5.0"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this theme exists.","type":"text"}],"type":"paragraph"},{"name":"Note","content":[{"inlineContent":[{"text":"This theme is related to Orange theme module to use some raw tokens of colors.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside"},{"name":"Note","content":[{"inlineContent":[{"text":"It contains also colors dedicated to charts.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside"},{"name":"Important","content":[{"inlineContent":[{"text":"The Orange Compact theme is read only: it cannot be suclassed or derivated.","type":"text"}],"type":"paragraph"}],"style":"important","type":"aside"},{"level":2,"anchor":"How-to-use-the-theme","text":"How to use the theme","type":"heading"},{"inlineContent":[{"text":"You can use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","type":"reference"},{"text":" directly. To use the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","type":"reference"},{"text":" without further modifications, you will have to use the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" for your root view and give it an instance of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","type":"reference"},{"text":". Keep in mind the themes are ","type":"text"},{"inlineContent":[{"text":"Swift class objects","type":"text"}],"type":"emphasis"},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}],"type":"paragraph"},{"code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeCompactTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This theme embeds and registers the fonts for the ","type":"text"},{"code":"Orange Compact","type":"codeVoice"},{"text":" theme, you just need to use the theme object as is.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Tunable-theme","text":"Tunable theme","type":"heading"},{"inlineContent":[{"text":"The theme can be tuned with ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object to give at init.","type":"text"},{"text":" ","type":"text"},{"text":"Some tuning object exists.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","\/\/ Apply it to your theme","let theme = OrangeCompactTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"A default tuning is applied for this theme:","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"text":"Tunable elements","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default values","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"rounded corners buttons","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"❌ false","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"rounded corners text inputs","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"✅ true","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"rounded corners alert messages","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"❌ false","type":"text"}]}]]],"header":"row","type":"table"},{"level":2,"anchor":"Typography","text":"Typography","type":"heading"},{"level":3,"anchor":"Helvetica-Neue","text":"Helvetica Neue","type":"heading"},{"inlineContent":[{"text":"The Orange theme uses ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":" typography. This font is already available through iOS.","type":"text"},{"text":" ","type":"text"},{"text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens.","type":"text"}],"type":"paragraph"},{"code":["\/\/ The three following instanciations are the same","let theme = OrangeCompactTheme()","let theme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Other-fonts","text":"Other fonts","type":"heading"},{"inlineContent":[{"text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeCompactTheme(family: theFontFamilyNameInPostScript)"],"syntax":"swift","type":"codeListing"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Specific rules to compute PostScript value are defined in ","type":"text"},{"code":"PostScriptFontNamesMap.swift","type":"codeVoice"}]}],"style":"note","type":"aside"},{"name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"If your font family is not well managed, you can ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","type":"reference"}]}],"style":"tip","type":"aside"},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"For production products and official tools, ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":" is preferred and should be used","type":"text"}]}],"style":"important","type":"aside"},{"name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","type":"reference"}]}],"style":"tip","type":"aside"},{"name":"Caution","content":[{"type":"paragraph","inlineContent":[{"text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps","type":"text"}]}],"style":"note","type":"aside"},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)","type":"text"}]}],"style":"important","type":"aside"},{"level":2,"anchor":"How-to-enrich-the-theme","text":"How to enrich the theme","type":"heading"},{"inlineContent":[{"text":"You cannot derivate the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Orange Compact","type":"text"}]},{"text":" theme.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"How-it-looks-like","text":"How it looks like","type":"heading"},{"level":3,"anchor":"Actions","text":"Actions","type":"heading"},{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_OrangeCompact.png","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Content-display","text":"Content display","type":"heading"},{"level":4,"anchor":"Bullet-list","text":"Bullet list","type":"heading"},{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_bullet_list_OrangeCompact.png","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Controls","text":"Controls","type":"heading"},{"level":4,"anchor":"Checkboxes","text":"Checkboxes","type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_OrangeCompact.png","type":"image"}],"type":"paragraph"}],"title":"Checkbox"},{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_OrangeCompact.png","type":"image"}],"type":"paragraph"}],"title":"Checkbox item"}],"type":"tabNavigator"},{"level":4,"anchor":"Radios","text":"Radios","type":"heading"},{"tabs":[{"content":[{"inli