{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"codeListing","syntax":null,"code":["🧬 Theme version: 2.3.0"]},{"type":"paragraph","inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this theme exists.","type":"text"}]},{"content":[{"inlineContent":[{"text":"This theme is related to Orange theme module to use some raw tokens of colors.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"content":[{"inlineContent":[{"text":"It contains also colors dedicated to charts.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"content":[{"inlineContent":[{"text":"The Orange Compact theme is read only: it cannot be suclassed or derivated.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"type":"heading","anchor":"How-to-use-the-theme","level":2,"text":"How to use the theme"},{"type":"paragraph","inlineContent":[{"text":"You can use ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true,"type":"reference"},{"text":" directly. To use the ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true,"type":"reference"},{"text":" without further modifications, you will have to use the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" for your root view and give it an instance of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true,"type":"reference"},{"text":". Keep in mind the themes are ","type":"text"},{"inlineContent":[{"text":"Swift class objects","type":"text"}],"type":"emphasis"},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeCompactTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This theme embeds and registers the fonts for the ","type":"text"},{"code":"Orange Compact","type":"codeVoice"},{"text":" theme, you just need to use the theme object as is.","type":"text"}]},{"type":"heading","anchor":"Tunable-theme","level":2,"text":"Tunable theme"},{"type":"paragraph","inlineContent":[{"text":"The theme can be tuned with ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object to give at init.","type":"text"},{"text":" ","type":"text"},{"text":"Some tuning object exists.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","\/\/ Apply it to your theme","let theme = OrangeCompactTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"]},{"type":"paragraph","inlineContent":[{"text":"A default tuning is applied for this theme:","type":"text"}]},{"type":"table","rows":[[[{"inlineContent":[{"text":"Tunable elements","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default values","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"rounded corners buttons","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"❌ false","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"rounded corners text inputs","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"✅ true","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"rounded corners alert messages","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"❌ false","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","anchor":"Typography","level":2,"text":"Typography"},{"type":"heading","anchor":"Helvetica-Neue","level":3,"text":"Helvetica Neue"},{"type":"paragraph","inlineContent":[{"text":"The Orange theme uses ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":" typography. This font is already available through iOS.","type":"text"},{"text":" ","type":"text"},{"text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ The three following instanciations are the same","let theme = OrangeCompactTheme()","let theme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"]},{"type":"heading","anchor":"Other-fonts","level":3,"text":"Other fonts"},{"type":"paragraph","inlineContent":[{"text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeCompactTheme(family: theFontFamilyNameInPostScript)"]},{"content":[{"inlineContent":[{"text":"Specific rules to compute PostScript value are defined in ","type":"text"},{"code":"PostScriptFontNamesMap.swift","type":"codeVoice"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"content":[{"inlineContent":[{"text":"If your font family is not well managed, you can ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","type":"reference"}],"type":"paragraph"}],"type":"aside","style":"tip","name":"Tip"},{"content":[{"inlineContent":[{"text":"For production products and official tools, ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" is preferred and should be used","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"content":[{"inlineContent":[{"text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","type":"reference"}],"type":"paragraph"}],"type":"aside","style":"tip","name":"Tip"},{"content":[{"inlineContent":[{"text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Caution"},{"content":[{"inlineContent":[{"text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"type":"heading","anchor":"How-to-enrich-the-theme","level":2,"text":"How to enrich the theme"},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the ","type":"text"},{"inlineContent":[{"text":"Orange Compact","type":"text"}],"type":"emphasis"},{"text":" theme.","type":"text"}]},{"type":"heading","anchor":"How-it-looks-like","level":2,"text":"How it looks like"},{"type":"heading","anchor":"Actions","level":3,"text":"Actions"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_OrangeCompact.png","type":"image"}]},{"type":"heading","anchor":"Content-display","level":3,"text":"Content display"},{"type":"heading","anchor":"Bullet-list","level":4,"text":"Bullet list"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_bullet_list_OrangeCompact.png","type":"image"}]},{"type":"heading","anchor":"Controls","level":3,"text":"Controls"},{"type":"heading","anchor":"Checkboxes","level":4,"text":"Checkboxes"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_OrangeCompact.png"}],"type":"paragraph"}],"title":"Checkbox"},{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_OrangeCompact.png"}],"type":"paragraph"}],"title":"Checkbox item"}]},{"type":"heading","anchor":"Radios","level":4,"text":"Radios"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radio_OrangeCompact.png"}],"type":"paragraph"}],"title":"Radio"},{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radioItem_OrangeCompact.png"}],"type":"paragraph"}],"title":"Radio item"}]},{"type":"heading","anchor":"Switches","level":4,"text":"Switches"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_switch_OrangeCompact.png"}],"type":"paragraph"}],"title":"Switch"},{"content":[{"inlin