{"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[[]]},"kind":"symbol","sections":[],"topicSections":[{"anchor":"Group","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"],"title":"Group"},{"generated":true,"anchor":"Classes","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorChartSemanticTokensProvider","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorDecorativeSemanticTokensProvider"],"title":"Classes"},{"generated":true,"anchor":"Extended-Modules","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/Foundation","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/SwiftUICore"],"title":"Extended Modules"}],"abstract":[{"type":"text","text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"code":["🧬 Theme version: 2.5.0"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this theme exists."}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"text":"This theme is related to Orange theme module to use some raw tokens of colors.","type":"text"}],"type":"paragraph"}]},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"It contains also colors dedicated to charts."}],"type":"paragraph"}]},{"name":"Important","style":"important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"The Orange Compact theme is read only: it cannot be suclassed or derivated."}],"type":"paragraph"}]},{"level":2,"text":"How to use the theme","anchor":"How-to-use-the-theme","type":"heading"},{"inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true},{"type":"text","text":" directly. To use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"},{"type":"text","text":". Keep in mind the themes are "},{"inlineContent":[{"type":"text","text":"Swift class objects"}],"type":"emphasis"},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}],"type":"paragraph"},{"type":"codeListing","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeCompactTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the "},{"type":"codeVoice","code":"Orange Compact"},{"type":"text","text":" theme, you just need to use the theme object as is."}]},{"level":2,"type":"heading","text":"Tunable theme","anchor":"Tunable-theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be tuned with "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object to give at init."},{"type":"text","text":" "},{"type":"text","text":"Some tuning object exists."}]},{"type":"codeListing","code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","\/\/ Apply it to your theme","let theme = OrangeCompactTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"A default tuning is applied for this theme:","type":"text"}]},{"rows":[[[{"inlineContent":[{"text":"Tunable elements","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default values","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"rounded corners buttons"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"❌ false"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"rounded corners text inputs"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✅ true"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"rounded corners alert messages","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"❌ false","type":"text"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"heading","level":2,"anchor":"Typography","text":"Typography"},{"type":"heading","level":3,"anchor":"Helvetica-Neue","text":"Helvetica Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange theme uses "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" typography. This font is already available through iOS."},{"type":"text","text":" "},{"type":"text","text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ The three following instanciations are the same","let theme = OrangeCompactTheme()","let theme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"]},{"type":"heading","anchor":"Other-fonts","text":"Other fonts","level":3},{"type":"paragraph","inlineContent":[{"text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeCompactTheme(family: theFontFamilyNameInPostScript)"]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Specific rules to compute PostScript value are defined in ","type":"text"},{"type":"codeVoice","code":"PostScriptFontNamesMap.swift"}]}]},{"style":"tip","name":"Tip","type":"aside","content":[{"inlineContent":[{"type":"text","text":"If your font family is not well managed, you can "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For production products and official tools, "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" is preferred and should be used","type":"text"}]}],"type":"aside","style":"important","name":"Important"},{"type":"aside","name":"Tip","style":"tip","content":[{"inlineContent":[{"type":"text","text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), "},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","isActive":true,"type":"reference"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps"}]}],"type":"aside","style":"note","name":"Caution"},{"style":"important","name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)"}]}]},{"text":"How to enrich the theme","anchor":"How-to-enrich-the-theme","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You cannot derivate the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange Compact"}]},{"type":"text","text":" theme."}]},{"anchor":"How-it-looks-like","level":2,"type":"heading","text":"How it looks like"},{"anchor":"Actions","level":3,"type":"heading","text":"Actions"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_OrangeCompact.png"}]},{"anchor":"Content-display","level":3,"type":"heading","text":"Content display"},{"anchor":"Bullet-list","level":4,"type":"heading","text":"Bullet list"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_bullet_list_OrangeCompact.png"}]},{"level":3,"anchor":"Controls","type":"heading","text":"Controls"},{"level":4,"anchor":"Checkboxes","type":"heading","text":"Checkboxes"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_OrangeCompact.png","type":"image"}]}],"title":"Checkbox"},{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_OrangeCompact.png","type":"image"}],"type":"paragraph"}],"title":"Checkbox item"}],"type":"tabNavigator"},{"level":4,"anchor":"Radios","type":"heading","text":"Radios"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radio_OrangeCompact.png","type":"image"}]}],"title":"Radio"},{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radioItem_OrangeCompact.png"}],"type":"paragraph"}],"title":"Radio item"}],"type":"tabNavigator"},{"level":4,"anchor":"Switches","type":"heading","text":"Switches"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_switch_OrangeCompact.png"}],"type":"paragraph"}],"title":"Switch"},{"title":"Switch item","content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_switchItem_OrangeCompact.png","type":"image"}]}]}],"type":"tabNavigator"},{"type":"heading","anchor":"Chips","level":4,"text":"Chips"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_filterChip_OrangeCompact.png"}]}],"title":"Filter chip"},{"title":"Suggestion chip","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_suggestionChip_OrangeCompact.png"}]}]}]},{"text":"Text input","type":"heading","anchor":"Text-input","level":4},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/