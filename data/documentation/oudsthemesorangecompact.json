{"metadata":{"externalID":"OUDSThemesOrangeCompact","symbolKind":"module","modules":[{"name":"Theme Orange Compact"}],"images":[{"type":"icon","identifier":"ic_theme_orangecompact.png"}],"title":"Theme Orange Compact","roleHeading":"Library","role":"collection"},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"codeListing","code":["🧬 Theme version: 2.5.0"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this theme exists."}]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This theme is related to Orange theme module to use some raw tokens of colors.","type":"text"}]}],"style":"note"},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"It contains also colors dedicated to charts.","type":"text"}]}],"style":"note"},{"type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"The Orange Compact theme is read only: it cannot be suclassed or derivated.","type":"text"}]}],"style":"important"},{"type":"heading","text":"How to use the theme","level":2,"anchor":"How-to-use-the-theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"},{"type":"text","text":" directly. To use the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"},{"type":"text","text":" without further modifications, you will have to use the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" for your root view and give it an instance of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"type":"codeListing","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeCompactTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the "},{"code":"Orange Compact","type":"codeVoice"},{"type":"text","text":" theme, you just need to use the theme object as is."}]},{"type":"heading","text":"Tunable theme","level":2,"anchor":"Tunable-theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be tuned with "},{"code":"Tuning","type":"codeVoice"},{"type":"text","text":" object to give at init."},{"type":"text","text":" "},{"type":"text","text":"Some tuning object exists."}]},{"type":"codeListing","code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","\/\/ Apply it to your theme","let theme = OrangeCompactTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A default tuning is applied for this theme:"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Tunable elements","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default values","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"rounded corners buttons","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"❌ false","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"rounded corners text inputs","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"✅ true","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"rounded corners alert messages","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"❌ false","type":"text"}]}]]]},{"type":"heading","text":"Typography","level":2,"anchor":"Typography"},{"type":"heading","text":"Helvetica Neue","level":3,"anchor":"Helvetica-Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange theme uses "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":" typography. This font is already available through iOS."},{"type":"text","text":" "},{"type":"text","text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens."}]},{"type":"codeListing","code":["\/\/ The three following instanciations are the same","let theme = OrangeCompactTheme()","let theme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"syntax":"swift"},{"type":"heading","text":"Other fonts","level":3,"anchor":"Other-fonts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init."}]},{"type":"codeListing","code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeCompactTheme(family: theFontFamilyNameInPostScript)"],"syntax":"swift"},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Specific rules to compute PostScript value are defined in ","type":"text"},{"type":"codeVoice","code":"PostScriptFontNamesMap.swift"}]}],"style":"note"},{"type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"If your font family is not well managed, you can ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","isActive":true}]}],"style":"tip"},{"type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"For production products and official tools, ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":" is preferred and should be used","type":"text"}]}],"style":"important"},{"type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","isActive":true}]}],"style":"tip"},{"type":"aside","name":"Caution","content":[{"type":"paragraph","inlineContent":[{"text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps","type":"text"}]}],"style":"note"},{"type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)","type":"text"}]}],"style":"important"},{"type":"heading","text":"How to enrich the theme","level":2,"anchor":"How-to-enrich-the-theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You cannot 