{"variants":[{"paths":["\/documentation\/oudsthemesorangecompact"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact","interfaceLanguage":"swift"},"hierarchy":{"paths":[[]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"],"title":"Group","anchor":"Group"},{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorChartSemanticTokensProvider","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactThemeColorDecorativeSemanticTokensProvider"],"anchor":"Classes","title":"Classes","generated":true},{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/Foundation","doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/SwiftUICore"],"anchor":"Extended-Modules","title":"Extended Modules","generated":true}],"sections":[],"metadata":{"roleHeading":"Library","role":"collection","modules":[{"name":"Theme Orange Compact"}],"externalID":"OUDSThemesOrangeCompact","title":"Theme Orange Compact","symbolKind":"module","images":[{"type":"icon","identifier":"ic_theme_orangecompact.png"}]},"kind":"symbol","abstract":[{"text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"code":["🧬 Theme version: 2.5.0"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this theme exists.","type":"text"}],"type":"paragraph"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme is related to Orange theme module to use some raw tokens of colors."}]}],"style":"note","type":"aside"},{"name":"Note","content":[{"inlineContent":[{"text":"It contains also colors dedicated to charts.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside"},{"name":"Important","content":[{"inlineContent":[{"type":"text","text":"The Orange Compact theme is read only: it cannot be suclassed or derivated."}],"type":"paragraph"}],"style":"important","type":"aside"},{"text":"How to use the theme","level":2,"anchor":"How-to-use-the-theme","type":"heading"},{"inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true},{"type":"text","text":" directly. To use the "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true},{"type":"text","text":" without further modifications, you will have to use the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" for your root view and give it an instance of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","isActive":true,"type":"reference"},{"text":". Keep in mind the themes are ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift class objects"}],"type":"emphasis"},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeCompactTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the "},{"code":"Orange Compact","type":"codeVoice"},{"type":"text","text":" theme, you just need to use the theme object as is."}]},{"type":"heading","level":2,"text":"Tunable theme","anchor":"Tunable-theme"},{"type":"paragraph","inlineContent":[{"text":"The theme can be tuned with ","type":"text"},{"type":"codeVoice","code":"Tuning"},{"text":" object to give at init.","type":"text"},{"text":" ","type":"text"},{"text":"Some tuning object exists.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","\/\/ Apply it to your theme","let theme = OrangeCompactTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A default tuning is applied for this theme:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Tunable elements","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default values","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"rounded corners buttons","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"❌ false"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"rounded corners text inputs","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"✅ true","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"rounded corners alert messages","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"❌ false"}]}]]]},{"level":2,"type":"heading","anchor":"Typography","text":"Typography"},{"level":3,"type":"heading","anchor":"Helvetica-Neue","text":"Helvetica Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange theme uses "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" typography. This font is already available through iOS."},{"type":"text","text":" "},{"type":"text","text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens."}]},{"code":["\/\/ The three following instanciations are the same","let theme = OrangeCompactTheme()","let theme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"Other-fonts","text":"Other fonts"},{"type":"paragraph","inlineContent":[{"text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init.","type":"text"}]},{"code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeCompactTheme(family: theFontFamilyNameInPostScript)"],"type":"codeListing","syntax":"swift"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Specific rules to compute PostScript value are defined in "},{"type":"codeVoice","code":"PostScriptFontNamesMap.swift"}],"type":"paragraph"}]},{"name":"Tip","type":"aside","style":"tip","content":[{"inlineContent":[{"type":"text","text":"If your font family is not well managed, you can "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues"}],"type":"paragraph"}]},{"name":"Important","type":"aside","style":"important","content":[{"inlineContent":[{"type":"text","text":"For production products and official tools, "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":" is preferred and should be used"}],"type":"paragraph"}]},{"name":"Tip","type":"aside","style":"tip","content":[{"type":"paragraph","inlineContent":[{"text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions"}]}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps"}]}],"name":"Caution","style":"note"},{"type":"aside","content":[{"inlineContent":[{"text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)","type":"text"}],"type":"paragraph"}],"name":"Important","style":"important"},{"text":"How to enrich the theme","type":"heading","anchor":"How-to-enrich-the-theme","level":2},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Orange Compact","type":"text"}]},{"text":" theme.","type":"text"}]},{"text":"How it looks like","type":"heading","anchor":"How-it-looks-like","level":2},{"text":"Actions","type":"heading","anchor":"Actions","level":3},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_OrangeCompact.png","type":"image"}]},{"text":"Content display","type":"heading","anchor":"Content-display","level":3},{"text":"Bullet list","type":"heading","anchor":"Bullet-list","level":4},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_bul