up of all "},{"type":"strong","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":" related to "},{"type":"strong","inlineContent":[{"text":"colors mode","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Values are defined in "},{"type":"emphasis","inlineContent":[{"text":"ColorModeRawTokens+Values.swift","type":"text"}]},{"type":"text","text":" file and not generated by the tokenator, as frozen values."},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ColorModeRawTokens"},{"type":"text","text":" are tokens to use to define "},{"type":"emphasis","inlineContent":[{"text":"color mode","type":"text"}]},{"type":"text","text":" of components, i.e. if a component or something must be considered"},{"type":"text","text":" "},{"type":"text","text":"in light or dark color scheme, or in monochrome mode."},{"type":"text","text":" "},{"type":"text","text":"Primitive types such as  "},{"type":"codeVoice","code":"String"},{"type":"text","text":" must be used to as to allow to use "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" keywords in extensions for overriding."},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"type":"emphasis","inlineContent":[{"text":"Swift enum","type":"text"}]},{"type":"text","text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than "},{"type":"emphasis","inlineContent":[{"text":"struct","type":"text"}]},{"type":"text","text":"."}],"kind":"symbol","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ColorModeRawTokens","title":"ColorModeRawTokens","url":"\/documentation\/oudstokensraw\/colormoderawtokens"}}}