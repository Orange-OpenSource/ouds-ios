s"},{"type":"text","text":" and the "},{"inlineContent":[{"text":"Y offset","type":"text"}],"type":"emphasis"},{"type":"text","text":", all of them being "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawToken"},{"type":"text","text":" type."},{"type":"text","text":" "},{"type":"text","text":"Combinations of these three values can be defined inside "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken"},{"type":"text","text":" i.e. "},{"inlineContent":[{"type":"text","text":"composite tokens"}],"type":"emphasis"},{"type":"text","text":" defining a whil box shadow to use for elevation effect."}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawTokens","type":"topic","kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationRawTokens","kind":"identifier"}],"navigatorTitle":[{"text":"ElevationRawTokens","kind":"identifier"}],"title":"ElevationRawTokens","role":"symbol"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationCompositeRawToken":{"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","title":"ElevationCompositeRawToken","navigatorTitle":[{"text":"ElevationCompositeRawToken","kind":"identifier"}],"url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken","type":"topic","abstract":[{"text":"In the ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" global design system, composite tokens are defined for elevation effects.","type":"text"},{"text":" ","type":"text"},{"text":"Composite tokens are tokens defined in ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" by other tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Here an ","type":"text"},{"inlineContent":[{"text":"elevation","type":"text"}],"type":"emphasis"},{"text":" is caracterized by ","type":"text"},{"inlineContent":[{"text":"X and Y offsets","type":"text"}],"type":"emphasis"},{"text":", a ","type":"text"},{"inlineContent":[{"type":"text","text":"radius"}],"type":"emphasis"},{"text":" for the shadow and a ","type":"text"},{"inlineContent":[{"type":"text","text":"color"}],"type":"emphasis"},{"text":" to apply on that shadow.","type":"text"},{"text":" ","type":"text"},{"text":"All these elements are ","type":"text"},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"text":", and together define a ","type":"text"},{"inlineContent":[{"type":"text","text":"composite raw token"}],"type":"emphasis"},{"text":" for ","type":"text"},{"inlineContent":[{"text":"elevation","type":"text"}],"type":"emphasis"},{"text":" effect.","type":"text"},{"text":" ","type":"text"},{"text":"It is defined as a ","type":"text"},{"code":"final class","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"NSObject","type":"codeVoice"},{"text":" so as to be shared through ","type":"text"},{"code":"@objc","type":"codeVoice"},{"text":" with extensions and protocols within modules.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationCompositeRawToken","kind":"identifier"}]},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationRawTokens/y600":{"abstract":[{"type":"text","text":"Has for value 20"}],"kind":"symbol","url":"\/documentation\/oudstokensraw\/elevationrawtokens\/y600","title":"y600","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawTokens\/y600","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"y600","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ElevationRawToken","kind":"typeIdentifier","preciseIdentifier":"s:13OUDSTokensRaw09ElevationB5Tokena"}],"type":"topic","