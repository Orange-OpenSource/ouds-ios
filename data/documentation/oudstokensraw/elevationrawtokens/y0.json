ntent":[{"type":"text","text":"ElevationRawTokens+Values.swift"}]},{"type":"text","text":" file updated by the tokenator and "},{"type":"emphasis","inlineContent":[{"text":"ElevationRawTokens+Values.swift","type":"text"}]},{"type":"text","text":" updated manualy by the development team."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawTokens","type":"reference","isActive":true},{"type":"text","text":" are tokens to use to define "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevations"}]},{"type":"text","text":" , i.e. in the end box shadow effects."},{"type":"text","text":" "},{"type":"text","text":"These tokens are used to define these effects thanks to several types: the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"blur"}]},{"type":"text","text":", the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"X offset"}]},{"type":"text","text":" and the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Y offset"}]},{"type":"text","text":", all of them being "},{"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawToken","type":"reference","isActive":true},{"type":"text","text":" type."},{"type":"text","text":" "},{"type":"text","text":"Combinations of these three values can be defined inside "},{"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","type":"reference","isActive":true},{"type":"text","text":" i.e. "},{"type":"emphasis","inlineContent":[{"text":"composite tokens","type":"text"}]},{"type":"text","text":" defining a whil box shadow to use for elevation effect."}],"kind":"symbol","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawTokens","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationRawTokens"}],"type":"topic","title":"ElevationRawTokens"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/