type":"text","text":"color"}]},{"text":" to apply on that shadow.","type":"text"},{"text":" ","type":"text"},{"text":"All these elements are ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":", and together define a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite raw token"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"text":"elevation","type":"text"}]},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"type":"codeVoice","code":"final class"},{"type":"text","text":" and "},{"type":"codeVoice","code":"NSObject"},{"type":"text","text":" so as to be shared through "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" with extensions and protocols within modules."}],"type":"topic","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken"}}}