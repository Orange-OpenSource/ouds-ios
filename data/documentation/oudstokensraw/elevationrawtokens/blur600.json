s assigned to the ","type":"text"},{"inlineContent":[{"text":"components","type":"text"}],"type":"emphasis"},{"text":" properties.","type":"text"}],"role":"collection","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw","url":"\/documentation\/oudstokensraw","images":[{"identifier":"ic_design_token_figma_raw.png","type":"icon"}],"kind":"symbol","title":"Tokens with raw values"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationRawTokens/blur600":{"role":"symbol","url":"\/documentation\/oudstokensraw\/elevationrawtokens\/blur600","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"blur600","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:13OUDSTokensRaw09ElevationB5Tokena","text":"ElevationRawToken","kind":"typeIdentifier"}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawTokens\/blur600","title":"blur600","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Has for value 12"}]},"ic_design_token_figma_raw.png":{"type":"image","variants":[{"url":"\/images\/OUDSTokensRaw\/ic_design_token_figma_raw.png","traits":["1x","light"]}],"identifier":"ic_design_token_figma_raw.png","alt":null},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationCompositeRawToken":{"role":"symbol","url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationCompositeRawToken"}],"title":"ElevationCompositeRawToken","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"In the "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" global design system, composite tokens are defined for elevation effects."},{"type":"text","text":" "},{"type":"text","text":"Composite tokens are tokens defined in "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here an "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" is caracterized by "},{"inlineContent":[{"type":"text","text":"X and Y offsets"}],"type":"emphasis"},{"type":"text","text":", a "},{"inlineContent":[{"type":"text","text":"radius"}],"type":"emphasis"},{"type":"text","text":" for the shadow and a "},{"inlineContent":[{"type":"text","text":"color"}],"type":"emphasis"},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"inlineContent":[{"type":"text","text":"raw tokens"}],"type":"emphasis"},{"type":"text","text":", and together define a "},{"inlineContent":[{"type":"text","text":"composite raw token"}],"type":"emphasis"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"code":"final class","type":"codeVoice"},{"type":"text","text":" and "},{"code":"NSObject","type":"codeVoice"},{"type":"text","text":" so as to be shared through "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" with extensions and protocols within modules."}],"navigatorTitle":[{"kind":"identifier","text":"ElevationCompositeRawToken"}]},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationRawToken":{"role":"symbol","url":"\/documentation\/oudstokensraw\/elevationrawtoken","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationRawToken","kind":"identifier"}],"title":"ElevationRawToken","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawToken","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Type aliases precising "},{"code":"CGFloat","type":"codeVoice"},{"type":"text","text":" values are used (because used in "},{"inlineContent":[{"type":"text","text":"SwiftUI"}],"type":"emphasis"},{"type":"text","text":" API) for each "},{"inlineContent":[{"type":"text","text":"elevation raw token"}],"type":"strong"},{"type":"text","text":", to keep grammar clean and clear with design system grammar."}],"navigatorTitle":[{"text":"ElevationRawToken","kind":"identifier"}]},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationRawTokens":{"role":"symbol","url":"\/documentation\/oudstokensraw\/elevationrawtokens","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationRawTokens","kind":"identifier"}],"title":"ElevationRawTokens","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawTokens","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Defined as the group of all "},{"type":"strong","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":" related to "},{"type":"strong","inlineContent":[{"text":"elevations","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawTokens","type":"reference","isActive":true},{"type":"text","text":" are tokens to use to define "},{"type":"emphasis","inlineContent":[{"text":"elevations","type":"text"}]},{"type":"text","text":" , i.e. in the end box shadow effects."},{"type":"text","text":" "},{"type":"text","text":"These tokens are used to define these effects thanks to several types: the "},{"type":"emphasis","inlineContent":[{"text":"blur","type":"text"}]},{"type":"text","text":", the "},{"type":"emphasis","inlineContent":[{"text":"X offset","type":"text"}]},{"type":"text","text":" and the "},{"type":"emphasis","inlineContent":[{"text":"Y offset","type":"text"}]},{"type":"text","text":", all of them being "},{"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawToken","type":"reference","isActive":true},{"type":"text","text":" type."},{"type":"text","text":" "},{"type":"text","text":"Combinations of these three values can be defined inside "},{"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","type":"reference","isActive":true},{"type":"text","text":" i.e. "},{"type":"emphasis","inlineContent":[{"text":"composite tokens","type":"text"}]},{"type":"text","text":" defining a whil box shadow to use for elevation effect."}],"navigatorTitle":[{"text":"ElevationRawTokens","kind":"identifier"}]}}}