{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","identifier":{"url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","interfaceLanguage":"swift"},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"type":"inheritsFrom","title":"Inherits From"},{"kind":"relationships","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/SQ","doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"],"type":"conformsTo","title":"Conforms To"}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"]]},"topicSections":[{"anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)"],"title":"Initializers"},{"anchor":"Type-Properties","generated":true,"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/name"],"title":"Type Properties"}],"metadata":{"modules":[{"name":"Theme Orange Compact"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"externalID":"s:23OUDSThemesOrangeCompact0bC5ThemeC","navigatorTitle":[{"kind":"identifier","text":"OrangeCompactTheme"}],"role":"symbol","title":"OrangeCompactTheme","symbolKind":"class","roleHeading":"Class"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangecompact\/orangecompacttheme"]}],"abstract":[{"type":"text","text":"The "},{"code":"Orange Compact","type":"codeVoice"},{"type":"text","text":" theme is an Orange theme but tailored for some products with heavy UI."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"Usages","type":"heading","text":"Usages"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if"},{"type":"text","text":" "},{"type":"text","text":"these products must be Orange flavored."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this team is created: a kind of "},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":" but wih adjustments on some tokens like spacings and sizings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the theme:"}]},{"code":["    @Environment(\\.theme) var theme"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Integration","type":"heading","text":"Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" and get it through environment variable."}]},{"code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeCompactTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Theme-tuning","type":"heading","text":"Theme tuning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To apply the tuning:"}]},{"code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false)","","    \/\/ Apply it to your theme","    let theme = OrangeCompactTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Typography","type":"heading","text":"Typography"},{"level":3,"anchor":"Helvetica-Neue","type":"heading","text":"Helvetica Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange brand strongly relies on the "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"type":"codeVoice","code":"OrangeCompactTheme"},{"type":"text","text":" uses as font family the token "},{"type":"codeVoice","code":"OrangeBrandFontRawTokens.familyBrandDefault"},{"type":"text","text":", which is today "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use another font family, you will have to send the suitable token or the suitable font family.","type":"text"},{"text":" ","type":"text"},{"text":"However, beware, iOS API relies also on the PostScript name of the font.","type":"text"},{"text":" ","type":"text"},{"text":"To be sure of the value to use, look at the font book of your device.","type":"text"},{"text":" ","type":"text"},{"text":"It is recommended to use the font raw tokens.","type":"text"}]},{"code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeCompactTheme()","    let orangeTheme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Helvetica-Neue-Arabic","type":"heading","text":"Helvetica Neue Arabic"},{"type":"paragraph","inlineContent":[{"text":"Because the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue Arabic","type":"text"}]},{"type":"text","text":". This font family assets can be retrieved through the "},{"isActive":true,"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"register them and define the font family name to use."}]},{"code":["    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue Arabic\")"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Tokens-versions","type":"heading","text":"Tokens versions"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Core OUDS version: 1.10.0"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Core Orange version: 1.2.0","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Brand Orange Compact version: 2.5.0"}],"type":"paragraph"}]}],"type":"unorderedList"},{"name":"Since","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"0.17.0"}],"type":"paragraph"}]}]}],"references":{"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme/init(fontFamily:tuning:)":{"url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme\/init(fontfamily:tuning:)","role":"symbol","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)","type":"topic","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"fontFamily"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","text":"FontFamilySemanticToken"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tuning"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","text":"Tuning"},{"kind":"text","text":")"}],"title":"init(fontFamily:tuning:)","kind":"symbol","abstract":[{"type":"text","text":"Constructor of the OrangeCompact theme with its own providers of tokens."},{"type":"text","text":" "},{"type":"text","text":"It uses also the providers of charts colors from Orange theme ("},{"type":"codeVoice","code":"OrangeThemeColorChartSemanticTokensProvider"},{"type":"text","text":")."}]},"doc://OUDSThemesOrangeCompact/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact":{"abstract":[{"type":"text","text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints."}],"role":"collection","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact","type":"topic","images":[{"type":"icon","identifier":"ic_theme_orangecompact.png"}],"title":"Theme Orange Compact","kind":"symbol","url":"\/documentation\/oudsthemesorangecompact"},"doc://OUDSThemesOrangeCompact/SQ":{"type":"unresolvable","title":"Swift.Equatable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/SQ"},"doc://OUDSThemesOrangeCompact/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s8SendableP"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme":{"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeCompactTheme"}],"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme","type":"topic","navigatorTitle":[{"kind":"identifier","text":"OrangeCompactTheme"}],"abstract":[{"type":"text","text":"The "},{"code":"Orange Compact","type":"codeVoice"},{"type":"text","text":" theme is an Orange theme but tailored for some products with heavy UI."}],"title":"OrangeCompactTheme","role":"symbol"},"https://brand.orange.com/en/brand-basics/typography":{"type":"link","title":"Orange Brand website (authentication needed)","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"topic","url":"\/documentation\/oudsthemescontract\/oudstheme","navigatorTitle":[{"kind":"identifier","text":"OUDSTheme"}],"abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"title":"OUDSTheme","role":"symbol"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme/name":{"url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme\/name","role":"symbol","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/name","type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"name"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}],"title":"name","kind":"symbol","abstract":[{"type":"text","text":"The theme name (“Orange Compact”)"}]},"ic_theme_orangecompact.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrangeCompact\/ic_theme_orangecompact.png"}],"alt":null,"type":"image","identifier":"ic_theme_orangecompact.png"}}}