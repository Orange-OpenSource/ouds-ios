{"topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)"],"title":"Initializers","anchor":"Initializers","generated":true}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"type":"inheritsFrom","title":"Inherits From","kind":"relationships"},{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/SQ","doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"variants":[{"paths":["\/documentation\/oudsthemesorangecompact\/orangecompacttheme"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Orange Compact"},{"type":"text","text":" theme is an Orange theme but tailored for some products with heavy UI."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeCompactTheme"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Usages","anchor":"Usages"},{"inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if","type":"text"},{"text":" ","type":"text"},{"text":"these products must be Orange flavored.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this team is created: a kind of ","type":"text"},{"code":"OrangeTheme","type":"codeVoice"},{"text":" but wih adjustments on some tokens like spacings and sizings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To get the theme:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.theme) var theme"]},{"level":2,"type":"heading","text":"Integration","anchor":"Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" and get it through environment variable.","type":"text"}]},{"type":"codeListing","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeCompactTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"syntax":"swift"},{"level":2,"type":"heading","anchor":"Theme-tuning","text":"Theme tuning"},{"type":"paragraph","inlineContent":[{"text":"The theme can be customized a bit for more flexibility thanks to ","type":"text"},{"type":"codeVoice","code":"Tuning"},{"text":" object.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"inlineContent":[{"type":"text","text":"To apply the tuning:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false)","","    \/\/ Apply it to your theme","    let theme = OrangeCompactTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"]},{"text":"Typography","type":"heading","level":2,"anchor":"Typography"},{"level":3,"text":"Helvetica Neue","anchor":"Helvetica-Neue","type":"heading"},{"inlineContent":[{"type":"text","text":"The Orange brand strongly relies on the "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":" font family. Thus each Orange brand should, or must, use it."},{"type":"text","text":" "},{"type":"text","text":"For iOS the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"code":"OrangeCompactTheme","type":"codeVoice"},{"type":"text","text":" uses as font family the token "},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"type":"text","text":", which is today "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"text":"However, beware, iOS API relies also on the PostScript name of the font.","type":"text"},{"text":" ","type":"text"},{"text":"To be sure of the value to use, look at the font book of your device.","type":"text"},{"text":" ","type":"text"},{"text":"It is recommended to use the font raw tokens.","type":"text"}],"type":"paragraph"},{"code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeCompactTheme()","    let orangeTheme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Helvetica-Neue-Arabic","level":3,"text":"Helvetica Neue Arabic"},{"inlineContent":[{"type":"text","text":"Because the "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}],"type":"emphasis"},{"text":". This font family assets can be retrieved through the ","type":"text"},{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}],"type":"paragraph"},{"type":"codeListing","code":["    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue Arabic\")"],"syntax":"swift"},{"type":"heading","text":"Tokens versions","anchor":"Tokens-versions","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Core OUDS version: 1.10.0"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Core Orange version: 1.2.0","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Brand Orange Compact version: 2.5.0"}],"type":"paragraph"}]}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.17.0","type":"text"}]}],"style":"note","name":"Since"}]}],"identifier":{"url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"]]},"metadata":{"externalID":"s:23OUDSThemesOrangeCompact0bC5ThemeC","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"OrangeCompactTheme","kind":"identifier"}],"modules":[{"name":"Theme Orange Compact"}],"title":"OrangeCompactTheme","roleHeading":"Class","role":"symbol","navigatorTitle":[{"text":"OrangeCompactTheme","kind":"identifier"}],"symbolKind":"class"},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"references":{"doc://OUDSThemesOrangeCompact/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"https://brand.orange.com/en/brand-basics/typography":{"titleInlineContent":[{"text":"Orange Brand website (authentication needed)","type":"text"}],"type":"link","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","title":"Orange Brand website (authentication needed)","url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"text":"A Swift ","type":"text"},{"type":"codeVoice","code":"class"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"type":"text","text":", or "},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"title":"OUDSTheme","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSTheme"}],"kind":"symbol"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact":{"title":"Theme Orange Compact","url":"\/documentation\/oudsthemesorangecompact","images":[{"type":"icon","identifier":"ic_theme_orangecompact.png"}],"type":"topic","abstract":[{"type":"text","text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints."}],"kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme":{"kind":"symbol","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","title":"OrangeCompactTheme","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Orange Compact"},{"type":"text","text":" theme is an Orange theme but tailored for some products with heavy UI."}],"type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeCompactTheme"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeCompactTheme"}]},"ic_theme_orangecompact.png":{"type":"image","identifier":"ic_theme_orangecompact.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrangeCompact\/ic_theme_orangecompact.png"}]},"doc://OUDSThemesOrangeCompact/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","title":"Swift.Sendable"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme/init(fontFamily:tuning:)":{"kind":"symbol","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme\/init(fontfamily:tuning:)","title":"init(fontFamily:tuning:)","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)","abstract":[{"type":"text","text":"Constructor of the OrangeCompact theme with its own providers of tokens."},{"type":"text","text":" "},{"type":"text","text":"It uses also the providers of charts colors from Orange theme ("},{"type":"codeVoice","code":"OrangeThemeColorChartSemanticTokensProvider"},{"type":"text","text":")."}],"type":"topic","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"fontFamily","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FontFamilySemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena"},{"text":"?, ","kind":"text"},{"text":"tuning","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Tuning","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract6Tuninga"},{"text":")","kind":"text"}]},"doc://OUDSThemesOrangeCompact/SQ":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/SQ","title":"Swift.Equatable"}}