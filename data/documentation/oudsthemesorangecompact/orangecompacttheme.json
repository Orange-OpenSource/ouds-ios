{"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"Orange Compact"},{"text":" theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"sections":[],"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)"]}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"type":"inheritsFrom","title":"Inherits From","kind":"relationships"},{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/SQ","doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangecompact\/orangecompacttheme"]}],"metadata":{"symbolKind":"class","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"modules":[{"name":"Theme Orange Compact"}],"externalID":"s:23OUDSThemesOrangeCompact0bC5ThemeC","title":"OrangeCompactTheme","navigatorTitle":[{"text":"OrangeCompactTheme","kind":"identifier"}],"roleHeading":"Class"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeCompactTheme"}]}],"kind":"declarations"},{"content":[{"text":"Usages","anchor":"Usages","type":"heading","level":2},{"inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if","type":"text"},{"text":" ","type":"text"},{"text":"these products must be Orange flavored.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this team is created: a kind of ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"text":" but wih adjustments on some tokens like spacings and sizings.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To get the theme:","type":"text"}]},{"syntax":"swift","code":["    @Environment(\\.theme) var theme"],"type":"codeListing"},{"text":"Integration","anchor":"Integration","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" and get it through environment variable."}]},{"syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeCompactTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing"},{"text":"Theme tuning","anchor":"Theme-tuning","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"code":"Tuning","type":"codeVoice"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"text":"To apply the tuning:","type":"text"}]},{"syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false)","","    \/\/ Apply it to your theme","    let theme = OrangeCompactTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"type":"codeListing"},{"text":"Typography","anchor":"Typography","type":"heading","level":2},{"text":"Helvetica Neue","anchor":"Helvetica-Neue","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"type":"codeVoice","code":"OrangeCompactTheme"},{"type":"text","text":" uses as font family the token "},{"type":"codeVoice","code":"OrangeBrandFontRawTokens.familyBrandDefault"},{"type":"text","text":", which is today "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeCompactTheme()","    let orangeTheme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"syntax":"swift","type":"codeListing"},{"text":"Helvetica Neue Arabic","anchor":"Helvetica-Neue-Arabic","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Because the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}]},{"type":"text","text":". This font family assets can be retrieved through the "},{"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}],"type":"paragraph"},{"code":["    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue Arabic\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Tokens-versions","level":2,"text":"Tokens versions","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"Core OUDS version: 1.9.0","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Core Orange version: 1.2.0","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Brand Orange Compact version: 2.3.0","type":"text"}]}]}],"type":"unorderedList"},{"style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.17.0","type":"text"}]}],"type":"aside"}],"kind":"content"}],"identifier":{"url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"]]},"kind":"symbol","references":{"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme":{"abstract":[{"type":"text","text":"The "},{"code":"Orange Compact","type":"codeVoice"},{"type":"text","text":" theme is an Orange theme but tailored for some products with heavy UI."}],"url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme","type":"topic","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeCompactTheme"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeCompactTheme"}],"title":"OrangeCompactTheme","role":"symbol","kind":"symbol"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact":{"images":[{"identifier":"ic_theme_orangecompact.png","type":"icon"}],"title":"Theme Orange Compact","kind":"symbol","type":"topic","role":"collection","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact","url":"\/documentation\/oudsthemesorangecompact","abstract":[{"type":"text","text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints."}]},"https://brand.orange.com/en/brand-basics/typography":{"type":"link","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","title":"Orange Brand website (authentication needed)","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}],"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"type":"codeVoice","code":"class"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"text":", or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" is not a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"kind":"symbol","url":"\/documentation\/oudsthemescontract\/oudstheme","title":"OUDSTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","role":"symbol"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme/init(fontFamily:tuning:)":{"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"fontFamily","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","text":"FontFamilySemanticToken","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"tuning","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract6Tuninga","text":"Tuning","kind":"typeIdentifier"},{"text":")","kind":"text"}],"abstract":[{"type":"text","text":"Constructor of the OrangeCompact theme with its own providers of tokens."},{"type":"text","text":" "},{"type":"text","text":"It uses also the providers of charts colors from Orange theme ("},{"code":"OrangeThemeColorChartSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"type":"topic","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme\/init(fontfamily:tuning:)","title":"init(fontFamily:tuning:)","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)"},"ic_theme_orangecompact.png":{"identifier":"ic_theme_orangecompact.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrangeCompact\/ic_theme_orangecompact.png"}],"type":"image","alt":null},"doc://OUDSThemesOrangeCompact/s8SendableP":{"title":"Swift.Sendable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","type":"unresolvable"},"doc://OUDSThemesOrangeCompact/SQ":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/SQ","type":"unresolvable","title":"Swift.Equatable"},"doc://OUDSThemesOrangeCompact/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP","type":"unresolvable"}}}