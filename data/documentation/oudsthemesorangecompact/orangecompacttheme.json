{"sections":[],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)"],"title":"Initializers","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangecompact\/orangecompacttheme"]}],"abstract":[{"text":"The ","type":"text"},{"code":"Orange Compact","type":"codeVoice"},{"text":" theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"metadata":{"roleHeading":"Class","role":"symbol","navigatorTitle":[{"text":"OrangeCompactTheme","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"symbolKind":"class","title":"OrangeCompactTheme","externalID":"s:23OUDSThemesOrangeCompact0bC5ThemeC","modules":[{"name":"Theme Orange Compact"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"Usages","level":2,"text":"Usages","type":"heading"},{"inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if","type":"text"},{"text":" ","type":"text"},{"text":"these products must be Orange flavored.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this team is created: a kind of ","type":"text"},{"code":"OrangeTheme","type":"codeVoice"},{"text":" but wih adjustments on some tokens like spacings and sizings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To get the theme:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.theme) var theme"],"type":"codeListing"},{"anchor":"Integration","level":2,"text":"Integration","type":"heading"},{"inlineContent":[{"text":"To use this theme, inject it to your view using ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" and get it through environment variable.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeCompactTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing"},{"anchor":"Theme-tuning","level":2,"text":"Theme tuning","type":"heading"},{"inlineContent":[{"text":"The theme can be customized a bit for more flexibility thanks to ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object.","type":"text"},{"text":" ","type":"text"},{"text":"You just need to give a predefined tuning configuration at theme init to build the one you need.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To apply the tuning:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false)","","    \/\/ Apply it to your theme","    let theme = OrangeCompactTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"type":"codeListing"},{"anchor":"Typography","level":2,"text":"Typography","type":"heading"},{"anchor":"Helvetica-Neue","level":3,"text":"Helvetica Neue","type":"heading"},{"inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":" font family is available at system level, so it is not needed to get it through external assets.","type":"text"},{"text":" ","type":"text"},{"text":"By default an instance of ","type":"text"},{"code":"OrangeCompactTheme","type":"codeVoice"},{"text":" uses as font family the token ","type":"text"},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"text":", which is today ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use another font family, you will have to send the suitable token or the suitable font family.","type":"text"},{"text":" ","type":"text"},{"text":"However, beware, iOS API relies also on the PostScript name of the font.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeCompactTheme()","    let orangeTheme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"type":"codeListing"},{"anchor":"Helvetica-Neue-Arabic","level":3,"text":"Helvetica Neue Arabic","type":"heading"},{"inlineContent":[{"type":"text","text":"Because the "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}],"type":"emphasis"},{"text":". This font family assets can be retrieved through the ","type":"text"},{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,","type":"text"},{"text":" ","type":"text"},{"text":"register them and define the font family name to use.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue Arabic\")"],"type":"codeListing"},{"level":2,"text":"Tokens versions","anchor":"Tokens-versions","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Core OUDS version: 1.9.0"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Core Orange version: 1.2.0","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Brand Orange Compact version: 2.3.0","type":"text"}]}]}],"type":"unorderedList"},{"content":[{"type":"paragraph","inlineContent":[{"text":"0.17.0","type":"text"}]}],"name":"Since","type":"aside","style":"note"}]}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"kind":"relationships","title":"Inherits From","type":"inheritsFrom"},{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/SQ","doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"]]},"identifier":{"url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","interfaceLanguage":"swift"},"references":{"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact":{"type":"topic","role":"collection","abstract":[{"type":"text","text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints."}],"title":"Theme Orange Compact","images":[{"identifier":"ic_theme_orangecompact.png","type":"icon"}],"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact","url":"\/documentation\/oudsthemesorangecompact","kind":"symbol"},"https://brand.orange.com/en/brand-basics/typography":{"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"link","title":"Orange Brand website (authentication needed)","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","titleInlineContent":[{"text":"Orange Brand website (authentication needed)","type":"text"}]},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme/init(fontFamily:tuning:)":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme\/init(fontfamily:tuning:)","title":"init(fontFamily:tuning:)","type":"topic","kind":"symbol","abstract":[{"text":"Constructor of the OrangeCompact theme with its own providers of tokens.","type":"text"},{"text":" ","type":"text"},{"text":"It uses also the providers of charts colors from Orange theme (","type":"text"},{"code":"OrangeThemeColorChartSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"fontFamily"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"FontFamilySemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tuning"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Tuning","preciseIdentifier":"s:18OUDSThemesContract6Tuninga"},{"kind":"text","text":")"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference","isActive":true},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"title":"OUDSTheme","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","title":"OrangeCompactTheme","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme","kind":"symbol","abstract":[{"text":"The ","type":"text"},{"code":"Orange Compact","type":"codeVoice"},{"text":" theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeCompactTheme"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeCompactTheme"}]},"doc://OUDSThemesOrangeCompact/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"},"ic_theme_orangecompact.png":{"alt":null,"variants":[{"url":"\/images\/OUDSThemesOrangeCompact\/ic_theme_orangecompact.png","traits":["1x","light"]}],"type":"image","identifier":"ic_theme_orangecompact.png"},"doc://OUDSThemesOrangeCompact/SQ":{"type":"unresolvable","title":"Swift.Equatable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/SQ"},"doc://OUDSThemesOrangeCompact/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s8SendableP"}}}