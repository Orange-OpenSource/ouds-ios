{"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"navigatorTitle":[{"text":"OrangeCompactTheme","kind":"identifier"}],"modules":[{"name":"Theme Orange Compact"}],"roleHeading":"Class","symbolKind":"class","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"title":"OrangeCompactTheme","externalID":"s:23OUDSThemesOrangeCompact0bC5ThemeC"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"]]},"topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)"],"generated":true,"anchor":"Initializers","title":"Initializers"}],"identifier":{"url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangecompact\/orangecompacttheme"]}],"abstract":[{"text":"The ","type":"text"},{"code":"Orange Compact","type":"codeVoice"},{"text":" theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"]},{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/SQ","doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeCompactTheme"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"Usages","type":"heading","level":2,"text":"Usages"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if"},{"type":"text","text":" "},{"type":"text","text":"these products must be Orange flavored."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this team is created: a kind of "},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":" but wih adjustments on some tokens like spacings and sizings."}]},{"type":"paragraph","inlineContent":[{"text":"To get the theme:","type":"text"}]},{"syntax":"swift","code":["    @Environment(\\.theme) var theme"],"type":"codeListing"},{"anchor":"Integration","type":"heading","level":2,"text":"Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" and get it through environment variable.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeCompactTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"]},{"text":"Theme tuning","type":"heading","anchor":"Theme-tuning","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"code":"Tuning","type":"codeVoice"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To apply the tuning:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false)","","    \/\/ Apply it to your theme","    let theme = OrangeCompactTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"]},{"text":"Typography","type":"heading","anchor":"Typography","level":2},{"text":"Helvetica Neue","type":"heading","anchor":"Helvetica-Neue","level":3},{"type":"paragraph","inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":" font family is available at system level, so it is not needed to get it through external assets.","type":"text"},{"text":" ","type":"text"},{"text":"By default an instance of ","type":"text"},{"code":"OrangeCompactTheme","type":"codeVoice"},{"text":" uses as font family the token ","type":"text"},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"text":", which is today ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeCompactTheme()","    let orangeTheme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"]},{"type":"heading","level":3,"anchor":"Helvetica-Neue-Arabic","text":"Helvetica Neue Arabic"},{"type":"paragraph","inlineContent":[{"text":"Because the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}],"type":"emphasis"},{"text":". This font family assets can be retrieved through the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,","type":"text"},{"text":" ","type":"text"},{"text":"register them and define the font family name to use.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue Arabic\")"]},{"type":"heading","level":2,"anchor":"Tokens-versions","text":"Tokens versions"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Core OUDS version: 1.9.0"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Core Orange version: 1.2.0","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Brand Orange Compact version: 2.3.0","type":"text"}],"type":"paragraph"}]}]},{"style":"note","content":[{"inlineContent":[{"text":"0.17.0","type":"text"}],"type":"paragraph"}],"name":"Since","type":"aside"}],"kind":"content"}],"kind":"symbol","references":{"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"url":"\/documentation\/oudsthemescontract\/oudstheme","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","title":"OUDSTheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"code":"class","type":"codeVoice"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true,"type":"reference"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"role":"symbol"},"ic_theme_orangecompact.png":{"alt":null,"variants":[{"url":"\/images\/OUDSThemesOrangeCompact\/ic_theme_orangecompact.png","traits":["1x","light"]}],"type":"image","identifier":"ic_theme_orangecompact.png"},"doc://OUDSThemesOrangeCompact/SQ":{"title":"Swift.Equatable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/SQ","type":"unresolvable"},"doc://OUDSThemesOrangeCompact/s8SendableP":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"https://brand.orange.com/en/brand-basics/typography":{"type":"link","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","title":"Orange Brand website (authentication needed)","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}],"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},"doc://OUDSThemesOrangeCompact/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact":{"url":"\/documentation\/oudsthemesorangecompact","title":"Theme Orange Compact","abstract":[{"type":"text","text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints."}],"images":[{"type":"icon","identifier":"ic_theme_orangecompact.png"}],"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact","kind":"symbol","type":"topic","role":"collection"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme":{"title":"OrangeCompactTheme","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Orange Compact"},{"type":"text","text":" theme is an Orange theme but tailored for some products with heavy UI."}],"kind":"symbol","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeCompactTheme","kind":"identifier"}],"url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme","type":"topic"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme/init(fontFamily:tuning:)":{"type":"topic","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)","abstract":[{"type":"text","text":"Constructor of the OrangeCompact theme with its own providers of tokens."},{"type":"text","text":" "},{"type":"text","text":"It uses also the providers of charts colors from Orange theme ("},{"type":"codeVoice","code":"OrangeThemeColorChartSemanticTokensProvider"},{"type":"text","text":")."}],"url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme\/init(fontfamily:tuning:)","role":"symbol","title":"init(fontFamily:tuning:)","kind":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"fontFamily","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FontFamilySemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena"},{"text":"?, ","kind":"text"},{"text":"tuning","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Tuning","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract6Tuninga"},{"text":")","kind":"text"}]}}}