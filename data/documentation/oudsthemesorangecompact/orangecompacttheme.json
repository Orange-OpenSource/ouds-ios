{"identifier":{"url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","interfaceLanguage":"swift"},"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)"],"anchor":"Initializers","generated":true,"title":"Initializers"}],"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"kind":"relationships","title":"Inherits From"},{"type":"conformsTo","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/SQ","doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"],"kind":"relationships","title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeCompactTheme"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Usages","anchor":"Usages","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if"},{"type":"text","text":" "},{"type":"text","text":"these products must be Orange flavored."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this team is created: a kind of "},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":" but wih adjustments on some tokens like spacings and sizings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the theme:"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.theme) var theme"]},{"level":2,"anchor":"Integration","type":"heading","text":"Integration"},{"type":"paragraph","inlineContent":[{"text":"To use this theme, inject it to your view using ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" and get it through environment variable.","type":"text"}]},{"syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeCompactTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing"},{"level":2,"anchor":"Theme-tuning","type":"heading","text":"Theme tuning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"text":"To apply the tuning:","type":"text"}]},{"syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false)","","    \/\/ Apply it to your theme","    let theme = OrangeCompactTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"type":"codeListing"},{"level":2,"anchor":"Typography","type":"heading","text":"Typography"},{"level":3,"anchor":"Helvetica-Neue","type":"heading","text":"Helvetica Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange brand strongly relies on the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family. Thus each Orange brand should, or must, use it."},{"type":"text","text":" "},{"type":"text","text":"For iOS the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"type":"codeVoice","code":"OrangeCompactTheme"},{"type":"text","text":" uses as font family the token "},{"type":"codeVoice","code":"OrangeBrandFontRawTokens.familyBrandDefault"},{"type":"text","text":", which is today "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"type":"codeListing","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeCompactTheme()","    let orangeTheme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"syntax":"swift"},{"type":"heading","text":"Helvetica Neue Arabic","anchor":"Helvetica-Neue-Arabic","level":3},{"type":"paragraph","inlineContent":[{"text":"Because the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue Arabic","type":"text"}],"type":"emphasis"},{"text":". This font family assets can be retrieved through the ","type":"text"},{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,","type":"text"},{"text":" ","type":"text"},{"text":"register them and define the font family name to use.","type":"text"}]},{"type":"codeListing","code":["    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue Arabic\")"],"syntax":"swift"},{"type":"heading","text":"Tokens versions","anchor":"Tokens-versions","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Core OUDS version: 1.9.0"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Core Orange version: 1.2.0"}]}]},{"content":[{"inlineContent":[{"text":"Brand Orange Compact version: 2.3.0","type":"text"}],"type":"paragraph"}]}]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"text":"0.17.0","type":"text"}],"type":"paragraph"}]}]}],"metadata":{"symbolKind":"class","roleHeading":"Class","title":"OrangeCompactTheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeCompactTheme"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeCompactTheme"}],"role":"symbol","modules":[{"name":"Theme Orange Compact"}],"externalID":"s:23OUDSThemesOrangeCompact0bC5ThemeC"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"text":"The ","type":"text"},{"code":"Orange Compact","type":"codeVoice"},{"text":" theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangecompact\/orangecompacttheme"]}],"references":{"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact":{"title":"Theme Orange Compact","kind":"symbol","abstract":[{"text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints.","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact","type":"topic","role":"collection","images":[{"type":"icon","identifier":"ic_theme_orangecompact.png"}],"url":"\/documentation\/oudsthemesorangecompact"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"kind":"symbol","title":"OUDSTheme","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"type":"topic","role":"symbol","url":"\/documentation\/oudsthemescontract\/oudstheme"},"https://brand.orange.com/en/brand-basics/typography":{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","titleInlineContent":[{"text":"Orange Brand website (authentication needed)","type":"text"}],"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","title":"Orange Brand website (authentication needed)","type":"link"},"doc://OUDSThemesOrangeCompact/s8SendableP":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"doc://OUDSThemesOrangeCompact/SQ":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/SQ","title":"Swift.Equatable"},"doc://OUDSThemesOrangeCompact/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP","type":"unresolvable","title":"Swift.SendableMetatype"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme/init(fontFamily:tuning:)":{"title":"init(fontFamily:tuning:)","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)","role":"symbol","abstract":[{"type":"text","text":"Constructor of the OrangeCompact theme with its own providers of tokens."},{"type":"text","text":" "},{"type":"text","text":"It uses also the providers of charts colors from Orange theme ("},{"type":"codeVoice","code":"OrangeThemeColorChartSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"fontFamily","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","kind":"typeIdentifier","text":"FontFamilySemanticToken"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tuning"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","text":"Tuning"},{"kind":"text","text":")"}],"type":"topic","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme\/init(fontfamily:tuning:)","kind":"symbol"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme":{"title":"OrangeCompactTheme","kind":"symbol","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"Orange Compact"},{"text":" theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeCompactTheme"}],"url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme"},"ic_theme_orangecompact.png":{"type":"image","identifier":"ic_theme_orangecompact.png","alt":null,"variants":[{"url":"\/images\/OUDSThemesOrangeCompact\/ic_theme_orangecompact.png","traits":["1x","light"]}]}}}