{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangecompact\/orangecompacttheme"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Usages","anchor":"Usages"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if"},{"type":"text","text":" "},{"type":"text","text":"these products must be Orange flavored."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this team is created: a kind of "},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":" but wih adjustments on some tokens like spacings and sizings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the theme:"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.theme) var theme"]},{"type":"heading","level":2,"text":"Integration","anchor":"Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" and get it through environment variable."}]},{"type":"codeListing","syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeCompactTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"]},{"type":"heading","level":2,"text":"Theme tuning","anchor":"Theme-tuning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"code":"Tuning","type":"codeVoice"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To apply the tuning:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false)","","    \/\/ Apply it to your theme","    let theme = OrangeCompactTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"]},{"type":"heading","level":2,"text":"Typography","anchor":"Typography"},{"type":"heading","level":3,"text":"Helvetica Neue","anchor":"Helvetica-Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange brand strongly relies on the "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family. Thus each Orange brand should, or must, use it."},{"type":"text","text":" "},{"type":"text","text":"For iOS the "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"code":"OrangeCompactTheme","type":"codeVoice"},{"type":"text","text":" uses as font family the token "},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"type":"text","text":", which is today "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeCompactTheme()","    let orangeTheme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"]},{"type":"heading","level":3,"text":"Helvetica Neue Arabic","anchor":"Helvetica-Neue-Arabic"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}],"type":"emphasis"},{"type":"text","text":". This font family assets can be retrieved through the "},{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}]},{"type":"codeListing","syntax":"swift","code":["    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue Arabic\")"]},{"type":"heading","level":2,"text":"Tokens versions","anchor":"Tokens-versions"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Core OUDS version: 1.10.0","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Core Orange version: 1.2.0","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Brand Orange Compact version: 2.5.0","type":"text"}]}]}]},{"name":"Since","type":"aside","content":[{"inlineContent":[{"type":"text","text":"0.17.0"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"metadata":{"role":"symbol","modules":[{"name":"Theme Orange Compact"}],"externalID":"s:23OUDSThemesOrangeCompact0bC5ThemeC","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeCompactTheme","kind":"identifier"}],"title":"OrangeCompactTheme","roleHeading":"Class","symbolKind":"class"},"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"title":"Inherits From","kind":"relationships"},{"type":"conformsTo","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/SQ","doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"],"title":"Conforms To","kind":"relationships"}],"kind":"symbol","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Orange Compact"},{"type":"text","text":" theme is an Orange theme but tailored for some products with heavy UI."}],"topicSections":[{"anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)"],"title":"Initializers"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"},"references":{"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme":{"role":"symbol","type":"topic","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeCompactTheme","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"The ","type":"text"},{"code":"Orange Compact","type":"codeVoice"},{"text":" theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"title":"OrangeCompactTheme","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"},"doc://OUDSThemesOrangeCompact/SQ":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/SQ","type":"unresolvable","title":"Swift.Equatable"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact":{"type":"topic","kind":"symbol","title":"Theme Orange Compact","abstract":[{"text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints.","type":"text"}],"url":"\/documentation\/oudsthemesorangecompact","role":"collection","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact","images":[{"identifier":"ic_theme_orangecompact.png","type":"icon"}]},"https://brand.orange.com/en/brand-basics/typography":{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}],"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"link","title":"Orange Brand website (authentication needed)"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme/init(fontFamily:tuning:)":{"kind":"symbol","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme\/init(fontfamily:tuning:)","type":"topic","abstract":[{"text":"Constructor of the OrangeCompact theme with its own providers of tokens.","type":"text"},{"text":" ","type":"text"},{"text":"It uses also the providers of charts colors from Orange theme (","type":"text"},{"code":"OrangeThemeColorChartSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"fontFamily","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FontFamilySemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"tuning","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Tuning","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","kind":"typeIdentifier"},{"text":")","kind":"text"}],"role":"symbol","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)","title":"init(fontFamily:tuning:)"},"ic_theme_orangecompact.png":{"identifier":"ic_theme_orangecompact.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrangeCompact\/ic_theme_orangecompact.png"}],"type":"image","alt":null},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"role":"symbol","type":"topic","url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"title":"OUDSTheme","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},"doc://OUDSThemesOrangeCompact/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP","type":"unresolvable","title":"Swift.SendableMetatype"},"doc://OUDSThemesOrangeCompact/s8SendableP":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"}}}