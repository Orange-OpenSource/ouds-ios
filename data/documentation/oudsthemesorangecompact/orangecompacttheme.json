{"sections":[],"metadata":{"modules":[{"name":"Theme Orange Compact"}],"roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"title":"OrangeCompactTheme","externalID":"s:23OUDSThemesOrangeCompact0bC5ThemeC","navigatorTitle":[{"kind":"identifier","text":"OrangeCompactTheme"}],"symbolKind":"class","role":"symbol"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme"},"abstract":[{"type":"text","text":"The "},{"code":"Orange Compact","type":"codeVoice"},{"type":"text","text":" theme is an Orange theme but tailored for some products with heavy UI."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact"]]},"kind":"symbol","relationshipsSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"kind":"relationships","type":"inheritsFrom","title":"Inherits From"},{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/SQ","doc:\/\/OUDSThemesOrangeCompact\/s8SendableP","doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP"],"type":"conformsTo"}],"variants":[{"paths":["\/documentation\/oudsthemesorangecompact\/orangecompacttheme"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"final","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}]}]},{"content":[{"level":2,"anchor":"Usages","text":"Usages","type":"heading"},{"inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if"},{"type":"text","text":" "},{"type":"text","text":"these products must be Orange flavored."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this team is created: a kind of "},{"code":"OrangeTheme","type":"codeVoice"},{"text":" but wih adjustments on some tokens like spacings and sizings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To get the theme:"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.theme) var theme"],"type":"codeListing"},{"level":2,"anchor":"Integration","text":"Integration","type":"heading"},{"inlineContent":[{"text":"To use this theme, inject it to your view using ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" and get it through environment variable.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeCompactTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing"},{"anchor":"Theme-tuning","type":"heading","level":2,"text":"Theme tuning"},{"inlineContent":[{"text":"The theme can be customized a bit for more flexibility thanks to ","type":"text"},{"type":"codeVoice","code":"Tuning"},{"text":" object.","type":"text"},{"text":" ","type":"text"},{"text":"You just need to give a predefined tuning configuration at theme init to build the one you need.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To apply the tuning:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false)","","    \/\/ Apply it to your theme","    let theme = OrangeCompactTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeCompactTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: false))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeCompactTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeCompactTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeCompactTheme(tuning: Tuning.MaxIt)"],"type":"codeListing"},{"anchor":"Typography","type":"heading","level":2,"text":"Typography"},{"anchor":"Helvetica-Neue","type":"heading","level":3,"text":"Helvetica Neue"},{"inlineContent":[{"type":"text","text":"The Orange brand strongly relies on the "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":" font family. Thus each Orange brand should, or must, use it."},{"type":"text","text":" "},{"type":"text","text":"For iOS the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"type":"codeVoice","code":"OrangeCompactTheme"},{"type":"text","text":" uses as font family the token "},{"type":"codeVoice","code":"OrangeBrandFontRawTokens.familyBrandDefault"},{"type":"text","text":", which is today "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"If you want to use another font family, you will have to send the suitable token or the suitable font family.","type":"text"},{"text":" ","type":"text"},{"text":"However, beware, iOS API relies also on the PostScript name of the font.","type":"text"},{"text":" ","type":"text"},{"text":"To be sure of the value to use, look at the font book of your device.","type":"text"},{"text":" ","type":"text"},{"text":"It is recommended to use the font raw tokens.","type":"text"}],"type":"paragraph"},{"code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeCompactTheme()","    let orangeTheme = OrangeCompactTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeCompactTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue\")"],"type":"codeListing","syntax":"swift"},{"text":"Helvetica Neue Arabic","type":"heading","level":3,"anchor":"Helvetica-Neue-Arabic"},{"type":"paragraph","inlineContent":[{"text":"Because the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}]},{"text":". This font family assets can be retrieved through the ","type":"text"},{"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,","type":"text"},{"text":" ","type":"text"},{"text":"register them and define the font family name to use.","type":"text"}]},{"code":["    let orangeTheme = OrangeCompactTheme(fontFamily: \"Helvetica Neue Arabic\")"],"type":"codeListing","syntax":"swift"},{"text":"Tokens versions","type":"heading","level":2,"anchor":"Tokens-versions"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Core OUDS version: 1.10.0","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Core Orange version: 1.2.0","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Brand Orange Compact version: 2.5.0","type":"text"}],"type":"paragraph"}]}]},{"name":"Since","content":[{"inlineContent":[{"text":"0.17.0","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"}],"kind":"content"}],"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)"]}],"references":{"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"type":"topic","kind":"symbol","role":"symbol","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"type":"codeVoice","code":"class"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true,"type":"reference"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"text":", or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" is not a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"text":" class, its type cannot be seen as ","type":"text"},{"type":"codeVoice","code":"Sendable"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"title":"OUDSTheme","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}]},"https://brand.orange.com/en/brand-basics/typography":{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","title":"Orange Brand website (authentication needed)","type":"link","titleInlineContent":[{"text":"Orange Brand website (authentication needed)","type":"text"}],"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},"doc://OUDSThemesOrangeCompact/SQ":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/SQ","title":"Swift.Equatable","type":"unresolvable"},"doc://OUDSThemesOrangeCompact/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSThemesOrangeCompact\/s16SendableMetatypeP","title":"Swift.SendableMetatype","type":"unresolvable"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme/init(fontFamily:tuning:)":{"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"fontFamily","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","kind":"typeIdentifier","text":"FontFamilySemanticToken"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tuning"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Tuning","preciseIdentifier":"s:18OUDSThemesContract6Tuninga"},{"kind":"text","text":")"}],"title":"init(fontFamily:tuning:)","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme\/init(fontFamily:tuning:)","url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme\/init(fontfamily:tuning:)","abstract":[{"type":"text","text":"Constructor of the OrangeCompact theme with its own providers of tokens."},{"type":"text","text":" "},{"type":"text","text":"It uses also the providers of charts colors from Orange theme ("},{"type":"codeVoice","code":"OrangeThemeColorChartSemanticTokensProvider"},{"type":"text","text":")."}],"type":"topic","kind":"symbol","role":"symbol"},"doc://OUDSThemesOrangeCompact/s8SendableP":{"title":"Swift.Sendable","type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrangeCompact\/s8SendableP"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact/OrangeCompactTheme":{"type":"topic","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact\/OrangeCompactTheme","abstract":[{"text":"The ","type":"text"},{"code":"Orange Compact","type":"codeVoice"},{"text":" theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeCompactTheme","kind":"identifier"}],"kind":"symbol","title":"OrangeCompactTheme","navigatorTitle":[{"kind":"identifier","text":"OrangeCompactTheme"}],"url":"\/documentation\/oudsthemesorangecompact\/orangecompacttheme","role":"symbol"},"ic_theme_orangecompact.png":{"variants":[{"url":"\/images\/OUDSThemesOrangeCompact\/ic_theme_orangecompact.png","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"ic_theme_orangecompact.png"},"doc://OUDSThemesOrangeCompact/documentation/OUDSThemesOrangeCompact":{"role":"collection","identifier":"doc:\/\/OUDSThemesOrangeCompact\/documentation\/OUDSThemesOrangeCompact","type":"topic","title":"Theme Orange Compact","images":[{"identifier":"ic_theme_orangecompact.png","type":"icon"}],"kind":"symbol","abstract":[{"type":"text","text":"The Orange Compact theme is dedicated to applications with strong dimensions constraints."}],"url":"\/documentation\/oudsthemesorangecompact"}}}