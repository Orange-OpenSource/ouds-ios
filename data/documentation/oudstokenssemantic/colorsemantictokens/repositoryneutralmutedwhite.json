ifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorMultipleSemanticTokens"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If it possible a theme won’t have such semantic tokens of colors defined as not specified nor used in Figma."},{"type":"text","text":" "},{"type":"text","text":"Thus the value for these tokens will be “ouds-forbidden-color-value” as returned by the tokenator."},{"type":"text","text":" "},{"type":"text","text":"Thus if the token is still used, even if explained in the documentation it should not,"},{"type":"text","text":" "},{"type":"text","text":"this special value won’t be successfully parsed as color and the app will crash like expected."}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ColorSemanticTokens"}],"kind":"symbol","title":"ColorSemanticTokens","url":"\/documentation\/oudstokenssemantic\/colorsemantictokens","role":"symbol","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorSemanticTokens","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ColorSemanticTokens"}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ColorSemanticToken":{"kind":"symbol","url":"\/documentation\/oudstokenssemantic\/colorsemantictoken","type":"topic","abstract":[{"type":"text","text":"Basically a color semantic  token is a "},{"type":"codeVoice","code":"ColorRawToken"},{"type":"text","text":", to keep grammar clean and clear with design system grammar."}],"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"ColorSemanticToken"}],"navigatorTitle":[{"kind":"identifier","text":"ColorSemanticToken"}],"title":"ColorSemanticToken","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorSemanticToken","role":"symbol"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ColorSemanticTokens/repositoryNeutralMutedWhite":