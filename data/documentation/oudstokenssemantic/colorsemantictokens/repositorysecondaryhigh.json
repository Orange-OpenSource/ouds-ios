agments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"ColorSemanticToken"}],"title":"ColorSemanticToken","type":"topic","role":"symbol","url":"\/documentation\/oudstokenssemantic\/colorsemantictoken"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"images":[{"type":"icon","identifier":"ic_design_token_figma_semantic.png"}],"type":"topic","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic","url":"\/documentation\/oudstokenssemantic","kind":"symbol","abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" can be used mainly for "},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"type":"text","text":" to apply some style and configuration values ; today "},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"components"}],"type":"emphasis"},{"type":"text","text":" are not defined yet."},{"type":"text","text":" "},{"type":"text","text":"They can be seen as an high level of usage with functional meanings."}],"title":"Tokens for semantics","role":"collection"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleColorSemanticToken":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleColorSemanticToken"}],"type":"topic","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken","navigatorTitle":[{"text":"MultipleColorSemanticToken","kind":"identifier"}],"abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorSemanticToken","isActive":true},{"type":"text","text":" depending to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"color scheme"}]},{"type":"text","text":" (i.e. ligh mode or dark mode)."},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a color token exists with its value depending to the color scheme, it must be packed in such ``MultipleColorSemanticToken`"}],"title":"MultipleColorSemanticToken","url":"\/documentation\/oudstokenssemantic\/multiplecolorsemantictoken","kind":"symbol","role":"symbol"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ColorSemanticTokens":{"navigatorTitle":[{"kind":"identifier","text":"ColorSemanticTokens"}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorSemanticTokens","abstract":[{"type":"text","text":"This is a group of semantic tokens for "},{"inlineContent":[{"text":"colors","type":"text"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It defines all "},{"isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorSemanticToken","type":"reference"},{"type":"text","text":"  a theme must have."},{"type":"text","text":" "},{"type":"text","text":"These tokens are then gathered inside "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken","isActive":true},{"type":"text","text":" objects defined in "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorMultipleSemanticTokens","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If it possible a theme won’t have such semantic tokens of colors defined as not specified nor used in Figma."},{"type":"text","text":" "},{"type":"text","text":"Thus the value for these tokens will be “ouds-forbidden-color-value” as returned by the tokenator."},{"type":"text","text":" "},{"type":"text","text":"Thus if the token is still used, even if explained in the documentation it should not,"},{"type":"text","text":" "},{"type":"text","text":"this special value won’t be successfully parsed as color and the app will crash like expected."}],"kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ColorSemanticTokens","kind":"identifier"}],"title":"ColorSemanticTokens","type":"topic","role":"symbol","url":"\/documentation\/oudstokenssemantic\/colorsemantictokens"}}}