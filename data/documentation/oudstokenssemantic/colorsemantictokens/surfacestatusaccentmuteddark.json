ode).","type":"text"},{"type":"text","text":" "},{"text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" inside one object.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If a color token exists with its value depending to the color scheme, it must be packed in such ``MultipleColorSemanticToken`"}],"title":"MultipleColorSemanticToken"},"ic_design_token_figma_semantic.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/OUDSTokensSemantic\/ic_design_token_figma_semantic.png","traits":["1x","light"]}],"identifier":"ic_design_token_figma_semantic.png"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ColorSemanticTokens":{"url":"\/documentation\/oudstokenssemantic\/colorsemantictokens","role":"symbol","navigatorTitle":[{"text":"ColorSemanticTokens","kind":"identifier"}],"abstract":[{"text":"This is a group of semantic tokens for ","type":"text"},{"inlineContent":[{"text":"colors","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It defines all ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorSemanticToken","type":"reference"},{"text":"  a theme must have.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"These tokens are then gathered inside "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken","isActive":true},{"type":"text","text":" objects defined in "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorMultipleSemanticTokens","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If it possible a theme won’t have such semantic tokens of colors defined as not specified nor used in Figma.","type":"text"},{"text":" ","type":"text"},{"text":"Thus the value for these tokens will be “ouds-forbidden-color-value” as returned by the tokenator.","type":"text"},{"text":" ","type":"text"},{"text":"Thus if the token is still used, even if explained in the documentation it should not,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this special value won’t be successfully parsed as color and the app will crash like expected."}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorSemanticTokens","title":"ColorSemanticTokens","type":"topic","kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ColorSemanticTokens"}]}}}