 value depending to the color scheme, it must be packed in such ``MultipleElevationCompositeRawTokens`"}],"title":"MultipleElevationCompositeRawTokens","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleElevationCompositeRawTokens","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtokens"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ElevationCompositeSemanticTokens":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens","kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ElevationCompositeSemanticTokens"}],"abstract":[{"type":"text","text":"This is a group of semantic tokens for "},{"inlineContent":[{"text":"elevations","type":"text"}],"type":"strong"},{"type":"text","text":", but only "},{"inlineContent":[{"text":"composite tokens","type":"text"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"There are splitted and not declared in "},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationSemanticTokens","isActive":true,"type":"reference"},{"type":"text","text":" as the "},{"inlineContent":[{"text":"tokenator","type":"text"}],"type":"emphasis"},{"type":"text","text":" tool parsing "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" JSON to Swift code is not able to manage them."},{"type":"text","text":" "},{"type":"text","text":"Thus we need to declare them in another file to prevent them to be erased."},{"type":"text","text":" "},{"type":"text","text":"It declares in fact box shadows effects."}],"title":"ElevationCompositeSemanticTokens","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationCompositeSemanticTokens"}],"type":"topic","url":"\/documentation\/oudstokenssemantic\/elevationcomp