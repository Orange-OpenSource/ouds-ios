t","text":"There are splitted and not declared in "},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationSemanticTokens","isActive":true,"type":"reference"},{"type":"text","text":" as the "},{"inlineContent":[{"text":"tokenator","type":"text"}],"type":"emphasis"},{"type":"text","text":" tool parsing "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" JSON to Swift code is not able to manage them."},{"type":"text","text":" "},{"type":"text","text":"Thus we need to declare them in another file to prevent them to be erased."},{"type":"text","text":" "},{"type":"text","text":"It declares in fact box shadows effects."}],"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationCompositeSemanticTokens","kind":"identifier"}],"title":"ElevationCompositeSemanticTokens","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ElevationCompositeSemanticTokens/sticky":{"kind":"symbol","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens\/sticky","required":true,"type":"topic","abstract":[],"title":"sticky","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sticky"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSTokensSemantic018ElevationCompositeB5Tokena","kind":"typeIdentifier","text":"ElevationCompositeSemanticToken"}],"url":"\/documentation\/oudstokenssemantic\/elevationcompositesemantictokens\/sticky"},"ic_design_token_figma_semantic.png":{"variants":[{"url":"\/images\/OUDSTokensSemantic\/ic_design_token_figma_semantic.png","traits":["1x","light"]}],"identifier":"ic_design_token_figma_semantic.png","alt":null,"type":"image"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationC