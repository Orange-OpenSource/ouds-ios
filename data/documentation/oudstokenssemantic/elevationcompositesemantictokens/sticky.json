except "},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens","isActive":true,"type":"reference"},{"type":"text","text":")"}],"navigatorTitle":[{"text":"ElevationSemanticTokens","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationSemanticTokens","kind":"identifier"}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ElevationCompositeSemanticTokens":{"url":"\/documentation\/oudstokenssemantic\/elevationcompositesemantictokens","type":"topic","kind":"symbol","role":"symbol","title":"ElevationCompositeSemanticTokens","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens","abstract":[{"text":"This is a group of semantic tokens for ","type":"text"},{"inlineContent":[{"type":"text","text":"elevations"}],"type":"strong"},{"text":", but only ","type":"text"},{"inlineContent":[{"type":"text","text":"composite tokens"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"There are splitted and not declared in ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationSemanticTokens","type":"reference","isActive":true},{"text":" as the ","type":"text"},{"inlineContent":[{"type":"text","text":"tokenator"}],"type":"emphasis"},{"text":" tool parsing ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" JSON to Swift code is not able to manage them.","type":"text"},{"text":" ","type":"text"},{"text":"Thus we need to declare them in another file to prevent them to be erased.","type":"text"},{"text":" ","type":"text"},{"text":"It declares in fact box shadows effects.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"ElevationCompositeSemanticTokens"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationCom