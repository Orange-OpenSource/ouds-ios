"text","text":" values."}],"kind":"symbol"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ElevationSemanticTokens":{"title":"ElevationSemanticTokens","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"ElevationSemanticTokens","kind":"identifier"}],"abstract":[{"text":"This is a group of semantic tokens for ","type":"text"},{"inlineContent":[{"text":"elevations","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"It defines all elevation semantic tokens a theme must have (","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationXSemanticToken","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationYSemanticToken","isActive":true,"type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationBlurSemanticToken","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationColorSemanticToken","isActive":true,"type":"reference"},{"text":").","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"However the composite tokens (here for box shadows) are defined in "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens"},{"text":" because the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokenator"}]},{"type":"text","text":" "},{"text":"is not able to generate them yet, and they must be defined elsewhere to not be deleted.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Any elevation semantic token must be declared there (except "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/