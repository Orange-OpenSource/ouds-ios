"type":"strong","inlineContent":[{"text":"elevations","type":"text"}]},{"type":"text","text":", but only "},{"type":"strong","inlineContent":[{"text":"composite tokens","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"There are splitted and not declared in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationSemanticTokens"},{"type":"text","text":" as the "},{"type":"emphasis","inlineContent":[{"text":"tokenator","type":"text"}]},{"type":"text","text":" tool parsing "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" JSON to Swift code is not able to manage them."},{"text":" ","type":"text"},{"type":"text","text":"Thus we need to declare them in another file to prevent them to be erased."},{"text":" ","type":"text"},{"type":"text","text":"It declares in fact box shadows effects."}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens","url":"\/documentation\/oudstokenssemantic\/elevationcompositesemantictokens","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"ElevationCompositeSemanticTokens","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"ElevationCompositeSemanticTokens"}],"title":"ElevationCompositeSemanticTokens","kind":"symbol","role":"symbol"},"ic_design_token_figma_semantic.png":{"identifier":"ic_design_token_figma_semantic.png","type":"image","alt":null,"variants":[{"url":"\/images\/OUDSTokensSemantic\/ic_design_token_figma_semantic.png","traits":["1x","light"]}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ElevationCompositeSemanticTokens/drag":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens\/drag","kind":"symbol","required":true,"url":"\/documentation\/oudstokenssemantic\/elevationcompositesemantictokens\/dra