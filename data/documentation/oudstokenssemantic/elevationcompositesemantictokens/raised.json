 must have ("},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationXSemanticToken","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationYSemanticToken","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationBlurSemanticToken","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationColorSemanticToken","isActive":true},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"However the composite tokens (here for box shadows) are defined in "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens","isActive":true},{"type":"text","text":" because the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokenator"}]},{"type":"text","text":" "},{"type":"text","text":"is not able to generate them yet, and they must be defined elsewhere to not be deleted."},{"type":"text","text":" "},{"type":"text","text":"Any elevation semantic token must be declared there (except "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens","isActive":true},{"type":"text","text":")"}],"kind":"symbol","type":"topic","url":"\/documentation\/oudstokenssemantic\/elevationsemantictokens","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationSemanticTokens","title":"ElevationSemanticTokens","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationSemanticTokens","kind":"identifier"}],"navigatorTitle":[{"text":"ElevationSemanticTokens","kind":"identifier"}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ElevationCompositeSemanticTokens":{"url":"\/documentation\/oudstokenssemantic\/elevationcompositesemantictokens","title":"ElevationCompositeSemanticTokens","kind":"symbol","abstract":[{"text":"This is a group of semantic tokens for ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"elevations"}]},{"text":", but only ","type":"text"},{"type":"strong","inlineContent":[{"text":"composite tokens","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"There are splitted and not declared in ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationSemanticTokens"},{"text":" as the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokenator","type":"text"}]},{"text":" tool parsing ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" JSON to Swift code is not able to manage them.","type":"text"},{"text":" ","type":"text"},{"text":"Thus we need to declare them in another file to prevent them to be erased.","type":"text"},{"text":" ","type":"text"},{"text":"It declares in fact box shadows effects.","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationCompositeSemanticTokens","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"ElevationCompositeSemanticTokens","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticTokens"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/ElevationCompositeSemanticToken":{"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationCompositeSemanticToken"}],"abstract":[{"type":"text","text":"Basically an elevationcomposite  semantic token, used mainly for box shadow, is a pair of elevation composite raw tokens used depending to the color scheme."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens"},{"type":"text","text":" contains "},{"type":"codeVoice","code":"ElevationCompositeRawToken"},{"type":"text","text":" objects for light and dark modes, which contains "},{"type":"codeVoice","code":"ElevationRawToken"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ColorRawToken"},{"type":"text","text":" values."}],"url":"\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","title":"ElevationCompositeSemanticToken","role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ElevationCompositeSemanticToken"}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ElevationCompositeSemanticToken","kind":"symbol"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationCompositeRawTokens":{"kind":"symbol","role":"symbol","title":"MultipleElevationCompositeRawTokens","abstract":[{"type":"text","text":"Semantic tokens which will wrap a combination of "},{"type":"codeVoice","code":"ElevationCompositeRawToken"},{"type":"text","text":" depending to color scheme (i.e. light mode or dark mode)"},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If an elevation token exists with its value depending to the color scheme, it must be packed in such ``MultipleElevationCompositeRawTokens`"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleElevationCompositeRawTokens"}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens","url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtokens","navigatorTitle":[{"kind":"identifier","text":"MultipleElevationCompositeRawTokens"}],"type":"topic"}}}