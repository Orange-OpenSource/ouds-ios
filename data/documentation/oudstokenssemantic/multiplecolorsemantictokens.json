adata":{"externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticTokens","title":"MultipleColorSemanticTokens","symbolKind":"class","modules":[{"name":"Tokens for semantics"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleColorSemanticTokens","kind":"identifier"}],"navigatorTitle":[{"text":"MultipleColorSemanticTokens","kind":"identifier"}],"role":"symbol","roleHeading":"Class"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleColorSemanticTokens","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"syntax":"swift","code":["        \/\/ Assuming in Figma with have a color semantic token bgPrimary,","        \/\/ two semantic color tokens will be defined in Figma and generated by tokenator.","        \/\/ They can be declared in protocol ColorSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+ColorSemanticTokens extension","        var bgPrimaryLight: ColorSemanticToken { ColorRawTokens.functionalWhite }","        var bgPrimaryDark: ColorSemanticToken { ColorRawTokens.functionalDarkGray880 }","","        \/\/ Then the develoment team declares an \"higher\" level color semantic token for bgPrimary","        \/\/ inside ColorMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+ColorMultipleSemanticToken extension","        var bgPrimary: MultipleColorSemanticTokens { MultipleColorSemanticTokens(light: bgPrimaryLight, dark: bgPrimaryDark) }","","        \/\/ If the same color is used whatever the color scheme is","        var bgPrimary: MultipleColorSemanticTokens { MultipleColorSemanticTokens(bgPrimaryLight) }","","        \/\/ The theme exposes both generated color semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"type":"codeListing"},{"syntax":"swift","code":["     @Environment(\\.theme) var theme","     @Environment(\\.colorScheme) var colorScheme","","    \/\/ Given you want to apply the color token \"surfaceBrandPrimary\"","    var body: some View {","        \/\/ Apply the token of color for the view without managing yourself the color scheme","        SomeView()","            .oudsBackground(theme.colors.surfaceBrandPrimary)","","        \/\/ Or also oudsForegroundtyle(), oudsForegroundColor(), oudsAccentColor(), ...","    }"],"type":"codeListing"},{"syntax":"swift","code":["    \/\/ Or get the token depending to the color scheme and do whatever you want with","    theme.colors.surfaceBrandPrimary.color(for: colorScheme)"],"type":"codeListing"},{"name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.8.0"}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorSemanticToken","type":"reference"},{"text":" depending to ","type":"text"},{"inlineContent":[{"text":"color scheme","type":"text"}],"type":"emphasis"},{"text":" (i.e. ligh mode or dark mode).","type":"text"},{"text":" ","type":"text"},{"text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system.","type":"text"},{"text":" ","type":"text"},{"text":"Allows to gather the multiple-value tokens from ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a color token exists with its value depending to the color sc