, and together define a "},{"inlineContent":[{"text":"composite raw token","type":"text"}],"type":"emphasis"},{"type":"text","text":" for "},{"inlineContent":[{"text":"font","type":"text"}],"type":"emphasis"},{"type":"text","text":" thing."}],"title":"FontCompositeSemanticToken","kind":"symbol"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"type":"topic","abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" can be used mainly for "},{"inlineContent":[{"text":"component tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" to apply some style and configuration values ; today "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"components","type":"text"}]},{"text":" are not defined yet.","type":"text"},{"type":"text","text":" "},{"text":"They can be seen as an high level of usage with functional meanings.","type":"text"}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic","images":[{"type":"icon","identifier":"ic_design_token_figma_semantic.png"}],"url":"\/documentation\/oudstokenssemantic","title":"Tokens for semantics","kind":"symbol","role":"collection"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleFontCompositeSemanticToken":{"title":"MultipleFontCompositeSemanticToken","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleFontCompositeSemanticToken","kind":"identifier"}],"abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"code":"FontCompositeSemanticToken","type":"codeVoice"},{"type":"text","text":" depending to size classes."},{"type":"text","text":" "},{"text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system.","type":"text"},{"text":" ","type":"text"},{"text":"Allows to gather the multiple-value tokens from ","type":"text"},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"text":"If a font token exists with its value depending to the size class, it must be packed in such ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","isActive":true},{"text":".","type":"text"}],"navigatorTitle":[{"text":"MultipleFontCompositeSemanticToken","kind":"identifier"}],"url":"\/documentation\/oudstokenssemantic\/multiplefontcompositesemantictoken","type":"topic","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","role":"symbol","kind":"symbol"}}}