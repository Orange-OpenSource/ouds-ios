om "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a font token exists with its value depending to the size class, it must be packed in such "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken"},{"type":"text","text":"."}],"title":"MultipleFontCompositeSemanticToken","url":"\/documentation\/oudstokenssemantic\/multiplefontcompositesemantictoken","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","role":"symbol","navigatorTitle":[{"text":"MultipleFontCompositeSemanticToken","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleFontCompositeSemanticToken","kind":"identifier"}]}}}