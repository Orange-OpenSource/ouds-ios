 ","type":"text"},{"inlineContent":[{"type":"text","text":"font"}],"type":"emphasis"},{"text":" thing is caracterized by a ","type":"text"},{"inlineContent":[{"text":"font size","type":"text"}],"type":"emphasis"},{"text":", a ","type":"text"},{"inlineContent":[{"text":"line height","type":"text"}],"type":"emphasis"},{"text":", a ","type":"text"},{"inlineContent":[{"text":"font weight","type":"text"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"letter spacing"}],"type":"emphasis"},{"text":" values.","type":"text"},{"text":" ","type":"text"},{"text":"All these elements are ","type":"text"},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"text":", and together define a ","type":"text"},{"inlineContent":[{"text":"composite raw token","type":"text"}],"type":"emphasis"},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"text":"font","type":"text"}]},{"type":"text","text":" thing."}],"title":"FontCompositeSemanticToken","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontCompositeSemanticToken","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FontCompositeSemanticToken","kind":"identifier"}],"role":"symbol","url":"\/documentation\/oudstokenssemantic\/fontcompositesemantictoken","navigatorTitle":[{"text":"FontCompositeSemanticToken","kind":"identifier"}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleFontCompositeSemanticToken":{"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","url":"\/documentation\/oudstokenssemantic\/multiplefontcompositesemantictoken","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontCompositeSemanticToken"}],"title":"MultipleFontCompositeSemanticToken","navigatorTitle":[{"kind":"identifier","text":"MultipleFontCompositeSemanticToken"}],"role":"symbol","abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"type":"codeVoice","code":"FontCompositeSemanticToken"},{"type":"text","text":" depending to size classes."},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"text":"Allows to gather the multiple-value tokens from ","type":"text"},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"text":" inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a font token exists with its value depending to the size class, it must be packed in such ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","type":"reference","isActive":true},{"text":".","type":"text"}]}}}