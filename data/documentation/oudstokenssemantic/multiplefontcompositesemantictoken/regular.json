"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontCompositeSemanticToken","title":"FontCompositeSemanticToken","abstract":[{"type":"text","text":"In the "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" global design system, composite tokens are defined for font-related things."},{"type":"text","text":" "},{"type":"text","text":"Composite tokens are tokens defined in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here a "},{"type":"emphasis","inlineContent":[{"text":"font","type":"text"}]},{"type":"text","text":" thing is caracterized by a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font size"}]},{"type":"text","text":", a "},{"type":"emphasis","inlineContent":[{"text":"line height","type":"text"}]},{"type":"text","text":", a "},{"type":"emphasis","inlineContent":[{"text":"font weight","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"letter spacing","type":"text"}]},{"type":"text","text":" values."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":", and together define a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite raw token"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font"}]},{"type":"text","text":" thing."}],"navigatorTitle":[{"kind":"identifier","text":"FontCompositeSemanticToken"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FontCompositeSemanticToken"}]},"ic_design_token_figma_semantic.png":{"alt":null,"variants":[{"url":"\/images\/OUDSTokensSemantic\/ic_design_token_figma_semantic.png","traits":["1x","light"]}],"