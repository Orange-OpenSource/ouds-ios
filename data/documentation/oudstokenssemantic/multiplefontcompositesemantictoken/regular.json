s are defined for font-related things."},{"type":"text","text":" "},{"type":"text","text":"Composite tokens are tokens defined in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font"}]},{"type":"text","text":" thing is caracterized by a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font size"}]},{"type":"text","text":", a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"line height"}]},{"type":"text","text":", a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font weight"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"letter spacing"}]},{"type":"text","text":" values."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":", and together define a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite raw token"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font"}]},{"type":"text","text":" thing."}],"type":"topic","title":"FontCompositeSemanticToken","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontCompositeSemanticToken","kind":"symbol","url":"\/documentation\/oudstokenssemantic\/fontcompositesemantictoken"}}}