ipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+FontMultipleSemanticTokens extension","        var lineHeightLabelXLarge: MultipleFontLineHeightSemanticToken {","            MultipleFontLineHeightSemanticToken(compact: lineHeightLabelXLargeMobile, regular: lineHeightLabelXLargeTablet)","        }","","        \/\/ If the same value is used whatever the size class is","        var lineHeightLabelXLarge: MultipleFontLineHeightSemanticToken { MultipleFontLineHeightSemanticToken(lineHeightLabelXLargeMobile) }","","        \/\/ The theme exposes both generated font line height semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}],"style":"note","name":"Since","type":"aside"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontLineHeightSemanticToken"},"metadata":{"modules":[{"name":"Tokens for semantics"}],"navigatorTitle":[{"text":"MultipleFontLineHeightSemanticToken","kind":"identifier"}],"symbolKind":"class","roleHeading":"Class","title":"MultipleFontLineHeightSemanticToken","externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleFontLineHeightSemanticToken","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontLineHeightSemanticToken"}]},"hierarchy":{"paths":[["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontLineHeightSemanticToken\/_(_:_:)"],"generated":true,"title":"Operators","anchor":"Operators"},{"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontLineHeightSemanticToken\/init(_:)","doc