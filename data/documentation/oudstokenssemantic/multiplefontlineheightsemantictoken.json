ined in Figma and generated by tokenator because","        \/\/ its value can vary if compact or regular modes.","        \/\/ They can be declared in protocol FontSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+FontSemanticTokens extension","        var lineHeightLabelXLargeMobile: FontLineHeightSemanticToken { FontRawTokens.lineHeight450 }","        var lineHeightLabelXLargeTablet: FontLineHeightSemanticToken { FontRawTokens.lineHeight450 }","","        \/\/ Then the develoment team declares an \"higher\" level line height semantic token for lineHeightLabelXLarge","        \/\/ inside FontMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+FontMultipleSemanticTokens extension","        var lineHeightLabelXLarge: MultipleFontLineHeightSemanticToken {","            MultipleFontLineHeightSemanticToken(compact: lineHeightLabelXLargeMobile, regular: lineHeightLabelXLargeTablet)","        }","","        \/\/ If the same value is used whatever the size class is","        var lineHeightLabelXLarge: MultipleFontLineHeightSemanticToken { MultipleFontLineHeightSemanticToken(lineHeightLabelXLargeMobile) }","","        \/\/ The theme exposes both generated font line height semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"syntax":"swift","type":"codeListing"},{"name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"style":"note"}]}],"topicSections":[{"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontLineHeightSemanticToken\/_(_:_:)"],"title":"Operators","generated":true,"anchor":"Operators"},{"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontLineHeightSemanticToken\/init(_:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontLineHeightSemanticToken\/init(comp