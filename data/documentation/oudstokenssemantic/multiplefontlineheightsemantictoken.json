pleSemanticTokens extension","        var lineHeightLabelXLarge: MultipleFontLineHeightSemanticToken {","            MultipleFontLineHeightSemanticToken(compact: lineHeightLabelXLargeMobile, regular: lineHeightLabelXLargeTablet)","        }","","        \/\/ If the same value is used whatever the size class is","        var lineHeightLabelXLarge: MultipleFontLineHeightSemanticToken { MultipleFontLineHeightSemanticToken(lineHeightLabelXLargeMobile) }","","        \/\/ The theme exposes both generated font line height semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"name":"Since","type":"aside","style":"note","content":[{"inlineContent":[{"text":"0.8.0","type":"text"}],"type":"paragraph"}]}]}],"identifier":{"url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontLineHeightSemanticToken","interfaceLanguage":"swift"},"abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontLineHeightSemanticToken","type":"reference"},{"text":" depending to size classes.","type":"text"},{"text":" ","type":"text"},{"text":"Allows to gather the multiple-value tokens from ","type":"text"},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"text":" inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a font line height token exists with its value depending to the size class, it must be packed in such ``MultipleFontLineHeightSemanticToken`","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplefontlineheightsemantictoken"]}],"sections":[],"references":{"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleFontLineHeightSemanticToken":{"url":"\/documentation\/oudstokenssemantic\/multiplefontlineheig