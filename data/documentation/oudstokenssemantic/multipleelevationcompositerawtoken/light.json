okensRaw/ElevationCompositeRawToken":{"navigatorTitle":[{"text":"ElevationCompositeRawToken","kind":"identifier"}],"abstract":[{"type":"text","text":"In the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" global design system, composite tokens are defined for elevation effects."},{"type":"text","text":" "},{"type":"text","text":"Composite tokens are tokens defined in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here an "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation"}]},{"type":"text","text":" is caracterized by "},{"type":"emphasis","inlineContent":[{"type":"text","text":"X and Y offsets"}]},{"type":"text","text":", a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radius"}]},{"type":"text","text":" for the shadow and a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"color"}]},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":", and together define a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite raw token"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation"}]},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"type":"codeVoice","code":"final class"},{"type":"text","text":" and "},{"type":"codeVoice","code":"NSObject"},{"type":"text","text":" so as to be shared through "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" with extensions and protocols within modules."}],"kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationCompositeRawToken","kind":"identifier"}],"url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","title":"ElevationCompositeRawToken"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"type":"topic","url":"\/documentation\/oudstokenssemantic","images":[{"identifier":"ic_design_token_figma_semantic.png","type":"icon"}],"abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"text":" can be used mainly for ","type":"text"},{"inlineContent":[{"text":"component tokens","type":"text"}],"type":"emphasis"},{"text":" to apply some style and configuration values ; today ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"components"}],"type":"emphasis"},{"text":" are not defined yet.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"They can be seen as an high level of usage with functional meanings."}],"kind":"symbol","title":"Tokens for semantics","role":"collection","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationCompositeRawToken/light":{"abstract":[{"text":"For ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"light"}]},{"text":" mode scheme","type":"text"}],"kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"light","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ElevationCompositeRawToken","preciseIdentifier":"c:@M@OUDSTokensRaw@objc(cs)ElevationCompositeRawToken","kind":"typeIdentifier"}],"url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtoken\/light","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawToken\/light","title":"light"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationCompositeRawToken":{"navigatorTitle":[{"text":"MultipleElevationCompositeRawToken","kind":"identifier"}],"abstract":[{"type":"text","text":"Semantic tokens which will wrap a combination of "},{"type":"codeVoice","code":"ElevationCompositeRawToken"},{"type":"text","text":" depending to color scheme (i.e. light mode or dark mode)"},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If an elevation token exists with its value depending to the color scheme, it must be packed in such ``MultipleElevationCompositeRawToken`"}],"kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MultipleElevationCompositeRawToken"}],"url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtoken","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawToken","title":"MultipleElevationCompositeRawToken"}}}