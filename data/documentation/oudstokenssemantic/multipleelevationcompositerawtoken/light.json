ultipleElevationCompositeRawToken\/light","type":"topic","title":"light","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"For "},{"inlineContent":[{"text":"light","type":"text"}],"type":"strong"},{"text":" mode scheme","type":"text"}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"light","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ElevationCompositeRawToken","preciseIdentifier":"c:@M@OUDSTokensRaw@objc(cs)ElevationCompositeRawToken","kind":"typeIdentifier"}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"title":"Tokens for semantics","kind":"symbol","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic","role":"collection","images":[{"type":"icon","identifier":"ic_design_token_figma_semantic.png"}],"url":"\/documentation\/oudstokenssemantic","abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"type":"text","text":" can be used mainly for "},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"type":"text","text":" to apply some style and configuration values ; today "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"components"}]},{"type":"text","text":" are not defined yet."},{"type":"text","text":" "},{"type":"text","text":"They can be seen as an high level of usage with functional meanings."}],"type":"topic"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationCompositeRawToken":{"kind":"symbol","type":"topic","abstract":[{"text":"In the ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" global design system, composite tokens are defined for elevation effects.","type":"text"},{"text":" ","type":"text"},{"text":"Composite tokens are tokens defined in ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" by other tokens.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Here an "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" is caracterized by "},{"inlineContent":[{"text":"X and Y offsets","type":"text"}],"type":"emphasis"},{"type":"text","text":", a "},{"inlineContent":[{"type":"text","text":"radius"}],"type":"emphasis"},{"type":"text","text":" for the shadow and a "},{"inlineContent":[{"type":"text","text":"color"}],"type":"emphasis"},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":", and together define a "},{"inlineContent":[{"text":"composite raw token","type":"text"}],"type":"emphasis"},{"type":"text","text":" for "},{"inlineContent":[{"text":"elevation","type":"text"}],"type":"emphasis"},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"code":"final class","type":"codeVoice"},{"type":"text","text":" and "},{"code":"NSObject","type":"codeVoice"},{"type":"text","text":" so as to be shared through "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" with extensions and protocols within modules."}],"title":"ElevationCompositeRawToken","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","fragments":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationCompositeRawToken","kind":"identifier"}],"role":"symbol","url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken"},"ic_design_token_figma_semantic.png":{"variants":[{"url":"\/images\/OUDSTokensSemantic\/ic_design_token_figma_semantic.png","traits":["1x","light"]}],"identifier":"ic_design_token_figma_semantic.png","type":"image","alt":null},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationCompositeRawToken":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Semantic tokens which will wrap a combination of "},{"code":"ElevationCompositeRawToken","type":"codeVoice"},{"text":" depending to color scheme (i.e. light mode or dark mode)","type":"text"},{"text":" ","type":"text"},{"text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system.","type":"text"},{"type":"text","text":" "},{"text":"Allows to gather the multiple-value tokens from ","type":"text"},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"text":" inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If an elevation token exists with its value depending to the color scheme, it must be packed in such ``MultipleElevationCompositeRawToken`","type":"text"}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawToken","type":"topic","title":"MultipleElevationCompositeRawToken","url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtoken","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MultipleElevationCompositeRawToken","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MultipleElevationCompositeRawToken"}]}}}