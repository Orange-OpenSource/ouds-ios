","code":"NSObject"},{"text":" so as to be shared through ","type":"text"},{"type":"codeVoice","code":"@objc"},{"text":" with extensions and protocols within modules.","type":"text"}],"type":"topic"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"kind":"symbol","title":"Tokens for semantics","role":"collection","images":[{"identifier":"ic_design_token_figma_semantic.png","type":"icon"}],"url":"\/documentation\/oudstokenssemantic","type":"topic","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic","abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" can be used mainly for "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" to apply some style and configuration values ; today "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"text":"components","type":"text"}]},{"text":" are not defined yet.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as an high level of usage with functional meanings.","type":"text"}]},"ic_design_token_figma_semantic.png":{"type":"image","identifier":"ic_design_token_figma_semantic.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSTokensSemantic\/ic_design_token_figma_semantic.png"}]}}}