.","type":"text"},{"text":" ","type":"text"},{"text":"Composite tokens are tokens defined in ","type":"text"},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"text":" by other tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Here an ","type":"text"},{"inlineContent":[{"text":"elevation","type":"text"}],"type":"emphasis"},{"text":" is caracterized by ","type":"text"},{"inlineContent":[{"type":"text","text":"X and Y offsets"}],"type":"emphasis"},{"text":", a ","type":"text"},{"inlineContent":[{"text":"radius","type":"text"}],"type":"emphasis"},{"text":" for the shadow and a ","type":"text"},{"inlineContent":[{"type":"text","text":"color"}],"type":"emphasis"},{"text":" to apply on that shadow.","type":"text"},{"text":" ","type":"text"},{"text":"All these elements are ","type":"text"},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"text":", and together define a ","type":"text"},{"inlineContent":[{"text":"composite raw token","type":"text"}],"type":"emphasis"},{"text":" for ","type":"text"},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"text":" effect.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It is defined as a "},{"code":"final class","type":"codeVoice"},{"type":"text","text":" and "},{"code":"NSObject","type":"codeVoice"},{"type":"text","text":" so as to be shared through "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" with extensions and protocols within modules."}],"role":"symbol","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","type":"topic","fragments":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationCompositeRawToken"}],"title":"ElevationCompositeRawToken","url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken","kind":"symbol"},"doc://OUDSTokensSemantic/documentation/OU