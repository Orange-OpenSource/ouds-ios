adius","type":"text"}]},{"type":"text","text":" for the shadow and a "},{"type":"emphasis","inlineContent":[{"text":"color","type":"text"}]},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":", and together define a "},{"type":"emphasis","inlineContent":[{"text":"composite raw token","type":"text"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation"}]},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"type":"codeVoice","code":"final class"},{"type":"text","text":" and "},{"type":"codeVoice","code":"NSObject"},{"type":"text","text":" so as to be shared through "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" with extensions and protocols within modules."}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationCompositeRawToken","kind":"identifier"}],"title":"ElevationCompositeRawToken","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic","images":[{"type":"icon","identifier":"ic_design_token_figma_semantic.png"}],"type":"topic","url":"\/documentation\/oudstokenssemantic","title":"Tokens for semantics","kind":"symbol","role":"collection","abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"text":" can be used mainly for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" to apply some style and configuration values ; today "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text