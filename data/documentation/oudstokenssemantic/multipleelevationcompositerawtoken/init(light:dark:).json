":"text","text":"color"}],"type":"emphasis"},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":", and together define a "},{"inlineContent":[{"type":"text","text":"composite raw token"}],"type":"emphasis"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" effect."},{"type":"text","text":" "},{"text":"It is defined as a ","type":"text"},{"code":"final class","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"NSObject","type":"codeVoice"},{"text":" so as to be shared through ","type":"text"},{"code":"@objc","type":"codeVoice"},{"text":" with extensions and protocols within modules.","type":"text"}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken"}}}