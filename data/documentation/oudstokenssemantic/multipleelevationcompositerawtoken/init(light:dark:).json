"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","kind":"symbol","type":"topic","title":"ElevationCompositeRawToken","abstract":[{"type":"text","text":"In the "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" global design system, composite tokens are defined for elevation effects."},{"type":"text","text":" "},{"type":"text","text":"Composite tokens are tokens defined in "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here an "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" is caracterized by "},{"inlineContent":[{"text":"X and Y offsets","type":"text"}],"type":"emphasis"},{"type":"text","text":", a "},{"inlineContent":[{"text":"radius","type":"text"}],"type":"emphasis"},{"type":"text","text":" for the shadow and a "},{"inlineContent":[{"text":"color","type":"text"}],"type":"emphasis"},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":", and together define a "},{"inlineContent":[{"type":"text","text":"composite raw token"}],"type":"emphasis"},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation"}]},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"type":"codeVoice","code":"final class"},{"type":"text","text":" and "},{"type":"codeVoice","code":"NSObject"},{"type":"text","text":" so as to be shared through "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" with extensions and protocols within modules."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ElevationCompositeRawToken"}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"type":"text","text":" can be used mainly for "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" to apply some style and configuration values ; today "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"text":"components","type":"text"}]},{"type":"text","text":" are not defined yet."},{"type":"text","text":" "},{"type":"text","text":"They can be seen as an high level of usage with functional meanings."}],"role":"collection","title":"Tokens for semantics","images":[{"type":"icon","identifier":"ic_design_token_figma_semantic.png"}],"kind":"symbol","url":"\/documentation\/oudstokenssemantic","type":"topic","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"}}}