nsSemantic","type":"topic","role":"collection","url":"\/documentation\/oudstokenssemantic","abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"text":" can be used mainly for ","type":"text"},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"type":"text","text":" to apply some style and configuration values ; today "},{"inlineContent":[{"text":"component tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" or "},{"inlineContent":[{"text":"components","type":"text"}],"type":"emphasis"},{"text":" are not defined yet.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"They can be seen as an high level of usage with functional meanings."}],"title":"Tokens for semantics","kind":"symbol","images":[{"identifier":"ic_design_token_figma_semantic.png","type":"icon"}]},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationCompositeRawToken":{"abstract":[{"text":"In the ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" global design system, composite tokens are defined for elevation effects.","type":"text"},{"text":" ","type":"text"},{"text":"Composite tokens are tokens defined in ","type":"text"},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"text":" by other tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Here an ","type":"text"},{"inlineContent":[{"text":"elevation","type":"text"}],"type":"emphasis"},{"text":" is caracterized by ","type":"text"},{"inlineContent":[{"type":"text","text":"X and Y offsets"}],"type":"emphasis"},{"text":", a ","type":"text"},{"inlineContent":[{"text":"radius","type":"text"}],"type":"emphasis"},{"text":" for the shadow and a ","type":"text"},{"inlineContent":[{"type":"text","text":"color"}],"type":"emphasis"},{"text":" to apply on that shadow.","type":"text"},{"text":" ","type":"text"},{"text":"All these elements are ","type":"text"},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"text":", and together define a ","type":"text"},{"inlineContent":[{"text":"composite raw token","type":"text"}],"type":"emphasis"},{"text":" for ","type":"text"},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"text":" effect.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It is defined as a "},{"code":"final class","type":"codeVoice"},{"type":"text","text":" and "},{"code":"NSObject","type":"codeVoice"},{"type":"text","text":" so as to be shared through "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" with extensions and protocols within modules."}],"role":"symbol","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","type":"topic","fragments":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationCompositeRawToken"}],"title":"ElevationCompositeRawToken","url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken","kind":"symbol"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationCompositeRawToken/init(_:)":{"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"ElevationCompositeRawToken","preciseIdentifier":"c:@M@OUDSTokensRaw@objc(cs)ElevationCompositeRawToken","kind":"typeIdentifier"},{"text":")","kind":"text"}],"title":"init(_:)","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawToken\/init(_:)","role":"symbol","type":"topic","url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtoken\/init(_:)","abstract":[{"text":"Initializes a new elevation composite raw token with the same value for light and dark modes","type":"text"}],"kind":"symbol"}}}