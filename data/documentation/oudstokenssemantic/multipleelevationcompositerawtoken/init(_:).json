},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationCompositeRawToken":{"title":"ElevationCompositeRawToken","kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken","fragments":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationCompositeRawToken"}],"abstract":[{"type":"text","text":"In the "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" global design system, composite tokens are defined for elevation effects."},{"type":"text","text":" "},{"type":"text","text":"Composite tokens are tokens defined in "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here an "},{"inlineContent":[{"text":"elevation","type":"text"}],"type":"emphasis"},{"type":"text","text":" is caracterized by "},{"inlineContent":[{"text":"X and Y offsets","type":"text"}],"type":"emphasis"},{"type":"text","text":", a "},{"inlineContent":[{"text":"radius","type":"text"}],"type":"emphasis"},{"type":"text","text":" for the shadow and a "},{"inlineContent":[{"type":"text","text":"color"}],"type":"emphasis"},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":", and together define a "},{"inlineContent":[{"type":"text","text":"composite raw token"}],"type":"emphasis"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" effect."},{"type":"text","text":" "},{"text":"It is defined as a ","type":"text"},{"code":"final class","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"NSObject","type":"codeVoice"},{"text":" so as to be shared through ","type":"text"},{"code":"@objc","type":"codeVoice"},{"text":" with extensions and protocols within modules.","type":"text"}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken"},"ic_design_token_figma_semantic.png":{"identifier":"ic_design_token_figma_semantic.png","type":"image","variants":[{"url":"\/images\/OUDSTokensSemantic\/ic_design_token_figma_semantic.png","traits":["1x","light"]}],"alt":null},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationCompositeRawToken":{"type":"topic","navigatorTitle":[{"text":"MultipleElevationCompositeRawToken","kind":"identifier"}],"title":"MultipleElevationCompositeRawToken","abstract":[{"type":"text","text":"Semantic tokens which will wrap a combination of "},{"code":"ElevationCompositeRawToken","type":"codeVoice"},{"type":"text","text":" depending to color scheme (i.e. light mode or dark mode)"},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If an elevation token exists with its value depending to the color scheme, it must be packed in such ``MultipleElevationCompositeRawToken`"}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawToken","url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtoken","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleElevationCompositeRawToken","kind":"identifier"}]}}}