emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":", and together define a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite raw token"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation"}]},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"type":"codeVoice","code":"final class"},{"type":"text","text":" and "},{"code":"NSObject","type":"codeVoice"},{"type":"text","text":" so as to be shared through "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" with extensions and protocols within modules."}],"type":"topic","title":"ElevationCompositeRawToken","kind":"symbol","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken"},"ic_design_token_figma_semantic.png":{"identifier":"ic_design_token_figma_semantic.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSTokensSemantic\/ic_design_token_figma_semantic.png"}],"alt":null,"type":"image"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationCompositeRawToken/init(_:)":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawToken\/init(_:)","url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtoken\/init(_:)","type":"topic","title":"init(_:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"preciseIdentifier":"c:@M@OUDSTokensRaw@objc(cs)ElevationCompositeRawToken","kind":"typeIdentifier","text":"ElevationCompositeRawToken"},{"kind":"text","text":")"}],"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Initializes a new elevation composite raw token with the same value for light and dark modes"}]}}}