asis"},{"text":" for ","type":"text"},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"text":" effect.","type":"text"},{"text":" ","type":"text"},{"text":"It is defined as a ","type":"text"},{"code":"final class","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"NSObject","type":"codeVoice"},{"text":" so as to be shared through ","type":"text"},{"code":"@objc","type":"codeVoice"},{"text":" with extensions and protocols within modules.","type":"text"}],"navigatorTitle":[{"text":"ElevationCompositeRawToken","kind":"identifier"}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ElevationCompositeRawToken","kind":"identifier"}],"url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken","type":"topic"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic":{"abstract":[{"text":"These ","type":"text"},{"inlineContent":[{"text":"tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" can be used mainly for "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" to apply some style and configuration values ; today "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"components"}]},{"text":" are not defined yet.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as an high level of usage with functional meanings.","type":"text"}],"title":"Tokens for semantics","kind":"symbol","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic","url":"\/documentation\/oudstokenssemantic","images":[{"type":"icon","identifier":"ic_design_token_figma_semantic.png"}],"type":"topic","role":"collection"}}}