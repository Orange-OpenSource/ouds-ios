{"sections":[],"kind":"symbol","abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SizeSemanticToken","isActive":true,"type":"reference"},{"text":" depending to viewports \/ size classes.","type":"text"},{"text":" ","type":"text"},{"text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system.","type":"text"},{"text":" ","type":"text"},{"text":"Allows to gather the multiple-value tokens from Figma inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a size token exists with its value depending to the size class, it must be packed in such ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticTokens","isActive":true,"type":"reference"},{"text":".","type":"text"}],"identifier":{"url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticTokens","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleSizeSemanticTokens"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"syntax":"swift","code":["        \/\/ Assuming in Figma with have a size semantic token iconWithHeadingXLargeTall,","        \/\/ two semantic size tokens will be defined in Figma and generated by tokenator because","        \/\/ its value can vary if compact or regular modes.","        \/\/ They can be declared in protocol SizeSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+SizeSemanticTokens extension","        var iconWithHeadingXLargeTallMobile: SizeSemanticToken { DimensionRawTokens._650 }","     