oth generated font size semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}],"type":"aside","name":"Since"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SizeSemanticToken","isActive":true},{"type":"text","text":" depending to viewports \/ size classes."},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from Figma inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a size token exists with its value depending to the size class, it must be packed in such "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticTokens","isActive":true},{"type":"text","text":"."}],"references":{"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleSizeSemanticTokens/init(compact:regular:)":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticTokens\/init(compact:regular:)","role":"symbol","title":"init(compact:regular:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"compact","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SizeSemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"regular","kin