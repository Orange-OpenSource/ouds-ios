{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleSizeSemanticTokens"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"syntax":"swift","type":"codeListing","code":["        \/\/ Assuming in Figma with have a size semantic token iconWithHeadingXLargeTall,","        \/\/ two semantic size tokens will be defined in Figma and generated by tokenator because","        \/\/ its value can vary if compact or regular modes.","        \/\/ They can be declared in protocol SizeSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+SizeSemanticTokens extension","        var iconWithHeadingXLargeTallMobile: SizeSemanticToken { DimensionRawTokens._650 }","        var iconWithHeadingXLargeTallTablet: SizeSemanticToken { DimensionRawTokens._800 }","","        \/\/ Then the develoment team declares an \"higher\" level size semantic token for iconWithHeadingXLargeTall","        \/\/ inside SizeMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+SizeMultipleSemanticTokens extension","        var iconWithHeadingXLargeTall: MultipleSizeSemanticTokens {","            MultipleSizeSemanticTokens(compact: iconWithHeadingXLargeTallMobile, regular: iconWithHeadingXLargeTallTablet)","        }","","        \/\/ If the same value is used whatever the size class is","        var iconWithHeadingXLargeTall: MultipleSizeSemanticTokens { MultipleSizeSemanticTokens(iconWithHeadingXLargeTallTablet) }","","        \/\/ The theme exposes both generated font size semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}]}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"relationshipsSections":[{"title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(cs)NSObject"],"type":"inheritsFrom"},{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(pl)NSObject","doc:\/\/OUDSTokensSemantic\/s7CVarArgP","doc:\/\/OUDSTokensSemantic\/s28CustomDebugStringConvertibleP","doc:\/\/OUDSTokensSemantic\/s23CustomStringConvertibleP","doc:\/\/OUDSTokensSemantic\/SQ","doc:\/\/OUDSTokensSemantic\/SH","doc:\/\/OUDSTokensSemantic\/s8SendableP","doc:\/\/OUDSTokensSemantic\/s16SendableMetatypeP"],"type":"conformsTo"}],"hierarchy":{"paths":[["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"identifier":{"url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticTokens","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/oudstokenssemantic\/multiplesizesemantictokens"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleSizeSemanticTokens","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MultipleSizeSemanticTokens"}],"symbolKind":"class","modules":[{"name":"Tokens for semantics"}],"role":"symbol","roleHeading":"Class","externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleSizeSemanticTokens","title":"MultipleSizeSemanticTokens"},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticTokens\/init(_:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticTokens\/init(compact:regular:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemant