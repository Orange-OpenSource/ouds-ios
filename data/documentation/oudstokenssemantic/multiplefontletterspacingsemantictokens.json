{"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(cs)NSObject"],"title":"Inherits From","kind":"relationships"},{"type":"conformsTo","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(pl)NSObject","doc:\/\/OUDSTokensSemantic\/s7CVarArgP","doc:\/\/OUDSTokensSemantic\/s28CustomDebugStringConvertibleP","doc:\/\/OUDSTokensSemantic\/s23CustomStringConvertibleP","doc:\/\/OUDSTokensSemantic\/SQ","doc:\/\/OUDSTokensSemantic\/SH","doc:\/\/OUDSTokensSemantic\/s8SendableP","doc:\/\/OUDSTokensSemantic\/s16SendableMetatypeP"],"title":"Conforms To","kind":"relationships"}],"identifier":{"url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontLetterSpacingSemanticTokens","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplefontletterspacingsemantictokens"]}],"abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontLetterSpacingSemanticTokens"},{"type":"text","text":" depending to size classes."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a font letter spacing token exists with its value depending to the size class (i.e. comapct or regular mode), it must be packed in such "},{"type":"codeVoice","code":"MultipleFontLetterSpacingSemanticTokens"}],"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontLetterSpacingSemanticTokens"}],"navigatorTitle":[{"kind":"identifier","text":"MultipleFontLetterSpacingSemanticTokens"}],"role":"symbol","modules":[{"name":"Tokens for semantics"}],