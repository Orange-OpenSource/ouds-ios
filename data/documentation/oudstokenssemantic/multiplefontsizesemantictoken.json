{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontSizeSemanticToken","isActive":true,"type":"reference"},{"text":" depending to size classes.","type":"text"},{"text":" ","type":"text"},{"text":"Allows to gather the multiple-value tokens from Figma inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a font size exists with its value depending to the size class, it must be packed in such ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticToken","isActive":true,"type":"reference"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontSizeSemanticToken"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"syntax":"swift","code":["        \/\/ Assuming in Figma with have a font size semantic token sizeBodySmall,","        \/\/ two semantic font size tokens will be defined in Figma and generated by tokenator because","        \/\/ its value can vary if compact or regular modes.","        \/\/ They can be declared in protocol FontSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+FontSemanticTokens extension","        var sizeBodySmallMobile: FontSizeSemanticToken { FontRawTokens.size150 }","        var sizeBodySmallTablet: FontSizeSemanticToken { FontRawTokens.size150 }","","        \/\/ Then the develoment team declares an \"higher\" level font size semantic token for sizeBodySmall","        \/\/ inside FontMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+FontMultipleSemanticTokens extension","        var sizeBodySmall: MultipleFontSizeSemanticToken { MultipleFontSizeSemanticToken(compact: sizeBodySmallMobile, regular: sizeBodySmallTablet) }","","        \/\/ If the same value is used whatever the size class is","        var sizeBodySmall: MultipleFontSizeSemanticToken { MultipleFontSizeSemanticToken(sizeBodySmallMobile) }","","        \/\/ The theme exposes both generated font size semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"type":"codeListing"},{"name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}],"style":"note","type":"aside"}],"kind":"content"}],"topicSections":[{"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticToken\/_(_:_:)"],"anchor":"Operators","generated":true,"title":"Operators"},{"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticToken\/init(_:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticToken\/init(compact:regular:)"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticToken\/compact","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticToken\/regular"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticToken\/isEqual(_:)"],"anchor":"Instance-Methods","generated":true,"title":"Instance Methods"},{"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticToken\/Comparable-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"identi