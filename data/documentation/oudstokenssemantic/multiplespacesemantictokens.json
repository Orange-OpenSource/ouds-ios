{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MultipleSpaceSemanticTokens","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"syntax":"swift","type":"codeListing","code":["        \/\/ Assuming in Figma with have a space semantic token scaled2xs,","        \/\/ two semantic size tokens will be defined in Figma and generated by tokenator because","        \/\/ its value can vary if compact or regular modes.","        \/\/ They can be declared in protocol SpaceSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+SpaceSemanticTokens extension","        @objc open var scaled2xsMobile: SpaceSemanticToken { DimensionRawTokens._50 }","        @objc open var scaled2xsTablet: SpaceSemanticToken { DimensionRawTokens._100 }","","        \/\/ Then the develoment team declares an \"higher\" level space semantic token for scaled2xs","        \/\/ inside SpaceMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+SpaceMultipleSemanticTokens extension","        var scaled2xs: MultipleSpaceSemanticTokens { MultipleSpaceSemanticTokens(compact: scaled2xsMobile, regular: scaled2xsTablet) }","","        \/\/ If the same value is used whatever the size class is","        var scaled2xs: MultipleSpaceSemanticTokens { MultipleSpaceSemanticTokens(scaled2xsTabley) }","","        \/\/ The theme exposes both generated font space semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"name":"Since","style":"note","type":"aside"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"relationshipsSecti