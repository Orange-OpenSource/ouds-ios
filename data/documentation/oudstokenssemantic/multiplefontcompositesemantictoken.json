{"hierarchy":{"paths":[["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"type":"codeVoice","code":"FontCompositeSemanticToken"},{"type":"text","text":" depending to size classes."},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" inside one object."},{"text":" ","type":"text"},{"text":"If a font token exists with its value depending to the size class, it must be packed in such ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","isActive":true,"type":"reference"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleFontCompositeSemanticToken","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"syntax":"swift","code":["        \/\/ Assuming in Figma with have a font semantic token displayLarge,","        \/\/ with values depending to size class. These values are defined as font composite raw tokens.","        let bold850 = FontCompositeSemanticToken(size: size850, lineHeight: lineHeight1050, weight: weight700, letterSpacing: letterSpacing850)","        let bold1450 = FontCompositeSemanticToken(size: size1450, lineHeight: lineHeight1850, weight: weight700, letterSpacing: letterSpacing1450)","","        \/\/ Then the develoment team declares an \"higher\" level font semantic token","        \/\/ inside FontCompositeSemanticTokens protocol,","        \/\/ and defined inside OrangeTheme+FontCompositeSemanticTokens extension","        var displayLarge: MultipleFontCompositeSemanticToken {","            MultipleFontCompositeSemanticToken(compact: bold850, regular: bold1450)","        }","","        \/\/ If the same font is used whatever the size class is","        var displayLarge: MultipleFontCompositeSemanticToken { MultipleFontCompositeSemanticToken(bold650) }","","        \/\/ The theme exposes both generated elevation semantic tokens and \"crafted\" higher level elevation semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The case of this "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","isActive":true},{"type":"text","text":" is quite particular because in fact it contains "},{"type":"codeVoice","code":"FontCompositeSemanticToken"},{"type":"text","text":" "},{"type":"text","text":"(i.e. raw tokens) instead of semantic tokens."},{"type":"text","text":" "},{"type":"text","text":"In fact there is not “font composite semantic tokens” defined in the "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" kit."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"0.22.0","type":"text"}]}],"name":"Since","style":"note","type":"aside"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplefontcompositesemantictoken"]}],"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"MultipleFontCompositeSemanticToken","kind":"identifier"}],"modules":[{"name":"Tokens for semantics"}],"externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleFontCompositeSemanticToken","symbo