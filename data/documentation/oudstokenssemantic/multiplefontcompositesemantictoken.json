{"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(cs)NSObject"],"kind":"relationships","title":"Inherits From"},{"type":"conformsTo","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(pl)NSObject","doc:\/\/OUDSTokensSemantic\/s7CVarArgP","doc:\/\/OUDSTokensSemantic\/SL","doc:\/\/OUDSTokensSemantic\/s28CustomDebugStringConvertibleP","doc:\/\/OUDSTokensSemantic\/s23CustomStringConvertibleP","doc:\/\/OUDSTokensSemantic\/SQ","doc:\/\/OUDSTokensSemantic\/SH","doc:\/\/OUDSTokensSemantic\/s8SendableP","doc:\/\/OUDSTokensSemantic\/s16SendableMetatypeP"],"kind":"relationships","title":"Conforms To"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontCompositeSemanticToken"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"syntax":"swift","type":"codeListing","code":["        \/\/ Assuming in Figma with have a font semantic token displayLarge,","        \/\/ with values depending to size class. These values are defined as font composite raw tokens.","        let bold850 = FontCompositeSemanticToken(size: size850, lineHeight: lineHeight1050, weight: weight700, letterSpacing: letterSpacing850)","        let bold1450 = FontCompositeSemanticToken(size: size1450, lineHeight: lineHeight1850, weight: weight700, letterSpacing: letterSpacing1450)","","        \/\/ Then the develoment team declares an \"higher\" level font semantic token","        \/\/ inside FontCompositeSemanticTokens protocol,","        \/\/ and defined inside OrangeTheme+FontCompositeSemanticTokens extension","        var displayLarge: MultipleFontCompositeSemanticToken {","            MultipleFontCompositeSemanticToken(compact: bold850, regular: bold1450)","        }","","        \/\/ If the same font is used whatever the size class is","        var displayLarge: MultipleFontCompositeSemanticToken { MultipleFontCompositeSemanticToken(bold650) }","","        \/\/ The theme exposes both generated elevation semantic tokens and \"crafted\" higher level elevation semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The case of this "},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","type":"reference","isActive":true},{"type":"text","text":" is quite particular because in fact it contains "},{"type":"codeVoice","code":"FontCompositeSemanticToken"},{"type":"text","text":" "},{"type":"text","text":"(i.e. raw tokens) instead of semantic tokens."},{"type":"text","text":" "},{"type":"text","text":"In fact there is not “font composite semantic tokens” defined in the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" kit."}]},{"type":"aside","name":"Since","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.22.0"}]}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplefontcompositesemantictoken"]}],"metadata":{"modules":[{"name":"Tokens for semantics"}],"role":"symbol","title":"MultipleFontCompositeSemanticToken","roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontCompositeSemanticToken"}],"externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleFontCompositeSemanticToken","navigatorTitle":[{"kind":"identifier","text":"MultipleFontCompositeSemanticToken"}],"symbolKind":"class"},"schemaVersion":{"minor":3,"major":0,