vation semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The case of this "},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","type":"reference","isActive":true},{"type":"text","text":" is quite particular because in fact it contains "},{"type":"codeVoice","code":"FontCompositeSemanticToken"},{"type":"text","text":" "},{"type":"text","text":"(i.e. raw tokens) instead of semantic tokens."},{"type":"text","text":" "},{"type":"text","text":"In fact there is not “font composite semantic tokens” defined in the "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" kit."}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"0.22.0","type":"text"}],"type":"paragraph"}],"name":"Since"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplefontcompositesemantictoken"]}],"identifier":{"url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontCompositeSemanticToken"}],"symbolKind":"class","externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleFontCompositeSemanticToken","modules":[{"name":"Tokens for semantics"}],"navigatorTitle":[{"text":"MultipleFontCompositeSemanticToken","kind":"identifier"}],"roleHeading":"Class","title":"MultipleFontCompositeSemanticToken"},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(cs)NSObject"],"type":"inheritsFrom","title":"Inherits From"},{"kind":"relationships","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(pl)NSObject","doc:\/