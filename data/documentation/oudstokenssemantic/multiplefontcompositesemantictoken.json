{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleFontCompositeSemanticToken","modules":[{"name":"Tokens for semantics"}],"symbolKind":"class","title":"MultipleFontCompositeSemanticToken","roleHeading":"Class","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontCompositeSemanticToken"}],"navigatorTitle":[{"kind":"identifier","text":"MultipleFontCompositeSemanticToken"}]},"kind":"symbol","abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"code":"FontCompositeSemanticToken","type":"codeVoice"},{"type":"text","text":" depending to size classes."},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a font token exists with its value depending to the size class, it must be packed in such "},{"isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","type":"reference"},{"type":"text","text":"."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplefontcompositesemantictoken"]}],"topicSections":[{"generated":true,"anchor":"Operators","title":"Operators","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken\/_(_:_:)"]},{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken\/init(_:)","doc:\/\/O