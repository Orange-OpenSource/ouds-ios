text":"Overview"},{"type":"codeListing","syntax":"swift","code":["        \/\/ Assuming in Figma with have a font semantic token displayLarge,","        \/\/ with values depending to size class. These values are defined as font composite raw tokens.","        let bold850 = FontCompositeSemanticToken(size: size850, lineHeight: lineHeight1050, weight: weight700, letterSpacing: letterSpacing850)","        let bold1450 = FontCompositeSemanticToken(size: size1450, lineHeight: lineHeight1850, weight: weight700, letterSpacing: letterSpacing1450)","","        \/\/ Then the develoment team declares an \"higher\" level font semantic token","        \/\/ inside FontCompositeSemanticTokens protocol,","        \/\/ and defined inside OrangeTheme+FontCompositeSemanticTokens extension","        var displayLarge: MultipleFontCompositeSemanticToken {","            MultipleFontCompositeSemanticToken(compact: bold850, regular: bold1450)","        }","","        \/\/ If the same font is used whatever the size class is","        var displayLarge: MultipleFontCompositeSemanticToken { MultipleFontCompositeSemanticToken(bold650) }","","        \/\/ The theme exposes both generated elevation semantic tokens and \"crafted\" higher level elevation semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"type":"paragraph","inlineContent":[{"text":"The case of this ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","isActive":true},{"text":" is quite particular because in fact it contains ","type":"text"},{"type":"codeVoice","code":"FontCompositeSemanticToken"},{"text":" ","type":"text"},{"text":"(i.e. raw tokens) instead of semantic tokens.","type":"text"},{"text":" ","type":"text"},{"text":"In fact there is not “font composite semantic tokens” defined in the ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" kit.","type":"text"}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.22.0"}]}],"type":"aside","name":"Since"}],"kind":"content"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken"},"hierarchy":{"paths":[["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"references":{"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleFontCompositeSemanticToken/init(compact:regular:)":{"url":"\/documentation\/oudstokenssemantic\/multiplefontcompositesemantictoken\/init(compact:regular:)","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"compact"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSTokensSemantic013FontCompositeB5TokenV","kind":"typeIdentifier","text":"FontCompositeSemanticToken"},{"kind":"text","text":", "},{"kind":"externalParam","text":"regular"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSTokensSemantic013FontCompositeB5TokenV","kind":"typeIdentifier","text":"FontCompositeSemanticToken"},{"kind":"text","text":")"}],"abstract":[{"type":"text","text":"Initializes a new font composite semantic token."}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken\/init(compact:regular:)","type":"topic","role":"symbol","title":"init(compact:regular:)"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleFontCompositeSemanticToken/regular":{"abstract":[{"type":"text","text":"For "},{"type":"strong","inlineContent":[{"text":"regular","type":"text"}]},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"text":"medium","type":"text"}]},{"type":"text","text":" viewports"}],"title":"regular","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken\/re