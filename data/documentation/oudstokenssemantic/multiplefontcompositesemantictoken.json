ever the size class is","        var displayLarge: MultipleFontCompositeSemanticToken { MultipleFontCompositeSemanticToken(bold650) }","","        \/\/ The theme exposes both generated elevation semantic tokens and \"crafted\" higher level elevation semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"inlineContent":[{"type":"text","text":"The case of this "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeSemanticToken","isActive":true},{"type":"text","text":" is quite particular because in fact it contains "},{"type":"codeVoice","code":"FontCompositeSemanticToken"},{"type":"text","text":" "},{"type":"text","text":"(i.e. raw tokens) instead of semantic tokens."},{"type":"text","text":" "},{"type":"text","text":"In fact there is not “font composite semantic tokens” defined in the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" kit."}],"type":"paragraph"},{"style":"note","content":[{"inlineContent":[{"text":"0.22.0","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Since"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"type":"codeVoice","code":"FontCompositeSemanticToken"},{"text":" depending to size classes.","type":"text"},{"text":" ","type":"text"},{"text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system.","type":"text"},{"text":" ","type":"text"},{"text":"Allows to gather the multiple-value tokens from ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a font token exists with its value depending to the size class, it must be packed in such ","type":"text"},{"isActive":true,"type":"re