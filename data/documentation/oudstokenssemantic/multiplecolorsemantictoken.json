{"relationshipsSections":[{"title":"Inherits From","kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(cs)NSObject"]},{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(pl)NSObject","doc:\/\/OUDSTokensSemantic\/s7CVarArgP","doc:\/\/OUDSTokensSemantic\/s28CustomDebugStringConvertibleP","doc:\/\/OUDSTokensSemantic\/s23CustomStringConvertibleP","doc:\/\/OUDSTokensSemantic\/SQ","doc:\/\/OUDSTokensSemantic\/SH","doc:\/\/OUDSTokensSemantic\/s8SendableP","doc:\/\/OUDSTokensSemantic\/s16SendableMetatypeP"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleColorSemanticToken","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"code":["        \/\/ Assuming in Figma with have a color semantic token bgPrimary,","        \/\/ two semantic color tokens will be defined in Figma and generated by tokenator.","        \/\/ They can be declared in protocol ColorSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+ColorSemanticTokens extension","        var bgPrimaryLight: ColorSemanticToken { ColorRawTokens.functionalWhite }","        var bgPrimaryDark: ColorSemanticToken { ColorRawTokens.functionalDarkGray880 }","","        \/\/ Then the develoment team declares an \"higher\" level color semantic token for bgPrimary","        \/\/ inside ColorMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+ColorMultipleSemanticToken extension","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(light: bgPrimaryLight, dark: bgPrimaryDark) }","","        \/\/ If the same color is used whatever the color scheme is","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(bgPrimaryLight) }","","        \/\/ The theme exposes both generated color semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"syntax":"swift","type":"codeListing"},{"code":["     @Environment(\\.theme) var theme","     @Environment(\\.colorScheme) var colorScheme","","    \/\/ Given you want to apply the color token \"surfaceBrandPrimary\"","    var body: some View {","        \/\/ Apply the token of color for the view without managing yourself the color scheme","        SomeView()","            .background(theme.colors.surfaceBrandPrimary)","","        \/\/ Or also foregroundStyle(), foregroundColor(), accentColor(), ...","    }"],"syntax":"swift","type":"codeListing"},{"code":["    \/\/ Or get the token depending to the color scheme and do whatever you want with","    theme.colors.surfaceBrandPrimary.color(for: colorScheme)"],"syntax":"swift","type":"codeListing"},{"content":[{"inlineContent":[{"text":"0.8.0","type":"text"}],"type":"paragraph"}],"name":"Since","type":"aside","style":"note"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudstokenssemantic\/multiplecolorsemantictoken"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/init(_:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/init(light:dark:)"]},{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/dark","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/light"]},{"anchor":"Instance-Methods","title":"Instance Methods","generated":true,"identifiers":["doc:\/