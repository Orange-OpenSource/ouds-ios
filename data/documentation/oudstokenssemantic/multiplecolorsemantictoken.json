tent","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"syntax":"swift","type":"codeListing","code":["        \/\/ Assuming in Figma with have a color semantic token bgPrimary,","        \/\/ two semantic color tokens will be defined in Figma and generated by tokenator.","        \/\/ They can be declared in protocol ColorSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+ColorSemanticTokens extension","        var bgPrimaryLight: ColorSemanticToken { ColorRawTokens.functionalWhite }","        var bgPrimaryDark: ColorSemanticToken { ColorRawTokens.functionalDarkGray880 }","","        \/\/ Then the develoment team declares an \"higher\" level color semantic token for bgPrimary","        \/\/ inside ColorMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+ColorMultipleSemanticToken extension","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(light: bgPrimaryLight, dark: bgPrimaryDark) }","","        \/\/ If the same color is used whatever the color scheme is","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(bgPrimaryLight) }","","        \/\/ The theme exposes both generated color semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"syntax":"swift","type":"codeListing","code":["     @Environment(\\.theme) var theme","     @Environment(\\.colorScheme) var colorScheme","","    \/\/ Given you want to apply the color token \"surfaceBrandPrimary\"","    var body: some View {","        \/\/ Apply the token of color for the view without managing yourself the color scheme","        SomeView()","            .background(theme.colors.surfaceBrandPrimary)","","        \/\/ Or also foregroundStyle(), foregroundColor(), accentColor(), ...","    }"]},{"syntax":"swift","type":"codeListing","code":["    \/\/ Or get the token depending to the color scheme and do whatever you want with","    theme.colors.surfaceBrandPrimary.color(for: colorScheme)"]},{"style":"note","content":[{"inlineContent":[{"text":"0.8.0","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Since"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplecolorsemantictoken"]}],"identifier":{"url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorSemanticToken"},{"text":" depending to ","type":"text"},{"inlineContent":[{"type":"text","text":"color scheme"}],"type":"emphasis"},{"text":" (i.e. ligh mode or dark mode).","type":"text"},{"text":" ","type":"text"},{"text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system.","type":"text"},{"text":" ","type":"text"},{"text":"Allows to gather the multiple-value tokens from ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a color token exists with its value depending to the color scheme, it must be packed in such ``MultipleColorSemanticToken`","type":"text"}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"MultipleColorSemanticToken"}],"modules":[{"name":"Tokens for semantics"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleColorSemanticToken"}],"role":"symbol","title":"MultipleColorSemanticToken","symbolKind":"class","externalID":"c:@M@OUDSTokensSemantic@objc(cs)Multi