{"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/init(_:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/init(light:dark:)"],"generated":true},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/dark","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/light"],"generated":true},{"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/color(for:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/hasForbiddenColorValue()","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/isEqual(_:)"],"generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplecolorsemantictoken"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleColorSemanticToken","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"syntax":"swift","type":"codeListing","code":["        \/\/ Assuming in Figma with have a color semantic token bgPrimary,","        \/\/ two semantic color tokens will be defined in Figma and generated by tokenator.","        \/\/ They can be declared in protocol ColorSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+ColorSemanticTokens extension","        var bgPrimaryLight: ColorSemanticToken { ColorRawTokens.functionalWhite }","        var bgPrimaryDark: ColorSemanticToken { ColorRawTokens.functionalDarkGray880 }","","        \/\/ Then the develoment team declares an \"higher\" level color semantic token for bgPrimary","        \/\/ inside ColorMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+ColorMultipleSemanticToken extension","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(light: bgPrimaryLight, dark: bgPrimaryDark) }","","        \/\/ If the same color is used whatever the color scheme is","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(bgPrimaryLight) }","","        \/\/ The theme exposes both generated color semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"syntax":"swift","type":"codeListing","code":["     @Environment(\\.theme) var theme","     @Environment(\\.colorScheme) var colorScheme","","    \/\/ Given you want to apply the color token \"surfaceBrandPrimary\"","    var body: some View {","        \/\/ Apply the token of color for the view without managing yourself the color scheme","        SomeView()","            .background(theme.colors.surfaceBrandPrimary)","","        \/\/ Or also foregroundStyle(), foregroundColor(), accentColor(), ...","    }"]},{"syntax":"swift","type":"codeListing","code":["    \/\/ Or get the token depending to the color scheme and do whatever you want with","    theme.colors.surfaceBrandPrimary.color(for: colorScheme)"]},{"name":"Since","type":"aside","content":[{"inlineContent":[{"type":"text","text":"0.8.0"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"metadata":{"externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticToken","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleColorSemanticToken","kind":"identifier"}],"roleHeading":"Class","navigatorTitle":[{"text":"MultipleColorSemant