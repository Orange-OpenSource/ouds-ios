ic color tokens will be defined in Figma and generated by tokenator.","        \/\/ They can be declared in protocol ColorSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+ColorSemanticTokens extension","        var bgPrimaryLight: ColorSemanticToken { ColorRawTokens.functionalWhite }","        var bgPrimaryDark: ColorSemanticToken { ColorRawTokens.functionalDarkGray880 }","","        \/\/ Then the develoment team declares an \"higher\" level color semantic token for bgPrimary","        \/\/ inside ColorMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+ColorMultipleSemanticToken extension","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(light: bgPrimaryLight, dark: bgPrimaryDark) }","","        \/\/ If the same color is used whatever the color scheme is","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(bgPrimaryLight) }","","        \/\/ The theme exposes both generated color semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"syntax":"swift","type":"codeListing"},{"code":["     @Environment(\\.theme) var theme","     @Environment(\\.colorScheme) var colorScheme","","    \/\/ Given you want to apply the color token \"surfaceBrandPrimary\"","    var body: some View {","        \/\/ Apply the token of color for the view without managing yourself the color scheme","        SomeView()","            .background(theme.colors.surfaceBrandPrimary)","","        \/\/ Or also foregroundStyle(), foregroundColor(), accentColor(), ...","    }"],"syntax":"swift","type":"codeListing"},{"code":["    \/\/ Or get the token depending to the color scheme and do whatever you want with","    theme.colors.surfaceBrandPrimary.color(for: colorScheme)"],"syntax":"swift","type":"codeListing"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}],"type":"aside","name":"Since"}]}],"references":{"doc://OUDSTokensSemantic/s28CustomDebugStringConvertibleP":{"identifier":"doc:\/\/OUDSTokensSemantic\/s28CustomDebugStringConvertibleP","type":"unresolvable","title":"Swift.CustomDebugStringConvertible"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleColorSemanticToken/isEqual(_:)":{"url":"\/documentation\/oudstokenssemantic\/multiplecolorsemantictoken\/isequal(_:)","title":"isEqual(_:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isEqual","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"?) -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Returns "},{"code":"true","type":"codeVoice"},{"type":"text","text":" if "},{"code":"self","type":"codeVoice"},{"type":"text","text":" and "},{"code":"object","type":"codeVoice"},{"type":"text","text":" has the same "},{"code":"light","type":"codeVoice"},{"type":"text","text":" and "},{"code":"dark","type":"codeVoice"},{"type":"text","text":" values and with "},{"code":"object","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"as a "},{"code":"MultipleColorRawToken","type":"codeVoice"},{"type":"text","text":". Otherwise returns "},{"code":"false","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"code":"isEqual","type":"codeVoice"},{"type":"text","text":" override is preferred for "},{"code":"NSObject","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorSemanticToken\/isEqual(_:)"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleColorSemanticToken":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"MultipleColorSemanticToken","kind":"identifier"}],"kind":"symbol","type":"topic"