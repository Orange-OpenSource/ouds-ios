n the develoment team declares an \"higher\" level color semantic token for bgPrimary","        \/\/ inside ColorMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+ColorMultipleSemanticToken extension","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(light: bgPrimaryLight, dark: bgPrimaryDark) }","","        \/\/ If the same color is used whatever the color scheme is","        var bgPrimary: MultipleColorSemanticToken { MultipleColorSemanticToken(bgPrimaryLight) }","","        \/\/ The theme exposes both generated color semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"type":"codeListing","syntax":"swift","code":["     @Environment(\\.theme) var theme","     @Environment(\\.colorScheme) var colorScheme","","    \/\/ Given you want to apply the color token \"surfaceBrandPrimary\"","    var body: some View {","        \/\/ Apply the token of color for the view without managing yourself the color scheme","        SomeView()","            .background(theme.colors.surfaceBrandPrimary)","","        \/\/ Or also foregroundStyle(), foregroundColor(), accentColor(), ...","    }"]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Or get the token depending to the color scheme and do whatever you want with","    theme.colors.surfaceBrandPrimary.color(for: colorScheme)"]},{"name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"style":"note"}]}],"metadata":{"externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticToken","modules":[{"name":"Tokens for semantics"}],"symbolKind":"class","role":"symbol","title":"MultipleColorSemanticToken","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleColorSemanticToken"}],"roleHeading":"Class","navigatorTitle":[{"text":"MultipleColorSemantic