oken \"surfaceBrandPrimary\"","    var body: some View {","        \/\/ Apply the token of color for the view without managing yourself the color scheme","        SomeView()","            .background(theme.colors.surfaceBrandPrimary)","","        \/\/ Or also foregroundStyle(), foregroundColor(), accentColor(), ...","    }"],"type":"codeListing"},{"syntax":"swift","code":["    \/\/ Or get the token depending to the color scheme and do whatever you want with","    theme.colors.surfaceBrandPrimary.color(for: colorScheme)"],"type":"codeListing"},{"style":"note","name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}]}],"kind":"content"}],"metadata":{"title":"MultipleColorSemanticToken","roleHeading":"Class","symbolKind":"class","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MultipleColorSemanticToken","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MultipleColorSemanticToken"}],"modules":[{"name":"Tokens for semantics"}],"role":"symbol","externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticToken"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplecolorsemantictoken"]}],"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(cs)NSObject"],"title":"Inherits From"},{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/OUDSTokensSemantic\/objc(pl)NSObject","doc:\/\/OUDSTokensSemantic\/s7CVarArgP","doc:\/\/OUDSTokensSemantic\/s28CustomDebugStringConvertibleP","doc:\/\/OUDSTokensSemantic\/s23CustomStringConvertibleP","doc:\/\/OUDSTokensSemantic\/SQ","doc:\/\/OUDSTokensSemantic\/SH","doc:\/\/OUDSTokensSemantic\/s8SendableP","doc:\/\/OUDSTokensSemantic\/s16SendableMetatypeP"],"title":"Conforms To"}],"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSTokensSe