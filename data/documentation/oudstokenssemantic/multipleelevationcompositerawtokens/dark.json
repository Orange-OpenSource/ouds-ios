e multiple-value tokens from "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If an elevation token exists with its value depending to the color scheme, it must be packed in such ``MultipleElevationCompositeRawTokens`"}],"kind":"symbol","title":"MultipleElevationCompositeRawTokens","role":"symbol","url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtokens","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleElevationCompositeRawTokens","kind":"identifier"}]},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationCompositeRawTokens/dark":{"type":"topic","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens\/dark","abstract":[{"type":"text","text":"For "},{"type":"strong","inlineContent":[{"type":"text","text":"dark"}]},{"type":"text","text":" mode scheme"}],"kind":"symbol","title":"dark","role":"symbol","url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtokens\/dark","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"dark","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ElevationCompositeRawToken","kind":"typeIdentifier","preciseIdentifier":"c:@M@OUDSTokensRaw@objc(cs)ElevationCompositeRawToken"}]}}}