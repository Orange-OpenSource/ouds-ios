antic tokens which will wrap a combination of "},{"type":"codeVoice","code":"ElevationCompositeRawToken"},{"type":"text","text":" depending to color scheme (i.e. light mode or dark mode)"},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If an elevation token exists with its value depending to the color scheme, it must be packed in such ``MultipleElevationCompositeRawTokens`"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleElevationCompositeRawTokens"}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens","url":"\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtokens","navigatorTitle":[{"kind":"identifier","text":"MultipleElevationCompositeRawTokens"}],"type":"topic"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationCompositeRawToken":{"title":"ElevationCompositeRawToken","url":"\/documentation\/oudstokensraw\/elevationcompositerawtoken","kind":"symbol","fragments":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationCompositeRawToken"}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","abstract":[{"type":"text","text":"In the "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" global design system, composite tokens are defined for elevation effects."},{"type":"text","text":" "},{"type":"text","text":"Composite tokens are tokens defined in "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here an "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" is caracterized by "},{"inlineContent":[{"text":"X and Y offsets","type":"text"}],"type":"emphasis"},{"type":"text","text":", a "},{"inlineContent":[{"type":"text","text":"radius"}],"type":"emphasis"},{"type":"text","text":" for the shadow and a "},{"inlineContent":[{"text":"color","type":"text"}],"type":"emphasis"},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"inlineContent":[{"type":"text","text":"raw tokens"}],"type":"emphasis"},{"type":"text","text":", and together define a "},{"inlineContent":[{"text":"composite raw token","type":"text"}],"type":"emphasis"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"code":"final class","type":"codeVoice"},{"type":"text","text":" and "},{"code":"NSObject","type":"codeVoice"},{"type":"text","text":" so as to be shared through "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" with extensions and protocols within modules."}],"type":"topic","role":"symbol"}}}