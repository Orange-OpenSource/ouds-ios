:"Composite tokens are tokens defined in "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here an "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" is caracterized by "},{"inlineContent":[{"text":"X and Y offsets","type":"text"}],"type":"emphasis"},{"type":"text","text":", a "},{"inlineContent":[{"type":"text","text":"radius"}],"type":"emphasis"},{"type":"text","text":" for the shadow and a "},{"inlineContent":[{"text":"color","type":"text"}],"type":"emphasis"},{"type":"text","text":" to apply on that shadow."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"inlineContent":[{"type":"text","text":"raw tokens"}],"type":"emphasis"},{"type":"text","text":", and together define a "},{"inlineContent":[{"text":"composite raw token","type":"text"}],"type":"emphasis"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"elevation"}],"type":"emphasis"},{"type":"text","text":" effect."},{"type":"text","text":" "},{"type":"text","text":"It is defined as a "},{"code":"final class","type":"codeVoice"},{"type":"text","text":" and "},{"code":"NSObject","type":"codeVoice"},{"type":"text","text":" so as to be shared through "},{"code":"@objc","type":"codeVoice"},{"type":"text","text":" with extensions and protocols within modules."}],"type":"topic","role":"symbol"},"ic_design_token_figma_semantic.png":{"alt":null,"variants":[{"url":"\/images\/OUDSTokensSemantic\/ic_design_token_figma_semantic.png","traits":["1x","light"]}],"identifier":"ic_design_token_figma_semantic.png","type":"image"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleElevationCompositeRawTokens":{"kind":"symbol","role":"symbol","title":"MultipleElevationCompositeRawTokens","abstract":[{"type":"text","text":"Semantic tokens which will wrap a combination of "},{"type":"codeVoice","code":"