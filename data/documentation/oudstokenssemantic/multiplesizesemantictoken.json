ocol SizeSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+SizeSemanticTokens extension","        var iconWithHeadingXLargeTallMobile: SizeSemanticToken { DimensionRawTokens._650 }","        var iconWithHeadingXLargeTallTablet: SizeSemanticToken { DimensionRawTokens._800 }","","        \/\/ Then the develoment team declares an \"higher\" level size semantic token for iconWithHeadingXLargeTall","        \/\/ inside SizeMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+SizeMultipleSemanticTokens extension","        var iconWithHeadingXLargeTall: MultipleSizeSemanticToken {","            MultipleSizeSemanticToken(compact: iconWithHeadingXLargeTallMobile, regular: iconWithHeadingXLargeTallTablet)","        }","","        \/\/ If the same value is used whatever the size class is","        var iconWithHeadingXLargeTall: MultipleSizeSemanticToken { MultipleSizeSemanticToken(iconWithHeadingXLargeTallTablet) }","","        \/\/ The theme exposes both generated font size semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"syntax":"swift","type":"codeListing"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"0.8.0"}],"type":"paragraph"}],"type":"aside","name":"Since"}],"kind":"content"}],"references":{"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleSizeSemanticToken/compact":{"kind":"symbol","title":"compact","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"compact","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","text":"SizeSemanticToken","kind":"typeIdentifier"}],"role":"symbol","url":"\/documentation\/oudstokenssemantic\/multiplesizesemantictoken\/compact","type":"topic","abstract":[{"text":"For ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"extra-compact"}]},{"tex