{"identifier":{"url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticToken","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SizeSemanticToken","isActive":true},{"type":"text","text":" depending to viewports \/ size classes."},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from Figma inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a size token exists with its value depending to the size class, it must be packed in such "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticToken","isActive":true},{"type":"text","text":"."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleSizeSemanticToken","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"syntax":"swift","type":"codeListing","code":["        \/\/ Assuming in Figma with have a size semantic token iconWithHeadingXLargeTall,","        \/\/ two semantic size tokens will be defined in Figma and generated by tokenator because","        \/\/ its value can vary if compact or regular modes.","        \/\/ They can be declared in protocol SizeSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+SizeSemanticTokens extension","        var iconWithHeadingXLargeTallMobile: SizeSemanticToken { DimensionRawTokens._650 }","        var iconWithHeadingXLargeTallTablet: SizeSemanticToken { DimensionRawTokens._800 }","","        \/\/ Then the develoment team declares an \"higher\" level size semantic token for iconWithHeadingXLargeTall","        \/\/ inside SizeMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+SizeMultipleSemanticTokens extension","        var iconWithHeadingXLargeTall: MultipleSizeSemanticToken {","            MultipleSizeSemanticToken(compact: iconWithHeadingXLargeTallMobile, regular: iconWithHeadingXLargeTallTablet)","        }","","        \/\/ If the same value is used whatever the size class is","        var iconWithHeadingXLargeTall: MultipleSizeSemanticToken { MultipleSizeSemanticToken(iconWithHeadingXLargeTallTablet) }","","        \/\/ The theme exposes both generated font size semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}],"style":"note"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplesizesemantictoken"]}],"metadata":{"externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleSizeSemanticToken","symbolKind":"class","modules":[{"name":"Tokens for semantics"}],"title":"MultipleSizeSemanticToken","role":"symbol","roleHeading":"Class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleSizeSemanticToken","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MultipleSizeSemanticToken"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"generated":true,"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticToken\/init(_:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSizeSemanticToken\/init(compact:regular:)"],"ancho