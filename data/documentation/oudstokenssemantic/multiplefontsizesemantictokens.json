{"abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontSizeSemanticToken","isActive":true},{"type":"text","text":" depending to size classes."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from Figma inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a font size exists with its value depending to the size class, it must be packed in such "},{"type":"reference","identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens","isActive":true},{"type":"text","text":"."}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleFontSizeSemanticTokens","kind":"identifier"}],"symbolKind":"class","modules":[{"name":"Tokens for semantics"}],"roleHeading":"Class","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MultipleFontSizeSemanticTokens"}],"externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleFontSizeSemanticTokens","title":"MultipleFontSizeSemanticTokens"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontSizeSemanticTokens"}],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"code":["        \/\/ Assuming in Figma with have a font size semantic token sizeBodySmall,","        \/\/ two semantic font size tokens will be defined in Figma and generated by tokenator because","        \/\/ its value can vary if compact or regular modes.","        \/\/ They can be declared in protocol FontSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+FontSemanticTokens extension","        var sizeBodySmallMobile: FontSizeSemanticToken { FontRawTokens.size150 }","        var sizeBodySmallTablet: FontSizeSemanticToken { FontRawTokens.size150 }","","        \/\/ Then the develoment team declares an \"higher\" level font size semantic token for sizeBodySmall","        \/\/ inside FontMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+FontMultipleSemanticTokens extension","        var sizeBodySmall: MultipleFontSizeSemanticTokens { MultipleFontSizeSemanticTokens(compact: sizeBodySmallMobile, regular: sizeBodySmallTablet) }","","        \/\/ If the same value is used whatever the size class is","        var sizeBodySmall: MultipleFontSizeSemanticTokens { MultipleFontSizeSemanticTokens(sizeBodySmallMobile) }","","        \/\/ The theme exposes both generated font size semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"type":"codeListing","syntax":"swift"},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.8.0"}],"type":"paragraph"}]}],"kind":"content"}],"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/init(_:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/init(compact:regular:)"],"generated":true},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/compact","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/regular"],"generated":true},{"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\