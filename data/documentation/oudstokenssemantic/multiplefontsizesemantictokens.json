 }","","        \/\/ If the same value is used whatever the size class is","        var sizeBodySmall: MultipleFontSizeSemanticTokens { MultipleFontSizeSemanticTokens(sizeBodySmallMobile) }","","        \/\/ The theme exposes both generated font size semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"type":"codeListing"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"0.8.0"}],"type":"paragraph"}],"type":"aside","name":"Since"}],"kind":"content"}],"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontSizeSemanticTokens"}],"navigatorTitle":[{"kind":"identifier","text":"MultipleFontSizeSemanticTokens"}],"symbolKind":"class","modules":[{"name":"Tokens for semantics"}],"roleHeading":"Class","title":"MultipleFontSizeSemanticTokens","externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleFontSizeSemanticTokens","role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplefontsizesemantictokens"]}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens"},"abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontSizeSemanticToken","type":"reference","isActive":true},{"text":" depending to size classes.","type":"text"},{"text":" ","type":"text"},{"text":"Allows to gather the multiple-value tokens from Figma inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a font size exists with its value depending to the size class, it must be packed in such ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDS