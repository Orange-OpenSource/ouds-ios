{"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/FontSizeSemanticToken","isActive":true,"type":"reference"},{"text":" depending to size classes.","type":"text"},{"text":" ","type":"text"},{"text":"Allows to gather the multiple-value tokens from Figma inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a font size exists with its value depending to the size class, it must be packed in such ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens","isActive":true,"type":"reference"},{"text":".","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontSizeSemanticTokens"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"code":["        \/\/ Assuming in Figma with have a font size semantic token sizeBodySmall,","        \/\/ two semantic font size tokens will be defined in Figma and generated by tokenator because","        \/\/ its value can vary if compact or regular modes.","        \/\/ They can be declared in protocol FontSemanticTokens,","        \/\/ and defined automaticaly in OUDSTheme+FontSemanticTokens extension","        var sizeBodySmallMobile: FontSizeSemanticToken { FontRawTokens.size150 }","        var sizeBodySmallTablet: FontSizeSemanticToken { FontRawTokens.size150 }","","        \/\/ Then the develoment team declares an \"higher\" level font size semantic token for sizeBodySmall","        \/\/ inside FontMultipleSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+FontMultipleSemanticTokens extension","        var sizeBodySmall: MultipleFontSizeSemanticTokens { MultipleFontSizeSemanticTokens(compact: sizeBodySmallMobile, regular: sizeBodySmallTablet) }","","        \/\/ If the same value is used whatever the size class is","        var sizeBodySmall: MultipleFontSizeSemanticTokens { MultipleFontSizeSemanticTokens(sizeBodySmallMobile) }","","        \/\/ The theme exposes both generated font size semantic tokens and \"crafted\" higher level color semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"syntax":"swift","type":"codeListing"},{"name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"type":"aside","style":"note"}],"kind":"content"}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/_(_:_:)"],"anchor":"Operators","title":"Operators"},{"generated":true,"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/init(_:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/init(compact:regular:)"],"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/compact","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/regular"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/isEqual(_:)"],"anchor":"Instance-Methods","title":"Instance Methods"},{"generated":true,"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontSizeSemanticTokens\/Comparable-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"relations