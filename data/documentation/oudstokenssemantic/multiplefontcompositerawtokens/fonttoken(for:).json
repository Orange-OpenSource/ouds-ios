 tokens from ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"text":" inside one object.","type":"text"},{"text":" ","type":"text"},{"text":"If a font token exists with its value depending to the size class, it must be packed in such ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens","type":"reference","isActive":true},{"text":".","type":"text"}],"role":"symbol","title":"MultipleFontCompositeRawTokens","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontCompositeRawTokens"}],"navigatorTitle":[{"kind":"identifier","text":"MultipleFontCompositeRawTokens"}],"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/FontCompositeRawToken":{"type":"topic","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"In the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" global design system, composite tokens are defined for font-related things."},{"type":"text","text":" "},{"type":"text","text":"Composite tokens are tokens defined in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" by other tokens."},{"type":"text","text":" "},{"type":"text","text":"Here a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font"}]},{"type":"text","text":" thing is caracterized by a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font size"}]},{"type":"text","text":", a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"line height"}]},{"type":"text","text":", a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font weight"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"letter spacing"}]},{"type":"text","text":" values."},{"type":"text","text":" "},{"type":"text","text":"All these elements are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":", and together define a "},{"type":"emphasis","inlineContent":[{"text":"composite raw token","type":"text"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font"}]},{"type":"text","text":" thing."}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/FontCompositeRawToken","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FontCompositeRawToken"}],"title":"FontCompositeRawToken","url":"\/documentation\/oudstokensraw\/fontcompositerawtoken"}}}