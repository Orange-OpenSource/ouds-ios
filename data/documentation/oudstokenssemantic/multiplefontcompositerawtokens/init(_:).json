teRawToken"},{"kind":"text","text":")"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"references":{"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleFontCompositeRawTokens/init(_:)":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens\/init(_:)","role":"symbol","url":"\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens\/init(_:)","kind":"symbol","abstract":[{"type":"text","text":"Initializes a new font composite semantic token."}],"title":"init(_:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:13OUDSTokensRaw013FontCompositeB5TokenV","text":"FontCompositeRawToken"},{"kind":"text","text":")"}],"type":"topic"},"doc://OUDSTokensSemantic/documentation/OUDSTokensSemantic/MultipleFontCompositeRawTokens":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens","abstract":[{"type":"text","text":"Kind of semantic tokens which will wrap a combination of "},{"code":"FontCompositeRawToken","type":"codeVoice"},{"type":"text","text":" depending to size classes."},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If a font token exists with its value depending to the size class, it must be packed in such "},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens","type":"reference","isActive":true},{"type":"text","text":"."}],"url":"\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","navi