eMutedLight,","                                            dark: onStatusNegativeMutedDark)","        }","","        \/\/ Use if light color scheme the monochrome dark mode, and if dark color scheme the monochrome light mode","        var onStatusNeutralEmphasizedLight: ColorModeSemanticToken { ColorModeRawTokens.monochromeDark }","        var onStatusNeutralEmphasizedDark: ColorModeSemanticToken { ColorModeRawTokens.monochromeLight }","        var onStatusNeutralEmphasized: MultipleColorModeSemanticToken {","            MultipleColorModeSemanticToken(\"some unique name\",","                                            light: onStatusNeutralEmphasizedLight,","                                            dark: onStatusNeutralEmphasizedDark)","        }"],"type":"codeListing"},{"style":"note","name":"Since","type":"aside","content":[{"inlineContent":[{"text":"0.13.0","type":"text"}],"type":"paragraph"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplecolormodesemantictoken"]}],"abstract":[{"text":"Kind of semantic tokens which will wrap a combination of ","type":"text"},{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/ColorModeSemanticToken","isActive":true,"type":"reference"},{"text":" depending to ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"color scheme"}]},{"text":" (i.e. light mode or dark mode).","type":"text"},{"text":" ","type":"text"},{"text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system.","type":"text"}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorModeSemanticToken\/init(_:_:)","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleColorModeSemanticTok