, you can simply use the theme through an environment variable to get the tokens:"}],"type":"paragraph"},{"syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"type":"codeListing"},{"text":"How to tune the theme","level":2,"anchor":"How-to-tune-the-theme","type":"heading"},{"inlineContent":[{"type":"text","text":"You cannot tune the Sosh theme."}],"type":"paragraph"},{"text":"Typography","level":2,"anchor":"Typography","type":"heading"},{"inlineContent":[{"type":"text","text":"The Wireframe theme uses the Shantell Sans font family and must not use others."}],"type":"paragraph"},{"text":"How to enrich the theme","level":2,"anchor":"How-to-enrich-the-theme","type":"heading"},{"inlineContent":[{"type":"text","text":"You cannot derivate the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Wireframe"}]},{"type":"text","text":" theme."}],"type":"paragraph"},{"text":"How it looks like","level":2,"anchor":"How-it-looks-like","type":"heading"},{"text":"Actions","level":3,"anchor":"Actions","type":"heading"},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Wireframe.png"}],"type":"paragraph"},{"text":"Content display","level":3,"anchor":"Content-display","type":"heading"},{"text":"Bullet list","level":4,"anchor":"Bullet-list","type":"heading"},{"inlineContent":[{"type":"image","ident