":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: WireframeTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"level":2,"text":"How to tune the theme","type":"heading","anchor":"How-to-tune-the-theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You cannot tune the Sosh theme."}]},{"level":2,"text":"Typography","type":"heading","anchor":"Typography"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Wireframe theme uses the Shantell Sans font family and must not use others."}]},{"level":2,"text":"How to enrich the theme","type":"heading","anchor":"How-to-enrich-the-theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You cannot derivate the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Wireframe"}]},{"type":"text","text":" theme."}]},{"level":2,"text":"How it looks like","type":"heading","anchor":"How-it-looks-like"},{"level":3,"text":"Actions","type":"heading","anchor":"Actions"},{"type":"paragraph","inlineContent":[{"type