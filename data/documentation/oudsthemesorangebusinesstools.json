{"identifier":{"url":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"The Orange Business Tools theme is dedicated to applications with strong dimensions constraints."}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"codeListing","syntax":null,"code":["🧬 Theme version: 2.1.0"]},{"inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this theme exists."}],"type":"paragraph"},{"name":"Note","type":"aside","content":[{"inlineContent":[{"text":"This theme is related to Orange theme module to use some raw tokens of colors.","type":"text"}],"type":"paragraph"}],"style":"note"},{"name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"It contains also colors dedicated to charts."}],"type":"paragraph"}],"style":"note"},{"name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The Orange Business Tools theme is read-only: it cannot be suclassed or derivated.","type":"text"}]}],"style":"important"},{"type":"heading","anchor":"How-to-use-the-theme","text":"How to use the theme","level":2},{"inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","isActive":true},{"type":"text","text":" directly. To use the "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","isActive":true},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeBusinessToolsTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"inlineContent":[{"text":"This theme embeds and registers the fonts for the ","type":"text"},{"type":"codeVoice","code":"Orange Business Tools"},{"text":" theme, you just need to use the theme object as is.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Tunable-theme","text":"Tunable theme","level":2},{"inlineContent":[{"text":"The theme can be tuned with ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object to give at init.","type":"text"},{"text":" ","type":"text"},{"text":"Some tuning object exists.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","\/\/ Apply it to your theme","let theme = OrangeBusinessToolsTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeBusinessToolsTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeBusinessToolsTheme(tuning: Tuning.MaxIt)"]},{"inlineContent":[{"text":"A default tuning is applied for this theme:","type":"text"}],"type":"paragraph"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Tunable elements","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default values","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"rounded corners buttons","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"❌ false","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"rounded corners text inputs"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ true"}]}]]],"header":"row"},{"type":"heading","anchor":"Typography","text":"Typography","level":2},{"type":"heading","anchor":"Helvetica-Neue","text":"Helvetica Neue","level":3},{"inlineContent":[{"text":"The Orange theme uses ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":" typography. This font is already available through iOS.","type":"text"},{"text":" ","type":"text"},{"text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ The three following instanciations are the same","let theme = OrangeBusinessToolsTheme()","let theme = OrangeBusinessToolsTheme(family: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeBusinessToolsTheme(family: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeBusinessToolsTheme(family: \"Helvetica Neue\")"]},{"type":"heading","anchor":"Other-fonts","text":"Other fonts","level":3},{"inlineContent":[{"text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeBusinessToolsTheme(family: theFontFamilyNameInPostScript)"]},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Specific rules to compute PostScript value are defined in "},{"code":"PostScriptFontNamesMap.swift","type":"codeVoice"}]}],"style":"note"},{"name":"Tip","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your font family is not well managed, you can "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","isActive":true}]}],"style":"tip"},{"name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For production products and official tools, "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" is preferred and should be used"}]}],"style":"important"},{"name":"Tip","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions"}]}],"style":"tip"},{"name":"Caution","type":"aside","content":[{"inlineContent":[{"text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps","type":"text"}],"type":"paragraph"}],"style":"note"},{"name":"Important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)"}],"type":"paragraph"}],"style":"important"},{"type":"heading","anchor":"How-to-enrich-the-theme","text":"How to enrich the theme","level":2},{"inlineContent":[{"text":"You cannot derivate the ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange Business Tools"}],"type":"emphasis"},{"text