{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"syntax":null,"code":["🧬 Theme version: 2.3.0"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this theme exists.","type":"text"}]},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme is related to Orange theme module to use some raw tokens of colors."}]}],"style":"note"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It contains also colors dedicated to charts."}]}],"style":"note"},{"name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The Orange Business Tools theme is read only: it cannot be suclassed or derivated.","type":"text"}]}],"style":"important"},{"text":"How to use the theme","level":2,"type":"heading","anchor":"How-to-use-the-theme"},{"inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","isActive":true},{"type":"text","text":" directly. To use the "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","isActive":true},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}],"type":"paragraph"},{"syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeBusinessToolsTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the "},{"type":"codeVoice","code":"Orange Business Tools"},{"type":"text","text":" theme, you just need to use the theme object as is."}],"type":"paragraph"},{"level":2,"text":"Tunable theme","anchor":"Tunable-theme","type":"heading"},{"inlineContent":[{"text":"The theme can be tuned with ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object to give at init.","type":"text"},{"text":" ","type":"text"},{"text":"Some tuning object exists.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","\/\/ Apply it to your theme","let theme = OrangeBusinessToolsTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeBusinessToolsTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeBusinessToolsTheme(tuning: Tuning.MaxIt)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"A default tuning is applied for this theme:"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Tunable elements"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default values","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"rounded corners buttons"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"❌ false"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"rounded corners text inputs"}],"type":"paragraph"}],[{"inlineContent":[{"text":"✅ true","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"type":"heading","level":2,"text":"Typography","anchor":"Typography"},{"type":"heading","level":3,"text":"Helvetica Neue","anchor":"Helvetica-Neue"},{"type":"paragraph","inlineContent":[{"text":"The Orange theme uses ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" typography. This font is already available through iOS.","type":"text"},{"text":" ","type":"text"},{"text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens.","type":"text"}]},{"code":["\/\/ The three following instanciations are the same","let theme = OrangeBusinessToolsTheme()","let theme = OrangeBusinessToolsTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeBusinessToolsTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeBusinessToolsTheme(fontFamily: \"Helvetica Neue\")"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"text":"Other fonts","anchor":"Other-fonts"},{"type":"paragraph","inlineContent":[{"text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init.","type":"text"}]},{"code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeBusinessToolsTheme(family: theFontFamilyNameInPostScript)"],"type":"codeListing","syntax":"swift"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Specific rules to compute PostScript value are defined in "},{"type":"codeVoice","code":"PostScriptFontNamesMap.swift"}]}]},{"style":"tip","type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"If your font family is not well managed, you can ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","isActive":true,"type":"reference"}]}]},{"style":"important","type":"aside","name":"Important","content":[{"inlineContent":[{"type":"text","text":"For production products and official tools, "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" is preferred and should be used","type":"text"}],"type":"paragraph"}]},{"type":"aside","style":"tip","content":[{"inlineContent":[{"type":"text","text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions"}],"type":"paragraph"}],"name":"Tip"},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps","type":"text"}],"type":"paragraph"}],"name":"Caution"},{"type":"aside","style":"important","content":[{"inlineContent":[{"type":"text","text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)"}],"type":"paragraph"}],"name":"Important"},{"type":"heading","anchor":"How-to-enrich-the-theme","level":2,"text":"How to enrich the theme"},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the ","type":"text"},{"inlineContent":[{"text":"Orange Business Tools","type":"text"}],"type":"emphasis"},{"text":" theme.","type":"text"}]},{"type":"heading","anchor":"How-it-looks-like","level":2,"text":"How it looks like"},{"type":"heading","anchor":"Actions","level":3,"text":"Actions"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_OrangeBusinessTools.png","type":"image"}]},{"type":"heading","anchor":"Controls","level":3,"text":"Controls"},{"type":"heading","anchor":"Checkboxes","level":4,"text":"Checkboxes"},{"type":"tabNavigator","tabs":[{"title":"Checkbox","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_OrangeBusinessTools.png"}]}]},{"title":"Checkbox item","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_OrangeBusinessTools.png"}]}]}]},{"type":"heading","anchor":"Radios","level":4,"text":"Radios"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radio_OrangeBusinessTools.png"}],"type":"paragraph"}],"title":"Radio"},{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radioItem_OrangeBusinessTools.png","type":"image"}],"type":"paragraph"}],"title":"Radio item"}]},{"anchor":"Switches","level":4,"text":"Switches","type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_switch_OrangeBusinessTools.png","type":"image"}],"type":"paragraph"}],"title":"Switch"},{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_switchItem_OrangeBusinessTools.png","type":"image"}],"type":"paragraph"}],"title":"Switch item"}],"type":"tabNav