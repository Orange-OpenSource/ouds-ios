{"identifier":{"url":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools","interfaceLanguage":"swift"},"abstract":[{"text":"The Orange Business Tools theme is dedicated to applications with strong dimensions constraints.","type":"text"}],"sections":[],"kind":"symbol","hierarchy":{"paths":[[]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"codeListing","syntax":null,"code":["🧬 Theme version: 2.1.0"]},{"type":"paragraph","inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to display and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of dimensions, spaces and sizes.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this theme exists.","type":"text"}]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"This theme is related to Orange theme module to use some raw tokens of colors.","type":"text"}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"It contains also colors dedicated to charts."}],"type":"paragraph"}]},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange Business Tools theme is read-only: it cannot be suclassed or derivated."}]}]},{"type":"heading","anchor":"How-to-use-the-theme","level":2,"text":"How to use the theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","isActive":true},{"type":"text","text":" directly. To use the "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","isActive":true},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class objects"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeBusinessToolsTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This theme embeds and registers the fonts for the ","type":"text"},{"code":"Orange Business Tools","type":"codeVoice"},{"text":" theme, you just need to use the theme object as is.","type":"text"}]},{"type":"heading","anchor":"Tunable-theme","level":2,"text":"Tunable theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be tuned with "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object to give at init."},{"type":"text","text":" "},{"type":"text","text":"Some tuning object exists."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Define your theme tuning","let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","\/\/ Apply it to your theme","let theme = OrangeBusinessToolsTheme(tuning: tuning)","\/\/ Or in one line","let theme = OrangeBusinessToolsTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","\/\/ Or apply predefined tunings","let orangeFranceTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeFrance)","let orangeBusinessTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeBusiness)","let maxitTheme = OrangeBusinessToolsTheme(tuning: Tuning.MaxIt)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A default tuning is applied for this theme:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Tunable elements"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Default values"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"rounded corners buttons","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"❌ false","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"rounded corners text inputs","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✅ true"}],"type":"paragraph"}]]]},{"type":"heading","anchor":"Typography","level":2,"text":"Typography"},{"type":"heading","anchor":"Helvetica-Neue","level":3,"text":"Helvetica Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange theme uses "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" typography. This font is already available through iOS."},{"type":"text","text":" "},{"type":"text","text":"It is possible to use another typography, by the ones recommended are the ones defined in tokens."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ The three following instanciations are the same","let theme = OrangeBusinessToolsTheme()","let theme = OrangeBusinessToolsTheme(family: OrangeBrandFontRawTokens.familyBrandDefault)","let theme = OrangeBusinessToolsTheme(family: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","","\/\/ This instanciation won't work as the font family is not recognised","let theme = OrangeBusinessToolsTheme(family: \"Helvetica Neue\")"]},{"type":"heading","anchor":"Other-fonts","level":3,"text":"Other fonts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However if, in very particular cases, you need to use another font family, you can try using it by changing the value in the theme init."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Supposing you want to use another font:","\/\/ - like the Luciole font (https:\/\/luciole-vision.com\/) (very good for accessibility)","\/\/ - or the Roboto font (https:\/\/fonts.google.com\/specimen\/Roboto) (to support cyrillic alphabet)","\/\/ - or hevletica Neue Arabic (for arabic alphabet Helvetica flavoured)","\/\/ 1. Add the TTF files in your project","    ","\/\/ 2. Register the fonts with, for example, the function below","private func registerFonts() {","    let fonts = Bundle.main.urls(forResourcesWithExtension: \"ttf\", subdirectory: nil)","    fonts?.forEach { CTFontManagerRegisterFontsForURL($0 as CFURL, .process, nil) }","}","","\/\/ 3. At theme init, given the font family name, add it to the theme.","\/\/ Keep in mind that it might not work because PostScript name is used combining","\/\/ font family name and font weight.","\/\/ For Luciole font, use \"Luciole\", for Roboto font, use \"Roboto\", etc.","let theme = OrangeBusinessToolsTheme(family: theFontFamilyNameInPostScript)"]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Specific rules to compute PostScript value are defined in ","type":"text"},{"code":"PostScriptFontNamesMap.swift","type":"codeVoice"}]}]},{"type":"aside","style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your font family is not well managed, you can "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues"}]}]},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For production products and official tools, "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" is preferred and should be used"}]}]},{"type":"aside","style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"If for your needs Helvetica Neue is not relevant (because does not support cyrilic, or not enough accessible, or not aligned with your needs), ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/discussions","type":"reference"}]}]},{"type":"aside","style":"note","name":"Caution","content":[{"inlineContent":[{"type":"text","text":"For ecodesign principles you should challenge the use of fonts because they can increase the needed storage of your apps"}],"type":"paragraph"}]},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always check the license and terms of uses of the font your are using (distribution, hsoting, usage for comemrcial things, etc.)"}]}]},{"type":"heading","anchor":"How-to-enrich-the-theme","level":2,"text":"How to enrich the theme"},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the ","type":"text"},{"inlineContent":[{"text":"Orange Business Tools","type":"text"}],"type":"emphasis"},{"text":" theme.","type":"text"}]},{"type":"heading","anchor":"How-it-looks-like","level":2,"text":"How it looks like"},{"type":"heading","anchor":"Actions","level":3,"text":"Actions"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_OrangeBusinessTools.png"}]},{"type":"heading","anchor":"Controls","level":3,"text":"Controls"},{"type":"heading","anchor":"Checkboxes","level":4,"text":"Checkboxes"},{"type":"tabNavigator","tabs":[{"title":"Checkbox","content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_OrangeBusinessTools.png","type":"image"}]}]},{"title":"Checkbox item","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_OrangeBusinessTools.png"}]}]}]},{"type":"heading","anchor":"Radios","level":4,"text":"Radios"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radio_OrangeBusinessTools.png"}],"type":"paragraph"}],"title":"Radio"},{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radioItem_OrangeBusinessTools.png","type":"image"}],"type":"paragraph"}],"title":"Radio item"}]},{"type":"heading","anchor":"Switches","level":4,"text":"Switches"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_switch_OrangeBusinessTools.png","type":"image"}],"type":"paragraph"}],"title":"Switch"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unifie