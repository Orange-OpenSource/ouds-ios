{"abstract":[{"type":"text","text":"How to add the package as dependency, import libraries and use theme and components for your apps."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemescontract\/gettingstarted"]}],"identifier":{"url":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/GettingStarted","interfaceLanguage":"swift"},"metadata":{"title":"Getting Started with OUDS","modules":[{"name":"Welcome to Orange Unified Design System"}],"role":"article","roleHeading":"Article","images":[{"identifier":"ic_unified_ds.png","type":"icon"},{"type":"card","identifier":"ic_unified_ds.png"}]},"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Tokens","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Components","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Modules"],"generated":true,"anchor":"Essentials","title":"Essentials"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"content":[{"text":"Integrate OUDS","anchor":"Integrate-OUDS","type":"heading","level":2},{"text":"Use Swift Package Manager","anchor":"Use-Swift-Package-Manager","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"If you want to add the iOS library of ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System","type":"text"}]},{"type":"text","text":", you need to add our "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift Package"}]},{"type":"text","text":" into your project."},{"text":" ","type":"text"},{"text":"To do that, add a new ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"package dependency"}]},{"text":" to your ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Xcode"}]},{"type":"text","text":" project by refering to it by "},{"type":"codeVoice","code":"github.com\/Orange-OpenSource\/ouds-ios"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"You are free to choose whether or not you want a branch or a specific tag, pick the solution you want.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/50-%E2%80%90-About-versions,-releases-and-builds","type":"reference"},{"type":"text","text":" for more details about versions, releases and tags. You can find release tags (e.g. "},{"inlineContent":[{"text":"1.0.0","type":"text"}],"type":"emphasis"},{"text":") and release candidates tags (e.g. ","type":"text"},{"inlineContent":[{"type":"text","text":"1.0.0-rc3"}],"type":"emphasis"},{"text":").","type":"text"}]},{"type":"heading","text":"Import the librairies you need","anchor":"Import-the-librairies-you-need","level":3},{"type":"paragraph","inlineContent":[{"text":"You should use one (or several) of the following imports for your needs, which are basically ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift Package","type":"text"}]},{"text":" products.","type":"text"}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"We recommend to embed in your apps only the ones you need to avoid to embed useless assets.","type":"text"}]}],"name":"Tip","style":"tip"},{"type":"codeListing","code":["import OUDSThemesContract \/\/ If you want to define your theme, use themes or OUDSThemeableView","import OUDSModules \/\/ To use modules","import OUDSComponents \/\/ To use components","import OUDSThemesOrange \/\/ To use the default Orange theme","import OUDSThemesOrangeCompact \/\/ To use the Orange Compact theme","import OUDSThemesSosh \/\/ To use the Sosh theme","import OUDSThemesWireframe \/\/ To use the Wireframe theme","import OUDSTokensComponent \/\/ If you need to override or use directly components tokens","import OUDSTokenSemantic \/\/ If you need to override or use directly semantic tokens","import OUDSTokensRaw \/\/ If you need to override or use directly raw tokens","import OUDSFoundations \/\/ For some utilities"],"syntax":"swift"},{"type":"heading","text":"Or more simple, import umbrella library","anchor":"Or-more-simple-import-umbrella-library","level":3},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We do not recommend this solution because from our point of view use of tailored imports is better to import only the needed elements."},{"text":" ","type":"text"},{"text":"use of umbrella products can increase app sizes and needed storage because it emebds plenty of assets (images, fonts, etc.)","type":"text"},{"text":" ","type":"text"},{"text":"and useless constants.","type":"text"}]}]},{"inlineContent":[{"text":"Import the ","type":"text"},{"inlineContent":[{"text":"Swift Package","type":"text"}],"type":"emphasis"},{"type":"text","text":" product which suits your needs:"}],"type":"paragraph"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Umbrella"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"inlineContent":[{"text":"OUDSSwiftUI","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"All librairies listed above and all themes","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"OUDSSwiftUIOrange","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"All librairies listed above but with only Orange and Orange Compact themes","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"OUDSSwiftUIWireframe"}],"type":"paragraph"}],[{"inlineContent":[{"text":"All librairies listed above but with only Wireframe theme","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"OUDSSwiftUIOrangeSosh"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All librairies listed above but with only Orange and Sosh themes"}]}]]],"type":"table"},{"text":"Chose your theme","type":"heading","anchor":"Chose-your-theme","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System","type":"text"}]},{"type":"text","text":" framework provides today four themes:"}]},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Theme"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Orange","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"The default one for Orange products and can be enriched \/ derivated","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Orange Compact","type":"text"}]}],[{"inlineContent":[{"text":"For some Orange products with heavy \/ rich UI and dimensions constraints","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Sosh"}]}],[{"inlineContent":[{"type":"text","text":"For Sosh products"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Wireframe","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For mockups, prototypes and prooves of concepts witouth Orange-flavoured styles"}],"type":"paragraph"}]]],"type":"table"},{"level":3,"type":"heading","anchor":"Apply-a-theme","text":"Apply a theme"},{"columns":[{"size":1,"content":[{"inlineContent":[{"text":"You will need to use for your application root view the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/themes","isActive":true,"type":"reference"},{"text":" also.","type":"text"},{"text":" ","type":"text"},{"text":"This special view is here to define some elements as environment variables and injects the choosen theme.","type":"text"}],"type":"paragraph"}]},{"size":1,"content":[{"syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","       WindowGroup {","          OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","          }","       }","    }","}"],"type":"codeListing"}]}],"type":"row","numberOfColumns":2},{"type":"row","numberOfColumns":2,"columns":[{"content":[{"inlineContent":[{"text":"Then get the current applied theme in your views and use the tokens you want.","type":"text"},{"text":" ","type":"text"},{"text":"The tokens are wrapped in providers with clear names, you only need to choose the ones you want.","type":"text"}],"type":"paragraph"}],"size":1},{"content":[{"syntax":"swift","code":["\/\/ Use it in views as an environment variable","@Environment(\\.theme) var theme"],"type":"codeListing"}],"size":1}]},{"content":[{"inlineContent":[{"text":"Keep in mind only one theme can be used within one ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Tip","style":"tip"},{"type":"heading","anchor":"Trick-for-Xcode-Preview","level":3,"text":"Trick for Xcode Preview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you use Xcode "},{"type":"codeVoice","code":"#Preview"},{"type":"text","text":" blocks, you will have to be sure the theme is instanciated and injected through the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because it is not possible today to override the legit "},{"type":"codeVoice","code":"#Preview"},{"type":"text","text":" block, you can instead use some of our utilities to wrap your content"},{"type":"text","text":" "},{"type":"text","text":"inside the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" automatically. These utilities come with the themes modules. Without them you may face errors about undefined theme.","type":"text"}]},{"type":"codeListing","code":["\/\/ Apply Orange theme","#Preview {","    SampleView()","        .orangePreview()","}","","\/\/ Apply Orange Compact theme","#Preview {","    SampleView()","        .orangeCompactPreview()","}","","\/\/ Apply Sosh theme","#Preview {","    SampleView()","        .soshPreview()","}","","\/\/ Apply Wireframe theme","#Preview {","    SampleView()","        .wireframePreview()","}"],"syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract"]]},"references":{"ic_module_intro.png":{"variants":[{"url":"\/images\/OUDSThemesContract\/ic_module_intro.png","traits":["1x","light"]}],"type":"image","identifier":"ic_module_intro.png","alt":null},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Themes":{"title":"Themes","url":"\/documentation\/oudsthemescontract\/themes","role":"article","type":"topic","images":[{"identifier":"ic_theme_intro.png","type":"icon"},{"identifier":"ic_theme_intro.png","type":"card"}],"kind":"article","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","abstract":[{"type":"emphasis","inlineContent":[{"text":"Themes","type":"text"}]},{"text":" are applications of specific values for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"components tokens"}]},{"type":"text","text":" and dimensionsemantic tokens_ using in the end "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" contains any relevant tokens which can be used for components rendering."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineCon