sis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"A ","type":"text"},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"text":" contains any relevant tokens which can be used for components rendering.","type":"text"},{"text":" ","type":"text"},{"text":"A ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"text":" can use its own assets like fonts and icons.","type":"text"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","title":"Themes","type":"topic","kind":"article","images":[{"identifier":"ic_theme_intro.png","type":"icon"},{"identifier":"ic_theme_intro.png","type":"card"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract":{"url":"\/documentation\/oudsthemescontract","abstract":[{"text":"The Apple OS Swift Package of ","type":"text"},{"inlineContent":[{"text":"Orange Unified Design System","type":"text"}],"type":"emphasis"},{"text":", the new design system unified and cohesive across all platforms to build Orange mobile applications for everyone everywhere.","type":"text"}],"title":"Welcome to Orange Unified Design System","role":"collection","type":"topic","kind":"symbol","images":[{"identifier":"ic_unified_ds.png","type":"icon"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract"},"ic_module_intro.png":{"alt":null,"variants":[{"url":"\/images\/OUDSThemesContract\/ic_module_intro.png","traits":["1x","light"]}],"type":"image","identifier":"ic_module_intro.png"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Modules":{"url":"\/documentation\/oudsthemescontract\/modules","role":"article","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Modules","title":"Modules","images":[{"type":"icon","identifier":"ic_module_intro.png"},{"type":"card","identifier":"ic_module_intro.png"}],"kind":"article","type":"topic","abstract":[{"type":"text","text":"A "},{"type":"emphasis","inlineContent":