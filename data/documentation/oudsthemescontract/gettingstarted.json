{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract"]]},"identifier":{"url":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/GettingStarted","interfaceLanguage":"swift"},"metadata":{"role":"article","roleHeading":"Article","images":[{"identifier":"ic_unified_ds.png","type":"icon"},{"identifier":"ic_unified_ds.png","type":"card"}],"title":"Getting Started with OUDS","modules":[{"name":"Welcome to Orange Unified Design System"}]},"abstract":[{"type":"text","text":"How to add the package as dependency, import libraries and use theme and components for your apps."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Integrate OUDS","type":"heading","anchor":"Integrate-OUDS"},{"level":3,"text":"Use Swift Package Manager","type":"heading","anchor":"Use-Swift-Package-Manager"},{"inlineContent":[{"type":"text","text":"If you want to add the iOS library of "},{"inlineContent":[{"text":"Orange Unified Design System","type":"text"}],"type":"emphasis"},{"type":"text","text":", you need to add our "},{"inlineContent":[{"text":"Swift Package","type":"text"}],"type":"emphasis"},{"type":"text","text":" into your project."},{"type":"text","text":" "},{"type":"text","text":"To do that, add a new "},{"inlineContent":[{"type":"text","text":"package dependency"}],"type":"emphasis"},{"type":"text","text":" to your "},{"inlineContent":[{"text":"Xcode","type":"text"}],"type":"emphasis"},{"type":"text","text":" project by refering to it by "},{"type":"codeVoice","code":"github.com\/Orange-OpenSource\/ouds-ios"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You are free to choose wether or not you want a branch or a specific tag, pick the solution you want."}],"type":"paragraph"},{"inlineContent":[{"text":"You can ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/50-%E2%80%90-About-versions,-releases-and-builds","isActive":true,"type":"reference"},{"text":" for more details about versions, releases and tags. You can find release tags (e.g. ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"0.18.0","type":"text"}]},{"text":") and release candidates tags (e.g. ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"0.18.0-rc3"}]},{"text":").","type":"text"}],"type":"paragraph"},{"level":3,"text":"Import the librairies you need","type":"heading","anchor":"Import-the-librairies-you-need"},{"inlineContent":[{"type":"text","text":"You should use one (or several) of the following imports for your needs, which are basically "},{"type":"emphasis","inlineContent":[{"text":"Swift Package","type":"text"}]},{"type":"text","text":" products."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We recommend to embed in your apps only the ones you need to avoid to embed useless assets."}]}],"type":"aside","style":"tip","name":"Tip"},{"syntax":"swift","type":"codeListing","code":["import OUDSThemesContract \/\/ If you want to define your theme, use themes or OUDSThemeableView","import OUDSModules \/\/ To use modules","import OUDSComponents \/\/ To use components","import OUDSThemesOrange \/\/ To use the default Orange theme","import OUDSThemesOrangeBusinessTools \/\/ To use the Orange Business Tools theme","import OUDSThemesSosh \/\/ To use the Sosh theme","import OUDSThemesWireframe \/\/ To use the Wireframe theme","import OUDSTokensComponent \/\/ If you need to override or use directly components tokens","import OUDSTokenSemantic \/\/ If you need to override or use directly semantic tokens","import OUDSTokensRaw \/\/ If you need to override or use directly raw tokens","import OUDSFoundations \/\/ For some utilities"]},{"level":3,"text":"Or more simple, import umbrella library","type":"heading","anchor":"Or-more-simple-import-umbrella-library"},{"content":[{"type":"paragraph","inlineContent":[{"text":"We do not recommend this solution because from our point of view use of tailored imports is better to import only the needed elements.","type":"text"},{"text":" ","type":"text"},{"text":"use of umbrella products can increase app sizes and needed storage because it emebds plenty of assets (images, fonts, etc.)","type":"text"},{"text":" ","type":"text"},{"text":"and useless constants.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"inlineContent":[{"type":"text","text":"Import the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift Package"}]},{"type":"text","text":" product which suits your needs:"}],"type":"paragraph"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Umbrella"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"OUDSSwiftUI","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All librairies listed above and all themes"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"OUDSSwiftUIOrange","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All librairies listed above but with only Orange and Orange Business Tools themes"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"OUDSSwiftUIWireframe","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"All librairies listed above but with only Wireframe theme","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"OUDSSwiftUIOrangeSosh","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"All librairies listed above but with only Orange and Sosh themes","type":"text"}]}]]],"header":"row"},{"level":3,"text":"Chose your theme","type":"heading","anchor":"Chose-your-theme"},{"inlineContent":[{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange Unified Design System"}],"type":"emphasis"},{"text":" framework provides today four themes:","type":"text"}],"type":"paragraph"},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Theme"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Orange","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The default one for Orange products and can be enriched \/ derivated","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Orange Business Tools","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For some Orange products with heavy \/ rich UI and dimensions constraints"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Sosh"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For Sosh products","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Wireframe"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For mockups, prototypes and prooves of concepts witouth Orange-flavoured styles","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"level":3,"text":"Apply a theme","type":"heading","anchor":"Apply-a-theme"},{"columns":[{"content":[{"inlineContent":[{"text":"You will need to use for your application root view the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/"},{"text":".","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/themes"},{"text":" also.","type":"text"},{"text":" ","type":"text"},{"text":"This special view is here to define some elements as environment variables and injects the choosen theme.","type":"text"}],"type":"paragraph"}],"size":1},{"content":[{"syntax":"swift","type":"codeListing","code":["@main","struct YourApp: App {","    var body: some Scene {","       WindowGroup {","          OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","          }","       }","    }","}"]}],"size":1}],"numberOfColumns":2,"type":"row"},{"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"text":"Then get the current applied theme in your views and use the tokens you want.","type":"text"},{"text":" ","type":"text"},{"text":"The tokens are wrapped in providers with clear names, you only need to choose the ones you want.","type":"text"}]}]},{"size":1,"content":[{"type":"codeListing","code":["\/\/ Use it in views as an environment variable","@Environment(\\.theme) var theme"],"syntax":"swift"}]}],"numberOfColumns":2,"type":"row"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Keep in mind only one theme can be used within one ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":".","type":"text"}]}],"type":"aside","style":"tip","name":"Tip"}]}],"variants":[{"paths":["\/documentation\/oudsthemescontract\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"anchor":"Essentials","generated":true,"title":"Essentials","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Tokens","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Components","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Modules"]}],"kind":"article","references":{"doc://OUDSThemesContract/documentation/OUDSThemesContract/Tokens":{"url":"\/documentation\/oudsthemescontract\/tokens","abstract":[{"type":"text","text":"Design tokens represent the small, repeated design decisions that make up a design system’s visual style. Tokens wrap hard-coded static values, such as hexadecimal codes for color, with self-explanatory names. They are used to define the look and feel and the style of everything. They are exposed through the themes and can be used as they are."}],"role":"article","kind":"article","images":[{"identifier":"ic_design_token_intro.png","type":"icon"},{"identifier":"ic_design_token_intro.png","type":"card"}],"title":"Tokens","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Tokens"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Themes":{"kind":"article","title":"Themes","url":"\/documentation\/oudsthemescontract\/themes","type":"topic","abstract":[{"type":"emphasis","inlineContent":[{"text":"Themes","type":"text"}]},{"type":"text","text":" are applications of specific values for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"components tokens"}]},{"type":"text","text":" and dimensionsemantic tokens_ using in the end "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" contains any relevant tokens which can be used for components rendering."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" can use its own assets like fonts and icons."}],"images":[{"identifier":"ic_theme_intro.png","type":"icon"},{"identifier":"ic_theme_intro.png","type":"card"}],"role":"article","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes"},"ic_unified_ds.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_unified_ds.png"}],"type":"image","identifier":"ic_unified_ds.png","alt":null},"ic_module_intro.png":{"identifier":"ic_module_intro.png","alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_module_intro.png"}]},"https://ios.unified-design-system.orange.com/documentation/ouds/themes":{"title":"This page may help","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/themes","type":"link","identifier":"https:\/\/ios.unifie