{"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract"]]},"sections":[],"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Tokens","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Components","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Modules"],"anchor":"Essentials","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Integrate-OUDS","text":"Integrate OUDS","level":2,"type":"heading"},{"anchor":"Use-Swift-Package-Manager","text":"Use Swift Package Manager","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"If you want to add the iOS library of "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange Unified Design System"}]},{"text":", you need to add our ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift Package"}]},{"text":" into your project.","type":"text"},{"text":" ","type":"text"},{"text":"To do that, add a new ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"package dependency"}]},{"type":"text","text":" to your "},{"type":"emphasis","inlineContent":[{"text":"Xcode","type":"text"}]},{"type":"text","text":" project by refering to it by "},{"code":"github.com\/Orange-OpenSource\/ouds-ios","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"You are free to choose whether or not you want a branch or a specific tag, pick the solution you want."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You can ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/50-%E2%80%90-About-versions,-releases-and-builds","isActive":true},{"text":" for more details about versions, releases and tags. You can find release tags (e.g. ","type":"text"},{"inlineContent":[{"type":"text","text":"1.0.0"}],"type":"emphasis"},{"text":") and release candidates tags (e.g. ","type":"text"},{"inlineContent":[{"type":"text","text":"1.0.0-rc3"}],"type":"emphasis"},{"type":"text","text":")."}]},{"text":"Import the librairies you need","type":"heading","level":3,"anchor":"Import-the-librairies-you-need"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should use one (or several) of the following imports for your needs, which are basically "},{"inlineContent":[{"text":"Swift Package","type":"text"}],"type":"emphasis"},{"type":"text","text":" products."}]},{"name":"Tip","content":[{"inlineContent":[{"text":"We recommend to embed in your apps only the ones you need to avoid to embed useless assets.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"tip"},{"syntax":"swift","type":"codeListing","code":["import OUDSThemesContract \/\/ If you want to define your theme, use themes or OUDSThemeableView","import OUDSModules \/\/ To use modules","import OUDSComponents \/\/ To use components","import OUDSThemesOrange \/\/ To use the default Orange theme","import OUDSThemesOrangeCompact \/\/ To use the Orange Compact theme","import OUDSThemesSosh \/\/ To use the Sosh theme","import OUDSThemesWireframe \/\/ To use the Wireframe theme","import OUDSTokensComponent \/\/ If you need to override or use directly components tokens","import OUDSTokenSemantic \/\/ If you need to override or use directly semantic tokens","import OUDSTokensRaw \/\/ If you need to override or use directly raw tokens","import OUDSFoundations \/\/ For some utilities"]},{"text":"Or more simple, import umbrella library","type":"heading","level":3,"anchor":"Or-more-simple-import-umbrella-library"},{"name":"Note","content":[{"inlineContent":[{"text":"We do not recommend this solution because from our point of view use of tailored imports is better to import only the needed elements.","type":"text"},{"text":" ","type":"text"},{"text":"use of umbrella products can increase app sizes and needed storage because it emebds plenty of assets (images, fonts, etc.)","type":"text"},{"text":" ","type":"text"},{"text":"and useless constants.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Import the "},{"inlineContent":[{"text":"Swift Package","type":"text"}],"type":"emphasis"},{"type":"text","text":" product which suits your needs:"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Umbrella"}]}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDSSwiftUI"}]}],[{"inlineContent":[{"type":"text","text":"All librairies listed above and all themes"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"OUDSSwiftUIOrange"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"All librairies listed above but with only Orange and Orange Compact themes"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"OUDSSwiftUIWireframe"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"All librairies listed above but with only Wireframe theme"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"OUDSSwiftUIOrangeSosh"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"All librairies listed above but with only Orange and Sosh themes"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"text":"Chose your theme","type":"heading","level":3,"anchor":"Chose-your-theme"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange Unified Design System"}],"type":"emphasis"},{"type":"text","text":" framework provides today four themes:"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Theme","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Orange","type":"text"}]}],[{"inlineContent":[{"text":"The default one for Orange products and can be enriched \/ derivated","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Orange Compact","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For some Orange products with heavy \/ rich UI and dimensions constraints","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Sosh","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For Sosh products","type":"text"}]}]],[[{"inlineContent":[{"text":"Wireframe","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"For mockups, prototypes and prooves of concepts witouth Orange-flavoured styles","type":"text"}]}]]],"header":"row"},{"level":3,"anchor":"Apply-a-theme","text":"Apply a theme","type":"heading"},{"type":"row","columns":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You will need to use for your application root view the ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/themes","type":"reference","isActive":true},{"text":" also.","type":"text"},{"text":" ","type":"text"},{"text":"This special view is here to define some elements as environment variables and injects the choosen theme.","type":"text"}]}],"size":1},{"content":[{"syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","       WindowGroup {","          OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","          }","       }","    }","}"],"type":"codeListing"}],"size":1}],"numberOfColumns":2},{"type":"row","columns":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Then get the current applied theme in your views and use the tokens you want.","type":"text"},{"text":" ","type":"text"},{"text":"The tokens are wrapped in providers with clear names, you only need to choose the ones you want.","type":"text"}]}],"size":1},{"content":[{"type":"codeListing","code":["\/\/ Use it in views as an environment variable","@Environment(\\.theme) var theme"],"syntax":"swift"}],"size":1}],"numberOfColumns":2},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"Keep in mind only one theme can be used within one "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":"."}],"type":"paragraph"}],"style":"tip","name":"Tip"},{"anchor":"Trick-for-Xcode-Preview","type":"heading","level":3,"text":"Trick for Xcode Preview"},{"inlineContent":[{"type":"text","text":"If you use Xcode "},{"type":"codeVoice","code":"#Preview"},{"type":"text","text":" blocks, you will have to be sure the theme is instanciated and injected through the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because it is not possible today to override the legit "},{"type":"codeVoice","code":"#Preview"},{"type":"text","text":" block, you can instead use some of our utilities to wrap your content"},{"type":"text","text":" "},{"type":"text","text":"inside the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" automatically. These utilities come with the themes modules. Without them you may face errors about undefined theme."}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Apply Orange theme","#Preview {","    SampleView()","        .orangePreview()","}","","\/\/ Apply Orange Compact theme","#Preview {","    SampleView()","        .orangeCompactPreview()","}","","\/\/ Apply Sosh theme","#Preview {","    SampleView()","        .soshPreview()","}","","\/\/ Apply Wireframe theme","#Preview {","    SampleView()","        .wireframePreview()","}"],"syntax":"swift"}]}],"me