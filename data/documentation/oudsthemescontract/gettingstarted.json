ith self-explanatory names. They are used to define the look and feel and the style of everything. They are exposed through the themes and can be used as they are.","type":"text"}],"url":"\/documentation\/oudsthemescontract\/tokens"},"ic_module_intro.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_module_intro.png"}],"type":"image","identifier":"ic_module_intro.png"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Themes":{"abstract":[{"type":"emphasis","inlineContent":[{"text":"Themes","type":"text"}]},{"type":"text","text":" are applications of specific values for "},{"type":"emphasis","inlineContent":[{"text":"components tokens","type":"text"}]},{"type":"text","text":" and dimensionsemantic tokens_ using in the end "},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"text":" contains any relevant tokens which can be used for components rendering.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"text":" can use its own assets like fonts and icons.","type":"text"}],"title":"Themes","url":"\/documentation\/oudsthemescontract\/themes","images":[{"type":"icon","identifier":"ic_theme_intro.png"},{"type":"card","identifier":"ic_theme_intro.png"}],"role":"article","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","type":"topic","kind":"article"},"ic_theme_intro.png":{"type":"image","variants":[{"url":"\/images\/OUDSThemesContract\/ic_theme_intro.png","traits":["1x","light"]}],"alt":null,"identifier":"ic_theme_intro.png"},"https://ios.unified-design-system.orange.com/documentation/ouds/themes":{"type":"link","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/themes","title":"This page may hel