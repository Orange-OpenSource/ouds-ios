{"metadata":{"images":[{"type":"icon","identifier":"ic_unified_ds.png"},{"type":"card","identifier":"ic_unified_ds.png"}],"title":"Getting Started with OUDS","roleHeading":"Article","modules":[{"name":"Welcome to Orange Unified Design System"}],"role":"article"},"abstract":[{"text":"How to add the package as dependency, import libraries and use theme and components for your apps.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract"]]},"seeAlsoSections":[{"anchor":"Essentials","generated":true,"title":"Essentials","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Tokens","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Components","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Modules"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Integrate-OUDS","type":"heading","text":"Integrate OUDS"},{"level":3,"anchor":"Use-Swift-Package-Manager","type":"heading","text":"Use Swift Package Manager"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to add the iOS library of "},{"inlineContent":[{"type":"text","text":"Orange Unified Design System"}],"type":"emphasis"},{"type":"text","text":", you need to add our "},{"inlineContent":[{"text":"Swift Package","type":"text"}],"type":"emphasis"},{"type":"text","text":" into your project."},{"type":"text","text":" "},{"type":"text","text":"To do that, add a new "},{"type":"emphasis","inlineContent":[{"type":"text","text":"package dependency"}]},{"type":"text","text":" to your "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Xcode"}]},{"type":"text","text":" project by refering to it by "},{"type":"codeVoice","code":"github.com\/Orange-OpenSource\/ouds-ios"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"You are free to choose wether or not you want a branch or a specific tag, pick the solution you want.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/50-%E2%80%90-About-versions,-releases-and-builds","isActive":true},{"type":"text","text":" for more details about versions, releases and tags. You can find release tags (e.g. "},{"type":"emphasis","inlineContent":[{"type":"text","text":"0.18.0"}]},{"type":"text","text":") and release candidates tags (e.g. "},{"type":"emphasis","inlineContent":[{"text":"0.18.0-rc3","type":"text"}]},{"type":"text","text":")."}]},{"text":"Import the librairies you need","type":"heading","anchor":"Import-the-librairies-you-need","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should use one (or several) of the following imports for your needs, which are basically "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift Package"}]},{"type":"text","text":" products."}]},{"name":"Tip","type":"aside","style":"tip","content":[{"type":"paragraph","inlineContent":[{"text":"We recommend to embed in your apps only the ones you need to avoid to embed useless assets.","type":"text"}]}]},{"type":"codeListing","syntax":"swift","code":["import OUDSThemesContract \/\/ If you want to define your theme, use themes or OUDSThemeableView","import OUDSModules \/\/ To use modules","import OUDSComponents \/\/ To use components","import OUDSThemesOrange \/\/ To use the default Orange theme","import OUDSThemesOrangeBusinessTools \/\/ To use the Orange Business Tools theme","import OUDSThemesSosh \/\/ To use the Sosh theme","import OUDSThemesWireframe \/\/ To use the Wireframe theme","import OUDSTokensComponent \/\/ If you need to override or use directly components tokens","import OUDSTokenSemantic \/\/ If you need to override or use directly semantic tokens","import OUDSTokensRaw \/\/ If you need to override or use directly raw tokens","import OUDSFoundations \/\/ For some utilities"]},{"text":"Or more simple, import umbrella library","type":"heading","anchor":"Or-more-simple-import-umbrella-library","level":3},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We do not recommend this solution because from our point of view use of tailored imports is better to import only the needed elements."},{"text":" ","type":"text"},{"text":"use of umbrella products can increase app sizes and needed storage because it emebds plenty of assets (images, fonts, etc.)","type":"text"},{"text":" ","type":"text"},{"text":"and useless constants.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"Import the ","type":"text"},{"inlineContent":[{"text":"Swift Package","type":"text"}],"type":"emphasis"},{"text":" product which suits your needs:","type":"text"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Umbrella"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"OUDSSwiftUI","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"All librairies listed above and all themes","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"OUDSSwiftUIOrange","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All librairies listed above but with only Orange and Orange Business Tools themes"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDSSwiftUIWireframe"}]}],[{"type":"paragraph","inlineContent":[{"text":"All librairies listed above but with only Wireframe theme","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDSSwiftUIOrangeSosh"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All librairies listed above but with only Orange and Sosh themes"}]}]]]},{"anchor":"Chose-your-theme","type":"heading","level":3,"text":"Chose your theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System","type":"text"}]},{"type":"text","text":" framework provides today four themes:"}]},{"type":"table","rows":[[[{"inlineContent":[{"text":"Theme","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Orange","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The default one for Orange products and can be enriched \/ derivated"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Orange Business Tools","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For some Orange products with heavy \/ rich UI and dimensions constraints"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Sosh","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For Sosh products","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Wireframe"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For mockups, prototypes and prooves of concepts witouth Orange-flavoured styles"}],"type":"paragraph"}]]],"header":"row"},{"text":"Apply a theme","anchor":"Apply-a-theme","level":3,"type":"heading"},{"numberOfColumns":2,"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You will need to use for your application root view the "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/themes"},{"type":"text","text":" also."},{"type":"text","text":" "},{"type":"text","text":"This special view is here to define some elements as environment variables and injects the choosen theme."}]}]},{"size":1,"content":[{"syntax":"swift","type":"codeListing","code":["@main","struct YourApp: App {","    var body: some Scene {","       WindowGroup {","          OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","          }","       }","    }","}"]}]}],"type":"row"},{"numberOfColumns":2,"columns":[{"size":1,"content":[{"inlineContent":[{"type":"text","text":"Then get the current applied theme in your views and use the tokens you want."},{"type":"text","text":" "},{"type":"text","text":"The tokens are wrapped in providers with clear names, you only need to choose the ones you want."}],"type":"paragraph"}]},{"size":1,"content":[{"syntax":"swift","code":["\/\/ Use it in views as an environment variable","@Environment(\\.theme) var theme"],"type":"codeListing"}]}],"type":"row"},{"name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keep in mind only one theme can be used within one "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":"."}]}],"style":"tip","type":"aside"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemescontract\/gettingstarted"]}],"kind":"article","identifier":{"url":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/GettingStarted","interfaceLanguage":"swift"},"sections":[],"references":{"ic_module_intro.png":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_module_intro.png"}],"identifier":"ic_module_intro.png"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Components":{"title":"Components","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Components","type":"topic","kind":"article","role":"article","images":[{"type":"icon","identifier":"ic_component_intro.png"},{"type":"card","identifier":"ic_component_intro.png"}],"url":"\/documentation\/oudsthemescontract\/components","abstract":[{"inlineContent":[{"type":"text","text":"Components"}],"type":"emphasis"},{"type":"text","text":" are the "},{"type":"codeVoice","code":"View"},{"type":"text","text":" objects you can add in the views of your apps, like buttons, links, cards etc."}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract":{"type":"topic","kind":"symbol","url":"\/documentation\/oudsthemescontract","abstract":[{"type":"text","text":"The Apple OS Swift Package of "},{"inlineContent":[{"type":"text","text":"Orange Unified Design System"}],"type":"emphasis"},{"type":"text","text":", the new design system unified and cohesive across all platforms to build Orange mobile applications for everyone everywhere."}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract","title":"Welcome to Orange Unified Design System","role":"collection","images":[{"identifier":"ic_unified_ds.png","type":"icon"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Themes":{"title":"Themes","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","type":"topic","kind":"article","role":"article","images":[{"type":"icon","identifier":"ic_theme_intro.png"},{"type":"card","identifier":"ic_theme_intro.png"}],"url":"\/documentation\/oudsthemescontract\/themes","abstract":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Themes"}]},{"type":"text","text":" are applications of specific values for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"components tokens"}]},{"type":"text","text":" and dimensionsemantic tokens_ using in the end "},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" contains any relevant tokens which can be used for components rendering."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" can use its own assets like fonts and icons."}]},"https://ios.unified-design-system.orange.com/documentation/ouds/oudsthemeableview/":{"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/","titleInlineContent":[{"type":"codeVoice","code":"OUDSThemeableView"}],"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/","type":"link","title":"OUDSThemeableView"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Modules":{"title":"Modules","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Modules","type":"topic","kind":"article","role":"article","images":[{"type":"icon","identifier":"ic_module_intro.png"},{"type":"card","identifier":"ic_module_intro.png"}],"url":"\/documentation\/oudsthemescontract\/modules","abstract":[{"text":"A ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"module"}]},{"text":" can be seen as a set of features and components to fill a need.","type":"text"}]},"ic_theme_intro.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/OUDSThemesContract\/ic_theme_intro.png","traits":["1x","light"]}],"identifier":"ic_theme_intro.png"},"ic_component_intro.png":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_component_intro.png"}],"identifier":"ic_component_intro.png"},"ic_unified_ds.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesContract\/ic_unified_ds.png"}],"identifier":"ic_unified_ds.png","type":"image"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Tokens":{"title":"Tokens","url":"\/documentation\/oudsthemescontract\/tokens","role":"article","abstract":[{"type":"text","text":"Design tokens represent the small, repeated design decisions that make up a design system’s visual style. Tokens wrap hard-coded static valu