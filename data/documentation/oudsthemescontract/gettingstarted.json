{"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Integrate OUDS","anchor":"Integrate-OUDS","type":"heading"},{"text":"Use Swift Package Manager","type":"heading","anchor":"Use-Swift-Package-Manager","level":3},{"inlineContent":[{"text":"If you want to add the iOS library of ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System","type":"text"}]},{"text":", you need to add our ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift Package","type":"text"}]},{"text":" into your project.","type":"text"},{"text":" ","type":"text"},{"text":"To do that, add a new ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"package dependency","type":"text"}]},{"text":" to your ","type":"text"},{"inlineContent":[{"text":"Xcode","type":"text"}],"type":"emphasis"},{"text":" project by refering to it by ","type":"text"},{"type":"codeVoice","code":"github.com\/Orange-OpenSource\/ouds-ios"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"You are free to choose whether or not you want a branch or a specific tag, pick the solution you want.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/wiki\/50-%E2%80%90-About-versions,-releases-and-builds","isActive":true,"type":"reference"},{"text":" for more details about versions, releases and tags. You can find release tags (e.g. ","type":"text"},{"inlineContent":[{"text":"1.0.0","type":"text"}],"type":"emphasis"},{"text":") and release candidates tags (e.g. ","type":"text"},{"inlineContent":[{"text":"1.0.0-rc3","type":"text"}],"type":"emphasis"},{"text":").","type":"text"}],"type":"paragraph"},{"text":"Import the librairies you need","type":"heading","anchor":"Import-the-librairies-you-need","level":3},{"inlineContent":[{"text":"You should use one (or several) of the following imports for your needs, which are basically ","type":"text"},{"inlineContent":[{"text":"Swift Package","type":"text"}],"type":"emphasis"},{"text":" products.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"We recommend to embed in your apps only the ones you need to avoid to embed useless assets.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Tip","style":"tip"},{"type":"codeListing","code":["import OUDSThemesContract \/\/ If you want to define your theme, use themes or OUDSThemeableView","import OUDSModules \/\/ To use modules","import OUDSComponents \/\/ To use components","import OUDSThemesOrange \/\/ To use the default Orange theme","import OUDSThemesOrangeCompact \/\/ To use the Orange Compact theme","import OUDSThemesSosh \/\/ To use the Sosh theme","import OUDSThemesWireframe \/\/ To use the Wireframe theme","import OUDSTokensComponent \/\/ If you need to override or use directly components tokens","import OUDSTokenSemantic \/\/ If you need to override or use directly semantic tokens","import OUDSTokensRaw \/\/ If you need to override or use directly raw tokens","import OUDSFoundations \/\/ For some utilities"],"syntax":"swift"},{"text":"Or more simple, import umbrella library","type":"heading","anchor":"Or-more-simple-import-umbrella-library","level":3},{"content":[{"inlineContent":[{"text":"We do not recommend this solution because from our point of view use of tailored imports is better to import only the needed elements.","type":"text"},{"text":" ","type":"text"},{"text":"use of umbrella products can increase app sizes and needed storage because it emebds plenty of assets (images, fonts, etc.)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and useless constants."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"text":"Import the ","type":"text"},{"inlineContent":[{"text":"Swift Package","type":"text"}],"type":"emphasis"},{"text":" product which suits your needs:","type":"text"}]},{"type":"table","rows":[[[{"inlineContent":[{"text":"Umbrella","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"OUDSSwiftUI","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"All librairies listed above and all themes","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"OUDSSwiftUIOrange","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"All librairies listed above but with only Orange and Orange Compact themes","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"OUDSSwiftUIWireframe","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"All librairies listed above but with only Wireframe theme","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"OUDSSwiftUIOrangeSosh","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"All librairies listed above but with only Orange and Sosh themes","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","text":"Chose your theme","level":3,"anchor":"Chose-your-theme"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"inlineContent":[{"text":"Orange Unified Design System","type":"text"}],"type":"emphasis"},{"text":" framework provides today four themes:","type":"text"}]},{"type":"table","rows":[[[{"inlineContent":[{"text":"Theme","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Orange","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"The default one for Orange products and can be enriched \/ derivated","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Orange Compact","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For some Orange products with heavy \/ rich UI and dimensions constraints","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Sosh","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For Sosh products","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Wireframe","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For mockups, prototypes and prooves of concepts witouth Orange-flavoured styles","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","text":"Apply a theme","level":3,"anchor":"Apply-a-theme"},{"type":"row","numberOfColumns":2,"columns":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You will need to use for your application root view the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/themes","isActive":true,"type":"reference"},{"text":" also.","type":"text"},{"text":" ","type":"text"},{"text":"This special view is here to define some elements as environment variables and injects the choosen theme.","type":"text"}]}],"size":1},{"content":[{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","       WindowGroup {","          OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","          }","       }","    }","}"]}],"size":1}]},{"type":"row","numberOfColumns":2,"columns":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Then get the current applied theme in your views and use the tokens you want.","type":"text"},{"text":" ","type":"text"},{"text":"The tokens are wrapped in providers with clear names, you only need to choose the ones you want.","type":"text"}]}],"size":1},{"content":[{"type":"codeListing","syntax":"swift","code":["\/\/ Use it in views as an environment variable","@Environment(\\.theme) var theme"]}],"size":1}]},{"type":"aside","style":"tip","name":"Tip","content":[{"inlineContent":[{"text":"Keep in mind only one theme can be used within one ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":".","type":"text"}],"type":"paragraph"}]},{"type":"heading","text":"Trick for Xcode Preview","level":3,"anchor":"Trick-for-Xcode-Preview"},{"type":"paragraph","inlineContent":[{"text":"If you use Xcode ","type":"text"},{"code":"#Preview","type":"codeVoice"},{"text":" blocks, you will have to be sure the theme is instanciated and injected through the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because it is not possible today to override the legit ","type":"text"},{"code":"#Preview","type":"codeVoice"},{"text":" block, you can instead use some of our utilities to wrap your content","type":"text"},{"text":" ","type":"text"},{"text":"inside the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" automatically. These utilities come with the themes modules. Without them you may face errors about undefined theme.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Apply Orange theme","#Preview {","    SampleView()","        .orangePreview()","}","","\/\/ Apply Orange Compact theme","#Preview {","    SampleView()","        .orangeCompactPreview()","}","","\/\/ Apply Sosh theme","#Preview {","    SampleView()","        .soshPreview()","}","","\/\/ Apply Wireframe theme","#Preview {","    SampleView()","        .wireframePreview()","}"]}]}],"abstract":[{"text":"How to add the package as dependency, import libraries and use theme and components for your apps.","type":"text"}],"sections":[],"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract"]]},"variants":[{"paths":["\/documentation\/oudsthemescontract\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/GettingStarted","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Article","modules":[{"name":"Welcome to Orange Unified Design System"}],"role":"article","title":"Getting Started with OUDS","images":[{"identifier":"ic_unified_ds.png","type":"icon"},{"identifier":"ic_unified_ds.png","type":"card"}]},"seeAlsoSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Tokens","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Components","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Modules"],"generated":true,"title":"Essentials","anchor":"Essentials"}],"references":{"doc://OUDSThemesContract/documentation/OUDSThemesContract/Themes":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Themes","type":"topic","abstract":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Themes"}]},{"type":"text","text":" are applications of specific values for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"components tokens"}]},{"type":"text","text":" and dimensionsemantic tokens_ using in the end "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" contains any relevant tokens which can be used for components rendering."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" can use its own assets like fonts and icons."}],"kind":"article","role":"article","title":"Themes","url":"\/documentation\/oudsthemescontract\/themes","images":[{"identifier":"ic_theme_intro.png","type":"icon"},{"identifier":"ic_theme_intro.png","type":"card"}]},"https://ios.unified-design-system.orange.com/documentation/ouds/oudsthemeableview/":{"type":"link","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/","title":"OUDSThemeableView","titleInlineContent":[{"code":"OUDSThemeableView","type":"codeVoice"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Tokens":{"kind":"article","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Tokens","images":[{"type":"icon","identifier":"ic_design_token_intro.png"},{"type":"card","identifier":"ic_design_token_intro.png"}],"url":"\/documentation\/oudsthemescontract\/tokens","abstract":[{"text":"Design tokens represent the small, repeated design decisions that make up a design system’s visual style. Tokens wrap hard-coded static values, such as hexadecimal codes for color, with self-explanatory names. They are used to define the look and feel and the style of everything. They are exposed through the themes and can be used as they are.","type":"text"}],"title":"Tokens","role":"article"},"ic_theme_intro.png":{"type":"image","identifier":"ic_theme_intro.png","variants":[{"url":"\/images\/OUDSThemesContract\/ic_theme_intro.png","traits":["1x","light"]}],"alt":null},"ic_unified_ds.png":{"type":"image","identifier":"ic_unified_ds.png","variants":[{"url":"\/images\/OUDSThemesContract\/ic_unified_ds.png","traits":["1x","light"]}],"alt":null},"doc://OUDSThemesContract/documentation/OUDSThemesContract/Modules":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/Modules","type":"topic","abstract":[{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"module"}]},{"type":"text","text":" can be seen as a set of features and components to fill a need."}],"kind":"article","role":"article","title":"Modules","url":"\/documentation\/oudsthemescontract\/modules","images":[{"identifier":"ic_module_intro.png","type":"ic