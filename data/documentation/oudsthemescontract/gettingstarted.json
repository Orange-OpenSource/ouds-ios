":"text","text":"Components"}]},{"type":"text","text":" are the "},{"type":"codeVoice","code":"View"},{"type":"text","text":" objects you can add in the views of your apps, like buttons, links, cards etc."}],"title":"Components","role":"article","images":[{"type":"icon","identifier":"ic_component_intro.png"},{"type":"card","identifier":"ic_component_intro.png"}],"kind":"article"},"ic_module_intro.png":{"variants":[{"url":"\/images\/OUDSThemesContract\/ic_module_intro.png","traits":["1x","light"]}],"type":"image","identifier":"ic_module_intro.png","alt":null},"ic_component_intro.png":{"type":"image","alt":null,"identifier":"ic_component_intro.png","variants":[{"url":"\/images\/OUDSThemesContract\/ic_component_intro.png","traits":["1x","light"]}]},"https://ios.unified-design-system.orange.com/documentation/ouds/oudsthemeableview/":{"type":"link","titleInlineContent":[{"code":"OUDSThemeableView","type":"codeVoice"}],"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/oudsthemeableview\/","title":"OUDSThemeableView"},"doc://OUDSThemesContract/documentation/OUDSThemesContract":{"kind":"symbol","abstract":[{"type":"text","text":"Orange Unified Design System: Build Sharper. Ship faster. Perform better."}],"title":"Welcome to Orange Unified Design System","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract","role":"collection","images":[{"type":"icon","identifier":"ic_unified_ds.png"}],"type":"topic","url":"\/documentation\/oudsthemescontract"},"https://ios.unified-design-system.orange.com/documentation/ouds/themes":{"type":"link","titleInlineContent":[{"type":"text","text":"This page may help"}],"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/themes","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/ouds\/themes","title":"This page may help"},"doc://OUDSThemesContract/d