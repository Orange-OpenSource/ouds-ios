,{"text":" ","type":"text"},{"text":"This special view is here to define some elements as environment variables and injects the choosen theme.","type":"text"}],"type":"paragraph"}]},{"size":1,"content":[{"syntax":"swift","type":"codeListing","code":["@main","struct YourApp: App {","    var body: some Scene {","       WindowGroup {","          OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","          }","       }","    }","}"]}]}],"numberOfColumns":2},{"type":"row","columns":[{"size":1,"content":[{"inlineContent":[{"type":"text","text":"Then get the current applied theme in your views and use the tokens you want."},{"type":"text","text":" "},{"type":"text","text":"The tokens are wrapped in providers with clear names, you only need to choose the ones you want."}],"type":"paragraph"}]},{"size":1,"content":[{"syntax":"swift","type":"codeListing","code":["\/\/ Use it in views as an environment variable","@Environment(\\.theme) var theme"]}]}],"numberOfColumns":2},{"style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"Keep in mind only one theme can be used within one ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":".","type":"text"}]}],"type":"aside"},{"anchor":"Trick-for-Xcode-Preview","level":3,"type":"heading","text":"Trick for Xcode Preview"},{"inlineContent":[{"type":"text","text":"If you use Xcode "},{"type":"codeVoice","code":"#Preview"},{"type":"text","text":" blocks, you will have to be sure the theme is instanciated and injected through the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because it is not possible today to override the legit "},{"type":"codeVoice","code":"#Preview"},{"text":" block, you can instead use some of our utilities to wrap your content","type":"text"},{"text":" ","type":"text"},{"text":"inside the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":