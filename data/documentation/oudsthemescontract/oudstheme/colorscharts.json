 overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"url":"\/documentation\/oudsthemescontract\/oudstheme","title":"OUDSTheme","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"type":"topic","role":"symbol","kind":"symbol"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllColorChartSemanticTokensProvider":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllColorChartSemanticTokensProvider","abstract":[{"text":"Something which provides all semantic tokens of colors charts","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AllColorChartSemanticTokensProvider","kind":"identifier"}],"kind":"symbol","title":"AllColorChartSemanticTokensProvider","type":"topic","url":"\/documentation\/oudsthemescontract\/allcolorchartsemantict