 contract"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}]},"ic_unified_ds.png":{"alt":null,"type":"image","identifier":"ic_unified_ds.png","variants":[{"url":"\/images\/OUDSThemesContract\/ic_unified_ds.png","traits":["1x","light"]}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme/tuning":{"role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tuning","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Tuning","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","kind":"typeIdentifier"}],"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme\/tuning","kind":"symbol","title":"tuning","url":"\/documentation\/oudsthemescontract\/oudstheme\/tuning","abstract":[{"type":"text","text":"Some tuning for the theme"}]}}}