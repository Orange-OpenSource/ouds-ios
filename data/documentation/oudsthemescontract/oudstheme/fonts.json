ract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"url":"\/documentation\/oudsthemescontract\/oudstheme","kind":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}]}}}