o your own theme implementation:"}]},{"syntax":"swift","type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(inputTag: CustomInputTagComponentTokensProvider())","    }","}"]},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    OrangeTheme(inputTag: CustomInputTagComponentTokensProvider())"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemColorSemanticTokensProvider for colors","    let inputTagComponentTokensProvider = OrangeThemeInputTagComponentTokensProvider()","","    \/\/ Or use your own space, size and border semantic tokens providers (or only some)","    let inputTagComponentTokensProvider = OrangeThemeInputTagComponentTokensProvider(","                                            borders: CustomBorderSemanticTokensProvider(),","                                            colors: CustomColorSemanticTokensProvider())"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"0.17.0","type":"text"}]}],"style":"note","name":"Since","type":"aside"}]}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemeinputtagcomponenttokensprovider"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"OrangeThemeInputTagComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeInputTagComponentTokensProvider"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeInputTagComponentTokensProvider"}],"modules":[{"name":"Theme Orange"}],"roleHeading":"Class","externalID":"s:16OUDSThemesOrange0B36ThemeInputTagComponentTokensProvi