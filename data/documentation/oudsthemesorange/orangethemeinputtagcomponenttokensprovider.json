{"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider\/init(borders:colors:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider\/borders","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider\/colors"],"generated":true,"anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider\/InputTagComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider\/TokensProvider-Implementations"],"generated":true,"anchor":"Default-Implementations"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeInputTagComponentTokensProvider"}],"roleHeading":"Class","title":"OrangeThemeInputTagComponentTokensProvider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeInputTagComponentTokensProvider"}],"modules":[{"name":"Theme Orange"}],"externalID":"s:16OUDSThemesOrange0B36ThemeInputTagComponentTokensProviderC","symbolKind":"class"},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeInputTagComponentTokensProvider"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"code":["    \/\/ Define your own provider for tag input component tokens","    \/\/ by inheriting from existing provider","    class CustomInputTagComponentTokensProvider: OrangeThemeInputTagComponentTokensProvider {","","        \/\/ Then override the tag component tokens you want.","","        override var borderRadius: BorderRadiusSemanticToken  { borders.radiusNone }","","        override var colorBgPressed: MultipleColorSemanticTokens { colors.actionPressed }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomInputTagComponentTokensProvider: InputTagComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Then, you can give this ","type":"text"},{"type":"codeVoice","code":"CustomInputTagComponentTokensProvider"},{"text":" to your own theme implementation:","type":"text"}],"type":"paragraph"},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(inputTag: CustomInputTagComponentTokensProvider())","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"code":["    OrangeTheme(inputTag: CustomInputTagComponentTokensProvider())"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemColorSemanticTokensProvider for colors","    let inputTagComponentTokensProvider = OrangeThemeInputTagComponentTokensProvider()","","    \/\/ Or use your own space, size and border semantic tokens providers (or only some)","    let inputTagComponentTokensProvider = OrangeThemeInputTagComponentTokensProvider(","                                            borders: CustomBorderSemanticTokensProvider(),","                                            colors: CustomColorSemanticTokensProvider())"]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.17.0"}],"type":"paragraph"}]}],"kind":"content"}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllInputTagComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent08InputTagB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"type":"conformsTo"}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemeinputtagcomponenttokensprovider"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"text":"component  tokens of tag input","type":"text"}],"type":"strong"},{"type":"text","text":" objects like "},{"code":"OUDSInputTag","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllInputTagComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"InputTagComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"tag inputs","type":"text"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Tag inputs"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"and borders (from "},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"sections":[],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeInputTagComponentTokensProvider/colors":{"title":"colors","type":"topic","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemeinputtagcomponenttokensprovider\/colors","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider\/colors","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"colors","kind":"identifier"},{"text":": any ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract30AllColorSemanticTokensProviderP","text":"AllColorSemanticTokensProvider","kind":"typeIdentifier"}],"abstract":[{"text":"Provider of space semantic tokens to use for tag input colors","type":"text"}]},"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUD