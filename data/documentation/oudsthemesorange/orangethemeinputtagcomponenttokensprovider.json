"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"syntax":"swift","code":["    \/\/ Define your own provider for tag input component tokens","    \/\/ by inheriting from existing provider","    class CustomInputTagComponentTokensProvider: OrangeThemeInputTagComponentTokensProvider {","","        \/\/ Then override the tag component tokens you want.","","        override var borderRadius: BorderRadiusSemanticToken  { borders.radiusNone }","","        override var colorBgPressed: MultipleColorSemanticTokens { colors.actionPressed }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomInputTagComponentTokensProvider: InputTagComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomInputTagComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(inputTag: CustomInputTagComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    OrangeTheme(inputTag: CustomInputTagComponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemColorSemanticTokensProvider for colors","    let inputTagComponentTokensPr