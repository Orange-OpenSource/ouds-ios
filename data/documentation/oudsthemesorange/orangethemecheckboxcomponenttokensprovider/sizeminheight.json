izeSemanticToken","type":"codeVoice"},{"text":") and","type":"text"},{"text":" ","type":"text"},{"text":"borders (","type":"text"},{"code":"BorderRadiusSemanticToken","type":"codeVoice"},{"text":", ","type":"text"},{"code":"BorderWidthSemanticToken","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"These components share the same type of tokens which are all gather edhere.","type":"text"}]}}}