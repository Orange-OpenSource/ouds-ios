xt":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ButtonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"buttons"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Button"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}],"url":"\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}],"type":"topic","kind":"symbol","title":"OrangeThemeButtonComponentTokensProvider","role":"symbol"},"ic_theme_orange.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}],"identifier":"ic_theme_orange.png","type":"image"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"title":"Theme Orange"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllBorderSemanticTokensProvider":{"abstract":[{"text":"Something which provides all semantic tokens of border","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AllBorderSemanticTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemescontract\/allbordersemantictokensprovider","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllBorderSemanticTokensProvider","navigatorTitle":[{"text":"AllBorderSemanticTokensProvider","kind":"identifier"}],"type":"topic","kind":"symbol","title":"AllBorderSemanticTokensProvider","role":"symbol"}}}