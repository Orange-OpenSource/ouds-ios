eThemeButtonComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ButtonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"buttons"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Button"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}],"url":"\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}],"type":"topic","kind":"symbol","title":"OrangeThemeButtonComponentTokensProvider","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeButtonComponentTokensProvider/monoColorBgStrongPressed":{"role":"symbol","title":"monoColorBgStrongPressed","url":"\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider\/monocolorbgstrongpressed","abstract":[{"type":"text","text":"Has for value token MultipleColorSemanticToken(light: colors.repositoryOpacityWhiteHigher, dark: colors.repositoryOpacityBlackHigher)"}],"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThem