:" for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"button","type":"text"}]},{"text":" objects like ","type":"text"},{"type":"codeVoice","code":"OUDSButton"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"text":"This provider should be integrated as a ","type":"text"},{"code":"AllButtonComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"text":"Custom themes can use subclass of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider","type":"reference","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ButtonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"buttons"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Button","type":"text"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders"},{"type":"text","text":" "},{"text":"spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"kind":"symbol","title":"OrangeThemeButtonComponentTokensProvider","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeThemeButtonComponentTokensProvider","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"OrangeThemeButtonComponentTokensProvider","kind":"identifier"}]},"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"identifier":"ic_theme_orange.png","alt":null,"type":"image"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeButtonComponentTokensProvider/spaces":{"title":"spaces","role":"symbol","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/spaces","abstract":[{"text":"Provider of spaces semantic tokens to use for button spaces","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"spaces"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","text":"AllSpaceSemanticTokensProvider","preciseIdentifier":"s:18OUDSThemesContract30AllSpaceSemanticTokensProviderP"}],"url":"\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider\/spaces"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllSpaceSemanticTokensProvider":{"navigatorTitle":[{"text":"AllSpaceSemanticTokensProvider","kind":"identifier"}],"abstract":[{"type":"text","text":"Something which provides all semantic tokens of space"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllSpaceSemanticTokensProvider","role":"symbol","url":"\/documentation\/oudsthemescontract\/allspacesemantictokensprovider","type":"topic","kind":"sy