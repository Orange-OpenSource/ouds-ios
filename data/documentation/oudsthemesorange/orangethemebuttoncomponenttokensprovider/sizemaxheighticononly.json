umentation/OUDSThemesOrange/OrangeThemeButtonComponentTokensProvider/sizeMaxHeightIconOnly":{"abstract":[{"type":"text","text":"Has for value token sizes.minInteractiveArea"}],"url":"\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider\/sizemaxheighticononly","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizeMaxHeightIconOnly","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","text":"SizeSemanticToken","kind":"typeIdentifier"}],"role":"symbol","kind":"symbol","title":"sizeMaxHeightIconOnly","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/sizeMaxHeightIconOnly","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeButtonComponentTokensProvider":{"title":"OrangeThemeButtonComponentTokensProvider","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"OrangeThemeButtonComponentTokensProvider","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeButtonComponentTokensProvider","kind":"identifier"}],"abstract":[{"text":"A class which wraps all ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of buttons"}]},{"text":" for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"button","type":"text"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSButton"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllButtonComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"