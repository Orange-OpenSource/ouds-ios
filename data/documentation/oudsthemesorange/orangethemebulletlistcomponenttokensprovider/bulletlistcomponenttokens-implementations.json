ge"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeBulletListComponentTokensProvider","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider","abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component  tokens of bullet list"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"bullet list"}],"type":"emphasis"},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSBulletList"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllBulletListComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"BulletListComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"bullet list"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Bullet list"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with raw and semantic tokens of spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"title":"OrangeThemeBulletListComponentTokensProvider","navigatorTitle":[{"text":"OrangeThemeBulletListComponentTokensProvider","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider/spacePaddingInlineLevel1":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider\/spacePaddingInlineLevel1","title":"spacePaddingInlineLevel1","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacePaddingInlineLevel1","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SpaceSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena"}],"type":"topic","abstract":[{"type":"text","text":"Has for value token DimensionRawTokens._450"}],"kind":"symbol","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider\/spacepaddinginlinelevel1"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider/spacePaddingInlineLevel2":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider\/spacePaddingInlineLevel2","title":"spacePaddingInlineLevel2","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacePaddingInlineLevel2","kind":"identifier"},{"text":": ","kind":"text