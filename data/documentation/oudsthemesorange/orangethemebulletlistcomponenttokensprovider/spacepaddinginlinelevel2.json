/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider\/spacepaddinginlinelevel2","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider\/spacePaddingInlineLevel2","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacePaddingInlineLevel2","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena","text":"SpaceSemanticToken","kind":"typeIdentifier"}],"role":"symbol","abstract":[{"text":"Has for value token DimensionRawTokens._850","type":"text"}],"type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"Theme Orange","url":"\/documentation\/oudsthemesorange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"role":"collection","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"kind":"symbol","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider":{"title":"OrangeThemeBulletListComponentTokensProvider","role":"symbol","navigatorTitle":[{"text":"OrangeThemeBulletListComponentTokensProvider","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeBulletListComponentTokensProvider","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of bullet list"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"bullet list"}]},{"type":"text","text":" objects like "},{"code":"OUDSBulletList","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllBulletListComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"BulletListComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"bullet list","type":"text"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Bullet list","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"type":"topic","kind":"symbol"},"ic_theme_orange.png":{"variants":[{"traits":["1x","light"],"url