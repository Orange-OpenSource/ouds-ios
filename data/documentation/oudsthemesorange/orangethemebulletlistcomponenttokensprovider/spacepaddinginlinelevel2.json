deVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Bullet list"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeBulletListComponentTokensProvider"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider","title":"OrangeThemeBulletListComponentTokensProvider","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider/spacePaddingInlineLevel2":{"kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider\/spacePaddingInlineLevel2","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider\/spacepaddinginlinelevel2","title":"spacePaddingInlineLevel2","abstract":[{"text":"Has for value token DimensionRawTokens._850","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"spacePaddingInlineLevel2"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena","kind":"typeIdentifier","text":"SpaceSemanticToken"}],"type":"topic","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"url