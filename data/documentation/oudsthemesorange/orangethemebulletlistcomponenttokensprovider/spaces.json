ifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","kind":"symbol","title":"Theme Orange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"role":"collection","url":"\/documentation\/oudsthemesorange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"OrangeThemeBulletListComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeBulletListComponentTokensProvider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeBulletListComponentTokensProvider"}],"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component  tokens of bullet list"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"bullet list"}],"type":"emphasis"},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSBulletList"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllBulletListComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"BulletListComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"text":"bullet list","type":"text"}],"type":"emphasis"},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Bullet list"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with raw and semantic tokens of spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider/spaces":{"url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider\/spaces","role":"symbol","kind":"symbol","abstract":[{"text":"Provider of spaces semantic tokens to use for link spaces","type":"text"}],"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"spaces"},{"text":": any ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract30AllSpaceSemanticTokensProviderP","kind":"typeIdentifier","text":"AllSpaceSemanticTokensProvider"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider\/spaces","title":"spaces","type":"topic"}