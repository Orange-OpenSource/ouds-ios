":"emphasis","inlineContent":[{"type":"text","text":"bullet list"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Bullet list"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"role":"collection","title":"Theme Orange","url":"\/documentation\/oudsthemesorange","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"},"ic_theme_orange.png":{"type":"image","identifier":"ic_theme_orange.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}],"alt":null},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllSpaceSemanticTokensProvider":{"kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"AllSpaceSemanticTokensProvider","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"TokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract14TokensProviderP"},{"text":", ","kind":"text"},{"text":"SpaceMultipleSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic013SpaceMultipleB6TokensP"},{"text":", ","kind":"text"},{"text":"SpaceSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB6TokensP"}],"title":"AllSpaceSemanticTokensProvider","identifier":"doc:\/\/OUDSThemesContract\/do