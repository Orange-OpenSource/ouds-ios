ext":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Bullet list"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider","title":"OrangeThemeBulletListComponentTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider/spacePaddingBlockBodyLarge":{"url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider\/spacepaddingblockbodylarge","kind":"symbol","type":"topic","abstract":[{"text":"Has for value token spaces.paddingBlock2xsmall","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacePaddingBlockBodyLarge","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SpaceSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena"}],"role":"symbol","title":"spacePaddingBlockBodyLarge","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider\/spacePaddingBlockBodyLarge"},"ic_theme_orange.png":{"alt":null,"identifier":"ic_theme_orange.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"type":"topic","role":"collection","title":"Theme Orange","images"