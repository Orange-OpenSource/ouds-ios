eme","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"Text area","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"role":"symbol"},"ic_theme_orange.png":{"type":"image","identifier":"ic_theme_orange.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"Theme Orange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"type":"topic","role":"collection","kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextAreaComponentTokensProvider/spacePaddingBlock":{"abstract":[{"text":"Has for value token spaces.paddingBlockSmall","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/spacePaddingBlock","type":"topic","kind":"symbol","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemetextareacomponenttokensprovider\/spacepaddingblock","title":"spacePaddingBlock","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"spacePaddingBlock","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena","text":"Space