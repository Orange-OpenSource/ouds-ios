{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Usages","anchor":"Usages","type":"heading","level":1},{"inlineContent":[{"type":"text","text":"Any Orange products must use this theme. It provides core and Orange colors and any elements for sizings, spacings and dimensions for example."},{"type":"text","text":" "},{"type":"text","text":"The system font families are used; no "},{"type":"emphasis","inlineContent":[{"text":"Helevetica","type":"text"}]},{"type":"text","text":" font family is embeded nor providd  by OUDS."},{"type":"text","text":" "},{"type":"text","text":"This theme also provides colors charts tokens."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The theme can be got through environment variable:"}],"type":"paragraph"},{"code":["    @Environment(\\.theme) var theme"],"syntax":"swift","type":"codeListing"},{"text":"Integration","anchor":"Integration","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" and get it through environment variable."}],"type":"paragraph"},{"code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"syntax":"swift","type":"codeListing"},{"text":"Theme tuning","anchor":"Theme-tuning","type":"heading","level":2},{"inlineContent":[{"text":"The theme can be customized a bit for more flexibility thanks to ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object.","type":"text"},{"text":" ","type":"text"},{"text":"You just need to give a predefined tuning configuration at theme init to build the one you need.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To apply the tuning:","type":"text"}],"type":"paragraph"},{"code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","    \/\/ Apply it to your theme","    let theme = OrangeTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeTheme(tuning: Tuning.MaxIt)"],"syntax":"swift","type":"codeListing"},{"text":"Typography","anchor":"Typography","type":"heading","level":2},{"text":"Helvetica Neue","anchor":"Helvetica-Neue","type":"heading","level":3},{"inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family is available at system level, so it is not needed to get it through external assets.","type":"text"},{"text":" ","type":"text"},{"text":"By default an instance of ","type":"text"},{"code":"OrangeTheme","type":"codeVoice"},{"text":" uses as font family the token ","type":"text"},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"text":", which is today ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use another font family, you will have to send the suitable token or the suitable font family.","type":"text"},{"text":" ","type":"text"},{"text":"However, beware, iOS API relies also on the PostScript name of the font.","type":"text"},{"text":" ","type":"text"},{"text":"To be sure of the value to use, look at the font book of your device.","type":"text"},{"text":" ","type":"text"},{"text":"It is recommended to use the font raw tokens.","type":"text"}],"type":"paragraph"},{"code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeTheme()","    let orangeTheme = OrangeTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeTheme(fontFamily: \"Helvetica Neue\") \/\/ Which is font family nale"],"syntax":"swift","type":"codeListing"},{"text":"Helvetica Neue Arabic","anchor":"Helvetica-Neue-Arabic","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Because the "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue Arabic","type":"text"}]},{"type":"text","text":". This font family assets can be retrieved through the "},{"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}],"type":"paragraph"},{"code":["    let orangeTheme = OrangeTheme(family: \"Helvetica Neue Arabic\")"],"syntax":"swift","type":"codeListing"},{"text":"Tokens loading","anchor":"Tokens-loading","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"For example:"}],"type":"paragraph"},{"code":["   \/\/ Use some already defined providers","   let borders = OrangeThemeBorderSemanticTokensProvider()","   let sizes = OrangeThemeSizeSemanticTokensProvider()","   let spaces = OrangeThemeSpaceSemanticTokensProvider()","","   \/\/ For example, use your own provider of color semantic tokens","   \/\/ It must inherit from OrangeThemeBorderSemanticTokensProvider (which is instance of AllColorSemanticTokensProvider) or directly implement AllColorSemanticTokensProvider","   let colors = YourOwnColorSemanticTokensProvider()","","   \/\/ Some providers need other providers to use their tokens","   let button = OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces)","","   \/\/ But you can also use the providers as they are without assigning semantic tokens providers","   \/\/ and just use the default ones","   let badge = OrangeThemeBadgeComponentTokensProvider()","","   \/\/ Define in the end your theme by overriding some providers.","   \/\/ You can override all providers, or only some, or just keep the theme as is.","   \/\/ However you should uses thhese providers in a dedicated Orange theme subclass for clarity reasons.","   let yourOwnOrangeTheme = OrangeTheme(colors: colors, borders: borders, sizes: sizes, spaces: spaces, button: button, badge: badge)"],"syntax":"swift","type":"codeListing"},{"text":"Tokens versions","anchor":"Tokens-versions","type":"heading","level":2},{"items":[{"content":[{"inlineContent":[{"text":"Core OUDS version: 1.9.0","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Core Orange version: 1.2.0","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Brand Orange version: 2.3.0","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"style":"note","name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}]}],"kind":"content"}],"relationshipsSections":[{"title":"Inherits From","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"type":"inheritsFrom","kind":"relationships"},{"title":"Conforms To","identifiers":["doc:\/\/OUDSThemesOrange\/SQ","doc:\/\/OUDSThemesOrange\/s8SendableP","doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP"],"type":"conformsTo","kind":"relationships"}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangetheme"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:charts:effects:elevations:fonts:grids:opacities:dimensions:sizes:spaces:alert:badge:bar:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:fontFamily:tuning:)"],"generated":true,"anchor":"Initializers"}],"seeAlsoSections":[{"title":"Group","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens"],"generated":true,"anchor":"Group"}],"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}],"title":"OrangeTheme","modules":[{"name":"Theme Orange"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"role":"symbol","symbolKind":"class","externalID":"s:16OUDSThemesOrange0B5ThemeC"},"abstract":[{"type":"text","text":"The Orange theme is the bsic, default, theme for any Orange products."},{"type":"text","text":" "},{"type":"text","text":"This is an override of the abtract "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"text":"must be seen as the default theme for the OUDS library","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It can override any properties from its superclass, and can be derived too."}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"title":"OrangeBrandColorRawTokens","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBrandColorRawTokens","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeBrandColorRawTokens","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens","abstract":[{"type":"text","text":"This enum helps to add new "},{"type":"strong","inlineContent":[{"text":"color raw tokens","type":"text"}]},{"type":"text","text":" exclusive to this "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"type":"emphasis","inlineContent":[{"text":"Swift enum","type":"text"}]},{"type":"text","text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens","title":"OrangeBrandFontRawTokens","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBrandFontRawTokens","kind":"identifier"}],"abstract":[{"text":"This enum helps to add new ","type":"text"},{"type":"strong","inlineContent":[{"text":"font raw tokens","type":"text"}]},{"text":" exclusive to this ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift enum","type":"text"}]},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_.","type":"text"}],"type":"topic","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"OrangeBrandFontRawTokens","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangebrandfontrawtokens"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme/init(borders:colors:colorModes:charts:effects:elevations:fonts:grids:opacities:dimensions:sizes:spaces:alert:badge:bar:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:fontFamily:tuning:)":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"borders"},{"kind":"text","text":": (any "},{"kind":"typeIdentifier"