ion\/oudsthemesorange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrandFontRawTokens"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens","kind":"symbol","role":"symbol","title":"OrangeBrandFontRawTokens","navigatorTitle":[{"kind":"identifier","text":"OrangeBrandFontRawTokens"}],"type":"topic","url":"\/documentation\/oudsthemesorange\/orangebrandfontrawtokens","abstract":[{"type":"text","text":"This enum helps to add new "},{"type":"strong","inlineContent":[{"type":"text","text":"font raw tokens"}]},{"type":"text","text":" exclusive to this "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"type":"emphasis","inlineContent":[{"text":"Swift enum","type":"text"}]},{"type":"text","text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}]},"https://brand.orange.com/en/brand-basics/typography":{"type":"link","title":"Orange Brand website (authentication needed)","url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","titleInlineContent":[{"text":"Orange Brand website (authentication needed)","type":"text"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","role":"symbol","title":"OUDSTheme","type":"topic","url":"\/documentation\/oudsthemescontract\/oudstheme","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"text":" class, its type cannot be seen as ","type":"text"},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens","role":"symbol","type":"topic","kind":"symbol","abstract":[{"text":"This enum helps to add new ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"color raw tokens"}]},{"text":" exclusive to this ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift enum"}]},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeBrandColorRawTokens"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"text":"OrangeBrandColorRawTokens","kind":"identifier"}],"title":"OrangeBrandColorRawTokens"},"doc://OUDSThemesOrange/s8SendableP":{"identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"doc://OUDSThemesOrange/SQ":{"type":"unresolvable","title":"Swift.Equatable","identifier":"doc:\/\/OUDSThemesOrange\/SQ"},"doc://OUDSThemesOrange/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"ic_theme_orange.png":{"type":"image","alt":null,"identifier":"ic_theme_orange.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}]},"doc://OUDSThemesOrange/document