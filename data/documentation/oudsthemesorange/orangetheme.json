:[{"text":"The Orange theme is the bsic, default, theme for any Orange products.","type":"text"},{"text":" ","type":"text"},{"text":"This is an override of the abtract ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"must be seen as the default theme for the OUDS library","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"url":"\/documentation\/oudsthemesorange\/orangetheme","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","kind":"symbol","type":"topic","navigatorTitle":[{"text":"OrangeTheme","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme/name":{"abstract":[{"text":"The theme name (“Orange”)","type":"text"}],"kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/name","type":"topic","url":"\/documentation\/oudsthemesorange\/orangetheme\/name","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"name"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}],"title":"name","role":"symbol"},"doc://OUDSThemesOrange/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP","type":"unresolvable"},"doc://OUDSThemesOrange/SQ":{"title":"Swift.Equatable","type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/SQ"},"ic_theme_orange.png":{"alt":null,"identifier":"ic_theme_orange.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSTheme"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","title":"OUDSTheme","kind":"symbol","url":"\/documentation\/oudsthemescontract\/oudstheme","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"navigatorTitle":[{"text":"OrangeBrandColorRawTokens","kind":"identifier"}],"title":"OrangeBrandColorRawTokens","abstract":[{"text":"This enum helps to add new ","type":"text"},{"inlineContent":[{"text":"color raw tokens","type":"text"}],"type":"strong"},{"text":" exclusive to this ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"inlineContent":[{"text":"Swift enum","type":"text"}],"type":"emphasis"},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_.","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","role":"symbol","type":"topic","url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens","kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBrandColorRawTokens","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","type":"topic","url":"\/documentation\/oudsthemesorange","kind":"symbol"},"https://brand.orange.com/en/brand-basics/typography":{"title":"Orange Brand website (authentication needed)","type":"link","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}],"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"}}}