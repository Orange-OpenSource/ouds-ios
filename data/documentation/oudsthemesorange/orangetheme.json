},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"fontFamily"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","kind":"typeIdentifier","text":"FontFamilySemanticToken"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tuning"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSThemesContract6Tuninga","kind":"typeIdentifier","text":"Tuning"},{"kind":"text","text":")"}],"title":"init(borders:colors:colorModes:colorsCharts:colorsDecorative:effects:elevations:fonts:grids:opacities:dimensions:sizes:spaces:alert:badge:bar:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:fontFamily:tuning:)"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","abstract":[{"text":"This enum helps to add new ","type":"text"},{"inlineContent":[{"text":"color raw tokens","type":"text"}],"type":"strong"},{"type":"text","text":" exclusive to this "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift enum"}],"type":"emphasis"},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"OrangeBrandColorRawTokens","kind":"identifier"}],"type":"topic","kind":"symbol","title":"OrangeBrandColorRawTokens","navigatorTitle":[{"kind":"identifier","text":"OrangeBrandColorRawTokens"}]},"doc://OUDSThemesOrange/SQ":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/SQ","title":"Swift.Equatable"},"doc://OUDSThemesOrange/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"doc://OUDSThemesOrange/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP","title":"Swift.Sendable"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"url":"\/documentation\/oudsthemescontract\/oudstheme","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSTheme"}],"title":"OUDSTheme"},"ic_theme_orange.png":{"alt":null,"type":"image","identifier":"ic_theme_orange.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","abstract":[{"text":"The Orange theme is the bsic, default, theme for any Orange products.","type":"text"},{"text":" ","type":"text"},{"text":"This is an override of the abtract ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangetheme","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"OrangeTheme","kind":"identifier"}],"type":"topic","kind":"symbol","title":"OrangeTheme","navigatorTitle":[{"text":"OrangeTheme","kind":"identifier"}]},"https://brand.orange.com/en/brand-basics/typography":{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","title":"Orange Brand website (authentication needed)","type":"link","titleInlineContent":[{"text":"Orange Brand website (authentication needed)","type":"text"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"title":"OrangeBrandFontRawTokens","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBrandFontRawTokens","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens","abstract":[{"type":"text","text":"This enum helps to add new "},{"type":"strong","inlineContent":[{"type":"text","text":"font raw tokens"}]},{"type":"text","text":" exclusive to this "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift enum"}]},{"type":"text","text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}],"role":"symbol","kind":"symbol","navigatorTitle":[{"text":"OrangeBrandFontRawTokens","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangebrandfontrawtokens"}}}