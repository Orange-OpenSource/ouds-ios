Theme"},{"text":" is not a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"text":" class, its type cannot be seen as ","type":"text"},{"type":"codeVoice","code":"Sendable"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"kind":"symbol","title":"OUDSTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"url":"\/documentation\/oudsthemescontract\/oudstheme"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme/init(borders:colors:colorModes:charts:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:family:tuning:)":{"abstract":[{"type":"text","text":"Constructor of the Orange theme."},{"type":"text","text":" "},{"type":"text","text":"It needs several tokens providers for semantic tokens and component tokens."},{"type":"text","text":" "},{"type":"text","text":"If a nil token provider is given, the default version associated fo the theme is used."}],"role":"symbol","kind":"symbol","title":"init(borders:colors:colorModes:charts:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:family:tuning:)","type":"topic","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"borders","kind":"externalParam"},{"text":": (any ","kind":"text"},{"text":"AllBorderSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract31AllBorderSemanticTokensProviderP"},{"text":")?, ","kind":"text"},{"text":"colors","kind":"externalParam"},{"text":": (any ","kind":"text"},{"text":"AllColorSemanticTokensProvider","kin