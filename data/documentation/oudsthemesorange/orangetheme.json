{"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"symbolKind":"class","roleHeading":"Class","externalID":"s:16OUDSThemesOrange0B5ThemeC","role":"symbol","navigatorTitle":[{"text":"OrangeTheme","kind":"identifier"}],"title":"OrangeTheme","modules":[{"name":"Theme Orange"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}]},"abstract":[{"text":"The Orange theme is the bsic, default, theme for any Orange products.","type":"text"},{"text":" ","type":"text"},{"text":"This is an override of the abtract ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"text":"must be seen as the default theme for the OUDS library","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"seeAlsoSections":[{"generated":true,"anchor":"Group","title":"Group","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens"]}],"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"]},{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSThemesOrange\/SQ","doc:\/\/OUDSThemesOrange\/s8SendableP","doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Usages","level":1,"type":"heading","anchor":"Usages"},{"type":"paragraph","inlineContent":[{"text":"Any Orange products must use this theme. It provides core and Orange colors and any elements for sizings, spacings and dimensions for example.","type":"text"},{"text":" ","type":"text"},{"text":"The system font families are used; no ","type":"text"},{"inlineContent":[{"type":"text","text":"Helevetica"}],"type":"emphasis"},{"text":" font family is embeded nor providd  by OUDS.","type":"text"},{"text":" ","type":"text"},{"text":"This theme also provides colors charts tokens.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The theme can be got through environment variable:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.theme) var theme"]},{"text":"Integration","level":2,"type":"heading","anchor":"Integration"},{"type":"paragraph","inlineContent":[{"text":"To use this theme, inject it to your view using ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" and get it through environment variable.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"]},{"text":"Theme tuning","level":2,"type":"heading","anchor":"Theme-tuning"},{"type":"paragraph","inlineContent":[{"text":"The theme can be customized a bit for more flexibility thanks to ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object.","type":"text"},{"text":" ","type":"text"},{"text":"You just need to give a predefined tuning configuration at theme init to build the one you need.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To apply the tuning:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","    \/\/ Apply it to your theme","    let theme = OrangeTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeTheme(tuning: Tuning.MaxIt)"]},{"text":"Typography","level":2,"type":"heading","anchor":"Typography"},{"text":"Helvetica Neue","level":3,"type":"heading","anchor":"Helvetica-Neue"},{"type":"paragraph","inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family is available at system level, so it is not needed to get it through external assets.","type":"text"},{"text":" ","type":"text"},{"text":"By default an instance of ","type":"text"},{"code":"OrangeTheme","type":"codeVoice"},{"text":" uses as font family the token ","type":"text"},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"text":", which is today ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use another font family, you will have to send the suitable token or the suitable font family.","type":"text"},{"text":" ","type":"text"},{"text":"However, beware, iOS API relies also on the PostScript name of the font.","type":"text"},{"text":" ","type":"text"},{"text":"To be sure of the value to use, look at the font book of your device.","type":"text"},{"text":" ","type":"text"},{"text":"It is recommended to use the font raw tokens.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeTheme()","    let orangeTheme = OrangeTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeTheme(fontFamily: \"Helvetica Neue\") \/\/ Which is font family nale"]},{"text":"Helvetica Neue Arabic","level":3,"type":"heading","anchor":"Helvetica-Neue-Arabic"},{"type":"paragraph","inlineContent":[{"text":"Because the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}],"type":"emphasis"},{"text":". This font family assets can be retrieved through the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,","type":"text"},{"text":" ","type":"text"},{"text":"register them and define the font family name to use.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    let orangeTheme = OrangeTheme(family: \"Helvetica Neue Arabic\")"]},{"text":"Tokens loading","level":2,"type":"heading","anchor":"Tokens-loading"},{"type":"paragraph","inlineContent":[{"text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"For example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["   \/\/ Use some already defined providers","   let borders = OrangeThemeBorderSemanticTokensProvider()","   let sizes = OrangeThemeSizeSemanticTokensProvider()","   let spaces = OrangeThemeSpaceSemanticTokensProvider()","","   \/\/ For example, use your own provider of color semantic tokens","   \/\/ It must inherit from OrangeThemeBorderSemanticTokensProvider (which is instance of AllColorSemanticTokensProvider) or directly implement AllColorSemanticTokensProvider","   let colors = YourOwnColorSemanticTokensProvider()","","   \/\/ Some providers need other providers to use their tokens","   let button = OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces)","","   \/\/ But you can also use the providers as they are without assigning semantic tokens providers","   \/\/ and just use the default ones","   let badge = OrangeThemeBadgeComponentTokensProvider()","","   \/\/ Define in the end your theme by overriding some providers.","   \/\/ You can override all providers, or only some, or just keep the theme as is.","   \/\/ However you should uses thhese providers in a dedicated Orange theme subclass for clarity reasons.","   let yourOwnOrangeTheme = OrangeTheme(colors: colors, borders: borders, sizes: sizes, spaces: spaces, button: button, badge: badge)"]},{"text":"Tokens versions","level":2,"type":"heading","anchor":"Tokens-versions"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Core OUDS version: 1.9.0"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Core Orange version: 1.2.0"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Brand Orange version: 2.3.0","type":"text"}]}]}]},{"name":"Since","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangetheme"]}],"kind":"symbol","identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:charts:effects:elevations:fonts:grids:opacities:dimensions:sizes:spaces:alert:badge:bar:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:fontFamily:tuning:)"]}],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"abstract":[{"text":"This enum helps to add new ","type":"text"},{"inlineContent":[{"type":"text","text":"color raw tokens"}],"type":"strong"},{"text":" exclusive to this ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift enum"}],"type":"emphasis"},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_.","type":"text"}],"navigatorTitle":[{"text":"OrangeBrandColorRawTokens","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBrandColorRawTokens","kind":"identifier"}],"title":"OrangeBrandColorRawTokens","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens"},"doc://OUDSThemesOrange/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"abstract":[{"type":"text","text":"The Orange theme is the bsic, default, theme for any Orange products."},{"text":" ","type":"text"},{"type":"text","text":"This is an override of the abtract "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"navigatorTitle":[{"text":"OrangeTheme","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}],"title":"OrangeTheme","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangetheme"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"text":", or ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","kind":"symbol","title":"OUDSTheme","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"type":"topic"},"doc://OUDSThemesOrange/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"abstract":[{"text":"This enum helps to add new ","type":"text"},{"inlineContent":[{"type":"text","text":"font raw tokens"}],"type":"strong"},{"text":" exclusive to this ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","type":"reference"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift enum"}],"type":"emphasis"},{"type":"text","text":" so as to gather them in one object with