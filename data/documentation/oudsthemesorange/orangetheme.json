ier":"s:18OUDSThemesContract34AllTextAreaComponentTokensProviderP","kind":"typeIdentifier","text":"AllTextAreaComponentTokensProvider"},{"kind":"text","text":")?, "},{"kind":"externalParam","text":"textInput"},{"kind":"text","text":": (any "},{"preciseIdentifier":"s:18OUDSThemesContract35AllTextInputComponentTokensProviderP","kind":"typeIdentifier","text":"AllTextInputComponentTokensProvider"},{"kind":"text","text":")?, "},{"kind":"externalParam","text":"resourcesBundle"},{"kind":"text","text":": "},{"preciseIdentifier":"c:objc(cs)NSBundle","kind":"typeIdentifier","text":"Bundle"},{"kind":"text","text":", "},{"kind":"externalParam","text":"name"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"fontFamily"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","kind":"typeIdentifier","text":"FontFamilySemanticToken"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tuning"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSThemesContract6Tuninga","kind":"typeIdentifier","text":"Tuning"},{"text":")","kind":"text"}],"kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangetheme\/init(borders:colors:colormodes:charts:effects:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bar:bulletlist:button:checkbox:chip:controlitem:divider:icon:link:pincodeinput:quantityinput:radiobutton:selectinput:skeleton:switc-8laye","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:charts:effects:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bar:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:fontFamily:tuning:)","abstract":[{"type":"text","text":"Constructor of the Orange theme."},{"type":"text","text":" "},{"type":"text","text":"It needs several tokens providers for semantic tokens and component tokens."},{"type":"text","text":" "},{"type":"text","text":"If a nil token provider is given, the default version associated fo the theme is used."}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"kind":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"topic","url":"\/documentation\/oudsthemescontract\/oudstheme","title":"OUDSTheme","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}]}}}