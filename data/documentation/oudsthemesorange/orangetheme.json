{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"Usages","type":"heading","text":"Usages","level":1},{"inlineContent":[{"text":"Any Orange products must use this theme. It provides core and Orange colors and any elements for sizings, spacings and dimensions for example.","type":"text"},{"text":" ","type":"text"},{"text":"The system font families are used; no ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helevetica","type":"text"}]},{"text":" font family is embeded nor providd  by OUDS.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This theme also provides colors charts tokens."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be got through environment variable:"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.theme) var theme"]},{"level":2,"text":"Integration","anchor":"Integration","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" and get it through environment variable."}]},{"syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing"},{"level":2,"text":"Theme tuning","anchor":"Theme-tuning","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"text":"To apply the tuning:","type":"text"}]},{"syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","    \/\/ Apply it to your theme","    let theme = OrangeTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeTheme(tuning: Tuning.MaxIt)"],"type":"codeListing"},{"level":2,"text":"Typography","anchor":"Typography","type":"heading"},{"level":3,"text":"Helvetica Neue","anchor":"Helvetica-Neue","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":" font family is available at system level, so it is not needed to get it through external assets.","type":"text"},{"text":" ","type":"text"},{"text":"By default an instance of ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"text":" uses as font family the token ","type":"text"},{"type":"codeVoice","code":"OrangeBrandFontRawTokens.familyBrandDefault"},{"text":", which is today ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeTheme()","    let orangeTheme = OrangeTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeTheme(fontFamily: \"Helvetica Neue\") \/\/ Which is font family nale"],"syntax":"swift","type":"codeListing"},{"text":"Helvetica Neue Arabic","anchor":"Helvetica-Neue-Arabic","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Because the "},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}],"type":"emphasis"},{"type":"text","text":". This font family assets can be retrieved through the "},{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}],"type":"paragraph"},{"code":["    let orangeTheme = OrangeTheme(family: \"Helvetica Neue Arabic\")"],"syntax":"swift","type":"codeListing"},{"text":"Tokens loading","anchor":"Tokens-loading","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":")."},{"type":"text","text":" "},{"text":"For example:","type":"text"}],"type":"paragraph"},{"code":["   \/\/ Use some already defined providers","   let borders = OrangeThemeBorderSemanticTokensProvider()","   let sizes = OrangeThemeSizeSemanticTokensProvider()","   let spaces = OrangeThemeSpaceSemanticTokensProvider()","","   \/\/ For example, use your own provider of color semantic tokens","   \/\/ It must inherit from OrangeThemeBorderSemanticTokensProvider (which is instance of AllColorSemanticTokensProvider) or directly implement AllColorSemanticTokensProvider","   let colors = YourOwnColorSemanticTokensProvider()","","   \/\/ Some providers need other providers to use their tokens","   let button = OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces)","","   \/\/ But you can also use the providers as they are without assigning semantic tokens providers","   \/\/ and just use the default ones","   let badge = OrangeThemeBadgeComponentTokensProvider()","","   \/\/ Define in the end your theme by overriding some providers.","   \/\/ You can override all providers, or only some, or just keep the theme as is.","   \/\/ However you should uses thhese providers in a dedicated Orange theme subclass for clarity reasons.","   let yourOwnOrangeTheme = OrangeTheme(colors: colors, borders: borders, sizes: sizes, spaces: spaces, button: button, badge: badge)"],"syntax":"swift","type":"codeListing"},{"style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"type":"aside"}]}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangetheme"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"symbolKind":"class","externalID":"s:16OUDSThemesOrange0B5ThemeC","navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"modules":[{"name":"Theme Orange"}],"title":"OrangeTheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"role":"symbol","roleHeading":"Class"},"abstract":[{"type":"text","text":"The Orange theme is the bsic, default, theme for any Orange products."},{"type":"text","text":" "},{"type":"text","text":"This is an override of the abtract "},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"kind":"relationships","title":"Inherits From"},{"type":"conformsTo","identifiers":["doc:\/\/OUDSThemesOrange\/SQ","doc:\/\/OUDSThemesOrange\/s8SendableP","doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP"],"kind":"relationships","title":"Conforms To"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens"],"anchor":"Group","title":"Group"}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"topicSections":[{"generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorMo