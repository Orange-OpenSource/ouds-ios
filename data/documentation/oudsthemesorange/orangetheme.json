{"abstract":[{"text":"This is an override of the default basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},"metadata":{"navigatorTitle":[{"text":"OrangeTheme","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}],"modules":[{"name":"OUDSThemesOrange"}],"roleHeading":"Class","symbolKind":"class","externalID":"s:16OUDSThemesOrange0B5ThemeC","title":"OrangeTheme","role":"symbol"},"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/OUDS\/documentation\/OUDS\/OUDSTheme"],"type":"inheritsFrom","kind":"relationships","title":"Inherits From"},{"identifiers":["doc:\/\/OUDSThemesOrange\/s8SendableP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"seeAlsoSections":[{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens"],"generated":true,"anchor":"Group","title":"Group"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"To use this theme, inject it to your vie