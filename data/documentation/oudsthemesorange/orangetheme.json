pe":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","title":"Theme Orange","role":"collection","kind":"symbol"},"doc://OUDSThemesOrange/SQ":{"identifier":"doc:\/\/OUDSThemesOrange\/SQ","type":"unresolvable","title":"Swift.Equatable"},"ic_theme_orange.png":{"type":"image","identifier":"ic_theme_orange.png","variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"type":"topic","abstract":[{"text":"This enum helps to add new ","type":"text"},{"type":"strong","inlineContent":[{"text":"font raw tokens","type":"text"}]},{"text":" exclusive to this ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","type":"reference"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift enum","type":"text"}]},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_.","type":"text"}],"kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBrandFontRawTokens","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeBrandFontRawTokens","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens","url":"\/documentation\/oudsthemesorange\/orangebrandfontrawtokens","role":"symbol","title":"OrangeBrandFontRawTokens"},"https://brand.orange.com/en/brand-basics/typograph