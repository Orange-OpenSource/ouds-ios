a","kind":"externalParam"},{"text":": (any ","kind":"text"},{"text":"AllTextAreaComponentTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract34AllTextAreaComponentTokensProviderP"},{"text":")?, ","kind":"text"},{"text":"textInput","kind":"externalParam"},{"text":": (any ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract35AllTextInputComponentTokensProviderP","kind":"typeIdentifier","text":"AllTextInputComponentTokensProvider"},{"kind":"text","text":")?, "},{"kind":"externalParam","text":"resourcesBundle"},{"kind":"text","text":": "},{"text":"Bundle","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSBundle"},{"kind":"text","text":", "},{"kind":"externalParam","text":"name"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"fontFamily"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","text":"FontFamilySemanticToken"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tuning"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","text":"Tuning"},{"kind":"text","text":")"}],"title":"init(borders:colors:colorModes:colorsCharts:colorsDecorative:effects:elevations:fonts:grids:opacities:dimensions:sizes:spaces:alert:badge:bar:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:fontFamily:tuning:)","abstract":[{"type":"text","text":"Constructor of the Orange theme."},{"type":"text","text":" "},{"type":"text","text":"It needs several tokens providers for semantic tokens and component tokens."},{"type":"text","text":" "},{"type":"text","text":"If a nil token provider is given, the default version associated fo the theme is used."}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangetheme\/init(borders:colors:colormodes:colorscharts:colorsdecorative:effects:elevations:fonts:grids:opacities:dimensions:sizes:spaces:alert:badge:bar:bulletlist:button:checkbox:chip:controlitem:divider:icon:link:pincodeinput:quantityinput:radiobutt-5knth","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrandColorRawTokens"}],"url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens","abstract":[{"text":"This enum helps to add new ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"color raw tokens"}]},{"type":"text","text":" exclusive to this "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"inlineContent":[{"type":"text","text":"Swift enum"}],"type":"emphasis"},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeBrandColorRawTokens"}],"title":"OrangeBrandColorRawTokens","kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","kind":"symbol","title":"Theme Orange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"role":"collection","url":"\/documentation\/oudsthemesorange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"type":"topic"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference","isActive":true},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","title":"OUDSTheme","role":"symbol","kind":"symbol","url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"type":"topic"},"doc://OUDSThemesOrange/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"doc://OUDSThemesOrange/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP","title":"Swift.Sendable"},"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"type":"image","identifier":"ic_theme_orange.png","alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBrandFontRawTokens","kind":"identifier"}],"title":"OrangeBrandFontRawTokens","navigatorTitle":[{"text":"OrangeBrandFontRawTokens","kind":"identifier"}],"abstract":[{"text":"This enum helps to add new ","type":"text"},{"inlineContent":[{"type":"text","text":"font raw tokens"}],"type":"strong"},{"type":"text","text":" exclusive to this "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"inlineContent":[{"type":"text","text":"Swift enum"}],"type":"emphasis"},{"type":"text","text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangebrandfontrawtokens","type":"topic"},"doc://OUDSThemesOrange/SQ":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/SQ","title":"Swift.Equatable"},"https://brand.orange.com/en/brand-basics/typography":{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","title":"Orange Brand website (authentication needed)","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}],"type":"link"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"role":"symbol","navigatorTitle":[{"text":"OrangeTheme","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"OrangeTheme","kind":"identifier"}],"title":"OrangeTheme","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangetheme","abstract":[{"type":"text","text":"The Orange theme is the bsic, default, theme for any Orange products."},{"type":"text","text":" "},{"type":"text","text":"This is an override of the abtract "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and "},{"inlineContent":[{"text":"must be seen as the default theme for the OUDS library","type":"text"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It can override any properties from its superclass, and can be derived too."}]}}}