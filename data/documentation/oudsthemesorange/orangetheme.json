"OrangeBrandFontRawTokens","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrandFontRawTokens"}],"url":"\/documentation\/oudsthemesorange\/orangebrandfontrawtokens","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"kind":"symbol","type":"topic","title":"OrangeTheme","abstract":[{"type":"text","text":"The Orange theme is the bsic, default, theme for any Orange products."},{"text":" ","type":"text"},{"text":"This is an override of the abtract ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"must be seen as the default theme for the OUDS library","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"url":"\/documentation\/oudsthemesorange\/orangetheme","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}],"role":"symbol"},"doc://OUDSThemesOrange/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP","title":"Swift.Sendable"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens","title":"OrangeBrandColorRawTokens","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","abstract":[{"type":"text","text":"This enum helps to add new "},{"inlineContent":[{"type":"text","text":"color raw tokens"}],"type":"strong"},{"type":"text","text":" exclusive to this "},