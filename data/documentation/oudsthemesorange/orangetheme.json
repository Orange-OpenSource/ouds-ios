{"abstract":[{"text":"The Orange theme is the bsic, default, theme for any Orange products.","type":"text"},{"text":" ","type":"text"},{"text":"This is an override of the abtract ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"must be seen as the default theme for the OUDSThemesContract library","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"generated":true,"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:charts:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:family:tuning:)"],"anchor":"Initializers"}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangetheme"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Usages","type":"heading","anchor":"Usages","level":1},{"inlineContent":[{"text":"Any Orange products must use this theme. It provides core and Orange colors and any elements for sizings, spacings and dimensions for example.","type":"text"},{"text":" ","type":"text"},{"text":"The system font families are used; no ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helevetica"}]},{"text":" font family is embeded nor provider by OUDSThemesContract.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This theme also provides colors charts tokens."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The theme can be got through environment variable:"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.theme) var theme"],"type":"codeListing"},{"text":"Integration","type":"heading","anchor":"Integration","level":2},{"inlineContent":[{"text":"To use this theme, inject it to your view using ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" and get it through environment variable.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing"},{"text":"Theme tuning","type":"heading","anchor":"Theme-tuning","level":2},{"inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"code":"Tuning","type":"codeVoice"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To apply the tuning:"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","    \/\/ Apply it to your theme","    let theme = OrangeTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeTheme(tuning: Tuning.MaxIt)"],"type":"codeListing"},{"type":"heading","level":2,"anchor":"Typography","text":"Typography"},{"type":"heading","level":3,"anchor":"Helvetica-Neue","text":"Helvetica Neue"},{"type":"paragraph","inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":" font family is available at system level, so it is not needed to get it through external assets.","type":"text"},{"text":" ","type":"text"},{"text":"By default an instance of ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"text":" uses as font family the token ","type":"text"},{"type":"codeVoice","code":"OrangeBrandFontRawTokens.familyBrandDefault"},{"text":", which is today ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use another font family, you will have to send the suitable token or the suitable font family.","type":"text"},{"text":" ","type":"text"},{"text":"However, beware, iOS API relies also on the PostScript name of the font.","type":"text"},{"text":" ","type":"text"},{"text":"To be sure of the value to use, look at the font book of your device.","type":"text"},{"text":" ","type":"text"},{"text":"It is recommended to use the font raw tokens.","type":"text"}]},{"type":"codeListing","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeTheme()","    let orangeTheme = OrangeTheme(family: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeTheme(family: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeTheme(family: \"Helvetica Neue\") \/\/ Which is font family nale"],"syntax":"swift"},{"type":"heading","level":3,"anchor":"Helvetica-Neue-Arabic","text":"Helvetica Neue Arabic"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue Arabic","type":"text"}]},{"type":"text","text":". This font family assets can be retrieved through the "},{"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}]},{"type":"codeListing","code":["    let orangeTheme = OrangeTheme(family: \"Helvetica Neue Arabic\")"],"syntax":"swift"},{"type":"heading","level":2,"anchor":"Tokens-loading","text":"Tokens loading"},{"type":"paragraph","inlineContent":[{"text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"For example:","type":"text"}]},{"type":"codeListing","code":["   \/\/ Use some already defined providers","   let borders = OrangeThemeBorderSemanticTokensProvider()","   let sizes = OrangeThemeSizeSemanticTokensProvider()","   let spaces = OrangeThemeSpaceSemanticTokensProvider()","","   \/\/ For example, use your own provider of color semantic tokens","   \/\/ It must inherit from OrangeThemeBorderSemanticTokensProvider (which is instance of AllColorSemanticTokensProvider) or directly implement AllColorSemanticTokensProvider","   let colors = YourOwnColorSemanticTokensProvider()","","   \/\/ Some providers need other providers to use their tokens","   let button = OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces)","","   \/\/ But you can also use the providers as they are without assigning semantic tokens providers","   \/\/ and just use the default ones","   let badge = OrangeThemeBadgeComponentTokensProvider()","","   \/\/ Define in the end your theme by overriding some providers.","   \/\/ You can override all providers, or only some, or just keep the theme as is.","   \/\/ However you should uses thhese providers in a dedicated Orange theme subclass for clarity reasons.","   let yourOwnOrangeTheme = OrangeTheme(colors: colors, borders: borders, sizes: sizes, spaces: spaces, button: button, badge: badge)"],"syntax":"swift"},{"type":"aside","name":"Since","style":"note","content":[{"inlineContent":[{"text":"0.8.0","type":"text"}],"type":"paragraph"}]}]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"externalID":"s:16OUDSThemesOrange0B5ThemeC","title":"OrangeTheme","modules":[{"name":"Theme Orange"}],"role":"symbol","symbolKind":"class","roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}]},"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"type":"inheritsFrom"},{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSThemesOrange\/s8SendableP","doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP"],"type":"conformsTo"}],"seeAlsoSections":[{"generated":true,"title":"Group","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens"],"anchor":"Group"}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"type":"topic","title":"OrangeTheme","abstract":[{"type":"text","text":"The Orange theme is the bsic, default, theme for any Orange products."},{"type":"text","text":" "},{"type":"text","text":"This is an override of the abtract "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDSThemesContract library"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It can override any properties from its superclass, and can be derived too."}],"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"url":"\/documentation\/oudsthemesorange\/orangetheme","kind":"symbol"},"https://brand.orange.com/en/brand-basics/typography":{"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}],"type":"link","title":"Orange Brand website (authentication needed)","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"url":"\/documentation\/oudsthemescontract\/oudstheme","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference","isActive":true},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"text":", or ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"kind":"symbol","title":"OUDSTheme","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"type":"topic","role":"collection","title":"Theme Orange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","abstract":[{"type":"text","text":"This enum helps to add new "},{"inlineContent":[{"text":"color raw tokens","type":"text"}],"type":"strong"},{"type":"text","text":" exclusive to this "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","isActive":true,"type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"inlineContent":[{"text":"Swift enum","type":"text"}],"type":"emphasis"},{"type":"text","text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrandColorRawTokens"}],"title":"OrangeBrandColorRawTokens","kind":"symbol","type":"topic","url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeBrandColorRawTokens"}]},"doc://OUDSThemesOrange/s8SendableP":{"identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"doc://OUDSThemesOrange/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"title":"OrangeBrandFontRawTokens","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFon