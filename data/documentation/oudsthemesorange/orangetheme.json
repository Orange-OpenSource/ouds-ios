:"text"},{"text":"tuning","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Tuning","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"\/documentation\/oudsthemesorange\/orangetheme\/init(borders:colors:colormodes:charts:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bulletlist:button:checkbox:chip:controlitem:divider:icon:link:pincodeinput:quantityinput:radiobutton:selectinput:skeleton:switch:tag:inputt-5ok3d","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:charts:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:family:tuning:)","abstract":[{"type":"text","text":"Constructor of the Orange theme."},{"type":"text","text":" "},{"type":"text","text":"It needs several tokens providers for semantic tokens and component tokens."},{"type":"text","text":" "},{"type":"text","text":"If a nil token provider is given, the default version associated fo the theme is used."}],"title":"init(borders:colors:colorModes:charts:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:family:tuning:)"},"doc://OUDSThemesOrange/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrandFontRawTokens"}],"title":"OrangeBrandFontRawTokens","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeBrandFontRawTokens"}],"url":"\/documentation\/oudsthemesorange\/orangebrandfontrawtokens","abstract":[{"type":"text","text":"This enum helps to add new "},{"type":"strong","inlineContent":[{"type":"text","text":"font raw tokens"}]},{"type":"text","text":" exclusive to this "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift enum"}]},{"type":"text","text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"role":"collection","title":"Theme Orange","url":"\/documentation\/oudsthemesorange","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"},"https://brand.orange.com/en/brand-basics/typography":{"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"link","title":"Orange Brand website (authentication needed)","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"url":"\/documentation\/oudsthemescontract\/oudstheme","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"code":"class","type":"codeVoice"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"title":"OUDSTheme","kind":"symbol"},"doc://OUDSThemesOrange/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrandColorRawTokens"}],"title":"OrangeBrandColorRawTokens","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeBrandColorRawTokens"}],"url":"\/documentation\/oudsthemesorange\/orangebrandcolorrawtokens","abstract":[{"type":"text","text":"This enum helps to add new "},{"type":"strong","inlineContent":[{"type":"text","text":"color raw tokens"}]},{"type":"text","text":" exclusive to this "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift enum"}]},{"type":"text","text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}]},"ic_theme_orange.png":{"alt":null,"type":"image","variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"identifier":"ic_theme_orange.png"}}}