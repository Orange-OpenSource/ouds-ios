all providers, or only some, or just keep the theme as is.","   let yourOwnOrangeTheme = OrangeTheme(colors: colors, borders: borders, sizes: sizes, spaces: spaces, button: button, badge: badge)",""]},{"inlineContent":[{"text":"Then get it:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["    import OUDS","","    @Environment(\\.theme) var theme"]},{"type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.8.0","type":"text"}]}],"style":"note"}],"kind":"content"}],"topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:elevations:fonts:grids:opacities:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:inputText:listItem:link:radioButton:select:skeleton:switch:tag:fontFamily:)"],"generated":true,"anchor":"Initializers","title":"Initializers"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangetheme"]}],"references":{"doc://OUDSThemesOrange/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/s8SendableP","title":"Swift.Sendable"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"title":"OrangeTheme","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeTheme","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangetheme","abstract":[{"text":"This is an override of the default basic ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"must be seen as the default theme for the OUDS library","type":"text"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived