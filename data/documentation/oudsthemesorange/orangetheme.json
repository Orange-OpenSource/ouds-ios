{"seeAlsoSections":[{"title":"Group","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens"],"generated":true,"anchor":"Group"}],"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","title":"Inherits From","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"]},{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSThemesOrange\/SQ","doc:\/\/OUDSThemesOrange\/s8SendableP","doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP"]}],"abstract":[{"type":"text","text":"The Orange theme is the bsic, default, theme for any Orange products."},{"type":"text","text":" "},{"type":"text","text":"This is an override of the abtract "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}],"type":"strong"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"modules":[{"name":"Theme Orange"}],"role":"symbol","title":"OrangeTheme","navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"externalID":"s:16OUDSThemesOrange0B5ThemeC","roleHeading":"Class","symbolKind":"class"},"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:colorsCharts:colorsDecorative:effects:elevations:fonts:grids:opacities:dimensions:sizes:spaces:alert:badge:bar:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:fontFamily:tuning:)"],"generated":true}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangetheme"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"Usages","type":"heading","text":"Usages","level":1},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any Orange products must use this theme. It provides core and Orange colors and any elements for sizings, spacings and dimensions for example."},{"type":"text","text":" "},{"type":"text","text":"The system font families are used; no "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helevetica"}]},{"type":"text","text":" font family is embeded nor providd  by OUDS."},{"type":"text","text":" "},{"text":"This theme also provides colors charts tokens.","type":"text"}]},{"inlineContent":[{"text":"The theme can be got through environment variable:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.theme) var theme"],"type":"codeListing"},{"text":"Integration","anchor":"Integration","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" and get it through environment variable."}],"type":"paragraph"},{"code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"syntax":"swift","type":"codeListing"},{"text":"Theme tuning","anchor":"Theme-tuning","type":"heading","level":2},{"inlineContent":[{"text":"The theme can be customized a bit for more flexibility thanks to ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object.","type":"text"},{"text":" ","type":"text"},{"text":"You just need to give a predefined tuning configuration at theme init to build the one you need.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To apply the tuning:"}],"type":"paragraph"},{"code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true)","","    \/\/ Apply it to your theme","    let theme = OrangeTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true, hasRoundedAlertMessages: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeTheme(tuning: Tuning.MaxIt)"],"syntax":"swift","type":"codeListing"},{"text":"Typography","anchor":"Typography","type":"heading","level":2},{"text":"Helvetica Neue","anchor":"Helvetica-Neue","type":"heading","level":3},{"inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For iOS the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":" uses as font family the token "},{"type":"codeVoice","code":"OrangeBrandFontRawTokens.familyBrandDefault"},{"type":"text","text":", which is today "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeTheme()","    let orangeTheme = OrangeTheme(fontFamily: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeTheme(fontFamily: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeTheme(fontFamily: \"Helvetica Neue\") \/\/ Which is font family nale"],"type":"codeListing"},{"text":"Helvetica Neue Arabic","level":3,"type":"heading","anchor":"Helvetica-Neue-Arabic"},{"inlineContent":[{"type":"text","text":"Because the "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}]},{"type":"text","text":". This font family assets can be retrieved through the "},{"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}],"type":"paragraph"},{"syntax":"swift","code":["    let orangeTheme = OrangeTheme(family: \"Helvetica Neue Arabic\")"],"type":"codeListing"},{"text":"Tokens loading","level":2,"type":"heading","anchor":"Tokens-loading"},{"inlineContent":[{"type":"text","text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"For example:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["   \/\/ Use some already defined providers","   let borders = OrangeThemeBorderSemanticTokensProvider()","   let sizes = OrangeThemeSizeSemanticTokensProvider()","   let spaces = OrangeThemeSpaceSemanticTokensProvider()","","   \/\/ For example, use your own provider of color semantic tokens","   \/\/ It must inherit from OrangeThemeBorderSemanticTokensProvider (which is instance of AllColorSemanticTokensProvider) or directly implement AllColorSemanticTokensProvider","   let colors = YourOwnColorSemanticTokensProvider()","","   \/\/ Some providers need other providers to use their tokens","   let button = OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces)","","   \/\/ But you can also use the providers as they are without assigning semantic tokens providers","   \/\/ and just use the default ones","   let badge = OrangeThemeBadgeComponentTokensProvider()","","   \/\/ Define in the end your theme by overriding some providers.","   \/\/ You can override all providers, or only some, or just keep the theme as is.","   \/\/ However you should uses thhese providers in a dedicated Orange theme subclass for clarity reasons.","   let yourOwnOrangeTheme = OrangeTheme(colors: colors, borders: borders, sizes: sizes, spaces: spaces, button: button, badge: badge)"]},{"type":"heading","level":2,"text":"Tokens versions","anchor":"Tokens-versions"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Core OUDS version: 1.10.0"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Core Orange version: 1.2.0"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Brand Orange version: 2.5.0","type":"text"}]}]}]},{"type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"style":"note"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"references":{"ic_theme_orange.png":{"identifier":"ic_theme_orange.png","type":"image","variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"alt":null},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"url":"\/documentation\/oudsthemescontract\/oudstheme","title":"OUDSTheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSTheme"}],"kind":"symbol","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"text":", or ","type":"text"},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"type":"topic","abstract":[{"type":"text","text":"The Orange theme is the bsic, default, theme for any Orange products."},{"type":"text","text":" "},{"type":"text","text":"This is an override of the abtract "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"text":"must be seen as the default theme for the OUDS library","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It can override any properties from its superclass, and can be derived too."}],"role":"symbol","title":"OrangeTheme","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","url":"\/docume