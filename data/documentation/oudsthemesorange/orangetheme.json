{"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(borders:colors:colorModes:charts:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:family:tuning:)"],"generated":true}],"seeAlsoSections":[{"anchor":"Group","title":"Group","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandColorRawTokens","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens"],"generated":true}],"schemaVersion":{"major":0,"patch":0,"minor":3},"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"kind":"relationships"},{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSThemesOrange\/s8SendableP","doc:\/\/OUDSThemesOrange\/s16SendableMetatypeP"],"kind":"relationships"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}]}],"kind":"declarations"},{"content":[{"anchor":"Usages","type":"heading","level":1,"text":"Usages"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any Orange products must use this theme. It provides core and Orange colors and any elements for sizings, spacings and dimensions for example."},{"type":"text","text":" "},{"type":"text","text":"The system font families are used; no "},{"inlineContent":[{"text":"Helevetica","type":"text"}],"type":"emphasis"},{"type":"text","text":" font family is embeded nor providd  by OUDS."},{"type":"text","text":" "},{"type":"text","text":"This theme also provides colors charts tokens."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be got through environment variable:"}]},{"code":["    @Environment(\\.theme) var theme"],"type":"codeListing","syntax":"swift"},{"anchor":"Integration","type":"heading","level":2,"text":"Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" and get it through environment variable."}]},{"code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing","syntax":"swift"},{"anchor":"Theme-tuning","type":"heading","level":2,"text":"Theme tuning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"code":"Tuning","type":"codeVoice"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To apply the tuning:"}]},{"code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","    \/\/ Apply it to your theme","    let theme = OrangeTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeTheme(tuning: Tuning.MaxIt)"],"type":"codeListing","syntax":"swift"},{"anchor":"Typography","type":"heading","level":2,"text":"Typography"},{"anchor":"Helvetica-Neue","type":"heading","level":3,"text":"Helvetica Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange brand strongly relies on the "},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"type":"text","text":" font family. Thus each Orange brand should, or must, use it."},{"type":"text","text":" "},{"type":"text","text":"For iOS the "},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":" uses as font family the token "},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"type":"text","text":", which is today "},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeTheme()","    let orangeTheme = OrangeTheme(family: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeTheme(family: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeTheme(family: \"Helvetica Neue\") \/\/ Which is font family nale"],"type":"codeListing","syntax":"swift"},{"anchor":"Helvetica-Neue-Arabic","type":"heading","level":3,"text":"Helvetica Neue Arabic"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the "},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"inlineContent":[{"text":"Helvetica Neue Arabic","type":"text"}],"type":"emphasis"},{"type":"text","text":". This font family assets can be retrieved through the "},{"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}]},{"code":["    let orangeTheme = OrangeTheme(family: \"Helvetica Neue Arabic\")"],"type":"codeListing","syntax":"swift"},{"anchor":"Tokens-loading","type":"heading","level":2,"text":"Tokens loading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"For example:"}]},{"code":["   \/\/ Use some already defined providers","   let borders = OrangeThemeBorderSemanticTokensProvider()","   let sizes = OrangeThemeSizeSemanticTokensProvider()","   let spaces = OrangeThemeSpaceSemanticTokensProvider()","","   \/\/ For example, use your own provider of color semantic tokens","   \/\/ It must inherit from OrangeThemeBorderSemanticTokensProvider (which is instance of AllColorSemanticTokensProvider) or directly implement AllColorSemanticTokensProvider","   let colors = YourOwnColorSemanticTokensProvider()","","   \/\/ Some providers need other providers to use their tokens","   let button = OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces)","","   \/\/ But you can also use the providers as they are without assigning semantic tokens providers","   \/\/ and just use the default ones","   let badge = OrangeThemeBadgeComponentTokensProvider()","","   \/\/ Define in the end your theme by overriding some providers.","   \/\/ You can override all providers, or only some, or just keep the theme as is.","   \/\/ However you should uses thhese providers in a dedicated Orange theme subclass for clarity reasons.","   let yourOwnOrangeTheme = OrangeTheme(colors: colors, borders: borders, sizes: sizes, spaces: spaces, button: button, badge: badge)"],"type":"codeListing","syntax":"swift"},{"type":"aside","name":"Since","style":"note","content":[{"inlineContent":[{"text":"0.8.0","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"metadata":{"role":"symbol","title":"OrangeTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeTheme","kind":"identifier"}],"symbolKind":"class","externalID":"s:16OUDSThemesOrange0B5ThemeC","roleHeading":"Class","modules":[{"name":"Theme Orange"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangetheme"]}],"abstract":[{"text":"The Orange theme is the bsic, default, theme for any Orange products.","type":"text"},{"text":" ","type":"text"},{"text":"This is an override of the abtract ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"}],"kind":"symbol","references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"title":"OrangeTheme","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"url":"\/documentation\/oudsthemesorange\/orangetheme","abstract":[{"type":"text","text":"The Orange theme is the bsic, default, theme for any Orange products."},{"type":"text","text":" "},{"type":"text","text":"This is an override of the abtract "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It can override any properties from its superclass, and can be derived too."}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme/init(borders:colors:colorModes:charts:elevations:fonts:grids:opacities:dimensions:sizes:spaces:badge:bulletList:button:checkbox:chip:controlItem:divider:icon:link:pinCodeInput:quantityInput:radioButton:selectInput:skeleton:switch:tag:inputTag:textArea:textInput:resourcesBundle:name:family:tuning:)":{"kind":"symbol","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"borders","kind":"externalParam"},{"text":": (any ","kind":"text"},{"text":"AllBorderSemanticTokensProvider","preciseIdentifier":"s:18OUDSThemesContract31AllBorderSemanticTokensProviderP","kind":"typeIdentifier"},{"text":")?