heme for the OUDS library with the Orange brand colors for example.","type":"text"}],"role":"collection","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"kind":"symbol","url":"\/documentation\/oudsthemesorange","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangebrandfontrawtokens","navigatorTitle":[{"kind":"identifier","text":"OrangeBrandFontRawTokens"}],"abstract":[{"text":"This enum helps to add new ","type":"text"},{"inlineContent":[{"text":"font raw tokens","type":"text"}],"type":"strong"},{"text":" exclusive to this ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","type":"reference"},{"text":" ","type":"text"},{"text":"Such tokens are packed in a ","type":"text"},{"inlineContent":[{"text":"Swift enum","type":"text"}],"type":"emphasis"},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_.","type":"text"}],"role":"symbol","title":"OrangeBrandFontRawTokens","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrandFontRawTokens"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"kind":"symbol","url":"\/documentation\/oudsthemescontract\/oudstheme","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"role":"symbol","title":"OUDSTheme","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}]}}}