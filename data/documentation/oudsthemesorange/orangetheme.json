xt":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"fontFamily","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FontFamilySemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"tuning","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Tuning","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandFontRawTokens":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeBrandFontRawTokens"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrandFontRawTokens"}],"kind":"symbol","type":"topic","url":"\/documentation\/oudsthemesorange\/orangebrandfontrawtokens","abstract":[{"type":"text","text":"This enum helps to add new "},{"type":"strong","inlineContent":[{"type":"text","text":"font raw tokens"}]},{"type":"text","text":" exclusive to this "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":" "},{"type":"text","text":"Such tokens are packed in a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift enum"}]},{"type":"text","text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else"},{"type":"text","text":" "},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than dimensionstruct_."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeBrandFontRawTokens","title":"OrangeBrandFontRawTokens"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeBrandColorRawTokens":{"kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBrand