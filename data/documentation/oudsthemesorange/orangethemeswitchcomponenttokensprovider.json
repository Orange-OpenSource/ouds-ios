{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your own provider for switch component tokens","    \/\/ by inheriting from existing provider","    class CustomSwitchComponentTokensProvider: OrangeThemeSwitchComponentTokensProvider {","","        \/\/ Then override the switch component tokens you want.","","        override var switchColorCursor: MultipleColorSemanticTokens { colors.colorRepositoryPositiveDefault }","","        override var switchSpacePaddingInlineUnselected: SpaceSemanticToken { spaces.spaceFixedShortest }","","        override var switchSize: SizeSemanticToken { sizes.sizeIconWithLabelLargeSizeXl }","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomSwitchComponentTokensProvider: SwitchComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomSwitchComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}]},{"type":"codeListing","syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(switch: CustomSwitchComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}]},{"type":"codeListing","syntax":"swift","code":["    OrangeTheme(switch: CustomSwitchComponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeOpacitySemanticTokensProvider for opacities","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    let switchComponentTokensProvider = OrangeThemeSwitchComponentTokensProvider()","","    \/\/ Or use your own size, color, border, space and opacities semantic tokens providers (or only some)","    let switchComponentTokensProvider = OrangeThemeSwitchComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider(),","                                                colors: CustomColorSemanticTokensProvider(),","                                                space: CustomSpaceSemanticTokensProvider(),","                                                opacities: CustomOpacitySemanticTokensProvider())"]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.9.0"}]}],"style":"note","name":"Since"}],"kind":"content"}],"sections":[],"kind":"symbol","topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/init(sizes:borders:colors:spaces:opacities:)"]},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/borders","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/colors","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/opacities","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/spaces"]},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/SwitchComponentTokens-Implementations"]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeSwitchComponentTokensProvider"}],"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeSwitchComponentTokensProvider"}],"modules":[{"name":"OUDSThemesOrange"}],"symbolKind":"class","title":"OrangeThemeSwitchComponentTokensProvider","externalID":"s:16OUDSThemesOrange0B34ThemeSwitchComponentTokensProviderC","roleHeading":"Class"},"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component  tokens of switch","type":"text"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"switch \/ toggle"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllSwitchComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"SwitchComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"switch \/ toggle"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Switch"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpacesSemanticTokensProvider"},{"type":"text","text":") , sizes ("},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":") and opacities ("},{"type":"codeVoice","code":"AllOpacitiySemanticTokensProvider"},{"type":"te