{"sections":[],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component  tokens of switch","type":"text"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"switch \/ toggle"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllSwitchComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"SwitchComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"switch \/ toggle","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Switch"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpacesSemanticTokensProvider"},{"type":"text","text":") ,  dimensions ("},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"sizes ("},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":") and opacities ("},{"type":"codeVoice","code":"AllOpacitiySemanticTokensProvider"},{"type":"text","text":")."}],"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/init(sizes:borders:colors:spaces:opacities:dimensions:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/borders","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/colorCheckInteraction","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/colors","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/dimensions","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/opacities","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/sizeMinHeightInteractiveArea","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/spaces"]},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/SwitchComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/TokensProvider-Implementations"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider"]}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllSwitchComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent06SwitchB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"kind":"relationships","type":"conformsTo"}],"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeSwitchComponentTokensProvider"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"codeListing","code":["    \/\/ Define your own provider for switch component tokens","    \/\/ by inheriting from existing provider","    class CustomSwitchComponentTokensProvider: OrangeThemeSwitchComponentTokensProvider {","","        \/\/ Then override the switch component tokens you want.","","        override var colorCursor: MultipleColorSemanticTokens { colors.repositoryPositiveMedium }","","        override var spacePaddingInlineUnselected: SpaceSemanticToken { spaces.fixed2xsmall }","","        override var size: SizeSemanticToken { sizes.iconWithLabelLargeSizeXl }","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomSwitchComponentTokensProvider: SwitchComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"syntax":"swift"},{"inlineContent":[{"text":"Then, you can give this ","type":"text"},{"type":"codeVoice","code":"CustomSwitchComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(switch: CustomSwitchComponentTokensProvider())","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["    OrangeTheme(switch: CustomSwitchComponentTokensProvider())"],"syntax":"swift"},{"inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeOpacitySemanticTokensProvider for opacities","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    let switchComponentTokensProvider = OrangeThemeSwitchComponentTokensProvider()","","    \/\/ Or use your own _, color, border, space and opacities semantic tokens providers (or only some)","    let switchComponentTokensProvider = OrangeThemeSwitchComponentTokensProvider(","                                                sizes: CustomSizesSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider(),","                                                colors: CustomColorSemanticTokensProvider(),","                                                spaces: CustomSpaceSemanticTokensProvider(),","                                                opacities: CustomOpacitySemanticTokensProvider()","                                                dimensions: CustomDimensionSemanticTokensProvider())"],"syntax":"swift"},{"style":"note","type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.9.0","type":"text"}]}]}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"metadata":{"externalID":"s:16OUDSThemesOrange0B34ThemeSwitchComponentTokensProviderC","navigatorTitle":[{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeSwitchComponentTokensProvider","modules":[{"name":"Theme Orange"}],"symbolKind":"class","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"roleHeading":"Class"},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/init(sizes:borders:colors:spaces:opacities:dimensions:)":{"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/init(sizes:borders:colors:spaces:opacities:dimensions:)","title":"init(sizes:borders:colors:spaces:opacities:dimensions:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"sizes","kind":"externalParam"},{"text":": (any ","kind":"text"},{"text":"AllSizeSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract29AllSizeSemanticTokensProviderP"},{"text":")?, ","kind":"text"},{"text":"borders","kind":"externalParam"},{"text":": (any ","kind":"text"},{"text":"AllB