{"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"abstract":[{"text":"A class which wraps all ","type":"text"},{"inlineContent":[{"text":"component  tokens of switch","type":"text"}],"type":"strong"},{"text":" for ","type":"text"},{"inlineContent":[{"text":"switch \/ toggle","type":"text"}],"type":"emphasis"},{"text":" objects like ","type":"text"},{"code":"OUDSSwitch","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"text":"This provider should be integrated as a ","type":"text"},{"code":"AllSwitchComponentTokensProvider","type":"codeVoice"},{"text":" implementation inside ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" so as to provide","type":"text"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"SwitchComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"text":"switch \/ toggle","type":"text"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Switch"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"text":") ,  dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"sizes (","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":"), borders (","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":") and opacities (","type":"text"},{"code":"AllOpacitiySemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/init(sizes:borders:colors:spaces:opacities:dimensions:)"],"title":"Initializers","generated":true},{"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/borders","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/colorCheckInteraction","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/colors","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/dimensions","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/opacities","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/sizeMinHeightInteractiveArea","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/spaces"],"title":"Instance Properties","generated":true},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/SwitchComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/TokensProvider-Implementations"],"title":"Default Implementations","generated":true}],"metadata":{"role":"symbol","externalID":"s:16OUDSThemesOrange0B34ThemeSwitchComponentTokensProviderC","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"symbolKind":"class","modules":[{"name":"Theme Orange"}],"title":"OrangeThemeSwitchComponentTokensProvider","roleHeading":"Class"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeSwitchComponentTokensProvider"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"syntax":"swift","code":["    \/\/ Define your own provider for switch component tokens","    \/\/ by inheriting from existing provider","    class CustomSwitchComponentTokensProvider: OrangeThemeSwitchComponentTokensProvider {","","        \/\/ Then override the switch component tokens you want.","","        override var colorCursor: MultipleColorSemanticToken { colors.repositoryPositiveMedium }","","        override var spacePaddingInlineUnselected: SpaceSemanticToken { spaces.fixed2xsmall }","","        override var size: SizeSemanticToken { sizes.iconWithLabelLargeSizeXl }","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomSwitchComponentTokensProvider: SwitchComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomSwitchComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(switch: CustomSwitchComponentTokensProvider())","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}],"type":"paragraph"},{"syntax":"swift","code":["    OrangeTheme(switch: CustomSwitchComponentTokensProvider())"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeOpacitySemanticTokensProvider for opacities","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    let switchComponentTokensProvider = OrangeThemeSwitchComponentTokensProvider()","","    \/\/ Or use your own dimension, color, border, space and opacities semantic tokens providers (or only some)","    let switchComponentTokensProvider = OrangeThemeSwitchComponentTokensProvider(","                                                sizes: CustomSizesSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider(),","                                                colors: CustomColorSemanticTokensProvider(),","                                                spaces: CustomSpaceSemanticTokensProvider(),","                                                opacities: CustomOpacitySemanticTokensProvider()","                                                dimensions: CustomDimensionSemanticTokensProvider())"],"type":"codeListing"},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"text":"0.9.0","type":"text"}],"type":"paragraph"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider"]}],"sections":[],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllSwitchComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent06SwitchB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesOrange\/s9EscapableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"kind":"relationships","title":"Conforms To"}],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/borders":{"kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/borders","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"borders","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllBorderSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract31AllBorderSemanticTokensProviderP"}],"title":"borders","abstract":[{"type":"text","text":"Provider of border semantic tokens to use for switch borders"}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/borders","type":