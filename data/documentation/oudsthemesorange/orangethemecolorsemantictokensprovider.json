{"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"color semantic tokens","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"multiple"}]},{"type":"text","text":" or not, and expose them."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeColorSemanticTokensProvider"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your own provider for color semantic tokens","    class CustomColorTokensProviderr: OrangeThemeColorSemanticTokensProvider {","","        \/\/ Then override the color semantic tokens you want, using the color raw tokens available","","        override var bgSecondary: MultipleColorSemanticToken {","            MultipleColorSemanticToken(light: ColorRawTokens.colorDecorativeAmber500, dark: OrangeBrandColorRawTokens.colorOrange900)","        }","","        override var actionEnabled: MultipleColorSemanticToken {","            MultipleColorSemanticToken(light: ColorRawTokens.colorDecorativeShockingPink100, dark: ColorRawTokens.functionalScarlet600)","        }","}"]},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomColorTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(colors: CustomColorTokensProvider())","    }","}"]},{"inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["    OrangeTheme(colors: CustomColorTokensProvider())"]},{"content":[{"inlineContent":[{"type":"text","text":"0.8.0"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Since"}]}],"metadata":{"roleHeading":"Class","role":"symbol","title":"OrangeThemeColorSemanticTokensProvider","navigatorTitle":[{"text":"OrangeThemeColorSemanticTokensProvider","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeColorSemanticTokensProvider"}],"modules":[{"name":"Theme Orange"}],"symbolKind":"class","externalID":"s:16OUDSThemesOrange0B32ThemeColorSemanticTokensProviderC"},"relationshipsSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllColorSemanticTokensProvider","doc:\/\/OUDSThemesOrange\/18OUDSTokensSemantic013ColorMultipleB6TokensP","doc:\/\/OUDSThemesOrange\/18OUDSTokensSemantic05ColorB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesOrange\/s9EscapableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeColorSemanticTokensProvider\/init()"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeColorSemanticTokensProvider\/ColorMultipleSemanticTokens-Implementations","doc:\/\/OUDSThemesOrange\