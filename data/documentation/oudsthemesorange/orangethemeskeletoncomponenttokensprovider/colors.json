kensprovider","abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"text":"component  tokens of skeleton","type":"text"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"text":"skeleton","type":"text"}],"type":"emphasis"},{"type":"text","text":" objects like "},{"code":"OUDSSkeleton","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllSkeletonComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider","type":"reference","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"SkeletonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"skeleton"}],"type":"emphasis"},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Skeleton","type":"text"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":")."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeSkeletonComponentTokensProvider"}],"title":"OrangeThemeSkeletonComponentTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSkeletonComponentTokensProvider/colors":{"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider\/colors","type":"topic","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"colors","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllColorSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP"}],"kind":"symbol","title":"colors","abstract":[{"text":"Provider of color semantic tokens to use for link colors","type":"text"}],"url":"\/documentation\/oudsthemesorange\/orangethemeskeletoncomponenttokensprovider\/colors"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"type":"topic","url":"\/documentation\/oudsthemesorange","role":"collection","kind":"symbol","title":"OUDSThemesOrange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"},"doc://OUDS/documentation/OUDS/AllColorSemanticTokensProvider":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AllColorSemanticTokensProvider"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:4OUDS14TokensProviderP","text":"TokensProvider"},{"kind":"text","text":", "},{"kind":"ty