d.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"code":"SkeletonComponentTokens","type":"codeVoice"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"type":"text","text":"skeleton"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Skeleton"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeSkeletonComponentTokensProvider","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol","title":"OrangeThemeSkeletonComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemeskeletoncomponenttokensprovider","navigatorTitle":[{"text":"OrangeThemeSkeletonComponentTokensProvider","kind":"identifier"}]},"ic_theme_orange.png":{"identifier":"ic_theme_orange.png","alt":null,"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"type":"image"}}}