g"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextInputComponentTokensProvider":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeTextInputComponentTokensProvider","kind":"identifier"}],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of input text"}]},{"text":" for ","type":"text"},{"inlineContent":[{"type":"text","text":"input text"}],"type":"emphasis"},{"text":" objects like ","type":"text"},{"type":"codeVoice","code":"OUDSTextInput"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllTextInputComponentTokensProvider"},{"text":" implementation inside ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" so as to provide","type":"text"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider","isActive":true,"type":"reference"},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"code":"TextInputComponentTokens","type":"codeVoice"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"text":"input text","type":"text"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Inout text"}]},{"text":" components tokens are defined with raw and semantic tokens of colors (","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"borders (from ","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":"), spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and  dimensions (from ","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider","type":"topic","title":"OrangeThemeTextInputComponentTokensProvider","navigatorTitle":[{"text":"OrangeThemeTextInputComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemetextinputcomponenttokensprovider","kind":"symbol","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextInputComponentTokensProvider/sizeVerticalDividerHeight":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/sizeVerticalDividerHeight","role":"symbol","abstract":[{"ty