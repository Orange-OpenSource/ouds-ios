esContract/AllBorderSemanticTokensProvider":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllBorderSemanticTokensProvider","role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AllBorderSemanticTokensProvider","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"TokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract14TokensProviderP"},{"text":", ","kind":"text"},{"text":"BorderSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic06BorderB6TokensP"}],"title":"AllBorderSemanticTokensProvider","url":"\/documentation\/oudsthemescontract\/allbordersemantictokensprovider","abstract":[{"text":"Something which provides all semantic tokens of border","type":"text"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextInputComponentTokensProvider":{"url":"\/documentation\/oudsthemesorange\/orangethemetextinputcomponenttokensprovider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeTextInputComponentTokensProvider"}],"title":"OrangeThemeTextInputComponentTokensProvider","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component  tokens of input text","type":"text"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"input text"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSTextInput"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllTextInputComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"TextInputComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"input text"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Inout text","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of colors ("},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"borders (from "},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"), spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and  dimensions (from "},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeTextInputComponentTokensProvider"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"Theme Orange","url":"\/documentation\/oudsthemesorange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"role":"collection","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"kind":"symbol","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextInputComponentTokensProvider/borders":{"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"borders"},{"kind":"text","text":": any "},{"preciseIdentifier":"s:18OUDSThemesContract31AllBorderSemanticTokensProviderP","kind":"typeIdentifier","text":"AllBorderSemanticTokensProvider"}],"type":"topic","url":"\/documentation\/oudsthemesorange\/orangethemetextinputcomponenttokensprovider\/borders","abstract":[{"type":"text","text":"Provider of borders semantic tokens to use for text input colors"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/borders","title":"borders"}}}