otocol ","type":"text"},{"code":"TextInputComponentTokens","type":"codeVoice"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"text":"input text","type":"text"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Inout text"}]},{"text":" components tokens are defined with raw and semantic tokens of colors (","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"borders (from ","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":"), spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and  dimensions (from ","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider","type":"topic","title":"OrangeThemeTextInputComponentTokensProvider","navigatorTitle":[{"text":"OrangeThemeTextInputComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemetextinputcomponenttokensprovider","kind":"symbol","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextInputComponentTokensProvider/sizeMaxWidth":{"abstract":[{"text":"Has for value token DimensionRawTokens._4000","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizeMaxWidth"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","text":"SizeSemanticToken"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentT