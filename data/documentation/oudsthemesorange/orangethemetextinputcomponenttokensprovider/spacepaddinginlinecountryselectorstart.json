":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"text":" ","type":"text"},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllTextInputComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" implementation to use.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider","type":"reference","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"TextInputComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"text":"input text","type":"text"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Inout text","type":"text"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with raw and semantic tokens of colors ("},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"borders (from ","type":"text"},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"text":"), spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":")","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and  dimensions (from "},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"text":").","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemetextinputcomponenttokensprovider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeTextInputComponentTokensProvider"}],"title":"OrangeThemeTextInputComponentTokensProvider","kind":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"OrangeThemeTextInputComponentTokensProvider","kind":"identifier"}]}}}