","text":"Icons"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":")."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeIconComponentTokensProvider","title":"OrangeThemeIconComponentTokensProvider"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllColorSemanticTokensProvider":{"kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AllColorSemanticTokensProvider","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"TokensProvider","preciseIdentifier":"s:18OUDSThemesContract14TokensProviderP","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ColorMultipleSemanticTokens","preciseIdentifier":"s:18OUDSTokensSemantic013ColorMultipleB6TokensP","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ColorSemanticTokens","preciseIdentifier":"s:18OUDSTokensSemantic05ColorB6TokensP","kind":"typeIdentifier"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllColorSemanticTokensProvider","type":"topic","url":"\/documentation\/oudsthemescontract\/allcolorsemantictokensprovider","role":"symbol","abstract":[{"text":"Something which provides all semantic tokens of colors","type":"text"}],"title":"AllColorSemanticTokensProvider"},"ic_theme_orange.png":{"identifier":"ic_theme_orange.png","alt":null,"type":"image","variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","type":"topic","url":"\/documentation\/oudsthemesorange","role":"collection","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","co