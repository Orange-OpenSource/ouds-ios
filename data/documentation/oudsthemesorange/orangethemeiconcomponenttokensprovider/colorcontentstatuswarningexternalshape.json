h any "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Icons","type":"text"}]},{"text":" components tokens are defined with raw and semantic tokens of colors (from ","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"text":").","type":"text"}],"type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeIconComponentTokensProvider","title":"OrangeThemeIconComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeIconComponentTokensProvider"}],"url":"\/documentation\/oudsthemesorange\/orangethemeiconcomponenttokensprovider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeIconComponentTokensProvider"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeIconComponentTokensProvider/colorContentStatusWarningExternalShape":{"type":"topic","title":"colorContentStatusWarningExternalShape","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemeiconcomponenttokensprovider\/colorcontentstatuswarningexternalshape","kind":"symbol","abstract":[{"type":"text","text":"Has for value token MultipleColorSemanticToken(light: colors.repositoryWarningMedium, dark: colors.repositoryWarningLow)"}],"fragments":[{"kind":"keywo