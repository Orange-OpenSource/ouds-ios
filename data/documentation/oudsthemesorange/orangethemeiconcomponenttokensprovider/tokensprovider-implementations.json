{"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeIconComponentTokensProvider"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeIconComponentTokensProvider\/TokensProvider-Implementations"},"metadata":{"title":"TokensProvider Implementations","roleHeading":"API Collection","modules":[{"name":"Theme Orange"}],"role":"collectionGroup"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemeiconcomponenttokensprovider\/tokensprovider-implementations"]}],"topicSections":[{"title":"Instance Methods","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeIconComponentTokensProvider\/checkInstances(count:for:)"],"anchor":"Instance-Methods","generated":true}],"kind":"article","references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeIconComponentTokensProvider":{"type":"topic","url":"\/documentation\/oudsthemesorange\/orangethemeiconcomponenttokensprovider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeIconComponentTokensProvider"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeIconComponentTokensProvider"}],"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeIconComponentTokensProvider","abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component  tokens of icons"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"icons"}],"type":"emphasis"},{"type":"text","text":" used in some components like "},{"code":"OUDSTag","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contai