ovider/spaces":{"url":"\/documentation\/oudsthemesorange\/orangethemelinkcomponenttokensprovider\/spaces","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider\/spaces","abstract":[{"text":"Provider of spaces semantic tokens to use for link spaces","type":"text"}],"title":"spaces","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spaces","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllSpaceSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract30AllSpaceSemanticTokensProviderP"}],"role":"symbol","kind":"symbol"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllSpaceSemanticTokensProvider":{"kind":"symbol","title":"AllSpaceSemanticTokensProvider","type":"topic","abstract":[{"type":"text","text":"Something which provides all semantic tokens of space"}],"url":"\/documentation\/oudsthemescontract\/allspacesemantictokensprovider","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AllSpaceSemanticTokensProvider","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract14TokensProviderP","text":"TokensProvider","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic013SpaceMultipleB6TokensP","text":"SpaceMultipleSemanticTokens","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB6TokensP","text":"SpaceSemanticTokens","kind":"typeIdentifier"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllSpaceSemanticTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","title":"Theme Orange","type":"topic","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"url":"\/documentation\/oudsthemesorange","role":"collection","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeLinkComponentTokensProvider":{"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of links"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"link"}]},{"type":"text","text":" objects like "},{"code":"OUDSLink","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllLinkComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"LinkComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"links"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Link"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"colors (from "},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") and spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"url":"\/documentation\/oudsthemesorange\/orangethemelinkcomponenttokensprovider","navigatorTitle":[{"text":"OrangeThemeLinkComponentTokensProvider","kind":"identifier"}],"role":"symbol","kind":"symbol","title":"OrangeThemeLinkComponentTokensProvider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeLinkComponentTokensProvider","kind":"identifier"}],"type":"topic"}}}