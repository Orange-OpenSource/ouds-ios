],"type":"emphasis"},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":") and spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeLinkComponentTokensProvider/sizeIconSmall":{"title":"sizeIconSmall","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider\/sizeIconSmall","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Has for value token sizes.iconWithLabelMediumSizeSmall"}],"type":"topic","url":"\/documentation\/oudsthemesorange\/orangethemelinkcomponenttokensprovider\/sizeiconsmall","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizeIconSmall"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"SizeSemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"title":"Theme Orange","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","role":"collection","url":"\/documentation\/oudsthemesorange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"kind":"symbol","type":"topic"},"ic_theme_orange.png":{"identifier":"i