pe":"emphasis","inlineContent":[{"type":"text","text":"badge"}]},{"text":" objects like ","type":"text"},{"code":"OUDSBadge","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllBadgeComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" implementation to use.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider","type":"reference","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"BadgeComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"badge","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"Badge","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProviders","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"title":"OrangeThem