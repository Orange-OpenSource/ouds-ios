."},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Badge"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProviders","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"and spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"title":"OrangeThemeBadgeComponentTokensProvider","navigatorTitle":[{"text":"OrangeThemeBadgeComponentTokensProvider","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemebadgecomponenttokensprovider","type":"topic"}}}