"kind":"text"},{"text":"sizeSmall","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SizeSemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","kind":"typeIdentifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider\/sizeSmall","title":"sizeSmall","kind":"symbol","abstract":[{"text":"Has for value token dimensions._6xsmall","type":"text"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","title":"Theme Orange","role":"collection","kind":"symbol"},"ic_theme_orange.png":{"alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}],"identifier":"ic_theme_orange.png"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBadgeComponentTokensProvider":{"role":"symbol","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeBadgeComponentTokensProvider","kind":"identifier"}],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of badge"}]},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"badge"}],"type":"emphasis"},{"text":" objects like ","type":"text"},{"code":"OUDSBadge","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllBadgeComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"BadgeComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"badge"}],"type":"emphasis"},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Badge"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProviders","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"and spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"title":"OrangeThemeBadgeComponentTokensProvider","navigatorTitle":[{"text":"OrangeThemeBadgeComponentTokensProvider","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemebadgecomponenttokensprovider","type":"topic"}}}