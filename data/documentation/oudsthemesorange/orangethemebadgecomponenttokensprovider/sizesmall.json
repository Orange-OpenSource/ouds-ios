 "},{"type":"text","text":"and spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeBadgeComponentTokensProvider"}],"kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider","type":"topic","url":"\/documentation\/oudsthemesorange\/orangethemebadgecomponenttokensprovider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeBadgeComponentTokensProvider"}],"title":"OrangeThemeBadgeComponentTokensProvider","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","type":"topic","url":"\/documentation\/oudsthemesorange","kind":"symbol"},"ic_theme_orange.png":{"identifier":"ic_theme_orange.png","variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"alt":null,"type":"image"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBadgeComponentTokensProvider/sizeSmall":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizeSmall","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SizeSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena"}],"title":"sizeSmall","role":"symbol","abstract":[{"text":"Has for value token dimensions._6xsmall (= 12)","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/oudsthemesorange\/orangethemebadgecomponentt