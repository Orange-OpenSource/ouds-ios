":"Then, you can give this "},{"type":"codeVoice","code":"CustomTagComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}]},{"type":"codeListing","syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(tag: CustomTagComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}]},{"type":"codeListing","syntax":"swift","code":["    OrangeTheme(tag: CustomTagComponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let tagComponentTokensProvider = OrangeThemeTagComponentTokensProvider()","","    \/\/ Or use your own size, space, _ and border semantic tokens providers (or only some)","    let tagComponentTokensProvider = OrangeThemeTagComponentTokensProvider(","                                            sizes: CustomSizeSemanticTokensProvider(),","                                            borders: CustomBorderSemanticTokensProvider(),","                                            spaces: CustomSpaceSemanticTokensProvider,","                                            dimensions: CustomDimensionSemanticTokensProvider())"]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"0.9.0"}],"type":"paragraph"}],"style":"note","name":"Since"}],"kind":"content"}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllTagComponentTokensProvider","doc:\/\