ComponentTokensProvider = OrangeThemeTagComponentTokensProvider()","","    \/\/ Or use your own color, space, size and border semantic tokens providers (or only some)","    let tagComponentTokensProvider = OrangeThemeTagComponentTokensProvider(","                                            sizes: CustomSizeSemanticTokensProvider(),","                                            borders: CustomBorderSemanticTokensProvider(),","                                            colors: CustomColorSemanticTokensProvider(),","                                            spaces: CustomSpaceSemanticTokensProvider)"]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.9.0"}]}],"name":"Since"}],"kind":"content"}],"metadata":{"role":"symbol","externalID":"s:16OUDSThemesOrange0B31ThemeTagComponentTokensProviderC","title":"OrangeThemeTagComponentTokensProvider","navigatorTitle":[{"text":"OrangeThemeTagComponentTokensProvider","kind":"identifier"}],"roleHeading":"Class","modules":[{"name":"OUDSThemesOrange"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeTagComponentTokensProvider","kind":"identifier"}],"symbolKind":"class"},"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of tag"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tag"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSTag"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define t