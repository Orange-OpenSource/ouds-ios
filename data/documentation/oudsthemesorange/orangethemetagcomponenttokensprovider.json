{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeTagComponentTokensProvider","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define your own provider for tag component tokens","    \/\/ by inheriting from existing provider","    class CustomTagComponentTokensProvider: OrangeThemeTagComponentTokensProvider {","","        \/\/ Then override the tag component tokens you want.","","        override var borderRadius: BorderRadiusSemanticToken  { borders.radiusNone }","","        override var sizeMinWidthMedium: SizeSemanticToken { DimensionRawTokens._500 }","","        override var spacePaddingInlineIconStartSmall: SpaceSemanticToken { spaces.paddingInlineMedium }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomTagComponentTokensProvider: TagComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"]},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomTagComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(tag: CustomTagComponentTokensProvider())","    }","}"]},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    OrangeTheme(tag: CustomTagComponentTokensProvider())"]},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let tagComponentTokensProvider = OrangeThemeTagComponentTokensProvider()","","    \/\/ Or use your own size, space, _ and border semantic tokens providers (or only some)","    let tagComponentTokensProvider = OrangeThemeTagComponentTokensProvider(","                                            sizes: CustomSizeSemanticTokensProvider(),","                                            borders: CustomBorderSemanticTokensProvider(),","                                            spaces: CustomSpaceSemanticTokensProvider,","                                            dimensions: CustomDimensionSemanticTokensProvider())"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.9.0"}]}],"name":"Since","type":"aside","style":"note"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemetagcomponenttokensprovider"]}],"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"abstract":[{"text":"A class which wraps all ","type":"text"},{"inlineContent":[{"text":"component  tokens of tag","type":"text"}],"type":"strong"},{"text":" for ","type":"text"},{"inlineContent":[{"type":"text","text":"tag"}],"type":"emphasis"},{"text":" objects like ","type":"text"},{"type":"codeVoice","code":"OUDSTag"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"text":"This provider should be integrated as a ","type":"text"},{"code":"AllTagComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"TagComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"text":"tags","type":"text"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Tags","type":"text"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with semantic tokens of dimensions ("},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") ,"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") , sizes (from "},{"code":"AllSizesSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and borders (from "},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"metadata"