{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeTagComponentTokensProvider"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"code":["    \/\/ Define your own provider for tag component tokens","    \/\/ by inheriting from existing provider","    class CustomTagComponentTokensProvider: OrangeThemeTagComponentTokensProvider {","","        \/\/ Then override the tag component tokens you want.","","        override var borderRadius: BorderRadiusSemanticToken  { borders.radiusNone }","","        override var sizeMinWidthMedium: SizeSemanticToken { DimensionRawTokens._500 }","","        override var spacePaddingInlineIconStartSmall: SpaceSemanticToken { spaces.paddingInlineMedium }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomTagComponentTokensProvider: TagComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomTagComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(tag: CustomTagComponentTokensProvider())","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"code":["    OrangeTheme(tag: CustomTagComponentTokensProvider())"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let tagComponentTokensProvider = OrangeThemeTagComponentTokensProvider()","","    \/\/ Or use your own size, space, _ and border semantic tokens providers (or only some)","    let tagComponentTokensProvider = OrangeThemeTagComponentTokensProvider(","                                            sizes: CustomSizeSemanticTokensProvider(),","                                            borders: CustomBorderSemanticTokensProvider(),","                                            spaces: CustomSpaceSemanticTokensProvider,","                                            dimensions: CustomDimensionSemanticTokensProvider())"],"type":"codeListing","syntax":"swift"},{"style":"note","name":"Since","type":"aside","content":[{"inlineContent":[{"text":"0.9.0","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider"},"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component  tokens of tag"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"tag"}],"type":"emphasis"},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSTag"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllTagComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"TagComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"text":"tags","type":"text"}],"type":"emphasis"},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Tags"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with semantic tokens of dimensions ("},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"type":"text","text":") ,"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":") , sizes (from "},{"type":"codeVoice","code":"AllSizesSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and borders (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")."}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllTagComponentTokensProvi