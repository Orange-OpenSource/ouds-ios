{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeTagComponentTokensProvider","kind":"identifier"}],"languages":["swift"]}]},{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define your own provider for tag component tokens","    \/\/ by inheriting from existing provider","    class CustomTagComponentTokensProvider: OrangeThemeTagComponentTokensProvider {","","        \/\/ Then override the tag component tokens you want.","","        override var borderRadius: BorderRadiusSemanticToken  { borders.radiusNone }","","        override var sizeMinWidthMedium: SizeSemanticToken { DimensionRawTokens._500 }","","        override var spacePaddingInlineIconStartSmall: SpaceSemanticToken { spaces.paddingInlineMedium }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomTagComponentTokensProvider: TagComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"text":"Then, you can give this ","type":"text"},{"code":"CustomTagComponentTokensProvider","type":"codeVoice"},{"text":" to your own theme implementation:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(tag: CustomTagComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    OrangeTheme(tag: CustomTagComponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens prov