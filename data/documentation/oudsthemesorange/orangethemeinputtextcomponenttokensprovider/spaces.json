OUDS14TokensProviderP"},{"text":", ","kind":"text"},{"text":"SpaceMultipleSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic013SpaceMultipleB6TokensP"},{"text":", ","kind":"text"},{"text":"SpaceSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB6TokensP"}],"kind":"symbol","type":"topic","url":"\/documentation\/ouds\/allspacesemantictokensprovider","abstract":[{"type":"text","text":"Something which provides all semantic tokens of space"}],"title":"AllSpaceSemanticTokensProvider","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllSpaceSemanticTokensProvider","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","title":"OUDSThemesOrange","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","kind":"symbol","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"type":"topic","url":"\/documentation\/oudsthemesorange"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeInputTextComponentTokensProvider/spaces":{"type":"topic","url":"\/documentation\/oudsthemesorange\/orangethemeinputtextcomponenttokensprovider\/spaces","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spaces","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllSpaceSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:4OUDS30AllSpaceSemanticTokensProviderP"}],"abstract":[{"type":"text","text":"Provider of spaces semantic tokens to use for button spaces"}],"title":"spaces","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTextComponentTokensProvider\/spaces"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeInp