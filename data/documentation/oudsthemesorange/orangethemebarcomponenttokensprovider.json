ement maybe hundreds of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomBBarComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(bar: CustomBarComponentTokensProvider())","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["    OrangeTheme(bar: CustomBarComponentTokensProvider())"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeBordersSemanticTokensProvider for borders","    \/\/ - OrangeThemeEffectSemanticTokensProvider for effects","    \/\/ - OrangeThemeOpacitiySemanticTokensProvider for opacities","    let barComponentTokensProvider = OrangeThemeBarComponentTokensProvider()","","    \/\/ Or use your own providers","    let barComponentTokensProvider = OrangeThemeBarComponentTokensProvider(","                    sizes: CustomSizesSemanticTokensProvider(),","                    colors: CustomColorsSemanticTokensProvider(), ...)"],"type":"codeListing"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.22.0","type":"text"}]}],"name":"Since"}],"kind":"content"}],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBarComponentTokensProvider":{"fragments":[{"text":"class","kind":"keyword"}