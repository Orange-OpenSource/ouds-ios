{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider"},"metadata":{"roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeBarComponentTokensProvider"}],"symbolKind":"class","externalID":"s:16OUDSThemesOrange0B31ThemeBarComponentTokensProviderC","role":"symbol","modules":[{"name":"Theme Orange"}],"navigatorTitle":[{"text":"OrangeThemeBarComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeBarComponentTokensProvider"},"abstract":[{"text":"A class which wraps all ","type":"text"},{"type":"strong","inlineContent":[{"text":"component  tokens of bar","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"text":"This provider should be integrated as a ","type":"text"},{"code":"AllBarComponentTokensProvider","type":"codeVoice"},{"text":" implementation inside ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" so as to provide","type":"text"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider","type":"reference","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"BarComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"bar"}],"type":"emphasis"},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Bar"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with semantic tokens of colors ("},{"type":"codeVoice","code":"AllColorSemanticTokensProviders"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and effects (from "},{"type":"codeVoice","code":"AllEffectSemanticTokensProvider"},{"type":"text","text":")."}],"topicSections":[{"anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/init(sizes:borders:colors:opacities:effects:)"],"title":"Initializers"},{"anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/borders","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/colors","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/effects","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/opacities","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/sizes"],"title":"Instance Properties"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/BarComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/TokensProvider-Implementations"],"title":"Default Implementations"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeBarComponentTokensProvider","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your own provider for bar component tokens","    \/\/ by inheriting from existing provider","    class CustomBarComponentTokensProvider: OrangeThemeBarComponentTokensProvider {","","        \/\/ Then override the bar component tokens you want.","","        override var colorBgOpaque: MultipleColorSemanticToken { colors.bgTertiary }","","        override var effectBgBlur: EffectSemanticToken { EffectRawTokens.blur320 }","","        override var borderRadiusActiveIndicatorCustomTop: BorderRadiusSemanticToken { borders.radiusPill }","","        override var sizeWidthActiveIndicatorCustomBottom: SizeSemanticToken { DimensionRawTokens._650 }","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomBarComponentTokensProvider: BarComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomBBarComponentTokensProvider","type":"codeVoice"},{"text":" to your own theme implementation:","type":"text"}]},{"type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(bar: CustomBarComponentTokensProvider())","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"type":"codeListing","code":["    OrangeTheme(bar: CustomBarComponentTokensProvider())"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}]},{"type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeBordersSemanticTokensProvider for borders","    \/\/ - OrangeThemeEffectSemanticTokensProvider for effects","    \/\/ - OrangeThemeOpacitiySemanticTokensProvider for opacities","    let barComponentTokensProvider = OrangeThemeBarComponentTokensProvider()","","    \/\/ Or use your own providers","    let barComponentTokensProvider = OrangeThemeBarComponentTokensProvider(","                    sizes: CustomSizesSemanticTokensProvider(),","                    colors: CustomColorsSemanticTokensProvider(), ...)"],"syntax":"swift"},{"name":"Since","type":"aside","style":"note","content":[{"inlineContent":[{"text":"0.22.0","type":"text"}],"type":"paragraph"}]}]}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemebarcomponenttokensprovider"]}],"kind":"symbol","relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllBarComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent03BarB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"title":"Conforms To"}],"references":{"doc://OUDSThemesOrange/19OUDSTokensComponent03BarB6TokensP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent03BarB6TokensP","title":"OUDSTokensComp