{"topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/init(sizes:borders:colors:opacities:effects:)"],"anchor":"Initializers","title":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/borders","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/colors","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/effects","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/opacities","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/sizes"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/BarComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/TokensProvider-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"metadata":{"symbolKind":"class","roleHeading":"Class","title":"OrangeThemeBarComponentTokensProvider","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeBarComponentTokensProvider","kind":"identifier"}],"modules":[{"name":"Theme Orange"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeBarComponentTokensProvider"}],"externalID":"s:16OUDSThemesOrange0B31ThemeBarComponentTokensProviderC"},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllBarComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent03BarB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"type":"conformsTo","title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeBarComponentTokensProvider","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"codeListing","code":["    \/\/ Define your own provider for bar component tokens","    \/\/ by inheriting from existing provider","    class CustomBarComponentTokensProvider: OrangeThemeBarComponentTokensProvider {","","        \/\/ Then override the bar component tokens you want.","","        override var colorBgOpaque: MultipleColorSemanticTokens { colors.bgTertiary }","","        override var effectBgBlur: EffectSemanticToken { EffectRawTokens.blur320 }","","        override var borderRadiusActiveIndicatorCustomTop: BorderRadiusSemanticToken { borders.radiusPill }","","        override var sizeWidthActiveIndicatorCustomBottom: SizeSemanticToken { DimensionRawTokens._650 }","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomBarComponentTokensProvider: BarComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomBBarComponentTokensProvider"},{"text":" to your own theme implementation:","type":"text"}]},{"type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(bar: CustomBarComponentTokensProvider())","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["    OrangeTheme(bar: CustomBarComponentTokensProvider())"],"syntax":"swift"},{"inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeBordersSemanticTokensProvider for borders","    \/\/ - OrangeThemeEffectSemanticTokensProvider for effects","    \/\/ - OrangeThemeOpacitiySemanticTokensProvider for opacities","    let barComponentTokensProvider = OrangeThemeBarComponentTokensProvider()","","    \/\/ Or use your own providers","    let barComponentTokensProvider = OrangeThemeBarComponentTokensProvider(","                    sizes: CustomSizesSemanticTokensProvider(),","                    colors: CustomColorsSemanticTokensProvider(), ...)"],"syntax":"swift"},{"content":[{"inlineContent":[{"text":"0.22.0","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Since","style":"note"}]}],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of bar"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllBarComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"BarComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"bar"}]},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Bar"}]},{"text":" components tokens are defined with semantic tokens of colors (","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProviders"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":"), borders (from ","type":"text"},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and effects (from ","type":"text"},{"type":"codeVoice","code":"AllEffectSemanticTokensProvider"},{"text":").","type":"text"}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemebarcomponenttokensprovider"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"references":{"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllBarComponentTokensProvider":{"title":"AllBarComponentTokensProvider","abstract":[{"type":"text","text":"Something which p