nsProvider"},{"text":"), borders (from ","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")"},{"type":"text","text":" "},{"text":"and effects (from ","type":"text"},{"type":"codeVoice","code":"AllEffectSemanticTokensProvider"},{"text":").","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeBarComponentTokensProvider"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider","type":"topic","kind":"symbol","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemebarcomponenttokensprovider","title":"OrangeThemeBarComponentTokensProvider","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeBarComponentTokensProvider"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBarComponentTokensProvider/colorActiveIndicatorCustomSelectedHover":{"type":"topic","title":"colorActiveIndicatorCustomSelectedHover","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemebarcomponenttokensprovider\/coloractiveindicatorcustomselectedhover","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"colorActiveIndicatorCustomSelectedHover"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticToken","text":"MultipleColorSemanticToken"}],"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/colorActiveIndicatorCustomSelectedHover","abstract":[{"type":"text","text":"Has for value token colors.actionHover"}]},"ic_theme_orange.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}],"identifier":"ic_theme_orange.png","type":"image","alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"Theme Orange","abstract":[