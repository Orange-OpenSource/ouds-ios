xt","text":"bar"}],"type":"emphasis"},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Bar","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProviders"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":"), borders (from ","type":"text"},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and effects (from ","type":"text"},{"type":"codeVoice","code":"AllEffectSemanticTokensProvider"},{"text":").","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeBarComponentTokensProvider","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBarComponentTokensProvider/colorCurrentIndicatorCustomSelectedFocus":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"colorCurrentIndicatorCustomSelectedFocus","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MultipleColorSemanticToken","preciseIdentifier":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticToken","kind":"typeIdentifier"}],"abstract":[{"text":"Has for value token colors.actionFocus","type":"text"}],"type":"topic","role":"symbol","title":"colorCurrentIndicatorCustomSelectedFocus","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemebarcomponenttokensprovider\/colorcurrentindicatorcustomselectedfocus","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/colorCurrentIndicatorCustomSelectedFocus"}}}