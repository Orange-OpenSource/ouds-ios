ype":"emphasis","inlineContent":[{"type":"text","text":"bar"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Bar"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors ("},{"type":"codeVoice","code":"AllColorSemanticTokensProviders"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and effects (from "},{"type":"codeVoice","code":"AllEffectSemanticTokensProvider"},{"type":"text","text":")."}],"role":"symbol","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBarComponentTokensProvider/colorActiveIndicatorCustomSelectedPressed":{"title":"colorActiveIndicatorCustomSelectedPressed","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"colorActiveIndicatorCustomSelectedPressed","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MultipleColorSemanticToken","preciseIdentifier":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticToken","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Has for value token colors.actionPressed"}],"url":"\/documentation\/oudsthemesorange\/orangethemebarcomponenttokensprovider\/coloractiveindicatorcustomselectedpressed","role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/colorActiveIndicatorCustomSelectedPressed","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"images":