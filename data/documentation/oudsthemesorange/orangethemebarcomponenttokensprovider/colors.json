s of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider","type":"reference","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"BarComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"bar"}],"type":"emphasis"},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Bar","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProviders"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":"), borders (from ","type":"text"},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and effects (from ","type":"text"},{"type":"codeVoice","code":"AllEffectSemanticTokensProvider"},{"text":").","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeBarComponentTokensProvider","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBarComponentTokensProvider/colors":{"kind":"symbol","type":"topic","title":"colors","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"colors","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllColorSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract30AllColorSemanticTokensProviderP"}],"abstract":[{"type":"text","text":"Provider of colors semantic tokens to use for bar colors"}],"url":"\/documentation\/oudsthemesorange\/orangethemebarcomponenttokensprovider\/colors","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBarComponentTokensProvider\/colors","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","type":"topic","title":"Theme Orange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","role":"collection"}}}