"kind":"text"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"Theme Orange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"type":"topic","role":"collection","kind":"symbol"},"ic_theme_orange.png":{"identifier":"ic_theme_orange.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}],"type":"image","alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemePinCodeInputComponentTokensProvider":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider","title":"OrangeThemePinCodeInputComponentTokensProvider","type":"topic","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemepincodeinputcomponenttokensprovider","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemePinCodeInputComponentTokensProvider","kind":"identifier"}],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component  tokens of pin code input","type":"text"}]},{"type":"text","text":" objects like "},{"code":"OUDSPinCodeInput","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllPinCodeInputComponentTokensProvider"},{"text":" implementation inside ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" so as to provide","type":"text"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider","type":"reference","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"PinceCodeInputComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"pin code input"}]},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Pin code input"}]},{"text":" components tokens are defined with raw and semantic tokens of dimensions (from ","type":"text"},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":").","type":"text"}],"navigatorTitle":[{"text":"OrangeThemePinCodeInputComponentTokensProvider","kind":"identifier"}],"role":"symbol"}}}