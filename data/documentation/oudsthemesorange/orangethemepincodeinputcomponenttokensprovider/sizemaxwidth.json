pe":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Pin code input"}]},{"text":" components tokens are defined with raw and semantic tokens of dimensions (from ","type":"text"},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":").","type":"text"}],"navigatorTitle":[{"text":"OrangeThemePinCodeInputComponentTokensProvider","kind":"identifier"}],"role":"symbol"},"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"identifier":"ic_theme_orange.png","type":"image","alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"Theme Orange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"type":"topic","role":"collection","kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemePinCodeInputComponentTokensProvider/sizeMaxWidth":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizeMaxWidth"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","text":"SizeSemanticToken"}],"type":"topic","title":"sizeMaxWidth","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemepincodeinputcomponenttokensprovider\/sizemaxwidth","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider\/sizeMaxWidth","abstract":[{"type"