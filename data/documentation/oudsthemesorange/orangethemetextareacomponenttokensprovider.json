{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Class","externalID":"s:16OUDSThemesOrange0B36ThemeTextAreaComponentTokensProviderC","symbolKind":"class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeTextAreaComponentTokensProvider"}],"title":"OrangeThemeTextAreaComponentTokensProvider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeTextAreaComponentTokensProvider"}],"modules":[{"name":"Theme Orange"}],"role":"symbol"},"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllTextAreaComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent08TextAreaB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesOrange\/s9EscapableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"]}],"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemetextareacomponenttokensprovider"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeTextAreaComponentTokensProvider"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define your own provider for text area component tokens","    \/\/ by inheriting from existing provider","    class CustomTextAreaComponentTokensProvider: OrangeThemeTextAreaComponentTokensProvider {","","        \/\/ Then override the text area component tokens you want.","","        override var spacePaddingBlock: SpaceSemanticToken { spaces.paddingBlockXl }","        override var sizeMinHeightInput: SizeSemanticToken { DimensionRawTokens._1000 }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomTextAreaComponentTokensProvider: TextAreaComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomTextAreaComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}]},{"syntax":"swift","type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(textArea: CustomTextAreaComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    OrangeTheme(textArea: CustomTextAreaComponentTokensProvider())"]},{"inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}],"type":"paragraph"},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    let textAreaComponentTokensProvider = OrangeThemeTextAreaComponentTokensProvider()","","    \/\/ Or use your own size and space semantic tokens providers (or only some)","    let textAreaComponentTokensProvider = OrangeThemeTextAreaComponentTokensProvider(","                                            sizes: CustomSizeSemanticTokensProvider(),","                                            spaces: CustomSpaceSemanticTokensProvider())"],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.17.0"}]}],"style":"note","name":"Since","type":"aside"}]}],"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/init(sizes:spaces:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/spaces"]},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/TextAreaComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/TokensProvider-Implementations"]}],"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component tokens of text area"}],"type":"strong"},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSTextArea"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllTextAreaComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider","type":"reference","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"TextAreaComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"text area"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Text area"}]},{"type":"text","text":" components tokens are defined with semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextAreaComponentTokensProvider/TokensProvider-Implementations":{"title":"TokensProvider Implementations","url":"\/documentation\/oudsthemesorange\/orangethemetextareacomponenttokensprovider\/tokensprovider-implementations","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/TokensProvider-Implementations","kind":"article","abstract":[],"role":"collectionGroup"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextAreaComponentTokensProvider/sizes":{"title":"sizes","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizes"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","preciseIdentifier":