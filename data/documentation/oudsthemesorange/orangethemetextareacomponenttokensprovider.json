define your own provider from scratch","    class CustomTextAreaComponentTokensProvider: TextAreaComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomTextAreaComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}]},{"type":"codeListing","syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(textArea: CustomTextAreaComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    OrangeTheme(textArea: CustomTextAreaComponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    let textAreaComponentTokensProvider = OrangeThemeTextAreaComponentTokensProvider()","","    \/\/ Or use your own size and space semantic tokens providers (or only some)","    let textAreaComponentTokensProvider = OrangeThemeTextAreaComponentTokensProvider(","                                            sizes: CustomSizeSemanticTokensProvider(),","                                            spaces: CustomSpaceSemanticTokensProvider())"]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.17.0","type":"text"}]}],"name":"Since","style":"note"}]}],"topicSections":[{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/