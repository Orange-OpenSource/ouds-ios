\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/spaces"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/TextAreaComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/TokensProvider-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"sections":[],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component tokens of text area","type":"text"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSTextArea"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllTextAreaComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"TextAreaComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"text area","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Text area","type":"text"}]},{"type":"text","text":" components tokens are defined with semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllTextAreaComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent08TextAreaB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesOrange\/s9EscapableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"references":{"doc://OUDSThemesOrange/19OUDSTokensComponent08TextAreaB6TokensP":{"title":"OUDSTokensComponent.TextAreaComponentTokens","identifier":"doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent08TextAreaB6TokensP","type":"unresolvable"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextAreaComponentTokensProvider/sizes":{"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/sizes","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizes","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllSizeSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract29AllSizeSemanticTokensProviderP"}],"url":"\/documentation\/oudsthemesorange\/orangethemetextareaco