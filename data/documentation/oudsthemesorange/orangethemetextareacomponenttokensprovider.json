{"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/init(sizes:spaces:)"]},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/spaces"]},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/TextAreaComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/TokensProvider-Implementations"]}],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component  tokens of text area","type":"text"}]},{"type":"text","text":" objects like "},{"code":"OUDSTextArea","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllTextAreaComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider","type":"reference","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"TextAreaComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"text area"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Text area"}]},{"type":"text","text":" components tokens are defined with semantic tokens of sizes (from "},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider","interfaceLanguage":"swift"},"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeTextAreaComponentTokensProvider"}],"roleHeading":"Class","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeTextAreaComponentTokensProvider"}],"symbolKind":"class","externalID":"s:16OUDSThemesOrange0B36ThemeTextAreaComponentTokensProviderC","title":"OrangeThemeTextAreaComponentTokensProvider","modules":[{"name":"Theme Orange"}],"role":"symbol"},"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemetextareacomponenttokensprovider"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","relationshipsSections":[{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllTextAreaComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent08TextAreaB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeTextAreaComponentTokensProvider","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"code":["    \/\/ Define your own provider for text area component tokens","    \/\/ by inheriting from existing provider","    class CustomTextAreaComponentTokensProvider: OrangeThemeTextAreaComponentTokensProvider {","","        \/\/ Then override the text area component tokens you want.","","        override var spacePaddingBlock: SpaceSemanticToken { spaces.paddingBlockXl }","        override var sizeMinHeightInput: SizeSemanticToken { DimensionRawTokens._1000 }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomTextAreaComponentTokensProvider: TextAreaComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Then, you can give this ","type":"text"},{"code":"CustomTextAreaComponentTokensProvider","type":"codeVoice"},{"text":" to your own theme implementation:","type":"text"}]},{"syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(textArea: CustomTextAreaComponentTokensProvider())","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    OrangeTheme(textArea: CustomTextAreaComponentTokensProvider())"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    let textAreaComponentTokensProvider = OrangeThemeTextAreaComponentTokensProvider()","","    \/\/ Or use your own space and size semantic tokens providers (or only some)","    let textAreaComponentTokensProvider = OrangeThemeTextAreaComponentTokensProvider(","                                            sizes: CustomSizeSemanticTokensProvider(),","                                            spaces: CustomSpaceSemanticTokensProvider())"],"type":"codeListing"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.17.0"}]}],"name":"Since","type":"aside"}]}],"sections":[],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextAreaComponentTokensProvider/TokensProvider-Implementations":{"type":"topic","abstract":[],"kind":"article","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/TokensProvider-Implementations","url":"\/documentation\/oudsthemesorange\/orangethemetextareacomponenttokensprovider\/tokensprovider-implementations","title":"TokensProvider Implementations","role":"collectionGroup"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTextAreaComponentTokensProvider/TextAreaComponentTokens-Implementations":{"url":"\/documentation\/oudsthemesorange\/orangethemetextareacomponenttokensprovider\/textareacomponenttokens-implementations","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/TextAreaComponentTokens-Implementations","type":"topic","role":"collectionGroup","title":"TextAreaComponentTokens Implemen