{"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component tokens of text area"}],"type":"strong"},{"type":"text","text":" objects like "},{"code":"OUDSTextArea","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllTextAreaComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider","type":"reference","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"TextAreaComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"text area"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Text area"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with semantic tokens of sizes (from "},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllTextAreaComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent08TextAreaB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesOrange\/s9EscapableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeTextAreaComponentTokensProvider"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"code":["    \/\/ Define your own provider for text area component tokens","    \/\/ by inheriting from existing provider","    class CustomTextAreaComponentTokensProvider: OrangeThemeTextAreaComponentTokensProvider {","","        \/\/ Then override the text area component tokens you want.","","        override var spacePaddingBlock: SpaceSemanticToken { spaces.paddingBlockXl }","        override var sizeMinHeightInput: SizeSemanticToken { DimensionRawTokens._1000 }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomTextAreaComponentTokensProvider: TextAreaComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomTextAreaComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(textArea: CustomTextAreaComponentTokensProvider())","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}],"type":"paragraph"},{"code":["    OrangeTheme(textArea: CustomTextAreaComponentTokensProvider())"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    let textAreaComponentTokensProvider = OrangeThemeTextAreaComponentTokensProvider()","","    \/\/ Or use your own size and space semantic tokens providers (or only some)","    let textAreaComponentTokensProvider = OrangeThemeTextAreaComponentTokensProvider(","                                            sizes: CustomSizeSemanticTokensProvider(),","                                            spaces: CustomSpaceSemanticTokensProvider())"],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.17.0"}]}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"sections":[],"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/init(sizes:spaces:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextAreaComponentTokensProvider\/spaces"],"generated":true},{"anchor":"Def