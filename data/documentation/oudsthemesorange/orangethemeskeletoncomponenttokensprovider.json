e your own provider for skeleton component tokens","    \/\/ by inheriting from existing provider","    class CustomSkeletonComponentTokensProvider: OrangeThemeSkeletonComponentTokensProvider {","","        \/\/ Then override the skeleton component tokens you want.","","        override var colorGradientMiddle:  MultipleColorSemanticTokens { colors.repositoryOpacityBlackHigher }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomSkeletonComponentTokensProvider: SkeletonComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomSkeletonComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(skeleton: CustomSkeletonComponentTokensProvider())","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}],"type":"paragraph"},{"syntax":"swift","code":["    OrangeTheme(skeleton: CustomSkeletonComponentTokensProvider())"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    let skeletonComponentTokensProvider = OrangeThemeSkeletonComponentTokensProvider()","","    \/\/ Or use your own color semantic tokens providers (or only some)","    let skeletonComponentTokensProvider = OrangeThemeSkeletonComponentTokensProvider(","                                                colors: CustomColorSemanticTokensProvider())"]