t"}],"type":"paragraph"},{"syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(skeleton: CustomSkeletonComponentTokensProvider())","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    OrangeTheme(skeleton: CustomSkeletonComponentTokensProvider())"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    let skeletonComponentTokensProvider = OrangeThemeSkeletonComponentTokensProvider()","","    \/\/ Or use your own color semantic tokens providers (or only some)","    let skeletonComponentTokensProvider = OrangeThemeSkeletonComponentTokensProvider(","                                                colors: CustomColorSemanticTokensProvider())"],"type":"codeListing"},{"name":"Since","content":[{"inlineContent":[{"text":"0.9.0","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemeskeletoncomponenttokensprovider"]}],"kind":"symbol","topicSections":[{"anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider\/init(colors:)"],"title":"Initializers"},{"anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider\/colors"],"title":"Instance Properties"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider\/Skele