t"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Radio buttons","type":"text"}]},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"code":"SizeSemanticToken","type":"codeVoice"},{"text":") and","type":"text"},{"text":" ","type":"text"},{"text":"borders (","type":"text"},{"code":"BorderRadiusSemanticToken","type":"codeVoice"},{"text":", ","type":"text"},{"code":"BorderWidthSemanticToken","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"These components share the same type of tokens which are all gathered here.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeRadioButtonComponentTokensProvider"}],"type":"topic","title":"OrangeThemeRadioButtonComponentTokensProvider"},"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"identifier":"ic_theme_orange.png","alt":null,"type":"image"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeRadioButtonComponentTokensProvider/sizeIndicator":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider\/sizeIndicator","url":"\/documentation\/oudsthemesorange\/orangethemeradiobuttoncomponenttokensprovider\/sizeindicator","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Has for value token sizes.iconWithLabelLargeSizeXsmall"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizeIndicator","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","text":"SizeSemanticToken","kind":"typeIdentifier"}],"type":"topic","title":"sizeIndicator"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","role":"collection","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"url":"\/documentation\/oudsthemesorange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"kind":"symbol","type":"topic"}}}