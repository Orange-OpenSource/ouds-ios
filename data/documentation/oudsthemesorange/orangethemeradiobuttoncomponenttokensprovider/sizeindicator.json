{"sections":[],"metadata":{"title":"sizeIndicator","modules":[{"name":"Theme Orange"}],"role":"symbol","symbolKind":"property","externalID":"s:16OUDSThemesOrange0B39ThemeRadioButtonComponentTokensProviderC13sizeIndicatorSdvp","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizeIndicator","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SizeSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena"}],"extendedModule":"OUDSThemesOrange","roleHeading":"Instance Property"},"abstract":[{"text":"Has for value token sizes.iconWithLabelLargeSizeXsmall","type":"text"}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemeradiobuttoncomponenttokensprovider\/sizeindicator"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider\/sizeIndicator","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@objc"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizeIndicator"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","kind":"typeIdentifier","text":"SizeSemanticToken"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"]}]}],"references":{"ic_theme_orange.png":{"identifier":"ic_theme_orange.png","alt":null,"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeRadioButtonComponentTokensProvider":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider","role":"symbol","type":"topic","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of radio button"}]},{"type":"text","text":" for  "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radios"}]},{"type":"text","text":" objects"},{"type":"text","text":" "},{"type":"text","text":"like "},{"type":"codeVoice","code":"OUDSRadioButton"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioButtonItem"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllRadioButtonComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide all tokens to the users."},{"type":"text","text":" "},{"type":"text","text":"It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"RadioButtonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"radio buttons","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Radio buttons","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"SizeSemanticToken"},{"type":"text","text":") and"},{"type":"text","text":" "},{"type":"text","text":"borders ("},{"type":"codeVoice","code":"BorderRadiusSemanticToken"},{"type":"text","text":", "},{"type":"codeVoice","code":"BorderWidthSemanticToken"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"These components share the same type of tokens which are all gathered here."}],"title":"OrangeThemeRadioButtonComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemeradiobuttoncomponenttokensprovider","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeThemeRadioButtonComponentTokensProvider","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeThemeRadioButtonComponentTokensProvider","kind":"identifier"}],"kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeRadioButtonComponentTokensProvider/sizeIndicator":{"title":"sizeIndicator","type":"topic","abstract":[{"text":"Has for value token sizes.iconWithLabelLargeSizeXsmall","type":"text"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider\/sizeIndicator","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizeIndicator","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SizeSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena"}],"url":"\/documentation\/oudsthemesorange\/orangethemeradiobuttoncomponenttokensprovider\/sizeindicator"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","url":"\/documentation\/oudsthemesorange","type":"topic","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"title":"Theme Orange","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","role":"collection","images":[{"type":"icon","identifier":"ic_theme_orange.png"}]}}}