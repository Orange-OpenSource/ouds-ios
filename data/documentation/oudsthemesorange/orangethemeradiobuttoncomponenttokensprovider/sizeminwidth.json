nticToken"},{"type":"text","text":") and"},{"type":"text","text":" "},{"type":"text","text":"borders ("},{"type":"codeVoice","code":"BorderRadiusSemanticToken"},{"type":"text","text":", "},{"type":"codeVoice","code":"BorderWidthSemanticToken"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"These components share the same type of tokens which are all gathered here."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeRadioButtonComponentTokensProvider"}],"url":"\/documentation\/oudsthemesorange\/orangethemeradiobuttoncomponenttokensprovider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeRadioButtonComponentTokensProvider"}],"type":"topic","kind":"symbol","title":"OrangeThemeRadioButtonComponentTokensProvider","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeRadioButtonComponentTokensProvider/sizeMinWidth":{"role":"symbol","title":"sizeMinWidth","url":"\/documentation\/oudsthemesorange\/orangethemeradiobuttoncomponenttokensprovider\/sizeminwidth","abstract":[{"type":"text","text":"Has for value token sizes.minInteractiveArea"}],"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider\/sizeMinWidth","kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizeMinWidth","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SizeSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena"}]},"ic_theme_orange.png":{"type":"image","identifier":"ic_theme_orange.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesora