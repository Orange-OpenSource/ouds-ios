erWidthSemanticToken","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"These components share the same type of tokens which are all gathered here.","type":"text"}],"kind":"symbol","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemeradiobuttoncomponenttokensprovider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeRadioButtonComponentTokensProvider"}],"type":"topic"}}}