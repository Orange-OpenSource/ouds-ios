":"text"},{"inlineContent":[{"type":"text","text":"component  tokens of radio button"}],"type":"strong"},{"text":" for  ","type":"text"},{"inlineContent":[{"text":"radios","type":"text"}],"type":"emphasis"},{"type":"text","text":" objects"},{"type":"text","text":" "},{"type":"text","text":"like "},{"code":"OUDSRadioButton","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioButtonItem"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllRadioButtonComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide all tokens to the users."},{"type":"text","text":" "},{"type":"text","text":"It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"RadioButtonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"radio buttons","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Radio buttons"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"SizeSemanticToken"},{"type":"text","text":") and"},{"type":"text","text":" "},{"type":"text","text":"borders ("},{"type":"codeVoice","code":"BorderRadiusSemanticToken"},{"type":"text","text":", "},{"type":"codeVoice","code":"BorderWidthSemanticToken"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"These components share the same type of tokens which are all gathered here."}]}}}