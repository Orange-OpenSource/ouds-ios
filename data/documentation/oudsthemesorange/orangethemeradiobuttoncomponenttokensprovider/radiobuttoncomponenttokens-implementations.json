":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"RadioButtonComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"radio buttons","type":"text"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Radio buttons"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"code":"SizeSemanticToken","type":"codeVoice"},{"type":"text","text":") and"},{"type":"text","text":" "},{"type":"text","text":"borders ("},{"code":"BorderRadiusSemanticToken","type":"codeVoice"},{"type":"text","text":", "},{"code":"BorderWidthSemanticToken","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"These components share the same type of tokens which are all gathered here."}],"url":"\/documentation\/oudsthemesorange\/orangethemeradiobuttoncomponenttokensprovider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeRadioButtonComponentTokensProvider/borderWidthUnselectedHover":{"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeRadioButtonComponentTokensProvider\/borderWidthUnselectedHover","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemeradiobuttoncomponenttokensprovider\/borderwidthunselectedhover","abstract":[{"type":"text","text":"Has for value token borders.widthMedium"}],"t