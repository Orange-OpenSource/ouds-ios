{"topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/init(sizes:borders:colors:spaces:dimensions:)"],"anchor":"Initializers","title":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/borders","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/colors","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/dimensions","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/spaces"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/TextInputComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider\/TokensProvider-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeTextInputComponentTokensProvider"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your own provider for input text component tokens","    \/\/ by inheriting from existing provider","    class CustomTextInputComponentTokensProvider: OrangeThemeTextInputComponentTokensProvider {","","        \/\/ Then override the text input component tokens you want.","","        override var sizeMaxWidth: SizeSemanticToken { DimensionRawTokens._3000 }","","        override var spacePaddingBlockDefault: SpaceSemanticToken { spaces.paddingInlineSmall }","","        override var colorBorderEnabled: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","","        override var borderWidthDefault: BorderWidthSemanticToken { borders.widthMedium}","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomTextInputComponentTokensProvider: TextInputComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomTextInputComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}]},{"type":"codeListing","syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(textInput: CustomTextInputComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}]},{"type":"codeListing","syntax":"swift","code":["    OrangeTheme(textInput: CustomTextInputComponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    let inputTextComponentTokensProvider = OrangeThemeTextInputComponentTokensProvider()","","    \/\/ Or use your own size, border, color, space and _ semantic tokens providers (or only some)","    let inputTextComponentTokensProvider = OrangeThemeTextInputComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider(),","                                                colors: CustomColorSemanticTokensProvider(),","                                                space: CustomSpaceSemanticTokensProvider(),","                                                dimensions: CustomDimensionSemanticTokensProvider())"]},{"content":[{"inlineContent":[{"type":"text","text":"0.17.0"}],"type":"paragraph"}],"type":"aside","name":"Since","style":"note"}]}],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of input text"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"input text"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSTextInput"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllTextInputComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTextInputComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"TextInputComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"input text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Inout text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of colors ("},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"borders (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":"), spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and  dimensions (from "},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"type":"text","text":")."}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemetextinputcomponenttokensprovider"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"symbolKind":"class","roleHeading":"Class","modules":[{"name":"Theme Orange"}],"role":"symbol","externalID":"s:16OUDSThemesOrange0B37ThemeTextInputComponentTokensProviderC","navigatorTitle":[{"text":"OrangeThemeTextInputComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeTextInputComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeTextInputComponentTokensProvider"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTh