{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeTextInputComponentTokensProvider"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your own provider for input text component tokens","    \/\/ by inheriting from existing provider","    class CustomTextInputComponentTokensProvider: OrangeThemeTextInputComponentTokensProvider {","","        \/\/ Then override the text input component tokens you want.","","        override var sizeMaxWidth: SizeSemanticToken { DimensionRawTokens._3000 }","","        override var spacePaddingBlockDefault: SpaceSemanticToken { spaces.paddingInlineSmall }","","        override var colorBorderEnabled: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","","        override var borderWidthDefault: BorderWidthSemanticToken { borders.widthMedium}","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomTextInputComponentTokensProvider: TextInputComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomTextInputComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}]},{"syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(textInput: CustomTextInputComponentTokensProvider())","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    OrangeTheme(textInput: CustomTextInputC