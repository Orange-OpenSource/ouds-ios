rough any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Select input","type":"text"}]},{"type":"text","text":" components tokens are defined with semantic tokens of dimensions (from "},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"type":"text","text":")"}],"title":"OrangeThemeSelectInputComponentTokensProvider","kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"role":"collection","title":"Theme Orange","url":"\/documentation\/oudsthemesorange","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSelectInputComponentTokensProvider/dimensions":{"abstract":[{"type":"text","text":"Provider of dimensions semantic tokens to use for text input dimensions"}],"kind":"symbol","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"dimensions","kind":"identifier"},{"text":": any ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract34AllDimensionSemanticTokensProviderP","text":"AllDimensionSemanticTokensProvider","kind":"typeIdentifier"}],"title":"dimensions","url":"\/documentation\/oudsthemesorange\/orangethemeselectinputcomponenttokensprovider\/dimensions","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSelectInputComponentTokensProvider\/dimensions"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllDimensionSemanticTokensProvider":{"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword