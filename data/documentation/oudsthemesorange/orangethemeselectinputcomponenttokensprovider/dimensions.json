me","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Select input"}]},{"type":"text","text":" components tokens are defined with semantic tokens of dimensions (from "},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeSelectInputComponentTokensProvider"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSelectInputComponentTokensProvider","title":"OrangeThemeSelectInputComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemeselectinputcomponenttokensprovider","type":"topic"}}}