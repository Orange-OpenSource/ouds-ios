{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component  tokens of quantity input","type":"text"}]},{"type":"text","text":" objects like "},{"code":"OUDSQuantityInput","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllQuantityInputComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeQuantityInputComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"QuantityInputComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"tag inputs","type":"text"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Quantity inputs","type":"text"}]},{"type":"text","text":" components tokens are defined with semantic tokens of sizes (from "},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"and spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeQuantityInputComponentTokensProvider"}]}]},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"code":["    \/\/ Define your own provider for quantity input component tokens","    \/\/ by inheriting from existing provider","    class CustomQuantityInputComponentTokensProvider: OrangeThemeQuantityInputComponentTokensProvider {","","        \/\/ Then override the tag component tokens you want.","","        override var spaceColumnGapQuantitySelector: SpaceSemanticToken { spaces.columnGap2Xs }","","        override var sizeMinWidth: SizeSemanticToken { DimensionRawTokens._3000 }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomQuantityInputComponentTokensProvider: QuantityInputComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Then, you can give this ","type":"text"},{"code":"CustomQuantityInputComponentTokensProvider","type":"codeVoice"},{"text":" to your own theme implementation:","type":"text"}]},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(quantityInput: CustomQuantityInputComponentTokensProvider())","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"code":["    OrangeTheme(quantityInput: CustomQuantityInputComponentTokensProvider())"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}]},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let quantityInputComponentTokensProvider = OrangeThemeQuantityInputComponentTokensProvider()","","    \/\/ Or use your own space, size and border semantic tokens providers (or only some)","    let quantityInputComponentTokensProvider = OrangeThemeQuantityInputComponentTokensProvider(","                                            sizes: CustomSizesSemanticTokensProvider(),","                                            spaces: CustomSpacesSemanticTokensProvider())"],"type":"codeListing","syntax":"swift"},{"content":[{"inlineContent":[{"text":"0.17.0","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"metadata":{"role":"symbol","externalID":"s:16OUDSThemesOrange0B41ThemeQuantityInputComponentTokensProviderC","title":"OrangeThemeQuantityInputComponentTokensProvider","modules":[{"name":"Theme Orange"}],"symbolKind":"class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeQuantityInputComponentTokensProvider"}],"roleHeading":"Class","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeQuantityInputComponentTokensProvider"}]},"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeQuantityInputComponentTokensProvider\/init(sizes:spaces:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeT