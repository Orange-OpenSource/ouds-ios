{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeQuantityInputComponentTokensProvider"},"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllQuantityInputComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent013QuantityInputB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"]}],"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component  tokens of quantity input"}],"type":"strong"},{"type":"text","text":" objects like "},{"code":"OUDSQuantityInput","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllQuantityInputComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeQuantityInputComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"QuantityInputComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"tag inputs"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Quantity inputs"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with semantic tokens of sizes (from "},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"and spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"metadata":{"role":"symbol","navigatorTitle":[{"text":"OrangeThemeQuantityInputComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeQuantityInputComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeQuantityInputComponentTokensProvider"}],"externalID":"s:16OUDSThemesOrange0B41ThemeQuantityInputComponentTokensProviderC","symbolKind":"class","roleHeading":"Class","modules":[{"name":"Theme Orange"}]},"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeQuantityInputComponentTokensProvider"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"code":["    \/\/ Define your own provider for quantity input component tokens","    \/\/ by inheriting from existing provider","    class CustomQuantityInputComponentTokensProvider: OrangeThemeQuantityInputComponentTokensProvider {","","        \/\/ Then override the tag component tokens you want.","","        override var spaceColumnGapQuantitySelector: SpaceSemanticToken { spaces.columnGap2Xs }","","        override var sizeMinWidth: SizeSemanticToken { DimensionRawTokens._3000 }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomQuantityInputComponentTokensProvider: QuantityInputComponentTokens {","","        \/\/ And implement maybe hundreds of tokens.","        \/\/ You are allowed to use semantic tokens providers if you want to define values.","    }"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomQuantityInputComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(quantityInput: CustomQuantityInputComponentTokensProvider())","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}],"type":"paragraph"},{"code":["    OrangeTheme(quantityInput: CustomQuantityInputComponentTokensProvider())"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let quantityInputComponentTokensProvider = OrangeThemeQuantityInputComponentTokensProvider()","","    \/\/ Or use your own space, size and border semantic tokens providers (or only some)","    let quantityInputComponentTokensProvider = OrangeThemeQuantityInputComponentTokensProvider(","                                            sizes: CustomSizesSemanticTokensProvider(),","                                            spaces: Cust