":"text"}],"type":"paragraph"},{"code":["    OrangeTheme(badge: CustomBadgeComponentTokensProvider())"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    let badgeComponentTokensProvider = OrangeThemeBadgeComponentTokensProvider()","","    \/\/ Or use your own dimension and space semantic tokens provider","    let badgeComponentTokensProvider = OrangeThemeBadgeComponentTokensProvider(","                    spaces: CustomSpaceSemanticTokensProvider(),","                    dimensions: CustomDimensionSemanticTokensProvider())"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.10.0"}]}],"style":"note","type":"aside","name":"Since"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBadgeComponentTokensProvider/BadgeComponentTokens-Implementations":{"title":"BadgeComponentTokens Implementations","role":"collectionGroup","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider\/BadgeComponentTokens-Implementations","kind":"article","url":"\/documentation\/oudsthemesorange\/orangethemebadgecomponenttokensprovider\/badgecomponenttokens-implementations","abstract":[]},"doc://OUDSThemesOrange/s9EscapableP":{"title":"Swift.Escapable","type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/s9EscapableP"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","title":"Theme Orange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the b