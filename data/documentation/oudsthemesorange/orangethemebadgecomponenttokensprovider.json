mponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    let badgeComponentTokensProvider = OrangeThemeBadgeComponentTokensProvider()","","    \/\/ Or use your own dimension and space semantic tokens provider","    let badgeComponentTokensProvider = OrangeThemeBadgeComponentTokensProvider(","                    spaces: CustomSpaceSemanticTokensProvider(),","                    dimensions: CustomDimensionSemanticTokensProvider())"]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.10.0"}]}],"name":"Since"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemebadgecomponenttokensprovider"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSThemesOrange/s8CopyableP":{"title":"Swift.Copyable","type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrange\/s8CopyableP"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBadgeComponentTokensProvider/TokensProvider-Implementations":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider\/TokensProvider-Implementations","role":"collectionGroup","abstract":[],"title":"TokensProvider Implementations","url":"\/documentation\/oudsthemesorange\/orangethemebadgecomponenttokensprovider\/tokensprovider-implementations","kind":"article","type":"topic"},"doc://OUDSThemesOrange/19OUDSTokensComponent05BadgeB6TokensP":{"identifier":"doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent05BadgeB6TokensP","type":"unresolvable","title":"OUDSTokensComponent.BadgeComponentTokens"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/TokensProvider":{"identifier":"doc:\/\/OUDSThemesContract\/d