","text":" and apply the provider they need."},{"type":"text","text":" "},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"QuantityInputComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"tag inputs"}],"type":"emphasis"},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"text":" ","type":"text"},{"inlineContent":[{"text":"Quantity inputs","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"and spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeQuantityInputComponentTokensProvider"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeQuantityInputComponentTokensProvider","type":"topic","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemequantityinputcomponenttokensprovider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeQuantityInputComponentTokensProvider/spaceColumnGapQuantitySelector":{"kind":"symbol","type":"topic","title":"spaceColumnGapQuantitySelector","abstract":[{"text":"Has for value token DimensionRawTokens.outOfSystem25","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"spaceColumnGapQuantitySelector"},{"kind":"text","text":": "},{"text":"SpaceSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena"}],"url":"\/documentation\/oudsthemesorange\/orangethemequantityinputcomponenttokensprovider\/spacecolumngapquantityselector","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/O