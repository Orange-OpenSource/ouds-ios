{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeControlItemComponentTokensProvider","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your own provider for control-item-layout-based component tokens","    \/\/ by inheriting from existing provider","    class CustomControlItemComponentTokensProvider: OrangeThemeControlItemComponentTokensProvider {","","        \/\/ Then override the control-item-layout-based component tokens you want.","","        override var controlItemSizeMinHeight: SizeSemanticToken { DimensionRawTokens.dimension500 }","","        override var controlItemColorBgFocus: MultipleColorSemanticTokens { colors.colorContentDefault }","","        override var controlItemSpaceRowGap: SpaceSemanticToken { spaces.spacePaddingInlineTall }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomControlItemComponentTokensProvider: ControlItemComponentTokens {","","        \/\/ And implement hundreds of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"text":"Then, you can give this ","type":"text"},{"code":"CustomControlItemComponentTokensProvider","type":"codeVoice"},{"text":" to your own theme implementation:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(controlItem: CustomControlItemComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    OrangeTheme(controlItem: CustomControlItemComponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let controlItemComponentTokensProvider = OrangeThemeControlItemComponentTokensProvider()","","    \/\/ Or use your own size, color and space semantic tokens providers (or only some)","    let controlItemComponentTokensProvider = OrangeThemeControlItemComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                colors: CustomColorSemanticTokensProvider(),","                                                space: CustomSpaceSemanticTokensProvider())"]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"text":"0.10.0","type":"text"}],"type":"paragraph"}]}]}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDS\/documentation\/OUDS\/AllControlItemComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent011ControlItemB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDS\/documentation\/OUDS\/TokensProvider"],"type":"conformsTo"}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider\/init(sizes:colors:spaces:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider\/colors","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvi