n, you can give this "},{"type":"codeVoice","code":"CustomControlItemComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(controlItem: CustomControlItemComponentTokensProvider())","    }","}"]},{"inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    OrangeTheme(controlItem: CustomControlItemComponentTokensProvider())"]},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let controlItemComponentTokensProvider = OrangeThemeControlItemComponentTokensProvider()","","    \/\/ Or use your own size, color and space semantic tokens providers (or only some)","    let controlItemComponentTokensProvider = OrangeThemeControlItemComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider(),","                                                colors: CustomColorSemanticTokensProvider(),","                                                space: CustomSpaceSemanticTokensProvider())"]},{"name":"Since","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.10.0"}]}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ou