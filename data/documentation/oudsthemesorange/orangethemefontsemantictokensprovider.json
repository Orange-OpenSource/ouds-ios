.typeBold300)","        }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomFontTokensProvider"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(fonts: CustomFontTokensProvider())","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"code":["    OrangeTheme(fonts: CustomFontTokensProvider())"],"syntax":"swift","type":"codeListing"},{"name":"Since","style":"note","content":[{"inlineContent":[{"text":"0.8.0","type":"text"}],"type":"paragraph"}],"type":"aside"}]}],"references":{"doc://OUDS/documentation/OUDS/AllFontSemanticTokensProvider":{"url":"\/documentation\/ouds\/allfontsemantictokensprovider","abstract":[{"text":"Something which provides all semantic tokens of font","type":"text"}],"title":"AllFontSemanticTokensProvider","kind":"symbol","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllFontSemanticTokensProvider","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AllFontSemanticTokensProvider","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"TokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:4OUDS14TokensProviderP"},{"text":", ","kind":"text"},{"text":"FontCompositeSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic013FontCompositeB6TokensP"},{"text":", ","kind":"text"},{"text":"FontMultipleSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic012FontMultipleB6TokensP"},{"text":", ","kind":"text"},{"text":"FontSemanticTokens","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04FontB6TokensP"}],"role":"symbol","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeFontSemanticTo