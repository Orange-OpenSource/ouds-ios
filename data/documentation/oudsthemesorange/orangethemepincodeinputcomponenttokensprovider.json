{"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"sections":[],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of pin code input"}]},{"type":"text","text":" objects like "},{"code":"OUDSPinCodeInput","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllPinCodeInputComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider","type":"reference","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"PinceCodeInputComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"pin code input"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Pin code input"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of dimensions (from "},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"and spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"topicSections":[{"generated":true,"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider\/init(spaces:dimensions:)"],"anchor":"Initializers"},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider\/dimensions","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider\/spaces"],"anchor":"Instance-Properties"},{"generated":true,"title":"Default Implementations","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider\/PinCodeInputComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider\/TokensProvider-Implementations"],"anchor":"Default-Implementations"}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllPinCodeInputComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent012PinCodeInputB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesOrange\/s9EscapableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"type":"conformsTo","kind":"relationships"}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemePinCodeInputComponentTokensProvider","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"code":["    \/\/ Define your own provider for pin code input component tokens","    \/\/ by inheriting from existing provider","    class CustomPinCodeInputComponentTokensProvider: OrangeThemePinCodeInputComponentTokensProvider {","","        \/\/ Then override the input text component tokens you want.","","        override var inputTextSizeMaxWidth: SizeSemanticToken { DimensionRawTokens._3000 }","","        override var inputTextSpacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSmall }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomPinCodeInputComponentTokensProvider: AllIPinCodeInputComponentTokensProvider {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomPinCodeInputComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}]},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(pinCodeInput: CustomPinCodeInputComponentTokensProvider())","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}]},{"code":["    OrangeTheme(pinCodeInput: CustomPinCodeInputComponentTokensProvider())"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    let pintCodeInputComponentTokensProvider = OrangeThemePinCodeInputComponentTokensProvider()","","    \/\/ Or use your own dimension and space semantic tokens providers (or only some)","    let pintCodeInputComponentTokensProvider = OrangeThemePinCodeInputComponentTokensProvider(","                                                sizes: CustomSpaceSemanticTokensProvider(),","                                                dimensions: CustomDimensionSemanticTokensProvider())"],"type":"codeListing","syntax":"swift"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.17.0"}]}],"type":"aside","name":"Since","style":"note"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemepincodeinputcomponenttokensprovider"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","modules":[{"name":"Theme Orange"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemePinCodeInputComponentTokensProvider","kind":"identifier"}],"externalID":"s:16OUDSThemesOrange0B40ThemePinCodeInputComponentTokensProviderC","navigatorTitle":[{"kind":"identifier","text":"OrangeThemePinCodeInputComponentTokensProvider"}],"roleHeading":"Class","title":"OrangeThemePinCodeInputComponentTokensProvider","symbolKind":"class"},"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemePinCodeInputComponentTokensProvider/spaces":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemePinCodeInputComponentTokensProvider\/spaces","abstract":[{"type":"text","text":"Provider of spaces semantic tokens to use for pin code input spaces"}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemepincodeinputcomponenttokensprovider\/spaces","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spaces","kind":"identifier"},{"text":