{"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider"]]},"metadata":{"title":"colors","role":"symbol","roleHeading":"Instance Property","symbolKind":"property","modules":[{"name":"Theme Orange"}],"externalID":"s:16OUDSThemesOrange0B39ThemeControlItemComponentTokensProviderC6colors0A8Contract016AllColorSemanticgH0_pvp","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"colors","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllColorSemanticTokensProvider","preciseIdentifier":"s:18OUDSThemesContract30AllColorSemanticTokensProviderP","kind":"typeIdentifier"}]},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"colors","kind":"identifier"},{"text":": any ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract30AllColorSemanticTokensProviderP","text":"AllColorSemanticTokensProvider","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllColorSemanticTokensProvider","kind":"typeIdentifier"}],"platforms":["macOS"]}],"kind":"declarations"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemecontrolitemcomponenttokensprovider\/colors"]}],"identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider\/colors","interfaceLanguage":"swift"},"abstract":[{"text":"Provider of color semantic tokens to use for control-item-layout-based colors","type":"text"}],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeControlItemComponentTokensProvider":{"url":"\/documentation\/oudsthemesorange\/orangethemecontrolitemcomponenttokensprovider","title":"OrangeThemeControlItemComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeControlItemComponentTokensProvider"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeControlItemComponentTokensProvider"}],"kind":"symbol","abstract":[{"text":"A class which wraps all ","type":"text"},{"type":"strong","inlineContent":[{"text":"component  tokens","type":"text"}]},{"type":"text","text":" for components with a "},{"type":"emphasis","inlineContent":[{"text":"control item","type":"text"}]},{"type":"text","text":" layout like "},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":", "},{"type":"codeVoice","code":"OUDSRadioButton"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSCheckboItem"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllControlItemComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ControlItemComponentTokens"},{"type":"text","text":" so as to expose the component tokens for control-item-layout-basded components through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Such components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"SizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"borders (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":"),  colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":")  and spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider","role":"symbol"},"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"type":"image","identifier":"ic_theme_orange.png","alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","type":"topic","title":"Theme Orange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","role":"collection"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllColorSemanticTokensProvider":{"navigatorTitle":[{"kind":"identifier","text":"AllColorSemanticTokensProvider"}],"title":"AllColorSemanticTokensProvider","role":"symbol","kind":"symbol","type":"topic","url":"\/documentation\/oudsthemescontract\/allcolorsemantictokensprovider","identifier":"doc:\/\/OUDSTheme