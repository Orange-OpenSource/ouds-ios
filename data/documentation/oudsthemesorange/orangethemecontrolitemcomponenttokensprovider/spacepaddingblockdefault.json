ntifier","text":"OrangeThemeControlItemComponentTokensProvider"}],"title":"OrangeThemeControlItemComponentTokensProvider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeControlItemComponentTokensProvider"}],"abstract":[{"text":"A class which wraps all ","type":"text"},{"inlineContent":[{"text":"component  tokens","type":"text"}],"type":"strong"},{"text":" for components with a ","type":"text"},{"inlineContent":[{"text":"control item","type":"text"}],"type":"emphasis"},{"text":" layout like ","type":"text"},{"type":"codeVoice","code":"OUDSSwitch"},{"text":", ","type":"text"},{"type":"codeVoice","code":"OUDSRadioButton"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboItem"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"text":"This provider should be integrated as a ","type":"text"},{"type":"codeVoice","code":"AllControlItemComponentTokensProvider"},{"text":" implementation inside ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" so as to provide","type":"text"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"ControlItemComponentTokens"},{"text":" so as to expose the component tokens for control-item-layout-basded components through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Such components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"type":"codeVoice","code":"SizeSemanticTokensProvider"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"borders (from ","type":"text"},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"text":"),  colors (from ","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"text":")  and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":").","type":"text"}],"url":"\/documentation\/oudsthemesorange\/orangethemecontrolitemcomponenttokensprovider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeControlItemComponentTokensProvider/spacePaddingBlockDefault":{"type":"topic","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacePaddingBlockDefault","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SpaceSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena"}],"kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider\/spacePaddingBlockDefault","abstract":[{"text":"Has for value token spaces.paddingBlockMedium","type":"text"}],"title":"spacePaddingBlockDefault","url":"\/documentation\/oudsthemesorange\/orangethemecontrolitemcomponenttokensprovider\/spacepaddingblockdefault"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"title":"Theme Orange","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","role":"collection","url":"\/documentation\/oudsthemesorange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"kind":"symbol","type":"topic"},"ic_theme_orange.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}],"type":"image","identifier":"ic_theme_orange.png"}}}