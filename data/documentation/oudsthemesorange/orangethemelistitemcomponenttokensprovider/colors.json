d":"typeIdentifier","preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP"}],"abstract":[{"text":"Provider of color semantic tokens to use for button colors","type":"text"}],"url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider\/colors","type":"topic","title":"colors","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider\/colors","kind":"symbol"},"doc://OUDS/documentation/OUDS/AllColorSemanticTokensProvider":{"url":"\/documentation\/ouds\/allcolorsemantictokensprovider","type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AllColorSemanticTokensProvider"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:4OUDS14TokensProviderP","text":"TokensProvider"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic013ColorMultipleB6TokensP","text":"ColorMultipleSemanticTokens"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05ColorB6TokensP","text":"ColorSemanticTokens"}],"kind":"symbol","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllColorSemanticTokensProvider","role":"symbol","abstract":[{"type":"text","text":"Something which provides all semantic tokens of colors"}],"title":"AllColorSemanticTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeListItemComponentTokensProvider":{"role":"symbol","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component  tokens of list item","type":"text"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"list item"}]},{"type":"text","text":" objects like "},{"code":"OUDSListItem","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllListItemComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"ListItemComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"list item"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"List item","type":"text"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") and sizes ("},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"navigatorTitle":[{"text":"OrangeThemeListItemComponentTokensProvider","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider","type":"topic","kind":"symbol","title":"OrangeThemeListItemComponentTokensProvider","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeListItemComponentTokensProvider","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","role":"collection","title":"OUDSThemesOrange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/oudsthemesorange"}}}