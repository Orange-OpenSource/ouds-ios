,"title":"sizes","kind":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizes"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","text":"AllSizeSemanticTokensProvider","preciseIdentifier":"s:4OUDS29AllSizeSemanticTokensProviderP"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider\/sizes"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeListItemComponentTokensProvider":{"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeListItemComponentTokensProvider"}],"type":"topic","title":"OrangeThemeListItemComponentTokensProvider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of list item"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"list item"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSListItem"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllListItemComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ListItemComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"list item"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"List item"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpacesSemanticTokensProvider"},{"type":"text","text":") and sizes ("},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeListItemComponentTokensProvider"}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider","kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","role":"collection","kind":"symbol","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"type":"topic"},"doc://OUDS/documentation/OUDS/AllSizeSemanticTokensProvider":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AllSizeSemanticTokensProvider","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"TokensProvider","preciseIdentifier":"s:4OUDS14TokensProviderP","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"SizeMultipleSemanticTokens","preciseIdentifier":"s:18OUDSTokensSemantic012SizeMultipleB6TokensP","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"SizeSemanticTokens","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB6TokensP","kind":"typeIdentifier"}],"abstract":[{"text":"Something which provides all semantic tokens of size","type":"text"}],"url":"\/documentation\/ouds\/allsizesemantictokensprovider","kind":"symbol","role":"symbol","title":"AllSizeSemanticTokensProvider","type":"topic","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllSizeSemanticTokensProvider"}}}