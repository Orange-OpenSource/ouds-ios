rovider","isActive":true,"type":"reference"},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"code":"ListItemComponentTokens","type":"codeVoice"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"type":"text","text":"list item"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"List item","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"text":") and sizes (","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeListItemComponentTokensProvider/listItemColorContentLoader":{"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider\/listItemColorContentLoader","abstract":[],"url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider\/listitemcolorcontentloader","kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"listItemColorContentLoader","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MultipleColorSemanticTokens","preciseIdentifier":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticTokens","kind":"typeIdentifier"}],"title":"listItemColorContentLoader","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"type":"topic","url":"\/documentation\/oudsthemesorange","role":"collection","kind":"symbol","title":"OUDSThemesOrange","ab