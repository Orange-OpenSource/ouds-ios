{"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeCheckboxComponentTokensProvider"},"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of checkbox"}]},{"type":"text","text":" for  "},{"type":"emphasis","inlineContent":[{"type":"text","text":"checkboxes"}]},{"type":"text","text":" objects"},{"type":"text","text":" "},{"type":"text","text":"like "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllCheckboxComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide all tokens to the users."},{"type":"text","text":" "},{"type":"text","text":"It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeCheckboxComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"CheckboxComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"checkboxes","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Checkboxes"}],"type":"emphasis"},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"code":"SizeSemanticToken","type":"codeVoice"},{"text":") and","type":"text"},{"text":" ","type":"text"},{"text":"borders (","type":"text"},{"code":"BorderRadiusSemanticToken","type":"codeVoice"},{"text":", ","type":"text"},{"code":"BorderWidthSemanticToken","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"These components share the same type of tokens which are all gather edhere.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeCheckboxComponentTokensProvider"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"code":["    \/\/ Define your own provider for checkbox component tokens","    \/\/ by inheriting from existing provider","    class CustomCheckboxComponentTokensProvider: OrangeThemeCheckboxComponentTokensProvider {","","        \/\/ Then override the checkbox component tokens you want.","","        override var sizeMinWidth: SizeSemanticToken { sizes.iconWithLabelLargeSizeXl }","","        override var borderWidthSelected: BorderWidthSemanticToken { borders.widthThin }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomCheckboxComponentTokensProvider: CheckboxComponentTokens {","","        \/\/ And implement hundreds of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomCheckboxComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}]},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(checkbox: CustomCheckboxComponentTokensProvider())","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"code":["    OrangeTheme(checkbox: CustomCheckboxComponentTokensProvider())"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}]},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    let checkboxComponentTokensProvider = OrangeThemeCheckboxComponentTokensProvider()","","    \/\/ Or use your own size, border, color and opacity semantic tokens providers (or only some)","    let checkboxComponentTokensProvider = OrangeThemeCheckboxComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider()))"],"syntax":"swift","type":"codeListing"},{"name":"Since","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.10.0"}]}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemecheckboxcomponenttokensprovider"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllCheckboxComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent08Ch