hundreds of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomCheckboxComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(checkbox: CustomCheckboxComponentTokensProvider())","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}],"type":"paragraph"},{"code":["    OrangeTheme(checkbox: CustomCheckboxComponentTokensProvider())"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}],"type":"paragraph"},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    let checkboxComponentTokensProvider = OrangeThemeCheckboxComponentTokensProvider()","","    \/\/ Or use your own size, border, color and opacity semantic tokens providers (or only some)","    let checkboxComponentTokensProvider = OrangeThemeCheckboxComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider()))"],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.10.0"}]}],"type":"aside","style":"note","name":"Since"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"sections":[],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeT