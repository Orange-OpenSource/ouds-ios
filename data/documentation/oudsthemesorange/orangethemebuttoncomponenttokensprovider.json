onentTokensProvider\/spaceColumnGapChevron","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/spaceColumnGapIconChevron","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/spaces"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/ButtonComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/ButtonMonoComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/TokensProvider-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your own provider for button component tokens","    \/\/ by inheriting from existing provider","    class CustomButtonComponentTokensProvider: OrangeThemeButtonComponentTokensProvider {","","        \/\/ Then override the button component tokens you want.","","        override var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","","        override var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","","        override var buttonBorderRadius: BorderRadiusSemanticToken { borders.radiusMd }","","        override var colorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.repositoryOpacityBlackHigher }","","        override var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomButtonComponentTokensProvider: ButtonComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomButtonComponentTokensProvider","type":"codeVoice"},{"text":" to your own theme implementation:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(button: CustomButtonComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    OrangeTheme(button: CustomButtonComponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let buttonComponentTokensProvider = OrangeThemeButtonComponentTokensProvider()","","    \/\/ Or use your own size, borders, colors and space semantic tokens providers (or only some)","    let buttonComponentTokensProvider = OrangeThemeButtonComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider","                                                colors: CustomColorSemanticTokensProvider","                                                spaces: CustomSpaceSemanticTokensProvider())"]},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.9.0"}]}]}]}],"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component  tokens of buttons","type":"text"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"button"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSButton"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllButtonComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ButtonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"buttons"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTh