{"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeButtonComponentTokensProvider","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"code":["    \/\/ Define your own provider for button component tokens","    \/\/ by inheriting from existing provider","    class CustomButtonComponentTokensProvider: OrangeThemeButtonComponentTokensProvider {","","        \/\/ Then override the button component tokens you want.","","        override var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","","        override var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","","        override var buttonBorderRadius: BorderRadiusSemanticToken { borders.radiusMd }","","        override var colorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.repositoryOpacityBlackHigher }","","        override var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomButtonComponentTokensProvider: ButtonComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Then, you can give this ","type":"text"},{"code":"CustomButtonComponentTokensProvider","type":"codeVoice"},{"text":" to your own theme implementation:","type":"text"}],"type":"paragraph"},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(button: CustomButtonComponentTokensProvider())","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}],"type":"paragraph"},{"code":["    OrangeTheme(button: CustomButtonComponentTokensProvider())"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}],"type":"paragraph"},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let buttonComponentTokensProvider = OrangeThemeButtonComponentTokensProvider()","","    \/\/ Or use your own size, borders, colors and space semantic tokens providers (or only some)","    let buttonComponentTokensProvider = OrangeThemeButtonComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider","                                                colors: CustomColorSemanticTokensProvider","                                                spaces: CustomSpaceSemanticTokensProvider())"],"syntax":"swift","type":"codeListing"},{"style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.9.0"}],"type":"paragraph"}],"type":"aside"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider"},"abstract":[{"text":"A class which wraps all ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of buttons"}]},{"text":" for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"button"}]},{"text":" objects like ","type":"text"},{"type":"codeVoice","code":"OUDSButton"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"text":"This provider should be integrated as a ","type":"text"},{"type":"codeVoice","code":"AllButtonComponentTokensProvider"},{"text":" implementation inside ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" so as to provide","type":"text"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider"},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"ButtonComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"buttons"}]},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Button","type":"text"}]},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":"), borders","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":").","type":"text"}],"metadata":{"role":"symbol","externalID":"s:16OUDSThemesOrange0B34ThemeButtonComponentTokensProviderC","symbolKind":"class","roleHeading":"Class","title":"OrangeThemeButtonComponentTokensProvider","modules":[{"name":"Theme Orange"}],"fragments":[{"text"