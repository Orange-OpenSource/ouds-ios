{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider"]}],"metadata":{"externalID":"s:16OUDSThemesOrange0B34ThemeButtonComponentTokensProviderC","roleHeading":"Class","modules":[{"name":"Theme Orange"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}],"title":"OrangeThemeButtonComponentTokensProvider","role":"symbol","symbolKind":"class"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider"},"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component  tokens of buttons"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"button"}],"type":"emphasis"},{"type":"text","text":" objects like "},{"code":"OUDSButton","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllButtonComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"ButtonComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"buttons"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Button"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"), borders"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"sections":[],"topicSections":[{"generated":true,"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/init(sizes:borders:colors:spaces:)"],"anchor":"Initializers"},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/borders","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/colors","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/spaceColumnGapChevron","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/spaceColumnGapIconChevron","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/spaces"],"anchor":"Instance-Properties"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/ButtonComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/ButtonMonoComponentTokens-Implementations","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/TokensProvider-Implementations"],"title":"Default Implementations","generated":true}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllButtonComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent06ButtonB6TokensP","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent010ButtonMonoB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"code":["    \/\/ Define your own provider for button component tokens","    \/\/ by inheriting from existing provider","    class CustomButtonComponentTokensProvider: OrangeThemeButtonComponentTokensProvider {","","        \/\/ Then override the button component tokens you want.","","        override var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","","        override var borderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","","        override var borderRadius: BorderRadiusSemanticToken { borders.radiusMd }","","        override var colorBgDefaultPressedMono: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","","        override var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomButtonComponentTokensProvider: ButtonComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomButtonComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(button: CustomButtonComponentTokensProvider())","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}],"type":"paragraph"},{"code":["    OrangeTheme(button: CustomButtonComponentTokensProvider())"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}],"type":"paragraph"},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let buttonComponentTokensProvider = OrangeThemeButtonComponentTokensProvider()","","    \/\/ Or use your own size, borders, colors and space semantic tokens providers (or only some)","    let buttonComponentTokensProvider = OrangeThemeButtonComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                borders: CustomBorderSemanticTokensProvider","                                                colors: CustomColorSemanticTokensProvider","                                                spaces: CustomSpaceSemanticTokensProvider())"],"type":"codeListing","syntax":"swift"},{"name":"Since","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.9.0"}]}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeButtonComponentTokensProvider/borders":{"url":"\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider\/borders","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/borders","kind":"symbol","abstract":[{"type":"text","text":"Provider of border semantic tokens to use for button borders"}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"borders","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllBorderSemanticTokensProvider","preciseIdentifier":"s:18OUDSThemesContract31AllBorderSemanticTokensProviderP","kind":"typeIdentifier"}],"type":"topic","role":"symbol","title":"borders"},"doc://OUDSThemesOrange/19OUDSTokensComponent010ButtonMonoB6TokensP":{"identifier":"doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent010ButtonMonoB6TokensP","title":"OUDSTokensComponent.ButtonMonoComponentTokens","type":"unresolvable"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"title":"Theme Orange","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","role":"collection","url":"\/documentatio