"},{"text":" ","kind":"text"},{"text":"AllBorderSemanticTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemescontract\/allbordersemantictokensprovider","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllBorderSemanticTokensProvider","navigatorTitle":[{"text":"AllBorderSemanticTokensProvider","kind":"identifier"}],"type":"topic","kind":"symbol","title":"AllBorderSemanticTokensProvider","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeInputTagComponentTokensProvider/borders":{"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider\/borders","url":"\/documentation\/oudsthemesorange\/orangethemeinputtagcomponenttokensprovider\/borders","title":"borders","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"borders","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllBorderSemanticTokensProvider","preciseIdentifier":"s:18OUDSThemesContract31AllBorderSemanticTokensProviderP","kind":"typeIdentifier"}],"kind":"symbol","abstract":[{"text":"Provider of border semantic tokens to use for tag input borders","type":"text"}]},"ic_theme_orange.png":{"type":"image","identifier":"ic_theme_orange.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"title":"Theme Orange"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeInputTagComponentTokensProvider":{"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"text":"component  tokens of tag input","type":"text"}],"type":"strong"},{"type":"text","text":" objects like "},{"code":"OUDSInputTag","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllInputTagComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider","type":"reference"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"InputTagComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"text":"tag inputs","type":"text"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Tag inputs","type":"text"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"and borders (from "},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeInputTagComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemeinputtagcomponenttokensprovider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider","navigatorTitle":[{"text":"OrangeThemeInputTagComponentTokensProvider","kind":"identifier"}],"type":"topic","kind":"symbol","title":"OrangeThemeInputTagComponentTokensProvider","role":"symbol"}}}