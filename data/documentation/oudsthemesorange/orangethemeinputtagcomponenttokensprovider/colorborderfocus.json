"ic_theme_orange.png","type":"image","alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeInputTagComponentTokensProvider":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemeinputtagcomponenttokensprovider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeInputTagComponentTokensProvider"}],"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of tag input"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSInputTag"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllInputTagComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider","isActive":true,"type":"reference"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"InputTagComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tag inputs"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Tag inputs"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"and borders (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeInputTagComponentTokensProvider"}],"type":"topic","title":"OrangeThemeInputTagComponentTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeInputTagComponentTokensProvider/colorBorderFocus":{"kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"colorBorderFocus"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MultipleColorSemanticToken","preciseIdentifier":"c:@M@OUDSTokensSemantic@objc(cs)MultipleColorSemanticToken"}],"abstract":[{"text":"Has for value token colors.actionFocus","type":"text"}],"url":"\/documentation\/oudsthemesorange\/orangethemeinputtagcomponenttokensprovider\/colorborderfocus","title":"colorBorderFocus","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTagComponentTokensProvider\/colorBorderFocus"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","role":"collection","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"url":"\/documentation\/oudsthemesorange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"kind":"symbol","type":"topic"}}}