{"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"text":"component  tokens of chip","type":"text"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"text":"chip","type":"text"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSFilterChip"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSSuggestionChip"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllChipComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ChipComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"chip","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Chip","type":"text"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") ,"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":"), dimensions ("},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and border  (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")."}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllChipComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent04ChipB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"],"type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeChipComponentTokensProvider","kind":"identifier"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"codeListing","code":["    \/\/ Define your own provider for chip component tokens","    \/\/ by inheriting from existing provider","    class CustomChipComponentTokensProvider: OrangeThemeChipComponentTokensProvider {","","        \/\/ Then override the chip component tokens you want.","","        override var sizeMinHeight: SizeSemanticToken { DimensionRawTokens._500 }","","        override var borderWidthDefault: BorderWidthSemanticToken { borders.widthmediumt }","","        override var colorBgFocus: MultipleColorSemanticToken { colors.contentDefault }","","        override var spaceInsetIconOnly: SpaceSemanticToken { spaces.paddingInlineTall }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomChipComponentTokensProvider: ChipComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Then, you can give this ","type":"text"},{"code":"CustomChipComponentTokensProvider","type":"codeVoice"},{"text":" to your own theme implementation:","type":"text"}]},{"type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(chip: CustomChipComponentTokensProvider())","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"type":"codeListing","code":["    OrangeTheme(chip: CustomChipComponentTokensProvider())"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}]},{"type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    let chipComponentTokensProvider = OrangeThemeChipComponentTokensProvider()","","    \/\/ Or use your own dimension, border, color and space semantic tokens providers (or only some)","    let chipComponentTokensProvider = OrangeThemeChipComponentTokensProvider(","                                                borders: CustomBorderSemanticTokensProvider(),","                                                colors: CustomColorSemanticTokensProvider(),","                                                space: CustomSpaceSemanticTokensProvider(),","                                                dimensions: CustomDimensionSemanticTokensProvider())"]