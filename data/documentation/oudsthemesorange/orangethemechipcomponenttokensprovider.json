ders if you want to define values.","    }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"type":"codeVoice","code":"CustomChipComponentTokensProvider"},{"type":"text","text":" to your own theme implementation:"}]},{"type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(chip: CustomChipComponentTokensProvider())","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"or to an already existing theme for example:","type":"text"}]},{"type":"codeListing","code":["    OrangeTheme(chip: CustomChipComponentTokensProvider())"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}]},{"type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    let chipComponentTokensProvider = OrangeThemeChipComponentTokensProvider()","","    \/\/ Or use your own _, border, color and space semantic tokens providers (or only some)","    let chipComponentTokensProvider = OrangeThemeChipComponentTokensProvider(","                                                borders: CustomBorderSemanticTokensProvider(),","                                                colors: CustomColorSemanticTokensProvider(),","                                                space: CustomSpaceSemanticTokensProvider(),","                                                dimensions: CustomDimensionSemanticTokensProvider())"],"syntax":"swift"},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.10.0","type":"text"}]}]}]}],"hierarchy":{"paths":[["doc:\/\