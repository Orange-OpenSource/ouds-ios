{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"sections":[],"kind":"symbol","metadata":{"role":"symbol","externalID":"s:16OUDSThemesOrange0B32ThemeChipComponentTokensProviderC","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeChipComponentTokensProvider"}],"modules":[{"name":"Theme Orange"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeChipComponentTokensProvider"}],"title":"OrangeThemeChipComponentTokensProvider","symbolKind":"class","roleHeading":"Class"},"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component  tokens of chip"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"chip"}],"type":"emphasis"},{"type":"text","text":" objects like "},{"code":"OUDSFilterChip","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSSuggestionChip","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllChipComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"ChipComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"chip"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Chip"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") ,"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"), dimensions ("},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and border  (from "},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllChipComponentTokensProvider","doc:\/\/OUDSThemesOrange\/19OUDSTokensComponent04ChipB6TokensP","doc:\/\/OUDSThemesOrange\/s8CopyableP","doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/TokensProvider"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeChipComponentTokensProvider"}]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define your own provider for chip component tokens","    \/\/ by inheriting from existing provider","    class CustomChipComponentTokensProvider: OrangeThemeChipComponentTokensProvider {","","        \/\/ Then override the chip component tokens you want.","","        override var sizeMinHeight: SizeSemanticToken { DimensionRawTokens._500 }","","        override var borderWidthDefault: BorderWidthSemanticToken { borders.widthmediumt }","","        override var colorBgFocus: MultipleColorSemanticTokens { colors.contentDefault }","","        override var spaceInsetIconOnly: SpaceSemanticToken { spaces.paddingInlineTall }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomChipComponentTokensProvider: ChipComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"text":"Then, you can give this ","type":"text"},{"type":"codeVoice","code":"CustomChipComponentTokensProvider"},{"text":" to your own theme implementation:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(chip: CustomChipComponentTokensProvider())","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}]},{"syntax":"swift","type":"codeListing","code":["    OrangeTheme(chip: CustomChipComponentTokensProvider())"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"syntax":"swift","type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    \/\/ - OrangeThemeDimensionSemanticTokensProvider for dimensions","    let c