ensProvider()","","    \/\/ Or use your own semantic tokens providers","    let alertComponentTokensProvider = OrangeThemeAlertComponentTokensProvider(","                    sizes: CustomSizeSemanticTokensProvider(),","                    borders: CustomBorderSemanticTokensProvider(),","                    spaces: CustomSpaceSemanticTokensProvider())"]},{"type":"aside","name":"Since","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.2.0"}]}]}]}],"sections":[],"metadata":{"title":"OrangeThemeAlertComponentTokensProvider","modules":[{"name":"Theme Orange"}],"roleHeading":"Class","symbolKind":"class","role":"symbol","externalID":"s:16OUDSThemesOrange0B33ThemeAlertComponentTokensProviderC","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeAlertComponentTokensProvider","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeThemeAlertComponentTokensProvider","kind":"identifier"}]},"abstract":[{"text":"A class which wraps all ","type":"text"},{"type":"strong","inlineContent":[{"text":"component  tokens of alert","type":"text"}]},{"text":" for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"alert","type":"text"}]},{"text":" objects like ","type":"text"},{"code":"OUDSAlert","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"text":"This provider should be integrated as a ","type":"text"},{"code":"AllAlertComponentTokensProvider","type":"codeVoice"},{"text":" implementation inside ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" so as to provide","type":"text"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" implementation to use."