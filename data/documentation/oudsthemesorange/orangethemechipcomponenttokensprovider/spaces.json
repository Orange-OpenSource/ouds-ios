hasis","inlineContent":[{"type":"text","text":"Chip"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") ,"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":"), dimensions ("},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and border  (from ","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider"},"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"ic_theme_orange.png"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeChipComponentTokensProvider/spaces":{"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"spaces"},{"kind":"text","text":": any "},{"preciseIdentifier":"s:18OUDSThemesContract30AllSpaceSemanticTokensProviderP","kind":"typeIdentifier","text":"AllSpaceSemanticTokensProvider"}],"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider\/spaces","abstract":[{"type":"text","text":"Provider of spaces semantic tokens to use for chip spaces"}],"url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider\/spaces","title":"spaces"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"Theme Orange","url":"\/documentation\/oudsthemesorange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","