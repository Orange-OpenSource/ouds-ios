er they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"ChipComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"text":"chip","type":"text"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Chip","type":"text"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") ,"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":"), dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and border  (from ","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeChipComponentTokensProvider"}],"type":"topic","url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider","title":"OrangeThemeChipComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeChipComponentTokensProvider"}],"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllSpaceSemanticTokensProvider":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllSpaceSemanticTokensProvider","title":"AllSpaceSemanticTokensProvider","abstract":[{"text":"Something which provides all semantic tokens of space","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":