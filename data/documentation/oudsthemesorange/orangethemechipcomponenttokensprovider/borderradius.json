t","text":"chip"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Chip"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":") ,","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":"), dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and border  (from ","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider","navigatorTitle":[{"text":"OrangeThemeChipComponentTokensProvider","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeChipComponentTokensProvider/borderRadius":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider\/borderRadius","title":"borderRadius","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"borderRadius"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"BorderRadiusSemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic012BorderRadiusB5Tokena"}],"type":"topic","abstract":[{"type":"text","text":"Has for value token borders.radiusPill"}],"kind":"symbol","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider\/borderradius"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"type":"topic","kind":"symbol","role":"collection","url":"\/documentation\/oudsthemesorange"}}}