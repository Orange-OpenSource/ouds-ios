nge\/documentation\/OUDSThemesOrange\/OrangeThemeSelectComponentTokensProvider","type":"reference","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"SelectComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"select"}]},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Select","type":"text"}]},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"colors (from ","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"text":") and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":").","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeSelectComponentTokensProvider","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeThemeSelectComponentTokensProvider","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"type":"topic","url":"\/documentation\/oudsthemesorange","role":"collection","kind":"symbol","title":"OUDSThemesOrange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"},"doc://OUDS/documentation/OUDS/AllColorSemanticTokensProvider":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"