STheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Select","type":"text"}]},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"colors (from ","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"text":") and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":").","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeSelectComponentTokensProvider","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeThemeSelectComponentTokensProvider","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSelectComponentTokensProvider/selectSizeMinHeightIconOnly":{"role":"symbol","abstract":[],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"selectSizeMinHeightIconOnly","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","text":"SizeSemanticToken","kind":"typeIdentifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSelectComponentTokensProvider\/selectSizeMinHeightIconOnly","type":"topic","kind":"symbol","title":"selectSizeMinHeightIconOnly","url":"\/documentation\/oudsthemesorange\/orangethemeselectcomponenttokensprovider\/selectsizeminheighticononly"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"type":"topic","url":"\/documentation\/oudsthemesorange","role":"collection","kind":"symbol","title":"OUDSThemesOrange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors