okens to use for alert borders","type":"text"}],"role":"symbol","title":"borders","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"borders"},{"kind":"text","text":": any "},{"preciseIdentifier":"s:18OUDSThemesContract31AllBorderSemanticTokensProviderP","kind":"typeIdentifier","text":"AllBorderSemanticTokensProvider"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider\/borders"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllBorderSemanticTokensProvider":{"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"AllBorderSemanticTokensProvider"}],"abstract":[{"text":"Something which provides all semantic tokens of border","type":"text"}],"type":"topic","role":"symbol","title":"AllBorderSemanticTokensProvider","kind":"symbol","navigatorTitle":[{"text":"AllBorderSemanticTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemescontract\/allbordersemantictokensprovider","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllBorderSemanticTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","type":"topic","title":"Theme Orange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","role":"collection"},"ic_theme_orange.png":{"type":"image","identifier":"ic_theme_orange.png","variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"alt":null},"doc://OUDSThemesOrange/documentatio