ponenttokensprovider\/spaces","role":"symbol","kind":"symbol","title":"spaces","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider\/spaces","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spaces","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllSpaceSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract30AllSpaceSemanticTokensProviderP"}],"type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeAlertComponentTokensProvider":{"abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of alert"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"alert"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSAlert"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllAlertComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider","type":"reference","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"AlertComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"alert"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Alert"}]},{"type":"text","text":" components tokens are defined with semantic tokens of borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProviders"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":") and sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")."}],"url":"\/documentation\/oudsthemesorange\/orangethemealertcomponenttokensprovider","navigatorTitle":[{"text":"OrangeThemeAlertComponentTokensProvider","kind":"identifier"}],"role":"symbol","kind":"symbol","title":"OrangeThemeAlertComponentTokensProvider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeAlertComponentTokensProvider","kind":"identifier"}],"type":"topic"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllSpaceSemanticTokensProvider":{"kind":"symbol","title":"AllSpaceSemanticTokensProvider","type":"topic","abstract":[{"type":"text","text":"Something which provides all semantic tokens of space"}],"url":"\/documentation\/oudsthemescontract\/allspacesemantictokensprovider","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AllSpaceSemanticTokensProvider","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract14TokensProviderP","text":"TokensProvider","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic013SpaceMultipleB6TokensP","text":"SpaceMultipleSemanticTokens","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB6TokensP","text":"SpaceSemanticTokens","kind":"typeIdentifier"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllSpaceSemanticTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","title":"Theme Orange","type":"topic","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"url":"\/documentation\/oudsthemesorange","role":"collection","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"},"ic_theme_orange.png":{"alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}],"identifier":"ic_theme_orange.png"}}}