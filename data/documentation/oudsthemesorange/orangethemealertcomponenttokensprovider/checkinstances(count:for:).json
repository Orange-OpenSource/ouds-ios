r:)"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeAlertComponentTokensProvider":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemealertcomponenttokensprovider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeAlertComponentTokensProvider"}],"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of alert"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"alert"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSAlert"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllAlertComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider","isActive":true,"type":"reference"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"AlertComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"alert"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Alert"}]},{"type":"text","text":" components tokens are defined with semantic tokens of borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProviders"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":") and sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeAlertComponentTokensProvider"}],"type":"topic","title":"OrangeThemeAlertComponentTokensProvider"}}}