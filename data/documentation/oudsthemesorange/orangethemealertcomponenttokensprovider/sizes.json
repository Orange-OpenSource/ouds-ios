{"sections":[],"abstract":[{"text":"Provider of sizes semantic tokens to use for alert sizes","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"externalID":"s:16OUDSThemesOrange0B33ThemeAlertComponentTokensProviderC5sizes0A8Contract015AllSizeSemanticfG0_pvp","symbolKind":"property","modules":[{"name":"Theme Orange"}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizes","kind":"identifier"},{"text":": any ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract29AllSizeSemanticTokensProviderP","text":"AllSizeSemanticTokensProvider","kind":"typeIdentifier"}],"role":"symbol","title":"sizes","roleHeading":"Instance Property"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider"]]},"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemealertcomponenttokensprovider\/sizes"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizes","kind":"identifier"},{"text":": any ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract29AllSizeSemanticTokensProviderP","text":"AllSizeSemanticTokensProvider","kind":"typeIdentifier","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllSizeSemanticTokensProvider"}],"languages":["swift"],"platforms":["macOS"]}]}],"kind":"symbol","identifier":{"url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider\/sizes","interfaceLanguage":"swift"},"references":{"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"type":"image","identifier":"ic_theme_orange.png","alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeAlertComponentTokensProvider":{"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemealertcomponenttokensprovider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeAlertComponentTokensProvider"}],"title":"OrangeThemeAlertComponentTokensProvider","abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"text":"component  tokens of alert","type":"text"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"text":"alert","type":"text"}],"type":"emphasis"},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSAlert"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllAlertComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"AlertComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"alert","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Alert"}]},{"type":"text","text":" components tokens are defined with semantic tokens of borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProviders"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":") and sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeAlertComponentTokensProvider"}],"type":"topic","kind":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","type":"topic","url":"\/documentation\/oudsthemesorange","kind":"symbol"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllSizeSemanticTokensProvider":{"abstract":[{"type":"text","text":"Something which provides all semantic tokens of size"}],"navigatorTitle":[{"kind":"identifier","text":"AllSizeSemanticTokensProvider"}],"kind":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllSizeSemanticTokensProvider","type":"topic","url":"\/documentation\/oudsthemescontract\/allsizesemantictokensprovider","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AllSizeSemanticTokensProvider"}],"title":"AllSizeSemanticTokensProvider","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeAlertComponentTokensProvider/sizes":{"title":"sizes","abstract":[{"text":"Provider of sizes semantic tokens to use for alert sizes","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider\/sizes","role":"symbol","type":"topic","url":"\/documentation\/oudsthemesorange\/orangethemealertcomponenttokensprovider\/sizes","kind":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizes","kind":"identifier"},{"text":": any ","kind":"text"},{"text":"AllSizeSemanticTokensProvider","preciseIdentifier":"s:18OUDSThemesContract29AllSizeSemanticTokensProviderP","kind":"typeIdentifier"}]}}}