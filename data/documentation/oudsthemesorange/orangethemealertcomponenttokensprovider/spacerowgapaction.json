":"alert","type":"text"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Alert","type":"text"}]},{"type":"text","text":" components tokens are defined with semantic tokens of borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProviders"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":") and sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeAlertComponentTokensProvider","kind":"identifier"}],"role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeAlertComponentTokensProvider/spaceRowGapAction":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider\/spaceRowGapAction","title":"spaceRowGapAction","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spaceRowGapAction","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SpaceSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena"}],"type":"topic","abstract":[{"text":"Has for value token spaces.rowGap2xsmall","type":"text"}],"kind":"symbol","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemealertcomponenttokensprovider\/spacerowgapaction"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"type":"topic","kind":"symbol","role":"collection","url":"\/documentation\/oudsthemesorange"}}}