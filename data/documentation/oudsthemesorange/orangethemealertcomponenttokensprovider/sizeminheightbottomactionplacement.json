hemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"AlertComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"alert"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"Alert","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of borders (","type":"text"},{"type":"codeVoice","code":"AllBorderSemanticTokensProviders"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":") and sizes (from ","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeAlertComponentTokensProvider"}],"navigatorTitle":[{"text":"OrangeThemeAlertComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeAlertComponentTokensProvider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeAlertComponentTokensProvider","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemealertcomponenttokensprovider","type":"topic"},"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"identifier":"ic_theme_orange.png","type":"image","alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","type":"topic","url":"\/documentation\/oudsthemesorange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","t