ovider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"text":") ,  dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"sizes (","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":"), borders (","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":") and opacities (","type":"text"},{"code":"AllOpacitiySemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","navigatorTitle":[{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"type":"topic","kind":"symbol","title":"OrangeThemeSwitchComponentTokensProvider","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/sizeWidthCursorSelected":{"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/sizeWidthCursorSelected","url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/sizewidthcursorselected","title":"sizeWidthCursorSelected","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizeWidthCursorSelected"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","kind":"typeIdentifier","text":"SizeSemanticToken"}],"kind":"symbol","abstract":[{"type":"text","text":"Has for value token dimensions._3