":"codeVoice"},{"text":") ,  dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"sizes (","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":"), borders (","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":") and opacities (","type":"text"},{"code":"AllOpacitiySemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeSwitchComponentTokensProvider"}],"url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider","type":"topic","title":"OrangeThemeSwitchComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeSwitchComponentTokensProvider"}],"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider"},"ic_theme_orange.png":{"alt":null,"identifier":"ic_theme_orange.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}],"type":"image"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"type":"topic","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","kind":"symbol","role":"collection","url":"\/documentation\/oudsthemesorange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/opacityCheck":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"opacityCheck","kind":"identifi