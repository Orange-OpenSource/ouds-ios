efined with semantic tokens of colors (from ","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"text":"spaces (from ","type":"text"},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"text":") ,  dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"sizes (","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":"), borders (","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") and opacities ("},{"code":"AllOpacitiySemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"role":"symbol","title":"OrangeThemeSwitchComponentTokensProvider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeSwitchComponentTokensProvider"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeSwitchComponentTokensProvider"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/opacityCheck":{"abstract":[{"type":"text","text":"Has for value token opacities.opaque"}],"role":"symbol","title":"opacityCheck","url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/opacitycheck","kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"opacityCheck","kind":"identifier"},{"text":": ","kind":"text"},{"text":"OpacitySemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic07OpacityB5Tokena","kind":"typeIdentifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/opacityCheck","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThem