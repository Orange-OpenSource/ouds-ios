:true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"code":"SwitchComponentTokens","type":"codeVoice"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"type":"text","text":"switch \/ toggle"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Switch"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"text":") ,  dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"sizes (","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":"), borders (","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":") and opacities (","type":"text"},{"code":"AllOpacitiySemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","navigatorTitle":[{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"type":"topic","kind":"symbol","title":"OrangeThemeSwitchComponentTokensProvider","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","type":