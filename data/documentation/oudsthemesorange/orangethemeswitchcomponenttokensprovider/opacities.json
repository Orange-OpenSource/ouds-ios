emesOrange/OrangeThemeSwitchComponentTokensProvider/opacities":{"abstract":[{"text":"Provider of opacities semantic tokens to use for switch spaces","type":"text"}],"url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/opacities","role":"symbol","kind":"symbol","title":"opacities","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/opacities","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"opacities"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract32AllOpacitySemanticTokensProviderP","text":"AllOpacitySemanticTokensProvider"}],"type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider":{"kind":"symbol","navigatorTitle":[{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeSwitchComponentTokensProvider","type":"topic","abstract":[{"text":"A class which wraps all ","type":"text"},{"inlineContent":[{"type":"text","text":"component  tokens of switch"}],"type":"strong"},{"text":" for ","type":"text"},{"inlineContent":[{"type":"text","text":"switch \/ toggle"}],"type":"emphasis"},{"text":" objects like ","type":"text"},{"type":"codeVoice","code":"OUDSSwitch"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllSwitchComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","type":"reference","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"code":"SwitchComponentTokens","type":"codeVoice"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"switch \/ toggle"}]},{"text":" through any ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Switch"}]},{"text":" components tokens are defined with semantic tokens of colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"text":") ,  dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"type":"text","text":" "},{"text":"sizes (","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":") and opacities ("},{"type":"codeVoice","code":"AllOpacitiySemanticTokensProvider"},{"type":"text","text":")."}],"url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","title":"Theme Orange","type":"topic","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"url":"\/documentation\/oudsthemesorange","role":"collection","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/AllOpacitySemanticTokensProvider":{"url":"\/documentation\/oudsthemescontract\/allopacitysemantictokensprovider","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/AllOpacitySemanticTokensProvider","abstract":[{"type":"text","text":"Something which provides all semantic tokens of opacity"}],"title":"AllOpacitySemanticTokensProvider","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AllOpacitySemanticTokensProvider","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"TokensProvider","preciseIdentifier":"s:18OUDSThemesContract14TokensProviderP","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"OpacitySemanticTokens","preciseIdentifier":"s:18OUDSTokensSemantic07OpacityB6TokensP","kind":"typeIdentifier"}],"role":"symbol","kind":"symbol"}}}