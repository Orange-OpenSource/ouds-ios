ColorSemanticTokensProvider"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"text":") ,  dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"sizes ("},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":") and opacities ("},{"type":"codeVoice","code":"AllOpacitiySemanticTokensProvider"},{"type":"text","text":")."}],"type":"topic","role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/opacities":{"url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/opacities","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/opacities","role":"symbol","type":"topic","title":"opacities","abstract":[{"type":"text","text":"Provider of opacities semantic tokens to use for switch spaces"}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"opacities","kind":"identifier"},{"text":": any ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract32AllOpacitySemanticTokensProviderP","text":"AllOpacitySemanticTokensProvider","kind":"typeIdentifier"}]}}}