Provider","isActive":true,"type":"reference"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"SwitchComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"switch \/ toggle"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Switch"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpacesSemanticTokensProvider"},{"type":"text","text":") , sizes ("},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"borders ("},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":") and opacities ("},{"type":"codeVoice","code":"AllOpacitiySemanticTokensProvider"},{"type":"text","text":")."}],"navigatorTitle":[{"text":"OrangeThemeSwitchComponentTokensProvider","kind":"identifier"}]},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/borders":{"url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/borders","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"borders"},{"kind":"text","text":": any "},{"kind":"typeIdentifier","preciseIdentifier":"s:4OUDS31AllBorderSemanticTokensProviderP","text":"AllBorderSemanticTokensProvider"}],"title":"borders","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/borders","abstract":[{"type":"text","text":"Provider of size semantic tokens to use for switch sizes"}],"type":"topic"},"doc://OUDS/documentation/OUDS/AllBorderSemanticTokensProvider":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AllBorderSemanticTokensProvider"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"TokensProvider","preciseIdentifier":"s:4OUDS14TokensProviderP"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"BorderSemanticTokens","preciseIdentifier":"s:18OUDSTokensSemantic06BorderB6TokensP"}],"url":"\/documentation\/ouds\/allbordersemantictokensprovider","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/AllBorderSemanticTokensProvider","kind":"symbol","type":"topic","title":"AllBorderSemanticTokensProvider","role":"symbol","abstract":[{"type":"text","text":"Something which provides all semantic tokens of border"}]}}}