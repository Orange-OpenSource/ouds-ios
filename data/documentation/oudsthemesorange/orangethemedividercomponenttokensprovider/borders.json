asis","inlineContent":[{"text":"Divider","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of borders (from "},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeDividerComponentTokensProvider"}],"url":"\/documentation\/oudsthemesorange\/orangethemedividercomponenttokensprovider"}}}