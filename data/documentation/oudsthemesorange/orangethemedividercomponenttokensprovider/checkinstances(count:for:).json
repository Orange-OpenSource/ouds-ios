xt","text":", "},{"kind":"externalParam","text":"for"},{"kind":"text","text":" "},{"kind":"internalParam","text":"providerName"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":")"}],"platforms":["macOS"]}],"kind":"declarations"}],"references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"type":"topic","role":"collection","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"url":"\/documentation\/oudsthemesorange","title":"Theme Orange"},"ic_theme_orange.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png"}],"identifier":"ic_theme_orange.png","type":"image","alt":null},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeDividerComponentTokensProvider":{"url":"\/documentation\/oudsthemesorange\/orangethemedividercomponenttokensprovider","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeDividerComponentTokensProvider"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeDividerComponentTokensProvider"}],"role":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeDividerComponentTokensProvider","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of divider"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"divider"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSVerticalDivider"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllDividerComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeDividerComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"DividerComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"divider"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Divider"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of borders (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")."}],"title":"OrangeThemeDividerComponentTokensProvider","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeDividerComponentTokensProvider/checkInstances(count:for:)":{"url":"\/documentation\/oudsthemesorange\/orang