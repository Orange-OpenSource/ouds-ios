{"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemedividercomponenttokensprovider\/dividercomponenttokens-implementations"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeDividerComponentTokensProvider\/DividerComponentTokens-Implementations"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeDividerComponentTokensProvider"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeDividerComponentTokensProvider\/borderWidth"],"anchor":"Instance-Properties"}],"metadata":{"title":"DividerComponentTokens Implementations","role":"collectionGroup","roleHeading":"API Collection","modules":[{"name":"Theme Orange"}]},"sections":[],"kind":"article","references":{"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"Theme Orange","images":[{"type":"icon","identifier":"ic_theme_orange.png"}],"type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeDividerComponentTokensProvider":{"kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemedividercomponenttokensprovider","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of divider"}]},{"type":"text","text":" for "},{"