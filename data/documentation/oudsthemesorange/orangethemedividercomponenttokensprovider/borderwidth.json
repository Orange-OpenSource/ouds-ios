nd":"symbol","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","type":"topic","url":"\/documentation\/oudsthemesorange","role":"collection","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"title":"Theme Orange"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeDividerComponentTokensProvider/borderWidth":{"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"borderWidth"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"BorderWidthSemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic011BorderWidthB5Tokena"}],"kind":"symbol","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeDividerComponentTokensProvider\/borderWidth","url":"\/documentation\/oudsthemesorange\/orangethemedividercomponenttokensprovider\/borderwidth","abstract":[{"text":"Has for value token borders.widthThin","type":"text"}],"type":"topic","title":"borderWidth"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeDividerComponentTokensProvider":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeDividerComponentTokensProvider"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeDividerComponentTokensProvider"}],"kind":"symbol","type":"topic","url":"\/documentation\/oudsthemesorange\/orangethemedividercomponenttokensprovider","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of divider"}]},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"divider"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSVerticalDivider"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllDividerComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeDividerComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"DividerComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"divider"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Divider"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of borders (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")."}],"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeDividerComponentTokensProvider","title":"OrangeThemeDivider