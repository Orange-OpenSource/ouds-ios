wn provider from scratch","    class CustomDividerComponentTokensProvider: ChipComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomDividerComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}]},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(divider: CustomDividerComponentTokensProvider())","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}]},{"code":["    OrangeTheme(divider: CustomDividerComponentTokensProvider())"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to use your own semantic tokens providers for this component tokens providers:"}]},{"code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeBorderSemanticTokensProvider for borders","    let dividerComponentTokensProvider = OrangeThemeDividerComponentTokensProvider()","","    \/\/ Or use your own border semantic tokens providers","    let dividerComponentTokensProvider = OrangeThemeDividerComponentTokensProvider(","                                                borders: CustomBorderSemanticTokensProvider())"],"type":"codeListing","syntax":"swift"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.13.0"}]}],"type":"aside","name":"Since","style":"note"}],"kind":"content"}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeDividerComponentTokensProvider\/init(borders:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSTheme