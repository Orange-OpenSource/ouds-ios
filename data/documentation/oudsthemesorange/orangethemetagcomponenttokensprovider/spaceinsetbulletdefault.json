on inside "},{"type":"codeVoice","code":"OUDSTheme"},{"text":" so as to provide","type":"text"},{"type":"text","text":" "},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"TagComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"text":"tags","type":"text"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"inlineContent":[{"text":"Tags","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of dimensions (","type":"text"},{"type":"codeVoice","code":"AllDimensionSemanticTokensProvider"},{"text":") ,","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":") , sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizesSemanticTokensProvider"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and borders (from ","type":"text"},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")."}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemetagcomponenttokensprovider","type":"topic"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"title":"Theme Orange","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","role":"collection","url":"\/documentation\/oudsthemesorange","images":[{"identifier":"ic_theme_orange.png","type":"icon"}],"kind":"symbol","type":"topic"}}}