y ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Tags"}]},{"text":" components tokens are defined with semantic tokens of dimensions (","type":"text"},{"code":"AllDimensionSemanticTokensProvider","type":"codeVoice"},{"text":") ,","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":") , sizes (from ","type":"text"},{"code":"AllSizesSemanticTokensProvider","type":"codeVoice"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and borders (from ","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}]},"ic_theme_orange.png":{"variants":[{"url":"\/images\/OUDSThemesOrange\/ic_theme_orange.png","traits":["1x","light"]}],"alt":null,"type":"image","identifier":"ic_theme_orange.png"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTagComponentTokensProvider/sizeAssetDefault":{"identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider\/sizeAssetDefault","title":"sizeAssetDefault","type":"topic","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemetagcomponenttokensprovider\/sizeassetdefault","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizeAssetDefault","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena","text":"SizeSemanticToken"}],"abstract":[{"type":"text","text":"Has for value token sizes.iconWithLabelMediumSizeSmall"}],"role":"symbol"},"doc://OUDSThemesOrange/documentation/OUDSThemesOrange":{"title":"Theme Orange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the 