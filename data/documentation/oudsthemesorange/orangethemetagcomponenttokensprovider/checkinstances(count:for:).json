ensionSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") ,"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") , sizes (from "},{"type":"codeVoice","code":"AllSizesSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and borders (from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":")."}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeTagComponentTokensProvider","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeTagComponentTokensProvider"}],"title":"OrangeThemeTagComponentTokensProvider","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemetagcomponenttokensprovider","type":"topic"}}}