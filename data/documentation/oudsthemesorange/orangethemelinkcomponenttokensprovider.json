{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"A class which wraps all ","type":"text"},{"inlineContent":[{"type":"text","text":"component  tokens of links"}],"type":"strong"},{"text":" for ","type":"text"},{"inlineContent":[{"type":"text","text":"link"}],"type":"emphasis"},{"text":" objects like ","type":"text"},{"type":"codeVoice","code":"OUDSLink"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"text":"This provider should be integrated as a ","type":"text"},{"type":"codeVoice","code":"AllLinkComponentTokensProvider"},{"text":" implementation inside ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" so as to provide","type":"text"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"LinkComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"links"}]},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Link","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") and spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeLinkComponentTokensProvider"}],"platforms":["macOS"]}]},{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define your own provider for link component tokens","    \/\/ by inheriting from existing provider","    class CustomLinkComponentTokensProvider: OrangeThemeLinkComponentTokensProvider {","","        \/\/ Then override the link component tokens you want.","","        override var sizeMinHeightMedium: SizeSemanticToken { DimensionRawTokens._600 }","","        override var colorChevronHover: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","","        override var spaceColumnGapIconSmall: SpaceSemanticToken { spaces.paddingInlineSpacious }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomLinkComponentTokensProvider: LinkComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"]},{"inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomLinkComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(link: CustomLinkComponentTokensProvider())","    }","}"]},{"inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    OrangeTheme(link: CustomLinkComponentTokensProvider())"]},{"inlineContent":[{"text":"It is also possible to use your own semantic tokens providers for this component tokens providers:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Uses by default here:","    \/\/ - OrangeThemeSizeSemanticTokensProvider for sizes","    \/\/ - OrangeThemeColorSemanticTokensProvider for colors","    \/\/ - OrangeThemeSpaceSemanticTokensProvider for spaces","    let linkComponentTokensProvider = OrangeThemeLinkComponentTokensProvider()","","    \/\/ Or use your own size, color and space semantic tokens providers (or only some)","    let linkComponentTokensProvider = OrangeThemeLinkComponentTokensProvider(","                                                sizes: CustomSizeSemanticTokensProvider(),","                                                colors: CustomColorSemanticTokensProvider(),","                                                space: CustomSpaceSemanticTokensProvider())"]},{"name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.9.0","type":"text"}]}],"type":"aside","style":"note"}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"topicSections":[{"generated":true,"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider\/init(sizes:colors:spaces:)"],"anchor":"Initializers"},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider\/colors","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider\/sizes","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkCompone