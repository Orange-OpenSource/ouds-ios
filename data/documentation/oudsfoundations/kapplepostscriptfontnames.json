{"abstract":[{"type":"text","text":"Contains the Apple PostScript name of a font given a font family name and a font weight."},{"type":"text","text":" "},{"type":"text","text":"Such values have been picked from the Apple Font Book."}],"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/kApplePostScriptFontNames"},"hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"kApplePostScriptFontNames"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/PostScriptFontNamesMap","text":"PostScriptFontNamesMap","preciseIdentifier":"s:15OUDSFoundations22PostScriptFontNamesMapa"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"If you use your own fonts, be sure their PostScript name:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"do not collide with one the the values defined here (depending to tokens)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"do not collide with one of the Apple available fonts (in iOS side)","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Defines also kind of fallbacks if the weight or the style is not defined."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/oudsfoundations\/kapplepostscriptfontnames"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","roleHeading":"Global Variable","modules":[{"name":"Foundations"}],"symbolKind":"var","externalID":"s:15OUDSFoundations25kApplePos