. 7:1 for textual","type":"text"},{"text":" ","type":"text"},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference"}],"navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"title":"OUDSWCAG21Ratio","role":"symbol","url":"\/documentation\/oudsfoundations\/oudswcag21ratio"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"type":"topic","images":[{"identifier":"ic_layers.png","type":"icon"}],"kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","abstract":[{"text":"Contains a set of helpers and extensions shared for higher level targets.","type":"text"}],"title":"Foundations","role":"collection","url":"\/documentation\/oudsfoundations"},"ic_layers.png":{"alt":null,"identifier":"ic_layers.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"type":"image"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"title":"the following guidelines","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","titleInlineContent":[{"text":"the following guidelines","type":"text"}],"url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"link"}}}