 link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual","type":"text"},{"text":" ","type":"text"},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference"}],"role":"symbol","type":"topic"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"images":[{"identifier":"ic_layers.png","type":"icon"}],"role":"collection","abstract":[{"text":"Contains a set of helpers and extensions shared for higher level targets.","type":"text"}],"url":"\/documentation\/oudsfoundations","kind":"symbol","type":"topic","title":"Foundations","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations"},"https://accessibilite.numerique.gouv.fr":{"type":"link","identifier":"https:\/\/accessibilite.numerique.gouv.fr","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}],"url":"https:\/\/accessibilite.numerique.gouv.fr","title":"Référentiel Général d’Amélioration de l’Accessibilité"},"ic_layers.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"identifier":"ic_layers.png","type":"image","alt":null}}}