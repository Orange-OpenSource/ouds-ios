xt":", ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") -> ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"typeIdentifier","preciseIdentifier":"s:15OUDSFoundations15OUDSWCAG21RatioV"},{"text":"?","kind":"text"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/contrastRatios(_:_:)","kind":"symbol","abstract":[{"text":"Computes accessibility contrast ratio between two colors in hexadecimal strings.","type":"text"},{"text":" ","type":"text"},{"text":"If the hexadecimal strings are colors format in RGBA, will use their format in RGB (i.e. apply opacity, not truncate).","type":"text"}]},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"type":"link","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","titleInlineContent":[{"type":"text","text":"the following guidelines"}],"url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"title":"OUDSWCAG21Ratio","kind":"symbol","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","type":"topic","abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"https://accessibilite.numerique.gouv.fr":{"title":"Référentiel Général d’Amélioration de l’Accessibilité","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}],"type":"link","identifier":"https:\/\/accessibilite.numerique.gouv.fr","url":"https:\/\/accessibilite.numerique.gouv.fr"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","role":"collection","title":"Foundations","abstract":[{"text":"Contains a set of helpers and extensions shared for higher level targets.","type":"text"}],"type":"topic","url":"\/documentation\/oudsfoundations","images":[{"type":"icon","identifier":"ic_layers.png"}]}}}