text":"This is for example the case for France with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"also named “RGAA”.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","title":"OUDSWCAG21Ratio"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/contrastRatios(_:_:)":{"abstract":[{"text":"Computes accessibility contrast ratio between two colors in hexadecimal strings.","type":"text"},{"text":" ","type":"text"},{"text":"If the hexadecimal strings are colors format in RGBA, will use their format in RGB (i.e. apply opacity, not truncate).","type":"text"}],"role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fu