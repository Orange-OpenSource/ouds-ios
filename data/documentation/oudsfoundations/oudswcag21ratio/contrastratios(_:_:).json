ext":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"contrastRatios"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OUDSFoundations15OUDSWCAG21RatioV","text":"OUDSWCAG21Ratio"},{"kind":"text","text":"?"}],"abstract":[{"type":"text","text":"Computes accessibility contrast ratio between two colors in hexadecimal strings."},{"type":"text","text":" "},{"type":"text","text":"If the hexadecimal strings are colors format in RGBA, will use their format in RGB (i.e. apply opacity, not truncate)."}],"type":"topic","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/contrastratios(_:_:)","role":"symbol","title":"contrastRatios(_:_:)"},"ic_layers.png":{"type":"image","identifier":"ic_layers.png","alt":null,"variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}]},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"link","titleInlineContent":[{"text":"the following guidelines","type":"text"}],"title":"the following guidelines","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"},"https://accessibilite.numerique.gouv.fr":{"url":"https:\/\/accessibilite.numerique.gouv.fr","identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"link","title":"Référentiel Général d’Amélioration de l’Accessibilité","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","title":"OUDSWCAG21Ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"}]}}}