ty issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"}],"kind":"symbol","title":"OUDSWCAG21Ratio","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"titleInlineContent":[{"text":"the following guidelines","type":"text"}],"type":"link","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"type":"topic","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"images":[{"type":"icon","identifier":"ic_layers.png"}],"title":"Foundations","kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","url":"\/documentation\/oudsfoundations"}}}