).","type":"text"},{"type":"text","text":" "},{"text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"text":"See for example ","type":"text"},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true,"type":"reference"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","type":"topic"},"https://accessibilite.numerique.gouv.fr":{"titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"title":"Référentiel Général d’Amélioration de l’Accessibilité","url":"https:\/\/accessibilite.numerique.gouv.fr","type":"link","identifier":"https:\/\/accessibilite.numerique.gouv.fr"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"title":"the following guidelines","type":"link","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","titleInlineContent":[{"type":"text","text":"the following guidelines"}],"url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"}}}