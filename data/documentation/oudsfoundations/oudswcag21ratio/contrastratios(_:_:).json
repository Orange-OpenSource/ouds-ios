n-value","level":2},{"type":"paragraph","inlineContent":[{"text":"The computed ratio and flags saying if it match 3:1, 4.5:1 or 7:1","type":"text"}]}],"kind":"content"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"See https:\/\/www.w3.org\/WAI\/WCAG21\/Techniques\/general\/G18.html#procedure","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsfoundations\/oudswcag21ratio\/contrastratios(_:_:)"]}],"metadata":{"symbolKind":"method","title":"contrastRatios(_:_:)","modules":[{"name":"Foundations"}],"roleHeading":"Type Method","externalID":"s:15OUDSFoundations15OUDSWCAG21RatioV14contrastRatiosyACSgSS_SStFZ","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"contrastRatios","kind":"identifier"},{"text":"(","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") -> ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"typeIdentifier","preciseIdentifier":"s:15OUDSFoundations15OUDSWCAG21RatioV"},{"text":"?","kind":"text"}]},"references":{"doc://OUDSFoundations/documentation/OUDSFoundations":{"role":"collection","kind":"symbol","url":"\/documentation\/oudsfoundations","title":"Foundations","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","images":[{"type":"icon","identifier":"ic_layers.png"}],"type":"topic"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibil