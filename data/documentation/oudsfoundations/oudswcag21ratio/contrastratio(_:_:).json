 "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"isActive":true,"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"}],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"title":"OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"kind":"symbol","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","url":"\/documentation\/oudsfoundations","title":"Foundations","images":[{"type":"icon","identifier":"ic_layers.png"}],"role":"collection"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/contrastRatio(_:_:)":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/contrastRatio(_:_:)","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/contrastratio(_:_:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"contrastRatio","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Color","preciseIdentifier":"s:7SwiftUI5ColorV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Color","preciseIdentifier":"s:7SwiftUI5ColorV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Double","preciseId