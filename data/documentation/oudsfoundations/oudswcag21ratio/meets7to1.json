{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"meets7to1"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","metadata":{"title":"meets7to1","modules":[{"name":"Foundations"}],"externalID":"s:15OUDSFoundations15OUDSWCAG21RatioV9meets7to1Sbvp","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"meets7to1"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"symbolKind":"property","roleHeading":"Instance Property"},"sections":[],"abstract":[{"text":"If the computed contrast ratio between two given colors meets the 7:1 requirement","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsfoundations\/oudswcag21ratio\/meets7to1"]}],"identifier":{"url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/meets7to1","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio"]]},"references":{"doc://OUDSFoundations/documentation/OUDSFoundations":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"images":[{"identifier":"ic_layers.png","type":"icon"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","title":"Foundations","role":"collection","url":"\/documentation\/oudsfoundations"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","type":"topic","title":"OUDSWCAG21Ratio","role":"symbol","abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","kind":"symbol","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"https://accessibilite.numerique.gouv.fr":{"titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"link","title":"Référentiel Général d’Amélioration de l’Accessibilité","url":"https:\/\/accessibilite.numerique.gouv.fr"},"doc://OUDSFoundations/documen