ations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/meets7to1","type":"topic","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"meets7to1","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/meets7to1","title":"meets7to1","abstract":[{"type":"text","text":"If the computed contrast ratio between two given colors meets the 7:1 requirement"}]},"ic_layers.png":{"identifier":"ic_layers.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"type":"image","alt":null},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"titleInlineContent":[{"type":"text","text":"the following guidelines"}],"title":"the following guidelines","type":"link","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"},"https://accessibilite.numerique.gouv.fr":{"titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"title":"Référentiel Général d’Amélioration de l’Accessibilité","type":"link","identifier":"https:\/\/accessibilite.numerique.gouv.fr","url":"https:\/\/accessibilite.numerique.gouv.fr"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","title":"OUDSWCAG21Ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"}]}}}