{"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/oudsfoundations\/oudswcag21ratio\/meets7to1"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio"]]},"identifier":{"url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/meets7to1","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"Foundations"}],"role":"symbol","roleHeading":"Instance Property","externalID":"s:15OUDSFoundations15OUDSWCAG21RatioV9meets7to1Sbvp","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"meets7to1","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"symbolKind":"property","title":"meets7to1"},"kind":"symbol","abstract":[{"text":"If the computed contrast ratio between two given colors meets the 7:1 requirement","type":"text"}],"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"meets7to1"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}],"kind":"declarations"}],"references":{"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference","isActive":true}],"title":"OUDSWCAG21Ratio","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"type":"topic"},"https://accessibilite.numerique.gouv.fr":{"url":"https:\/\/accessibilite.numerique.gouv.fr","type":"link","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"title":"Référentiel Général d’Amélioration de l’Accessibilité","identifier":"https:\/\/accessibilite.numerique.gouv.fr"},"ic_layers.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"identifier":"ic_layers.png"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/meets7to1":{"url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/meets7to1","type":"topic","abstract":[{"text":"If the computed contrast ratio between two given colors meets the 7:1 requirement","type":"te