s.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true,"type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"also named “RGAA”.","type":"text"},{"text":" ","type":"text"},{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual","type":"text"},{"text":" ","type":"text"},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","role":"symbol"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"kind":"symbol","images":[{"identifier":"ic_layers.png","type":"icon"}],"role":"collection","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","title":"Foundations","type":"topic","url":"\/documentation\/oudsfoundations"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/meets7to1":{"title":"meets7to1","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/meets7to1","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"meets7to1"},{"kind":"text","t