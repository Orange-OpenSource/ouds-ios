ol","abstract":[{"text":"If the computed contrast ratio between two given colors meets the 7:1 requirement","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"meets7to1","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/meets7to1","kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/meets7to1"},"ic_layers.png":{"identifier":"ic_layers.png","variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"type":"image","alt":null},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"titleInlineContent":[{"text":"the following guidelines","type":"text"}],"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","type":"link"},"https://accessibilite.numerique.gouv.fr":{"titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"identifier":"https:\/\/accessibilite.numerique.gouv.fr","url":"https:\/\/accessibilite.numerique.gouv.fr","title":"Référentiel Général d’Amélioration de l’Accessibilité","type":"link"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"text":" ","type":"text"},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"text":" ","type":"text"},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"title":"OUDSWCAG21Ratio","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}]}}}