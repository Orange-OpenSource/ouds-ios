":"text"},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference","isActive":true}],"title":"OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","role":"symbol","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"kind":"symbol"},"ic_layers.png":{"variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"ic_layers.png"},"https://accessibilite.numerique.gouv.fr":{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"link","title":"Référentiel Général d’Amélioration de l’Accessibilité","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"url":"https:\/\/accessibilite.numerique.gouv.fr"}}}