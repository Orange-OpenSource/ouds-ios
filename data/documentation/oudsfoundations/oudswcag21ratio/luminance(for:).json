ype":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","kind":"symbol","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"images":[{"identifier":"ic_layers.png","type":"icon"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","title":"Foundations","role":"collection","url":"\/documentation\/oudsfoundations"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/luminance(for:)":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/luminance(for:)","role":"symbol","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/luminance(for:)","title":"luminance(for:)","kind":"symbol","abstract":[{"text":"Returns the luminance of the given color using the WCAG 2.1 algorithm.","type":"text"},{"text":" ","type":"text"},{"text":"See https:\/\/www.w