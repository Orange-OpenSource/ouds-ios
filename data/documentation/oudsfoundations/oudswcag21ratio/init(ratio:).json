e of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference","isActive":true}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"role":"symbol","title":"OUDSWCAG21Ratio","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}]},"ic_layers.png":{"type":"image","identifier":"ic_layers.png","variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"alt":null},"https://accessibilite.numerique.gouv.fr":{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","title":"Référentiel Général d’Amélioration de l’Accessibilité","url":"https:\/\/accessibilite.numerique.gouv.fr","type":"link","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}]}}}