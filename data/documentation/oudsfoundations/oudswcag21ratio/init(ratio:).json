{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio"]]},"metadata":{"symbolKind":"init","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"ratio"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"},{"kind":"text","text":")"}],"modules":[{"name":"Foundations"}],"role":"symbol","roleHeading":"Initializer","title":"init(ratio:)","externalID":"s:15OUDSFoundations15OUDSWCAG21RatioV5ratioACSd_tcfc"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/init(ratio:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"ratio"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":")"}]}]},{"parameters":[{"name":"ratio","content":[{"type":"paragraph","inlineContent":[{"text":"The contrast ratio to use","type":"text"}]}]}],"kind":"parameters"}],"variants":[{"paths":["\/documentation\/oudsfoundations\/oudswcag21ratio\/init(ratio:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Defines a WCAG 2.1 ratio with the given contrast ratio value","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"references":{"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","title":"OUDSWCAG21Ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/init(ratio:)":{"abstract":[{"text":"Defines a WCAG 2.1 ratio with the given contrast ratio value","type":"text"}],"title":"init(ratio:)","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/init(ratio:)","kind":"symbol","type":"topic","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"ratio","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":")","kind":"text"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/init(ratio:)","role":"symbol"},"ic_layers.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"alt":null,"identifier":"ic_layers.png","type":"image"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"link","title":"the following guidelines","titleInlineContent":[{"text":"the following guidelines","type":"text"}]},"https://accessibilite.numerique.gouv.fr":{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}],"type":"link","url":"https:\/\/accessibilite.numerique.gouv.fr","title":"Référentiel Général d’Amélioration de l’Accessibilité"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"title":"Foundations","type":"topic","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"images":[{"type":"icon","identifier":"ic_layers.png"}],"url":"\/documentation\/oudsfoundations","role":"collection","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","kind":"symbol"}}}