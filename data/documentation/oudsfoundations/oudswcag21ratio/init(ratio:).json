ype":"text"},{"type":"text","text":" "},{"text":"See for example ","type":"text"},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true,"type":"reference"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio"},"ic_layers.png":{"identifier":"ic_layers.png","variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"type":"image","alt":null},"https://accessibilite.numerique.gouv.fr":{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"type":"link","title":"Référentiel Général d’Amélioration de l’Accessibilité","url":"https:\/\/accessibilite.numerique.gouv.fr"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"role":"collection","images":[{"type":"icon","identifier":"ic_layers.png"}],"title":"Foundations","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","url":"\/documentation\/oudsfoundations"}}}