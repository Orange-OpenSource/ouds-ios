s higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"type":"topic"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"role":"collection","kind":"symbol","url":"\/documentation\/oudsfoundations","title":"Foundations","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","images":[{"type":"icon","identifier":"ic_layers.png"}],"type":"topic"}}}