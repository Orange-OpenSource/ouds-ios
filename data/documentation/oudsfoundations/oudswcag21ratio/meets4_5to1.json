{"identifier":{"url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/meets4_5to1","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio"]]},"metadata":{"externalID":"s:15OUDSFoundations15OUDSWCAG21RatioV11meets4_5to1Sbvp","role":"symbol","modules":[{"name":"Foundations"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"meets4_5to1"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"title":"meets4_5to1","roleHeading":"Instance Property","symbolKind":"property"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"meets4_5to1"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","variants":[{"paths":["\/documentation\/oudsfoundations\/oudswcag21ratio\/meets4_5to1"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"If the computed contrast ratio between two given colors meets the 4.5:1 requirement"}],"references":{"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/meets4_5to1":{"role":"symbol","abstract":[{"type":"text","text":"If the computed contrast ratio between two given colors meets the 4.5:1 requirement"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/meets4_5to1","title":"meets4_5to1","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"meets4_5to1","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/meets4_5to1"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","type":"topic","title":"OUDSWCAG21Ratio","role":"symbol","abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","kind":"symbol","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"ic_layers.png":{"identifier":"ic_layers.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"alt":null,"type":"image"},"https://accessibilite.numerique.gouv.fr":{"type":"link","identifier":"https:\/\/accessibilite.numerique.gouv.fr","title":"Référentiel Général d’Amélioration de l’Accessibilité","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}],"url":"https:\/\/accessibilite.numerique.gouv.fr"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"type":"link","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","titleInlineContent":[{"type":"text","text":"the following guidelines"}],"url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"images":[{"identifier":"ic_layers.png","type":"icon"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","title":"Foundations","role":"collection","url":"\/documentation\/oudsfoundations"}}}