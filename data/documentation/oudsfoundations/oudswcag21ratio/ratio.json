r","text":"Double"}],"abstract":[{"type":"text","text":"The computed contrast ratio between two given colors"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/ratio","type":"topic","kind":"symbol"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"abstract":[{"text":"Contains a set of helpers and extensions shared for higher level targets.","type":"text"}],"kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","url":"\/documentation\/oudsfoundations","images":[{"identifier":"ic_layers.png","type":"icon"}],"type":"topic","title":"Foundations"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"titleInlineContent":[{"type":"text","text":"the following guidelines"}],"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"link","title":"the following guidelines"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","abstract":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"also named “RGAA”."},{"text":" ","type":"text"},{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual","type":"text"},{"text":" ","type":"text"},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference","isActive":true}],"title":"OUDSWCAG21Ratio","kind":"symbol","role":"symbol","url":"\/documentation\/oudsfoundations\/oudswcag21ratio"},"ic_layers.png":{"identifier":"ic_layers.png","variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"type":"image","alt":null}}}