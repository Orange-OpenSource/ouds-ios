mbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","title":"OUDSWCAG21Ratio","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/ratio":{"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/ratio","title":"ratio","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"ratio"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"type":"topic","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/ratio","abstract":[{"text":"The computed contrast ratio between two given colors","type":"text"}],"kind":"symbol"}}}