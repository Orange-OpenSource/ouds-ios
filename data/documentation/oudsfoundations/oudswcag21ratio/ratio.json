ndations\/oudswcag21ratio\/ratio","title":"ratio","type":"topic","abstract":[{"type":"text","text":"The computed contrast ratio between two given colors"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/ratio","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ratio","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}]},"https://accessibilite.numerique.gouv.fr":{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","title":"Référentiel Général d’Amélioration de l’Accessibilité","type":"link","url":"https:\/\/accessibilite.numerique.gouv.fr","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}]},"doc://OUDSFoundations/documentation/OUDSFoundations":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","abstract":[{"text":"Contains a set of helpers and extensions shared for higher level targets.","type":"text"}],"title":"Foundations","role":"collection","images":[{"identifier":"ic_layers.png","type":"icon"}],"url":"\/documentation\/oudsfoundations","kind":"symbol","type":"topic"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"abstract":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"also named “RGAA”.","type":"text"},{"text":" ","type":"text"},{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"text":" ","type":"text"},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true,"type":"reference"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"title":"OUDSWCAG21Ratio","kind":"symbol","role":"symbol"}}}