ilité","identifier":"https:\/\/accessibilite.numerique.gouv.fr"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"type":"link","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","titleInlineContent":[{"type":"text","text":"the following guidelines"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/ratio":{"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"ratio"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"}],"kind":"symbol","abstract":[{"type":"text","text":"The computed contrast ratio between two given colors"}],"title":"ratio","role":"symbol","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/ratio"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"text":" ","type":"text"},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"title":"OUDSWCAG21Ratio","role":"symbol","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio"},"ic_layers.png":{"type":"image","identifier":"ic_layers.png","alt":null,"variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}]}}}