med “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference","isActive":true}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"role":"symbol","title":"OUDSWCAG21Ratio","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}]},"ic_layers.png":{"type":"image","identifier":"ic_layers.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"alt":null},"doc://OUDSFoundations/documentation/OUDSFoundations/WCAG21Requirements":{"abstract":[{"type":"text","text":"WCAG 2.1 AA and AAA requirements use ratio for textual and non textual components"}],"fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WCAG21Requirements","kind":"identifier"}],"type":"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/WCAG21Requirements","title":"WCAG21Requirements","navigatorTitle":[{"text":"WCAG21Requirements","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/wcag21requirements"},"https://accessibilite.numerique.gouv.fr":{"type":"link",