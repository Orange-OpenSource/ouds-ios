undations/documentation/OUDSFoundations/OUDSWCAG21Ratio/requirementsAAA":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/requirementsAAA","role":"symbol","type":"topic","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/requirementsaaa","kind":"symbol","abstract":[{"type":"text","text":"WCAG 2.1 requirement for AAA level needs to have textual component matching 7:1 contrast ratio"},{"type":"text","text":" "},{"type":"text","text":"and non textual component matching 4.5:1 contrast ratio."},{"type":"text","text":" "},{"type":"text","text":"This is recommended for mobiles devices projects (because of screen sizes and luminosity issues)."}],"title":"requirementsAAA","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"requirementsAAA"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"WCAG21Requirements","preciseIdentifier":"s:15OUDSFoundations18WCAG21Requirementsa"}]},"ic_layers.png":{"variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"type":"image","identifier":"ic_layers.png","alt":null},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","type":"topic","title":"OUDSWCAG21Ratio","role":"symbol","abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","kind":"symbol","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/WCAG21Requirements":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/WCAG21Requirements","url":"\/documentation\/oudsfoundations\/wcag21requirements","type":"topic","role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"WCAG21Requirements"}],"kind":"symbol","title":"WCAG21Requirements","abstract":[{"type":"text","text":"WCAG 2.1 AA and AAA requirements use ratio for textual and non textual components"}],"navigatorTitle":[{"text":"WCAG21Requirements","kind":"identifier"}]},"https://accessibilite.numerique.gouv.fr":{"title":"Référentiel Général d’Amélioration de l’Accessibilité","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}],"url":"https:\/\/accessibilite.numerique.gouv.fr","type":"link","identifier":"https:\/\/accessibilite.numerique.gouv.fr"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"title":"the following guidelines","identifier":"https: