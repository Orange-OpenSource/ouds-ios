g":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"type":"image","identifier":"ic_layers.png","alt":null},"https://accessibilite.numerique.gouv.fr":{"type":"link","url":"https:\/\/accessibilite.numerique.gouv.fr","title":"Référentiel Général d’Amélioration de l’Accessibilité","identifier":"https:\/\/accessibilite.numerique.gouv.fr","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/requirementsAAA":{"role":"symbol","type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/requirementsAAA","title":"requirementsAAA","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/requirementsaaa","abstract":[{"type":"text","text":"WCAG 2.1 requirement for AAA level needs to have textual component matching 7:1 contrast ratio"},{"type":"text","text":" "},{"text":"and non textual component matching 4.5:1 contrast ratio.","type":"text"},{"type":"text","text":" "},{"text":"This is recommended for mobiles devices projects (because of screen sizes and luminosity issues).","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"requirementsAAA"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OUDSFoundations18WCAG21Requirementsa","text":"WCAG21Requirements"}]},"doc://OUDSFoundations/documentation/OUDSFoundations":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","abstract":[{"text":"Contains a set of helpers and extensions shared for higher level targets.","type":"text"}],"title":"Foundations","role":"collection","images":[{"identifier":"ic_layers.png","type":"icon"}],"url":"\/documentation\/oudsfoundations","kind":"symbol","type":"topic"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"abstract":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"also named “RGAA”.","type":"text"},{"text":" ","type":"text"},{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"text":" ","type":"text"},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true,"type":"reference"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"title":"OUDSWCAG21Ratio","kind":"symbol","role":"symbol"},"doc://OUDSFoundations/documentation/OUDSFoundations/WCAG21Requirements":{"title":"WCAG21Requirements","abstract":[{"text":"WCAG 2.1 AA and AAA requirements use ratio for textual and non textual components","type":"text"}],"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"WCAG21Requirements"}],"navigatorTitle":[{"kind":"identifier","text":"WCAG21Requirements"}],"role":"symbol","url":"\/documentation\/oudsfoundations\/wcag21requirements","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/WCAG21Requirements"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"link","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","titleInlineContent":[{"text":"the following guidelines","type":"text"}]}}}