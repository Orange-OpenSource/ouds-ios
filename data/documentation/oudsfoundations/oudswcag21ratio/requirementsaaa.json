ssibilite.numerique.gouv.fr":{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"url":"https:\/\/accessibilite.numerique.gouv.fr","title":"Référentiel Général d’Amélioration de l’Accessibilité","type":"link"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","titleInlineContent":[{"type":"text","text":"the following guidelines"}],"url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","type":"link"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/requirementsAAA":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/requirementsAAA","abstract":[{"type":"text","text":"WCAG 2.1 requirement for AAA level needs to have textual component matching 7:1 contrast ratio"},{"type":"text","text":" "},{"type":"text","text":"and non textual component matching 4.5:1 contrast ratio."},{"type":"text","text":" "},{"type":"text","text":"This is recommended for mobiles devices projects (because of screen sizes and luminosity issues)."}],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"requirementsAAA"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"WCAG21Requirements","preciseIdentifier":"s:15OUDSFoundations18WCAG21Requirementsa"}],"title":"requirementsAAA","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/requirementsaaa"},"doc://OUDSFoundations/documentation/OUDSFoundations/WCAG21Requirements":{"navigatorTitle":[{"kind":"identifier","text":"WCAG21Requirements"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/WCAG21Requirements","abstract":[{"type":"text","text":"WCAG 2.1 AA and AAA requirements use ratio for textual and non textual components"}],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"WCAG21Requirements"}],"title":"WCAG21Requirements","url":"\/documentation\/oudsfoundations\/wcag21requirements"},"ic_layers.png":{"identifier":"ic_layers.png","alt":null,"variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"kind":"symbol","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"type":"topic","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","url":"\/documentation\/oudsfoundations","title":"Foundations","images":[{"type":"icon","identifier":"ic_layers.png"}],"role":"collection"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"isActive":true,"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"isActive":true,"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"}],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"title":"OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio"}}}