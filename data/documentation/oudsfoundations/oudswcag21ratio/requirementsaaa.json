ssibilite.numerique.gouv.fr":{"title":"Référentiel Général d’Amélioration de l’Accessibilité","identifier":"https:\/\/accessibilite.numerique.gouv.fr","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"url":"https:\/\/accessibilite.numerique.gouv.fr","type":"link"},"doc://OUDSFoundations/documentation/OUDSFoundations/WCAG21Requirements":{"kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WCAG21Requirements","kind":"identifier"}],"abstract":[{"type":"text","text":"WCAG 2.1 AA and AAA requirements use ratio for textual and non textual components"}],"title":"WCAG21Requirements","url":"\/documentation\/oudsfoundations\/wcag21requirements","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/WCAG21Requirements","navigatorTitle":[{"text":"WCAG21Requirements","kind":"identifier"}]},"ic_layers.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"identifier":"ic_layers.png","alt":null,"type":"image"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/requirementsAAA":{"type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"requirementsAAA","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OUDSFoundations18WCAG21Requirementsa","text":"WCAG21Requirements","kind":"typeIdentifier"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/requirementsAAA","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/requirementsaaa","abstract":[{"text":"WCAG 2.1 requirement for AAA level needs to have textual component matching 7:1 contrast ratio","type":"text"},{"text":" ","type":"text"},{"text":"and non textual component matching 4.5:1 contrast ratio.","type":"text"},{"text":" ","type":"text"},{"text":"This is recommended for mobiles devices projects (because of screen sizes and luminosity issues).","type":"text"}],"kind":"symbol","role":"symbol","title":"requirementsAAA"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"abstract":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","title":"OUDSWCAG21Ratio","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"title":"the following guidelines","identifier":"https: