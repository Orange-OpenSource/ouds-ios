tion","kind":"symbol","url":"\/documentation\/oudsfoundations","abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}]},"https://accessibilite.numerique.gouv.fr":{"titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}],"url":"https:\/\/accessibilite.numerique.gouv.fr","title":"Référentiel Général d’Amélioration de l’Accessibilité","type":"link","identifier":"https:\/\/accessibilite.numerique.gouv.fr"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"type":"link","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","titleInlineContent":[{"text":"the following guidelines","type":"text"}],"title":"the following guidelines"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"title":"OUDSWCAG21Ratio","abstract":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"also named “RGAA”.","type":"text"},{"text":" ","type":"text"},{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual","type":"text"},{"text":" ","type":"text"},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"role":"symbol","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","kind":"symbol"}}}