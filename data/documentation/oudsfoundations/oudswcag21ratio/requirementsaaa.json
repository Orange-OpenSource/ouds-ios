{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"externalID":"s:15OUDSFoundations15OUDSWCAG21RatioV15requirementsAAASb7textual_Sb10nonTextualtvp","title":"requirementsAAA","symbolKind":"property","modules":[{"name":"Foundations"}],"role":"symbol","roleHeading":"Instance Property","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"requirementsAAA"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OUDSFoundations18WCAG21Requirementsa","text":"WCAG21Requirements"}]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsfoundations\/oudswcag21ratio\/requirementsaaa"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"requirementsAAA"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/WCAG21Requirements","preciseIdentifier":"s:15OUDSFoundations18WCAG21Requirementsa","text":"WCAG21Requirements"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}]}],"hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio"]]},"abstract":[{"type":"text","text":"WCAG 2.1 requirement for AAA level needs to have textual component matching 7:1 contrast ratio"},{"type":"text","text":" "},{"type":"text","text":"and non textual component matching 4.5:1 contrast ratio."},{"type":"text","text":" "},{"type":"text","text":"This is recommended for mobiles devices projects (because of screen sizes and luminosity issues)."}],"identifier":{"url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/requirementsAAA","interfaceLanguage":"swift"},"references":{"doc://OUDSFo