://OUDSFoundations/documentation/OUDSFoundations":{"images":[{"identifier":"ic_layers.png","type":"icon"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","abstract":[{"text":"Contains a set of helpers and extensions shared for higher level targets.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","url":"\/documentation\/oudsfoundations","title":"Foundations"},"ic_layers.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"type":"image","alt":null,"identifier":"ic_layers.png"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"abstract":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true,"type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"text":"See for example ","type":"text"},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true,"type":"reference"}],"role":"symbol","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","f