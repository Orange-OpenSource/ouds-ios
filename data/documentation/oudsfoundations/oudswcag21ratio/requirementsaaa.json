undations/documentation/OUDSFoundations/WCAG21Requirements":{"title":"WCAG21Requirements","kind":"symbol","url":"\/documentation\/oudsfoundations\/wcag21requirements","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WCAG21Requirements","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/WCAG21Requirements","type":"topic","abstract":[{"type":"text","text":"WCAG 2.1 AA and AAA requirements use ratio for textual and non textual components"}],"navigatorTitle":[{"text":"WCAG21Requirements","kind":"identifier"}]},"ic_layers.png":{"identifier":"ic_layers.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSFoundations\/ic_layers.png"}],"alt":null},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"title":"OUDSWCAG21Ratio","kind":"symbol","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","type":"topic","abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/requirementsAAA":{"title":"requirementsAAA","kind":"symbol","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/requirementsaaa","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"requirementsAAA","kind":"identifier"},{"text":": ","kind":"text"},{"text":"WCAG21Requirements","preciseIdentifier":"s:15OUDSFoundations18WCAG21Requirementsa","kind":"typeIdentifier"}],"role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/requirementsAAA","type":"topic","abstract":[{"type":"text","text":"WCAG 2.1 requirement for AAA level needs to have textual component matching 7:1 contrast ratio"},{"type":"text","text":" "},{"type":"text","text":"and non textual component matching 4.5:1 contrast ratio."},{"type":"text","text":" "},{"type":"text","text":"This is recommended for mobiles devices projects (because of screen sizes and luminosity issues)."}]},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"link","title":"the following guidelines","titleInlineContent":[{"type":"text","text":"the following guidelines"}],"url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"kind":"symbol","iden