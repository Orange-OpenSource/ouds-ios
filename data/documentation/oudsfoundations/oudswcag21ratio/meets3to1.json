/2531b9-accessibility-compliance":{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","titleInlineContent":[{"type":"text","text":"the following guidelines"}],"type":"link","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"abstract":[{"type":"text","text":"Contains a set of helpers and extensions shared for higher level targets."}],"kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","url":"\/documentation\/oudsfoundations","images":[{"type":"icon","identifier":"ic_layers.png"}],"type":"topic","title":"Foundations"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/meets3to1":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/meets3to1","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"meets3to1","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"kind":"symbol","role":"symbol","title":"meets3to1","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/meets3to1","abstract":[{"text":"If the computed contrast ratio between two given colors meets the 3:1 requirement","type":"text"}],"type":"topic"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"text":" ","type":"text"},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"text":" ","type":"text"},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"title":"OUDSWCAG21Ratio","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}]}}}