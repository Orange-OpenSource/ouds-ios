xt":" ","type":"text"},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"text":" ","type":"text"},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference","isActive":true}],"title":"OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","role":"symbol","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"kind":"symbol"},"ic_layers.png":{"alt":null,"type":"image","variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"identifier":"ic_layers.png"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/meets3to1":{"type":"topic","abstract":[{"type":"text","text":"If the computed contrast ratio between two given colors meets the 3:1 requirement"}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/meets3to1","title":"meets3to1","role":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/meets3to1","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"meets3to1"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"