ty helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"}]},"ic_layers.png":{"variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"ic_layers.png"},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"link","titleInlineContent":[{"type":"text","text":"the following guidelines"}],"title":"the following guidelines"},"https://accessibilite.numerique.gouv.fr":{"type":"link","identifier":"https:\/\/accessibilite.numerique.gouv.fr","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"title":"Référentiel Général d’Amélioration de l’Accessibilité","url":"https:\/\/accessibilite.numerique.gouv.fr"}}}