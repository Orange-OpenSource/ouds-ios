ual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"type":"reference","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","isActive":true}],"navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}]},"doc://OUDSFoundations/documentation/OUDSFoundations":{"kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","role":"collection","title":"Foundations","abstract":[{"text":"Contains a set of helpers and extensions shared for higher level targets.","type":"text"}],"type":"topic","url":"\/documentation\/oudsfoundations","images":[{"type":"icon","identifier":"ic_layers.png"}]},"https://accessibilite.numerique.gouv.fr":{"titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"type":"link","title":"Référentiel Général d’Amélioration de l’Accessibilité","url":"https:\/\/accessibilite.numerique.gouv.fr","identifier":"https:\/\/accessibilite.numerique.gouv.fr"}}}