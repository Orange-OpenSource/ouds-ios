symbol","role":"symbol","type":"topic","title":"requirementsAA","abstract":[{"text":"WCAG 2.1 requirement for AA level needs to have textual component matching 4.5:1 contrast ratio","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and non textual component matching 3:1 contrast ratio."},{"type":"text","text":" "},{"type":"text","text":"This is recommended for web projects."}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"requirementsAA","kind":"identifier"},{"text":": ","kind":"text"},{"text":"WCAG21Requirements","kind":"typeIdentifier","preciseIdentifier":"s:15OUDSFoundations18WCAG21Requirementsa"}],"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/requirementsAA"},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"navigatorTitle":[{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"title":"OUDSWCAG21Ratio","url":"\/documentation\/oudsfoundations\/oudswcag21ratio","kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}],"abstract":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"also named “RGAA”.","type":"text"},{"text":" ","type":"text"},{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual","type":"text"},{"text":" ","type":"text"},{"text":"and 4.5:1 for non-textual elements.","type":"text"},{"text":" ","type":"text"},{"text":"This utility helps to define wether a set of contrast ratio matches AA and AAA or not.","type":"text"},{"text":" ","type":"text"},{"text":"See for example ","type":"text"},{"isActive":true,"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference"}],"role":"symbol","type":"topic"}}}