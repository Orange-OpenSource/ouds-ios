ntiel Général d’Amélioration de l’Accessibilité","type":"text"}],"identifier":"https:\/\/accessibilite.numerique.gouv.fr","url":"https:\/\/accessibilite.numerique.gouv.fr","type":"link","title":"Référentiel Général d’Amélioration de l’Accessibilité"},"ic_layers.png":{"alt":null,"identifier":"ic_layers.png","type":"image","variants":[{"url":"\/images\/OUDSFoundations\/ic_layers.png","traits":["1x","light"]}]},"https://system.design.orange.com/0c1af118d/p/2531b9-accessibility-compliance":{"titleInlineContent":[{"text":"the following guidelines","type":"text"}],"url":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","title":"the following guidelines","type":"link","identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance"},"doc://OUDSFoundations/documentation/OUDSFoundations":{"type":"topic","role":"collection","abstract":[{"text":"Contains a set of helpers and extensions shared for higher level targets.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","url":"\/documentation\/oudsfoundations","title":"Foundations","images":[{"identifier":"ic_layers.png","type":"icon"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio":{"identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio","kind":"symbol","abstract":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"text":"This is for example the case for France with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr","type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"also named “RGAA”."},{"type":"text","text":" "},{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is higly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for textual"},{"type":"text","text":" "},{"type":"text","text":"and 4.5:1 for non-textual elements."},{"type":"text","text":" "},{"type":"text","text":"This utility helps to define whether a set of contrast ratio matches AA and AAA or not."},{"type":"text","text":" "},{"type":"text","text":"See for example "},{"identifier":"https:\/\/system.design.orange.com\/0c1af118d\/p\/2531b9-accessibility-compliance","type":"reference","isActive":true}],"url":"\/documentation\/oudsfoundations\/oudswcag21ratio","navigatorTitle":[{"text":"OUDSWCAG21Ratio","kind":"identifier"}],"role":"symbol","title":"OUDSWCAG21Ratio","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSWCAG21Ratio"}]},"doc://OUDSFoundations/documentation/OUDSFoundations/OUDSWCAG21Ratio/requirementsAA":{"type":"topic","role":"symbol","abstract":[{"text":"WCAG 2.1 requirement for AA level needs to have textual component matching 4.5:1 contrast ratio","type":"text"},{"text":" ","type":"text"},{"text":"and non textual component matching 3:1 contrast ratio.","type":"text"},{"text":" ","type":"text"},{"text":"This is recommended for web projects.","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"requirementsAA","kind":"identifier"},{"text":": ","kind":"text"},{"text":"WCAG21Requirements","preciseIdentifier":"s:15OUDSFoundations18WCAG21Requirementsa","kind":"typeIdentifier"}],"kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/OUDSWCAG21Ratio\/requirementsAA","url":"\/documentation\/oudsfoundations\/oudswcag21ratio\/requirementsaa","title":"requirementsAA"},"doc://OUDSFoundations/documentation/OUDSFoundations/WCAG21Requirements":{"abstract":[{"ty