ict[PSFNMK(\"Luciole\", Font.Weight.bold)] \/\/ Luciole"]}]}],"variants":[{"paths":["\/documentation\/oudsfoundations\/swift\/dictionary\/subscript(orkey:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary"]]},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary\/subscript(orKey:)","interfaceLanguage":"swift"},"metadata":{"fragments":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"orKey","kind":"externalParam"},{"text":" _: ","kind":"text"},{"text":"Key","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"}],"role":"symbol","roleHeading":"Instance Subscript","extendedModule":"Swift","modules":[{"relatedModules":["Swift"],"name":"Foundations"}],"externalID":"s:SD15OUDSFoundationsAA25PostScriptFontNamesMapKeyVRszSSRs_rlE02orG0SSAC_tcip","title":"subscript(orKey:)","symbolKind":"subscript","conformance":{"conformancePrefix":[{"text":"Conforms when","type":"text"}],"constraints":[{"code":"Key","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"PostScriptFontNamesMapKey","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Value","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"String","type":"codeVoice"},{"text":".","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}]}},"abstract":[{"type":"text","text":"If there is no value for the given "},{"type":"codeVoice","code":"key"},{"type":"text","text":", returns the description of this key,"},{"type":"text","text":" "},{"type":"text","text":"i.e.font family name without the font weight in the end and without whitespaces."}],"references":{"doc://OU