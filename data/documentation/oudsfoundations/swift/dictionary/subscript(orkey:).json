{"abstract":[{"type":"text","text":"If there is no value for the given "},{"type":"codeVoice","code":"key"},{"type":"text","text":", returns the description of this key,"},{"type":"text","text":" "},{"type":"text","text":"i.e.font family name without the font weight in the end and without whitespaces."}],"hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary"]]},"metadata":{"symbolKind":"subscript","fragments":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"orKey","kind":"externalParam"},{"text":" _: ","kind":"text"},{"text":"Key","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"modules":[{"relatedModules":["Swift"],"name":"Foundations"}],"conformance":{"availabilityPrefix":[{"text":"Available when","type":"text"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"type":"codeVoice","code":"Key"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"PostScriptFontNamesMapKey"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Value"},{"type":"text","text":" is "},{"type":"codeVoice","code":"String"},{"type":"text","text":"."}]},"externalID":"s:SD15OUDSFoundationsAA25PostScriptFontNamesMapKeyVRszSSRs_rlE02orG0SSAC_tcip","role":"symbol","title":"subscript(orKey:)","extendedModule":"Swift","roleHeading":"Instance Subscript"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"("},{"kind":"externalParam","text":"orKey"},{"kind":"text","text":" "},{"kind":"internalParam","text":"key"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Key"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The key to use to get a value"}],"type":"paragraph"}],"name":"key"}]},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact if it seems some rules are missing, or weight are not managed, if the font family only is returned"},{"type":"text","text":" "},{"type":"text","text":"the user has an higher probability to use the expected font. Because if a mashup of family name and weight is returned"},{"type":"text","text":" "},{"type":"text","text":"it can produce a PostScript identifier not available, so not usable, so implying a fallback to default system font like "},{"type":"emphasis","inlineContent":[{"type":"text","text":"San Francisco"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because PostScript identifiers in most of cases do not have whitespaces, remove them."}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Given a dictionary with one value","    let myDict: PostScriptFontNamesMap = [PSFNMK(\"Arial\", Font.Weight.bold): \"Aria-BoldMT\"]","","    \/\/ The given value is returned if the key exists","    let keyExists = myDict[PSFNMK(\"Arial\", Font.Weight.bold)] \/\/ Arial-BoldMT","","    \/\/ But if the key does not exist, the only the key is returned","    let keyDoesNotExist = myDict[PSFNMK(\"Luciole\", Font.Weight.bold)] \/\/ Luciole"]}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/oudsfoundations\/swift\/dictionary\/subscript(orkey:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary\/subscript(orKey:)"},"sections":[],"references":{"doc://OU