{"abstract":[{"text":"If there is no value for the given ","type":"text"},{"code":"key","type":"codeVoice"},{"text":", returns the description of this key,","type":"text"},{"text":" ","type":"text"},{"text":"i.e.font family name without the font weight in the end and without whitespaces.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"extendedModule":"Swift","modules":[{"relatedModules":["Swift"],"name":"Foundations"}],"conformance":{"availabilityPrefix":[{"type":"text","text":"Available when"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"type":"codeVoice","code":"Key"},{"type":"text","text":" is "},{"type":"codeVoice","code":"PostScriptFontNamesMapKey"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Value"},{"type":"text","text":" is "},{"type":"codeVoice","code":"String"},{"type":"text","text":"."}]},"role":"symbol","symbolKind":"subscript","fragments":[{"kind":"keyword","text":"subscript"},{"kind":"text","text":"("},{"kind":"externalParam","text":"orKey"},{"kind":"text","text":" _: "},{"kind":"typeIdentifier","text":"Key"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}],"title":"subscript(orKey:)","roleHeading":"Instance Subscript","externalID":"s:SD15OUDSFoundationsAA25PostScriptFontNamesMapKeyVRszSSRs_rlE02orG0SSAC_tcip"},"hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary\/subscript(orKey:)"},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"orKey","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"key","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Key","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"name":"key","content":[{"inlineContent":[{"type":"text","text":"The key to use to get a value"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact if it seems some rules are missing, or weight are not managed, if the font family only is returned"},{"type":"text","text":" "},{"type":"text","text":"the user has an higher probability to use the expected font. Because if a mashup of family name and weight is returned"},{"type":"text","text":" "},{"type":"text","text":"it can produce a PostScript identifier not available, so not usable, so implying a fallback to default system font like "},{"inlineContent":[{"type":"text","text":"San Francisco"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because PostScript identifiers in most of cases do not have whitespaces, remove them."}]},{"code":["    \/\/ Given a dictionary with one value","    let myDict: PostScriptFontNamesMap = [PSFNMK(\"Arial\", Font.Weight.bold): \"Aria-BoldMT\"]","","    \/\/ The given value is returned if the key exists","    let keyExists = myDict[PSFNMK(\"Arial\", Font.Weight.bold)] \/\/ Arial-BoldMT","","    \/\/ But if the key does not exist, the only the key is returned","    let keyDoesNotExist = myDict[PSFNMK(\"Luciole\", Font.Weight.bold)] \/\/ Luciole"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsfoundations\/swift\/dictionary\/subscript(orkey:)"]}],"references":{"ic_layer