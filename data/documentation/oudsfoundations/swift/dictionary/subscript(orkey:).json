{"metadata":{"extendedModule":"Swift","title":"subscript(orKey:)","externalID":"s:SD15OUDSFoundationsAA25PostScriptFontNamesMapKeyVRszSSRs_rlE02orG0SSAC_tcip","roleHeading":"Instance Subscript","modules":[{"name":"Foundations","relatedModules":["Swift"]}],"symbolKind":"subscript","role":"symbol","conformance":{"constraints":[{"code":"Key","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"PostScriptFontNamesMapKey"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Value"},{"type":"text","text":" is "},{"type":"codeVoice","code":"String"},{"type":"text","text":"."}],"availabilityPrefix":[{"type":"text","text":"Available when"}],"conformancePrefix":[{"type":"text","text":"Conforms when"}]},"fragments":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"orKey","kind":"externalParam"},{"text":" _: ","kind":"text"},{"text":"Key","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"subscript"},{"text":"(","kind":"text"},{"text":"orKey","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"key","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Key","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The key to use to get a value"}]}],"name":"key"}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact if it seems some rules are missing, or weight are not managed, if the font family only is returned"},{"type":"text","text":" "},{"type":"text","text":"the user has an higher probability to use the expected font. Because if a mashup of family name and weight is returned"},{"text":" ","type":"text"},{"type":"text","text":"it can produce a PostScript identifier not available, so not usable, so implying a fallback to default system font like "},{"inlineContent":[{"type":"text","text":"San Francisco"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because PostScript identifiers in most of cases do not have whitespaces, remove them."}]},{"type":"codeListing","code":["    \/\/ Given a dictionary with one value","    let myDict: PostScriptFontNamesMap = [PSFNMK(\"Arial\", Font.Weight.bold): \"Aria-BoldMT\"]","","    \/\/ The given value is returned if the key exists","    let keyExists = myDict[PSFNMK(\"Arial\", Font.Weight.bold)] \/\/ Arial-BoldMT","","    \/\/ But if the key does not exist, the only the key is returned","    let keyDoesNotExist = myDict[PSFNMK(\"Luciole\", Font.Weight.bold)] \/\/ Luciole"],"syntax":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"If there is no value for the given ","type":"text"},{"code":"key","type":"codeVoice"},{"text":", returns the description of this key,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"i.e.font family name without the font weight in the end and without whitespaces."}],"variants":[{"paths":["\/documentation\/oudsfoundations\/swift\/dictionary\/subscript(orkey:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary\/subscript(orKey:)","interfaceLanguage":"swift"},"references":{"doc://OU