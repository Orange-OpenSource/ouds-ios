{"sections":[],"metadata":{"externalID":"s:SD15OUDSFoundationsAA25PostScriptFontNamesMapKeyVRszSSRs_rlE02orG0SSAC_tcip","extendedModule":"Swift","title":"subscript(orKey:)","conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"availabilityPrefix":[{"text":"Available when","type":"text"}],"constraints":[{"type":"codeVoice","code":"Key"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"PostScriptFontNamesMapKey"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Value"},{"type":"text","text":" is "},{"type":"codeVoice","code":"String"},{"type":"text","text":"."}]},"modules":[{"name":"Foundations","relatedModules":["Swift"]}],"symbolKind":"subscript","role":"symbol","roleHeading":"Instance Subscript","fragments":[{"text":"subscript","kind":"keyword"},{"kind":"text","text":"("},{"text":"orKey","kind":"externalParam"},{"text":" _: ","kind":"text"},{"text":"Key","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsfoundations\/swift\/dictionary\/subscript(orkey:)"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"subscript","kind":"keyword"},{"text":"(","kind":"text"},{"text":"orKey","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"key","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Key","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"key","content":[{"type":"paragraph","inlineContent":[{"text":"The key to use to get a value","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact if it seems some rules are missing, or weight are not managed, if the font family only is returned"},{"type":"text","text":" "},{"type":"text","text":"the user has an higher probability to use the expected font. Because if a mashup of family name and weight is returned"},{"type":"text","text":" "},{"type":"text","text":"it can produce a PostScript identifier not available, so not usable, so implying a fallback to default system font like "},{"type":"emphasis","inlineContent":[{"type":"text","text":"San Francisco"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Because PostScript identifiers in most of cases do not have whitespaces, remove them."}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Given a dictionary with one value","    let myDict: PostScriptFontNamesMap = [PSFNMK(\"Arial\", Font.Weight.bold): \"Aria-BoldMT\"]","","    \/\/ The given value is returned if the key exists","    let keyExists = myDict[PSFNMK(\"Arial\", Font.Weight.bold)] \/\/ Arial-BoldMT","","    \/\/ But if the key does not exist, the only the key is returned","    let keyDoesNotExist = myDict[PSFNMK(\"Luciole\", Font.Weight.bold)] \/\/ Luciole"]}]}],"hierarchy":{"paths":[["doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary"]]},"abstract":[{"text":"If there is no value for the given ","type":"text"},{"type":"codeVoice","code":"key"},{"type":"text","text":", returns the description of this key,"},{"text":" ","type":"text"},{"text":"i.e.font family name without the font weight in the end and without whitespaces.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations\/Swift\/Dictionary\/subscript(orKey:)"},"references":{"doc://OU