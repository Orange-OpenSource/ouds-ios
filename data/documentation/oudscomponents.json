{"kind":"symbol","topicSections":[{"generated":true,"title":"Articles","anchor":"Articles","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Inputs","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"]},{"generated":true,"title":"Structures","anchor":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurfaceModifier","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitch","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider"]},{"generated":true,"title":"Enumerations","anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndicatorState","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerPlacement"]},{"generated":true,"title":"Extended Modules","anchor":"Extended-Modules","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Foundation","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Swift","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/SwiftUI","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"]}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Components are grouped in several categories, the same as the ones defined in the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" design kit:"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Actions","type":"text"}]},{"type":"text","text":" component are for example buttons. "},{"type":"emphasis","inlineContent":[{"text":"Navigations","type":"text"}]},{"type":"text","text":" group contains links, "},{"type":"emphasis","inlineContent":[{"type":"text","text":"inputs"}]},{"type":"text","text":" group has checkboxes, radio buttons and switches, "},{"type":"emphasis","inlineContent":[{"text":"layouts","type":"text"}]},{"type":"text","text":" groups is dedicated to things like dividers."},{"type":"text","text":" "},{"type":"text","text":"You can get more details about them in the categories below:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations","type":"reference","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Inputs"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","isActive":true}]}]}]},{"text":"Customize components","type":"heading","level":2,"anchor":"Customize-components"},{"text":"Apply a specific shadow effect (elevation tokens)","type":"heading","level":3,"anchor":"Apply-a-specific-shadow-effect-elevation-tokens"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The unified design system implemented by OUDS iOS library allows to apply "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation effets"}]},{"type":"text","text":" on a "},{"type":"codeVoice","code":"View"},{"type":"text","text":", i.e. a shadow under the component."},{"type":"text","text":" "},{"type":"text","text":"Because the design tool in use is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" which defines such shadow with a "},{"type":"emphasis","inlineContent":[{"text":"blur","type":"text"}]},{"type":"text","text":" and a "},{"type":"emphasis","inlineContent":[{"text":"spread","type":"text"}]},{"type":"text","text":" radiuses, and because "},{"type":"emphasis","inlineContent":[{"text":"SwiftUI","type":"text"}]},{"type":"text","text":" uses only its own "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radius"}]},{"type":"text","text":" definition, an extension of "},{"type":"codeVoice","code":"View"},{"type":"text","text":" has been implemented to let users apply some effect using an "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","isActive":true,"type":"reference"},{"type":"text","text":" from the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true,"type":"reference"},{"type":"text","text":" library thanks to the method "},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"type":"text","text":"."}]},{"syntax":"swift","type":"codeListing","code":["\/\/ For example, apply the elevation effect \"elevationDrag\" from your theme:","myView.oudsShadow(theme.elevations.elevationDrag)","","\/\/ And in the theme this \"elevationDrag\" has been defined for example like:","@objc open var elevationDrag: ElevationCompositeSemanticToken { ElevationCompositeSemanticToken(ElevationRawTokens.elevationBottom_3_500) }","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: elevationX0, y: elevationY300, blur: elevationBlur400, color: ColorRawTokens.colorOpacityBlack320)","","\/\/ Blur will be used to compute the radius value"]},{"text":"Apply a specific typography (font tokens)","type":"heading","level":3,"anchor":"Apply-a-specific-typography-font-tokens"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your application identity can be strongly based on the "},{"type":"emphasis","inlineContent":[{"text":"typography","type":"text"}]},{"type":"text","text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact mode"}]},{"type":"text","text":" or in "},{"type":"emphasis","inlineContent":[{"text":"regular mode","type":"text"}]},{"type":"text","text":", and is defined with a "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","type":"reference","isActive":true},{"type":"text","text":". defined in the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","type":"reference","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" contains lots of "},{"type":"codeVoice","code":"MultipleFontCompositeRawTokens"},{"type":"text","text":" listing all the combinations of typography you can apply, and these "},{"type":"emphasis","inlineContent":[{"text":"composite semantic tokens","type":"text"}]},{"type":"text","text":" use "},{"type":"emphasis","inlineContent":[{"text":"composite raw tokens","type":"text"}]},{"type":"text","text":". For example:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"However the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" must know which "},{"type":"emphasis","inlineContent":[{"text":"font family","type":"text"}]},{"type":"text","text":" to apply, and this font family can be a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"custom one"}]},{"type":"text","text":" or the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"system one"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Thus, we let the users define the font family they want by overriding the "},{"type":"codeVoice","code":"fontFamily"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"type":"codeVoice","code":"View"},{"type":"text","text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."]},{"text":"Apply a specific border (border tokens)","type":"heading","level":3,"anchor":"Apply-a-specific-border-border-tokens"},{"type":"paragraph","inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"code":"oudsBorder(style:width:radius:color)","type":"codeVoice"},{"text":" so as to apply border semantic tokens on a view in order to define a border effect.","type":"text"},{"text":" ","type":"text"},{"text":"The helper is available through ","type":"text"},{"code":"View","type":"codeVoice"},{"text":", and tokens through the provider of the theme.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"]},{"text":"Apply specific colors","type":"heading","level":3,"anchor":"Apply-specific-colors"},{"type":"paragraph","inlineContent":[{"text":"Colors can be applied on view for background and foreground colors, foreground style or also accent color.","type":"text"},{"text":" ","type":"text"},{"text":"Some helpers are available in the OUDS API to avoid to use the ","type":"text"},{"type":"codeVoice","code":"color(for:ColorScheme)"},{"text":" method.","type":"text"}]},{"code":["    \/\/ Given a color at theme.colors.colorBgPrimary","    \/\/ This token can have light and dark declinations ","","    @Environment(\\.theme) private var theme","","    \/\/ Apply a foreground style","    someView.oudsForegroundStyle(theme.colors.colorBgPrimary)","","    \/\/ Apply a foreground color","    someView.oudsForegroundColor(theme.colors.colorBgPrimary)","","    \/\/ Apply a background","    someView.oudsBackground(theme.colors.colorBgPrimary)","","    \/\/ Apply an accent color","    someView.oudsAccentColor(theme.colors.colorBgPrimary)"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents"]}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"hierarchy":{"paths":[[]]},"metadata":{"modules":[{"name":"OUDSComponents"}],"role":"collection","externalID":"OUDSComponents","roleHeading":"Framework","title":"OUDSComponents","symbolKind":"module"},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem":{"navigatorTitle":[{"kind":"identifier","text":"OUDSRadioItem"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioItem"}],"url":"\/documentation\/oudscomponents\/oudsradioitem","role":"symbol","abstract":[{"type":"t