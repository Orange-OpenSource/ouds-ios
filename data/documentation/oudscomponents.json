{"variants":[{"paths":["\/documentation\/oudscomponents"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"externalID":"OUDSComponents","roleHeading":"Framework","role":"collection","symbolKind":"module","modules":[{"name":"OUDSComponents"}],"title":"OUDSComponents"},"kind":"symbol","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","interfaceLanguage":"swift"},"hierarchy":{"paths":[[]]},"topicSections":[{"generated":true,"anchor":"Articles","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Inputs","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"],"title":"Articles"},{"generated":true,"anchor":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurfaceModifier","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitch","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider"],"title":"Structures"},{"generated":true,"anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndicatorState","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerPlacement"],"title":"Enumerations"},{"generated":true,"anchor":"Extended-Modules","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Foundation","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Swift","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/SwiftUI","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"title":"Extended Modules"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Components are grouped in several categories, the same as the ones defined in the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" design kit:"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Actions","type":"text"}]},{"type":"text","text":" component are for example buttons. "},{"type":"emphasis","inlineContent":[{"text":"Navigations","type":"text"}]},{"type":"text","text":" group contains links, "},{"type":"emphasis","inlineContent":[{"type":"text","text":"inputs"}]},{"type":"text","text":" group has checkboxes, radio buttons and switches, "},{"type":"emphasis","inlineContent":[{"text":"layouts","type":"text"}]},{"type":"text","text":" groups is dedicated to things like dividers."},{"type":"text","text":" "},{"type":"text","text":"You can get more details about them in the categories below:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions","type":"reference"}]}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Inputs"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","type":"reference","isActive":true}]}]}],"type":"unorderedList"},{"text":"Customize components","level":2,"anchor":"Customize-components","type":"heading"},{"text":"Apply a specific shadow effect (elevation tokens)","level":3,"anchor":"Apply-a-specific-shadow-effect-elevation-tokens","type":"heading"},{"inlineContent":[{"type":"text","text":"The unified design system implemented by OUDS iOS library allows to apply "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation effets"}]},{"type":"text","text":" on a "},{"type":"codeVoice","code":"View"},{"type":"text","text":", i.e. a shadow under the component."},{"type":"text","text":" "},{"type":"text","text":"Because the design tool in use is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" which defines such shadow with a "},{"type":"emphasis","inlineContent":[{"text":"blur","type":"text"}]},{"type":"text","text":" and a "},{"type":"emphasis","inlineContent":[{"text":"spread","type":"text"}]},{"type":"text","text":" radiuses, and because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"type":"text","text":" uses only its own "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radius"}]},{"type":"text","text":" definition, an extension of "},{"type":"codeVoice","code":"View"},{"type":"text","text":" has been implemented to let users apply some effect using an "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","isActive":true},{"type":"text","text":" from the "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true},{"type":"text","text":" library thanks to the method "},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ For example, apply the elevation effect \"elevationDrag\" from your theme:","myView.oudsShadow(theme.elevations.elevationDrag)","","\/\/ And in the theme this \"elevationDrag\" has been defined for example like:","@objc open var elevationDrag: ElevationCompositeSemanticToken { ElevationCompositeSemanticToken(ElevationRawTokens.elevationBottom_3_500) }","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: elevationX0, y: elevationY300, blur: elevationBlur400, color: ColorRawTokens.colorOpacityBlack320)","","\/\/ Blur will be used to compute the radius value"],"type":"codeListing"},{"text":"Apply a specific typography (font tokens)","level":3,"anchor":"Apply-a-specific-typography-font-tokens","type":"heading"},{"inlineContent":[{"type":"text","text":"Your application identity can be strongly based on the "},{"type":"emphasis","inlineContent":[{"text":"typography","type":"text"}]},{"type":"text","text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact mode"}]},{"type":"text","text":" or in "},{"type":"emphasis","inlineContent":[{"text":"regular mode","type":"text"}]},{"type":"text","text":", and is defined with a "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","isActive":true},{"type":"text","text":". defined in the "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" contains lots of "},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"type":"text","text":" listing all the combinations of typography you can apply, and these "},{"inlineContent":[{"text":"composite semantic tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" use "},{"inlineContent":[{"text":"composite raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":". For example:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"However the "},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"type":"text","text":" must know which "},{"inlineContent":[{"type":"text","text":"font family"}],"type":"emphasis"},{"type":"text","text":" to apply, and this font family can be a "},{"inlineContent":[{"text":"custom one","type":"text"}],"type":"emphasis"},{"type":"text","text":" or the "},{"inlineContent":[{"text":"system one","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Thus, we let the users define the font family they want by overriding the "},{"code":"fontFamily","type":"codeVoice"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}],"type":"paragraph"},{"inlineContent":[{"text":"Thus, if you want to apply a specific typography to a ","type":"text"},{"code":"View","type":"codeVoice"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"type":"codeListing"},{"text":"Apply a specific border (border tokens)","level":3,"anchor":"Apply-a-specific-border-border-tokens","type":"heading"},{"inlineContent":[{"type":"text","text":"This module exposes the helper "},{"type":"codeVoice","code":"oudsBorder(style:width:radius:color)"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"type":"text","text":" "},{"type":"text","text":"The helper is available through "},{"type":"codeVoice","code":"View"},{"type":"text","text":", and tokens through the provider of the theme."}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing"},{"text":"Apply specific colors","level":3,"anchor":"Apply-specific-colors","type":"heading"},{"inlineContent":[{"text":"Colors can be applied on view for background and foreground colors, foreground style or also accent color.","type":"text"},{"text":" ","type":"text"},{"text":"Some helpers are available in the OUDS API to avoid to use the ","type":"text"},{"code":"color(for:ColorScheme)","type":"codeVoice"},{"text":" method.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Given a color at theme.colors.colorBgPrimary","    \/\/ This token can have light and dark declinations ","","    @Environment(\\.theme) private var theme","","    \/\/ Apply a foreground style","    someView.oudsForegroundStyle(theme.colors.colorBgPrimary)","","    \/\/ Apply a foreground color","    someView.oudsForegroundColor(theme.colors.colorBgPrimary)","","    \/\/ Apply a background","    someView.oudsBackground(theme.colors.colorBgPrimary)","","    \/\/ Apply an accent color","    someView.oudsAccentColor(theme.colors.colorBgPrimary)"],"type":"codeListing"}]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioPickerData":{"navigatorTitle":[{"text":"OUDSRadioPickerData","kind":"identifier"}],"type":"topic","abstract":[{"text":"The data to use to populate the picker of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference"},{"text":" objects.","type":"text"},{"text":" ","type":"text"},{"text":"Each property in this ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData","type":"reference"},{"text":" is used to define the suitable ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference"},{"text":".","type":"text"}],"title":"OUDSRadioPickerData","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioPickerData","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsradiopickerdata","role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"abstract":[{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSVerticalDivider"}],"url":"\/documentation\/oudscomponents\/oudsverticaldivider","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSVerticalDivider"}],"type":"topic","title":"OUDSVerticalDivider"},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/":{"titleInlineContent":[{"text":"OUDSTokensSemantic","type":"text"}],"url":"https:\/\/ios.unified-design-system.orange.