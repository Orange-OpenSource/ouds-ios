{"topicSections":[{"identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckboxComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ControlItemComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/DividerComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ExpandLinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/IconComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/PinCodeInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/QuantityInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/RadioButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTagComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TextAreaComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TextInputComponentTokens"],"title":"Group","anchor":"Group"},{"identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonMonoComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkMonoComponentTokens"],"title":"Protocols","anchor":"Protocols","generated":true}],"kind":"symbol","hierarchy":{"paths":[[]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent"},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"syntax":null,"code":["🧬 Core version: 1.8.0"],"type":"codeListing"},{"inlineContent":[{"text":"Thus if a component need to change for example its ","type":"text"},{"inlineContent":[{"text":"background color","type":"text"}],"type":"emphasis"},{"text":", and if a ","type":"text"},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"text":" is used for it, then only the value of this ","type":"text"},{"inlineContent":[{"text":"token","type":"text"}],"type":"emphasis"},{"text":" should be changed without any modification on the ","type":"text"},{"inlineContent":[{"text":"component","type":"text"}],"type":"emphasis"},{"text":" definition.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"Components","type":"text"}],"type":"emphasis"},{"text":" use ","type":"text"},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"text":" exposed through the ","type":"text"},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"text":" thanks to token providers to get their style values.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"type":"text","text":" so as to be exposed then through implementation of "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"protocols"}]},{"type":"text","text":" and defined in "},{"type":"emphasis","inlineContent":[{"text":"extensions","type":"text"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"That is the reason why tokens are exposed as ","type":"text"},{"code":"@objc open","type":"codeVoice"},{"text":" to be available and overridable anywhere.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Example with ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"type":"codeListing"},{"text":"How to use component tokens","anchor":"How-to-use-component-tokens","level":2,"type":"heading"},{"inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"text":" have for values ","type":"text"},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"semantic tokens"}],"type":"emphasis"},{"text":", and in the end for values primitive types, and all these tokens are declared with ","type":"text"},{"inlineContent":[{"type":"text","text":"type aliases"}],"type":"emphasis"},{"text":" refering all together, you can handle a ","type":"text"},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"text":" directly in your view because the final value will be used.","type":"text"},{"text":" ","type":"text"},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"The components tokens are wrapped in tokens provider acessible through the themes:","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Components tokens provider"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Target component"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"badge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For badges like "},{"type":"codeVoice","code":"OUDSBadge"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"button"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For buttons like "},{"type":"codeVoice","code":"OUDSButton"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":