{"metadata":{"role":"collection","modules":[{"name":"Tokens for components"}],"symbolKind":"module","roleHeading":"Library","images":[{"type":"icon","identifier":"ic_design_token_figma_component.png"}],"title":"Tokens for components","externalID":"OUDSTokensComponent"},"abstract":[{"text":"These ","type":"text"},{"inlineContent":[{"text":"tokens","type":"text"}],"type":"emphasis"},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"syntax":null,"code":["🧬 Core version: 1.9.0"],"type":"codeListing"},{"inlineContent":[{"text":"Thus if a component need to change for example its ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"background color"}]},{"text":", and if a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"text":" is used for it, then only the value of this ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"token"}]},{"text":" should be changed without any modification on the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component"}]},{"text":" definition.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Components"}]},{"text":" use ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"text":" exposed through the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"text":" thanks to token providers to get their style values.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Components tokens are defined and gathered inside ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"text":" so as to be exposed then through implementation of ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" thanks to dedicated tokens providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"protocols"}]},{"text":" and defined in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"extensions"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why tokens are exposed as ","type":"text"},{"code":"@objc open","type":"codeVoice"},{"text":" to be available and overridable anywhere.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Example with ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var borderWidthDefault: BorderWidthSemanticToken { get }","    var borderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticToken { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var borderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var borderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"type":"codeListing"},{"level":2,"text":"How to use component tokens","anchor":"How-to-use-component-tokens","type":"heading"},{"inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"text":" have for values ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"semantic tokens"}]},{"text":", and in the end for values primitive types, and all these tokens are declared with ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"type aliases"}]},{"text":" refering all together, you can handle a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"text":" directly in your view because the final value will be used.","type":"text"},{"text":" ","type":"text"},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.borderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.borderRadius)","                .stroke(Color.blue, lineWidth: theme.button.borderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"borderRadius\" and \"borderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"The components tokens are wrapped in tokens provider acessible through the themes:","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"text":"Components tokens provider","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Target component"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"bar"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For bars components like bottom and navigation bars"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"badge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For badges like "},{"code":"OUDSBadge","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"button"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For buttons like "},{"type":"codeVoice","code":"OUDSButton"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"bulletList"}]}],[{"type":"paragraph","inlineContent":[{"text":"For list of elements with bullets","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"checkbox","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For checkboxes like ","type":"text"},{"code":"OUDSCheckbox","type":"codeVoice"},{"text":", ","type":"text"},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"text":" and their indeterminate variants","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"chip","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For chips like ","type":"text"},{"code":"OUDSSuggestionChip","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSFilterChip","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"controlItem","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Shared and used for switch, checkbox and radio items layouts","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"divider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For dividers like ","type":"text"},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSVerticalDivider","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"icon","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For components containing icons like ","type":"text"},{"code":"OUDSTag","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"link","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For links like ","type":"text"},{"code":"OUDSLink","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"pinCodeInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"quantityInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"radioButton","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For radio components like ","type":"text"},{"code":"OUDSRadio","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSRadioItem","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"selectInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"skeleton","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"switch","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For switch components like ","type":"text"},{"code":"OUDSSwitch","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSSwitchItem","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"tag","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For tag components like ","type":"text"},{"code":"OUDSTag","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"inputTag","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For input tag components like ","type":"text"},{"code":"OUDSInputTag","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"textArea","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For text area components like ","type":"text"},{"code":"OUDSTextArea","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"textInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For text fi