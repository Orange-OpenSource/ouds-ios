{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" are defined for components and refer to semantic tokens or raw tokens."},{"type":"text","text":" "},{"type":"text","text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent"},"sections":[],"topicSections":[{"identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckboxComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ControlItemComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/DividerComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTextComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ListItemComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/RadioButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens"],"title":"Group","anchor":"Group"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"hierarchy":{"paths":[[]]},"metadata":{"symbolKind":"module","modules":[{"name":"OUDSTokensComponent"}],"role":"collection","externalID":"OUDSTokensComponent","title":"OUDSTokensComponent","roleHeading":"Framework"},"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"codeListing","syntax":null,"code":["🧱 Tokens version: 0.11.0"]},{"type":"paragraph","inlineContent":[{"text":"Thus if a component need to change for example its ","type":"text"},{"inlineContent":[{"text":"background color","type":"text"}],"type":"emphasis"},{"text":", and if a ","type":"text"},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"text":" is used for it, then only the value of this ","type":"text"},{"inlineContent":[{"text":"token","type":"text"}],"type":"emphasis"},{"text":" should be changed without any modification on the ","type":"text"},{"inlineContent":[{"type":"text","text":"component"}],"type":"emphasis"},{"text":" definition.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Components"}],"type":"emphasis"},{"text":" use ","type":"text"},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"text":" exposed through the ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"text":" thanks to token providers to get their style values.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"type":"text","text":" so as to be exposed then through implementation of "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"protocols"}]},{"type":"text","text":" and defined in "},{"type":"emphasis","inlineContent":[{"text":"extensions","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why tokens are exposed as "},{"code":"@objc open","type":"codeVoice"},{"type":"text","text":" to be available and overridable anywhere."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var buttonSizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var buttonSpacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var buttonSizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens.dimension600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.borderWidthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.borderRadiusMedium }","    @objc open var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.colorRepositoryOpacityBlackHigher }","    @objc open var buttonSpacePaddingBlock: SpaceSemanticToken { spaces.spacePaddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"]},{"text":"How to use component tokens","type":"heading","anchor":"How-to-use-component-tokens","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact, the component tokens are declared and gathered in "},{"type":"emphasis","inlineContent":[{"text":"Swift protocol","type":"text"}]},{"type":"text","text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" have for values "},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"semantic tokens"}]},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"type":"emphasis","inlineContent":[{"type":"text","text":"type aliases"}]},{"text":" refering all together, you can handle a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"text":" directly in your view because the final value will be used.","type":"text"},{"text":" ","type":"text"},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.buttonSpacePaddingInlineArrowStart)","        .padding(.trailing, theme.button.buttonSpacePaddingInlineArrowEnd)","        .background(theme.button.buttonColorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"buttonColorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"buttonSpacePaddingInlineArrowStart\" and \"buttonSpacePaddingInlineArrowEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"]}],"kind":"content"}],"references":{"doc://OUDSTokensComponent/documentation/OUDSTokensComponent/RadioButtonComponentTokens":{"kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"RadioButtonComponentTokens"}],"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/RadioButtonComponentTokens","url":"\/documentation\/oudstokenscomponent\/radiobuttoncomponenttokens","abstract":[{"type":"text","text":"Declares all component tokens for radio button components like "},{"type":"codeVoice","code":"OUDSRadioButton"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioButtonItem"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"type":"codeVoice","code":"OrangeThemeRadioButtonComponentTokensProvider"},{"type":"text","text":"."}],"role":"symbol","title":"RadioButtonComponentTokens","navigatorTitle":[{"kind":"identifier","text":"RadioButtonComponentTokens"}],"type":"topic"},"doc://OUDSTokensComponent/documentation/OUDSTokensComponent/SkeletonComponentTokens":{"title":"SkeletonComponentTokens","identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"SkeletonComponentTokens"}],"url":"\/documentation\/oudstokenscomponent\/skeletoncomponenttokens","abstract":[{"type":"text","text":"Declares all component tokens for links components like "},{"code":"OUDSSkeleton","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"code":"OrangeThemeSkeletonComponentTokensProvider","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","navigatorTitle":[{"text":"SkeletonComponentTokens","kind":"identifier"}]},"doc://OUDSTokensComponent/documentation/OUDSTokensComponent/SwitchComponentTokens":{"navigatorTitle":[{"kind":"identifier","text":"SwitchComponentTokens"}],"url":"\/documentation\/oudstokenscomponent\/switchcomponenttokens","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"SwitchComponentTokens"}],"abstract":[{"type":"text","text":"Declares all component tokens for switch components like "},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"type":"codeVoice","code":"OrangeThemeSwitchComponentTokensProvider"},{"type":"text","text":"."}],"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchCom