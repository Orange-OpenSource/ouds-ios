{"kind":"symbol","abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"topicSections":[{"title":"Group","identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BarComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckboxComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ControlItemComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/DividerComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ExpandLinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/IconComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/PinCodeInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/QuantityInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/RadioButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTagComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TextAreaComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TextInputComponentTokens"],"anchor":"Group"},{"generated":true,"title":"Protocols","identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonMonoComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkMonoComponentTokens"],"anchor":"Protocols"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"syntax":null,"code":["🧬 Core version: 1.9.0"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"type":"emphasis","inlineContent":[{"type":"text","text":"background color"}]},{"type":"text","text":", and if a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"type":"text","text":" is used for it, then only the value of this "},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"type":"text","text":" should be changed without any modification on the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component"}]},{"type":"text","text":" definition."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Components"}]},{"type":"text","text":" use "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"text":" exposed through the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"text":" thanks to token providers to get their style values.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Components tokens are defined and gathered inside ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"text":" so as to be exposed then through implementation of ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" thanks to dedicated tokens providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in ","type":"text"},{"inlineContent":[{"type":"text","text":"protocols"}],"type":"emphasis"},{"text":" and defined in ","type":"text"},{"inlineContent":[{"type":"text","text":"extensions"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why tokens are exposed as ","type":"text"},{"code":"@objc open","type":"codeVoice"},{"text":" to be available and overridable anywhere.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Example with ","type":"text"},{"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"syntax":"swift"},{"anchor":"How-to-use-component-tokens","text":"How to use component tokens","level":2,"type":"heading"},{"inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift protocol","type":"text"}]},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"inlineContent":[{"text":"component tokens","type":"text"}],"type":"emphasis"},{"text":" have for values ","type":"text"},{"inlineContent":[{"type":"text","text":"raw tokens"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"semantic tokens"}],"type":"emphasis"},{"text":", and in the end for values primitive types, and all these tokens are declared with ","type":"text"},{"inlineContent":[{"type":"text","text":"type aliases"}],"type":"emphasis"},{"text":" refering all together, you can handle a ","type":"text"},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"text":" directly in your view because the final value will be used.","type":"text"},{"text":" ","type":"text"},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The components tokens are wrapped in tokens provider acessible through the themes:"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Components tokens provider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Target component","type":"text"}]}]],[[{"inlineContent":[{"text":"bar","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For bars components like bottom and navigation bars","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"badge"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For badges like "},{"type":"codeVoice","code":"OUDSBadge"}]}]],[[{"inlineContent":[{"text":"button","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For buttons like ","type":"text"},{"type":"codeVoice","code":"OUDSButton"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"bulletList","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For list of elements with bullets"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"checkbox","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For checkboxes like ","type":"text"},{"type":"codeVoice","code":"OUDSCheckbox"},{"text":", ","type":"text"},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":" and their indeterminate variants"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"chip","type":"text"}]}],[{"inlineContent":[{"text":"For chips like ","type":"text"},{"code":"OUDSSuggestionChip","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSFilterChip","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"controlItem","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Shared and used for switch, checkbox and radio items layouts"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"divider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For dividers like "},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSVerticalDivider"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"icon"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For components containing icons like "},{"type":"codeVoice","code":"OUDSTag"}]}]],[[{"inlineContent":[{"type":"text","text":"link"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For links like "},{"type":"codeVoice","code":"OUDSLink"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"pinCodeInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"quantityInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"radioButton"}]}],[{"inlineContent":[{"type":"text","text":"For radio components like "},{"code":"OUDSRadio","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSRadioItem","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"selectInput"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"skeleton"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"switch"}]}],[{"inlineContent":[{"type":"text","text":"For switch components like "},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSSwitchItem"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"tag","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For tag components like "},{"type":"codeVoice","code":"OUDSTag"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"inputTag","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For input tag components like "},{"code":"OUDSInputTag","type":"codeVoice"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"textArea","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For text area components like "},{"type":"codeVoice","code":"OUDSTextArea"}]}]],[[{"inlineContent":[{"text":"textInput","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For text field input components like ","type":"text"},{"type":"codeVoice","code":"OUDSTextInput"}],"type":"paragraph"}]]]}]}],"hierarchy":{"paths":[[]]},"metadata":{"externalID":"OUDSTokensComponent","role":"collection","roleHeading":"Library","images":[{"type":"icon","identifier":"ic_design_token_figma_component.png"}],"symbolKind":"module","title":"Tokens for components","modules":[{"name":"Tokens for components"}]},"variants":[{"paths":["\/documentation\/oudstokenscomponent"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent"},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"references":{"doc://OUDSTokensComponent/documentation/OUDSTokensComponent/IconComponentTokens":{"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/IconComponentTokens","type":"topic","title":"IconComponentTokens","navigatorTitle":[{"text":"IconComponentTokens","kind":"identifier"}],"url":"\/documentation\/oudstokenscomponent\/iconcomponenttokens","abstract":[{"text":"Declares all component tokens for components using icons (like ","type":"text"},{"type":"codeVoice","code":"OUDSTag"},{"type":"text","text":")."},{"text":" ","type":"text"},{"text":"Use for tokens providers like ","type":"text"},{"type":"codeVoice","code":"OrangeThemeIconComponentTokensProvider"},{"text":".","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IconComponentTokens","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://OUDSTokensComponent/documentation/OUDSTokensComponent/ExpandLinkComponentTokens":{"kind":"symbol","abstract":[{"type":"text","text":"Declares all component tokens for expand link components like "},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"type":"codeVoice","code":"OrangeThemeLinkComponentTokensPro