{"sections":[],"identifier":{"url":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent","interfaceLanguage":"swift"},"hierarchy":{"paths":[[]]},"abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"kind":"symbol","metadata":{"modules":[{"name":"Tokens for components"}],"images":[{"type":"icon","identifier":"ic_design_token_figma_component.png"}],"roleHeading":"Library","symbolKind":"module","role":"collection","title":"Tokens for components","externalID":"OUDSTokensComponent"},"topicSections":[{"anchor":"Group","identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BarComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckboxComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ControlItemComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/DividerComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ExpandLinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/IconComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/PinCodeInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/QuantityInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/RadioButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTagComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TextAreaComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TextInputComponentTokens"],"title":"Group"},{"anchor":"Protocols","identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonMonoComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkMonoComponentTokens"],"title":"Protocols","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"code":["🧬 Core version: 1.9.0"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"type":"emphasis","inlineContent":[{"text":"background color","type":"text"}]},{"type":"text","text":", and if a "},{"type":"emphasis","inlineContent":[{"text":"component token","type":"text"}]},{"type":"text","text":" is used for it, then only the value of this "},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"type":"text","text":" should be changed without any modification on the "},{"type":"emphasis","inlineContent":[{"text":"component","type":"text"}]},{"type":"text","text":" definition."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Components","type":"text"}]},{"type":"text","text":" use "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" exposed through the "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" thanks to token providers to get their style values."}]},{"type":"paragraph","inlineContent":[{"text":"Components tokens are defined and gathered inside ","type":"text"},{"inlineContent":[{"text":"Swift protocol","type":"text"}],"type":"emphasis"},{"text":" so as to be exposed then through implementation of ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" thanks to dedicated tokens providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in ","type":"text"},{"inlineContent":[{"text":"protocols","type":"text"}],"type":"emphasis"},{"text":" and defined in ","type":"text"},{"inlineContent":[{"text":"extensions","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why tokens are exposed as ","type":"text"},{"code":"@objc open","type":"codeVoice"},{"text":" to be available and overridable anywhere.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Example with ","type":"text"},{"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"How to use component tokens","anchor":"How-to-use-component-tokens"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact, the component tokens are declared and gathered in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"text":" have for values ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"semantic tokens","type":"text"}]},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"type":"emphasis","inlineContent":[{"text":"type aliases","type":"text"}]},{"type":"text","text":" refering all together, you can handle a "},{"type":"emphasis","inlineContent":[{"text":"component token","type":"text"}]},{"type":"text","text":" directly in your view because the final value will be used."},{"type":"text","text":" "},{"type":"text","text":"Thus, get the theme and call the needed property with some helpers."}]},{"code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The components tokens are wrapped in tokens provider acessible through the themes:","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Components tokens provider"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Target component"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"bar"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For bars components like bottom and navigation bars"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"badge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For badges like "},{"type":"codeVoice","code":"OUDSBadge"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"button"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For buttons like "},{"type":"codeVoice","code":"OUDSButton"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"bulletList"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For list of elements with bullets"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"checkbox"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For checkboxes like "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":", "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":" and their indeterminate variants"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"chip"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For chips like "},{"type":"codeVoice","code":"OUDSSuggestionChip"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSFilterChip"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"controlItem"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Shared and sued for switch, checkbox and radio items layouts"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"divider"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For dividers like "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSVerticalDivider"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"icon"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For components containing icons like "},{"type":"codeVoice","code":"OUDSTag"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"link"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For links like "},{"type":"codeVoice","code":"OUDSLink"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"pinCodeInput"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"quantityInput"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"radioButton"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For radio components like "},{"type":"codeVoice","code":"OUDSRadio"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioItem"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"selectInput"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"skeleton"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"switch"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For switch components like "},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSSwitchItem"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"tag"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For tag components like "},{"type":"codeVoice","code":"OUDSTag"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"inputTag"}]}],[{"type":"paragraph","inlineContent":[{"type":"