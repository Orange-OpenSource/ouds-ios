{"kind":"symbol","metadata":{"title":"Tokens for components","roleHeading":"Library","externalID":"OUDSTokensComponent","images":[{"identifier":"ic_design_token_figma_component.png","type":"icon"}],"role":"collection","symbolKind":"module","modules":[{"name":"Tokens for components"}]},"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"syntax":null,"type":"codeListing","code":["🧬 Core version: 1.10.0"]},{"inlineContent":[{"text":"Thus if a component need to change for example its ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"background color","type":"text"}]},{"type":"text","text":", and if a "},{"type":"emphasis","inlineContent":[{"text":"component token","type":"text"}]},{"type":"text","text":" is used for it, then only the value of this "},{"type":"emphasis","inlineContent":[{"type":"text","text":"token"}]},{"text":" should be changed without any modification on the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component","type":"text"}]},{"type":"text","text":" definition."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Components","type":"text"}]},{"type":"text","text":" use "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" exposed through the "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" thanks to token providers to get their style values."}],"type":"paragraph"},{"inlineContent":[{"text":"Components tokens are defined and gathered inside ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift protocol","type":"text"}]},{"text":" so as to be exposed then through implementation of ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" thanks to dedicated tokens providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in ","type":"text"},{"inlineContent":[{"text":"protocols","type":"text"}],"type":"emphasis"},{"text":" and defined in ","type":"text"},{"inlineContent":[{"text":"extensions","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why tokens are exposed as ","type":"text"},{"type":"codeVoice","code":"@objc open"},{"text":" to be available and overridable anywhere.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Example with ","type":"text"},{"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var borderWidthDefault: BorderWidthSemanticToken { get }","    var borderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticToken { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var borderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var borderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"type":"codeListing"},{"level":2,"type":"heading","text":"How to use component tokens","anchor":"How-to-use-component-tokens"},{"type":"paragraph","inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift protocol","type":"text"}]},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"text":" have for values ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"semantic tokens","type":"text"}]},{"text":", and in the end for values primitive types, and all these tokens are declared with ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"type aliases"}]},{"text":" refering all together, you can handle a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"text":" directly in your view because the final value will be used.","type":"text"},{"text":" ","type":"text"},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}]},{"syntax":"swift","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.borderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.borderRadius)","                .stroke(Color.blue, lineWidth: theme.button.borderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"borderRadius\" and \"borderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The components tokens are wrapped in tokens provider acessible through the themes:"}]},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Components tokens provider"}]}],[{"type":"paragraph","inlineContent":[{"text":"Target component","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"bar","type":"text"}]}],[{"inlineContent":[{"text":"For bars components like bottom and navigation bars","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"badge","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For badges like "},{"type":"codeVoice","code":"OUDSBadge"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"button","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For buttons like ","type":"text"},{"code":"OUDSButton","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"bulletList","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For list of elements with bullets"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"checkbox"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For checkboxes like "},{"code":"OUDSCheckbox","type":"codeVoice"},{"text":", ","type":"text"},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"text":" and their indeterminate variants","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"chip","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For chips like ","type":"text"},{"code":"OUDSSuggestionChip","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSFilterChip","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"controlItem","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Shared and used for switch, checkbox and radio items layouts"}]}]],[[{"inlineContent":[{"text":"divider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For dividers like "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSVerticalDivider"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"icon","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For components containing icons like ","type":"text"},{"type":"codeVoice","code":"OUDSTag"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"link","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For links like ","type":"text"},{"type":"codeVoice","code":"OUDSLink"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"pinCodeInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"quantityInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"radioButton"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For radio components like "},{"type":"codeVoice","code":"OUDSRadio"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioItem"}]}]],[[{"inlineContent":[{"text":"selectInput","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"skeleton","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"switch"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For switch components like "},{"code":"OUDSSwitch","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSSwitchItem","type":"codeVoice"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"tag"}]}],[{"type":"paragraph","inlineContent":[{"text":"For tag components like ","type":"text"},{"type":"codeVoice","code":"OUDSTag"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"inputTag","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For input tag components like ","type":"text"},{"type":"codeVoice","code":"OUDSInputTag"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"textArea","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For text area components like ","type":"text"},{"code":"OUDSTextArea","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"textInput","type":"text"}]}],[{"inlineContent":[{"text":"For text field input components like ","type":"text"},{"type":"codeVoice","code":"OUDSTextInput"}],"type":"paragraph"}]]],"type":"table"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"identifier":{"url":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent","int