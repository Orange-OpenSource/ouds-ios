{"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"code":["🧬 Core version: 1.10.0"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Thus if a component need to change for example its ","type":"text"},{"inlineContent":[{"type":"text","text":"background color"}],"type":"emphasis"},{"text":", and if a ","type":"text"},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"text":" is used for it, then only the value of this ","type":"text"},{"inlineContent":[{"type":"text","text":"token"}],"type":"emphasis"},{"text":" should be changed without any modification on the ","type":"text"},{"inlineContent":[{"type":"text","text":"component"}],"type":"emphasis"},{"text":" definition.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Components"}],"type":"emphasis"},{"text":" use ","type":"text"},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"text":" exposed through the ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"text":" thanks to token providers to get their style values.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"inlineContent":[{"text":"Swift protocol","type":"text"}],"type":"emphasis"},{"type":"text","text":" so as to be exposed then through implementation of "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"inlineContent":[{"text":"protocols","type":"text"}],"type":"emphasis"},{"type":"text","text":" and defined in "},{"inlineContent":[{"text":"extensions","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why tokens are exposed as "},{"code":"@objc open","type":"codeVoice"},{"type":"text","text":" to be available and overridable anywhere."}]},{"type":"paragraph","inlineContent":[{"text":"Example with ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens"},{"text":":","type":"text"}]},{"code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var borderWidthDefault: BorderWidthSemanticToken { get }","    var borderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticToken { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var borderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var borderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"How-to-use-component-tokens","text":"How to use component tokens","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"text":" have for values ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"semantic tokens"}]},{"text":", and in the end for values primitive types, and all these tokens are declared with ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"type aliases"}]},{"text":" refering all together, you can handle a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"text":" directly in your view because the final value will be used.","type":"text"},{"text":" ","type":"text"},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}]},{"code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.borderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.borderRadius)","                .stroke(Color.blue, lineWidth: theme.button.borderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"borderRadius\" and \"borderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The components tokens are wrapped in tokens provider acessible through the themes:"}]},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Components tokens provider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Target component","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"bar","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For bars components like bottom and navigation bars","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"badge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For badges like ","type":"text"},{"code":"OUDSBadge","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"button","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For buttons like ","type":"text"},{"code":"OUDSButton","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"bulletList","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For list of elements with bullets","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"checkbox","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For checkboxes like ","type":"text"},{"code":"OUDSCheckbox","type":"codeVoice"},{"text":", ","type":"text"},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"text":" and their indeterminate variants","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"chip","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For chips like ","type":"text"},{"code":"OUDSSuggestionChip","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSFilterChip","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"controlItem","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Shared and used for switch, checkbox and radio items layouts","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"divider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For dividers like ","type":"text"},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSVerticalDivider","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"icon","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For components containing icons like ","type":"text"},{"code":"OUDSTag","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"link","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For links like ","type":"text"},{"code":"OUDSLink","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"pinCodeInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"quantityInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"radioButton","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For radio components like ","type":"text"},{"code":"OUDSRadio","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSRadioItem","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"selectInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"skeleton","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"switch","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For switch components like ","type":"text"},{"code":"OUDSSwitch","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSSwitchItem","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"tag","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For tag components like ","type":"text"},{"code":"OUDSTag","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"inputTag","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For input tag components like ","type":"text"},{"code":"OUDSInputTag","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"textArea","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For text area components like ","type":"text"},{"code":"OUDSTextArea","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"textInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For text field input components like ","type":"text"},{"code":"OUDSTextInput","type":"codeVoice"}]}]]],"type":"table"}],"kind":"content"}],"abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"topicSections":[{"anchor":"Group","title":"Group","identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/AlertComponentTokens","do