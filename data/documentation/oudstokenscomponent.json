{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"codeListing","syntax":null,"code":["🧬 Core version: 1.9.0"]},{"type":"paragraph","inlineContent":[{"text":"Thus if a component need to change for example its ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"background color","type":"text"}]},{"text":", and if a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"text":" is used for it, then only the value of this ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"text":" should be changed without any modification on the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component","type":"text"}]},{"text":" definition.","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Components"}]},{"text":" use ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" exposed through the "},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" thanks to token providers to get their style values."}]},{"inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"inlineContent":[{"text":"Swift protocol","type":"text"}],"type":"emphasis"},{"type":"text","text":" so as to be exposed then through implementation of "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"inlineContent":[{"type":"text","text":"protocols"}],"type":"emphasis"},{"type":"text","text":" and defined in "},{"inlineContent":[{"text":"extensions","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why tokens are exposed as "},{"type":"codeVoice","code":"@objc open"},{"type":"text","text":" to be available and overridable anywhere."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example with "},{"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","type":"reference","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var borderWidthDefault: BorderWidthSemanticToken { get }","    var borderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticToken { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var borderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var borderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"type":"codeListing"},{"text":"How to use component tokens","anchor":"How-to-use-component-tokens","level":2,"type":"heading"},{"inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" have for values "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"semantic tokens"}]},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"type":"emphasis","inlineContent":[{"type":"text","text":"type aliases"}]},{"type":"text","text":" refering all together, you can handle a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"type":"text","text":" directly in your view because the final value will be used."},{"type":"text","text":" "},{"type":"text","text":"Thus, get the theme and call the needed property with some helpers."}],"type":"paragraph"},{"code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.borderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.borderRadius)","                .stroke(Color.blue, lineWidth: theme.button.borderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"borderRadius\" and \"borderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The components tokens are wrapped in tokens provider acessible through the themes:"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Components tokens provider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Target component"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"bar"}]}],[{"type":"paragraph","inlineContent":[{"text":"For bars components like bottom and navigation bars","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"badge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For badges like "},{"code":"OUDSBadge","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"button"}]}],[{"inlineContent":[{"text":"For buttons like ","type":"text"},{"type":"codeVoice","code":"OUDSButton"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"bulletList"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For list of elements with bullets","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"checkbox"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For checkboxes like ","type":"text"},{"code":"OUDSCheckbox","type":"codeVoice"},{"text":", ","type":"text"},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"text":" and their indeterminate variants","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"chip","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For chips like "},{"type":"codeVoice","code":"OUDSSuggestionChip"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSFilterChip"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"controlItem","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Shared and used for switch, checkbox and radio items layouts"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"divider"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For dividers like "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSVerticalDivider"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"icon"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For components containing icons like "},{"type":"codeVoice","code":"OUDSTag"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"link","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For links like ","type":"text"},{"type":"codeVoice","code":"OUDSLink"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"pinCodeInput"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"quantityInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"radioButton"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For radio components like "},{"type":"c