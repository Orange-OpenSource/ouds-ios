{"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"metadata":{"roleHeading":"Framework","role":"collection","title":"OUDSTokensComponent","externalID":"OUDSTokensComponent","symbolKind":"module","modules":[{"name":"OUDSTokensComponent"}]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"codeListing","syntax":null,"code":["🧱 Tokens version: 0.11.0"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"inlineContent":[{"type":"text","text":"background color"}],"type":"emphasis"},{"type":"text","text":", and if a "},{"inlineContent":[{"text":"component token","type":"text"}],"type":"emphasis"},{"type":"text","text":" is used for it, then only the value of this "},{"inlineContent":[{"text":"token","type":"text"}],"type":"emphasis"},{"type":"text","text":" should be changed without any modification on the "},{"inlineContent":[{"type":"text","text":"component"}],"type":"emphasis"},{"type":"text","text":" definition."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Components"}],"type":"emphasis"},{"type":"text","text":" use "},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"type":"text","text":" exposed through the "},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"type":"text","text":" thanks to token providers to get their style values."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"type":"text","text":" so as to be exposed then through implementation of "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"inlineContent":[{"type":"text","text":"protocols"}],"type":"emphasis"},{"type":"text","text":" and defined in "},{"inlineContent":[{"text":"extensions","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why tokens are exposed as "},{"code":"@objc open","type":"codeVoice"},{"type":"text","text":" to be available and overridable anywhere."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var buttonSizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var buttonSpacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var buttonSizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens.dimension600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.borderWidthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.borderRadiusMedium }","    @objc open var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.colorRepositoryOpacityBlackHigher }","    @objc open var buttonSpacePaddingBlock: SpaceSemanticToken { spaces.spacePaddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"]},{"level":2,"type":"heading","text":"How to use component tokens","anchor":"How-to-use-component-tokens"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact, the component tokens are declared and gathered in "},{"type":"emphasis","inlineContent":[{"text":"Swift protocol","type":"text"}]},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"text":" have for values ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"semantic tokens","type":"text"}]},{"text":", and in the end for values primitive types, and all these tokens are declared with ","type":"text"},{"inlineContent":[{"type":"text","text":"type aliases"}],"type":"emphasis"},{"type":"text","text":" refering all together, you can handle a "},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"type":"text","text":" directly in your view because the final value will be used."},{"type":"text","text":" "},{"type":"text","text":"Thus, get the theme and call the needed property with some helpers."}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.buttonSpacePaddingInlineArrowStart)","        .padding(.trailing, theme.button.buttonSpacePaddingInlineArrowEnd)","        .background(theme.button.buttonColorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"buttonColorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"buttonSpacePaddingInlineArrowStart\" and \"buttonSpacePaddingInlineArrowEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"]}]}],"topicSections":[{"title":"Group","identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckboxComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ControlItemComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/DividerComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTextComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ListItemComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/RadioButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens"],"anchor":"Group"}],"variants":[{"paths":["\/documentation\/oudstokenscomponent"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[[]]},"abstract":[{"type":"text","text":"These "},{"inlineContent":[{"type":"text","text":"tokens"}],"type":"emphasis"},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"references":{"doc://OUDSTokensComponent/documentation/OUDSTokensComponent/DividerComponentTokens":{"abstract":[{"text":"Declares all component tokens for divider components like ","type":"text"},{"code":"OUDSDivider","type":"codeVoice"},{"text":" ","type":"text"},{"text":"Use for tokens providers like ","type":"text"},{"code":"OrangeThemeDividerComponentTokensProvider","type":"codeVoice"},{"text":".","type":"text"}],"navigatorTitle":[{"text":"DividerComponentTokens","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/DividerComponentTokens","title":"DividerComponentTokens","role":"symb