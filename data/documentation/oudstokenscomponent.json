{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"code":["🧬 Core version: 1.10.0"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"text":"Thus if a component need to change for example its ","type":"text"},{"inlineContent":[{"text":"background color","type":"text"}],"type":"emphasis"},{"text":", and if a ","type":"text"},{"inlineContent":[{"text":"component token","type":"text"}],"type":"emphasis"},{"text":" is used for it, then only the value of this ","type":"text"},{"inlineContent":[{"text":"token","type":"text"}],"type":"emphasis"},{"text":" should be changed without any modification on the ","type":"text"},{"inlineContent":[{"text":"component","type":"text"}],"type":"emphasis"},{"text":" definition.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"Components","type":"text"}],"type":"emphasis"},{"text":" use ","type":"text"},{"inlineContent":[{"text":"component tokens","type":"text"}],"type":"emphasis"},{"text":" exposed through the ","type":"text"},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"text":" thanks to token providers to get their style values.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Components tokens are defined and gathered inside ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"text":" so as to be exposed then through implementation of ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"type":"emphasis","inlineContent":[{"text":"protocols","type":"text"}]},{"type":"text","text":" and defined in "},{"type":"emphasis","inlineContent":[{"text":"extensions","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why tokens are exposed as "},{"code":"@objc open","type":"codeVoice"},{"type":"text","text":" to be available and overridable anywhere."}]},{"inlineContent":[{"text":"Example with ","type":"text"},{"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var borderWidthDefault: BorderWidthSemanticToken { get }","    var borderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticToken { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var borderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var borderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"How to use component tokens","type":"heading","anchor":"How-to-use-component-tokens"},{"inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"text":" have for values ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"semantic tokens","type":"text"}]},{"text":", and in the end for values primitive types, and all these tokens are declared with ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"type aliases","type":"text"}]},{"text":" refering all together, you can handle a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component token","type":"text"}]},{"text":" directly in your view because the final value will be used.","type":"text"},{"text":" ","type":"text"},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}],"type":"paragraph"},{"code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.borderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.borderRadius)","                .stroke(Color.blue, lineWidth: theme.button.borderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"borderRadius\" and \"borderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The components tokens are wrapped in tokens provider acessible through the themes:","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"text":"Components tokens provider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Target component"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"bar"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For bars components like bottom and navigation bars"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"badge"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For badges like ","type":"text"},{"code":"OUDSBadge","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"button","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For buttons like ","type":"text"},{"code":"OUDSButton","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"bulletList","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For list of elements with bullets"}],"type":"paragraph"}]],[[{"inlineContent