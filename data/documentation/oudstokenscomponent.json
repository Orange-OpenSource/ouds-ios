{"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"syntax":null,"type":"codeListing","code":["🧬 Core version: 1.8.0"]},{"inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"type":"emphasis","inlineContent":[{"text":"background color","type":"text"}]},{"type":"text","text":", and if a "},{"type":"emphasis","inlineContent":[{"text":"component token","type":"text"}]},{"type":"text","text":" is used for it, then only the value of this "},{"type":"emphasis","inlineContent":[{"type":"text","text":"token"}]},{"type":"text","text":" should be changed without any modification on the "},{"type":"emphasis","inlineContent":[{"text":"component","type":"text"}]},{"type":"text","text":" definition."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Components","type":"text"}]},{"type":"text","text":" use "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" exposed through the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" thanks to token providers to get their style values."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"type":"text","text":" so as to be exposed then through implementation of "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"inlineContent":[{"type":"text","text":"protocols"}],"type":"emphasis"},{"type":"text","text":" and defined in "},{"inlineContent":[{"type":"text","text":"extensions"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why tokens are exposed as "},{"type":"codeVoice","code":"@objc open"},{"type":"text","text":" to be available and overridable anywhere."}]},{"type":"paragraph","inlineContent":[{"text":"Example with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","type":"reference"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"]},{"level":2,"anchor":"How-to-use-component-tokens","type":"heading","text":"How to use component tokens"},{"type":"paragraph","inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"text":" have for values ","type":"text"},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"semantic tokens"}],"type":"emphasis"},{"text":", and in the end for values primitive types, and all these tokens are declared with ","type":"text"},{"inlineContent":[{"text":"type aliases","type":"text"}],"type":"emphasis"},{"text":" refering all together, you can handle a ","type":"text"},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"text":" directly in your view because the final value will be used.","type":"text"},{"text":" ","type":"text"},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The components tokens are wrapped in tokens provider acessible through the themes:"}]},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Components tokens provider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Target component"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"badge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For badges like "},{"code":"OUDSBadge","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"button","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For buttons like ","type":"text"},{"type":"codeVoice","code":"OUDSButton"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"bulletList","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For list of elements with bullets","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"checkbox","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For checkboxes like ","type":"text"},{"code":"OUDSCheckbox","type":"codeVoice"},{"text":", ","type":"text"},{"code":"OUDSCheckboxItem","type":"codeVoice"},{"text":" and their indeterminate variants","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"chip"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For chips like "},{"type":"codeVoice","code":"OUDSSuggestionChip"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSFilterChip"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"controlItem","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Shared and sued for switch, checkbox and radio items layouts"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"divider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For dividers like ","type":"text"},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"OUDSVerticalDivider"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"icon"}]}],[{"type":"paragraph","inlineContent":[{"text":"For components containing icons like ","type":"text"},{"code":"OUDSTag","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"link","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For links like "},{"type":"codeVoice","code":"OUDSLink"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"pinCodeInput"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"quantityInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"radioButton"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For radio components like "},{"type":"codeVoice","code":"OUDSRadio"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSRadioItem"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"selectInput"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"skeleton"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"switch","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For switch components like ","type":"text"},{"code":"OUDSSwitch","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSSwitchItem","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"tag"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For tag components like "},{"code":"OUDSTag","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"inputTag","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For input tag components like "},{"code":"OUDSInputTag","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"textArea"}]}],[{"type":"paragraph","inlineContent":[{"text":"For text area components like ","type":"text"},{"code":"OUDSTextArea","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"textInput"}]}],[{"type":"paragraph","inlineContent":[{"text":"For text field input components like ","type":"text"},{"code":"OUDSTextInput","type":"codeVoice"}]}]]],"type":"table"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"hierarchy":{"paths":[[]]},"metadata":{"role":"collection","title":"Tokens for components","images":[{"identifier":"ic_design_token_figma_component.png","type":"icon"}],"modules":[{"name":"Tokens for components"}],"externalID":"OUDSTokensComponent","roleHeading":"Library","symbolKind":"module"},"identifier":{"url":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"anchor":"Group","title":"Group","identifiers":["doc:\/\/OUDSTokensComponent\/doc