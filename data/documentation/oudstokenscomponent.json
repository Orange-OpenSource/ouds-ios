","type":"text"},{"inlineContent":[{"text":"tokens","type":"text"}],"type":"emphasis"},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"references":{"doc://OUDSTokensComponent/documentation/OUDSTokensComponent/TagComponentTokens":{"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens","navigatorTitle":[{"text":"TagComponentTokens","kind":"identifier"}],"title":"TagComponentTokens","url":"\/documentation\/oudstokenscomponent\/tagcomponenttokens","abstract":[{"type":"text","text":"Declares all component tokens for tags components like "},{"code":"OUDSTag","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"Used for tokens providers like "},{"code":"OrangeThemeTagComponentTokensProvider","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TagComponentTokens","kind":"identifier"}]},"doc://OUDSTokensComponent/documentation/OUDSTokensComponent/BadgeComponentTokens":{"navigatorTitle":[{"text":"BadgeComponentTokens","kind":"identifier"}],"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","url":"\/documentation\/oudstokenscomponent\/badgecomponenttokens","abstract":[{"type":"text","text":"Declares all component tokens for links components like "},{"type":"codeVoice","code":"OUDSBadge"},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"type":"codeVoice","code":"OrangeThemeBadgeComponentTokensProvider"},{"type":"text","text":"."}],"title":"BadgeComponentTokens","role":"symbol","fragments":[{"text":