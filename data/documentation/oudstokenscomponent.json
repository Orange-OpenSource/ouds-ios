{"abstract":[{"text":"These ","type":"text"},{"inlineContent":[{"text":"tokens","type":"text"}],"type":"emphasis"},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[[]]},"metadata":{"symbolKind":"module","externalID":"OUDSTokensComponent","images":[{"type":"icon","identifier":"ic_design_token_figma_component.png"}],"roleHeading":"Library","role":"collection","title":"Tokens for components","modules":[{"name":"Tokens for components"}]},"topicSections":[{"title":"Group","identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/AlertComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BarComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckboxComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ControlItemComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/DividerComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ExpandLinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/IconComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/PinCodeInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/QuantityInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/RadioButtonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectInputComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTagComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TextAreaComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TextInputComponentTokens"],"anchor":"Group"},{"title":"Protocols","identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonMonoComponentTokens","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkMonoComponentTokens"],"generated":true,"anchor":"Protocols"}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"codeListing","code":["🧬 Core version: 1.9.0"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"type":"emphasis","inlineContent":[{"type":"text","text":"background color"}]},{"type":"text","text":", and if a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"type":"text","text":" is used for it, then only the value of this "},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"type":"text","text":" should be changed without any modification on the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component"}]},{"type":"text","text":" definition."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Components"}]},{"type":"text","text":" use "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" exposed through the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" thanks to token providers to get their style values."}]},{"inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"type":"emphasis","inlineContent":[{"text":"Swift protocol","type":"text"}]},{"type":"text","text":" so as to be exposed then through implementation of "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"type":"emphasis","inlineContent":[{"text":"protocols","type":"text"}]},{"type":"text","text":" and defined in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"extensions"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why tokens are exposed as "},{"type":"codeVoice","code":"@objc open"},{"type":"text","text":" to be available and overridable anywhere."}],"type":"paragraph"},{"inlineContent":[{"text":"Example with ","type":"text"},{"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var borderWidthDefault: BorderWidthSemanticToken { get }","    var borderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticToken { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var borderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var borderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"type":"codeListing"},{"anchor":"How-to-use-component-tokens","level":2,"text":"How to use component tokens","type":"heading"},{"inlineContent":[{"type":"text","text":"In fact, the component tokens are declared and gathered in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"type":"text","text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"type":"text","text":" have for values "},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" or "},{"inlineContent":[{"text":"semantic tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"inlineContent":[{"type":"text","text":"type aliases"}],"type":"emphasis"},{"type":"text","text":" refering all together, you can handle a "},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"text":" directly in your view because the final value will be used.","type":"text"},{"type":"text","text":" "},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}],"type":"paragraph"},{"code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.borderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.borderRadius)","                .stroke(Color.blue, lineWidth: theme.button.borderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"borderRadius\" and \"borderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The components tokens are wrapped in tokens provider acessible through the themes:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Components tokens provider","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Target component"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"bar"}],"type":"paragraph"}],[{"inlineContent":[{"text":"For bars components like bottom and navigation bars","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"badge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For badges like "},{"code":"OUDSBadge","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"button"}]}],[{"type":"paragraph","inlineContent":[{"text":"For buttons like ","type":"text"},{"code":"OUDSButton","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"bulletList"}]}],[{"inlineContent":[{"type":"text","text":"For list of elements with bullets"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"checkbox","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For checkboxes like "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":", "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":" and their indeterminate variants"}]}]],[[{"inlineContent":[{"type":"text","text":"chip"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For chips like "},{"code":"OUDSSuggestionChip","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSFilterChip","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"controlItem"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Shared and used for switch, checkbox and radio items layouts","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"divider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For dividers like ","type":"text"},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"OUDSVerticalDivider","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"icon","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For components containing icons like "},{"type":"codeVoice","code":"OUDSTag"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"link","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"For links like ","type":"text"},{"code":"OUDSLink","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"pinCodeInput"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"quantityInput","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"radioButton","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For radio components like "},{"code":"OUDSRadio","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSRadioItem","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"selectInput"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"skeleton","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"switch","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For switch components like "},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":" and "},{"code":"OUDSSwitchItem","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"tag","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For tag components like "},{"type":"codeVoice","code":"OUDSTag"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"inputTag","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"For input tag components like "},{"code":"OUDSInputTag","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[