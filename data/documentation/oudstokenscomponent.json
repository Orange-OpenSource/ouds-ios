{"sections":[],"metadata":{"roleHeading":"Library","role":"collection","title":"Tokens for components","modules":[{"name":"Tokens for components"}],"symbolKind":"module","externalID":"OUDSTokensComponent","images":[{"identifier":"ic_design_token_figma_component.png","type":"icon"}]},"variants":[{"paths":["\/documentation\/oudstokenscomponent"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"codeListing","syntax":null,"code":["🧬 Core version: 1.10.0"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"inlineContent":[{"type":"text","text":"background color"}],"type":"emphasis"},{"type":"text","text":", and if a "},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"type":"text","text":" is used for it, then only the value of this "},{"type":"emphasis","inlineContent":[{"type":"text","text":"token"}]},{"type":"text","text":" should be changed without any modification on the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component"}]},{"type":"text","text":" definition."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Components","type":"text"}]},{"type":"text","text":" use "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"text":" exposed through the ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"text":" thanks to token providers to get their style values.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"type":"text","text":" so as to be exposed then through implementation of "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"protocols"}]},{"type":"text","text":" and defined in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"extensions"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why tokens are exposed as "},{"code":"@objc open","type":"codeVoice"},{"type":"text","text":" to be available and overridable anywhere."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var sizeMaxHeightIconOnly: SizeSemanticToken { get }","    var borderWidthDefault: BorderWidthSemanticToken { get }","    var borderRadius: BorderRadiusSemanticToken { get }","    var colorBgDefaultPressedMono: MultipleColorSemanticToken { get }","    var spacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var sizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens._600 }","    ","    \/\/ And also semantic tokens","","    @objc open var borderWidthDefault: BorderWidthSemanticToken { borders.widthThicker }","    @objc open var borderRadius: BorderRadiusSemanticToken { borders.radiusMedium }","    @objc open var colorBgDefaultPressedMono: MultipleColorSemanticToken { colors.repositoryOpacityBlackHigher }","    @objc open var spacePaddingBlock: SpaceSemanticToken { spaces.paddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"]},{"level":2,"type":"heading","anchor":"How-to-use-component-tokens","text":"How to use component tokens"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact, the component tokens are declared and gathered in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"type":"text","text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" have for values "},{"inlineContent":[{"type":"text","text":"raw tokens"}],"type":"emphasis"},{"type":"text","text":" or "},{"inlineContent":[{"type":"text","text":"semantic tokens"}],"type":"emphasis"},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"inlineContent":[{"type":"text","text":"type aliases"}],"type":"emphasis"},{"type":"text","text":" refering all together, you can handle a "},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"type":"text","text":" directly in your view because the final value will be used."},{"type":"text","text":" "},{"type":"text","text":"Thus, get the theme and call the needed property with some helpers."}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.borderRadius)","        }","        .padding(.leading, theme.button.spacePaddingInlineChevronStart)","        .padding(.trailing, theme.button.spacePaddingInlineChevronEnd)","        .background(theme.button.colorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.borderRadius)","                .stroke(Color.blue, lineWidth: theme.button.borderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"borderRadius\" and \"borderWidthDefault\"","    - The theme provides a color semantic token \"colorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"spacePaddingInlineChevronStart\" and \"spacePaddingInlineChevronEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The components tokens are wrapped in tokens provider acessible through the themes:"}]},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Components tokens provider"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Target component"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"bar"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For bars components like bottom and navigation bars"}]}]],[[{"inlineContent":[{"type":"text","text":"badge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For badges like "},{"type":"codeVoice","code":"OUDSBadgeStandard"},{"type":"text","text":", "},{"type":"codeVoice","code":"OUDSBadgeIcon"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSBadgeCount"},{"type":"text","text":"."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"button"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For buttons like "},{"type":"codeVoice","code":"OUDSButton"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"bulletList"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For list of elements with bullets"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"checkbox"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For checkboxes like "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":", "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":" and their indeterminate variants"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"chip"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"For chips like "},{"code":"OUDSSuggestionChip","type":"codeVoice"},{"type":"text","text":" and "},{"code":"OUDSFilterChip","type":"codeVoice"}]}]],[[{"inlineContent":[{"type":"text","text":"controlItem"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Shared and used for switch, checkbox and radio items layouts"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"divider"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For dividers like "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSVerticalDivider"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"icon"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"For components containing icons like "},{"type":"codeVoice","code":"OUDSTag"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"link"}],"type":"paragraph"}],[{"inlineContent":[{"typ