{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"Usages","text":"Usages","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if","type":"text"},{"text":" ","type":"text"},{"text":"these products must be Orange flavored.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this team is created: a kind of ","type":"text"},{"code":"OrangeTheme","type":"codeVoice"},{"text":" but wih adjustments on some tokens like spacings and sizings.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To get the theme:","type":"text"}]},{"code":["    @Environment(\\.theme) var theme"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Integration","text":"Integration","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"To use this theme, inject it to your view using ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" and get it through environment variable.","type":"text"}]},{"code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeBusinessToolsTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Theme-tuning","text":"Theme tuning","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"code":"Tuning","type":"codeVoice"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To apply the tuning:"}]},{"code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","    \/\/ Apply it to your theme","    let theme = OrangeBusinessToolsTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeBusinessToolsTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeBusinessToolsTheme(tuning: Tuning.MaxIt)"],"type":"codeListing","syntax":"swift"},{"text":"Typography","level":2,"type":"heading","anchor":"Typography"},{"type":"heading","text":"Helvetica Neue","level":3,"anchor":"Helvetica-Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange brand strongly relies on the "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family. Thus each Orange brand should, or must, use it."},{"type":"text","text":" "},{"type":"text","text":"For iOS the "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"code":"OrangeBusinessToolsTheme","type":"codeVoice"},{"type":"text","text":" uses as font family the token "},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"type":"text","text":", which is today "},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"type":"codeListing","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeBusinessToolsTheme()","    let orangeTheme = OrangeBusinessToolsTheme(family: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeBusinessToolsTheme(family: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue\")"],"syntax":"swift"},{"type":"heading","text":"Helvetica Neue Arabic","level":3,"anchor":"Helvetica-Neue-Arabic"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}]},{"type":"text","text":". This font family assets can be retrieved through the "},{"type":"reference","isActive":true,"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}]},{"syntax":"swift","type":"codeListing","code":["    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue Arabic\")"]},{"name":"Since","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.17.0"}]}]}]}],"abstract":[{"text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)"],"anchor":"Initializers","generated":true}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme"]}],"identifier":{"url":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","interfaceLanguage":"swift"},"relationshipsSections":[{"kind":"relationships","title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"]},{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP"]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"title":"OrangeBusinessToolsTheme","externalID":"s:29OUDSThemesOrangeBusinessTools0bcD5ThemeC","modules":[{"name":"Theme Orange Business Tools"}],"role":"symbol","symbolKind":"class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"roleHeading":"Class"},"kind":"symbol","references":{"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools":{"title":"Theme Orange Business Tools","kind":"symbol","images":[{"identifier":"ic_theme_orangebusinesstools.png","type":"icon"}],"type":"topic","abstract":[{"type":"text","text":"The Orange Business Tools theme is dedicated to applications with strong dimensions constraints."}],"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools","url":"\/documentation\/oudsthemesorangebusinesstools","role":"collection"},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme/init(family:tuning:)":{"role":"symbol","type":"topic","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"family","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FontFamilySemanticToken","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"tuning","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Tuning","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","kind":"typeIdentifier"},{"text":")","kind":"text"}],"abstract":[{"text":"Constructor of the OrangeBusinessTools theme with its own providers of tokens.","type":"text"},{"text":" ","type":"text"},{"text":"It uses also the providers of charts colors from Orange theme (","type":"text"},{"type":"codeVoice","code":"OrangeThemeColorChartSemanticTokensProvider"},{"text":").","type":"text"}],"title":"init(family:tuning:)","url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme\/init(family:tuning:)","kind":"symbol"},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme":{"title":"OrangeBusinessToolsTheme","kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","abstract":[{"text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme","navigatorTitle":[{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBusinessToolsTheme"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"role":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","kind":"symbol","url":"\/documentation\/oudsthemescontract\/oudstheme","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"type":"codeVoice","code":"class"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"type":"topic","title":"OUDSTheme"},"https://brand.orange.com/en/brand-basics/typography":{"type":"link","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","title":"Orange Brand website (authentication needed)","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}],"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},"doc://OUDSThemesOrangeBusinessTools/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","title":"Swift.Sendable"},"doc://OUDSThemesOrangeBusinessTools/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"ic_theme_orangebusinesstools.png":{"variants":[{"url":"\/images\/OUDSThemesOrangeBusinessTools\/ic_theme_orangebusinesstools.png","traits":["1x","light"]}],"type":"image","identifier":"ic_theme_orangebusinesstools.png","alt":null}}}