{"sections":[],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"role":"symbol","externalID":"s:29OUDSThemesOrangeBusinessTools0bcD5ThemeC","navigatorTitle":[{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"title":"OrangeBusinessToolsTheme","roleHeading":"Class","symbolKind":"class","modules":[{"name":"Theme Orange Business Tools"}]},"abstract":[{"type":"text","text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI."}],"relationshipsSections":[{"title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"type":"inheritsFrom"},{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP"],"type":"conformsTo"}],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools"]]},"identifier":{"url":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)"],"anchor":"Initializers","title":"Initializers","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBusinessToolsTheme","kind":"identifier"}]}]},{"kind":"content","content":[{"anchor":"Usages","level":2,"type":"heading","text":"Usages"},{"inlineContent":[{"text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and","type":"text"},{"text":" ","type":"text"},{"text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if","type":"text"},{"text":" ","type":"text"},{"text":"these products must be Orange flavored.","type":"text"},{"text":" ","type":"text"},{"text":"That is the reason why this team is created: a kind of ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"text":" but wih adjustments on some tokens like spacings and sizings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To get the theme:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.theme) var theme"]},{"level":2,"anchor":"Integration","type":"heading","text":"Integration"},{"inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" and get it through environment variable."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeBusinessToolsTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"]},{"level":2,"type":"heading","text":"Theme tuning","anchor":"Theme-tuning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"type":"codeVoice","code":"Tuning"},{"text":" object.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To apply the tuning:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","    \/\/ Apply it to your theme","    let theme = OrangeBusinessToolsTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeBusinessToolsTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeBusinessToolsTheme(tuning: Tuning.MaxIt)"]},{"type":"heading","text":"Typography","anchor":"Typography","level":2},{"type":"heading","text":"Helvetica Neue","anchor":"Helvetica-Neue","level":3},{"type":"paragraph","inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"text":" ","type":"text"},{"text":"By default an instance of ","type":"text"},{"code":"OrangeBusinessToolsTheme","type":"codeVoice"},{"text":" uses as font family the token ","type":"text"},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"text":", which is today ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use another font family, you will have to send the suitable token or the suitable font family.","type":"text"},{"text":" ","type":"text"},{"text":"However, beware, iOS API relies also on the PostScript name of the font.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeBusinessToolsTheme()","    let orangeTheme = OrangeBusinessToolsTheme(family: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeBusinessToolsTheme(family: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue\")"]},{"text":"Helvetica Neue Arabic","anchor":"Helvetica-Neue-Arabic","level":3,"type":"heading"},{"inlineContent":[{"text":"Because the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}],"type":"emphasis"},{"type":"text","text":". This font family assets can be retrieved through the "},{"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue Arabic\")"]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"0.17.0","type":"text"}]}],"type":"aside","name":"Since"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme"]}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://OUDSThemesOrangeBusinessTools/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP","type":"unresolvable","title":"Swift.SendableMetatype"},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools":{"title":"Theme Orange Business Tools","role":"collection","images":[{"type":"icon","identifier":"ic_theme_orangebusinesstools.png"}],"kind":"symbol","abstract":[{"text":"The Orange Business Tools theme is dedicated to applications with strong dimensions constraints.","type":"text"}],"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools","type":"topic","url":"\/documentation\/oudsthemesorangebusinesstools"},"https://brand.orange.com/en/brand-basics/typography":{"url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"link","title":"Orange Brand website (authentication needed)","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}]},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme","role":"symbol","navigatorTitle":[{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"title":"OrangeBusinessToolsTheme","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","kind":"symbol","abstract":[{"type":"text","text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI."}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"title":"OUDSTheme","role":"symbol","url":"\/documentation\/oudsthemescontract\/oudstheme","kind":"symbol","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme/init(family:tuning:)":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"family"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","text":"FontFamilySemanticToken"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tuning"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","text":"Tuning"},{"kind":"text","text":")"}],"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)","title":"init(family:tuning:)","type":"topic","role":"symbol","kind":"symbol","url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme\/init(family:tuning:)","abstract":[{"text":"Constructor of the OrangeBusinessTools theme with its own providers of tokens.","type":"text"},{"text":" ","type":"text"},{"text":"It uses also the providers of charts colors from Orange theme (","type":"text"},{"code":"OrangeThemeColorChartSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}]},"doc://OUDSThemesOrangeBusinessTools/s8SendableP":{"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"ic_theme_orangebusinesstools.png":{"alt":null,"identifier":"ic_theme_orangebusinesstools.png","type":"image","variants":[{"url":"\/images\/OUDSThemesOrangeBusinessTools\/ic_theme_orangebusinesstools.png","traits":["1x","light"]}]}}}