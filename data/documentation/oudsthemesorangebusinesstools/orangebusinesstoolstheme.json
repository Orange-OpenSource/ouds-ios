{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme"]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"navigatorTitle":[{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"externalID":"s:29OUDSThemesOrangeBusinessTools0bcD5ThemeC","symbolKind":"class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"title":"OrangeBusinessToolsTheme","modules":[{"name":"Theme Orange Business Tools"}],"roleHeading":"Class","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools"]]},"abstract":[{"text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Usages","type":"heading","anchor":"Usages"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if"},{"type":"text","text":" "},{"type":"text","text":"these products must be Orange flavored."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this team is created: a kind of "},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":" but wih adjustments on some tokens like spacings and sizings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the theme:"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.theme) var theme"]},{"level":2,"text":"Integration","type":"heading","anchor":"Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" and get it through environment variable."}]},{"type":"codeListing","syntax":"swift","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeBusinessToolsTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"]},{"level":2,"text":"Theme tuning","type":"heading","anchor":"Theme-tuning"},{"type":"paragraph","inlineContent":[{"text":"The theme can be customized a bit for more flexibility thanks to ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object.","type":"text"},{"text":" ","type":"text"},{"text":"You just need to give a predefined tuning configuration at theme init to build the one you need.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To apply the tuning:"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","    \/\/ Apply it to your theme","    let theme = OrangeBusinessToolsTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeBusinessToolsTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeBusinessToolsTheme(tuning: Tuning.MaxIt)"]},{"level":2,"text":"Typography","type":"heading","anchor":"Typography"},{"level":3,"text":"Helvetica Neue","type":"heading","anchor":"Helvetica-Neue"},{"type":"paragraph","inlineContent":[{"text":"The Orange brand strongly relies on the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"text":" font family. Thus each Orange brand should, or must, use it.","type":"text"},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"text":" font family is available at system level, so it is not needed to get it through external assets.","type":"text"},{"text":" ","type":"text"},{"text":"By default an instance of ","type":"text"},{"type":"codeVoice","code":"OrangeBusinessToolsTheme"},{"text":" uses as font family the token ","type":"text"},{"type":"codeVoice","code":"OrangeBrandFontRawTokens.familyBrandDefault"},{"text":", which is today ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use another font family, you will have to send the suitable token or the suitable font family.","type":"text"},{"text":" ","type":"text"},{"text":"However, beware, iOS API relies also on the PostScript name of the font.","type":"text"},{"text":" ","type":"text"},{"text":"To be sure of the value to use, look at the font book of your device.","type":"text"},{"text":" ","type":"text"},{"text":"It is recommended to use the font raw tokens.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeBusinessToolsTheme()","    let orangeTheme = OrangeBusinessToolsTheme(family: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeBusinessToolsTheme(family: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue\")"]},{"level":3,"text":"Helvetica Neue Arabic","type":"heading","anchor":"Helvetica-Neue-Arabic"},{"type":"paragraph","inlineContent":[{"text":"Because the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}]},{"text":". This font family assets can be retrieved through the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,","type":"text"},{"text":" ","type":"text"},{"text":"register them and define the font family name to use.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue Arabic\")"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.17.0"}]}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme"},"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"]},{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP"]}],"kind":"symbol","topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)"],"anchor":"Initializers"}],"references":{"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools":{"kind":"symbol","title":"Theme Orange Business Tools","type":"topic","url":"\/documentation\/oudsthemesorangebusinesstools","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools","abstract":[{"text":"The Orange Business Tools theme is dedicated to applications with strong dimensions constraints.","type":"text"}],"role":"collection","images":[{"type":"icon","identifier":"ic_theme_orangebusinesstools.png"}]},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme/init(family:tuning:)":{"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"family","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FontFamilySemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena"},{"text":"?, ","kind":"text"},{"text":"tuning","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Tuning","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract6Tuninga"},{"text":")","kind":"text"}],"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)","abstract":[{"text":"Constructor of the OrangeBusinessTools theme with its own providers of tokens.","type":"text"},{"text":" ","type":"text"},{"text":"It uses also the providers of charts colors from Orange theme (","type":"text"},{"type":"codeVoice","code":"OrangeThemeColorChartSemanticTokensProvider"},{"text":").","type":"text"}],"title":"init(family:tuning:)","type":"topic","url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme\/init(family:tuning:)","kind":"symbol"},"ic_theme_orangebusinesstools.png":{"alt":null,"identifier":"ic_theme_orangebusinesstools.png","variants":[{"url":"\/images\/OUDSThemesOrangeBusinessTools\/ic_theme_orangebusinesstools.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSThemesOrangeBusinessTools/s8SendableP":{"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"doc://OUDSThemesOrangeBusinessTools/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP","type":"unresolvable"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"type":"topic","title":"OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"type":"codeVoice","code":"class"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}]},"https://brand.orange.com/en/brand-basics/typography":{"title":"Orange Brand website (authentication needed)","titleInlineContent":[{"text":"Orange Brand website (authentication needed)","type":"text"}],"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"link","url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","navigatorTitle":[{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"abstract":[{"text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"title":"OrangeBusinessToolsTheme","type":"topic","url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme","kind":"symbol"}}}