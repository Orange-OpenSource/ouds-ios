{"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI."}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)"],"anchor":"Initializers","generated":true}],"metadata":{"roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"symbolKind":"class","externalID":"s:29OUDSThemesOrangeBusinessTools0bcD5ThemeC","title":"OrangeBusinessToolsTheme","navigatorTitle":[{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"modules":[{"name":"Theme Orange Business Tools"}],"role":"symbol"},"variants":[{"paths":["\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"]},{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP"]}],"identifier":{"url":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBusinessToolsTheme"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"Usages","text":"Usages","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if"},{"type":"text","text":" "},{"type":"text","text":"these products must be Orange flavored."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this team is created: a kind of "},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":" but wih adjustments on some tokens like spacings and sizings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the theme:"}]},{"type":"codeListing","code":["    @Environment(\\.theme) var theme"],"syntax":"swift"},{"type":"heading","anchor":"Integration","text":"Integration","level":2},{"type":"paragraph","inlineContent":[{"text":"To use this theme, inject it to your view using ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" and get it through environment variable.","type":"text"}]},{"type":"codeListing","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeBusinessToolsTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"syntax":"swift"},{"type":"heading","anchor":"Theme-tuning","text":"Theme tuning","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"code":"Tuning","type":"codeVoice"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To apply the tuning:"}]},{"type":"codeListing","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","    \/\/ Apply it to your theme","    let theme = OrangeBusinessToolsTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeBusinessToolsTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeBusinessToolsTheme(tuning: Tuning.MaxIt)"],"syntax":"swift"},{"type":"heading","anchor":"Typography","text":"Typography","level":2},{"type":"heading","anchor":"Helvetica-Neue","text":"Helvetica Neue","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange brand strongly relies on the "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family. Thus each Orange brand should, or must, use it."},{"text":" ","type":"text"},{"text":"For iOS the ","type":"text"},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"code":"OrangeBusinessToolsTheme","type":"codeVoice"},{"type":"text","text":" uses as font family the token "},{"code":"OrangeBrandFontRawTokens.familyBrandDefault","type":"codeVoice"},{"type":"text","text":", which is today "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"type":"codeListing","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeBusinessToolsTheme()","    let orangeTheme = OrangeBusinessToolsTheme(family: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeBusinessToolsTheme(family: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue\")"],"syntax":"swift"},{"type":"heading","level":3,"text":"Helvetica Neue Arabic","anchor":"Helvetica-Neue-Arabic"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Helvetica Neue Arabic","type":"text"}]},{"type":"text","text":". This font family assets can be retrieved through the "},{"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","isActive":true},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,","type":"text"},{"type":"text","text":" "},{"text":"register them and define the font family name to use.","type":"text"}]},{"type":"codeListing","code":["    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue Arabic\")"],"syntax":"swift"},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.17.0"}],"type":"paragraph"}]}]}],"sections":[],"kind":"symbol","references":{"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools":{"role":"collection","title":"Theme Orange Business Tools","type":"topic","kind":"symbol","images":[{"type":"icon","identifier":"ic_theme_orangebusinesstools.png"}],"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools","url":"\/documentation\/oudsthemesorangebusinesstools","abstract":[{"type":"text","text":"The Orange Business Tools theme is dedicated to applications with strong dimensions constraints."}]},"doc://OUDSThemesOrangeBusinessTools/s8SendableP":{"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme/init(family:tuning:)":{"role":"symbol","abstract":[{"text":"Constructor of the OrangeBusinessTools theme with its own providers of tokens.","type":"text"},{"text":" ","type":"text"},{"text":"It uses also the providers of charts colors from Orange theme (","type":"text"},{"type":"codeVoice","code":"OrangeThemeColorChartSemanticTokensProvider"},{"text":").","type":"text"}],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"family","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","text":"FontFamilySemanticToken","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"tuning","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract6Tuninga","text":"Tuning","kind":"typeIdentifier"},{"text":")","kind":"text"}],"title":"init(family:tuning:)","url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme\/init(family:tuning:)","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)","kind":"symbol","type":"topic"},"ic_theme_orangebusinesstools.png":{"alt":null,"identifier":"ic_theme_orangebusinesstools.png","variants":[{"url":"\/images\/OUDSThemesOrangeBusinessTools\/ic_theme_orangebusinesstools.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme":{"role":"symbol","abstract":[{"text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"title":"OrangeBusinessToolsTheme","url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","kind":"symbol","type":"topic"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/oudsthemescontract\/oudstheme","title":"OUDSTheme"},"doc://OUDSThemesOrangeBusinessTools/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP","title":"Swift.SendableMetatype","type":"unresolvable"},"https://brand.orange.com/en/brand-basics/typography":{"title":"Orange Brand website (authentication needed)","url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","type":"link","titleInlineContent":[{"type":"text","text":"Orange Brand website (authentication needed)"}],"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"}}}