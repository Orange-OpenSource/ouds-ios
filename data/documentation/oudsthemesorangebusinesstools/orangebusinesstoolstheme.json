{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Usages","text":"Usages"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some products may have heavy and very rich user interfaces with a lot of components and elements to displays and"},{"type":"text","text":" "},{"type":"text","text":"with which users can interact. Thus for such products there are specific constraints of spaces and sizes, even if"},{"type":"text","text":" "},{"type":"text","text":"these products must be Orange flavored."},{"type":"text","text":" "},{"type":"text","text":"That is the reason why this team is created: a kind of "},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":" but wih adjustments on some tokens like spacings and sizings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the theme:"}]},{"type":"codeListing","code":["    @Environment(\\.theme) var theme"],"syntax":"swift"},{"type":"heading","level":2,"anchor":"Integration","text":"Integration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use this theme, inject it to your view using "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" and get it through environment variable."}]},{"type":"codeListing","code":["    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeBusinessToolsTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"syntax":"swift"},{"type":"heading","level":2,"anchor":"Theme-tuning","text":"Theme tuning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The theme can be customized a bit for more flexibility thanks to "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object."},{"type":"text","text":" "},{"type":"text","text":"You just need to give a predefined tuning configuration at theme init to build the one you need."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To apply the tuning:"}]},{"type":"codeListing","code":["    \/\/ Define your theme tuning","    let tuning = Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true)","","    \/\/ Apply it to your theme","    let theme = OrangeBusinessToolsTheme(tuning: tuning)","    \/\/ Or in one line","    let theme = OrangeBusinessToolsTheme(tuning: Tuning(hasRoundedButtons: true, hasRoundedTextInputs: true))","","    \/\/ Or apply predefined tunings","    let orangeFranceTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeFrance)","    let orangeBusinessTheme = OrangeBusinessToolsTheme(tuning: Tuning.OrangeBusiness)","    let maxitTheme = OrangeBusinessToolsTheme(tuning: Tuning.MaxIt)"],"syntax":"swift"},{"type":"heading","level":2,"anchor":"Typography","text":"Typography"},{"type":"heading","level":3,"anchor":"Helvetica-Neue","text":"Helvetica Neue"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Orange brand strongly relies on the "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family. Thus each Orange brand should, or must, use it."},{"type":"text","text":" "},{"type":"text","text":"For iOS the "},{"inlineContent":[{"type":"text","text":"Helvetica Neue"}],"type":"emphasis"},{"type":"text","text":" font family is available at system level, so it is not needed to get it through external assets."},{"type":"text","text":" "},{"type":"text","text":"By default an instance of "},{"type":"codeVoice","code":"OrangeBusinessToolsTheme"},{"type":"text","text":" uses as font family the token "},{"type":"codeVoice","code":"OrangeBrandFontRawTokens.familyBrandDefault"},{"type":"text","text":", which is today "},{"inlineContent":[{"text":"Helvetica Neue","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If you want to use another font family, you will have to send the suitable token or the suitable font family."},{"type":"text","text":" "},{"type":"text","text":"However, beware, iOS API relies also on the PostScript name of the font."},{"type":"text","text":" "},{"type":"text","text":"To be sure of the value to use, look at the font book of your device."},{"type":"text","text":" "},{"type":"text","text":"It is recommended to use the font raw tokens."}]},{"type":"codeListing","code":["    \/\/ The following instanciations work","    let orangeTheme = OrangeBusinessToolsTheme()","    let orangeTheme = OrangeBusinessToolsTheme(family: OrangeBrandFontRawTokens.familyBrandDefault)","    let orangeTheme = OrangeBusinessToolsTheme(family: \"HelveticaNeue\") \/\/ Which is PostScript name of the font","    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue\")"],"syntax":"swift"},{"type":"heading","level":3,"anchor":"Helvetica-Neue-Arabic","text":"Helvetica Neue Arabic"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue"}]},{"type":"text","text":" font family does not manage arabic alphabet but latin one, it is possible apply another font family to the theme like the"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Helvetica Neue Arabic"}]},{"type":"text","text":". This font family assets can be retrieved through the "},{"isActive":true,"type":"reference","identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"PostScript name management has been implemented for this font family, thus the weight are managed and it is only needed to add the font assets to the project,"},{"type":"text","text":" "},{"type":"text","text":"register them and define the font family name to use."}]},{"type":"codeListing","syntax":"swift","code":["    let orangeTheme = OrangeBusinessToolsTheme(family: \"Helvetica Neue Arabic\")"]},{"name":"Since","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.17.0"}]}]}]}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"],"type":"inheritsFrom","kind":"relationships","title":"Inherits From"},{"identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)"]}],"metadata":{"roleHeading":"Class","modules":[{"name":"Theme Orange Business Tools"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"navigatorTitle":[{"text":"OrangeBusinessToolsTheme","kind":"identifier"}],"role":"symbol","symbolKind":"class","externalID":"s:29OUDSThemesOrangeBusinessTools0bcD5ThemeC","title":"OrangeBusinessToolsTheme"},"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools"]]},"abstract":[{"text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme"]}],"references":{"https://brand.orange.com/en/brand-basics/typography":{"type":"link","titleInlineContent":[{"text":"Orange Brand website (authentication needed)","type":"text"}],"identifier":"https:\/\/brand.orange.com\/en\/brand-basics\/typography","title":"Orange Brand website (authentication needed)","url":"https:\/\/brand.orange.com\/en\/brand-basics\/typography"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"url":"\/documentation\/oudsthemescontract\/oudstheme","type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"text":"to implement all tokens.","type":"text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true,"type":"reference"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"text":", or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"kind":"symbol","title":"OUDSTheme"},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme/init(family:tuning:)":{"role":"symbol","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme\/init(family:tuning:)","abstract":[{"text":"Constructor of the OrangeBusinessTools theme with its own providers of tokens.","type":"text"},{"text":" ","type":"text"},{"text":"It uses also the providers of charts colors from Orange theme (","type":"text"},{"code":"OrangeThemeColorChartSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"type":"topic","url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme\/init(family:tuning:)","title":"init(family:tuning:)","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"family"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic010FontFamilyB5Tokena","text":"FontFamilySemanticToken"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tuning"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract6Tuninga","text":"Tuning"},{"kind":"text","text":")"}]},"ic_theme_orangebusinesstools.png":{"identifier":"ic_theme_orangebusinesstools.png","type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSThemesOrangeBusinessTools\/ic_theme_orangebusinesstools.png"}]},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools/OrangeBusinessToolsTheme":{"type":"topic","abstract":[{"type":"text","text":"The `Orange Business Tools`` theme is an Orange theme but tailored for some products with heavy UI."}],"title":"OrangeBusinessToolsTheme","navigatorTitle":[{"kind":"identifier","text":"OrangeBusinessToolsTheme"}],"url":"\/documentation\/oudsthemesorangebusinesstools\/orangebusinesstoolstheme","kind":"symbol","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools\/OrangeBusinessToolsTheme","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeBusinessToolsTheme"}]},"doc://OUDSThemesOrangeBusinessTools/documentation/OUDSThemesOrangeBusinessTools":{"abstract":[{"type":"text","text":"The Orange Business Tools theme is dedicated to applications with strong dimensions constraints."}],"images":[{"identifier":"ic_theme_orangebusinesstools.png","type":"icon"}],"title":"Theme Orange Business Tools","type":"topic","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/documentation\/OUDSThemesOrangeBusinessTools","role":"collection","kind":"symbol","url":"\/documentation\/oudsthemesorangebusinesstools"},"doc://OUDSThemesOrangeBusinessTools/s8SendableP":{"identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"doc://OUDSThemesOrangeBusinessTools/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSThemesOrangeBusinessTools\/s16SendableMetatypeP","title":"Swift.SendableMetatype"}}}