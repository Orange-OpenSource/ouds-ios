{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemessosh"]}],"identifier":{"url":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"codeListing","code":["🧬 Theme version: 2.1.0"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the Sosh theme any Sosh product must use, and cannot be subclassed."},{"type":"text","text":" "},{"type":"text","text":"It embeds also in its target the Sosh brand colors which are not shared nor exposed in lower level targets or outside any module not depending to it."},{"type":"text","text":" "},{"type":"text","text":"In other words, this "},{"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true},{"type":"text","text":" is based on the abstract "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":", uses all the "},{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System","type":"text"}]},{"type":"text","text":" kit and brings the Sosh brand colors and assets."}]},{"type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is."}]}],"style":"tip"},{"type":"aside","name":"Important","content":[{"inlineContent":[{"type":"text","text":"The Sosh theme does not embed colors for charts yet and is read-only: it cannot be subclassed or derivated"}],"type":"paragraph"}],"style":"important"},{"type":"heading","level":2,"anchor":"How-to-use-the-theme","text":"How to use the theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" directly. To use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" without further modifications, you will have to use the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"type":"codeListing","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}]},{"type":"codeListing","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"syntax":"swift"},{"type":"heading","level":2,"anchor":"How-to-tune-the-theme","text":"How to tune the theme"},{"type":"paragraph","inlineContent":[{"text":"You cannot tune the Sosh theme.","type":"text"}]},{"type":"heading","level":2,"anchor":"Typography","text":"Typography"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Sosh theme uses its Sosh font and must not use others."}]},{"type":"heading","level":2,"anchor":"How-to-enrich-the-theme","text":"How to enrich the theme"},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the Sosh theme.","type":"text"}]},{"type":"heading","level":2,"anchor":"How-it-looks-like","text":"How it looks like"},{"type":"heading","level":3,"anchor":"Actions","text":"Actions"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Sosh.png"}]},{"type":"heading","level":3,"anchor":"Controls","text":"Controls"},{"type":"heading","level":4,"anchor":"Checkboxes","text":"Checkboxes"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_Sosh.png","type":"image"}],"type":"paragraph"}],"title":"Checkbox"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_Sosh.png"}]}],"title":"Checkbox item"}]},{"type":"heading","level":4,"anchor":"Radios","text":"Radios"},{"type":"tabNavigator","tabs":[{"title":"Radio","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radio_Sosh.png"}]}]},{"title":"Radio item","content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radioItem_Sosh.png","type":"image"}],"type":"paragraph"}]}]},{"type":"heading","level":4,"anchor":"Switches","text":"Switches"},{"type":"tabNavigator","tabs":[{"title":"Switch","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifie