{"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"codeListing","code":["🧬 Theme version: 2.5.0"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the Sosh theme any Sosh product must use, and cannot be subclassed."},{"type":"text","text":" "},{"type":"text","text":"It embeds also in its target the Sosh brand colors which are not shared nor exposed in lower level targets or outside any module not depending to it."},{"type":"text","text":" "},{"type":"text","text":"In other words, this "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" is based on the abstract "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":", uses all the "},{"inlineContent":[{"text":"Orange Unified Design System","type":"text"}],"type":"emphasis"},{"type":"text","text":" kit and brings the Sosh brand colors and assets."}]},{"content":[{"inlineContent":[{"text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is.","type":"text"}],"type":"paragraph"}],"style":"tip","type":"aside","name":"Tip"},{"content":[{"inlineContent":[{"text":"The Sosh theme does not embed colors for charts yet and is read only: it cannot be subclassed or derivated","type":"text"}],"type":"paragraph"}],"style":"important","type":"aside","name":"Important"},{"anchor":"How-to-use-the-theme","level":2,"type":"heading","text":"How to use the theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" directly. To use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" without further modifications, you will have to use the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" for your root view and give it an instance of ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"anchor":"How-to-tune-the-theme","type":"heading","text":"How to tune the theme","level":2},{"type":"paragraph","inlineContent":[{"text":"You cannot tune the Sosh theme.","type":"text"}]},{"anchor":"Typography","type":"heading","text":"Typography","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Sosh theme uses its Sosh font and must not use others."}]},