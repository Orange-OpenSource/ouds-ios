{"topicSections":[{"anchor":"Group","identifiers":["doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshBrandColorRawTokens","doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshBrandFontRawTokens"],"title":"Group"},{"generated":true,"anchor":"Type-Aliases","identifiers":["doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/ColorSoshBrandRawToken","doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/ColorSoshDecorativeRawToken","doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshBrandFontRawToken"],"title":"Type Aliases"},{"generated":true,"anchor":"Extended-Modules","identifiers":["doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/OUDSThemesContract","doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SwiftUICore"],"title":"Extended Modules"}],"kind":"symbol","identifier":{"url":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh","interfaceLanguage":"swift"},"metadata":{"role":"collection","images":[{"type":"icon","identifier":"ic_theme_sosh.png"}],"modules":[{"name":"Theme Sosh"}],"roleHeading":"Library","externalID":"OUDSThemesSosh","title":"Theme Sosh","symbolKind":"module"},"abstract":[{"type":"text","text":"The Sosh theme is the theme dedicated to the Sosh brand only."}],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"codeListing","syntax":null,"code":["🧬 Theme version: 2.3.0"]},{"inlineContent":[{"type":"text","text":"This is the Sosh theme any Sosh product must use, and cannot be subclassed."},{"type":"text","text":" "},{"type":"text","text":"It embeds also in its target the Sosh brand colors which are not shared nor exposed in lower level targets or outside any module not depending to it."},{"type":"text","text":" "},{"type":"text","text":"In other words, this "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" is based on the abstract "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":", uses all the "},{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System","type":"text"}]},{"type":"text","text":" kit and brings the Sosh brand colors and assets."}],"type":"paragraph"},{"style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is.","type":"text"}]}],"type":"aside"},{"style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"The Sosh theme does not embed colors for charts yet and is read only: it cannot be subclassed or derivated","type":"text"}]}],"type":"aside"},{"anchor":"How-to-use-the-theme","level":2,"type":"heading","text":"How to use the theme"},{"inlineContent":[{"type":"text","text":"You can use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" directly. To use the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"anchor":"How-to-tune-the-theme","level":2,"type":"heading","text":"How to tune the theme"},{"inlineContent":[{"type":"text","text":"You cannot tune the Sosh theme."}],"type":"paragraph"},{"anchor":"Typography","level":2,"type":"heading","text":"Typography"},{"inlineContent":[{"type":"text","text":"The Sosh theme uses its Sosh font and must not use others."}],"type":"paragraph"},{"anchor":"How-to-enrich-the-theme","level":2,"type":"heading","text":"How to enrich the theme"},{"inlineContent":[{"type":"text","text":"You cannot derivate the Sosh theme."}],"type":"paragraph"},{"anchor":"How-it-looks-like","level":2,"type":"heading","text":"How it looks like"},{"anchor":"Actions","level":3,"type":"heading","text":"Actions"},{"anchor":"Button","level":4,"type":"heading","text":"Button"},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Sosh.png"}],"type":"paragraph"},{"anchor":"Content-display","level":3,"type":"heading","text":"Content display"},{"anchor":"Bullet-list","level":4,"ty