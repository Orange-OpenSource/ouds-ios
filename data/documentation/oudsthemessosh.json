:"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":", uses all the ","type":"text"},{"inlineContent":[{"text":"Orange Unified Design System","type":"text"}],"type":"emphasis"},{"text":" kit and brings the Sosh brand colors and assets.","type":"text"}],"type":"paragraph"},{"style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is."}]}],"type":"aside"},{"style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"The Sosh theme does not embed colors for charts yet and is read only: it cannot be subclassed or derivated","type":"text"}]}],"type":"aside"},{"level":2,"text":"How to use the theme","anchor":"How-to-use-the-theme","type":"heading"},{"inlineContent":[{"text":"You can use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","type":"reference"},{"text":" directly. To use the ","type":"text"},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true,"type":"reference"},{"text":" without further modifications, you will have to use the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" for your root view and give it an instance of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true,"type":"reference"},{"text":". Keep in mind the themes are ","type":"text"},{"inlineContent":[{"text":"Swift class objects","type":"text"}],"type":"emphasis"},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"type":"heading","text":"How to tune the theme","level":2,"anchor":"How-to-tune-the-theme"},{"type":"paragraph","inlineContent":[{"text":"You cannot tune the Sosh theme.","type":"text"}]},{"type":"heading","text":"Typography","level":2,"anchor":"Typography"},{"type":"paragraph","inlineContent":[{"text":"The Sosh theme uses its Sosh font and must not use others.","type":"text"}]},{"type":"heading","text":"How to enrich the theme","level":2,"anchor":"How-to-enrich-the-theme"},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the Sosh theme.","type":"text"}]},{"type":"heading","text":"How it looks like","level":2,"anchor":"How-it-looks-like"},{"type":"heading","text":"Actions","level":3,"anchor":"Actions"},{"type":"heading","text":"Button","level":4,"anchor":"Button"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Sosh.png","type":"image"}]},{"type":"heading","text":"Content display","level":3,"anchor":"Content-display"},{"type":"heading","text":"Bullet list","level":4,"anchor":"Bullet-list"}