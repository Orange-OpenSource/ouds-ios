r link configuration: theme.link","        \/\/ Etc.","    }","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"How-to-tune-the-theme","text":"How to tune the theme"},{"inlineContent":[{"text":"You cannot tune the Sosh theme.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Typography","text":"Typography"},{"inlineContent":[{"text":"The Sosh theme uses its Sosh font and must not use others.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"How-to-enrich-the-theme","text":"How to enrich the theme"},{"inlineContent":[{"text":"You cannot derivate the Sosh theme.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"How-it-looks-like","text":"How it looks like"},{"level":3,"type":"heading","anchor":"Actions","text":"Actions"},{"level":4,"type":"heading","anchor":"Button","text":"Button"},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Sosh.png"}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Content-display","text":"Content display"},{"level":4,"type":"heading","anchor":"Bullet-list","text":"Bullet list"},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_bullet_list_Sosh.png"}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Controls","text":"Controls"},{"level":4,"type":"heading","anchor":"Checkboxes","text":"Checkboxes"},{"type":"tabNavigator","tabs":[{"title":"Checkbox","content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_Sosh.png","type":"image"}],"type":"paragraph"}]},{"title":"Checkbox item","content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_Sosh.png","type":"image"}],"type":"paragraph"}]}]},{"level":4,"type