{"sections":[],"metadata":{"role":"collection","modules":[{"name":"Theme Sosh"}],"symbolKind":"module","externalID":"OUDSThemesSosh","title":"Theme Sosh","images":[{"type":"icon","identifier":"ic_theme_sosh.png"}],"roleHeading":"Library"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/oudsthemessosh"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh"},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"code":["🧬 Theme version: 2.3.0"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"This is the Sosh theme any Sosh product must use, and cannot be subclassed.","type":"text"},{"text":" ","type":"text"},{"text":"It embeds also in its target the Sosh brand colors which are not shared nor exposed in lower level targets or outside any module not depending to it.","type":"text"},{"text":" ","type":"text"},{"text":"In other words, this ","type":"text"},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true,"type":"reference"},{"text":" is based on the abstract ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":", uses all the ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange Unified Design System"}],"type":"emphasis"},{"text":" kit and brings the Sosh brand colors and assets.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is."}]}],"name":"Tip","type":"aside","style":"tip"},{"content":[{"inlineContent":[{"text":"The Sosh theme does not embed colors for charts yet and is read only: it cannot be subclassed or derivated","type":"text"}],"type":"paragraph"}],"name":"Important","type":"aside","style":"important"},{"level":2,"text":"How to use the theme","type":"heading","anchor":"How-to-use-the-theme"},{"inlineContent":[{"type":"text","text":"You can use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" directly. To use the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"text":" without further modifications, you will have to use the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" for your root view and give it an instance of ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true},{"text":". Keep in mind the themes are ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"type":"codeListing"},{"text":"How to tune the theme","anchor":"How-to-tune-the-theme","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"You cannot tune the Sosh theme."}],"type":"paragraph"},{"text":"Typography","anchor":"Typography","level":2,"type":"heading"},{"inlineContent":[{"text":"The Sosh theme uses its Sosh font and must not use others.","type":"text"}],"type":"paragraph"},{"text":"How to enrich the theme","anchor":"How-to-enrich-the-theme","level":2,"type":"heading"},{"inlineContent":[{"text":"You cannot derivate the Sosh theme.","type":"text"}],"type":"paragraph"},{"text":"How it looks like","anchor":"How-it-looks-like","level":2,"type":"heading"},{"text":"Actions","anchor":"Actions","level":3,"type":"heading"},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Sosh.png"}],"type":"paragraph"},{"text":"Controls","anchor":"Controls","level":3,"type":"heading"},{"text":"Checkboxes","anchor":"Checkboxes","level":4,"type":"heading"},{"tabs":[{"title":"Checkbox","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_Sosh.png"}]}]},{"title":"Checkbox item","content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_Sosh.png","type":"image"}]}]}],"type":"tabNavigator"},{"text":"Radios","anchor":"Radios","level":4,"type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radio_Sosh.png","type":"image"}],"type":"paragraph"}],"title":"Radio"},{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUD