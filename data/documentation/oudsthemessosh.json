{"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"syntax":null,"code":["🧬 Theme version: 2.2.0"],"type":"codeListing"},{"inlineContent":[{"text":"This is the Sosh theme any Sosh product must use, and cannot be subclassed.","type":"text"},{"text":" ","type":"text"},{"text":"It embeds also in its target the Sosh brand colors which are not shared nor exposed in lower level targets or outside any module not depending to it.","type":"text"},{"text":" ","type":"text"},{"text":"In other words, this ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","type":"reference"},{"text":" is based on the abstract ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":", uses all the ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange Unified Design System"}],"type":"emphasis"},{"text":" kit and brings the Sosh brand colors and assets.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is.","type":"text"}]}],"style":"tip","name":"Tip","type":"aside"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The Sosh theme does not embed colors for charts yet and is read-only: it cannot be subclassed or derivated"}]}],"style":"important","name":"Important","type":"aside"},{"level":2,"anchor":"How-to-use-the-theme","type":"heading","text":"How to use the theme"},{"inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" directly. To use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class objects"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}],"type":"paragraph"},{"syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}],"type":"paragraph"},{"syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"type":"codeListing"},{"level":2,"anchor":"How-to-tune-the-theme","type":"heading","text":"How to tune the theme"},{"inlineContent":[{"type":"text","text":"You cannot tune the Sosh theme."}],"type":"paragraph"},{"level":2,"anchor":"Typography","type":"heading","text":"Typography"},{"inlineContent":[{"type":"text","text":"The Sosh theme uses its Sosh font and must not use others."}],"type":"paragraph"},{"level":2,"anchor":"How-to-enrich-the-theme","type":"heading","text":"How to enrich the theme"},{"inlineContent":[{"type":"text","text":"You cannot derivate the Sosh theme."}],"type":"paragraph"},{"level":2,"anchor":"How-it-looks-like","type":"heading","text":"How it looks like"},{"level":3,"anchor":"Actions","type":"heading","text":"Actions"},{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Sosh.png"}],"type":"paragraph"},{"level":3,"anchor":"Controls","type":"heading","text":"Controls"},{"level":4,"anchor":"Checkboxes","type":"heading","text":"Checkboxes"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_Sosh.png","type":"image"}]}],"title":"Checkbox"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_Sosh.png","type":"image"}]}],"title":"Checkbox item"}],"type":"tabNavigator"},{"level":4,"anchor":"Radios","text":"Radios","type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radio_Sosh.png"}],"type":"paragraph"}],"title":"Radio"},{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radioItem_Sosh.png"}],"type":"paragraph"}],"title":"Radio item"}],"type":"tabNavigator"},{"level":4,"anchor":"Switches","text":"Switches","type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_switch_Sosh.png"}],"type":"paragraph"}],"title":"Switch"},{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange