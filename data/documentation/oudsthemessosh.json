nge Unified Design System","type":"text"}]},{"type":"text","text":" kit and brings the Sosh brand colors and assets."}]},{"type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is."}]}],"style":"tip"},{"type":"aside","name":"Important","content":[{"inlineContent":[{"type":"text","text":"The Sosh theme does not embed colors for charts yet and is read only: it cannot be subclassed or derivated"}],"type":"paragraph"}],"style":"important"},{"type":"heading","anchor":"How-to-use-the-theme","level":2,"text":"How to use the theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true},{"type":"text","text":" directly. To use the "},{"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}]},{"code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"How-to-tune-the-theme","text":"How to tune the theme","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You cannot tune the Sosh theme."}]},{"anchor":"Typography","text":"Typography","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Sosh theme uses its Sosh font and must not use others."}]},{"anchor":"How-to-enrich-the-theme","text":"How to enrich the theme","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the Sosh theme.","type":"text"}]},{"anchor":"How-it-looks-like","text":"How it looks like","type":"heading","level":2},{"anchor":"Actions","text":"Actions","type":"heading","level":3},{"anchor":"Button","text":"Button","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Sosh.png","type":"image"}]},{"anchor":"Content-display","text":"Content display","type":"heading","level":3},{"anchor":"Bullet-list","text":"Bullet list","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_bullet_list_Sosh.png",