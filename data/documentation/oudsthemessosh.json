{"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh"},"hierarchy":{"paths":[[]]},"abstract":[{"text":"The Sosh theme is the theme dedicated to the Sosh brand only.","type":"text"}],"metadata":{"symbolKind":"module","title":"Theme Sosh","modules":[{"name":"Theme Sosh"}],"externalID":"OUDSThemesSosh","roleHeading":"Library","role":"collection","images":[{"type":"icon","identifier":"ic_theme_sosh.png"}]},"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"codeListing","code":["🧬 Theme version: 2.1.0"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"This is the Sosh theme any Sosh product must use, and cannot be subclassed.","type":"text"},{"text":" ","type":"text"},{"text":"It embeds also in its target the Sosh brand colors which are not shared nor exposed in lower level targets or outside any module not depending to it.","type":"text"},{"text":" ","type":"text"},{"text":"In other words, this ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true},{"text":" is based on the abstract ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":", uses all the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange Unified Design System"}]},{"text":" kit and brings the Sosh brand colors and assets.","type":"text"}]},{"type":"aside","name":"Tip","style":"tip","content":[{"inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is."}],"type":"paragraph"}]},{"type":"aside","name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"The Sosh theme does not embed colors for charts yet and is read-only: it cannot be subclassed or derivated"}],"type":"paragraph"}]},{"type":"heading","anchor":"How-to-use-the-theme","text":"How to use the theme","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","type":"reference","isActive":true},{"type":"text","text":" directly. To use the "},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","type":"reference","isActive":true},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","type":"reference","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class objects"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"type":"codeListing","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"How-to-tune-the-theme","text":"How to tune the theme","level":2},{"type":"paragraph","inlineContent":[{"text":"You cannot tune the Sosh theme.","type":"text"}]},{"type":"heading","anchor":"Typography","text":"Typography","level":2},{"type":"paragraph","inlineContent":[{"text":"The Sosh theme uses its Sosh font and must not use others.","type":"text"}]},{"type":"heading","anchor":"How-to-enrich-the-theme","text":"How to enrich the theme","level":2},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the Sosh theme.","type":"text"}]},{"type":"heading","anchor":"How-it-looks-like","text":"How it looks like","level":2},{"type":"heading","anchor":"Actions","text":"Actions","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Sosh.png"}]},{"type":"heading","anchor":"Controls","text":"Controls","level":3},{"type":"heading","anchor":"Checkboxes","text":"Checkboxes","level":4},{"type":"tabNavigator","tabs":[{"title":"Checkbox","content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_Sosh.png"}],"type":"paragraph"}]},{"title":"Checkbox item","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_Sosh.png"}]}]}]},{"type":"heading","anchor":"Radios","text":"Radios","level":4},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radio_Sosh.png"}]}],"title":"Radio"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.ora