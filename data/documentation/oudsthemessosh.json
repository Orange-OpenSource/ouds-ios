{"metadata":{"images":[{"identifier":"ic_theme_sosh.png","type":"icon"}],"roleHeading":"Library","externalID":"OUDSThemesSosh","role":"collection","title":"Theme Sosh","symbolKind":"module","modules":[{"name":"Theme Sosh"}]},"abstract":[{"type":"text","text":"The Sosh theme is the theme dedicated to the Sosh brand only."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"codeListing","syntax":null,"code":["🧬 Theme version: 2.3.0"]},{"inlineContent":[{"type":"text","text":"This is the Sosh theme any Sosh product must use, and cannot be subclassed."},{"type":"text","text":" "},{"type":"text","text":"It embeds also in its target the Sosh brand colors which are not shared nor exposed in lower level targets or outside any module not depending to it."},{"type":"text","text":" "},{"type":"text","text":"In other words, this "},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","type":"reference","isActive":true},{"type":"text","text":" is based on the abstract "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":", uses all the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange Unified Design System"}]},{"type":"text","text":" kit and brings the Sosh brand colors and assets."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is."}]}],"type":"aside","style":"tip","name":"Tip"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The Sosh theme does not embed colors for charts yet and is read only: it cannot be subclassed or derivated"}]}],"type":"aside","style":"important","name":"Important"},{"level":2,"type":"heading","text":"How to use the theme","anchor":"How-to-use-the-theme"},{"inlineContent":[{"type":"text","text":"You can use "},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","type":"reference","isActive":true},{"type":"text","text":" directly. To use the "},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","type":"reference","isActive":true},{"type":"text","text":" without further modifications, you will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","type":"reference","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class objects"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"level":2,"type":"heading","text":"How to tune the theme","anchor":"How-to-tune-the-theme"},{"inlineContent":[{"type":"text","text":"You cannot tune the Sosh theme."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Typography","anchor":"Typography"},{"inlineContent":[{"type":"text","text":"The Sosh theme uses its Sosh font and must not use others."}],"type":"paragraph"},{"level":2,"type":"heading","text":"How to enrich the theme","anchor":"How-to-enrich-the-theme"},{"inlineContent":[{"type":"text","text":"You cannot derivate the Sosh theme."}],"type":"paragraph"},{"level":2,"type":"heading","text":"How it looks like","anchor":"How-it-looks-like"},{"level":3,"type":"heading","text":"Actions","anchor":"Actions"},{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_button_Sosh.png","type":"image"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Controls","anchor":"Controls"},{"level":4,"type":"heading","text":"Checkboxes","anchor":"Checkboxes"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkbox_Sosh.png"}],"type":"paragraph"}],"title":"Checkbox"},{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_checkboxItem_Sosh.png"}],"type":"paragraph"}],"title":"Checkbox item"}]},{"level":4,"type":"heading","text":"Radios","anchor":"Radios"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radio_Sosh.png"}],"type":"paragraph"}],"title":"Radio"},{"content":[{"inlineContent":[{"type":"image","identifier":"https:\/\/ios.unified-design-system.orange.com\/images\/OUDSComponents\/component_radioItem_Sosh.png"}],"type":"paragraph"}],"title":"Radio item"}]},{"leve