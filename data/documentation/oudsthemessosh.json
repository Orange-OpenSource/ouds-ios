 it."},{"type":"text","text":" "},{"type":"text","text":"In other words, this "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme"},{"type":"text","text":" is based on the abstract "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":", uses all the "},{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System","type":"text"}]},{"type":"text","text":" kit and brings the Sosh brand colors and assets."}],"type":"paragraph"},{"style":"tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This theme embeds and registers the fonts for the Sosh theme, you just need to use the theme object as is."}]}],"name":"Tip","type":"aside"},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"The Sosh theme does not embed colors for charts yet and is read only: it cannot be subclassed or derivated","type":"text"}]}],"name":"Important","type":"aside"},{"text":"How to use the theme","anchor":"How-to-use-the-theme","level":2,"type":"heading"},{"inlineContent":[{"text":"You can use ","type":"text"},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true,"type":"reference"},{"text":" directly. To use the ","type":"text"},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true,"type":"reference"},{"text":" without further modifications, you will have to use the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" for your root view and give it an instance of ","type":"text"},{"identifier":"doc:\/\/OUDSThemesSosh\/documentation\/OUDSThemesSosh\/SoshTheme","isActive":true,"type":"reference"},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: SoshTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","        \/\/ For button configuration: theme.button","        \/\/ For link configuration: theme.link","        \/\/ Etc.","    }","}"]},{"anchor":"How-to-tune-the-theme","type":"heading","level":2,"text":"How to tune the theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You cannot tune the Sosh theme."}]},{"anchor":"Typography","type":"heading","level":2,"text":"Typography"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Sosh theme uses its Sosh font and must not use others."}]},{"anchor":"How-to-enrich-the-theme","type":"heading","level":2,"text":"How to enrich the theme"},{"type":"paragraph","inlineContent":[{"text":"You cannot derivate the Sosh theme.","type":"text"}]},{"anchor":"How-it-looks-like","type":"heading","level":2,"text":"How it looks like"},{"anchor":"Actions","type":"heading","level":3,"text":"Actions"},{"anchor":"Button","type":"heading","level":4,"text":"Button"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/ios.