{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"anchor":"Badge","type":"heading","text":"Badge","level":3},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_OrangeCompact","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Wireframe","type":"image"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","type":"reference","isActive":true},{"type":"text","text":" is a small UI element used to highlight status, notifications, or categorization within an interface. It is often displayed as a label or indicator with a distinct background color and text."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Info badge in medium size without information","OUDSBadge(status: .info, size: .medium)","","\/\/ Negative badge in medium size with count information","OUDSBadge(count: 1, status: .negative, size: .medium)","","\/\/ Neutral badge in medium size with an image","OUDSBadge(status: .neutral(icon: Image(decorative: \"ic_heart\")), accessibilityLabel: \"Like\", size: .medium)"],"type":"codeListing"},{"anchor":"Tag","type":"heading","text":"Tag","level":3},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_OrangeCompact","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Wireframe","type":"image"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"An "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","type":"reference","isActive":true},{"type":"text","text":" is a small element that shows short information like a label, keyword, or category. It helps users quickly find, group, or understand content."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","\/\/ Or also","OUDSTag(label: \"Label\")","            ","\/\/ Tag with negative status with bullet","OUDSTag(label: \"Label\", status: .negative(leading: .bullet)","            ","\/\/ Tag with neutral status with a custom decorative icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","\/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","\/\/ you can flip the icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","            ","\/\/ Text with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","            ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"type":"codeListing"},{"anchor":"Input-Tag","type":"heading","text":"Input Tag","level":3},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_OrangeCompact","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Wireframe","type":"image"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"An "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag","type":"reference","isActive":true},{"type":"text","text":" is a small element that shows short information like a label, keyword, or category, which can be removed or changed on tap."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Create an input tag","OUDSInputTag(\"Label\") {","    \/\/ Do something, usually remove itself from a list","}","    ","\/\/ Show in a list and remove when clicked","var names: [String] = [ \"Foo\", \"Bar\", \"Wizz\" ]","    ","ForEach(names, id: \\.self) { name in","    OUDSInputTag(label: name) {","        if let index = names.firstIndex(of: name) {","            names.remove(at: index)","        }","    }","}"],"type":"codeListing"}]}],"kind":"article","variants":[{"paths":["\/documentation\/oudscomponents\/indicators"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"roleHeading":"Article","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"type":"card","identifier":"ic_folder_categories.png"}],"modules":[{"name":"Components"}],"title":"Indicators","role":"article"},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Some components can be used for "},{"inlineContent":[{"type":"text","text":"indicators"}],"type":"strong"},{"type":"text","text":"."}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSC