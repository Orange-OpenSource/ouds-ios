{"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"level":3,"text":"Badge","type":"heading","anchor":"Badge"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_badge_OrangeBusinessTools"}]}],"title":"Orange Business Tools"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_badge_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","type":"reference"},{"text":" is a small UI element used to highlight status, notifications, or categorization within an interface. It is often displayed as a label or indicator with a distinct background color and text.","type":"text"}],"type":"paragraph"},{"tabs":[{"title":"SwiftUI","content":[{"code":["    \/\/ Neutral badge in medium size without information","    OUDSBadge(status: .neutral, size: .medium)","","    \/\/ Negative badge in medium size with count information","    OUDSBadge(count: 1, status: .negative, size: .medium)","","    \/\/ Info badge in medium size with icon information","    OUDSBadge(icon: Image(\"ic_heart\"), status: .info, size: .medium)"],"syntax":"swift","type":"codeListing"}]},{"title":"UIKit (experimental)","content":[{"type":"codeListing","syntax":"swift","code":["    import OUDSComponentsUIKit","    ","    \/\/ Neutral badge in medium size without information","    OUDSUIKit.createBadge(status: .neutral, size: .medium)","","    \/\/ Negative badge in medium size with count information","    OUOUDSUIKit.createBadgeDSBadge(count: 1, status: .negative, size: .medium)","","    \/\/ Info badge in medium size with icon information","    OUDSUIKit.createBadge(icon: Image(\"ic_heart\"), status: .info, size: .medium)"]}]}],"type":"tabNavigator"},{"level":3,"text":"Tag","type":"heading","anchor":"Tag"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Orange"}]}]},{"title":"Orange Business Tools","content":[{"inlineContent":[{"identifier":"component_tag_OrangeBusinessTools","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Wireframe","type":"image"}]}]}],"type":"tabNavigator"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","isActive":true,"type":"reference"},{"text":" is a small element that shows short information like a label, keyword, or category. It helps users quickly find, group, or understand content.","type":"text"}],"type":"paragraph"},{"tabs":[{"title":"SwiftUI","content":[{"type":"codeListing","syntax":"swift","code":["\/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","\/\/ Or also","OUDSTag(label: \"Label\")","    ","\/\/ Tag with negative status with bullet","OUDSTag(label: \"Label\", status: .negative(leading: .bullet)","    ","\/\/ Tag with neutral status with a custom decorative icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","\/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","\/\/ you can flip the icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","    ","\/\/ Text with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","    ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]}]},{"title":"UIKit (experimental)","content":[{"syntax":"swift","type":"codeListing","code":["import OUDSComponentsUIKit","    ","\/\/ Text only with neutral status, for emphasized hierarchy with rounded shape in default size            ","OUDSUIKit.createTag(label: \"label\",","                    status: .neutral,","                    appearance: .emphasized,","                    shape: .rounded,","                    size: .default,","\/\/ Or also","OUDSUIKit.createTag(label: \"label\")","    ","\/\/ ext with bullet and negative status, using default hierarchy (emphasized), shape (rounded) and size (default)","    OUDSUIKit.createTag(label: \"Label\", status: .negative(leading: .bullet)","","\/\/ Tag with label and icon with image","OUDSUIKit.createTag((label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","","\/\/ Tag with label and loader","OUDSUIKit.createTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]}]}],"type":"tabNavigator"},{"level":3,"text":"Input Tag","type":"heading","anchor":"Input-Tag"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_Orange"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_OrangeBusinessTools"}]}],"title":"Orange Business Tools"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_Sosh"}]}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\