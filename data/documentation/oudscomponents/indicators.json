{"kind":"article","primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"text":"Badge","type":"heading","anchor":"Badge","level":3},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Orange","type":"image"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_OrangeCompact","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Wireframe","type":"image"}]}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","isActive":true,"type":"reference"},{"text":" is a small UI element used to highlight status, notifications, or categorization within an interface. It is often displayed as a label or indicator with a distinct background color and text.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Info badge in medium size without information","OUDSBadge(status: .info, size: .medium)","","\/\/ Negative badge in medium size with count information","OUDSBadge(count: 1, status: .negative, size: .medium)","","\/\/ Neutral badge in medium size with an image","OUDSBadge(status: .neutral(icon: Image(decorative: \"ic_heart\")), accessibilityLabel: \"Like\", size: .medium)"]},{"text":"Tag","type":"heading","anchor":"Tag","level":3},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Orange","type":"image"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_OrangeCompact","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Wireframe","type":"image"}]}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","isActive":true,"type":"reference"},{"text":" is a small element that shows short information like a label, keyword, or category. It helps users quickly find, group, or understand content.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","\/\/ Or also","OUDSTag(label: \"Label\")","            ","\/\/ Tag with negative status with bullet","OUDSTag(label: \"Label\", status: .negative(leading: .bullet)","            ","\/\/ Tag with neutral status with a custom decorative icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","\/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","\/\/ you can flip the icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","            ","\/\/ Text with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","            ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]},{"text":"Input Tag","type":"heading","anchor":"Input-Tag","level":3},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Orange","type":"image"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_OrangeCompact","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Wireframe","type":"image"}]}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag","isActive":true,"type":"reference"},{"text":" is a small element that shows short information like a label, keyword, or category, which can be removed or changed on tap.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Create an input tag","OUDSInputTag(\"Label\") {","    \/\/ Do something, usually remove itself from a list","}","    ","\/\/ Show in a list and remove when clicked","var names: [String] = [ \"Foo\", \"Bar\", \"Wizz\" ]","    ","ForEach(names, id: \\.self) { name in","    OUDSInputTag(label: name) {","        if let index = names.firstIndex(of: name) {","            names.remove(at: index)","        }","    }","}"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudscomponents\/indicators"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"},"metadata":{"modules":[{"name":"Components"}],"role":"article","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"roleHeading":"Article","title":"Indicators"},"abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"text":"indicators","type":"text"}]},{"text":".","type":"text"}],"references":{"component_tag_Wireframe":{"alt":"A tag component in light and dark modes with Wireframe theme","type":"image","identifier":"component_tag_Wireframe","va