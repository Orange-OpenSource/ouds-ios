{"kind":"article","hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"text":"indicators","type":"text"}]},{"text":".","type":"text"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/indicators"]}],"metadata":{"title":"Indicators","roleHeading":"Article","role":"article","modules":[{"name":"Components"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}]},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"level":3,"text":"Badge","type":"heading","anchor":"Badge"},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"type":"image","identifier":"component_badge_Orange"}],"type":"paragraph"}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_badge_OrangeBusinessTools"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_badge_Sosh"}]}]},{"content":[{"inlineContent":[{"type":"image","identifier":"component_badge_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","type":"reference","isActive":true},{"type":"text","text":" is a small UI element used to highlight status, notifications, or categorization within an interface. It is often displayed as a label or indicator with a distinct background color and text."}],"type":"paragraph"},{"tabs":[{"title":"SwiftUI","content":[{"syntax":"swift","type":"codeListing","code":["    \/\/ Neutral badge in medium size without information","    OUDSBadge(status: .neutral, size: .medium)","","    \/\/ Negative badge in medium size with count information","    OUDSBadge(count: 1, status: .negative, size: .medium)","","    \/\/ Info badge in medium size with icon information","    OUDSBadge(icon: Image(\"ic_heart\"), status: .info, size: .medium)"]}]},{"title":"UIKit (experimental)","content":[{"type":"codeListing","syntax":"swift","code":["    import OUDSComponentsUIKit","    ","    \/\/ Neutral badge in medium size without information","    OUDSUIKit.createBadge(status: .neutral, size: .medium)","","    \/\/ Negative badge in medium size with count information","    OUOUDSUIKit.createBadgeDSBadge(count: 1, status: .negative, size: .medium)","","    \/\/ Info badge in medium size with icon information","    OUDSUIKit.createBadge(icon: Image(\"ic_heart\"), status: .info, size: .medium)"]}]}],"type":"tabNavigator"},{"level":3,"anchor":"Tag","text":"Tag","type":"heading"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Orange"}]}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_OrangeBusinessTools"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Sosh"}]}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_tag_Wireframe"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag"},{"type":"text","text":" is a small element that shows short information like a label, keyword, or category. It helps users quickly find, group, or understand content."}],"type":"paragraph"},{"tabs":[{"content":[{"code":["\/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","\/\/ Or also","OUDSTag(label: \"Label\")","    ","\/\/ Tag with negative status with bullet","OUDSTag(label: \"Label\", status: .negative(leading: .bullet)","    ","\/\/ Tag with neutral status with a custom decorative icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","\/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","\/\/ you can flip the icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","    ","\/\/ Text with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","    ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"syntax":"swift","type":"codeListing"}],"title":"SwiftUI"},{"content":[{"type":"codeListing","syntax":"swift","code":["import OUDSComponentsUIKit","    ","\/\/ Text only with neutral status, for emphasized hierarchy with rounded shape in default size            ","OUDSUIKit.createTag(label: \"label\",","                    status: .neutral,","                    appearance: .emphasized,","                    shape: .rounded,","                    size: .default,","\/\/ Or also","OUDSUIKit.createTag(label: \"label\")","    ","\/\/ ext with bullet and negative status, using default hierarchy (emphasized), shape (rounded) and size (default)","    OUDSUIKit.createTag(label: \"Label\", status: .negative(leading: .bullet)","","\/\/ Tag with label and icon with image","OUDSUIKit.createTag((label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","","\/\/ Tag with label and loader","OUDSUIKit.createTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]}],"title":"UIKit (experimental)"}],"type":"tabNavigator"},{"anchor":"Input-Tag","type":"heading","level":3,"text":"Input Tag"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_OrangeBusinessTools"}],"type":"paragraph"}],"title":"Orange Business Tools"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_Sosh"}]}],"title":"Sosh"},{"content":[{"inlineContent":[{"identifier":"component_inputTag_Wireframe","type":"image"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag","isActive":true,"type":"reference"},{"text":" is a small element that shows short information like a label, keyword, or category, which can be removed or changed on tap.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Create an input tag","OUDSInputTag(\"Label\") {","    \/\/ Do something, usually remove itself from a list","}","    ","\/\/ Show in a list and remove when clicked","var names: [String] = [ \"Foo\", \"Bar\", \"Wizz\" ]","    ","ForEach(names, id: \\.self) { name in","    OUDSInputTag(label: name) {","        if let index = names.firstIndex(of: name) {","            names.remove(at: index)","        }","    }","}"]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"component_badge_OrangeBusinessTools":{"alt":"A badge component in light and dark mode with Orange Business Tools theme","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_badge_OrangeBusinessTools.png"}],"identifier":"component_badge_OrangeBusinessTools"},"ic_folder_categories.png":{"type":"image","variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png","alt":null},"component_badge_Sosh"