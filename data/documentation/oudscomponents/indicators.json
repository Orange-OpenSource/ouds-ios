{"kind":"article","primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"anchor":"Badge","type":"heading","level":3,"text":"Badge"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_badge_Orange"}]}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_badge_OrangeBusinessTools"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_badge_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_badge_Wireframe"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","isActive":true},{"type":"text","text":" is a small UI element used to highlight status, notifications, or categorization within an interface. It is often displayed as a label or indicator with a distinct background color and text."}]},{"type":"tabNavigator","tabs":[{"content":[{"code":["    \/\/ Info badge in medium size without information","    OUDSBadge(status: .info, size: .medium)","","    \/\/ Negative badge in medium size with count information","    OUDSBadge(count: 1, status: .negative, size: .medium)","","    \/\/ Neutral badge in medium size with an image","    OUDSBadge(status: .neutral(icon: Image(decorative: \"ic_heart\")), accessibilityLabel: \"Like\", size: .medium)"],"type":"codeListing","syntax":"swift"}],"title":"SwiftUI"},{"content":[{"type":"codeListing","syntax":"swift","code":["    import OUDSComponentsUIKit","    ","    \/\/ Info badge in medium size without information","    OUDSUIKit.createBadge(status: .info, size: .medium)","","    \/\/ Negative badge in medium size with count information","    OUOUDSUIKit.createBadge(count: 1, status: .negative, size: .medium)","","    \/\/ Neutral badge in medium size with an image","    OUDSUIKit.createBadge(status: .neutral(icon: Image(decorative: \"ic_heart\")), accessibilityLabel: \"Like\", size: .medium)"]}],"title":"UIKit (experimental)"}]},{"type":"heading","text":"Tag","level":3,"anchor":"Tag"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_OrangeBusinessTools"}]}],"title":"Orange Business Tools"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Sosh"}]}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tag_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","isActive":true},{"text":" is a small element that shows short information like a label, keyword, or category. It helps users quickly find, group, or understand content.","type":"text"}]},{"type":"tabNavigator","tabs":[{"content":[{"type":"codeListing","code":["\/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","\/\/ Or also","OUDSTag(label: \"Label\")","    ","\/\/ Tag with negative status with bullet","OUDSTag(label: \"Label\", status: .negative(leading: .bullet)","    ","\/\/ Tag with neutral status with a custom decorative icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","\/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","\/\/ you can flip the icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","    ","\/\/ Text with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","    ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"syntax":"swift"}],"title":"SwiftUI"},{"content":[{"code":["import OUDSComponentsUIKit","    ","\/\/ Text only with neutral status, for emphasized hierarchy with rounded shape in default size            ","OUDSUIKit.createTag(label: \"label\",","                    status: .neutral,","                    appearance: .emphasized,","                    shape: .rounded,","                    size: .default,","\/\/ Or also","OUDSUIKit.createTag(label: \"label\")","    ","\/\/ ext with bullet and negative status, using default hierarchy (emphasized), shape (rounded) and size (default)","    OUDSUIKit.createTag(label: \"Label\", status: .negative(leading: .bullet)","","\/\/ Tag with label and icon with image","OUDSUIKit.createTag((label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","","\/\/ Tag with label and loader","OUDSUIKit.createTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"syntax":"swift","type":"codeListing"}],"title":"UIKit (experimental)"}]},{"type":"heading","level":3,"anchor":"Input-Tag","text":"Input Tag"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_OrangeBusinessTools"}],"type":"paragraph"}],"title":"Orange Business Tools"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}]},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag","isActive":true},{"text":" is a small element that shows short information like a label, keyword, or category, which can be removed or changed on tap.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Create an input tag","OUDSInputTag(\"Label\") {","    \/\/ Do something, usually remove itself from a list","}","    ","\/\/ Show in a list and remove when clicked","var names: [String] = [ \"Foo\", \"Bar\", \"Wizz\" ]","    ","ForEach(names, id: \\.self) { name in","    OUDSInputTag(label: name) {","        if let index = names.firstIndex(of: name) {","            names.remove(at: index)","        }","    }","}"],"syntax":"swift"}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/indicators"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"modules":[{"name":"Components"}],"roleHeading":"Article","role":"article","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"title":"Indicators"},"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"indicators"}]},{"text":".","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators","interfaceLanguage":"swift"},"references":{"component_tag_OrangeBusinessTools":{"identifier":"component_tag_OrangeBusinessTools","alt":"A tag component in light and dark modes with Orange Business Tools theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tag_OrangeBusinessTools.png"}],"type":"image"},"component_badge_Orange":{"identifier":"component_badge_Orange","alt":"A badge component in light and dark modes with Orange theme","variants":[{"traits":["1x","