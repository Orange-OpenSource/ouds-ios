{"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"indicators","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"anchor":"Badge","level":3,"text":"Badge","type":"heading"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_OrangeCompact","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Wireframe","type":"image"}]}],"title":"Wireframe"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","type":"reference","isActive":true},{"text":" is a small UI element used to highlight status, notifications, or categorization within an interface. It is often displayed as a label or indicator with a distinct background color and text.","type":"text"}]},{"code":["\/\/ Info badge in medium size without information","OUDSBadge(status: .info, size: .medium)","","\/\/ Negative badge in medium size with count information","OUDSBadge(count: 1, status: .negative, size: .medium)","","\/\/ Neutral badge in medium size with an image","OUDSBadge(status: .neutral(icon: Image(decorative: \"ic_heart\")), accessibilityLabel: \"Like\", size: .medium)"],"type":"codeListing","syntax":"swift"},{"level":3,"text":"Tag","anchor":"Tag","type":"heading"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_OrangeCompact","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Wireframe","type":"image"}]}],"title":"Wireframe"}]},{"inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","type":"reference"},{"text":" is a small element that shows short information like a label, keyword, or category. It helps users quickly find, group, or understand content.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","\/\/ Or also","OUDSTag(label: \"Label\")","            ","\/\/ Tag with negative status with bullet","OUDSTag(label: \"Label\", status: .negative(leading: .bullet)","            ","\/\/ Tag with neutral status with a custom decorative icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","\/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","\/\/ you can flip the icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","            ","\/\/ Text with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","            ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"type":"codeListing","syntax":"swift"},{"level":3,"text":"Input Tag","anchor":"Input-Tag","type":"heading"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_Orange"}]}],"title":"Orange"},{"content":[{"type":"p