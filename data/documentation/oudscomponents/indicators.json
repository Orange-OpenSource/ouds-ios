{"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"text":"indicators","type":"text"}]},{"type":"text","text":"."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/indicators"]}],"metadata":{"modules":[{"name":"Components"}],"roleHeading":"Article","role":"article","title":"Indicators","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"},"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"anchor":"Badge","level":3,"type":"heading","text":"Badge"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Orange","type":"image"}]}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_OrangeBusinessTools","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Wireframe","type":"image"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge"},{"text":" is a small UI element used to highlight status, notifications, or categorization within an interface. It is often displayed as a label or indicator with a distinct background color and text.","type":"text"}]},{"type":"tabNavigator","tabs":[{"title":"SwiftUI","content":[{"code":["    \/\/ Neutral badge in medium size without information","    OUDSBadge(status: .neutral, size: .medium)","","    \/\/ Negative badge in medium size with count information","    OUDSBadge(count: 1, status: .negative, size: .medium)","","    \/\/ Info badge in medium size with icon information","    OUDSBadge(icon: Image(\"ic_heart\"), status: .info, size: .medium)"],"type":"codeListing","syntax":"swift"}]},{"title":"UIKit (experimental)","content":[{"code":["    import OUDSComponentsUIKit","    ","    \/\/ Neutral badge in medium size without information","    OUDSUIKit.createBadge(status: .neutral, size: .medium)","","    \/\/ Negative badge in medium size with count information","    OUOUDSUIKit.createBadgeDSBadge(count: 1, status: .negative, size: .medium)","","    \/\/ Info badge in medium size with icon information","    OUDSUIKit.createBadge(icon: Image(\"ic_heart\"), status: .info, size: .medium)"],"type":"codeListing","syntax":"swift"}]}]},{"anchor":"Tag","level":3,"type":"heading","text":"Tag"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Orange","type":"image"}]}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_OrangeBusinessTools","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Wireframe","type":"image"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag"},{"type":"text","text":" is a small element that shows short information like a label, keyword, or category. It helps users quickly find, group, or understand content."}]},{"type":"tabNavigator","tabs":[{"title":"SwiftUI","content":[{"type":"codeListing","syntax":"swift","code":["\/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","\/\/ Or also","OUDSTag(label: \"Label\")","    ","\/\/ Tag with negative status with bullet","OUDSTag(label: \"Label\", status: .negative(leading: .bullet)","    ","\/\/ Tag with neutral status with a custom decorative icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","\/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","\/\/ you can flip the icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","    ","\/\/ Text with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","    ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]}]},{"title":"UIKit (experimental)","content":[{"type":"codeListing","code":["import OUDSComponentsUIKit","    ","\/\/ Text only with neutral status, for emphasized hierarchy with rounded shape in default size            ","OUDSUIKit.createTag(label: \"label\",","                    status: .neutral,","                    appearance: .emphasized,","                    shape: .rounded,","                    size: .default,","\/\/ Or also","OUDSUIKit.createTag(label: \"label\")","    ","\/\/ ext with bullet and negative status, using default hierarchy (emphasized), shape (rounded) and size (default)","    OUDSUIKit.createTag(label: \"Label\", status: .negative(leading: .bullet)","","\/\/ Tag with label and icon with image","OUDSUIKit.createTag((label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","","\/\/ Tag with label and loader","OUDSUIKit.createTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"syntax":"swift"}]}]},{"anchor":"Input-Tag","level":3,"type":"heading","text":"Input Tag"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_inputTag_Orange","type":"image"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"component_inputTag_OrangeBusinessTools","type":"image"}],"type":"paragraph"}],"title":"Orange Business Tools"},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_Sosh"}]}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_Wireframe"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"An "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag"},{"type":"text","text":" is a small element that shows short information like a label, keyword, or category, which can be removed or changed on tap."}],"type":"paragraph"},{"code":["\/\/ Create an input tag","OUDSInputTag(\"Label\") {","    \/\/ Do something, usually remove itself from a list","}","    ","\/\/ Show in a list and remove when clicked","var names: [String] = [ \"Foo\", \"Bar\", \"Wizz\" ]","    ","ForEach(names, id: \\.self) { name in","    OUDSInputTag(label: name) {","        if let index = names.firstIndex(of: name) {","            names.remove(at: index)","        }","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"kind":"article","sections":[],"references":{"component_inputTag_Wireframe":{"variants":[{"url":"\/images\/OUDSComponents\/component_inputTag_Wireframe.png","traits":["1x","light"]}],"alt":"An input tag component in light and dark mode with Wireframe theme","type":"image","identifier":"component_inputTag_Wireframe"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTag":{"kind":"symbol","title":"OUDSTag","type":"topic","navigatorTitle":[{"text":"OUDSTag","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTa