{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/indicators"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"heading","text":"Badge","anchor":"Badge","level":3},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Orange","type":"image"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_OrangeCompact","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Wireframe","type":"image"}]}]}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","isActive":true,"type":"reference"},{"text":" is a small UI element used to highlight status, notifications, or categorization within an interface. It is often displayed as a label or indicator with a distinct background color and text.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Info badge in medium size without information","OUDSBadge(status: .info, size: .medium)","","\/\/ Negative badge in medium size with count information","OUDSBadge(count: 1, status: .negative, size: .medium)","","\/\/ Neutral badge in medium size with an image","OUDSBadge(status: .neutral(icon: Image(decorative: \"ic_heart\")), accessibilityLabel: \"Like\", size: .medium)"],"syntax":"swift","type":"codeListing"},{"anchor":"Tag","type":"heading","level":3,"text":"Tag"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_tag_Orange"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tag_OrangeCompact"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tag_Sosh"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tag_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","type":"reference","isActive":true},{"text":" is a small element that shows short information like a label, keyword, or category. It helps users quickly find, group, or understand content.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","\/\/ Or also","OUDSTag(label: \"Label\")","            ","\/\/ Tag with negative status with bullet","OUDSTag(label: \"Label\", status: .negative(leading: .bullet)","            ","\/\/ Tag with neutral status with a custom decorative icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","\/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","\/\/ you can flip the icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","            ","\/\/ Text with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","            ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"syntax":"swift","type":"codeListing"},{"anchor":"Input-Tag","type":"heading","level":3,"text":"Input Tag"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_Orange"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_OrangeCompact"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_Sosh"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag","type":"reference","isActive":true},{"text":" is a small element that shows short information like a label, keyword, or category, which can be removed or changed on tap.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Create an input tag","OUDSInputTag(\"Label\") {","    \/\/ Do something, usually remove itself from a list","}","    ","\/\/ Show in a list and remove when clicked","var names: [String] = [ \"Foo\", \"Bar\", \"Wizz\" ]","    ","ForEach(names, id: \\.self) { name in","    OUDSInputTag(label: name) {","        if let index = names.firstIndex(of: name) {","            names.remove(at: index)","        }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"metadata":{"role":"article","title":"Indicators","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"modules":[{"name":"Components"}],"roleHeading":"Article"},"abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"text":"indicators","type":"text"}]},{"text":".","type":"text"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSInputTag":{"navigatorTitle":[{"text":"OUDSInputTag","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsinputtag","role":"symbol","type":"topic","title":"OUDSInputTag","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSInputTag","kind":"identifier"}],"abstract":[{"text":"Input tag is a UI element that allows to enter multiple values, each represented as a tag.","type":"text"},{"text":" ","type":"text"},{"text":"As users type and submit values (usually by pressing enter, comma, or tab), each value is transformed into a tag.","type":"text"},{"text":" ","type":"text"},{"text":"Input tag is often used for adding labels, categories, or participants.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag","kind":"symbol"},"ic_folder_categories.png":{"alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","identifier":"ic_folder_categories.png"},"component_tag_Orange":{"identifier":"component_tag_Orange","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tag_Orange.png"}],"alt":"A tag component in light and dark modes with Orange theme"},"component_badge_Orange":{"alt":"A badge component in light and dark modes with Orange theme","variants":[{"url":"\/images\/OUDSComponents\/component_badge_Orange.png","traits":["1x","light"]}],"type":"image","identifier":"component_badge_Orange"},"component_inputTag_Wireframe":{"identifier":"component_inputTag_Wireframe","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_inputTag_Wireframe.png"}],"alt":"An input tag component in light and dark modes with Wireframe theme"},"component_inputTag_OrangeCompact":{"alt":"An input tag component in light and dark modes with Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_inputTag_OrangeCompact.png","traits":["1x","light"]}],"type":"image","identifier":"component_inputTag_OrangeCompact"},"component_badge_Sosh":{"identi