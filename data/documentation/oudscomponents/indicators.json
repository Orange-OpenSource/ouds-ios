":"component_inputTag_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_Wireframe"}]}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag","type":"reference"},{"type":"text","text":" is a small element that shows short information like a label, keyword, or category, which can be removed or changed on tap."}]},{"syntax":"swift","code":["\/\/ Create an input tag","OUDSInputTag(\"Label\") {","    \/\/ Do something, usually remove itself from a list","}","    ","\/\/ Show in a list and remove when clicked","var names: [String] = [ \"Foo\", \"Bar\", \"Wizz\" ]","    ","ForEach(names, id: \\.self) { name in","    OUDSInputTag(label: name) {","        if let index = names.firstIndex(of: name) {","            names.remove(at: index)","        }","    }","}"],"type":"codeListing"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Some components can be used for "},{"inlineContent":[{"type":"text","text":"indicators"}],"type":"strong"},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/oudscomponents\/indicators"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","metadata":{"role":"article","title":"Indicators","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"type":"card","identifier":"ic_folder_categories.png"}],"roleHeading":"Article","modules":[{"name":"Components"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"},"references":{"component_badge_Sosh":{"variants":[{"url":"\/images\/OUDSComponents\/component_badge_Sosh.png","traits":["1x","light"]}],"identifier":"component_badge_S