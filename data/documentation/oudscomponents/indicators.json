t with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","            ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"type":"codeListing"},{"text":"Input Tag","level":3,"anchor":"Input-Tag","type":"heading"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_OrangeCompact"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_Sosh"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_inputTag_Wireframe"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag","isActive":true,"type":"reference"},{"text":" is a small element that shows short information like a label, keyword, or category, which can be removed or changed on tap.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Create an input tag","OUDSInputTag(\"Label\") {","    \/\/ Do something, usually remove itself from a list","}","    ","\/\/ Show in a list and remove when clicked","var names: [String] = [ \"Foo\", \"Bar\", \"Wizz\" ]","    ","ForEach(names, id: \\.self) { name in","    OUDSInputTag(label: name) {","        if let index = names.firstIndex(of: name) {","            names.remove(at: index)","        }","    }","}"],"type":"codeListing"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSTag":{"title":"OUDSTag","url":"\/documentation\/oudscomponents\/oudstag","type":"topic","abstract"