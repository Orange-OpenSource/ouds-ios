{"metadata":{"modules":[{"name":"Components"}],"roleHeading":"Article","title":"Indicators","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"role":"article"},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"text":"indicators","type":"text"}]},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"anchor":"Badge","text":"Badge","type":"heading","level":3},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_badge_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_badge_OrangeCompact"}]}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"identifier":"component_badge_Sosh","type":"image"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_badge_Wireframe","type":"image"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge"},{"text":" is a small UI element used to highlight status, notifications, or categorization within an interface. It is often displayed as a label or indicator with a distinct background color and text.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Info badge in medium size without information","OUDSBadge(status: .info, size: .medium)","","\/\/ Negative badge in medium size with count information","OUDSBadge(count: 1, status: .negative, size: .medium)","","\/\/ Neutral badge in medium size with an image","OUDSBadge(status: .neutral(icon: Image(decorative: \"ic_heart\")), accessibilityLabel: \"Like\", size: .medium)"]},{"anchor":"Tag","text":"Tag","type":"heading","level":3},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Orange"}]}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tag_OrangeCompact"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tag_Sosh"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Wireframe"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","isActive":true,"type":"reference"},{"text":" is a small element that shows short information like a label, keyword, or category. It helps users quickly find, group, or understand content.","type":"text"}]},{"code":["\/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","\/\/ Or also","OUDSTag(label: \"Label\")","            ","\/\/ Tag with negative status with bullet","OUDSTag(label: \"Label\", status: .negative(leading: .bullet)","            ","\/\/ Tag with neutral status with a custom decorative icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","\/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","\/\/ you can flip the icon","OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","            ","\/\/ Text with neutral status with bullet","OUDSTag(label: \"Label\", status: .neutral(bullet: true))","            ","\/\/ Tag with loader with rounded shape in small size","OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"type":"codeListing","syntax":"swift"},{"anchor":"Input-Tag","type":"heading","level":3,"text":"Input Tag"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_inputTag_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"inlineContent":[{"identifier":"component_inputTag_OrangeCompact","type":"image"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_Sosh"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_inputTag_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag","isActive":true},{"type":"text","text":" is a small element that shows short information like a label, keyword, or category, which can be removed or changed on tap."}]},{"code":["\/\/ Create an input tag","OUDSInputTag(\"Label\") {","    \/\/ Do something, usually remove itself from a list","}","    ","\/\/ Show in a list and remove when clicked","var names: [String] = [ \"Foo\", \"Bar\", \"Wizz\" ]","    ","ForEach(names, id: \\.self) { name in","    OUDSInputTag(label: name) {","        if let index = names.firstIndex(of: name) {","            names.remove(at: index)","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/indicators"]}],"sections":[],"references":{"component_tag_OrangeCompact":{"type":"image","alt":"A tag component in light and dark modes with Orange Compact theme","variants":[{"url":"\/images\/OUD