_badge_OrangeCompact.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBadge","kind":"identifier"}],"title":"OUDSBadge","kind":"symbol","abstract":[{"text":"Badge is a UI element that emphasizes system notifications, status, or the categorization of an information, throughout colour only.","type":"text"},{"text":" ","type":"text"},{"text":"Badge is rendered as a coloured shape, without icon, text or number; and its chosen size remains unchanged regardless of the changes of the interface size.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","navigatorTitle":[{"text":"OUDSBadge","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsbadge","role":"symbol"},"component_badge_Wireframe":{"alt":"A badge component in light and dark modes with Wireframe theme","identifier":"component_badge_Wireframe","variants":[{"url":"\/images\/OUDSComponents\/component_badge_Wireframe.png","traits":["1x","light"]}],"type":"image"},"component_inputTag_Orange":{"alt":"An input tag component in light and dark modes with Orange theme","identifier":"component_inputTag_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_inputTag_Orange.png","traits":["1x","light"]}],"type":"image"},"component_badge_Orange":{"alt":"A badge component in light and dark modes with Orange theme","identifier":"component_badge_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_badge_Orange.png","traits":["1x","light"]}],"type":"image"},"component_tag_OrangeCompact":{"alt":"A tag component in light and dark modes with Orange Compact theme","identifier":"component_tag_OrangeCompact","variants":[{"url":"\/images\/OUDSComponents\/component_tag_OrangeCompact.png","traits":["1x","light"]}],"type":"image"},"ic_folder_categories.png":{"alt":null,"identifier":"ic_folder_categories.p