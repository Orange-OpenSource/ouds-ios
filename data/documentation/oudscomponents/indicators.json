pic","title":"Components","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","kind":"symbol","url":"\/documentation\/oudscomponents"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSInputTag":{"title":"OUDSInputTag","abstract":[{"text":"Input tag is a UI element that allows to enter multiple values, each represented as a tag.","type":"text"},{"text":" ","type":"text"},{"text":"As users type and submit values (usually by pressing enter, comma, or tab), each value is transformed into a tag.","type":"text"},{"text":" ","type":"text"},{"text":"Input tag is often used for adding labels, categories, or participants.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSInputTag"}],"type":"topic","url":"\/documentation\/oudscomponents\/oudsinputtag","kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSInputTag"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInputTag"},"component_badge_Orange":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_badge_Orange.png"}],"alt":"A badge component in light and dark modes with Orange theme","identifier":"component_badge_Orange","type":"image"},"component_tag_Sosh":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tag_Sosh.png"}],"alt":"A tag component in light and dark modes with Sosh theme","identifier":"component_tag_Sosh","type":"image"},"component_tag_OrangeCompact":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tag_OrangeCompact.png"}],"alt":"A tag component in light and dark modes with Orange Compact theme","identifier":"component_tag_OrangeCompact","type":"image"},"component_inputTag_Wireframe":{"identifier":"component_inputTag_Wireframe","alt":"An input tag component in light and dark modes with Wireframe theme","var