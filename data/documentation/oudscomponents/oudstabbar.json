{"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","isActive":true,"type":"reference"},{"text":" is a SwiftUI ","type":"text"},{"type":"codeVoice","code":"TabView"},{"text":" which applies OUDS tokens and styles on its content supposing to be","type":"text"},{"text":" ","type":"text"},{"text":"views with ","type":"text"},{"inlineContent":[{"text":"tab bar items","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The tab bar is, for iOS, a bottom bar with tabs containing for example images, texts and badges.","type":"text"}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selected:count:content:)"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"title":"Instance Properties","anchor":"Instance-Properties"},{"title":"Default Implementations","anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier","text":"View"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"]},{"kind":"content","content":[{"text":"Appearances","type":"heading","level":2,"anchor":"Appearances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars."},{"type":"text","text":" "},{"type":"text","text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"background color of tab bar can be changed for iOS lower than 26","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"background color of tab bar does not change since iOS 26","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed","type":"text"},{"text":" ","type":"text"},{"text":"and not the text making theme not readable in dark color scheme","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","type":"reference","isActive":true},{"type":"text","text":" component,"},{"text":" ","type":"text"},{"type":"text","text":"the native API is used instead."}],"type":"paragraph"},{"inlineContent":[{"text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you use SF Symbols for images, if they exist their ","type":"text"},{"inlineContent":[{"type":"text","text":"fill"}],"type":"emphasis"},{"text":" variant will be automatically used in the tab bar (native behaviour).","type":"text"}],"type":"paragraph"},{"text":"Platform considerations","type":"heading","level":2,"anchor":"Platform-considerations"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"This component is tailored for iOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On iPadOS the tabs do not apply the fonts since iPadOS 18"}]}]},{"content":[{"inlineContent":[{"text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The component is not available for watchOS","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The component is not available for tvOS","type":"text"}]}]}]},{"type":"heading","text":"Guidelines","anchor":"Guidelines","level":2},{"type":"paragraph","inlineContent":[{"text":"OUDS guidelines recommends to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"limit when possible the number of items to 5"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"use both images and texts in tab bar items"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"use badges only when needed to avoid to have heavy tab bar","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"if decorative images are used for tab bar item, apply ","type":"text"},{"inlineContent":[{"type":"text","text":"template"}],"type":"emphasis"},{"text":" rendering mode on it to apply color on tabs","type":"text"}],"type":"paragraph"}]}]},{"text":"Technical constraints","type":"heading","level":2,"anchor":"Technical-constraints"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"You must use in your tab bar items images with ","type":"text"},{"inlineContent":[{"text":"a size of 26 x 26","type":"text"}],"type":"strong"},{"text":", otherwise rendering could be unaligned with Figma specifications","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,","type":"text"},{"text":" ","type":"text"},{"text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS lower than 18","type":"text"}],"type":"paragraph"}]}]},{"text":"Accessibility considerations","type":"heading","level":2,"anchor":"Accessibility-considerations"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"If your tabs embeded in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"If your tabs embeded in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)","type":"text"},{"text":" ","type":"text"},{"text":"by using accessibilty value","type":"text"}],"type":"paragraph"}]}]},{"code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""],"type":"codeListing","syntax":"swift"},{"text":"Selection of tabs","type":"heading","level":2,"anchor":"Selection-of-tabs"},{"inlineContent":[{"text":"For iOS lower than 26, a selected tab indicator can be displayed in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" if the ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" parameter is defined (to the number of tabs in the component)","type":"text"},{"text":" ","type":"text"},{"text":"and if the ","type":"text"},{"code":"selected","type":"codeVoice"},{"text":" parameter is equal to a given tag associated to a tab item.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator.","type":"text"},{"text":" ","type":"text"},{"text":"This rule only applis if selected tab indicator must be displayed.","type":"text"}],"type":"paragraph"},{"text":"Technical considerations","type":"heading","level":2,"anchor":"Technical-considerations"},{"inlineContent":[{"text":"In order to improve the Developer eXperience the current ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" implementation lets users define their own tab items.","type":"text"},{"text":" ","type":"text"},{"text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a ","type":"text"},{"inlineContent":[{"text":"picker","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Thus users will need to add their own accessiiblity label if badges are used or also apply ","type":"text"},{"inlineContent":[{"text":"template","type":"text"}],"type":"emphasis"},{"text":" rendering mode on images if needed.","type":"text"}],"type":"paragraph"},{"text":"Code samples","type":"heading","level":2,"anchor":"Code-samples"},{"code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embeded.","    \/\/ Image with size of 26 x 26","    OUDSTabBar(selected: 0, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selected parameter","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","            .tag(1) \/\/ Must be used for the selected parameter","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selected parameter","    }"],"type":"codeListing","syntax":"swift"},{"text":"Design documentation","type":"heading","level":2,"anchor":"Design-documentation"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"reference","isActive":true}],"type":"paragraph"},{"text":"Themes rendering","type":"heading","level":2,"anchor":"Themes-rendering"},{"text":"Liquid Glass","type":"heading","level":3,"anchor":"Liquid-Glass"},{"text":"Orange","type":"heading","level":4,"anchor":"Orange"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}],"type":"paragraph"},{"text":"Orange Business Tools","type":"heading","level":4,"anchor":"Orange-Business-Tools"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeBusinessTools_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_OrangeBusinessTools_dark","type":"image"}],"type":"paragraph"},{"text":"Sosh","type":"heading","level":4,"anchor":"Sosh"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image"}],"type":"paragraph"},{"text":"Wireframe","type":"heading","level":4,"anchor":"Wireframe"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"}],"type":"paragraph"},{"text":"Without Liquid Glass","type":"heading","level":3,"anchor":"Without-Liquid-Glass"},{"text":"Orange","type":"heading","level":4,"anchor":"Orange"},{"inlineContent":[{"identifier":"component_tabBar_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Orange_dark","type":"image"}],"type":"paragraph"},{"text":"Orange Business Tools","type":"heading","level":4,"anchor":"Orange-Business-Tools"},{"inlineContent":[{"identifier":"component_tabBar_OrangeBusinessTools_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_OrangeBusinessTools_dark","type":"image"}],"type":"paragraph"},{"text":"Sosh","type":"heading","level":4,"anchor":"Sosh"},{"inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Sosh_dark","type":"image"}],"type":"paragraph"},{"text":"Wireframe","type":"heading","level":4,"anchor":"Wireframe"},{"inlineContent":[{"identifier":"component_tabBar_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Wireframe_dark","type":"image"}],"type":"paragraph"},{"name":"Version","content":[{"inlineContent":[{"text":"1.0.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"name":"Since","content":[{"inlineContent":[{"text":"1.0.0","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstabbar"]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"metadata":{"title":"OUDSTabBar","modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"symbolKind":"struct","navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"externalID":"s:14OUDSComponents10OUDSTabBarV","platforms":[{"introducedAt":"15.0","name":"iOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"15.0","name":"macOS","deprecated":false,"unavailable":false,"beta":false},{"in