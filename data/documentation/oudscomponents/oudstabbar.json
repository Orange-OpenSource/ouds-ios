t"]}],"alt":"A  tab bar component in dark mode with Liquid Glass effect and Sosh theme"},"doc://OUDSComponents/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP"},"doc://OUDSComponents/7SwiftUI4ViewP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","title":"SwiftUICore.View"},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"ic_folder_categories.png"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/View-Implementations":{"abstract":[],"role":"collectionGroup","url":"\/documentation\/oudscomponents\/oudstabbar\/view-implementations","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","title":"View Implementations","kind":"article"},"component_tabBar_LiquidGlass_OrangeCompact_dark":{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","alt":"A  tab bar component in dark mode with Liquid Glass effect and Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_dark.png","traits":["1x","light"]}]},"component_tabBar_LiquidGlass_Wireframe_light":{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_light","alt":"A  tab bar component in light mode with Liquid Glass effect and Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_light.png","traits":["1x","light"]}]},"component_tabBar_LiquidGlass_OrangeCompact_light":{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","alt":"A  tab bar component in light mode with Liquid Glass effect and Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_light.png","traits":["1x","light"]}]},"https://r.orange.fr/r/S-ouds-doc-ios-tab-bar":{"type":"link","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"title":"unified-design-system.orange.com","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"url":"\/documentation\/oudscomponents\/oudsbadge","role":"symbol","abstract":[{"text":"Badge is a UI element that emphasizes system notifications, status, or the categorization of an information, throughout colour only.","type":"text"},{"text":" ","type":"text"},{"text":"Badge is rendered as a coloured shape, without icon, text or number; and its chosen size remains unchanged regardless of the changes of the interface size.","type":"text"}],"title":"OUDSBadge","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSBadge"}],"type":"topic","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSBadge"}]},"component_tabBar_Wireframe_light":{"alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_Wireframe_light"},"component_tabBar_LiquidGlass_Orange_light":{"alt":"A tab bar component in light mode with Liquid Glass effect and Orange theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_light"},"component_tabBar_Orange_light":{"alt":"A tab bar component in light mode without Liquid Glass effect and Orange theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Orange_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_Orange_light"},"component_tabBar_LiquidGlass_Wireframe_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_dark.png","traits":["1x","light"]}],"type":"image","alt":"A  tab bar component in dark mode with Liquid Glass effect and Wireframe theme","identifier":"component_tabBar_LiquidGlass_Wireframe_dark"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(content:)":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"content","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":")","kind":"text"}],"type":"topic","kind":"symbol","abstract":[{"text":"Defines the tab bar component with given tab bar items.","type":"text"},{"text":" ","type":"text"},{"text":"If you target iOS lower than 26, prefer instead ","type":"text"},{"type":"codeVoice","code":"OUDSTabBar(selectedTab:count:content:)"}],"url":"\/documentation\/oudscomponents\/oudstabbar\/init(content:)","title":"init(content:)"}}}