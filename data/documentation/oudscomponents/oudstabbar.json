{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"role":"symbol","platforms":[{"introducedAt":"15.0","unavailable":false,"name":"iOS","deprecated":false,"beta":false},{"introducedAt":"13.0","unavailable":false,"name":"macOS","deprecated":false,"beta":false},{"introducedAt":"1.0","unavailable":false,"name":"visionOS","deprecated":false,"beta":false}],"title":"OUDSTabBar","roleHeading":"Structure","modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"externalID":"s:14OUDSComponents10OUDSTabBarV","navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"symbolKind":"struct"},"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstabbar"]}],"abstract":[{"text":"The Tab bar is a system navigation component with a position which can vary depending to the OS.","type":"text"},{"text":" ","type":"text"},{"text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to switch between the sections of an app.","type":"text"},{"text":" ","type":"text"},{"text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"]},{"kind":"content","content":[{"text":"Appearances","anchor":"Appearances","type":"heading","level":2},{"inlineContent":[{"text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars.","type":"text"},{"text":" ","type":"text"},{"text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"background color of tab bar can be changed for iOS lower than 26","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"background color of tab bar does not change since iOS 26","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed","type":"text"},{"text":" ","type":"text"},{"text":"and not the text making theme not readable in dark color scheme","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","type":"reference"},{"text":" component,","type":"text"},{"text":" ","type":"text"},{"text":"the native API is used instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you use SF Symbols for images, if they exist their ","type":"text"},{"inlineContent":[{"type":"text","text":"fill"}],"type":"emphasis"},{"text":" variant will be automatically used in the tab bar (native behaviour).","type":"text"}],"type":"paragraph"},{"text":"Platform considerations","anchor":"Platform-considerations","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"This component is tailored for iOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"On iPadOS the tabs do not apply the fonts since iPadOS 18","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The component is not available for watchOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The component is not available for tvOS","type":"text"}]}]}],"type":"unorderedList"},{"text":"Guidelines","anchor":"Guidelines","type":"heading","level":2},{"inlineContent":[{"text":"OUDS guidelines recommends to:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"limit when possible the number of items to 5","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"use both images and texts in tab bar items","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"use badges only when needed to avoid to have heavy tab bar","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"if decorative images are used for tab bar item, apply ","type":"text"},{"inlineContent":[{"text":"template","type":"text"}],"type":"emphasis"},{"text":" rendering mode on it to apply color on tabs","type":"text"}]}]}],"type":"unorderedList"},{"text":"Technical constraints","anchor":"Technical-constraints","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You must use in your tab bar items images with ","type":"text"},{"inlineContent":[{"text":"a size of 26 x 26","type":"text"}],"type":"strong"},{"text":", otherwise rendering could be unaligned with Figma specifications","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,","type":"text"},{"text":" ","type":"text"},{"text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Accessibility considerations","anchor":"Accessibility-considerations","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"If your tabs embedded in the ","type":"text"},{"type":"codeVoice","code":"OUDSTabBar"},{"text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If your tabs embedded in the ","type":"text"},{"type":"codeVoice","code":"OUDSTabBar"},{"text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)","type":"text"},{"text":" ","type":"text"},{"text":"by using accessibiltiy value","type":"text"}]}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""]},{"text":"Selection of tabs","anchor":"Selection-of-tabs","type":"heading","level":2},{"inlineContent":[{"text":"For iOS lower than 26, a selected tab indicator can be displayed in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" if the ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" parameter is defined (to the number of tabs in the component)","type":"text"},{"text":" ","type":"text"},{"text":"and if the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding value is equal to a given tag associated to a tab item.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator.","type":"text"},{"text":" ","type":"text"},{"text":"This rule is only applied if selected tab indicator must be displayed.","type":"text"},{"text":" ","type":"text"},{"text":"When the user taps a tab, the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding is updated automatically, keeping the parent view in sync.","type":"text"}],"type":"paragraph"},{"text":"Technical considerations","anchor":"Technical-considerations","type":"heading","level":2},{"inlineContent":[{"text":"In order to improve the Developer eXperience the current ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" implementation lets users define their own tab items.","type":"text"},{"text":" ","type":"text"},{"text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a ","type":"text"},{"inlineContent":[{"type":"text","text":"picker"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Thus users will need to add their own accessiiblity label if badges are used or also apply ","type":"text"},{"inlineContent":[{"type":"text","text":"template"}],"type":"emphasis"},{"text":" rendering mode on images if needed.","type":"text"},{"text":" ","type":"text"},{"text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking.","type":"text"}],"type":"paragraph"},{"text":"Code samples","anchor":"Code-samples","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embedded.","    \/\/ Image with size of 26 x 26","    @State private var selectedTab = 0","","    OUDSTabBar(selectedTab: $selectedTab, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selectedTab binding value","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","             }","            .tag(1) \/\/ Must be used for the selectedTab binding","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selectedTab binding","    }"]},{"text":"Design documentation","anchor":"Design-documentation","type":"heading","level":2},{"inlineContent":[{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"reference"}],"type":"paragraph"},{"text":"Themes rendering","anchor":"Themes-rendering","type":"heading","level":2},{"text":"Liquid Glass","anchor":"Liquid-Glass","type":"heading","level":3},{"text":"Orange","anchor":"Orange","type":"heading","level":4},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}],"type":"paragraph"},{"text":"Orange Compact","anchor":"Orange-Compact","type":"heading","level":4},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image"}],"type":"paragraph"},{"text":"Sosh","anchor":"Sosh","type":"heading","level":4},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image"}],"type":"paragraph"},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":4},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"}],"type":"paragraph"},{"text":"Without Liquid Glass","anchor":"Without-Liquid-Glass","type":"heading","level":3},{"text":"Orange","anchor":"Orange","type":"heading","level":4},{"inlineContent":[{"identifier":"component_tabBar_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Orange_dark","type":"image"}],"type":"paragraph"},{"text":"Orange Compact","anchor":"Orange-Compact","type":"heading","level":4},{"inlineContent":[{"identifier":"component_tabBar_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_OrangeCompact_dark","type":"image"}],"type":"paragraph"},{"text":"Sosh","anchor":"Sosh","type":"heading","level":4},{"inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Sosh_dark","type":"image"}],"type":"paragraph"},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":4},{"inlineContent":[{"identifier":"component_tabBar_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Wireframe_dark","type":"image"}],"type":"paragraph"},{"name":"Version","content":[{"inlineContent":[{"type":"text","text":"1.0.0 (Figma component design version)"}],"type":"paragraph"}],"style":"note","type":"aside"},{"name":"Since","content":[{"inlineContent":[{"type":"text","text":"1.0.0"}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selected:count:content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)"],"generated":true,"title":"Initializers"},{"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"generated":true,"title":"Instance Properties"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDS