e","alt":"A  tab bar component in dark mode without Liquid Glass effect and Sosh theme"},"component_tabBar_Orange_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Orange_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_Orange_dark","type":"image","alt":"A tab bar component in dark mode without Liquid Glass effect and Orange theme"},"component_tabBar_LiquidGlass_Sosh_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image","alt":"A  tab bar component in dark mode with Liquid Glass effect and Sosh theme"},"doc://OUDSComponents/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype","type":"unresolvable"},"component_tabBar_Sosh_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Sosh_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_Sosh_light","type":"image","alt":"A  tab bar component in light mode without Liquid Glass effect and Sosh theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(selectedTab:count:content:)":{"url":"\/documentation\/oudscomponents\/oudstabbar\/init(selectedtab:count:content:)","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)","title":"init(selectedTab:count:content:)","abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items and a two-way binding to the selected tab index."},{"type":"text","text":" "},{"type":"text","text":"Number of tabs and selected tab are needed to compute the selected tab indicator for iOS lower than 26."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS 26+ or other platform, prefer instead "},{"type":"codeVoice","code":"OUDSTabBar(content:)"},{"type":"text","text":"."}],"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"selectedTab"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI7BindingV","text":"Binding"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V","text":"UInt8"},{"kind":"text","text":", "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":")"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"role":"collection","images":[{"identifier":"ic_folder_categories.png","type":"icon"}]},"component_tabBar_Wireframe_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_Wireframe_dark","type":"image","alt":"A  tab bar component in dark mode without Liquid Glass effect and Wireframe theme"},"component_tabBar_LiquidGlass_OrangeCompact_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image","alt":"A  tab bar component in dark mode with Liquid Glass effect and Orange Compact theme"},"component_tabBar_LiquidGlass_Wireframe_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image","alt":"A  tab bar component in dark mode with Liquid Glass effect and Wireframe theme"},"component_tabBar_Wireframe_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_Wireframe_light","type":"image","alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme"},"https://r.orange.fr/r/S-ouds-doc-ios-tab-bar":{"titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","title":"unified-design-system.orange.com","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"link"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/body":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body","title":"body","url":"\/documentation\/oudscomponents\/oudstabbar\/body","abstract":[{"type":"text","text":"Uses a native SwiftUI "},{"type":"codeVoice","code":"TabView"},{"type":"text","text":" populated with the given content where "},{"type":"emphasis","inlineContent":[{"text":"tab item","type":"text"}]},{"type":"text","text":" elements are defined."},{"type":"text","text":" "},{"type":"text","text":"Rendering wil change depending to OS version, with a top divider and a selected tab indicator for legacy layouts."}],"kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"type":"topic","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar":{"navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"kind":"symbol","title":"OUDSTabBar","url":"\/documentation\/oudscomponents\/oudstabbar","role":"symbol","abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"type":"text","text":" "},{"type":"text","text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS."},{"type":"text","text":" "},{"type":"text","text":"It allows users to switch between the sections of an app."},{"type":"text","text":" "},{"type":"text","text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations."}],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}]},"component_tabBar_LiquidGlass_OrangeCompact_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image","alt":"A  tab bar component in light mode with Liquid Glass effect and Orange Compact theme"},"component_tabBar_Orange_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Orange_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_Orange_light","type":"image","alt":"A tab bar component in light mode without Liquid Glass effect and Orange theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","abstract":[{"text":"Badge is a UI element that emphasizes system notifications, status, or the categorization of an information, throughout colour only.","type":"text"},{"text":" ","type":"text"},{"text":"Badge is rendered as a coloured shape, without icon, text or number; and its chosen size remains unchanged regardless of the changes of the interface size.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudsbadge","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSBadge"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSBadge"}],"title":"OUDSBadge"},"component_tabBar_LiquidGlass_Orange_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image","alt":"A tab bar component in light mode with Liquid Glass effect and Orange theme"},"doc://OUDSComponents/s8SendableP":{"identifier":"doc:\/\/OUDSComponents\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"component_tabBar_OrangeCompact_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_OrangeCompact_dark","type":"image","alt":"A  tab bar component in dark mode without Liquid Glass effect and Orange Compact theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/View-Implementations":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","title":"View Implementations","url":"\/documentation\/oudscomponents\/oudstabbar\/view-implementations","abstract":[],"kind":"article","type":"topic","role":"collectionGroup"},"doc://OUDSComponents/7SwiftUI4ViewP":{"identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","title":"SwiftUICore.View","type":"unresolvable"},"component_tabBar_LiquidGlass_Wireframe_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image","alt":"A  tab bar component in light mode with Liquid Glass effect and Wireframe theme"},"component_tabBar_LiquidGlass_Orange_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image","alt":"A tab bar component in dark mode with Liquid Glass effect and Orange theme"},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png","type":"image","alt":null},"component_tabBar_LiquidGlass_Sosh_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image","alt":"A  tab bar component in light mode with Liquid Glass effect and Sosh theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(content:)":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","url":"\/documentation\/oudscomponents\/oudstabbar\/init(content:)","title":"init(content:)","abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS lower than 26, prefer instead "},{"code":"OUDSTabBar(selectedTab:count:content:)","type":"codeVoice"}],"kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":")"}],"type":"topic","role":"symbol"}}}