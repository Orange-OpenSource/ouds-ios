{"sections":[],"metadata":{"role":"symbol","symbolKind":"struct","platforms":[{"beta":false,"deprecated":false,"unavailable":false,"name":"iOS","introducedAt":"15.0"},{"beta":false,"deprecated":false,"unavailable":false,"name":"macOS","introducedAt":"13.0"},{"beta":false,"deprecated":false,"unavailable":false,"name":"visionOS","introducedAt":"1.0"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSTabBar"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"}],"roleHeading":"Structure","externalID":"s:14OUDSComponents10OUDSTabBarV","title":"OUDSTabBar","modules":[{"name":"Components"}]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar"},"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"generated":true},{"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"],"generated":true}],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI4ViewP","text":"View","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"]},{"kind":"content","content":[{"text":"Appearances","anchor":"Appearances","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars."},{"type":"text","text":" "},{"type":"text","text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"background color of tab bar can be changed for iOS lower than 26"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"background color of tab bar does not change since iOS 26"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed"},{"type":"text","text":" "},{"type":"text","text":"and not the text making theme not readable in dark color scheme"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge"},{"type":"text","text":" component,"},{"type":"text","text":" "},{"type":"text","text":"the native API is used instead."}]},{"inlineContent":[{"type":"text","text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you use SF Symbols for images, if they exist their "},{"inlineContent":[{"type":"text","text":"fill"}],"type":"emphasis"},{"type":"text","text":" variant will be automatically used in the tab bar (native behaviour)."}],"type":"paragraph"},{"type":"heading","anchor":"Platform-considerations","level":2,"text":"Platform considerations"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"This component is tailored for iOS"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"On iPadOS the tabs do not apply the fonts since iPadOS 18"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The component is not available for watchOS"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The component is not available for tvOS"}]}]}]},{"text":"Guidelines","level":2,"anchor":"Guidelines","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS guidelines recommends to:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"limit when possible the number of items to 5"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"use both images and texts in tab bar items"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"use badges only when needed to avoid to have heavy tab bar"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"if decorative images are used for tab bar item, apply ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"template"}]},{"type":"text","text":" rendering mode on it to apply color on tabs"}]}]}]},{"text":"Technical constraints","anchor":"Technical-constraints","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You must use in your tab bar items images with ","type":"text"},{"inlineContent":[{"type":"text","text":"a size of 26 x 26"}],"type":"strong"},{"type":"text","text":", otherwise rendering could be unaligned with Figma specifications"}]}]},{"content":[{"inlineContent":[{"text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,","type":"text"},{"type":"text","text":" "},{"text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS.","type":"text"}],"type":"paragraph"}]}]},{"level":2,"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)"},{"type":"text","text":" "},{"type":"text","text":"by using accessibiltiy value"}]}]}]},{"syntax":"swift","type":"codeListing","code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""]},{"type":"heading","anchor":"Selection-of-tabs","level":2,"text":"Selection of tabs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For iOS lower than 26, a selected tab indicator can be displayed in the "},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" if the "},{"code":"count","type":"codeVoice"},{"type":"text","text":" parameter is defined (to the number of tabs in the component)"},{"type":"text","text":" "},{"type":"text","text":"and if the "},{"code":"selectedTab","type":"codeVoice"},{"type":"text","text":" binding value is equal to a given tag associated to a tab item."},{"type":"text","text":" "},{"type":"text","text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator."},{"type":"text","text":" "},{"type":"text","text":"This rule is only applied if selected tab indicator must be displayed."},{"type":"text","text":" "},{"type":"text","text":"When the user taps a tab, the "},{"code":"selectedTab","type":"codeVoice"},{"type":"text","text":" binding is updated automatically, keeping the parent view in sync."}]},{"type":"heading","level":2,"anchor":"Technical-considerations","text":"Technical considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to improve the Developer eXperience the current "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" implementation lets users define their own tab items."},{"type":"text","text":" "},{"type":"text","text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"picker"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Thus users will need to add their own accessiiblity label if badges are used or also apply "},{"inlineContent":[{"type":"text","text":"template"}],"type":"emphasis"},{"type":"text","text":" rendering mode on images if needed."},{"type":"text","text":" "},{"type":"text","text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking."}]},{"type":"heading","anchor":"Code-samples","level":2,"text":"Code samples"},{"type":"codeListing","code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embedded.","    \/\/ Image with size of 26 x 26","    @State private var selectedTab = 0","","    OUDSTabBar(selectedTab: $selectedTab, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selectedTab binding value","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","             }","            .tag(1) \/\/ Must be used for the selectedTab binding","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selectedTab binding","    }"],"syntax":"swift"},{"type":"heading","level":2,"anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar"}]},{"level":2,"anchor":"Themes-rendering","type":"heading","text":"Themes rendering"},{"text":"Liquid Glass","anchor":"Liquid-Glass","type":"heading","level":3},{"text":"Orange","anchor":"Orange","type":"heading","level":4},{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_dark"}],"type":"paragraph"},{"text":"Orange Compact","anchor":"Orange-Compact","type":"heading","level":4},{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark"}],"type":"paragraph"},{"text":"Sosh","anchor":"Sosh","type":"heading","level":4},{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark"}],"type":"paragraph"},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":4},{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark"}],"type":"paragraph"},{"text":"Without Liquid Glass","anchor":"Without-Liquid-Glass","type":"heading","level":3},{"text":"Orange","anchor":"Orange","type":"heading","level":4},{"inlineContent":[{"type":"image","identifier":"component_tabBar_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Orange_dark"}],"type":"paragraph"},{"text":"Orange Compact","anchor":"Orange-Compact","type":"heading","level":4},{"inlineContent":[{"type":"image","identifier":"component_tabBar_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_OrangeCompact_dark"}],"type":"paragraph"},{"text":"Sosh","anchor":"Sosh","type":"heading","level":4},{"inlineContent":[{"type":"image","identifier":"component_tabBar_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Sosh_dark"}],"type":"paragraph"},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":4},{"inlineContent":[{"type":"image","identifier":"component_tabBar_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Wireframe_dark"}],"type":"paragraph"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"1.0.0 (Figma component design version)"}],"type":"paragraph"}],"type":"aside","name":"Version"},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"1.0.0"}],"type":"paragraph"}],"name":"Since"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/oudscomponents\/oudstabbar"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"type":"text","text":" "},{"type":"text","text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS."},{"type":"text","text":" "},{"type":"text","text":"It allows users to switch between the sections of an app."},{"type":"text","text":" "},{"type":"text","text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations."}],"references":{"component_tabBar_LiquidGlass_Orange_dark":{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_dark","alt":"A tab bar component in dark mode with Liquid Glass effect and Orange theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_dark.png","traits":["1x","light"]}]},"component_tabBar_OrangeCompact_dark":{"type":"image","identifier":"component_tabBar_OrangeCompact_dark","alt":"A  tab bar component in dark mode without Liquid Glass effect and Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_dark.png","traits":["1x","light"]}]},"doc://OUDSComponents/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s8SendableP","title":"Swift.Sendable"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/body":{"url":"\/documentation\/oudscomponents\/oudstabbar\/body","role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"title":"body","abstract":[{"type":"text","text":"Uses a native SwiftUI "},{"code":"TabView","type":"codeVoice"},{"type":"text","text":" populated with the given content where "},{"inlineContent":[{"type":"text","text":"tab item"}],"type":"emphasis"},{"type":"text","text":" elements are defined."},{"type":"text","text":" "},{"type":"text","text":"Rendering wil change depending to OS version, with a top divider and a selected tab indicator for legacy layouts."}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"}],"abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"type":"text","text":" "},{"text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It allows users to switch between the sections of an app."},{"text":" ","type":"text"},{"text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSTabBar"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","url":"\/documentation\/oudscomponents\/oudstabbar","role":"symbol","title":"OUDSTabBar"},"component_tabBar_OrangeCompact_light":{"type":"image","identifier":"component_tabBar_OrangeCompact_light","alt":"A  tab bar component in light mode without Liquid Glass effect and Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_light.png","traits":["1x","light"]}]},"component_tabBar_LiquidGlass_Sosh_light":{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_light","alt":"A  tab bar component in light mode with Liquid Glass effect and Sosh theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_light.png","traits":["1x","light"]}]},"component_tabBar_Orange_dark":{"type":"image","identifier":"component_tabBar_Orange_dark",