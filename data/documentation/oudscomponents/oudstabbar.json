light","alt":"A  tab bar component in light mode without Liquid Glass effect and Sosh theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Sosh_light.png","traits":["1x","light"]}],"type":"image"},"component_tabBar_LiquidGlass_Orange_light":{"type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Orange_light","alt":"A tab bar component in light mode with Liquid Glass effect and Orange theme"},"doc://OUDSComponents/documentation/OUDSComponents":{"type":"topic","kind":"symbol","url":"\/documentation\/oudscomponents","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"role":"collection","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","images":[{"identifier":"ic_folder_categories.png","type":"icon"}]}}}