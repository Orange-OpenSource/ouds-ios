en the sections of an app.","type":"text"},{"text":" ","type":"text"},{"text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(selectedTab:count:content:)":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)","role":"symbol","type":"topic","url":"\/documentation\/oudscomponents\/oudstabbar\/init(selectedtab:count:content:)","title":"init(selectedTab:count:content:)","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"selectedTab"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI7BindingV","text":"Binding"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":">, "},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":", "},{"text":"content","kind":"externalParam"},{"kind":"text","text":": () -> "},{"text":"Content","kind":"typeIdentifier"},{"kind":"text","text":")"}],"abstract":[{"text":"Defines the tab bar component with given tab bar items and a two-way binding to the selected tab index.","type":"text"},{"type":"text","text":" "},{"text":"Number of tabs and selected tab are needed to compute the selected tab indicator for iOS lower than 26.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If you target iOS 26+ or other platform, prefer instead "},{"type":"codeVoice","code":"OUDSTabBar(content:)"},{"type":"text","text":"."}]},"component_tabBar_Wireframe_dark":{"identifier":"component_tabBar_Wireframe_dark",