{"variants":[{"paths":["\/documentation\/oudscomponents\/oudstabbar"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"type":"text","text":" "},{"type":"text","text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS."},{"type":"text","text":" "},{"type":"text","text":"It allows users to switch between the sections of an app."},{"type":"text","text":" "},{"type":"text","text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations."}],"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selected:count:content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)"],"generated":true},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"generated":true},{"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"],"generated":true}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"OUDSTabBar"}],"platforms":[{"beta":false,"name":"iOS","introducedAt":"15.0","unavailable":false,"deprecated":false},{"beta":false,"name":"macOS","introducedAt":"13.0","unavailable":false,"deprecated":false},{"beta":false,"name":"visionOS","introducedAt":"1.0","unavailable":false,"deprecated":false}],"role":"symbol","title":"OUDSTabBar","roleHeading":"Structure","externalID":"s:14OUDSComponents10OUDSTabBarV","modules":[{"name":"Components"}],"symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"],"kind":"mentions"},{"content":[{"level":2,"anchor":"Appearances","type":"heading","text":"Appearances"},{"type":"paragraph","inlineContent":[{"text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars.","type":"text"},{"text":" ","type":"text"},{"text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"background color of tab bar can be changed for iOS lower than 26","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"background color of tab bar does not change since iOS 26"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed"},{"type":"text","text":" "},{"type":"text","text":"and not the text making theme not readable in dark color scheme"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","isActive":true,"type":"reference"},{"text":" component,","type":"text"},{"text":" ","type":"text"},{"text":"the native API is used instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before."}],"type":"paragraph"},{"inlineContent":[{"text":"If you use SF Symbols for images, if they exist their ","type":"text"},{"inlineContent":[{"type":"text","text":"fill"}],"type":"emphasis"},{"text":" variant will be automatically used in the tab bar (native behaviour).","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Platform considerations","anchor":"Platform-considerations"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"This component is tailored for iOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"On iPadOS the tabs do not apply the fonts since iPadOS 18","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The component is not available for watchOS"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The component is not available for tvOS"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Guidelines","anchor":"Guidelines"},{"type":"paragraph","inlineContent":[{"type":"text","text":"OUDS guidelines recommends to:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"limit when possible the number of items to 5","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"use both images and texts in tab bar items","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"use badges only when needed to avoid to have heavy tab bar"}]}]},{"content":[{"inlineContent":[{"text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"if decorative images are used for tab bar item, apply "},{"type":"emphasis","inlineContent":[{"text":"template","type":"text"}]},{"text":" rendering mode on it to apply color on tabs","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Technical constraints","anchor":"Technical-constraints"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You must use in your tab bar items images with ","type":"text"},{"inlineContent":[{"text":"a size of 26 x 26","type":"text"}],"type":"strong"},{"text":", otherwise rendering could be unaligned with Figma specifications","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,"},{"type":"text","text":" "},{"type":"text","text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS."}]}]}]},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"If your tabs embedded in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)"},{"type":"text","text":" "},{"text":"by using accessibiltiy value","type":"text"}]}]}]},{"type":"codeListing","code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""],"syntax":"swift"},{"type":"heading","level":2,"anchor":"Selection-of-tabs","text":"Selection of tabs"},{"inlineContent":[{"text":"For iOS lower than 26, a selected tab indicator can be displayed in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" if the ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" parameter is defined (to the number of tabs in the component)"},{"text":" ","type":"text"},{"text":"and if the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding value is equal to a given tag associated to a tab item.","type":"text"},{"type":"text","text":" "},{"text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This rule is only applied if selected tab indicator must be displayed."},{"text":" ","type":"text"},{"text":"When the user taps a tab, the ","type":"text"},{"type":"codeVoice","code":"selectedTab"},{"type":"text","text":" binding is updated automatically, keeping the parent view in sync."}],"type":"paragraph"},{"anchor":"Technical-considerations","text":"Technical considerations","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to improve the Developer eXperience the current "},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" implementation lets users define their own tab items."},{"type":"text","text":" "},{"text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"picker"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Thus users will need to add their own accessiiblity label if badges are used or also apply ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"template"}]},{"text":" rendering mode on images if needed.","type":"text"},{"text":" ","type":"text"},{"text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking.","type":"text"}]},{"text":"Code samples","type":"heading","anchor":"Code-samples","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embedded.","    \/\/ Image with size of 26 x 26","    @State private var selectedTab = 0","","    OUDSTabBar(selectedTab: $selectedTab, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selectedTab binding value","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","             }","            .tag(1) \/\/ Must be used for the selectedTab binding","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selectedTab binding","    }"]},{"text":"Design documentation","type":"heading","anchor":"Design-documentation","level":2},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"reference","isActive":true}]},{"level":2,"anchor":"Themes-rendering","type":"heading","text":"Themes rendering"},{"anchor":"Liquid-Glass","type":"heading","level":3,"text":"Liquid Glass"},{"type":"heading","anchor":"Orange","text":"Orange","level":4},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","typ