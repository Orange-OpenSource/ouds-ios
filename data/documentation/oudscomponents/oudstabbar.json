{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selected:count:content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"abstract":[{"text":"The Tab bar is a system navigation component with a position which can vary depending to the OS.","type":"text"},{"text":" ","type":"text"},{"text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to switch between the sections of an app.","type":"text"},{"text":" ","type":"text"},{"text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations.","type":"text"}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"metadata":{"symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"title":"OUDSTabBar","platforms":[{"unavailable":false,"deprecated":false,"beta":false,"name":"iOS","introducedAt":"15.0"},{"unavailable":false,"deprecated":false,"beta":false,"name":"macOS","introducedAt":"13.0"},{"unavailable":false,"deprecated":false,"beta":false,"name":"visionOS","introducedAt":"1.0"}],"roleHeading":"Structure","role":"symbol","modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents10OUDSTabBarV"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Content"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"]},{"kind":"content","content":[{"level":2,"anchor":"Appearances","text":"Appearances","type":"heading"},{"inlineContent":[{"text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars.","type":"text"},{"text":" ","type":"text"},{"text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"background color of tab bar can be changed for iOS lower than 26"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"background color of tab bar does not change since iOS 26"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed"},{"type":"text","text":" "},{"type":"text","text":"and not the text making theme not readable in dark color scheme"}]}]}]},{"inlineContent":[{"text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","type":"reference"},{"text":" component,","type":"text"},{"text":" ","type":"text"},{"text":"the native API is used instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you use SF Symbols for images, if they exist their ","type":"text"},{"inlineContent":[{"text":"fill","type":"text"}],"type":"emphasis"},{"text":" variant will be automatically used in the tab bar (native behaviour).","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Platform-considerations","text":"Platform considerations","type":"heading"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This component is tailored for iOS"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On iPadOS the tabs do not apply the fonts since iPadOS 18"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The component is not available for watchOS"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The component is not available for tvOS"}]}]}]},{"level":2,"anchor":"Guidelines","text":"Guidelines","type":"heading"},{"inlineContent":[{"text":"OUDS guidelines recommends to:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"limit when possible the number of items to 5"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"use both images and texts in tab bar items"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"use badges only when needed to avoid to have heavy tab bar"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"if decorative images are used for tab bar item, apply "},{"inlineContent":[{"type":"text","text":"template"}],"type":"emphasis"},{"type":"text","text":" rendering mode on it to apply color on tabs"}]}]}]},{"level":2,"anchor":"Technical-constraints","text":"Technical constraints","type":"heading"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You must use in your tab bar items images with "},{"inlineContent":[{"type":"text","text":"a size of 26 x 26"}],"type":"strong"},{"type":"text","text":", otherwise rendering could be unaligned with Figma specifications"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,"},{"type":"text","text":" "},{"type":"text","text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS."}]}]}]},{"level":2,"anchor":"Accessibility-considerations","text":"Accessibility considerations","type":"heading"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)"},{"type":"text","text":" "},{"type":"text","text":"by using accessibiltiy value"}]}]}]},{"syntax":"swift","code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""],"type":"codeListing"},{"level":2,"anchor":"Selection-of-tabs","text":"Selection of tabs","type":"heading"},{"inlineContent":[{"text":"For iOS lower than 26, a selected tab indicator can be displayed in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" if the ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" parameter is defined (to the number of tabs in the component)","type":"text"},{"text":" ","type":"text"},{"text":"and if the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding value is equal to a given tag associated to a tab item.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator.","type":"text"},{"text":" ","type":"text"},{"text":"This rule is only applied if selected tab indicator must be displayed.","type":"text"},{"text":" ","type":"text"},{"text":"When the user taps a tab, the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding is updated automatically, keeping the parent view in sync.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Technical-considerations","text":"Technical considerations","type":"heading"},{"inlineContent":[{"text":"In order to improve the Developer eXperience the current ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" implementation lets users define their own tab items.","type":"text"},{"text":" ","type":"text"},{"text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a ","type":"text"},{"inlineContent":[{"text":"picker","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Thus users will need to add their own accessiiblity label if badges are used or also apply ","type":"text"},{"inlineContent":[{"text":"template","type":"text"}],"type":"emphasis"},{"text":" rendering mode on images if needed.","type":"text"},{"text":" ","type":"text"},{"text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Code-samples","text":"Code samples","type":"heading"},{"syntax":"swift","code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embedded.","    \/\/ Image with size of 26 x 26","    @State private var selectedTab = 0","","    OUDSTabBar(selectedTab: $selectedTab, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selectedTab binding value","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","             }","            .tag(1) \/\/ Must be used for the selectedTab binding","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selectedTab binding","    }"],"type":"codeListing"},{"level":2,"anchor":"Design-documentation","text":"Design documentation","type":"heading"},{"inlineContent":[{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"reference"}],"type":"paragraph"},{"level":2,"anchor":"Themes-rendering","text":"Themes rendering","type":"heading"},{"level":3,"anchor":"Liquid-Glass","text":"Liquid Glass","type":"heading"},{"level":4,"anchor":"Orange","text":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}],"type":"paragraph"},{"level":4,"anchor":"Orange-Compact","text":"Orange Compact","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image"}],"type":"paragraph"},{"level":4,"anchor":"Sosh","text":"Sosh","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image"}],"type":"paragraph"},{"level":4,"anchor":"Wireframe","text":"Wireframe","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Without-Liquid-Glass","text":"Without Liquid Glass","type":"heading"},{"level":4,"anchor":"Orange","text":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Orange_dark","type":"image"}],"type":"paragraph"},{"level":4,"anchor":"Orange-Compact","text":"Orange Compact","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_OrangeCompact_dark","type":"image"}],"type":"paragraph"},{"level":4,"anchor":"Sosh","text":"Sosh","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Sosh_dark","type":"image"}],"type":"paragraph"},{"level":4,"anchor":"Wireframe","text":"Wireframe","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Wireframe_dark","type":"image"}],"type":"paragraph"},{"name":"Version","content":[{"inlineContent":[{"text":"1.0.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"name":"Since","content":[{"inlineContent":[{"text":"1.0.0","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstabbar"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"component_tabBar_LiquidGlass_Orange_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Orange_light","alt":"A tab bar component in light mode with Liquid Glass effect and Orange theme","type":"image"},"component_tabBar_LiquidGlass_Sosh_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Sosh_dark","alt":"A  tab bar component in dark mode with Liquid Glass effect and Sosh theme","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(content:)":{"title":"init(content:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","type":"topic","url":"\/documentation\/oudscomponents\/oudstabbar\/init(content:)","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":")"}],"kind":"symbol","abstract":[{"type":"text","text":"NOTE: No use of #if os(iOS) to let OUDS maintainers macOS computers compute the documentation"},{"type":"text","text":" "},{"type":"text","text":"Defines the tab bar component with given tab bar items."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS lower than 26, prefer instead "},{"code":"OUDSTabBar(selectedTab:count:content:)","type":"codeVoice"}]},"https://r.orange.fr/r/S-ouds-doc-ios-tab-bar":{"url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"type":"link","title":"unified-design-system.orange.com"},"doc://OUDSComponents/7SwiftUI4ViewP":{"identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","type":"unresolvable","title":"SwiftUICore.View"},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png","alt":null,"type":"image"},"component_tabBar_LiquidGlass_Wireframe_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Wireframe_light","alt":"A  tab bar component in light mode with Liquid Glass effect and Wireframe theme","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(selectedTab:count:content:)":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items and a two-way binding to the selected tab index."},{"type":"text","text":" "},{"type":"text","text":"Number of tabs and selected tab are needed to compute the selected tab indicator for iOS lower than 26."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS 26+ or other platform, prefer instead "},{"type":"codeVoice","code":"OUDSTabBar(content:)"},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/oudstabbar\/init(selectedtab:count:content:)","role":"symbol","title":"init(selectedTab:count:content:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalPar