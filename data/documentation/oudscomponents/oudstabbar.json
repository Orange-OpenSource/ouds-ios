es\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_light.png"}],"type":"image","alt":"A  tab bar component in light mode with Liquid Glass effect and Orange Compact theme"},"component_tabBar_OrangeCompact_light":{"identifier":"component_tabBar_OrangeCompact_light","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_light.png","traits":["1x","light"]}],"alt":"A  tab bar component in light mode without Liquid Glass effect and Orange Compact theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/View-Implementations":{"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","title":"View Implementations","kind":"article","abstract":[],"url":"\/documentation\/oudscomponents\/oudstabbar\/view-implementations","role":"collectionGroup"},"doc://OUDSComponents/s8SendableP":{"title":"Swift.Sendable","identifier":"doc:\/\/OUDSComponents\/s8SendableP","type":"unresolvable"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBadge","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudscomponents\/oudsbadge","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","title":"OUDSBadge","navigatorTitle":[{"text":"OUDSBadge","kind":"identifier"}],"abstract":[{"type":"text","text":"Badge is a UI element that emphasizes system notifications, status, or the categorization of an information, throughout colour only."},{"type":"text","text":" "},{"type":"text","text":"Badge is rendered as a coloured shape, without icon, text or number; and its chosen size remains unchanged regardless of the changes of the interface size."}],"role":"symbol","kind":"symbol"},"component_tabBar_Sosh_dark":{"alt":"A  tab bar component in dark mode without Liquid Glass effect and Sosh theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Sosh_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_Sosh_dark","type":"image"},"component_tabBar_LiquidGlass_Orange_light":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_light.png"}],"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image","alt":"A tab bar component in light mode with Liquid Glass effect and Orange theme"},"component_tabBar_Wireframe_light":{"identifier":"component_tabBar_Wireframe_light","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_light.png"}],"alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme"},"component_tabBar_LiquidGlass_Wireframe_dark":{"alt":"A  tab bar component in dark mode with Liquid Glass effect and Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"},"component_tabBar_Sosh_light":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Sosh_light.png"}],"identifier":"component_tabBar_Sosh_light","type":"image","alt":"A  tab bar component in light mode without Liquid Glass effect and Sosh theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"}],"url":"\/documentation\/oudscomponents\/oudstabbar","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","title":"OUDSTabBar","navigatorTitle":[{"kind":"identifier","text":"OUDSTabBar"}],"abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"type":"text","text":" "},{"type":"text","text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS."},{"type":"text","text":" "},{"type":"text","text":"It allows users to switch between the sections of an app."},{"type":"text","text":" "},{"type":"text","text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations."}],"role":"symbol","kind":"symbol"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"alt":null},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/body":{"title":"body","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body","url":"\/documentation\/oudscomponents\/oudstabbar\/body","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"role":"symbol","type":"topic","abstract":[{"text":"Uses a native SwiftUI ","type":"text"},{"type":"codeVoice","code":"TabView"},{"text":" populated with the given content where ","type":"text"},{"inlineContent":[{"text":"tab item","type":"text"}],"type":"emphasis"},{"text":" elements are defined.","type":"text"},{"text":" ","type":"text"},{"text":"Rendering wil change depending to OS version, with a top divider and a selected tab indicator for legacy layouts.","type":"text"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(selectedTab:count:content:)":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"selectedTab"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Binding","preciseIdentifier":"s:7SwiftUI7BindingV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":")"}],"abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items and a two-way binding to the selected tab index."},{"type":"text","text":" "},{"type":"text","text":"Number of tabs and selected tab are needed to compute the selected tab indicator for iOS lower than 26."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS 26+ or other platform, prefer instead "},{"type":"codeVoice","code":"OUDSTabBar(content:)"},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/oudstabbar\/init(selectedtab:count:content:)","title":"init(selectedTab:count:content:)","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)","kind":"symbol"},"component_tabBar_LiquidGlass_Sosh_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_dark.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark","alt":"A  tab bar component in dark mode with Liquid Glass effect and Sosh theme"},"component_tabBar_OrangeCompact_dark":{"type":"image","identifier":"component_tabBar_OrangeCompact_dark","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_dark.png","traits":["1x","light"]}],"alt":"A  tab bar component in dark mode without Liquid Glass effect and Orange Compact theme"},"doc://OUDSComponents/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP"},"https://r.orange.fr/r/S-ouds-doc-ios-tab-bar":{"titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"type":"link","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","title":"unified-design-system.orange.com","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar"},"doc://OUDSComponents/documentation/OUDSComponents":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"url":"\/documentation\/oudscomponents","kind":"symbol","type":"topic","role":"collection","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}]},"component_tabBar_LiquidGlass_OrangeCompact_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_dark.png","traits":["1x","light"]}],"type":"image","alt":"A  tab bar component in dark mode with Liquid Glass effect and Orange Compact theme","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark"}}}