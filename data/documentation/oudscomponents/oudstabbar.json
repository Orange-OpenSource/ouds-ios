{"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"metadata":{"title":"OUDSTabBar","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"}],"symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"OUDSTabBar"}],"modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents10OUDSTabBarV","roleHeading":"Structure","platforms":[{"unavailable":false,"introducedAt":"15.0","deprecated":false,"name":"iOS","beta":false},{"unavailable":false,"introducedAt":"13.0","deprecated":false,"name":"macOS","beta":false},{"unavailable":false,"introducedAt":"1.0","deprecated":false,"name":"visionOS","beta":false}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selected:count:content:)"],"anchor":"Initializers","title":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Appearances","text":"Appearances"},{"type":"paragraph","inlineContent":[{"text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars.","type":"text"},{"text":" ","type":"text"},{"text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"background color of tab bar can be changed for iOS lower than 26"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"background color of tab bar does not change since iOS 26"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed"},{"type":"text","text":" "},{"type":"text","text":"and not the text making theme not readable in dark color scheme"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","isActive":true},{"text":" component,","type":"text"},{"text":" ","type":"text"},{"text":"the native API is used instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you use SF Symbols for images, if they exist their "},{"type":"emphasis","inlineContent":[{"type":"text","text":"fill"}]},{"type":"text","text":" variant will be automatically used in the tab bar (native behaviour)."}]},{"type":"heading","text":"Platform considerations","anchor":"Platform-considerations","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"This component is tailored for iOS"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"On iPadOS the tabs do not apply the fonts since iPadOS 18","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The component is not available for watchOS"}]}]},{"content":[{"inlineContent":[{"text":"The component is not available for tvOS","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Guidelines","anchor":"Guidelines","level":2},{"type":"paragraph","inlineContent":[{"text":"OUDS guidelines recommends to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"limit when possible the number of items to 5"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"use both images and texts in tab bar items"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"use badges only when needed to avoid to have heavy tab bar","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"if decorative images are used for tab bar item, apply ","type":"text"},{"inlineContent":[{"text":"template","type":"text"}],"type":"emphasis"},{"type":"text","text":" rendering mode on it to apply color on tabs"}]}]}]},{"type":"heading","text":"Technical constraints","anchor":"Technical-constraints","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You must use in your tab bar items images with "},{"inlineContent":[{"text":"a size of 26 x 26","type":"text"}],"type":"strong"},{"type":"text","text":", otherwise rendering could be unaligned with Figma specifications"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,"},{"type":"text","text":" "},{"type":"text","text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"If your tabs embeded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your tabs embeded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)"},{"type":"text","text":" "},{"type":"text","text":"by using accessibiltiy value"}]}]}]},{"code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"text":"Selection of tabs","anchor":"Selection-of-tabs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For iOS lower than 26, a selected tab indicator can be displayed in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" if the "},{"type":"codeVoice","code":"count"},{"type":"text","text":" parameter is defined (to the number of tabs in the component)"},{"type":"text","text":" "},{"type":"text","text":"and if the "},{"type":"codeVoice","code":"selected"},{"type":"text","text":" parameter is equal to a given tag associated to a tab item."},{"type":"text","text":" "},{"type":"text","text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator."},{"type":"text","text":" "},{"type":"text","text":"This rule is only applied if selected tab indicator must be displayed."}]},{"type":"heading","level":2,"text":"Technical considerations","anchor":"Technical-considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to improve the Developer eXperience the current "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" implementation lets users define their own tab items."},{"type":"text","text":" "},{"type":"text","text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a "},{"type":"emphasis","inlineContent":[{"text":"picker","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Thus users will need to add their own accessiiblity label if badges are used or also apply "},{"type":"emphasis","inlineContent":[{"text":"template","type":"text"}]},{"type":"text","text":" rendering mode on images if needed."},{"type":"text","text":" "},{"type":"text","text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking."}]},{"level":2,"anchor":"Code-samples","type":"heading","text":"Code samples"},{"type":"codeListing","code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embeded.","    \/\/ Image with size of 26 x 26","    OUDSTabBar(selected: 0, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selected parameter","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","            .tag(1) \/\/ Must be used for the selected parameter","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selected parameter","    }"],"syntax":"swift"},{"level":2,"anchor":"Design-documentation","type":"heading","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"reference","isActive":true}]},{"level":2,"anchor":"Themes-rendering","type":"heading","text":"Themes rendering"},{"level":3,"anchor":"Liquid-Glass","type":"heading","text":"Liquid Glass"},{"level":4,"anchor":"Orange","type":"heading","text":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_dark"}]},{"text":"Orange Compact","type":"heading","anchor":"Orange-Compact","level":4},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark"}]},{"text":"Sosh","type":"heading","anchor":"Sosh","level":4},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark"}]},{"text":"Wireframe","type":"heading","anchor":"Wireframe","level":4},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark"}]},{"text":"Without Liquid Glass","type":"heading","anchor":"Without-Liquid-Glass","level":3},{"text":"Orange","type":"heading","anchor":"Orange","level":4},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Orange_dark"}]},{"text":"Orange Compact","type":"heading","anchor":"Orange-Compact","level":4},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_OrangeCompact_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_OrangeCompact_dark"}]},{"text":"Sosh","type":"heading","anchor":"Sosh","level":4},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_Sosh_dark","type":"image"}]},{"text":"Wireframe","type":"heading","anchor":"Wireframe","level":4},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Wireframe_light"},{"type":"text","text":" "},{"identifier":"component_tabBar_Wireframe_dark","type":"image"}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.0.0 (Figma component design version)"}]}],"name":"Version"},{"style":"note","type":"aside","content":[{"inlineContent":[{"text":"1.0.0","type":"text"}],"type":"paragraph"}],"name":"Since"}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstabbar"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar"},"kind":"symbol","abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"type":"text","text":" "},{"type":"text","text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS."},{"type":"text","text":" "},{"type":"text","text":"It allows users to switch between the sections of an app."},{"type":"text","text":" "},{"type":"text","text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations."}],"references":{"doc://OUDSComponents/documentation/OUDSComponents":{"type":"topic","url":"\/documentation\/oudscomponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","role":"collection","images":[{"identifier":"ic_folder_categories.png","type":"icon"}]},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png","type":"image","alt":null},"component_tabBar_LiquidGlass_Sosh_dark":{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","alt":"A  tab bar component in dark mode with Liquid Glass effect and Sosh theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_dark.png","traits":["1x","light"]}],"type":"image"},"component_tabBar_OrangeCompact_dark":{"identifier":"component_tabBar_OrangeCompact_dark","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_dark.png","traits":["1x","light"]}],"type":"image","alt":"A  tab bar component in dark mode without Liquid Glass effect and Orange Compact theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"abstract":[{"text":"Badge is a UI element that emphasizes system notifications, status, or the categorization of an information, throughout colour only.","type":"text"},{"text":" ","type":"text"},{"text":"Badge is rendered as a coloured shape, without icon, text or number; and its chosen size remains unchanged regardless of the changes of the interface size.","type":"text"}],"role":"symbol","type":"topic","url":"\/documentation\/oudscomponents\/oudsbadge","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","title":"OUDSBadge","navigatorTitle":[{"text":"OUDSBadge","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBadge","kind":"identifier"}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(selected:count:content:)":{"role":"symbol","type":"topic","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"selected"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":")"}],"title":"init(selected:count:content:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selected:count:content:)","url":"\/documentation\/oudscomponents\/oudstabbar\/init(selected:count:content:)","abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items."},{"type":"text","text":" "},{"type":"text","text":"Number of tabs and selected tab are needed to compute the selected tab indicator for iOS lower than 26."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS 26+ or other platform, prefer instead "},{"type":"codeVoice","code":"OUDSTabBar(content:)"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(content:)":{"url":"\/documentation\/oudscomponents\/oudstabbar\/init(content:)","type":"topic","abstract":[{"text":"Defines the tab bar component with given tab bar items