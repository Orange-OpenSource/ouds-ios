 theme","identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_light.png","traits":["1x","light"]}]},"component_tabBar_LiquidGlass_Orange_light":{"alt":"A tab bar component in light mode with Liquid Glass effect and Orange theme","identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_light.png","traits":["1x","light"]}]},"component_tabBar_OrangeCompact_light":{"alt":"A  tab bar component in light mode without Liquid Glass effect and Orange Compact theme","identifier":"component_tabBar_OrangeCompact_light","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_light.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(selectedTab:count:content:)":{"title":"init(selectedTab:count:content:)","type":"topic","abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items and a two-way binding to the selected tab index."},{"type":"text","text":" "},{"type":"text","text":"Number of tabs and selected tab are needed to compute the selected tab indicator for iOS lower than 26."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS 26+ or other platform, prefer instead "},{"type":"codeVoice","code":"OUDSTabBar(content:)"},{"type":"text","text":"."}],"kind":"symbol","role":"symbol","url":"\/documentation\/oudscomponents\/oudstabbar\/init(selectedtab:count:content:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"selectedTab","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Binding","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI7BindingV"},{"text":"<","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":">, ","kind":"text"},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":", ","kind":"text"},{"text":"content","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"doc://OUDSComponents/s8SendableP":{"title":"Swift.Sendable","identifier":"doc:\/\/OUDSComponents\/s8SendableP","type":"unresolvable"},"component_tabBar_LiquidGlass_Sosh_dark":{"alt":"A  tab bar component in dark mode with Liquid Glass effect and Sosh theme","identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_dark.png","traits":["1x","light"]}]},"component_tabBar_LiquidGlass_Orange_dark":{"alt":"A tab bar component in dark mode with Liquid Glass effect and Orange theme","identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_dark.png","traits":["1x","light"]}]},"component_tabBar_LiquidGlass_OrangeCompact_dark":{"alt":"A  tab bar component in dark mode with Liquid Glass effect and Orange Compact theme","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_dark.png","traits":["1x","light"]}]},"component_tabBar_Orange_light":{"alt":"A tab bar component in light mode without Liquid Glass effect and Orange theme","identifier":"component_tabBar_Orange_light","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Orange_light.png","traits":["1x","light"]}]},"doc://OUDSComponents/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","type":"unresolvable"},"doc://OUDSComponents/7SwiftUI4ViewP":{"title":"SwiftUICore.View","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","type":"unresolvable"},"doc://OUDSComponents/documentation/OUDSComponents":{"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"role":"collection","type":"topic","title":"Components","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","kind":"symbol","url":"\/documentation\/oudscomponents"},"ic_folder_categories.png":{"alt":null,"identifier":"ic_folder_categories.png","type":"image","variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]},"component_tabBar_Wireframe_light":{"alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme","identifier":"component_tabBar_Wireframe_light","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_light.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/Navigations":{"kind":"article","type":"topic","role":"article","abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"text":"navigation","type":"text"}]},{"type":"text","text":"."}],"images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"url":"\/documentation\/oudscomponents\/navigations","title":"Navigations","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/body":{"type":"topic","kind":"symbol","role":"symbol","abstract":[{"text":"Uses a native SwiftUI ","type":"text"},{"type":"codeVoice","code":"TabView"},{"text":" populated with the given content where ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tab item","type":"text"}]},{"text":" elements are defined.","type":"text"},{"text":" ","type":"text"},{"text":"Rendering wil change depending to OS version, with a top divider and a selected tab indicator for legacy layouts.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudstabbar\/body","title":"body","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier","text":"View"}]},"component_tabBar_Sosh_dark":{"identifier":"component_tabBar_Sosh_dark","type":"image","alt":"A  tab bar component in dark mode without Liquid Glass effect and Sosh theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Sosh_dark.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/View-Implementations":{"type":"topic","title":"View Implementations","abstract":[],"kind":"article","role":"collectionGroup","url":"\/documentation\/oudscomponents\/oudstabbar\/view-implementations","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"abstract":[{"text":"Badge is a UI element that emphasizes system notifications, status, or the categorization of an information, throughout colour only.","type":"text"},{"text":" ","type":"text"},{"text":"Badge is rendered as a coloured shape, without icon, text or number; and its chosen size remains unchanged regardless of the changes of the interface size.","type":"text"}],"title":"OUDSBadge","type":"topic","kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSBadge"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSBadge"}],"url":"\/documentation\/oudscomponents\/oudsbadge"},"component_tabBar_LiquidGlass_Wireframe_dark":{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image","alt":"A  tab bar component in dark mode with Liquid Glass effect and Wireframe theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_dark.png"}]},"component_tabBar_Orange_dark":{"identifier":"component_tabBar_Orange_dark","type":"image","alt":"A tab bar component in dark mode without Liquid Glass effect and Orange theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Orange_dark.png"}]},"component_tabBar_OrangeCompact_dark":{"identifier":"component_tabBar_OrangeCompact_dark","type":"image","alt":"A  tab bar component in dark mode without Liquid Glass effect and Orange Compact theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_dark.png"}]}}}