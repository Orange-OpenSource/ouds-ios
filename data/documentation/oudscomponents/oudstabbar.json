{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"symbolKind":"struct","modules":[{"name":"Components"}],"title":"OUDSTabBar","navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"externalID":"s:14OUDSComponents10OUDSTabBarV","role":"symbol","platforms":[{"introducedAt":"15.0","deprecated":false,"name":"iOS","unavailable":false,"beta":false},{"introducedAt":"13.0","deprecated":false,"name":"macOS","unavailable":false,"beta":false},{"introducedAt":"1.0","deprecated":false,"name":"visionOS","unavailable":false,"beta":false}],"roleHeading":"Structure"},"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)"],"title":"Initializers","generated":true},{"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"title":"Instance Properties","generated":true},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"],"title":"Default Implementations","generated":true}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"],"kind":"mentions"},{"content":[{"type":"heading","text":"Appearances","anchor":"Appearances","level":2},{"inlineContent":[{"type":"text","text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars."},{"type":"text","text":" "},{"type":"text","text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"background color of tab bar can be changed for iOS lower than 26","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"background color of tab bar does not change since iOS 26"}]}]},{"content":[{"inlineContent":[{"text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed","type":"text"},{"text":" ","type":"text"},{"text":"and not the text making theme not readable in dark color scheme","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge"},{"type":"text","text":" component,"},{"type":"text","text":" "},{"type":"text","text":"the native API is used instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you use SF Symbols for images, if they exist their "},{"type":"emphasis","inlineContent":[{"text":"fill","type":"text"}]},{"type":"text","text":" variant will be automatically used in the tab bar (native behaviour)."}]},{"anchor":"Platform-considerations","type":"heading","level":2,"text":"Platform considerations"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"This component is tailored for iOS","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"On iPadOS the tabs do not apply the fonts since iPadOS 18"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The component is not available for watchOS"}]}]},{"content":[{"inlineContent":[{"text":"The component is not available for tvOS","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"Guidelines","text":"Guidelines"},{"type":"paragraph","inlineContent":[{"text":"OUDS guidelines recommends to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"limit when possible the number of items to 5"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"use both images and texts in tab bar items","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"use badges only when needed to avoid to have heavy tab bar"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"if decorative images are used for tab bar item, apply ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"template","type":"text"}]},{"type":"text","text":" rendering mode on it to apply color on tabs"}]}]}]},{"type":"heading","level":2,"text":"Technical constraints","anchor":"Technical-constraints"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You must use in your tab bar items images with "},{"type":"strong","inlineContent":[{"type":"text","text":"a size of 26 x 26"}]},{"text":", otherwise rendering could be unaligned with Figma specifications","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS."}],"type":"paragraph"}]}]},{"text":"Accessibility considerations","anchor":"Accessibility-considerations","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)"},{"type":"text","text":" "},{"type":"text","text":"by using accessibiltiy value"}],"type":"paragraph"}]}]},{"syntax":"swift","code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""],"type":"codeListing"},{"level":2,"type":"heading","text":"Selection of tabs","anchor":"Selection-of-tabs"},{"type":"paragraph","inlineContent":[{"text":"For iOS lower than 26, a selected tab indicator can be displayed in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" if the "},{"type":"codeVoice","code":"count"},{"type":"text","text":" parameter is defined (to the number of tabs in the component)"},{"text":" ","type":"text"},{"text":"and if the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding value is equal to a given tag associated to a tab item.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator.","type":"text"},{"text":" ","type":"text"},{"text":"This rule is only applied if selected tab indicator must be displayed.","type":"text"},{"text":" ","type":"text"},{"text":"When the user taps a tab, the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding is updated automatically, keeping the parent view in sync.","type":"text"}]},{"level":2,"type":"heading","text":"Technical considerations","anchor":"Technical-considerations"},{"type":"paragraph","inlineContent":[{"text":"In order to improve the Developer eXperience the current ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" implementation lets users define their own tab items.","type":"text"},{"text":" ","type":"text"},{"text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a ","type":"text"},{"inlineContent":[{"type":"text","text":"picker"}],"type":"emphasis"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Thus users will need to add their own accessiiblity label if badges are used or also apply "},{"type":"emphasis","inlineContent":[{"type":"text","text":"template"}]},{"type":"text","text":" rendering mode on images if needed."},{"type":"text","text":" "},{"type":"text","text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking."}]},{"level":2,"anchor":"Code-samples","text":"Code samples","type":"heading"},{"syntax":"swift","code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embedded.","    \/\/ Image with size of 26 x 26","    @State private var selectedTab = 0","","    OUDSTabBar(selectedTab: $selectedTab, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selectedTab binding value","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","             }","            .tag(1) \/\/ Must be used for the selectedTab binding","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selectedTab binding","    }"],"type":"codeListing"},{"level":2,"anchor":"Design-documentation","text":"Design documentation","type":"heading"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","isActive":true,"type":"reference"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Themes rendering","anchor":"Themes-rendering"},{"level":3,"text":"Liquid Glass","type":"heading","anchor":"Liquid-Glass"},{"level":4,"text":"Orange","type":"heading","anchor":"Orange"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}],"type":"paragraph"},{"level":4,"anchor":"Orange-Compact","text":"Orange Compact","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image"}]},{"text":"Sosh","anchor":"Sosh","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark"}]},{"level":4,"text":"Wireframe","anchor":"Wireframe","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"}],"type":"paragraph"},{"text":"Without Liquid Glass","anchor":"Without-Liquid-Glass","type":"heading","level":3},{"anchor":"Orange","type":"heading","level":4,"text":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Orange_light"},{"type":"text","text":" "},{"identifier":"component_tabBar_Orange_dark","type":"image"}]},{"type":"heading","text":"Orange Compact","level":4,"anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_OrangeCompact_dark"}]},{"type":"heading","text":"Sosh","level":4,"anchor":"Sosh"},{"inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_Sosh_dark","type":"image"}],"type":"paragraph"},{"text":"Wireframe","type":"heading","level":4,"anchor":"Wireframe"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Wireframe_dark"}],"type":"paragraph"},{"type":"aside","style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"text":"1.0.0 (Figma component design version)","type":"text"}]}]},{"type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"1.0.0","type":"text"}]}],"style":"note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","interfaceLanguage":"swift"},"kind":"symbol","relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstabbar"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"type":"text","text":" "},{"type":"text","text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS."},{"type":"text","text":" "},{"type":"text","text":"It allows users to switch between the sections of an app."},{"type":"text","text":" "},{"type":"text","text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations."}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/Navigations":{"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations","title":"Navigations","kind":"article","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"identifier":"ic_folder_categories.png","type":"card"}],"abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"navigation"}]},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/navigations","role":"article"},"component_tabBar_Orange_dark":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Orange_dark.png"}],"alt":"A tab bar component in dark mode without Liquid Glass effect and Orange theme","identifier":"component_tabBar_Orange_dark","type":"image"},"component_tabBar_Orange_light":{"type":"image","alt":"A tab bar component in light mode without Liquid Glass effect and Orange theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Orange_light.png"}],"identifier":"component_tabBar_Orange_light"},"component_tabBar_Wireframe_dark":{"type":"image","identifier":"component_tabBar_Wireframe_dark","alt":"A  tab bar component in dark mode without Liquid Glass effect and Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_dark.png","traits":["1x","light"]}]},"component_tabBar_LiquidGlass_Sosh_light":{"alt":"A  tab bar component in ligh