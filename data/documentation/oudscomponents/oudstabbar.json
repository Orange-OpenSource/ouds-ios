{"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selected:count:content:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"],"title":"Default Implementations","generated":true,"anchor":"Default-Implementations"}],"abstract":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","isActive":true},{"type":"text","text":" is a SwiftUI "},{"type":"codeVoice","code":"TabView"},{"text":" which applies OUDS tokens and styles on its content supposing to be","type":"text"},{"text":" ","type":"text"},{"text":"views with ","type":"text"},{"inlineContent":[{"type":"text","text":"tab bar items"}],"type":"emphasis"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"The tab bar is, for iOS, a bottom bar with tabs containing for example images, texts and badges.","type":"text"}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstabbar"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"]},{"content":[{"type":"heading","level":2,"text":"Appearances","anchor":"Appearances"},{"type":"paragraph","inlineContent":[{"text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars.","type":"text"},{"text":" ","type":"text"},{"text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"background color of tab bar can be changed for iOS lower than 26"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"background color of tab bar does not change since iOS 26"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed"},{"type":"text","text":" "},{"type":"text","text":"and not the text making theme not readable in dark color scheme"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","isActive":true},{"text":" component,","type":"text"},{"text":" ","type":"text"},{"text":"the native API is used instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you use SF Symbols for images, if they exist their ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"fill","type":"text"}]},{"text":" variant will be automatically used in the tab bar (native behaviour).","type":"text"}]},{"type":"heading","level":2,"text":"Platform considerations","anchor":"Platform-considerations"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"This component is tailored for iOS"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"On iPadOS the tabs do not apply the fonts since iPadOS 18"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The component is not available for watchOS"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The component is not available for tvOS"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Guidelines","anchor":"Guidelines"},{"type":"paragraph","inlineContent":[{"text":"OUDS guidelines recommends to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"limit when possible the number of items to 5"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"use both images and texts in tab bar items"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"use badges only when needed to avoid to have heavy tab bar"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"if decorative images are used for tab bar item, apply "},{"type":"emphasis","inlineContent":[{"text":"template","type":"text"}]},{"type":"text","text":" rendering mode on it to apply color on tabs"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Technical constraints","anchor":"Technical-constraints"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"You must use in your tab bar items images with "},{"type":"strong","inlineContent":[{"text":"a size of 26 x 26","type":"text"}]},{"type":"text","text":", otherwise rendering could be unaligned with Figma specifications"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,"},{"type":"text","text":" "},{"type":"text","text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS lower than 18"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"If your tabs embeded in the "},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If your tabs embeded in the "},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)"},{"type":"text","text":" "},{"type":"text","text":"by using accessibilty value"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""]},{"type":"heading","level":2,"text":"Selection of tabs","anchor":"Selection-of-tabs"},{"type":"paragraph","inlineContent":[{"text":"For iOS lower than 26, a selected tab indicator can be displayed in the ","type":"text"},{"type":"codeVoice","code":"OUDSTabBar"},{"text":" if the ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" parameter is defined (to the number of tabs in the component)","type":"text"},{"text":" ","type":"text"},{"text":"and if the ","type":"text"},{"type":"codeVoice","code":"selected"},{"text":" parameter is equal to a given tag associated to a tab item.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator.","type":"text"},{"text":" ","type":"text"},{"text":"This rule only applis if selected tab indicator must be displayed.","type":"text"}]},{"type":"heading","level":2,"text":"Technical considerations","anchor":"Technical-considerations"},{"type":"paragraph","inlineContent":[{"text":"In order to improve the Developer eXperience the current ","type":"text"},{"type":"codeVoice","code":"OUDSTabBar"},{"text":" implementation lets users define their own tab items.","type":"text"},{"text":" ","type":"text"},{"text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"picker","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Thus users will need to add their own accessiiblity label if badges are used or also apply ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"template","type":"text"}]},{"text":" rendering mode on images if needed.","type":"text"}]},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embeded.","    \/\/ Image with size of 26 x 26","    OUDSTabBar(selected: 0, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selected parameter","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","            .tag(1) \/\/ Must be used for the selected parameter","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selected parameter","    }"]},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","isActive":true}]},{"type":"heading","level":2,"text":"Themes rendering","anchor":"Themes-rendering"},{"type":"heading","level":3,"text":"Liquid Glass","anchor":"Liquid-Glass"},{"type":"heading","level":4,"text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_dark"}]},{"type":"heading","level":4,"text":"Orange Business Tools","anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeBusinessTools_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeBusinessTools_dark"}]},{"type":"heading","level":4,"text":"Sosh","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark"}]},{"type":"heading","level":4,"text":"Wireframe","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark"}]},{"type":"heading","level":3,"text":"Without Liquid Glass","anchor":"Without-Liquid-Glass"},{"type":"heading","level":4,"text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Orange_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_Orange_dark"}]},{"type":"heading","level":4,"text":"Orange Business Tools","anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_OrangeBusinessTools_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_OrangeBusinessTools_dark"}]},{"type":"heading","level":4,"text":"Sosh","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Sosh_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_Sosh_dark"}]},{"type":"heading","level":4,"text":"Wireframe","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Wireframe_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_Wireframe_dark"}]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"1.0.0 (Figma component design version)","type":"text"}]}],"name":"Version"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"1.0.0","type":"text"}]}],"name":"Since"}],"kind":"content"}],"metadata":{"platforms":[{"name":"iOS","beta":false,"introducedAt":"15.0","deprecated":false,"unavailable":false},{"beta":false,"unavailable":false,"introducedAt":"15.0","name":"macOS","deprecated":false},{"name":"visionOS","beta":false,"introducedAt":"1.0","deprecated":false,"unavailable":false}],"modules":[{"name":"Components"}],"symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"role":"symbol","externalID":"s:14OUDSComponents10OUDSTabBar