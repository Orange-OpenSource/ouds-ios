{"abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"text":" ","type":"text"},{"text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to switch between the sections of an app.","type":"text"},{"text":" ","type":"text"},{"text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Content"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"]},{"kind":"content","content":[{"text":"Appearances","level":2,"anchor":"Appearances","type":"heading"},{"inlineContent":[{"type":"text","text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars."},{"type":"text","text":" "},{"type":"text","text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"background color of tab bar can be changed for iOS lower than 26"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"background color of tab bar does not change since iOS 26"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed"},{"type":"text","text":" "},{"type":"text","text":"and not the text making theme not readable in dark color scheme"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","isActive":true},{"type":"text","text":" component,"},{"type":"text","text":" "},{"type":"text","text":"the native API is used instead."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you use SF Symbols for images, if they exist their "},{"type":"emphasis","inlineContent":[{"text":"fill","type":"text"}]},{"type":"text","text":" variant will be automatically used in the tab bar (native behaviour)."}],"type":"paragraph"},{"text":"Platform considerations","level":2,"anchor":"Platform-considerations","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"This component is tailored for iOS"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"On iPadOS the tabs do not apply the fonts since iPadOS 18"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The component is not available for watchOS"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The component is not available for tvOS"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Guidelines","level":2,"anchor":"Guidelines","type":"heading"},{"inlineContent":[{"type":"text","text":"OUDS guidelines recommends to:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"limit when possible the number of items to 5"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"use both images and texts in tab bar items"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"use badges only when needed to avoid to have heavy tab bar"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"if decorative images are used for tab bar item, apply "},{"inlineContent":[{"type":"text","text":"template"}],"type":"emphasis"},{"type":"text","text":" rendering mode on it to apply color on tabs"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Technical constraints","level":2,"anchor":"Technical-constraints","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"You must use in your tab bar items images with "},{"inlineContent":[{"type":"text","text":"a size of 26 x 26"}],"type":"strong"},{"type":"text","text":", otherwise rendering could be unaligned with Figma specifications"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,"},{"type":"text","text":" "},{"type":"text","text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"If your tabs embeded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If your tabs embeded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)"},{"type":"text","text":" "},{"type":"text","text":"by using accessibiltiy value"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""],"syntax":"swift","type":"codeListing"},{"text":"Selection of tabs","level":2,"anchor":"Selection-of-tabs","type":"heading"},{"inlineContent":[{"type":"text","text":"For iOS lower than 26, a selected tab indicator can be displayed in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" if the "},{"type":"codeVoice","code":"count"},{"type":"text","text":" parameter is defined (to the number of tabs in the component)"},{"type":"text","text":" "},{"type":"text","text":"and if the "},{"type":"codeVoice","code":"selected"},{"type":"text","text":" parameter is equal to a given tag associated to a tab item."},{"type":"text","text":" "},{"type":"text","text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator."},{"type":"text","text":" "},{"type":"text","text":"This rule is only applied if selected tab indicator must be displayed."}],"type":"paragraph"},{"text":"Technical considerations","level":2,"anchor":"Technical-considerations","type":"heading"},{"inlineContent":[{"type":"text","text":"In order to improve the Developer eXperience the current "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" implementation lets users define their own tab items."},{"type":"text","text":" "},{"type":"text","text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a "},{"type":"emphasis","inlineContent":[{"text":"picker","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Thus users will need to add their own accessiiblity label if badges are used or also apply "},{"type":"emphasis","inlineContent":[{"text":"template","type":"text"}]},{"type":"text","text":" rendering mode on images if needed."},{"type":"text","text":" "},{"type":"text","text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking."}],"type":"paragraph"},{"text":"Code samples","level":2,"anchor":"Code-samples","type":"heading"},{"code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embeded.","    \/\/ Image with size of 26 x 26","    OUDSTabBar(selected: 0, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selected parameter","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","            .tag(1) \/\/ Must be used for the selected parameter","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selected parameter","    }"],"syntax":"swift","type":"codeListing"},{"text":"Design documentation","level":2,"anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","isActive":true}],"type":"paragraph"},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"text":"Liquid Glass","level":3,"anchor":"Liquid-Glass","type":"heading"},{"text":"Orange","level":4,"anchor":"Orange","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_dark"}],"type":"paragraph"},{"text":"Orange Compact","level":4,"anchor":"Orange-Compact","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark"}],"type":"paragraph"},{"text":"Sosh","level":4,"anchor":"Sosh","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark"}],"type":"paragraph"},{"text":"Wireframe","level":4,"anchor":"Wireframe","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark"}],"type":"paragraph"},{"text":"Without Liquid Glass","level":3,"anchor":"Without-Liquid-Glass","type":"heading"},{"text":"Orange","level":4,"anchor":"Orange","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Orange_dark"}],"type":"paragraph"},{"text":"Orange Compact","level":4,"anchor":"Orange-Compact","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_OrangeCompact_dark"}],"type":"paragraph"},{"text":"Sosh","level":4,"anchor":"Sosh","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Sosh_dark"}],"type":"paragraph"},{"text":"Wireframe","level":4,"anchor":"Wireframe","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Wireframe_dark"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"1.0.0 (Figma component design version)","type":"text"}]}],"style":"note","name":"Version","type":"aside"},{"content":[{"type":"paragraph","inlineContent":[{"text":"1.0.0","type":"text"}]}],"style":"note","name":"Since","type":"aside"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstabbar"]}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo"}],"sections":[],"kind":"symbol","topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selected:count:content:)"]},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"]},{"generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"],"title":"Default Implementations"}],"metadata":{"platforms":[{"introducedAt":"15.0","beta":false,"deprecated":false,"unavailable":false,"name":"iOS"},{"introducedAt":"13.0","beta":false,"deprecated":false,"unavailable":false,"name":"macOS"},{"introducedAt":"1.0","beta":false,"deprecated":false,"unavailable":false,"name":"visionOS"}],"symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"}],"modules":[{"name":"Components"}],"roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"OUDSTabBar"}],"externa