{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSTabBar"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Content"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI4ViewP","text":"View","kind":"typeIdentifier"}]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"],"kind":"mentions"},{"content":[{"level":2,"text":"Appearances","type":"heading","anchor":"Appearances"},{"inlineContent":[{"type":"text","text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars."},{"type":"text","text":" "},{"type":"text","text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"background color of tab bar can be changed for iOS lower than 26"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"background color of tab bar does not change since iOS 26"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed"},{"text":" ","type":"text"},{"type":"text","text":"and not the text making theme not readable in dark color scheme"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge"},{"text":" component,","type":"text"},{"text":" ","type":"text"},{"text":"the native API is used instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you use SF Symbols for images, if they exist their ","type":"text"},{"inlineContent":[{"text":"fill","type":"text"}],"type":"emphasis"},{"text":" variant will be automatically used in the tab bar (native behaviour).","type":"text"}],"type":"paragraph"},{"anchor":"Platform-considerations","type":"heading","text":"Platform considerations","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This component is tailored for iOS"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On iPadOS the tabs do not apply the fonts since iPadOS 18"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The component is not available for watchOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The component is not available for tvOS","type":"text"}]}]}]},{"level":2,"type":"heading","anchor":"Guidelines","text":"Guidelines"},{"type":"paragraph","inlineContent":[{"text":"OUDS guidelines recommends to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"limit when possible the number of items to 5"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"use both images and texts in tab bar items"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"use badges only when needed to avoid to have heavy tab bar"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"if decorative images are used for tab bar item, apply "},{"type":"emphasis","inlineContent":[{"type":"text","text":"template"}]},{"type":"text","text":" rendering mode on it to apply color on tabs"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","anchor":"Technical-constraints","text":"Technical constraints"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"You must use in your tab bar items images with "},{"type":"strong","inlineContent":[{"type":"text","text":"a size of 26 x 26"}]},{"type":"text","text":", otherwise rendering could be unaligned with Figma specifications"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,"},{"type":"text","text":" "},{"type":"text","text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS."}],"type":"paragraph"}]}]},{"level":2,"type":"heading","anchor":"Accessibility-considerations","text":"Accessibility considerations"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)"},{"type":"text","text":" "},{"type":"text","text":"by using accessibiltiy value"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""]},{"level":2,"type":"heading","anchor":"Selection-of-tabs","text":"Selection of tabs"},{"type":"paragraph","inlineContent":[{"text":"For iOS lower than 26, a selected tab indicator can be displayed in the ","type":"text"},{"type":"codeVoice","code":"OUDSTabBar"},{"text":" if the ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" parameter is defined (to the number of tabs in the component)","type":"text"},{"text":" ","type":"text"},{"text":"and if the ","type":"text"},{"type":"codeVoice","code":"selectedTab"},{"text":" binding value is equal to a given tag associated to a tab item.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator.","type":"text"},{"text":" ","type":"text"},{"text":"This rule is only applied if selected tab indicator must be displayed.","type":"text"},{"text":" ","type":"text"},{"text":"When the user taps a tab, the ","type":"text"},{"type":"codeVoice","code":"selectedTab"},{"text":" binding is updated automatically, keeping the parent view in sync.","type":"text"}]},{"level":2,"type":"heading","anchor":"Technical-considerations","text":"Technical considerations"},{"type":"paragraph","inlineContent":[{"text":"In order to improve the Developer eXperience the current ","type":"text"},{"type":"codeVoice","code":"OUDSTabBar"},{"text":" implementation lets users define their own tab items.","type":"text"},{"text":" ","type":"text"},{"text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a ","type":"text"},{"inlineContent":[{"type":"text","text":"picker"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Thus users will need to add their own accessiiblity label if badges are used or also apply ","type":"text"},{"inlineContent":[{"type":"text","text":"template"}],"type":"emphasis"},{"text":" rendering mode on images if needed.","type":"text"},{"text":" ","type":"text"},{"text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking.","type":"text"}]},{"level":2,"type":"heading","anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embedded.","    \/\/ Image with size of 26 x 26","    @State private var selectedTab = 0","","    OUDSTabBar(selectedTab: $selectedTab, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selectedTab binding value","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","             }","            .tag(1) \/\/ Must be used for the selectedTab binding","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selectedTab binding","    }"]},{"level":2,"type":"heading","anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","isActive":true,"type":"reference"}]},{"level":2,"type":"heading","anchor":"Themes-rendering","text":"Themes rendering"},{"level":3,"type":"heading","anchor":"Liquid-Glass","text":"Liquid Glass"},{"level":4,"type":"heading","anchor":"Orange","text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}]},{"level":4,"type":"heading","anchor":"Orange-Compact","text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image"}]},{"level":4,"type":"heading","anchor":"Sosh","text":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image"}]},{"level":4,"type":"heading","anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"}]},{"level":3,"type":"heading","anchor":"Without-Liquid-Glass","text":"Without Liquid Glass"},{"level":4,"type":"heading","anchor":"Orange","text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Orange_dark","type":"image"}]},{"level":4,"type":"heading","anchor":"Orange-Compact","text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_OrangeCompact_dark","type":"image"}]},{"level":4,"type":"heading","anchor":"Sosh","text":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Sosh_dark","type":"image"}]},{"level":4,"type":"heading","anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Wireframe_dark","type":"image"}]},{"type":"aside","name":"Version","style":"note","content":[{"inlineContent":[{"type":"text","text":"1.0.0 (Figma component design version)"}],"type":"paragraph"}]},{"type":"aside","name":"Since","style":"note","content":[{"inlineContent":[{"type":"text","text":"1.0.0"}],"type":"paragraph"}]}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/oudscomponents\/oudstabbar"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)"],"title":"Initializers","anchor":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"title":"Instance Properties","anchor":"Instance-Properties","generated":true},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"]}],"metadata":{"platforms":[{"name":"iOS","deprecated":false,"beta":false,"introducedAt":"15.0","unavailable":false},{"introducedAt":"13.0","unavailable":false,"name":"macOS","beta":false,"deprecated":false},{"introducedAt":"1.0","unavailable":false,"name":"visionOS","beta":false,"deprecated":false}],"title":"OUDSTabBar","roleHeading":"Structure","navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"role":"symbol","symbolKind":"struct","modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents10OUDSTabBarV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTabBar"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"text":"The Tab bar is a system navigation component with a position which can vary depending to the OS.","type":"text"},{"text":" ","type":"text"},{"text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to switch between the sections of an app.","type":"text"},{"text":" ","type":"text"},{"text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations.","type":"text"}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"navigatorTitle":[{"text":"OUDSBadge","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsbadge","role":"symbol","type":"topic","title":"OUDSBadge","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBadge","kind":"identifier"}],"abstract":[{"type":"text","text":"Badge is a UI element that emphasizes system notifications, status, or the categorization of an information, throughout colour only."},{"type":"text","text":" "},{"type":"text","text":"Badge is rendered as a coloured shape, without icon, text or number; and its chosen size remains unchanged regardless of the changes of the interface size."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","kind":"symbol"},"component_tabBar_Orange_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Orange_dark.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_Orange_dark","alt":"A tab bar component in dark mode without Liquid Glass effect and Orange theme"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","role":"collection","type":"topic","title":"Components","images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"type":"codeV