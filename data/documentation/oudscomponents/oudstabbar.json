k","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_dark.png"}],"type":"image"},"ic_folder_categories.png":{"alt":null,"identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"type":"image"},"component_tabBar_Orange_dark":{"identifier":"component_tabBar_Orange_dark","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Orange_dark.png"}],"alt":"A tab bar component in dark mode without Liquid Glass effect and Orange theme","type":"image"},"component_tabBar_LiquidGlass_Wireframe_light":{"alt":"A  tab bar component in light mode with Liquid Glass effect and Wireframe theme","identifier":"component_tabBar_LiquidGlass_Wireframe_light","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_light.png"}],"type":"image"},"doc://OUDSComponents/7SwiftUI4ViewP":{"identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","title":"SwiftUICore.View","type":"unresolvable"},"doc://OUDSComponents/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype","type":"unresolvable"},"https://r.orange.fr/r/S-ouds-doc-ios-tab-bar":{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"title":"unified-design-system.orange.com","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"link"},"doc://OUDSComponents/s8SendableP":{"identifier":"doc:\/\/OUDSComponents\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"component_tabBar_Wireframe_light":{"alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme","identifier":"component_tabBar_Wireframe_light","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_light.png"}],"type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/body":{"role":"symbol","kind":"symbol","type":"topic","abstract":[{"text":"Uses a native SwiftUI ","type":"text"},{"code":"TabView","type":"codeVoice"},{"text":" populated with the given content where ","type":"text"},{"inlineContent":[{"type":"text","text":"tab item"}],"type":"emphasis"},{"text":" elements are defined.","type":"text"},{"text":" ","type":"text"},{"text":"Rendering wil change depending to OS version, with a top divider and a selected tab indicator for legacy layouts.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body","url":"\/documentation\/oudscomponents\/oudstabbar\/body","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}],"title":"body"},"component_tabBar_Wireframe_dark":{"alt":"A  tab bar component in dark mode without Liquid Glass effect and Wireframe theme","identifier":"component_tabBar_Wireframe_dark","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_dark.png"}],"type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"url":"\/documentation\/oudscomponents\/oudsbadge","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","role":"symbol","title":"OUDSBadge","navigatorTitle":[{"kind":"identifier","text":"OUDSBadge"}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSBadge","kind":"identifier"}],"abstract":[{"type":"text","text":"Badge is a UI element that emphasizes system notifications, status, or the categorization of an information, throughout colour only."},{"type":"text","text":" "},{"type":"text","text":"Badge is rendered as a coloured shape, without icon, text or number; and its chosen size remains unchanged regardless of the changes of the interface size."}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/View-Implementations":{"role":"collectionGroup","abstract":[],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","type":"topic","kind":"article","title":"View Implementations","url":"\/documentation\/oudscomponents\/oudstabbar\/view-implementations"},"doc://OUDSComponents/documentation/OUDSComponents/Navigations":{"role":"article","abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"navigation"}],"type":"strong"},{"text":".","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations","type":"topic","kind":"article","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"title":"Navigations","url":"\/documentation\/oudscomponents\/navigations"},"component_tabBar_Orange_light":{"alt":"A tab bar component in light mode without Liquid Glass effect and Orange theme","identifier":"component_tabBar_Orange_light","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Orange_light.png"}],"type":"image"},"component_tabBar_LiquidGlass_Sosh_light":{"alt":"A  tab bar component in light mode with Liquid Glass effect and Sosh theme","identifier":"component_tabBar_LiquidGlass_Sosh_light","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_light.png"}],"type":"image"},"component_tabBar_OrangeCompact_dark":{"alt":"A  tab bar component in dark mode without Liquid Glass effect and Orange Compact theme","identifier":"component_tabBar_OrangeCompact_dark","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_dark.png"}],"type":"image"},"component_tabBar_LiquidGlass_OrangeCompact_dark":{"alt":"A  tab bar component in dark mode with Liquid Glass effect and Orange Compact theme","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_dark.png"}],"type":"image"},"component_tabBar_OrangeCompact_light":{"alt":"A  tab bar component in light mode without Liquid Glass effect and Orange Compact theme","identifier":"component_tabBar_OrangeCompact_light","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_light.png"}],"type":"image"}}}