DSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}],"type":"topic","kind":"symbol","url":"\/documentation\/oudscomponents\/oudstabbar\/body","abstract":[{"type":"text","text":"Uses a native SwiftUI "},{"type":"codeVoice","code":"TabView"},{"text":" populated with the given content where ","type":"text"},{"inlineContent":[{"text":"tab item","type":"text"}],"type":"emphasis"},{"text":" elements are defined.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Warning: rendering wil change depending to OS version!"}],"title":"body"},"https://r.orange.fr/r/S-ouds-doc-ios-tab-bar":{"url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","title":"unified-design-system.orange.com","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"link"},"component_tabBar_Wireframe_light":{"alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_Wireframe_light","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/Navigations":{"role":"article","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations","kind":"article","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"type":"topic","abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"navigation"}]},{"type":"text","text":"."}],"title":"Navigations","url":"\/documentation\/oudscomponents\/navigations"},"component_tabBar_Orange_light":{"alt":"A tab bar component in light mode without Liquid Glass effect and Orange theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Orange_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_Orange_light","type":"image"}}}