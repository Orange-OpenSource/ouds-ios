ight mode without Liquid Glass effect and Orange theme"},"component_tabBar_Wireframe_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_Wireframe_light","alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/View-Implementations":{"kind":"article","role":"collectionGroup","abstract":[],"title":"View Implementations","url":"\/documentation\/oudscomponents\/oudstabbar\/view-implementations","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","role":"collection","type":"topic","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(selectedTab:count:content:)":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items and a two-way binding to the selected tab index."},{"type":"text","text":" "},{"type":"text","text":"Number of tabs and selected tab are needed to compute the selected tab indicator for iOS lower than 26."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS 26+ or other platform, prefer instead "},{"code":"OUDSTabBar(content:)","type":"codeVoice"},{"type":"text","text":"."}],"title":"init(selectedTab:count:content:)","u