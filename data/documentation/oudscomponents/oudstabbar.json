SComponents\/OUDSTabBar","url":"\/documentation\/oudscomponents\/oudstabbar","title":"OUDSTabBar","role":"symbol","abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"type":"text","text":" "},{"type":"text","text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS."},{"type":"text","text":" "},{"type":"text","text":"It allows users to switch between the sections of an app."},{"type":"text","text":" "},{"type":"text","text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations."}],"type":"topic","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"role":"collection","url":"\/documentation\/oudscomponents","kind":"symbol","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components"},"component_tabBar_OrangeCompact_dark":{"alt":"A  tab bar component in dark mode without Liquid Glass effect and Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_dark.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_OrangeCompact_dark"},"component_tabBar_Wireframe_light":{"alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme","variants":[{"url":"\/images\/OUDSComponen