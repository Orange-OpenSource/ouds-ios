ve SwiftUI ","type":"text"},{"code":"TabView","type":"codeVoice"},{"text":" populated with the given content where ","type":"text"},{"inlineContent":[{"text":"tab item","type":"text"}],"type":"emphasis"},{"text":" elements are defined.","type":"text"},{"text":" ","type":"text"},{"text":"Rendering wil change depending to OS version, with a top divider and a selected tab indicator for legacy layouts.","type":"text"}],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI4ViewP","text":"View","kind":"typeIdentifier"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"role":"collection","title":"Components","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"kind":"symbol","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"url":"\/documentation\/oudscomponents"},"doc://OUDSComponents/documentation/OUDSComponents/Navigations":{"title":"Navigations","abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"navigation","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"role":"article","type":"topic","kind":"article","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations","url":"\/documentation\/oudscomponents\/navigations"},"co