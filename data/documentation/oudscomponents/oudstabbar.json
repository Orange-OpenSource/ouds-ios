{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)"],"anchor":"Initializers","title":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"abstract":[{"text":"The Tab bar is a system navigation component with a position which can vary depending to the OS.","type":"text"},{"text":" ","type":"text"},{"text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to switch between the sections of an app.","type":"text"},{"text":" ","type":"text"},{"text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations.","type":"text"}],"kind":"symbol","variants":[{"paths":["\/documentation\/oudscomponents\/oudstabbar"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar"},"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"platforms":[{"introducedAt":"15.0","unavailable":false,"beta":false,"deprecated":false,"name":"iOS"},{"introducedAt":"13.0","unavailable":false,"beta":false,"deprecated":false,"name":"macOS"},{"introducedAt":"1.0","unavailable":false,"beta":false,"deprecated":false,"name":"visionOS"}],"roleHeading":"Structure","title":"OUDSTabBar","role":"symbol","externalID":"s:14OUDSComponents10OUDSTabBarV","navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"modules":[{"name":"Components"}],"symbolKind":"struct"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"]},{"kind":"content","content":[{"text":"Appearances","level":2,"type":"heading","anchor":"Appearances"},{"type":"paragraph","inlineContent":[{"text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars.","type":"text"},{"text":" ","type":"text"},{"text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"background color of tab bar can be changed for iOS lower than 26","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"background color of tab bar does not change since iOS 26","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed","type":"text"},{"text":" ","type":"text"},{"text":"and not the text making theme not readable in dark color scheme","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","isActive":true,"type":"reference"},{"text":" component,","type":"text"},{"text":" ","type":"text"},{"text":"the native API is used instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you use SF Symbols for images, if they exist their ","type":"text"},{"inlineContent":[{"text":"fill","type":"text"}],"type":"emphasis"},{"text":" variant will be automatically used in the tab bar (native behaviour).","type":"text"}]},{"text":"Platform considerations","level":2,"type":"heading","anchor":"Platform-considerations"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"This component is tailored for iOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"On iPadOS the tabs do not apply the fonts since iPadOS 18","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The component is not available for watchOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The component is not available for tvOS","type":"text"}]}]}],"type":"unorderedList"},{"text":"Guidelines","level":2,"type":"heading","anchor":"Guidelines"},{"type":"paragraph","inlineContent":[{"text":"OUDS guidelines recommends to:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"limit when possible the number of items to 5","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"use both images and texts in tab bar items","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"use badges only when needed to avoid to have heavy tab bar","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"if decorative images are used for tab bar item, apply ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"template","type":"text"}]},{"text":" rendering mode on it to apply color on tabs","type":"text"}]}]}],"type":"unorderedList"},{"text":"Technical constraints","level":2,"type":"heading","anchor":"Technical-constraints"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You must use in your tab bar items images with ","type":"text"},{"type":"strong","inlineContent":[{"text":"a size of 26 x 26","type":"text"}]},{"text":", otherwise rendering could be unaligned with Figma specifications","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,","type":"text"},{"text":" ","type":"text"},{"text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Accessibility considerations","level":2,"type":"heading","anchor":"Accessibility-considerations"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"If your tabs embedded in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If your tabs embedded in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)","type":"text"},{"text":" ","type":"text"},{"text":"by using accessibiltiy value","type":"text"}]}]}],"type":"unorderedList"},{"type":"codeListing","syntax":"swift","code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""]},{"text":"Selection of tabs","level":2,"type":"heading","anchor":"Selection-of-tabs"},{"inlineContent":[{"text":"For iOS lower than 26, a selected tab indicator can be displayed in the ","type":"text"},{"code":"OUDSTabBar","type":"codeVoice"},{"text":" if the ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" parameter is defined (to the number of tabs in the component)","type":"text"},{"text":" ","type":"text"},{"text":"and if the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding value is equal to a given tag associated to a tab item.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator.","type":"text"},{"text":" ","type":"text"},{"text":"This rule is only applied if selected tab indicator must be displayed.","type":"text"},{"text":" ","type":"text"},{"text":"When the user taps a tab, the ","type":"text"},{"type":"codeVoice","code":"selectedTab"},{"text":" binding is updated automatically, keeping the parent view in sync.","type":"text"}],"type":"paragraph"},{"text":"Technical considerations","level":2,"type":"heading","anchor":"Technical-considerations"},{"type":"paragraph","inlineContent":[{"text":"In order to improve the Developer eXperience the current ","type":"text"},{"type":"codeVoice","code":"OUDSTabBar"},{"text":" implementation lets users define their own tab items.","type":"text"},{"text":" ","type":"text"},{"text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a ","type":"text"},{"inlineContent":[{"text":"picker","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Thus users will need to add their own accessiiblity label if badges are used or also apply ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"template","type":"text"}]},{"text":" rendering mode on images if needed.","type":"text"},{"text":" ","type":"text"},{"text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking.","type":"text"}]},{"text":"Code samples","level":2,"type":"heading","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embedded.","    \/\/ Image with size of 26 x 26","    @State private var selectedTab = 0","","    OUDSTabBar(selectedTab: $selectedTab, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selectedTab binding value","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","             }","            .tag(1) \/\/ Must be used for the selectedTab binding","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selectedTab binding","    }"]},{"text":"Design documentation","level":2,"type":"heading","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"reference","isActive":true}]},{"text":"Themes rendering","level":2,"type":"heading","anchor":"Themes-rendering"},{"text":"Liquid Glass","type":"heading","level":3,"anchor":"Liquid-Glass"},{"text":"Orange","level":4,"type":"heading","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}]},{"text":"Orange Compact","type":"heading","level":4,"anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image"}]},{"text":"Sosh","type":"heading","level":4,"anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image"}]},{"text":"Wireframe","type":"heading","level":4,"anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"}]},{"text":"Without Liquid Glass","level":3,"type":"heading","anchor":"Without-Liquid-Glass"},{"text":"Orange","level":4,"type":"heading","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Orange_dark","type":"image"}]},{"text":"Orange Compact","level":4,"type":"heading","anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_OrangeCompact_dark","type":"image"}]},{"text":"Sosh","level":4,"type":"heading","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Sosh_dark","type":"image"}]},{"text":"Wireframe","level":4,"type":"heading","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Wireframe_dark","type":"image"}]},{"content":[{"inlineContent":[{"text":"1.0.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"name":"Version","type":"aside","style":"note"},{"content":[{"inlineContent":[{"text":"1.0.0","type":"text"}],"type":"paragraph"}],"name":"Since","type":"aside","style":"note"}]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(content:)":{"kind":"symbol","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS lower than 26, prefer instead "},{"type":"codeVoice","code":"OUDSTabBar(selectedTab:count:content:)"}],"url":"\/documentation\/oudscomponents\/oudstabbar\/init(content:)","title":"init(content:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"content","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"component_tabBar_LiquidGlass_Wireframe_light":{"alt":"A  tab bar component in light mode with Liquid Glass effect and Wireframe theme","identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_light.png","traits":["1x","light"]}]},"https://r.orange.fr/r/S-ouds-doc-ios-tab-bar":{"title":"unified-design-system.orange.com","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"link","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}]},"component_tabBar_Sosh_light":{"alt":"A  tab bar component in ligh