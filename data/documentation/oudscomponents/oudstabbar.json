{"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Content"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier","text":"View"}]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"],"kind":"mentions"},{"content":[{"text":"Appearances","anchor":"Appearances","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS 26 brings Liquid Glass, the new Apple look and feel which will prevent developers to define specific styles for some critical components like bars."},{"type":"text","text":" "},{"type":"text","text":"Because today the OUDS tab bar relies on native component and is not designed from scratch, some elements will look different between iOS 26 and older versions:"}]},{"items":[{"content":[{"inlineContent":[{"text":"background color of tab bar can be changed for iOS lower than 26","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"background color of tab bar does not change since iOS 26","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"normal \/ unselected tab item color can be changed for both image and text only for iOS lower than 26","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"with iOS 26 no token of color are applied on unselected \/ normal tab item because only the image will be changed"},{"type":"text","text":" "},{"type":"text","text":"and not the text making theme not readable in dark color scheme"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition the badges colors will be the same and cannot be changed (except with token definition). These particular badges do not rely on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge"},{"type":"text","text":" component,"},{"type":"text","text":" "},{"type":"text","text":"the native API is used instead."}]},{"inlineContent":[{"text":"Because Liquid Glass is available since iOS 26, the tab bar will be liquified \/ glassified since this OS version, not before.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you use SF Symbols for images, if they exist their ","type":"text"},{"inlineContent":[{"text":"fill","type":"text"}],"type":"emphasis"},{"text":" variant will be automatically used in the tab bar (native behaviour).","type":"text"}],"type":"paragraph"},{"text":"Platform considerations","level":2,"type":"heading","anchor":"Platform-considerations"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This component is tailored for iOS"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On iPadOS the tabs do not apply the fonts since iPadOS 18"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Because macOS does not support UIKit and because UIKIt is used to define the style of the tab bar, there is not styling of the tab bar for macOS","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"visionOS with is specific UI does not apply colors on tab bars and things are glasssified"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The component is not available for watchOS"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The component is not available for tvOS"}]}]}]},{"anchor":"Guidelines","type":"heading","level":2,"text":"Guidelines"},{"type":"paragraph","inlineContent":[{"text":"OUDS guidelines recommends to:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"limit when possible the number of items to 5"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"use both images and texts in tab bar items"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"use badges only when needed to avoid to have heavy tab bar"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"be sure the selected information is not only defined by the color of the tab; you may need to change the shape or the fill of the image","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"if a badge must be displayed, prefer short texts. If the text is a decimal value greater than 99, prefer display “+99”"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"if decorative images are used for tab bar item, apply "},{"type":"emphasis","inlineContent":[{"text":"template","type":"text"}]},{"type":"text","text":" rendering mode on it to apply color on tabs"}]}]}]},{"level":2,"text":"Technical constraints","type":"heading","anchor":"Technical-constraints"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You must use in your tab bar items images with "},{"inlineContent":[{"type":"text","text":"a size of 26 x 26"}],"type":"strong"},{"type":"text","text":", otherwise rendering could be unaligned with Figma specifications"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Because the component cannot compute the ideal width of the selected tab indicator (for iOS before 26 and iPadOS before 18), ideal width based on the tab bar item content,"},{"type":"text","text":" "},{"type":"text","text":"this indicator is not displayed for iOS lower than 26 in landscape mode and iPadOS."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" do not contain texts but only images, add an accessibility label introducing the journey for this tab"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"If your tabs embedded in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" display a badge (empty or with text), vocalize it in your tab to let users know what it is (unread messages, new things, etc)"},{"type":"text","text":" "},{"type":"text","text":"by using accessibiltiy value"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":["    OUDSTabBar {","        SomeView()","            .tabItem {","                Label {","                    Text(\"Emails\") \/\/ The text is vocalized first","                        .accessibilityValue(\"5 unread emails\") \/\/ A value vocalized after the text","            } icon: {","                Image(systemName: \"mail\").accessibilityHidden(true)","            }","        }","        .badge(5) \/\/ The value you give to the badge","    }",""],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Selection of tabs","type":"heading","anchor":"Selection-of-tabs"},{"inlineContent":[{"type":"text","text":"For iOS lower than 26, a selected tab indicator can be displayed in the "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" if the "},{"type":"codeVoice","code":"count"},{"text":" parameter is defined (to the number of tabs in the component)","type":"text"},{"text":" ","type":"text"},{"text":"and if the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding value is equal to a given tag associated to a tab item.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise the indicator won’t appear; these parameters are mandatory to compute the location of the indicator.","type":"text"},{"text":" ","type":"text"},{"text":"This rule is only applied if selected tab indicator must be displayed.","type":"text"},{"text":" ","type":"text"},{"text":"When the user taps a tab, the ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" binding is updated automatically, keeping the parent view in sync.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Technical considerations","anchor":"Technical-considerations","type":"heading"},{"inlineContent":[{"type":"text","text":"In order to improve the Developer eXperience the current "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" implementation lets users define their own tab items."},{"type":"text","text":" "},{"type":"text","text":"OUDS applies only appearances and styles on elements to prevent users to define raw data to assign to the component before being rendered like a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"picker"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Thus users will need to add their own accessiiblity label if badges are used or also apply "},{"type":"emphasis","inlineContent":[{"type":"text","text":"template"}]},{"type":"text","text":" rendering mode on images if needed."},{"type":"text","text":" "},{"type":"text","text":"Thus it will be also possible to use Liquid Glass new API with animations and items stacking."}],"type":"paragraph"},{"level":2,"text":"Code samples","anchor":"Code-samples","type":"heading"},{"code":["    \/\/ Use the OUDS tab bar to wrap tab bar items and associated views","    \/\/ Item tagged 0 will be selected first, 3 tabs are embedded.","    \/\/ Image with size of 26 x 26","    @State private var selectedTab = 0","","    OUDSTabBar(selectedTab: $selectedTab, count: 3) {","","        \/\/ Add the views with the SwiftUI tab item and labels","        \/\/ No need to define colors, everything is done inside OUDSTabBar","        SomeView()","            .tabItem {","                Label(\"Label 1\", image: \"image_1\")","            }","            .tag(0) \/\/ Must match the selectedTab binding value","        OtherView()","            .tabItem {","                Label {","                    Text(\"Label 2\")","                } icon: {","                    Image(decorative: \"image_2\")","                        .renderingMode(.template) \/\/ Mandatory to apply color on selected item","                }","             }","            .tag(1) \/\/ Must be used for the selectedTab binding","        LastView()","            .tabItem {","                Label(\"Label 3\", image: \"image_3\")","            }","            .tag(2) \/\/ Must be used for the selectedTab binding","    }"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Design documentation","anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar"}],"type":"paragraph"},{"level":2,"text":"Themes rendering","anchor":"Themes-rendering","type":"heading"},{"level":3,"text":"Liquid Glass","anchor":"Liquid-Glass","type":"heading"},{"level":4,"text":"Orange","anchor":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}],"type":"paragraph"},{"level":4,"text":"Orange Compact","anchor":"Orange-Compact","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark"}],"type":"paragraph"},{"level":4,"text":"Sosh","anchor":"Sosh","type":"heading"},{"inlineContent":[{"type":"image","identifier":"comp