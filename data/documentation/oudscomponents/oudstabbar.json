n light mode without Liquid Glass effect and Sosh theme"},"component_tabBar_LiquidGlass_Orange_light":{"identifier":"component_tabBar_LiquidGlass_Orange_light","alt":"A tab bar component in light mode with Liquid Glass effect and Orange theme","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_light.png"}]},"doc://OUDSComponents/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP"},"component_tabBar_LiquidGlass_Sosh_light":{"identifier":"component_tabBar_LiquidGlass_Sosh_light","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_light.png"}],"type":"image","alt":"A  tab bar component in light mode with Liquid Glass effect and Sosh theme"},"component_tabBar_Orange_dark":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Orange_dark.png"}],"type":"image","identifier":"component_tabBar_Orange_dark","alt":"A tab bar component in dark mode without Liquid Glass effect and Orange theme"},"doc://OUDSComponents/documentation/OUDSComponents/Navigations":{"title":"Navigations","role":"article","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"navigation","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"url":"\/documentation\/oudscomponents\/navigations","kind":"article","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations","type":"topic"},"component_tabBar_OrangeCompact_light":{"type":"image","identifier":"component_tabBar_OrangeCompact_light","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_light.png"}],"alt":"A  tab bar component in light mode without Liquid Glass effect and Orange Compact theme"},"component_tabBar_LiquidGlass_Orange_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_dark.png","traits":["1x","light"]}],"alt":"A tab bar component in dark mode with Liquid Glass effect and Orange theme","identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"},"doc://OUDSComponents/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s8SendableP","title":"Swift.Sendable"},"doc://OUDSComponents/7SwiftUI4ViewP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","title":"SwiftUICore.View"},"component_tabBar_LiquidGlass_Wireframe_light":{"type":"image","alt":"A  tab bar component in light mode with Liquid Glass effect and Wireframe theme","identifier":"component_tabBar_LiquidGlass_Wireframe_light","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_light.png","traits":["1x","light"]}]},"component_tabBar_LiquidGlass_Wireframe_dark":{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_dark.png"}],"alt":"A  tab bar component in dark mode with Liquid Glass effect and Wireframe theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/View-Implementations":{"title":"View Implementations","role":"collectionGroup","abstract":[],"url":"\/documentation\/oudscomponents\/oudstabbar\/view-implementations","kind":"article","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/body":{"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"title":"body","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body","url":"\/documentation\/oudscomponents\/oudstabbar\/body","abstract":[{"type":"text","text":"Uses a native SwiftUI "},{"type":"codeVoice","code":"TabView"},{"type":"text","text":" populated with the given content where "},{"type":"emphasis","inlineContent":[{"text":"tab item","type":"text"}]},{"type":"text","text":" elements are defined."},{"type":"text","text":" "},{"type":"text","text":"Rendering wil change depending to OS version, with a top divider and a selected tab indicator for legacy layouts."}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar":{"title":"OUDSTabBar","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","url":"\/documentation\/oudscomponents\/oudstabbar","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"abstract":[{"text":"The Tab bar is a system navigation component with a position which can vary depending to the OS.","type":"text"},{"text":" ","type":"text"},{"text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to switch between the sections of an app.","type":"text"},{"text":" ","type":"text"},{"text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations.","type":"text"}],"type":"topic","role":"symbol","navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}]},"https://r.orange.fr/r/S-ouds-doc-ios-tab-bar":{"titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","title":"unified-design-system.orange.com","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"link"},"component_tabBar_Wireframe_dark":{"type":"image","alt":"A  tab bar component in dark mode without Liquid Glass effect and Wireframe theme","identifier":"component_tabBar_Wireframe_dark","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_dark.png","traits":["1x","light"]}]},"component_tabBar_LiquidGlass_OrangeCompact_light":{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_light.png"}],"alt":"A  tab bar component in light mode with Liquid Glass effect and Orange Compact theme"}}}