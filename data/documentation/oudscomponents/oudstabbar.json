omponent_tabBar_Wireframe_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_Wireframe_light","alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme"},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","identifier":"ic_folder_categories.png","alt":null},"component_tabBar_LiquidGlass_Sosh_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_dark.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark","alt":"A  tab bar component in dark mode with Liquid Glass effect and Sosh theme"},"doc://OUDSComponents/documentation/OUDSComponents/Navigations":{"url":"\/documentation\/oudscomponents\/navigations","role":"article","type":"topic","title":"Navigations","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"text":"navigation","type":"text"}]},{"text":".","type":"text"}],"kind":"article","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/View-Implementations":{"title":"View Implementations","url":"\/documentation\/oudscomponents\/oudstabbar\/view-implementations","type":"topic","abstract":[],"kind":"article","role":"collectionGroup","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"},"https://r.orange.fr/r/S-ouds-doc-ios-tab-bar":{"title":"unified-design-system.orange.com","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar","type":"link","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tab-bar"},"component_tabBar_LiquidGlass_OrangeCompact_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_dark.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","alt":"A  tab bar component in dark mode with Liquid Glass effect and Orange Compact theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar":{"navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudstabbar","role":"symbol","type":"topic","title":"OUDSTabBar","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"abstract":[{"text":"The Tab bar is a system navigation component with a position which can vary depending to the OS.","type":"text"},{"text":" ","type":"text"},{"text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to switch between the sections of an app.","type":"text"},{"text":" ","type":"text"},{"text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","kind":"symbol"},"component_tabBar_LiquidGlass_Orange_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_light","alt":"A tab bar component in light mode with Liquid Glass effect and Orange theme"},"doc://OUDSComponents/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP"},"component_tabBar_LiquidGlass_Wireframe_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_light","alt":"A  tab bar component in light mode with Liquid Glass effect and Wireframe theme"},"component_tabBar_LiquidGlass_Wireframe_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_dark.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark","alt":"A  tab bar component in dark mode with Liquid Glass effect and Wireframe theme"},"component_tabBar_LiquidGlass_OrangeCompact_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","alt":"A  tab bar component in light mode with Liquid Glass effect and Orange Compact theme"},"doc://OUDSComponents/7SwiftUI4ViewP":{"title":"SwiftUICore.View","type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(selectedTab:count:content:)":{"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"selectedTab","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Binding","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI7BindingV"},{"text":"<","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":">, ","kind":"text"},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":", ","kind":"text"},{"text":"content","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":")","kind":"text"}],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(selectedTab:count:content:)","title":"init(selectedTab:count:content:)","abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items and a two-way binding to the selected tab index."},{"type":"text","text":" "},{"type":"text","text":"Number of tabs and selected tab are needed to compute the selected tab indicator for iOS lower than 26."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS 26+ or other platform, prefer instead "},{"type":"codeVoice","code":"OUDSTabBar(content:)"},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/oudstabbar\/init(selectedtab:count:content:)","kind":"symbol","role":"symbol"},"component_tabBar_Wireframe_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_dark.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_Wireframe_dark","alt":"A  tab bar component in dark mode without Liquid Glass effect and Wireframe theme"},"component_tabBar_Orange_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Orange_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_Orange_light","alt":"A tab bar component in light mode without Liquid Glass effect and Orange theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/body":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/body","title":"body","abstract":[{"type":"text","text":"Uses a native SwiftUI "},{"type":"codeVoice","code":"TabView"},{"type":"text","text":" populated with the given content where "},{"inlineContent":[{"text":"tab item","type":"text"}],"type":"emphasis"},{"type":"text","text":" elements are defined."},{"type":"text","text":" "},{"type":"text","text":"Rendering wil change depending to OS version, with a top divider and a selected tab indicator for legacy layouts."}],"url":"\/documentation\/oudscomponents\/oudstabbar\/body","kind":"symbol","role":"symbol"},"component_tabBar_Sosh_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Sosh_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_Sosh_light","alt":"A  tab bar component in light mode without Liquid Glass effect and Sosh theme"},"component_tabBar_LiquidGlass_Orange_dark":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_dark.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_dark","alt":"A tab bar component in dark mode with Liquid Glass effect and Orange theme"},"component_tabBar_OrangeCompact_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_light.png","traits":["1x","light"]}],"type":"image","identifier":"component_tabBar_OrangeCompact_light","alt":"A  tab bar component in light mode without Liquid Glass effect and Orange Compact theme"},"doc://OUDSComponents/s8SendableP":{"title":"Swift.Sendable","type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s8SendableP"}}}