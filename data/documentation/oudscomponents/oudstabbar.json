n\/oudscomponents\/oudstabbar\/body","role":"symbol","type":"topic"},"doc://OUDSComponents/7SwiftUI4ViewP":{"title":"SwiftUICore.View","type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBadge":{"kind":"symbol","type":"topic","abstract":[{"text":"Badge is a UI element that emphasizes system notifications, status, or the categorization of an information, throughout colour only.","type":"text"},{"text":" ","type":"text"},{"text":"Badge is rendered as a coloured shape, without icon, text or number; and its chosen size remains unchanged regardless of the changes of the interface size.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudsbadge","title":"OUDSBadge","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBadge","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSBadge","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBadge","role":"symbol"},"component_tabBar_LiquidGlass_Orange_dark":{"alt":"A tab bar component in dark mode with Liquid Glass effect and Orange theme","type":"image","identifier":"component_tabBar_LiquidGlass_Orange_dark","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Orange_dark.png"}]},"component_tabBar_Orange_light":{"identifier":"component_tabBar_Orange_light","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Orange_light.png","traits":["1x","light"]}],"alt":"A tab bar component in light mode without Liquid Glass effect and Orange theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/View-Implementations":{"title":"View Implementations","kind":"article","role":"collectionGroup","url":"\/documentation\/oudscomponents\/oudstabbar\/view-implementations","abstract":[],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/View-Implementations"},