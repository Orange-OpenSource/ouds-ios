":"s:Si"},{"text":">, ","kind":"text"},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":", ","kind":"text"},{"text":"content","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"\/documentation\/oudscomponents\/oudstabbar\/init(selectedtab:count:content:)","role":"symbol","type":"topic"},"component_tabBar_LiquidGlass_Wireframe_dark":{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_dark.png"}],"alt":"A  tab bar component in dark mode with Liquid Glass effect and Wireframe theme"},"component_tabBar_Wireframe_dark":{"type":"image","alt":"A  tab bar component in dark mode without Liquid Glass effect and Wireframe theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_dark.png"}],"identifier":"component_tabBar_Wireframe_dark"},"component_tabBar_Wireframe_light":{"type":"image","identifier":"component_tabBar_Wireframe_light","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Wireframe_light.png","traits":["1x","light"]}],"alt":"A  tab bar component in light mode without Liquid Glass effect and Wireframe theme"},"component_tabBar_LiquidGlass_OrangeCompact_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_OrangeCompact_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","alt":"A  tab bar component in light mode with Liquid Glass effect and Orange Compact theme","type":"image"},"component_tabBar_Orange_dark":{"type":"image","identifier":"component_tabBar_Orange_dark","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Orange_dark.png","traits":["1x","light"]}],"alt":"A tab bar component in dark mode without Liquid Glass effect and Orange theme"},"component_tabBar_Sosh_light":{"type":"image","identifier":"component_tabBar_Sosh_light","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_Sosh_light.png","traits":["1x","light"]}],"alt":"A  tab bar component in light mode without Liquid Glass effect and Sosh theme"},"component_tabBar_OrangeCompact_dark":{"type":"image","alt":"A  tab bar component in dark mode without Liquid Glass effect and Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_dark.png","traits":["1x","light"]}],"identifier":"component_tabBar_OrangeCompact_dark"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar/init(content:)":{"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"content","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":")","kind":"text"}],"abstract":[{"type":"text","text":"Defines the tab bar component with given tab bar items."},{"type":"text","text":" "},{"type":"text","text":"If you target iOS lower than 26, prefer instead "},{"type":"codeVoice","code":"OUDSTabBar(selectedTab:count:content:)"}],"kind":"symbol","title":"init(content:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar\/init(content:)","url":"\/documentation\/oudscomponents\/oudstabbar\/init(content:)","type":"topic","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/Navigations":{"url":"\/documentation\/oudscomponents\/navigations","role":"article","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations","type":"topic","kind":"article","title":"Navigations","abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"navigation"}]},{"type":"text","text":"."}]},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png","alt":null,"type":"image"},"component_tabBar_Sosh_dark":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_Sosh_dark.png"}],"identifier":"component_tabBar_Sosh_dark","alt":"A  tab bar component in dark mode without Liquid Glass effect and Sosh theme","type":"image"},"component_tabBar_LiquidGlass_Wireframe_light":{"variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Wireframe_light.png","traits":["1x","light"]}],"identifier":"component_tabBar_LiquidGlass_Wireframe_light","alt":"A  tab bar component in light mode with Liquid Glass effect and Wireframe theme","type":"image"},"doc://OUDSComponents/s16SendableMetatypeP":{"title":"Swift.SendableMetatype","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","type":"unresolvable"},"component_tabBar_LiquidGlass_Sosh_dark":{"alt":"A  tab bar component in dark mode with Liquid Glass effect and Sosh theme","type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_LiquidGlass_Sosh_dark.png"}]},"component_tabBar_OrangeCompact_light":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_light.png"}],"identifier":"component_tabBar_OrangeCompact_light","alt":"A  tab bar component in light mode without Liquid Glass effect and Orange Compact theme","type":"image"}}}