s and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioPicker/labelModerateSmall(_:)":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker\/labelModerateSmall(_:)","type":"topic","url":"\/documentation\/oudscomponents\/oudsradiopicker\/labelmoderatesmall(_:)","kind":"symbol","abstract":[{"text":"Modifies the current ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" to apply a ","type":"text"},{"inlineContent":[{"text":"label moderate small","type":"text"}],"type":"emphasis"},{"text":" typography.","type":"text"},{"text":" ","type":"text"},{"text":"The current ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" must be given in parameter because ","type":"text"},{"code":"@Environment","type":"codeVoice"},{"text":" property cannot be accessed through an extension or inside a method.","type":"text"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"labelModerateSmall"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"OUDSTheme","preciseIdentifier":"s:18OUDSThemesContract9OUDSThemeC"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}],"title":"labelModerateSmall(_:)","role":"symbol"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"code":"class","type":"codeVoice"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"url":"\/documentation\/oudsthemescontract\/oudstheme","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","kind":"symbol","title":"OUDSTheme","type":"topic","role":"symbol"}}}