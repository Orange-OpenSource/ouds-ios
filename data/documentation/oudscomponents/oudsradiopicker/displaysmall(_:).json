 be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"text":", or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"role":"symbol","title":"OUDSTheme"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"type":"image","alt":null},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem":{"navigatorTitle":[{"kind":"identifier","text":"OUDSRadioItem"}],"url":"\/documentation\/oudscomponents\/oudsradioitem","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioItem"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"text":" proposes layouts to add in your views some radios components.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a radio with only an indicator, prefer instead ","type