omponents/OUDSRadioPicker":{"kind":"symbol","title":"OUDSRadioPicker","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioPicker"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSRadioPicker"}],"abstract":[{"text":"A picker allowing to expose several radio buttons and choose only one within the others.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Each radio button contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen value through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"url":"\/documentation\/oudscomponents\/oudsradiopicker"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem":{"abstract":[{"type":"text","text":"Radio button item is a UI element that allows to select a single option from a set of mutually exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Radio button item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsradioitem","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","kind":"symbol","navigatorTitle":[{"text":"OUDSRadioItem","kind":"identifier"}],"type":"topic","title":"OUDSRadioItem","role":"symbol"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OU