","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"kind":"symbol","role":"symbol","title":"OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioPicker":{"navigatorTitle":[{"kind":"identifier","text":"OUDSRadioPicker"}],"title":"OUDSRadioPicker","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioPicker"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","url":"\/documentation\/oudscomponents\/oudsradiopicker","role":"symbol","abstract":[{"text":"A picker allowing to expose several radio buttons and choose only one within the others.","type":"text"},{"text":" ","type":"text"},{"text":"Each radio button contains a “tag”, i.e. a supposed to be unique value.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen value through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}]}}}