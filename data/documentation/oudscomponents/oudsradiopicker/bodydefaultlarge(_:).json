veral radio buttons and choose only one within the others."},{"type":"text","text":" "},{"text":"Each radio button contains a “tag”, i.e. a supposed to be unique value.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The picker will expose the choosen value through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"url":"\/documentation\/oudscomponents\/oudsradiopicker","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSRadioItem"}],"type":"topic","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"text":" proposes layouts to add in your views some radios components.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If you want to use a radio with only an indicator, prefer instead "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","isActive":true},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/oudsradioitem","navigatorTitle":[{"kind":"identifier","text":"OUDSRadioItem"}],"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","kind":"symbol","title":"OUDSRadioItem"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioPicker/bodyDefaultLarge(_:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"bodyDefaultLarge"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract