{"kind":"symbol","sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"type":"text","text":"Alert message is a UI element that displays system feedback, status changes or required action; throughout detailed, prominent, persistent and actionable"},{"type":"text","text":" "},{"type":"text","text":"communication. Alert message includes functional icon and semantic colour, and may include as well a close button and\/or action link."},{"type":"text","text":" "},{"type":"text","text":"Alert Message does not disappear automatically and remains visible until dismissed or resolved by the user."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertMessage","kind":"identifier"}]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Dialogs"]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["        \/\/ A basic positive alert message with text and description","        OUDSAlertMessage(label: \"Label\", description: \"You should read this text\")","        \/\/ From a localizable in a bundle","        OUDSAlertMessage(LocalizedStringKey(\"label_wording\"), bundle: Bundle.module)","","        \/\/ With a rich text for the description (e.g. markdown here, do not forget to manage the errors)","        let richDescription = AttributedString(markdown: \"You **must read this text**\")","        OUDSAlertMessage(label: \"Label\", description: richDescription)","","        \/\/ A more complex alert message for warning status with a description and a close action","        \/\/ to dismiss the message.","        OUDSAlertMessage(label: \"Warning\", status: .warning, description: \"Some details about the warning\") {","              \/\/ Do some stuff here to dismiss the alert message when clicked","        }","","        \/\/ Add a custom icon for accent and neutral status","        OUDSAlertMessage(label: \"Label\", status: .accent(icon: OUDSIcon(asset: Image(\"ic_heart\"))))","        OUDSAlertMessage(label: \"Label\", status: .neutral(icon: OUDSIcon(asset: Image(\"ic_heart\"))))","","        \/\/ Add a custom action (i.e Link) at bottom (could also at top trailing position)","        @Environment(\\.openURL) private var openUrl","        let link = OUDSAlertMessage.Link(text: \"Action\", position: .bottom) {","           openUrl.callAsFunction(url)","        }","        OUDSAlertMessage(label: \"Label\", link: link)"]},{"level":2,"type":"heading","anchor":"Rich-text","text":"Rich text"},{"type":"paragraph","inlineContent":[{"text":"Only the alert message description and bullet list can use rich text.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Strong text can be used sparingly within alert messages to highlight key information.","type":"text"},{"text":" ","type":"text"},{"text":"Underlined text must not be used for emphasis, as it is commonly associated with links.","type":"text"},{"text":" ","type":"text"},{"text":"If a hyperlink is needed within the content, the underlined style should be used.","type":"text"},{"text":" ","type":"text"},{"text":"Italic should be used with care, some brands do not allow it like Orange brand.","type":"text"},{"text":" ","type":"text"},{"text":"No other text styles should be used.","type":"text"}]},{"level":2,"type":"heading","anchor":"Accessibility-considerations","text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"text":"Always check the results of rich text mode with high contrast, light and dark modes, and Voice Over vocalization.","type":"text"}]},{"level":2,"type":"heading","anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-alert-message","isActive":true,"type":"reference"}]},{"level":2,"type":"heading","anchor":"Themes-rendering","text":"Themes rendering"},{"level":3,"type":"heading","anchor":"Orange","text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_alertMessage_Orange","type":"image"}]},{"level":3,"type":"heading","anchor":"Orange-Compact","text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_alertMessage_OrangeCompact","type":"image"}]},{"level":3,"type":"heading","anchor":"Sosh","text":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_alertMessage_Sosh","type":"image"}]},{"level":3,"type":"heading","anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_alertMessage_Wireframe","type":"image"}]},{"type":"aside","style":"note","name":"Version","content":[{"inlineContent":[{"type":"text","text":"1.1.0 (Figma component design version)"}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"1.3.0"}],"type":"paragraph"}]}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsalertmessage"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage\/Link"],"generated":true,"title":"Structures","anchor":"Structures"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage\/init(_:tableName:bundle:status:description:bulletList:link:onClose:)-1p0x5","doc:\/\/OUDSCom