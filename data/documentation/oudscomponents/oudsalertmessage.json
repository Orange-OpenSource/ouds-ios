ert message is a UI element that displays system feedback, status changes or required action; throughout detailed, prominent, persistent and actionable","type":"text"},{"type":"text","text":" "},{"text":"communication. Alert message includes functional icon and semantic colour, and may include as well a close button and\/or action link.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Alert Message does not disappear automatically and remains visible until dismissed or resolved by the user."}],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsalertmessage"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents16OUDSAlertMessageV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertMessage","kind":"identifier"}],"platforms":[{"name":"iOS","deprecated":false,"beta":false,"introducedAt":"15.0","unavailable":false},{"introducedAt":"13.0","name":"macOS","beta":false,"deprecated":false,"unavailable":false},{"name":"tvOS","introducedAt":"16.0","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"1.0","name":"visionOS","beta":false,"deprecated":false,"unavailable":false}],"title":"OUDSAlertMessage","symbolKind":"struct","navigatorTitle":[{"text":"OUDSAlertMessage","kind":"identifier"}],"roleHeading":"Structure","role":"symbol"},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"a