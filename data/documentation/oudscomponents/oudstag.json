{"kind":"symbol","metadata":{"role":"symbol","platforms":[{"unavailable":false,"beta":false,"introducedAt":"15.0","deprecated":false,"name":"iOS"},{"unavailable":false,"beta":false,"introducedAt":"13.0","deprecated":false,"name":"macOS"},{"unavailable":false,"beta":false,"introducedAt":"16.0","deprecated":false,"name":"tvOS"},{"name":"visionOS","unavailable":false,"beta":false,"deprecated":false,"introducedAt":"1.0"},{"unavailable":false,"beta":false,"introducedAt":"11.0","deprecated":false,"name":"watchOS"}],"externalID":"s:14OUDSComponents7OUDSTagV","title":"OUDSTag","navigatorTitle":[{"text":"OUDSTag","kind":"identifier"}],"symbolKind":"struct","roleHeading":"Structure","modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTag","kind":"identifier"}]},"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTag"}]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"],"kind":"mentions"},{"content":[{"level":2,"text":"Appearances","type":"heading","anchor":"Appearances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags have two appearances so as to highlight or not their content:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"emphasized","type":"text"}]},{"type":"text","text":": A tag with a solid, high-contrast background. Used to draw strong attention to important"},{"type":"text","text":" "},{"type":"text","text":"labels or categories. Emphasized tags stand out prominently against the interface and are ideal for"},{"type":"text","text":" "},{"type":"text","text":"primary or high-priority information."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"muted"}]},{"text":": A tag with a subtle, light, or semi-transparent background. Used for secondary or","type":"text"},{"text":" ","type":"text"},{"text":"less prominent information. Muted tags blend more with the background, providing a softer visual","type":"text"},{"text":" ","type":"text"},{"text":"emphasis compared to emphasized tags.","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Status","text":"Status"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags have seven status depending on the context of the information they represent. Each state is designed"},{"type":"text","text":" "},{"type":"text","text":"to convey a specific meaning and ensure clarity in communication."}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Neutral","type":"text"}]},{"type":"text","text":": Default or inactive state. Used for standard labels, categories, or when no specific"},{"type":"text","text":" "},{"type":"text","text":"status needs to be communicated."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Accent","type":"text"}]},{"type":"text","text":": Used to draw attention to new features, recommendations, or content suggestions."},{"text":" ","type":"text"},{"text":"Invites users to explore and engage with new offerings, creating an exciting and engaging experience.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Positive"}]},{"text":": Indicates success, confirmation, or a positive status. Commonly used to highlight","type":"text"},{"text":" ","type":"text"},{"text":"completed actions or approved items.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Warning"}]},{"type":"text","text":": Signals caution or a potentially risky situation. Used to draw attention to items"},{"type":"text","text":" "},{"text":"requiring user awareness or intervention.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Negative","type":"text"}]},{"type":"text","text":": Represents errors, critical issues, or urgent attention needed. Used to highlight"},{"text":" ","type":"text"},{"text":"problems or failed actions.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Info"}]},{"type":"text","text":": Conveys informational messages or supplementary details. Used for neutral, helpful,"},{"text":" ","type":"text"},{"type":"text","text":"or contextual information."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Disabled","type":"text"}]},{"type":"text","text":": Shows that the tag is inactive and cannot be interacted with. Appears faded or greyed out. This is not"},{"type":"text","text":" "},{"type":"text","text":"allowed when loader is activated."}]}]}],"type":"unorderedList"},{"level":2,"text":"Shape","type":"heading","anchor":"Shape"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags can have two shapes:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rounded"}]},{"type":"text","text":": A tag with fully rounded corners, creating a pill-shaped appearance. Rounded"},{"text":" ","type":"text"},{"type":"text","text":"tags offer a softer and more approachable look, suitable for most modern interfaces."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Square"}]},{"type":"text","text":": A tag with sharp, square corners. Squared tags provide a more formal, structured, or"},{"type":"text","text":" "},{"type":"text","text":"technical feel. They are often used in business contexts to label promotions, offers, or important notices."}]}]}],"type":"unorderedList"},{"level":2,"text":"Size","type":"heading","anchor":"Size"},{"type":"paragraph","inlineContent":[{"text":"Tags can have two sizes:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Default"}]},{"text":": The standard tag size, suitable for most use cases and offering good readability.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Small"}]},{"text":": A compact tag with reduced height and font size. Used when saving space is important or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when grouping elements visually."}]}]}],"type":"unorderedList"},{"text":"Layout","type":"heading","level":2,"anchor":"Layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are four available layouts for tags:"}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"type":"strong","inlineContent":[{"text":"Text only","type":"text"}]},{"text":": A tag that displays only text. Used for simple labels, categories, or keywords without additional visual","type":"text"},{"text":" ","type":"text"},{"text":"elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"type":"strong","inlineContent":[{"text":"Text + Bullet","type":"text"}]},{"text":": A tag with a small indicator (dot) alongside the text. Used to show status, presence, or activity","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"next to the label."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"text":"Text + Icon","type":"text"}]},{"type":"text","text":": A tag that includes an icon before the text. Used to visually reinforce the meaning of the tag,"},{"text":" ","type":"text"},{"text":"such as status, type, or action.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Text + Loader"}]},{"text":": A tag that combines a loading spinner (or progress indicator) with text. Used to indicate that","type":"text"},{"text":" ","type":"text"},{"text":"a process or action related to the tag is in progress.","type":"text"}]}]}]},{"text":"Code samples","type":"heading","level":2,"anchor":"Code-samples"},{"syntax":"swift","code":["    \/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","    OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","    \/\/ Or also","    OUDSTag(label: \"Label\")","    \/\/ Or from a localizale and a bundle","    OUDSTag(LocalizedStringKey(\"label_wording\"), bundle: Bundle.module)","","    \/\/ Tag with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(leading: .bullet)","","    \/\/ Tag with neutral status with a custom decorative icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","    \/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","    \/\/ you can flip the icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","","    \/\/ Text with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(bullet: true))","","    \/\/ Tag with loader with rounded shape in small size","    OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"type":"codeListing"},{"text":"Design documentation","type":"heading","level":2,"anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-tag","type":"reference","isActive":true}]},{"type":"heading","level":2,"anchor":"Themes-rendering","text":"Themes rendering"},{"text":"Orange","type":"heading","level":3,"anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Orange","type":"image"}]},{"text":"Orange Compact","type":"heading","level":3,"anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_OrangeCompact"}]},{"text":"Sosh","type":"heading","level":3,"anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Sosh"}]},{"type":"heading","level":3,"anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Wireframe","type":"image"}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}]}],"style":"note","name":"Version"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.18.0","type":"text"}]}],"style":"note","name":"Since"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstag"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"abstract":[{"type":"text","text":"Tag is a UI element that allows to display short info like a label, keyword, or category."},{"type":"text","text":" "},{"type":"text","text":"Tag helps users quickly find, group, or understand content."}],"topicSections":[{"title":"Structures","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Status"],"anchor":"Structures"},{"anc