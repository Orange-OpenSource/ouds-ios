{"abstract":[{"type":"text","text":"Tag is a UI element that allows to display short info like a label, keyword, or category."},{"type":"text","text":" "},{"type":"text","text":"Tag helps users quickly find, group, or understand content."}],"topicSections":[{"anchor":"Structures","title":"Structures","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Status"]},{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(_:tableName:bundle:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(label:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingKey:tableName:bundle:shape:size:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingLabel:shape:size:)"]},{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body"]},{"anchor":"Enumerations","title":"Enumerations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Shape","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Size"]},{"anchor":"Default-Implementations","title":"Default Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/oudscomponents\/oudstag"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag"},"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTag"}],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"]},{"kind":"content","content":[{"anchor":"Appearances","type":"heading","text":"Appearances","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags have two appearances so as to highlight or not their content:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"emphasized","type":"text"}]},{"text":": A tag with a solid, high-contrast background. Used to draw strong attention to important","type":"text"},{"text":" ","type":"text"},{"text":"labels or categories. Emphasized tags stand out prominently against the interface and are ideal for","type":"text"},{"text":" ","type":"text"},{"text":"primary or high-priority information.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"muted","type":"text"}]},{"text":": A tag with a subtle, light, or semi-transparent background. Used for secondary or","type":"text"},{"text":" ","type":"text"},{"text":"less prominent information. Muted tags blend more with the background, providing a softer visual","type":"text"},{"text":" ","type":"text"},{"text":"emphasis compared to emphasized tags.","type":"text"}]}]}]},{"anchor":"Status","type":"heading","text":"Status","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags have seven status depending on the context of the information they represent. Each state is designed","type":"text"},{"text":" ","type":"text"},{"text":"to convey a specific meaning and ensure clarity in communication.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Neutral","type":"text"}]},{"text":": Default or inactive state. Used for standard labels, categories, or when no specific","type":"text"},{"text":" ","type":"text"},{"text":"status needs to be communicated.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Accent","type":"text"}]},{"text":": Used to draw attention to new features, recommendations, or content suggestions.","type":"text"},{"text":" ","type":"text"},{"text":"Invites users to explore and engage with new offerings, creating an exciting and engaging experience.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Positive","type":"text"}]},{"text":": Indicates success, confirmation, or a positive status. Commonly used to highlight","type":"text"},{"text":" ","type":"text"},{"text":"completed actions or approved items.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Warning","type":"text"}]},{"text":": Signals caution or a potentially risky situation. Used to draw attention to items","type":"text"},{"text":" ","type":"text"},{"text":"requiring user awareness or intervention.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Negative","type":"text"}]},{"text":": Represents errors, critical issues, or urgent attention needed. Used to highlight","type":"text"},{"text":" ","type":"text"},{"text":"problems or failed actions.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Info","type":"text"}]},{"text":": Conveys informational messages or supplementary details. Used for neutral, helpful,","type":"text"},{"text":" ","type":"text"},{"text":"or contextual information.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Disabled","type":"text"}]},{"text":": Shows that the tag is inactive and cannot be interacted with. Appears faded or greyed out. This is not","type":"text"},{"text":" ","type":"text"},{"text":"allowed when loader is activated.","type":"text"}]}]}]},{"anchor":"Shape","type":"heading","text":"Shape","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags can have two shapes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Rounded","type":"text"}]},{"text":": A tag with fully rounded corners, creating a pill-shaped appearance. Rounded","type":"text"},{"text":" ","type":"text"},{"text":"tags offer a softer and more approachable look, suitable for most modern interfaces.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Square","type":"text"}]},{"text":": A tag with sharp, square corners. Squared tags provide a more formal, structured, or","type":"text"},{"text":" ","type":"text"},{"text":"technical feel. They are often used in business contexts to label promotions, offers, or important notices.","type":"text"}]}]}]},{"anchor":"Size","type":"heading","text":"Size","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags can have two sizes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Default","type":"text"}]},{"text":": The standard tag size, suitable for most use cases and offering good readability.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Small","type":"text"}]},{"text":": A compact tag with reduced height and font size. Used when saving space is important or","type":"text"},{"text":" ","type":"text"},{"text":"when grouping elements visually.","type":"text"}]}]}]},{"anchor":"Layout","type":"heading","text":"Layout","level":2},{"type":"paragraph","inlineContent":[{"text":"There are four available layouts for tags:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"inlineContent":[{"type":"text","text":"Text only"}],"type":"strong"},{"text":": A tag that displays only text. Used for simple labels, categories, or keywords without additional visual","type":"text"},{"text":" ","type":"text"},{"text":"elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"inlineContent":[{"type":"text","text":"Text + Bullet"}],"type":"strong"},{"text":": A tag with a small indicator (dot) alongside the text. Used to show status, presence, or activity","type":"text"},{"text":" ","type":"text"},{"text":"next to the label.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"inlineContent":[{"type":"text","text":"Text + Icon"}],"type":"strong"},{"text":": A tag that includes an icon before the text. Used to visually reinforce the meaning of the tag,","type":"text"},{"text":" ","type":"text"},{"text":"such as status, type, or action.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Text + Loader","type":"text"}]},{"text":": A tag that combines a loading spinner (or progress indicator) with text. Used to indicate that","type":"text"},{"text":" ","type":"text"},{"text":"a process or action related to the tag is in progress.","type":"text"}]}]}]},{"anchor":"Code-samples","type":"heading","text":"Code samples","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","    OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","    \/\/ Or also","    OUDSTag(label: \"Label\")","    \/\/ Or from a localizale and a bundle","    OUDSTag(LocalizedStringKey(\"label_wording\"), bundle: Bundle.module)","","    \/\/ Tag with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(leading: .bullet)","","    \/\/ Tag with neutral status with a custom decorative icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","    \/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","    \/\/ you can flip the icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","","    \/\/ Text with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(bullet: true))","","    \/\/ Tag with loader with rounded shape in small size","    OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-tag","isActive":true,"type":"reference"}]},{"anchor":"Themes-rendering","type":"heading","text":"Themes rendering","level":2},{"anchor":"Orange","type":"heading","text":"Orange","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Orange","type":"image"}]},{"anchor":"Orange-Compact","type":"heading","text":"Orange Compact","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_OrangeCompact","type":"image"}]},{"anchor":"Sosh","type":"heading","text":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Sosh","type":"ima