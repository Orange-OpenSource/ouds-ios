{"sections":[],"topicSections":[{"generated":true,"title":"Structures","anchor":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Status"]},{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(label:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingLabel:shape:size:)"]},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body"]},{"generated":true,"title":"Enumerations","anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Shape","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Size"]},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations"]}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTag","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"]},{"kind":"content","content":[{"text":"Appearances","level":2,"anchor":"Appearances","type":"heading"},{"inlineContent":[{"type":"text","text":"Tags have two appearances so as to highlight or not their content:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"emphasized"}]},{"type":"text","text":": A tag with a solid, high-contrast background. Used to draw strong attention to important"},{"type":"text","text":" "},{"type":"text","text":"labels or categories. Emphasized tags stand out prominently against the interface and are ideal for"},{"type":"text","text":" "},{"type":"text","text":"primary or high-priority information."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"muted"}]},{"type":"text","text":": A tag with a subtle, light, or semi-transparent background. Used for secondary or"},{"type":"text","text":" "},{"type":"text","text":"less prominent information. Muted tags blend more with the background, providing a softer visual"},{"type":"text","text":" "},{"type":"text","text":"emphasis compared to emphasized tags."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Status","level":2,"anchor":"Status","type":"heading"},{"inlineContent":[{"type":"text","text":"Tags have seven status depending on the context of the information they represent. Each state is designed"},{"type":"text","text":" "},{"type":"text","text":"to convey a specific meaning and ensure clarity in communication."}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Neutral"}]},{"type":"text","text":": Default or inactive state. Used for standard labels, categories, or when no specific"},{"type":"text","text":" "},{"type":"text","text":"status needs to be communicated."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Accent"}]},{"type":"text","text":": Used to draw attention to new features, recommendations, or content suggestions."},{"type":"text","text":" "},{"type":"text","text":"Invites users to explore and engage with new offerings, creating an exciting and engaging experience."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Positive"}]},{"type":"text","text":": Indicates success, confirmation, or a positive status. Commonly used to highlight"},{"type":"text","text":" "},{"type":"text","text":"completed actions or approved items."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Warning"}]},{"type":"text","text":": Signals caution or a potentially risky situation. Used to draw attention to items"},{"type":"text","text":" "},{"type":"text","text":"requiring user awareness or intervention."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Negative"}]},{"type":"text","text":": Represents errors, critical issues, or urgent attention needed. Used to highlight"},{"type":"text","text":" "},{"type":"text","text":"problems or failed actions."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Info"}]},{"type":"text","text":": Conveys informational messages or supplementary details. Used for neutral, helpful,"},{"type":"text","text":" "},{"type":"text","text":"or contextual information."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Disabled"}]},{"type":"text","text":": Shows that the tag is inactive and cannot be interacted with. Appears faded or greyed out. This is not"},{"type":"text","text":" "},{"type":"text","text":"allowed when loader is activated."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Shape","level":2,"anchor":"Shape","type":"heading"},{"inlineContent":[{"type":"text","text":"Tags can have two shapes:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rounded"}]},{"type":"text","text":": A tag with fully rounded corners, creating a pill-shaped appearance. Rounded"},{"type":"text","text":" "},{"type":"text","text":"tags offer a softer and more approachable look, suitable for most modern interfaces."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Square"}]},{"type":"text","text":": A tag with sharp, square corners. Squared tags provide a more formal, structured, or"},{"type":"text","text":" "},{"type":"text","text":"technical feel. They are often used in business contexts to label promotions, offers, or important notices."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Size","level":2,"anchor":"Size","type":"heading"},{"inlineContent":[{"type":"text","text":"Tags can have two sizes:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Default"}]},{"type":"text","text":": The standard tag size, suitable for most use cases and offering good readability."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Small"}]},{"type":"text","text":": A compact tag with reduced height and font size. Used when saving space is important or"},{"type":"text","text":" "},{"type":"text","text":"when grouping elements visually."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Layout","level":2,"anchor":"Layout","type":"heading"},{"inlineContent":[{"type":"text","text":"There are four available layouts for tags:"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"text":"Text only","type":"text"}]},{"type":"text","text":": A tag that displays only text. Used for simple labels, categories, or keywords without additional visual"},{"type":"text","text":" "},{"type":"text","text":"elements."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"text":"Text + Bullet","type":"text"}]},{"type":"text","text":": A tag with a small indicator (dot) alongside the text. Used to show status, presence, or activity"},{"type":"text","text":" "},{"type":"text","text":"next to the label."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"text":"Text + Icon","type":"text"}]},{"type":"text","text":": A tag that includes an icon before the text. Used to visually reinforce the meaning of the tag,"},{"type":"text","text":" "},{"type":"text","text":"such as status, type, or action."}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Text + Loader"}]},{"type":"text","text":": A tag that combines a loading spinner (or progress indicator) with text. Used to indicate that"},{"type":"text","text":" "},{"type":"text","text":"a process or action related to the tag is in progress."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Code samples","level":2,"anchor":"Code-samples","type":"heading"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","    OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","    \/\/ Or also","    OUDSTag(label: \"Label\")","","    \/\/ Tag with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(leading: .bullet)","","    \/\/ Tag with neutral status with a custom decorative icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","    \/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","    \/\/ you can flip the icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","","    \/\/ Text with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(bullet: true))","","    \/\/ Tag with loader with rounded shape in small size","    OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]},{"text":"Design documentation","level":2,"anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/7565ce-tag","isActive":true}],"type":"paragraph"},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"text":"Orange","level":3,"anchor":"Orange","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tag_Orange"}],"type":"paragraph"},{"text":"Orange Business Tools","level":3,"anchor":"Orange-Business-Tools","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tag_OrangeBusinessTools"}],"type":"paragraph"},{"text":"Sosh","level":3,"anchor":"Sosh","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tag_Sosh"}],"type":"paragraph"},{"text":"Wireframe","level":3,"anchor":"Wireframe","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_tag_Wireframe"}],"type":"paragraph"},{"style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}]}],"type":"aside"},{"style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.18.0","type":"text"}]}],"type":"aside"}]}],"metadata":{"title":"OUDSTag","navigatorTitle":[{"text":"OUDSTag","kind":"identifier"}],"modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTag","kind":"identifier"}],"platforms":[{"introducedAt":"15.0","name":"iOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"15.0","name":"macOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"16.0","nam