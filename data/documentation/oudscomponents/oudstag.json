{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag"},"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstag"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"anchor":"Structures","title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Status"],"generated":true},{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(_:tableName:bundle:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(label:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingKey:tableName:bundle:shape:size:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingLabel:shape:size:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body"],"generated":true},{"anchor":"Enumerations","title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Shape","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Size"],"generated":true},{"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations"],"generated":true}],"abstract":[{"text":"Tag is a UI element that allows to display short info like a label, keyword, or category.","type":"text"},{"text":" ","type":"text"},{"text":"Tag helps users quickly find, group, or understand content.","type":"text"}],"metadata":{"title":"OUDSTag","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTag","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSTag","kind":"identifier"}],"role":"symbol","externalID":"s:14OUDSComponents7OUDSTagV","modules":[{"name":"Components"}],"symbolKind":"struct","platforms":[{"name":"iOS","introducedAt":"15.0","deprecated":false,"beta":false,"unavailable":false},{"name":"macOS","introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false},{"name":"tvOS","introducedAt":"16.0","deprecated":false,"beta":false,"unavailable":false},{"name":"visionOS","introducedAt":"1.0","deprecated":false,"beta":false,"unavailable":false},{"name":"watchOS","introducedAt":"11.0","deprecated":false,"beta":false,"unavailable":false}],"roleHeading":"Structure"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTag","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"]},{"content":[{"level":2,"type":"heading","text":"Appearances","anchor":"Appearances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags have two appearances so as to highlight or not their content:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"emphasized","type":"text"}],"type":"strong"},{"text":": A tag with a solid, high-contrast background. Used to draw strong attention to important","type":"text"},{"text":" ","type":"text"},{"text":"labels or categories. Emphasized tags stand out prominently against the interface and are ideal for","type":"text"},{"text":" ","type":"text"},{"text":"primary or high-priority information.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"muted"}]},{"type":"text","text":": A tag with a subtle, light, or semi-transparent background. Used for secondary or"},{"type":"text","text":" "},{"type":"text","text":"less prominent information. Muted tags blend more with the background, providing a softer visual"},{"type":"text","text":" "},{"type":"text","text":"emphasis compared to emphasized tags."}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Status","anchor":"Status"},{"type":"paragraph","inlineContent":[{"text":"Tags have seven status depending on the context of the information they represent. Each state is designed","type":"text"},{"text":" ","type":"text"},{"text":"to convey a specific meaning and ensure clarity in communication.","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Neutral"}],"type":"strong"},{"type":"text","text":": Default or inactive state. Used for standard labels, categories, or when no specific"},{"type":"text","text":" "},{"type":"text","text":"status needs to be communicated."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Accent","type":"text"}]},{"text":": Used to draw attention to new features, recommendations, or content suggestions.","type":"text"},{"text":" ","type":"text"},{"text":"Invites users to explore and engage with new offerings, creating an exciting and engaging experience.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Positive"}],"type":"strong"},{"text":": Indicates success, confirmation, or a positive status. Commonly used to highlight","type":"text"},{"text":" ","type":"text"},{"text":"completed actions or approved items.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Warning"}]},{"text":": Signals caution or a potentially risky situation. Used to draw attention to items","type":"text"},{"text":" ","type":"text"},{"text":"requiring user awareness or intervention.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Negative"}]},{"type":"text","text":": Represents errors, critical issues, or urgent attention needed. Used to highlight"},{"type":"text","text":" "},{"type":"text","text":"problems or failed actions."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Info"}],"type":"strong"},{"text":": Conveys informational messages or supplementary details. Used for neutral, helpful,","type":"text"},{"text":" ","type":"text"},{"text":"or contextual information.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Disabled","type":"text"}]},{"type":"text","text":": Shows that the tag is inactive and cannot be interacted with. Appears faded or greyed out. This is not"},{"type":"text","text":" "},{"type":"text","text":"allowed when loader is activated."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Shape","anchor":"Shape","type":"heading"},{"inlineContent":[{"text":"Tags can have two shapes:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rounded"}]},{"type":"text","text":": A tag with fully rounded corners, creating a pill-shaped appearance. Rounded"},{"type":"text","text":" "},{"type":"text","text":"tags offer a softer and more approachable look, suitable for most modern interfaces."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Square","type":"text"}]},{"type":"text","text":": A tag with sharp, square corners. Squared tags provide a more formal, structured, or"},{"type":"text","text":" "},{"type":"text","text":"technical feel. They are often used in business contexts to label promotions, offers, or important notices."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Size","anchor":"Size","level":2,"type":"heading"},{"inlineContent":[{"text":"Tags can have two sizes:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Default","type":"text"}],"type":"strong"},{"text":": The standard tag size, suitable for most use cases and offering good readability.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Small","type":"text"}]},{"type":"text","text":": A compact tag with reduced height and font size. Used when saving space is important or"},{"type":"text","text":" "},{"type":"text","text":"when grouping elements visually."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Layout","anchor":"Layout","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"There are four available layouts for tags:"}],"type":"paragraph"},{"inlineContent":[{"text":"-","type":"text"},{"inlineContent":[{"type":"text","text":"Text only"}],"type":"strong"},{"text":": A tag that displays only text. Used for simple labels, categories, or keywords without additional visual","type":"text"},{"text":" ","type":"text"},{"text":"elements.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"text":"Text + Bullet","type":"text"}]},{"type":"text","text":": A tag with a small indicator (dot) alongside the text. Used to show status, presence, or activity"},{"type":"text","text":" "},{"type":"text","text":"next to the label."}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"inlineContent":[{"text":"Text + Icon","type":"text"}],"type":"strong"},{"text":": A tag that includes an icon before the text. Used to visually reinforce the meaning of the tag,","type":"text"},{"text":" ","type":"text"},{"text":"such as status, type, or action.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Text + Loader"}]},{"type":"text","text":": A tag that combines a loading spinner (or progress indicator) with text. Used to indicate that"},{"type":"text","text":" "},{"type":"text","text":"a process or action related to the tag is in progress."}]}]}]},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"code":["    \/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","    OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","    \/\/ Or also","    OUDSTag(label: \"Label\")","    \/\/ Or from a localizale and a bundle","    OUDSTag(LocalizedStringKey(\"label_wording\"), bundle: Bundle.module)","","    \/\/ Tag with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(leading: .bullet)","","    \/\/ Tag with neutral status with a custom decorative icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","    \/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","    \/\/ you can flip the icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","","    \/\/ Text with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(bullet: true))","","    \/\/ Tag with loader with rounded shape in small size","    OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"type":"codeListing","