{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"anchor":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Status"],"title":"Structures"},{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(_:tableName:bundle:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(label:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingKey:tableName:bundle:shape:size:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingLabel:shape:size:)"],"title":"Initializers"},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body"],"title":"Instance Properties"},{"generated":true,"anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Shape","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Size"],"title":"Enumerations"},{"generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations"],"title":"Default Implementations"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTag","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"],"kind":"mentions"},{"content":[{"type":"heading","anchor":"Appearances","text":"Appearances","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags have two appearances so as to highlight or not their content:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"emphasized"}]},{"type":"text","text":": A tag with a solid, high-contrast background. Used to draw strong attention to important"},{"type":"text","text":" "},{"type":"text","text":"labels or categories. Emphasized tags stand out prominently against the interface and are ideal for"},{"type":"text","text":" "},{"type":"text","text":"primary or high-priority information."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"muted"}]},{"type":"text","text":": A tag with a subtle, light, or semi-transparent background. Used for secondary or"},{"type":"text","text":" "},{"type":"text","text":"less prominent information. Muted tags blend more with the background, providing a softer visual"},{"type":"text","text":" "},{"type":"text","text":"emphasis compared to emphasized tags."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Status","text":"Status","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags have seven status depending on the context of the information they represent. Each state is designed","type":"text"},{"text":" ","type":"text"},{"text":"to convey a specific meaning and ensure clarity in communication.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Neutral"}]},{"type":"text","text":": Default or inactive state. Used for standard labels, categories, or when no specific"},{"type":"text","text":" "},{"type":"text","text":"status needs to be communicated."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Accent"}]},{"type":"text","text":": Used to draw attention to new features, recommendations, or content suggestions."},{"type":"text","text":" "},{"type":"text","text":"Invites users to explore and engage with new offerings, creating an exciting and engaging experience."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Positive"}]},{"type":"text","text":": Indicates success, confirmation, or a positive status. Commonly used to highlight"},{"type":"text","text":" "},{"type":"text","text":"completed actions or approved items."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Warning"}]},{"type":"text","text":": Signals caution or a potentially risky situation. Used to draw attention to items"},{"type":"text","text":" "},{"type":"text","text":"requiring user awareness or intervention."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Negative"}]},{"type":"text","text":": Represents errors, critical issues, or urgent attention needed. Used to highlight"},{"type":"text","text":" "},{"type":"text","text":"problems or failed actions."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Info"}]},{"type":"text","text":": Conveys informational messages or supplementary details. Used for neutral, helpful,"},{"type":"text","text":" "},{"type":"text","text":"or contextual information."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Disabled"}]},{"type":"text","text":": Shows that the tag is inactive and cannot be interacted with. Appears faded or greyed out. This is not"},{"type":"text","text":" "},{"type":"text","text":"allowed when loader is activated."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Shape","text":"Shape","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags can have two shapes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rounded"}]},{"type":"text","text":": A tag with fully rounded corners, creating a pill-shaped appearance. Rounded"},{"type":"text","text":" "},{"type":"text","text":"tags offer a softer and more approachable look, suitable for most modern interfaces."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Square"}]},{"type":"text","text":": A tag with sharp, square corners. Squared tags provide a more formal, structured, or"},{"type":"text","text":" "},{"type":"text","text":"technical feel. They are often used in business contexts to label promotions, offers, or important notices."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Size","text":"Size","level":2},{"type":"paragraph","inlineContent":[{"text":"Tags can have two sizes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Default"}]},{"type":"text","text":": The standard tag size, suitable for most use cases and offering good readability."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Small"}]},{"type":"text","text":": A compact tag with reduced height and font size. Used when saving space is important or"},{"type":"text","text":" "},{"type":"text","text":"when grouping elements visually."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Layout","text":"Layout","level":2},{"type":"paragraph","inlineContent":[{"text":"There are four available layouts for tags:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"inlineContent":[{"type":"text","text":"Text only"}],"type":"strong"},{"text":": A tag that displays only text. Used for simple labels, categories, or keywords without additional visual","type":"text"},{"text":" ","type":"text"},{"text":"elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"inlineContent":[{"type":"text","text":"Text + Bullet"}],"type":"strong"},{"text":": A tag with a small indicator (dot) alongside the text. Used to show status, presence, or activity","type":"text"},{"text":" ","type":"text"},{"text":"next to the label.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"inlineContent":[{"type":"text","text":"Text + Icon"}],"type":"strong"},{"text":": A tag that includes an icon before the text. Used to visually reinforce the meaning of the tag,","type":"text"},{"text":" ","type":"text"},{"text":"such as status, type, or action.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Text + Loader"}]},{"type":"text","text":": A tag that combines a loading spinner (or progress indicator) with text. Used to indicate that"},{"type":"text","text":" "},{"type":"text","text":"a process or action related to the tag is in progress."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Code-samples","text":"Code samples","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","    OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","    \/\/ Or also","    OUDSTag(label: \"Label\")","    \/\/ Or from a localizale and a bundle","    OUDSTag(LocalizedStringKey(\"label_wording\"), bundle: Bundle.module)","","    \/\/ Tag with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(leading: .bullet)","","    \/\/ Tag with neutral status with a custom decorative icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","    \/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","    \/\/ you can flip the icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","","    \/\/ Text with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(bullet: true))","","    \/\/ Tag with loader with rounded shape in small size","    OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]},{"type":"heading","anchor":"Design-documentation","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-tag","type":"reference"}]},{"type":"heading","anchor":"Themes-rendering","text":"Themes rendering","level":2},{"type":"heading","anchor":"Orange","text":"Orange","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Orange","type":"image"}]},{"type":"heading","anchor":"Orange-Compact","text":"Orange Compact","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_OrangeCompact","type":"image"}]},{"type":"heading","anchor":"Sosh","text":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Sosh","type":"image"}]},{"type":"heading","anchor":"Wireframe","text":"Wireframe","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Wireframe","type":"image"}]},{"content":[{"inlineContent":[{"type":"text","text":"1.4.0 (Figma component design version)"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Version"},{"content":[{"inlineContent":[{"type":"text","text":"0.18.0"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstag"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","metada