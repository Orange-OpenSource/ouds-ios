{"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Status"],"generated":true,"anchor":"Structures","title":"Structures"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(label:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingLabel:shape:size:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body"],"generated":true},{"anchor":"Enumerations","title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Shape","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Size"],"generated":true},{"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations"],"generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstag"]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTag","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"],"kind":"mentions"},{"kind":"content","content":[{"text":"Appearances","anchor":"Appearances","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Tags have two appearances so as to highlight or not their content:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"emphasized","type":"text"}],"type":"strong"},{"text":": A tag with a solid, high-contrast background. Used to draw strong attention to important","type":"text"},{"text":" ","type":"text"},{"text":"labels or categories. Emphasized tags stand out prominently against the interface and are ideal for","type":"text"},{"text":" ","type":"text"},{"text":"primary or high-priority information.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"muted","type":"text"}],"type":"strong"},{"text":": A tag with a subtle, light, or semi-transparent background. Used for secondary or","type":"text"},{"text":" ","type":"text"},{"text":"less prominent information. Muted tags blend more with the background, providing a softer visual","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"emphasis compared to emphasized tags."}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"Status","anchor":"Status"},{"inlineContent":[{"type":"text","text":"Tags have seven status depending on the context of the information they represent. Each state is designed"},{"type":"text","text":" "},{"type":"text","text":"to convey a specific meaning and ensure clarity in communication."}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Neutral","type":"text"}],"type":"strong"},{"text":": Default or inactive state. Used for standard labels, categories, or when no specific","type":"text"},{"text":" ","type":"text"},{"text":"status needs to be communicated.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Accent","type":"text"}]},{"text":": Used to draw attention to new features, recommendations, or content suggestions.","type":"text"},{"text":" ","type":"text"},{"text":"Invites users to explore and engage with new offerings, creating an exciting and engaging experience.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Positive","type":"text"}],"type":"strong"},{"text":": Indicates success, confirmation, or a positive status. Commonly used to highlight","type":"text"},{"type":"text","text":" "},{"type":"text","text":"completed actions or approved items."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Warning"}]},{"type":"text","text":": Signals caution or a potentially risky situation. Used to draw attention to items"},{"type":"text","text":" "},{"type":"text","text":"requiring user awareness or intervention."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Negative","type":"text"}]},{"type":"text","text":": Represents errors, critical issues, or urgent attention needed. Used to highlight"},{"type":"text","text":" "},{"type":"text","text":"problems or failed actions."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Info"}]},{"type":"text","text":": Conveys informational messages or supplementary details. Used for neutral, helpful,"},{"type":"text","text":" "},{"type":"text","text":"or contextual information."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Disabled","type":"text"}],"type":"strong"},{"type":"text","text":": Shows that the tag is inactive and cannot be interacted with. Appears faded or greyed out. This is not"},{"type":"text","text":" "},{"type":"text","text":"allowed when loader is activated."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"anchor":"Shape","text":"Shape","type":"heading"},{"inlineContent":[{"type":"text","text":"Tags can have two shapes:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Rounded"}],"type":"strong"},{"text":": A tag with fully rounded corners, creating a pill-shaped appearance. Rounded","type":"text"},{"text":" ","type":"text"},{"text":"tags offer a softer and more approachable look, suitable for most modern interfaces.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Square"}],"type":"strong"},{"text":": A tag with sharp, square corners. Squared tags provide a more formal, structured, or","type":"text"},{"text":" ","type":"text"},{"text":"technical feel. They are often used in business contexts to label promotions, offers, or important notices.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Size","level":2,"type":"heading","text":"Size"},{"type":"paragraph","inlineContent":[{"text":"Tags can have two sizes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Default"}]},{"type":"text","text":": The standard tag size, suitable for most use cases and offering good readability."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Small"}],"type":"strong"},{"type":"text","text":": A compact tag with reduced height and font size. Used when saving space is important or"},{"type":"text","text":" "},{"type":"text","text":"when grouping elements visually."}]}]}]},{"anchor":"Layout","level":2,"type":"heading","text":"Layout"},{"inlineContent":[{"type":"text","text":"There are four available layouts for tags:"}],"type":"paragraph"},{"inlineContent":[{"text":"-","type":"text"},{"inlineContent":[{"text":"Text only","type":"text"}],"type":"strong"},{"type":"text","text":": A tag that displays only text. Used for simple labels, categories, or keywords without additional visual"},{"type":"text","text":" "},{"type":"text","text":"elements."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"text":"Text + Bullet","type":"text"}]},{"text":": A tag with a small indicator (dot) alongside the text. Used to show status, presence, or activity","type":"text"},{"text":" ","type":"text"},{"text":"next to the label.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"-","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Text + Icon"}]},{"text":": A tag that includes an icon before the text. Used to visually reinforce the meaning of the tag,","type":"text"},{"text":" ","type":"text"},{"text":"such as status, type, or action.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Text + Loader","type":"text"}]},{"text":": A tag that combines a loading spinner (or progress indicator) with text. Used to indicate that","type":"text"},{"text":" ","type":"text"},{"text":"a process or action related to the tag is in progress.","type":"text"}]}]}]},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","code":["    \/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","    OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","    \/\/ Or also","    OUDSTag(label: \"Label\")","","    \/\/ Tag with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(leading: .bullet)","","    \/\/ Tag with neutral status with a custom decorative icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","    \/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","    \/\/ you can flip the icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","","    \/\/ Text with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(bullet: true))","","    \/\/ Tag with loader with rounded shape in small size","    OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"syntax":"swift"},{"level":2,"text":"Design documentation","type":"heading","anchor":"Design-documentation"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-tag","isActive":true,"type":"reference"}],"type":"paragraph"},{"anchor":"Themes-rendering","text":"Themes rendering","type":"heading","level":2},{"anchor":"Orange","text":"Orange","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"component_tag_Orange"}],"type":"paragraph"},{"anchor":"Orange-Compact","level":3,"text":"Orange Compact","type":"heading"},{"inlineContent":[{"identifier":"component_tag_OrangeCompact","type":"image"}],"type":"paragraph"},{"text":"Sosh","type":"heading","anchor":"Sosh","level":3},{"inlineContent":[{"type":"image","identifier":"component_tag_Sosh"}],"type":"paragraph"},{"text":"Wireframe","level":3,"type":"heading","anchor":"Wireframe"},{"inlineContent":[{"identifier":"component_tag_Wireframe","type":"image"}],"type":"paragraph"},{"style":"note","content":[{"inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Version"},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.18.0","type":"text"}]}]}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"role":"symbol","symbolKind":"struct","roleHeading":"Structure","title":"OUDSTag","externalID":"s:14OUDSComponents7OUDSTagV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTag"}],"navigatorTitle":[{"kind":"identifier","text":