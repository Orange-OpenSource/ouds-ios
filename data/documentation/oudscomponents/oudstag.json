{"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo"}],"sections":[],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Tag is a UI element that allows to display short info like a label, keyword, or category."},{"type":"text","text":" "},{"type":"text","text":"Tag helps users quickly find, group, or understand content."}],"kind":"symbol","variants":[{"paths":["\/documentation\/oudscomponents\/oudstag"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Structure","role":"symbol","externalID":"s:14OUDSComponents7OUDSTagV","symbolKind":"struct","modules":[{"name":"Components"}],"title":"OUDSTag","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTag"}],"platforms":[{"introducedAt":"15.0","deprecated":false,"name":"iOS","beta":false,"unavailable":false},{"introducedAt":"13.0","deprecated":false,"name":"macOS","beta":false,"unavailable":false},{"introducedAt":"16.0","deprecated":false,"name":"tvOS","beta":false,"unavailable":false},{"introducedAt":"1.0","deprecated":false,"name":"visionOS","beta":false,"unavailable":false},{"introducedAt":"11.0","deprecated":false,"name":"watchOS","beta":false,"unavailable":false}],"navigatorTitle":[{"kind":"identifier","text":"OUDSTag"}]},"topicSections":[{"generated":true,"anchor":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Status"],"title":"Structures"},{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(label:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingLabel:shape:size:)"],"title":"Initializers"},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body"],"title":"Instance Properties"},{"generated":true,"anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Shape","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Size"],"title":"Enumerations"},{"generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations"],"title":"Default Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTag"}],"languages":["swift"],"platforms":["macOS"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"],"kind":"mentions"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Appearances","text":"Appearances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags have two appearances so as to highlight or not their content:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"emphasized"}]},{"type":"text","text":": A tag with a solid, high-contrast background. Used to draw strong attention to important"},{"type":"text","text":" "},{"type":"text","text":"labels or categories. Emphasized tags stand out prominently against the interface and are ideal for"},{"type":"text","text":" "},{"type":"text","text":"primary or high-priority information."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"muted"}]},{"type":"text","text":": A tag with a subtle, light, or semi-transparent background. Used for secondary or"},{"type":"text","text":" "},{"type":"text","text":"less prominent information. Muted tags blend more with the background, providing a softer visual"},{"type":"text","text":" "},{"type":"text","text":"emphasis compared to emphasized tags."}],"type":"paragraph"}]}]},{"anchor":"Status","type":"heading","text":"Status","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags have seven status depending on the context of the information they represent. Each state is designed"},{"type":"text","text":" "},{"type":"text","text":"to convey a specific meaning and ensure clarity in communication."}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Neutral"}]},{"type":"text","text":": Default or inactive state. Used for standard labels, categories, or when no specific"},{"type":"text","text":" "},{"type":"text","text":"status needs to be communicated."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Accent"}],"type":"strong"},{"type":"text","text":": Used to draw attention to new features, recommendations, or content suggestions."},{"type":"text","text":" "},{"type":"text","text":"Invites users to explore and engage with new offerings, creating an exciting and engaging experience."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Positive"}],"type":"strong"},{"type":"text","text":": Indicates success, confirmation, or a positive status. Commonly used to highlight"},{"type":"text","text":" "},{"type":"text","text":"completed actions or approved items."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Warning"}],"type":"strong"},{"type":"text","text":": Signals caution or a potentially risky situation. Used to draw attention to items"},{"type":"text","text":" "},{"type":"text","text":"requiring user awareness or intervention."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Negative"}],"type":"strong"},{"type":"text","text":": Represents errors, critical issues, or urgent attention needed. Used to highlight"},{"type":"text","text":" "},{"type":"text","text":"problems or failed actions."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Info"}],"type":"strong"},{"type":"text","text":": Conveys informational messages or supplementary details. Used for neutral, helpful,"},{"type":"text","text":" "},{"type":"text","text":"or contextual information."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Disabled"}],"type":"strong"},{"type":"text","text":": Shows that the tag is inactive and cannot be interacted with. Appears faded or greyed out. This is not"},{"type":"text","text":" "},{"type":"text","text":"allowed when loader is activated."}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Shape","type":"heading","text":"Shape"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags can have two shapes:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rounded"}]},{"type":"text","text":": A tag with fully rounded corners, creating a pill-shaped appearance. Rounded"},{"type":"text","text":" "},{"type":"text","text":"tags offer a softer and more approachable look, suitable for most modern interfaces."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Square"}]},{"type":"text","text":": A tag with sharp, square corners. Squared tags provide a more formal, structured, or"},{"type":"text","text":" "},{"type":"text","text":"technical feel. They are often used in business contexts to label promotions, offers, or important notices."}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Size","type":"heading","text":"Size"},{"inlineContent":[{"type":"text","text":"Tags can have two sizes:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Default"}]},{"type":"text","text":": The standard tag size, suitable for most use cases and offering good readability."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Small"}],"type":"strong"},{"type":"text","text":": A compact tag with reduced height and font size. Used when saving space is important or"},{"type":"text","text":" "},{"type":"text","text":"when grouping elements visually."}]}]}],"type":"unorderedList"},{"type":"heading","anchor":"Layout","level":2,"text":"Layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are four available layouts for tags:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"inlineContent":[{"type":"text","text":"Text only"}],"type":"strong"},{"type":"text","text":": A tag that displays only text. Used for simple labels, categories, or keywords without additional visual"},{"type":"text","text":" "},{"type":"text","text":"elements."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"type":"text","text":"Text + Bullet"}]},{"type":"text","text":": A tag with a small indicator (dot) alongside the text. Used to show status, presence, or activity"},{"type":"text","text":" "},{"type":"text","text":"next to the label."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"type":"text","text":"Text + Icon"}]},{"type":"text","text":": A tag that includes an icon before the text. Used to visually reinforce the meaning of the tag,"},{"type":"text","text":" "},{"type":"text","text":"such as status, type, or action."}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Text + Loader"}]},{"type":"text","text":": A tag that combines a loading spinner (or progress indicator) with text. Used to indicate that"},{"type":"text","text":" "},{"type":"text","text":"a process or action related to the tag is in progress."}],"type":"paragraph"}]}]},{"anchor":"Code-samples","type":"heading","text":"Code samples","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","    OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","    \/\/ Or also","    OUDSTag(label: \"Label\")","","    \/\/ Tag with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(leading: .bullet)","","    \/\/ Tag with neutral status with a custom decorative icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","    \/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","    \/\/ you can flip the icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","","    \/\/ Text with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(bullet: true))","","    \/\/ Tag with loader with rounded shape in small size","    OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-tag","isActive":true}],"type":"paragraph"},{"anchor":"Themes-rendering","type":"heading","text":"Themes rendering","level":2},{"anchor":"Orange","type":"heading","text":"Orange","level":3},{"inlineContent":[{"identifier":"component_tag_Orange","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Orange-Compact","type":"heading","text":"Orange Compact"},{"inlineContent":[{"identifier":"component_tag_OrangeCompact","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Sosh","type":"heading","text":"Sosh"},{"inlineContent":[{"identifier":"component_tag_Sosh","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Wireframe","type":"heading","text":"Wireframe"},{"inlineContent":[{"identifier":"component_tag_Wireframe","type":"image"}],"type":"paragraph"},{"style":"note","name":"Version","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.4.0 (Figma component design version)"}]}]},{"style":"note","name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.18.0"}]}]}]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSTag/body":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}],"title":"body","url":"\/documentation\/oudscomponents\/oudstag\/body","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body","abstract":[],"role":"symbol"},"component_tag_Orange":{"alt":"A tag component in light and dark modes with Orange theme","identifier":"component_tag_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_tag_Orange.png","traits":["1x","light"]}],"type":"image"},"https://r.orange.fr/r/S-ouds-doc-tag":{"type":"link","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-tag","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-tag","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"title":"unified-design-syste