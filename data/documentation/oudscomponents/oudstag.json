{"abstract":[{"text":"A tag is a small element that shows short information like a label, keyword, or category.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It helps users quickly find, group, or understand content."}],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Status"],"title":"Structures","generated":true,"anchor":"Structures"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(label:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingLabel:shape:size:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Shape","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Size"],"title":"Enumerations","generated":true,"anchor":"Enumerations"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations"],"title":"Default Implementations","generated":true,"anchor":"Default-Implementations"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstag"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"Components"}],"platforms":[{"introducedAt":"15.0","unavailable":false,"name":"iOS","deprecated":false,"beta":false},{"introducedAt":"15.0","unavailable":false,"name":"macOS","deprecated":false,"beta":false},{"unavailable":false,"name":"tvOS","introducedAt":"16.0","deprecated":false,"beta":false},{"introducedAt":"1.0","unavailable":false,"name":"visionOS","deprecated":false,"beta":false},{"unavailable":false,"name":"watchOS","introducedAt":"11.0","deprecated":false,"beta":false}],"navigatorTitle":[{"text":"OUDSTag","kind":"identifier"}],"roleHeading":"Structure","symbolKind":"struct","title":"OUDSTag","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTag","kind":"identifier"}],"role":"symbol","externalID":"s:14OUDSComponents7OUDSTagV"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTag"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"]},{"kind":"content","content":[{"text":"Appearances","type":"heading","level":2,"anchor":"Appearances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags have two appearances so as to highlight or not their content:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"emphasized","type":"text"}]},{"type":"text","text":": A tag with a solid, high-contrast background. Used to draw strong attention to important"},{"type":"text","text":" "},{"type":"text","text":"labels or categories. Emphasized tags stand out prominently against the interface and are ideal for"},{"type":"text","text":" "},{"type":"text","text":"primary or high-priority information."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"muted","type":"text"}]},{"type":"text","text":": A tag with a subtle, light, or semi-transparent background. Used for secondary or"},{"type":"text","text":" "},{"type":"text","text":"less prominent information. Muted tags blend more with the background, providing a softer visual"},{"type":"text","text":" "},{"type":"text","text":"emphasis compared to emphasized tags."}]}]}],"type":"unorderedList"},{"text":"Status","type":"heading","level":2,"anchor":"Status"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags have seven status depending on the context of the information they represent. Each state is designed"},{"type":"text","text":" "},{"type":"text","text":"to convey a specific meaning and ensure clarity in communication."}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Neutral","type":"text"}]},{"type":"text","text":": Default or inactive state. Used for standard labels, categories, or when no specific"},{"type":"text","text":" "},{"type":"text","text":"status needs to be communicated."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Accent","type":"text"}]},{"type":"text","text":": Used to draw attention to new features, recommendations, or content suggestions."},{"type":"text","text":" "},{"type":"text","text":"Invites users to explore and engage with new offerings, creating an exciting and engaging experience."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Positive","type":"text"}]},{"type":"text","text":": Indicates success, confirmation, or a positive status. Commonly used to highlight"},{"type":"text","text":" "},{"type":"text","text":"completed actions or approved items."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Warning","type":"text"}]},{"type":"text","text":": Signals caution or a potentially risky situation. Used to draw attention to items"},{"type":"text","text":" "},{"type":"text","text":"requiring user awareness or intervention."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Negative","type":"text"}]},{"type":"text","text":": Represents errors, critical issues, or urgent attention needed. Used to highlight"},{"type":"text","text":" "},{"type":"text","text":"problems or failed actions."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Info","type":"text"}]},{"type":"text","text":": Conveys informational messages or supplementary details. Used for neutral, helpful,"},{"type":"text","text":" "},{"type":"text","text":"or contextual information."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Disabled","type":"text"}]},{"type":"text","text":": Shows that the tag is inactive and cannot be interacted with. Appears faded or greyed out. This is not"},{"type":"text","text":" "},{"type":"text","text":"allowed when loader is activated."}]}]}],"type":"unorderedList"},{"text":"Shape","type":"heading","level":2,"anchor":"Shape"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags can have two shapes:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Rounded","type":"text"}]},{"type":"text","text":": A tag with fully rounded corners, creating a pill-shaped appearance. Rounded"},{"type":"text","text":" "},{"type":"text","text":"tags offer a softer and more approachable look, suitable for most modern interfaces."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Square","type":"text"}]},{"type":"text","text":": A tag with sharp, square corners. Squared tags provide a more formal, structured, or"},{"type":"text","text":" "},{"type":"text","text":"technical feel. They are often used in business contexts to label promotions, offers, or important notices."}]}]}],"type":"unorderedList"},{"text":"Size","type":"heading","level":2,"anchor":"Size"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags can have two sizes:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Default","type":"text"}]},{"type":"text","text":": The standard tag size, suitable for most use cases and offering good readability."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Small","type":"text"}]},{"type":"text","text":": A compact tag with reduced height and font size. Used when saving space is important or"},{"type":"text","text":" "},{"type":"text","text":"when grouping elements visually."}]}]}],"type":"unorderedList"},{"text":"Layout","type":"heading","level":2,"anchor":"Layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are four available layouts for tags:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"type":"text","text":"Text only"}]},{"type":"text","text":": A tag that displays only text. Used for simple labels, categories, or keywords without additional visual"},{"type":"text","text":" "},{"type":"text","text":"elements."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"type":"text","text":"Text + Bullet"}]},{"type":"text","text":": A tag with a small indicator (dot) alongside the text. Used to show status, presence, or activity"},{"type":"text","text":" "},{"type":"text","text":"next to the label."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"type":"text","text":"Text + Icon"}]},{"type":"text","text":": A tag that includes an icon before the text. Used to visually reinforce the meaning of the tag,"},{"type":"text","text":" "},{"type":"text","text":"such as status, type, or action."}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Text + Loader","type":"text"}]},{"type":"text","text":": A tag that combines a loading spinner (or progress indicator) with text. Used to indicate that"},{"type":"text","text":" "},{"type":"text","text":"a process or action related to the tag is in progress."}]}]}],"type":"unorderedList"},{"text":"Code samples","type":"heading","level":2,"anchor":"Code-samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","    OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","    \/\/ Or also","    OUDSTag(label: \"Label\")","","    \/\/ Tag with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(leading: .bullet)","","    \/\/ Tag with neutral status with a custom decorative icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","    \/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","    \/\/ you can flip the icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","","    \/\/ Text with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(bullet: true))","","    \/\/ Tag with loader with rounded shape in small size","    OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"]},{"text":"Design documentation","type":"heading","level":2,"anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/7565ce-tag","type":"reference","isActive":true}]},{"text":"Themes rendering","type":"heading","level":2,"anchor":"Themes-rendering"},{"text":"Orange","type":"heading","level":3,"anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Orange","type":"image"}]},{"text":"Orange Business Tools","type":"heading","level":3,"anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_OrangeBusinessTools","type":"image"}]},{"text":"Sosh","type":"heading","level":3,"anchor":"Sos