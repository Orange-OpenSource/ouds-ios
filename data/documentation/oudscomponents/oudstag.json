{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTag"}],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Indicators"],"kind":"mentions"},{"content":[{"level":2,"type":"heading","anchor":"Appearances","text":"Appearances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags have two appearances so as to highlight or not their content:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"emphasized"}]},{"type":"text","text":": A tag with a solid, high-contrast background. Used to draw strong attention to important"},{"type":"text","text":" "},{"type":"text","text":"labels or categories. Emphasized tags stand out prominently against the interface and are ideal for"},{"type":"text","text":" "},{"type":"text","text":"primary or high-priority information."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"muted","type":"text"}],"type":"strong"},{"text":": A tag with a subtle, light, or semi-transparent background. Used for secondary or","type":"text"},{"text":" ","type":"text"},{"text":"less prominent information. Muted tags blend more with the background, providing a softer visual","type":"text"},{"text":" ","type":"text"},{"text":"emphasis compared to emphasized tags.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Status","text":"Status"},{"type":"paragraph","inlineContent":[{"text":"Tags have seven status depending on the context of the information they represent. Each state is designed","type":"text"},{"text":" ","type":"text"},{"text":"to convey a specific meaning and ensure clarity in communication.","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Neutral","type":"text"}]},{"text":": Default or inactive state. Used for standard labels, categories, or when no specific","type":"text"},{"text":" ","type":"text"},{"text":"status needs to be communicated.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Accent"}],"type":"strong"},{"text":": Used to draw attention to new features, recommendations, or content suggestions.","type":"text"},{"text":" ","type":"text"},{"text":"Invites users to explore and engage with new offerings, creating an exciting and engaging experience.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Positive","type":"text"}]},{"type":"text","text":": Indicates success, confirmation, or a positive status. Commonly used to highlight"},{"type":"text","text":" "},{"type":"text","text":"completed actions or approved items."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Warning","type":"text"}],"type":"strong"},{"type":"text","text":": Signals caution or a potentially risky situation. Used to draw attention to items"},{"type":"text","text":" "},{"type":"text","text":"requiring user awareness or intervention."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Negative"}],"type":"strong"},{"text":": Represents errors, critical issues, or urgent attention needed. Used to highlight","type":"text"},{"text":" ","type":"text"},{"text":"problems or failed actions.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Info"}]},{"type":"text","text":": Conveys informational messages or supplementary details. Used for neutral, helpful,"},{"type":"text","text":" "},{"type":"text","text":"or contextual information."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Disabled","type":"text"}],"type":"strong"},{"text":": Shows that the tag is inactive and cannot be interacted with. Appears faded or greyed out. This is not","type":"text"},{"text":" ","type":"text"},{"text":"allowed when loader is activated.","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Shape","text":"Shape"},{"type":"paragraph","inlineContent":[{"text":"Tags can have two shapes:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Rounded","type":"text"}],"type":"strong"},{"text":": A tag with fully rounded corners, creating a pill-shaped appearance. Rounded","type":"text"},{"text":" ","type":"text"},{"text":"tags offer a softer and more approachable look, suitable for most modern interfaces.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Square"}],"type":"strong"},{"text":": A tag with sharp, square corners. Squared tags provide a more formal, structured, or","type":"text"},{"text":" ","type":"text"},{"text":"technical feel. They are often used in business contexts to label promotions, offers, or important notices.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Size","text":"Size"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tags can have two sizes:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Default","type":"text"}]},{"type":"text","text":": The standard tag size, suitable for most use cases and offering good readability."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Small"}]},{"text":": A compact tag with reduced height and font size. Used when saving space is important or","type":"text"},{"text":" ","type":"text"},{"text":"when grouping elements visually.","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Layout","text":"Layout"},{"type":"paragraph","inlineContent":[{"text":"There are four available layouts for tags:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"text":"Text only","type":"text"}]},{"type":"text","text":": A tag that displays only text. Used for simple labels, categories, or keywords without additional visual"},{"type":"text","text":" "},{"type":"text","text":"elements."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"inlineContent":[{"type":"text","text":"Text + Bullet"}],"type":"strong"},{"type":"text","text":": A tag with a small indicator (dot) alongside the text. Used to show status, presence, or activity"},{"type":"text","text":" "},{"type":"text","text":"next to the label."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"-"},{"type":"strong","inlineContent":[{"type":"text","text":"Text + Icon"}]},{"type":"text","text":": A tag that includes an icon before the text. Used to visually reinforce the meaning of the tag,"},{"type":"text","text":" "},{"type":"text","text":"such as status, type, or action."}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Text + Loader"}]},{"type":"text","text":": A tag that combines a loading spinner (or progress indicator) with text. Used to indicate that"},{"type":"text","text":" "},{"type":"text","text":"a process or action related to the tag is in progress."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Code-samples","text":"Code samples"},{"code":["    \/\/ Text only with neutral status, for emphasized appearance with rounded shape in default size","    OUDSTag(label: \"Label\",  status: .neutral(), appearance: .emphasized, shape: .rounded, size: .default)","    \/\/ Or also","    OUDSTag(label: \"Label\")","","    \/\/ Tag with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(leading: .bullet)","","    \/\/ Tag with neutral status with a custom decorative icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\")))","    \/\/ If your layout is in RTL mode but your tag has an icon with another meaning because of bad orientation,","    \/\/ you can flip the icon","    OUDSTag(label: \"Label\", status: .neutral(icon: Image(decorative: \"ic_heart\"), flipIcon: true))","","    \/\/ Text with neutral status with bullet","    OUDSTag(label: \"Label\", status: .neutral(bullet: true))","","    \/\/ Tag with loader with rounded shape in small size","    OUDSTag(loadingLabel: \"Label\", shape: .rounded, size: .small)"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/7565ce-tag"}]},{"level":2,"type":"heading","anchor":"Themes-rendering","text":"Themes rendering"},{"level":3,"type":"heading","anchor":"Orange","text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_Orange","type":"image"}]},{"level":3,"type":"heading","anchor":"Orange-Business-Tools","text":"Orange Business Tools"},{"type":"paragraph","inlineContent":[{"identifier":"component_tag_OrangeBusinessTools","type":"image"}]},{"level":3,"type":"heading","anchor":"Sosh","text":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Sosh"}]},{"level":3,"type":"heading","anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tag_Wireframe"}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"1.4.0 (Figma component design version)"}],"type":"paragraph"}],"name":"Version"},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"0.18.0"}],"type":"paragraph"}],"name":"Since"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstag"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"topicSections":[{"anchor":"Structures","title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Status"],"generated":true},{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(label:status:appearance:shape:size:hasLoader:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/init(loadingLabel:shape:size:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body"],"generated":true},{"anchor":"Enumerations","title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Shape","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/Size"],"generated":true},{"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/View-Implementations"],"generated":true}],"kind":"symbol","metadata":{"title":"OUDSTag","role":"symbol","externalID":"s:14OUDSComponents7OUDSTagV","symbolKind":"struct","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTag","kind":"identifier"}],"modules":[{"name":"Components"}],"navigatorTitle":[{"text":"OUDSTag","kind":"identifier"}]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag"},"abstract":[{"type":"text","text":"A tag is a small element that shows short information like a label, keyword, or category."},{"type":"text","text":" "},{"type":"text","text":"It helps users quickly find, group, or understand content."}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSTag":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSTag"}],"kind":"symbol","url":"\/documentation\/oudscomponents\/oudstag","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTag"}],"title":"OUDSTag","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag","type":"topic","abstract":[{"text":"A tag is a small element that shows short information like a label, keyword, or category.","type":"text"},{"text":" ","type":"text"},{"text":"It helps users quickly find, group, or understand content.","type":"text"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTag/body":{"role":"symbol","abstract":[],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTag\/body","kind":"symbol","url":"\/documentation\/oudscomponents\/oudstag\/body","type":"topic","title":"body","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}]},"https://unified-design-system.orange.com/472794e18/p/7565ce-tag":{"title":"unified-design-system.orange.com","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/756