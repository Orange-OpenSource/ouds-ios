e of the input"}],"type":"paragraph"}]},{"name":"text","content":[{"inlineContent":[{"type":"text","text":"The text to display and edit"}],"type":"paragraph"}]},{"name":"placeholder","content":[{"inlineContent":[{"type":"text","text":"The text displayed when the text input is empty, by default is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"nil"}]}],"type":"paragraph"}]},{"name":"prefix","content":[{"inlineContent":[{"type":"text","text":"Text placed before the user’s input. Commonly used to indicate expected formatting like a country code, a unit…"},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"prefix"},{"type":"text","text":" is hidden if a "},{"type":"codeVoice","code":"placeholder"},{"type":"text","text":" is not provided or empty. But it is visible in focus state or if the value is not empty."}],"type":"paragraph"}]},{"name":"suffix","content":[{"inlineContent":[{"type":"text","text":"Text placed after the user’s input, often used to display a currency or a unit (kg, %, cm…)."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"suffix"},{"type":"text","text":" is hidden if a "},{"type":"codeVoice","code":"placeholder"},{"type":"text","text":" is not provided or empty. But it is visible in focus state or if the value is not empty."}],"type":"paragraph"}]},{"name":"leadingIcon","content":[{"inlineContent":[{"type":"text","text":"An optional leading icon to provide more context (magnifying glass for search,"},{"type":"text","text":" "},{"type":"text","text":"envelope for email, etc.), by default is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"nil"}]}],"type":"paragraph"}]},{"name":"flipLeadingIcon","content":[{"inlineContent":[{"type":"text","text":"Default set to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"false"}]},{"type":"text","text":", set to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"true"}]},{"type":"text","text":" to mirror the leading icon (e.g. in RTL case)"}],"type":"paragraph"}]},{"name":"trailingAction","content":[{"inlineContent":[{"type":"text","text":"An optional trailing action related to the field: (clear input,"},{"type":"text","text":" "},{"type":"text","text":"toggle password visibility, etc.), by default is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"nil"}]}],"type":"paragraph"}]},{"name":"helperText","content":[{"inlineContent":[{"type":"text","text":"An optional helper text displayed below the text input. It conveys additional, by default is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"nil"}]},{"type":"text","text":" "},{"type":"text","text":"information about the input field, such as how it will be used., by default is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"nil"}]},{"type":"text","text":". If "},{"type":"codeVoice","code":"status"},{"type":"text","text":" is set to OUDSTextInput.Status.Error,"},{"type":"text","text":" "},{"type":"text","text":"this "},{"type":"codeVoice","code":"helperText"},{"type":"text","text":" is ignored."}],"type":"paragraph"}]},{"name":"helperLink","content":[{"inlineContent":[{"type":"text","text":"An helper link displayed below or in place of the helper text., by default is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"nil"}]}],"type":"paragraph"}]},{"name":"isOutlined","content":[{"inlineContent":[{"type":"text","text":"Controls the style of the text input. When "},{"type":"codeVoice","code":"true"},{"type":"text","text":", it displays a minimalist"},{"type":"text","text":" "},{"type":"text","text":"text input with a transparent background and a visible stroke outlining the field, by default is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"false"}]}],"type":"paragraph"}]},{"name":"constrainedMaxWidth","content":[{"inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"true"},{"type":"text","text":", the width is constrained to a maximum value defined by the design system."},{"type":"text","text":" "},{"type":"text","text":"When "},{"type":"codeVoice","code":"false"},{"type":"text","text":", no specific width constraint is applied, allowing the component to size itself or follow external"},{"type":"text","text":" "},{"type":"text","text":"modifier. Defaults to "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"status","content":[{"inlineContent":[{"type":"text","text":"The current status of the text input, by default to set "},{"type":"emphasis","inlineContent":[{"type":"text","text":"enabled"}]}],"type":"paragraph"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"code":["    OUDSTextInput(label: \"Email\",","                  text: $text,","                  helperText: AttributedString(markdown: \"You should use your **corporate email**\"))  \/\/ Manage in your side errors for init"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)-1pe0w","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstextinput\/init(label:text:placeholder:prefix:suffix:leadingicon:flipleadingicon:trailingaction:helpertext:helperlink:isoutlined:constrainedmaxwidth:status:)-1pe0w"]}],"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Creates a text input."}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:c