 "},{"type":"emphasis","inlineContent":[{"type":"text","text":"nil"}]}],"type":"paragraph"}],"name":"leadingIcon"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default set to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"false"}]},{"type":"text","text":", set to "},{"inlineContent":[{"type":"text","text":"true"}],"type":"emphasis"},{"type":"text","text":" to mirror the leading icon (e.g. in RTL case)"}]}],"name":"flipLeadingIcon"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional trailing action related to the field: (clear input,"},{"type":"text","text":" "},{"type":"text","text":"toggle password visibility, etc.), by default is "},{"inlineContent":[{"type":"text","text":"nil"}],"type":"emphasis"}]}],"name":"trailingAction"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional helper text displayed below the text input. It conveys additional, by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"information about the input field, such as how it will be used., by default is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"nil"}]},{"type":"text","text":". If "},{"code":"status","type":"codeVoice"},{"type":"text","text":" is set to OUDSTextInput.Status.Error,"},{"type":"text","text":" "},{"type":"text","text":"this "},{"code":"helperText","type":"codeVoice"},{"type":"text","text":" is ignored."}]}],"name":"helperText"},{"content":[{"inlineContent":[{"type":"text","text":"An optional helper link displayed below or in place of the helper text., by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]}],"type":"paragraph"}],"name":"helperLink"},{"content":[{"inlineContent":[{"type":"text","text":"Controls the style of the text input. When "},{"code":"true","type":"codeVoice"},{"type":"text","text":", it displays a minimalist"},{"type":"text","text":" "},{"type":"text","text":"text input with a transparent background and a visible stroke outlining the field, by default is "},{"inlineContent":[{"text":"false","type":"text"}],"type":"emphasis"}],"type":"paragraph"}],"name":"isOutlined"},{"content":[{"inlineContent":[{"type":"text","text":"When "},{"code":"true","type":"codeVoice"},{"type":"text","text":", the width is constrained to a maximum value defined by the design system."},{"type":"text","text":" "},{"type":"text","text":"When "},{"code":"false","type":"codeVoice"},{"type":"text","text":", no specific width constraint is applied, allowing the component to size itself or follow external"},{"type":"text","text":" "},{"type":"text","text":"modifier. Defaults to "},{"code":"false","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"constrainedMaxWidth"},{"content":[{"inlineContent":[{"type":"text","text":"The current status of the text input, by default to set "},{"type":"emphasis","inlineContent":[{"type":"text","text":"enabled"}]}],"type":"paragraph"}],"name":"status"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"codeListing","syntax":"swift","code":["    OUDSTextInput(label: \"Email\", text: $text)"]}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)-8b5ox"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Creates a text input."}],"metadata":{"modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents13OUDSTextInputV5label4text11placeholder6prefix6suffix11leadingIcon011flipLeadingJ014trailingAction10helperText0O4Link10isOutlined19constrainedMaxWidth6statusACSS_7SwiftUI7BindingVySSGSSSgA2uQ5ImageVSgSbAC08TrailingN0VSgAuC10HelperlinkVSgS2bAC6StatusOt