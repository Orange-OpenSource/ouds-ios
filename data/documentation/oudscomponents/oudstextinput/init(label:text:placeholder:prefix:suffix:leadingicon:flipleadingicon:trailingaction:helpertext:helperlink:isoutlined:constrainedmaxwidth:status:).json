:"The text displayed when the text input is empty, by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]}],"type":"paragraph"}],"name":"placeholder"},{"content":[{"inlineContent":[{"type":"text","text":"Text placed before the user’s input. Commonly used to indicate expected formatting like a country code, a unit…"},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"prefix"},{"type":"text","text":" is hidden if a "},{"type":"codeVoice","code":"placeholder"},{"type":"text","text":" is not provided or empty. But it is visible in focus state or if the value is not empty."}],"type":"paragraph"}],"name":"prefix"},{"content":[{"inlineContent":[{"type":"text","text":"Text placed after the user’s input, often used to display a currency or a unit (kg, %, cm…)."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"suffix"},{"type":"text","text":" is hidden if a "},{"type":"codeVoice","code":"placeholder"},{"type":"text","text":" is not provided or empty. But it is visible in focus state or if the value is not empty."}],"type":"paragraph"}],"name":"suffix"},{"content":[{"inlineContent":[{"type":"text","text":"An optional leading icon to provide more context (magnifying glass for search,"},{"type":"text","text":" "},{"type":"text","text":"envelope for email, etc.), by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]}],"type":"paragraph"}],"name":"leadingIcon"},{"content":[{"inlineContent":[{"type":"text","text":"Default set to "},{"type":"emphasis","inlineContent":[{"text":"false","type":"text"}]},{"type":"text","text":", set to "},{"type":"emphasis","inlineContent":[{"text":"true","type":"text"}]},{"type":"text","text":" to mirror the leading icon (e.g. in RTL case)"}],"type":"paragraph"}],"name":"flipLeadingIcon"},{"content":[{"inlineContent":[{"type":"text","text":"An optional trailing action related to the field: (clear input,"},{"type":"text","text":" "},{"type":"text","text":"toggle password visibility, etc.), by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]}],"type":"paragraph"}],"name":"trailingAction"},{"content":[{"inlineContent":[{"type":"text","text":"An optional helper text displayed below the text input. It conveys additional, by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"information about the input field, such as how it will be used., by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]},{"type":"text","text":". If "},{"type":"codeVoice","code":"status"},{"type":"text","text":" is set to OUDSTextInput.Status.Error,"},{"type":"text","text":" "},{"type":"text","text":"this "},{"type":"codeVoice","code":"helperText"},{"type":"text","text":" is ignored."}],"type":"paragraph"}],"name":"helperText"},{"content":[{"inlineContent":[{"type":"text","text":"An optional helper link displayed below or in place of the helper text., by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]}],"type":"paragraph"}],"name":"helperLink"},{"content":[{"inlineContent":[{"type":"text","text":"Controls the style of the text input. When "},{"type":"codeVoice","code":"true"},{"type":"text","text":", it displays a minimalist"},{"type":"text","text":" "},{"type":"text","text":"text input with a transparent background and a visible stroke outlining the field, by default is "},{"type":"emphasis","inlineContent":[{"text":"false","type":"text"}]}],"type":"paragraph"}],"name":"isOutlined"},{"content":[{"inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"true"},{"type":"text","text":", the width is constrained to a maximum value defined by the design system."},{"type":"text","text":" "},{"type":"text","text":"When "},{"type":"codeVoice","code":"false"},{"type":"text","text":", no specific width constraint is applied, allowing the component to size itself or follow external"},{"type":"text","text":" "},{"type":"text","text":"modifier. Defaults to "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"constrainedMaxWidth"},{"content":[{"inlineContent":[{"type":"text","text":"The current status of the text input, by default to set "},{"type":"emphasis","inlineContent":[{"text":"enabled","type":"text"}]}],"type":"paragraph"}],"name":"status"}],"kind":"parameters"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"codeListing","code":["    OUDSTextInput(label: \"Email\", text: $text)"],"syntax":"swift"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput"]]},"kind":"symbol","abstract":[{"text":"Creates a text input.","type":"text"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstextinput\/init(label:text:placeholder:prefix:suffix:leadingicon:flipleadingicon:trailingaction:helpertext:helperlink:isoutlined:constrainedmaxwidth:status:)"]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/Status":{"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Status","navigatorTitle":[{"kind":"identifier","text":"Status"}],"role":"symbol","abstract":[{"text":"Define all available status for the text input","type":"text"}],"url":"\/documentation\/oudscomponents\/oudstextinput\/status","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Status"}],"title":"OUDSTextInpu