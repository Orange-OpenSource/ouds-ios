t","content":[{"inlineContent":[{"type":"text","text":"The text to display and edit"}],"type":"paragraph"}]},{"name":"placeholder","content":[{"inlineContent":[{"type":"text","text":"The text displayed when the text input is empty, by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]}],"type":"paragraph"}]},{"name":"prefix","content":[{"inlineContent":[{"type":"text","text":"Text placed before the user’s input. Commonly used to indicate expected formatting like a country code, a unit…"},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"prefix"},{"type":"text","text":" is hidden if a "},{"type":"codeVoice","code":"placeholder"},{"type":"text","text":" is not provided or empty. But it is visible in focus state or if the value is not empty."}],"type":"paragraph"}]},{"name":"suffix","content":[{"inlineContent":[{"type":"text","text":"Text placed after the user’s input, often used to display a currency or a unit (kg, %, cm…)."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"suffix"},{"type":"text","text":" is hidden if a "},{"type":"codeVoice","code":"placeholder"},{"type":"text","text":" is not provided or empty. But it is visible in focus state or if the value is not empty."}],"type":"paragraph"}]},{"name":"leadingIcon","content":[{"inlineContent":[{"type":"text","text":"An optional leading icon to provide more context (magnifying glass for search,"},{"type":"text","text":" "},{"type":"text","text":"envelope for email, etc.), by default is "},{"type":"emphasis","inlineContent":[{"text":"nil","type":"text"}]}],"type":"paragraph"}]},{"name":"flipLeadingIcon","content":[{"inlineContent":[{"type":"text","text":"Default set to "},{"type":"emphasis","inlineContent":[{"text":"false","type":"text"}]},{"type":"text","text":", set to "},{"type":"emphasis","inlineContent":[{"text":"true","type":"text"}]},{"type":"text","text":" to mirror the leading icon (e.g. in RTL case)"}],"t