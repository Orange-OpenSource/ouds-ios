,"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSVerticalDivider"}],"kind":"symbol","title":"OUDSVerticalDivider","abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"text":").","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","navigatorTitle":[{"kind":"identifier","text":"OUDSVerticalDivider"}],"url":"\/documentation\/oudscomponents\/oudsverticaldivider","role":"symbol"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"kind":"symbol","title":"OUDSTheme","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol"},"ic_folder_categories.png":{"type":"image","identifier":"ic_folder_categories.png","variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"alt":null}}}