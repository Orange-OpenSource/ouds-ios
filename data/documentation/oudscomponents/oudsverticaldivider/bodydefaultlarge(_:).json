text"},{"text":" ","type":"text"},{"text":"Any properties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true,"type":"reference"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"role":"symbol","title":"OUDSTheme","type":"topic","url":"\/documentation\/oudsthemescontract\/oudstheme","kind":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}]},"ic_folder_categories.png":{"alt":null,"identifier":"ic_folder_categories.png","type":"image","variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]}}}