","type":"codeVoice"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","kind":"symbol","title":"OUDSTheme","type":"topic","role":"symbol"}}}