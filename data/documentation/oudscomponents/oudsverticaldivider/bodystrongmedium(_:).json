ducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"text":").","type":"text"},{"type":"text","text":" "},{"text":"The divider can be colored using dedicated ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor"},{"type":"text","text":" colors."},{"text":" ","type":"text"},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"}],"kind":"symbol","title":"OUDSVerticalDivider","role":"symbol"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"OUDSTheme","kind":"identifier"}],"abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"text":"to implement all tokens.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inli