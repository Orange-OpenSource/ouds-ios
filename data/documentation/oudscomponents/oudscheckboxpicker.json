{"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"type":"text","text":"A picker allowing to expose several checkboxes and select some of them within the others."},{"text":" ","type":"text"},{"type":"text","text":"Each checkbox contains a “tag”, i.e. a supposed to be unique value."},{"text":" ","type":"text"},{"type":"text","text":"The picker will expose the choosen values using this “tag”."},{"text":" ","type":"text"},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxpicker"]}],"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/init(selections:checkboxes:placement:isReversed:isError:isReadOnly:hasDivider:itemsSpacing:)"]},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/body"],"anchor":"Instance-Properties"},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/View-Implementations"]}],"kind":"symbol","metadata":{"title":"OUDSCheckboxPicker","navigatorTitle":[{"text":"OUDSCheckboxPicker","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSCheckboxPicker","kind":"identifier"}],"roleHeading":"Structure","symbolKind":"struct","externalID":"s:14OUDSComponents18OUDSCheckboxPickerV","modules":[{"name":"Components"}],"role":"symbol","platforms":[{"deprecated":false,"name":"iOS","introducedAt":"15.0","unavailable":false,"beta":false},{"deprecated":false,"name":"macOS","introducedAt":"15.0","unavailable":false,"beta":false},{"deprecated":false,"name":"visionOS","introducedAt":"1.0","unavailable":false,"beta":false}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxPicker"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Tag"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Tag"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"Hashable","preciseIdentifier":"s:SH"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"text":"Accessibility considerations","type":"heading","level":2,"anchor":"Accessibility-considerations"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a chekcbox trait."},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"type":"text","text":" "},{"type":"text","text":"However if defined in the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData"},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."},{"text":" ","type":"text"},{"text":"In addition the root item of the picker has for accessiiblity identifier the displayed text.","type":"text"}],"type":"paragraph"},{"anchor":"Forbidden-by-design","level":2,"type":"heading","text":"Forbidden by design"},{"inlineContent":[{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" in both an error situation and a read only state.","type":"text"},{"text":" ","type":"text"},{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" in both an error situation and a disabled state.","type":"text"},{"text":" ","type":"text"},{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" in both a read only and a disabled state.","type":"text"}],"type":"paragraph"},{"anchor":"Code-samples","level":2,"type":"heading","text":"Code samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define the elements to display in checkboxes using OUDSCheckboxPickerData.","    \/\/ This object has the same properties as the OUDSCheckboxItem,","    \/\/ and some of them are optional with default values set","    var someDataToPopulate: [OUDSCheckboxPickerData<String>] {","        [","        OUDSCheckboxPickerData<String>(tag: \"Choice_1\",","                                       label: \"Virgin Holy Lava\",","                                       additionalLabel: \"Very spicy\",","                                       helper: \"No alcohol, only tasty flavors\",","                                       icon: Image(systemName: \"flame\")),","","        OUDSCheckboxPickerData<String>(tag: \"Choice_2\",","                                       label: \"IPA beer\",","                                       helper: \"From Brewdog company\",","                                       icon: Image(systemName: \"dog.fill\")),","","        OUDSCheckboxPickerData<String>(tag: \"Choice_3\",","                                       label: \"Mineral water\",","                                       icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [String] = [\"Choice_1\"] \/\/ or empty if nothing selected","","    \/\/ Here the picker is vertical by default","    OUDSCheckboxPicker(selections: $selections, checkboxes: someDataToPopulate)","","    \/\/ The picker can be vertical and have a root item with a label and a counter","    OUDSCheckboxPicker(selections: $selections,","                       placement: .verticalRooted(label, .textAndCount))","","    \/\/ The picker can apply some settings to all its radio buttons.","    \/\/ It can be also horizontal with a scroll indicator.","    \/\/ Here all the the checkboxes are in read only mode and use reversed layout.","    \/\/ Here the picker is horizontal and shows the scroll indicator","    OUDSCheckboxPicker(selections: $selections,","                       checkboxes: someDataToPopulate)","                       isReversed: true,","                       isReadOnly: true,","                       placement: .horizontal(true))"]},{"anchor":"Design-documentation","level":2,"type":"heading","text":"Design documentation"},{"inlineContent":[{"text":"There is no online specification as this component is not an official OUDS one","type":"text"}],"type":"paragraph"},{"anchor":"Themes-rendering","level":2,"type":"heading","text":"Themes rendering"},{"anchor":"Orange","level":3,"type":"heading","text":"Orange"},{"inlineContent":[{"identifier":"component_checkboxPicker_Orange","type":"image"}],"type":"paragraph"},{"name":"Since","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"0.14.0"}],"type":"paragraph"}]}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxPickerData":{"navigatorTitle":[{"text":"OUDSCheckboxPickerData","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudscheckboxpickerdata","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxPickerData","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPickerData","abstract":[{"type":"text","text":"The data to use to populate the picker of "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"type":"text","text":" objects."},{"type":"text","text":" "},{"type":"text","text":"Each property in this "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPickerData","isActive":true},{"type":"text","text":" is used to define the suitable "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"type":"text","text":"."}],"type":"topic","title":"OUDSCheckboxPickerData","role":"symbol"},"doc://OUDSComponents/7SwiftUI4ViewP":{"title":"SwiftUICore.View","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","type":"unresolvable"},"doc://OUDSComponents/documentation/OUDSComponents/OUD