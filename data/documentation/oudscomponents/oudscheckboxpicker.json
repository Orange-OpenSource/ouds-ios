{"sections":[],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/init(selections:checkboxes:placement:isReversed:isError:isReadOnly:hasDivider:itemsSpacing:)"],"anchor":"Initializers"},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/body"]},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/View-Implementations"]}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxPicker","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Tag","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Tag","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SH","text":"Hashable","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"content":[{"anchor":"Accessibility-considerations","level":2,"type":"heading","text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a chekcbox trait.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"type":"text","text":" "},{"type":"text","text":"However if defined in the "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData","type":"reference","isActive":true},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."},{"type":"text","text":" "},{"type":"text","text":"In addition the root item of the picker has for accessiiblity identifier the displayed text."}]},{"anchor":"Forbidden-by-design","level":2,"type":"heading","text":"Forbidden by design"},{"type":"paragraph","inlineContent":[{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" in both an error situation and a read only state.","type":"text"},{"text":" ","type":"text"},{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" in both an error situation and a disabled state.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The design system does not allow to have "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" in both a read only and a disabled state."}]},{"anchor":"Code-samples","level":2,"type":"heading","text":"Code samples"},{"code":["    \/\/ Define the elements to display in checkboxes using OUDSCheckboxPickerData.","    \/\/ This object has the same properties as the OUDSCheckboxItem,","    \/\/ and some of them are optional with default values set","    var someDataToPopulate: [OUDSCheckboxPickerData<String>] {","        [","        OUDSCheckboxPickerData<String>(tag: \"Choice_1\",","                                       label: \"Virgin Holy Lava\",","                                       additionalLabel: \"Very spicy\",","                                       helper: \"No alcohol, only tasty flavors\",","                                       icon: Image(systemName: \"flame\")),","","        OUDSCheckboxPickerData<String>(tag: \"Choice_2\",","                                       label: \"IPA beer\",","                                       helper: \"From Brewdog company\",","                                       icon: Image(systemName: \"dog.fill\")),","","        OUDSCheckboxPickerData<String>(tag: \"Choice_3\",","                                       label: \"Mineral water\",","                                       icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [String] = [\"Choice_1\"] \/\/ or empty if nothing selected","","    \/\/ Here the picker is vertical by default","    OUDSCheckboxPicker(selections: $selections, checkboxes: someDataToPopulate)","","    \/\/ The picker can be vertical and have a root item with a label and a counter","    OUDSCheckboxPicker(selections: $selections,","                       placement: .verticalRooted(label, .textAndCount))","","    \/\/ The picker can apply some settings to all its radio buttons.","    \/\/ It can be also horizontal with a scroll indicator.","    \/\/ Here all the the checkboxes are in read only mode and use reversed layout.","    \/\/ Here the picker is horizontal and shows the scroll indicator","    OUDSCheckboxPicker(selections: $selections,","                       checkboxes: someDataToPopulate)","                       isReversed: true,","                       isReadOnly: true,","                       placement: .horizontal(true))"],"type":"codeListing","syntax":"swift"},{"anchor":"Design-documentation","level":2,"type":"heading","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no online specification as this component is not an official OUDSThemesContract one"}]},{"anchor":"Themes-rendering","level":2,"type":"heading","text":"Themes rendering"},{"anchor":"Orange","level":3,"type":"heading","text":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxPicker_Orange"}]},{"type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.14.0"}]}],"style":"note"}],"kind":"content"}],"metadata":{"title":"OUDSCheckboxPicker","navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxPicker"}],"modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSCheckboxPicker"}],"role":"symbol","platforms":[{"beta":false,"deprecated":false,"name":"iOS","unavailable":false,"introducedAt":"15.0"},{"introducedAt":"15.0","name":"macOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"1.0","name":"visionOS","deprecated":false,"beta":false,"unavailable":false}],"symbolKind":"struct","roleHeading":"Structure","externalID":"s:14OUDSComponents18OUDSCheckboxPickerV"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxpicker"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker"},"abstract":[{"type":"text","text":"A picker allowing to expose several checkboxes and select some of them within the others."},{"text":" "