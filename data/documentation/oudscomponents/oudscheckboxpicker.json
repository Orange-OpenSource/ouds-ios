{"metadata":{"modules":[{"name":"Components"}],"title":"OUDSCheckboxPicker","role":"symbol","platforms":[{"introducedAt":"15.0","deprecated":false,"name":"iOS","beta":false,"unavailable":false},{"introducedAt":"13.0","deprecated":false,"name":"macOS","beta":false,"unavailable":false},{"name":"visionOS","unavailable":false,"introducedAt":"1.0","deprecated":false,"beta":false}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSCheckboxPicker"}],"roleHeading":"Structure","symbolKind":"struct","navigatorTitle":[{"text":"OUDSCheckboxPicker","kind":"identifier"}],"externalID":"s:14OUDSComponents18OUDSCheckboxPickerV"},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxPicker"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Tag"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Tag","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Hashable","preciseIdentifier":"s:SH","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations","type":"heading"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a chekcbox trait."},{"type":"text","text":" "},{"text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used.","type":"text"},{"text":" ","type":"text"},{"text":"However if defined in the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData","type":"reference","isActive":true},{"text":" the items inside the picker will have such accessibility identifiers.","type":"text"},{"text":" ","type":"text"},{"text":"In addition the root item of the picker has for accessiiblity identifier the displayed text.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Forbidden by design","anchor":"Forbidden-by-design","type":"heading"},{"inlineContent":[{"text":"The design system does not allow to have ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true,"type":"reference"},{"text":" in both an error situation and a read only state.","type":"text"},{"text":" ","type":"text"},{"text":"The design system does not allow to have ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true,"type":"reference"},{"text":" in both an error situation and a disabled state.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The design system does not allow to have "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true,"type":"reference"},{"type":"text","text":" in both a read only and a disabled state."}],"type":"paragraph"},{"type":"heading","anchor":"Code-samples","level":2,"text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define the elements to display in checkboxes using OUDSCheckboxPickerData.","    \/\/ This object has the same properties as the OUDSCheckboxItem,","    \/\/ and some of them are optional with default values set","    var someDataToPopulate: [OUDSCheckboxPickerData<String>] {","        [","        OUDSCheckboxPickerData<String>(tag: \"Choice_1\",","                                       label: \"Virgin Holy Lava\",","                                       extraLabel: \"Very spicy\",","                                       helper: \"No alcohol, only tasty flavors\",","                                       icon: Image(systemName: \"flame\")),","","        OUDSCheckboxPickerData<String>(tag: \"Choice_2\",","                                       label: \"IPA beer\",","                                       helper: \"From Brewdog company\",","                                       icon: Image(systemName: \"dog.fill\")),","","        OUDSCheckboxPickerData<String>(tag: \"Choice_3\",","                                       label: \"Mineral water\",","                                       icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [String] = [\"Choice_1\"] \/\/ or empty if nothing selected","","    \/\/ Here the picker is vertical by default","    OUDSCheckboxPicker(selections: $selections, checkboxes: someDataToPopulate)","","    \/\/ The picker can be vertical and have a root item with a label and a counter","    OUDSCheckboxPicker(selections: $selections,","                       placement: .verticalRooted(label, .textAndCount))","","    \/\/ The picker can apply some settings to all its radio buttons.","    \/\/ It can be also horizontal with a scroll indicator.","    \/\/ Here all the the checkboxes are in read only mode and use reversed layout.","    \/\/ Here the picker is horizontal and shows the scroll indicator","    OUDSCheckboxPicker(selections: $selections,","                       checkboxes: someDataToPopulate)","                       isReversed: true,","                       isReadOnly: true,","                       placement: .horizontal(true))"]},{"type":"heading","anchor":"Design-documentation","level":2,"text":"Design documentation"},{"type":"paragraph","inlineContent":[{"text":"There is no online specification as this component is not an official OUDS one","type":"text"}]},{"type":"heading","anchor":"Themes-rendering","level":2,"text":"Themes rendering"},{"type":"heading","anchor":"Orange","level":3,"text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_checkboxPicker_Orange","type":"image"}]},{"type":"aside","name":"Since","content":[{"inlineContent":[{"text":"0.14.0","type":"text"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxpicker"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/init(selections:checkboxes:placement:isReversed:isError:isReadOnly:hasDivider:itemsSpacing:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/body"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker\/View-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"abstract":[{"text":"A picker allowing to expose several checkboxes and select some of them within the others