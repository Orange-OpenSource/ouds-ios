orce the security context."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Helper text"}]},{"text":":  A supporting text conveys additional information about the password field.","type":"text"}]}]}]},{"level":2,"type":"heading","anchor":"Outlined-style","text":"Outlined style"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By "},{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look."}]},{"code":["   \/\/ An outlined text input","   OUDSPasswordInput(label: \"Your password\", password: $password, isOutlined: true)","","   \/\/ With a localizable from a bundle","   OUDSPasswordInput(LocalizedStringKey(\"password_label\"), bundle: Bundle.module, password: $password)"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"Rounded-layout","text":"Rounded layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As the"},{"type":"codeVoice","code":" OUDSTextInput"},{"type":"text","text":", rounded corners can be enabled or disabled using the "},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration."}]},{"level":2,"type":"heading","anchor":"Status","text":"Status"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As "},{"type":"codeVoice","code":"OUDSPasswordInput"},{"type":"text","text":" is based on the"},{"type":"codeVoice","code":" OUDSTextInput"},{"type":"text","text":", all the status are the same and have the same behavior available here "},{"type":"codeVoice","code":"OUDSTextInput.Status"}]},{"anchor":"Accessibility-considerations","type":"heading","level":2,"text":"Accessibility considerations"},{"type":"parag