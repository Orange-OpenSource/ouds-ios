":2},{"inlineContent":[{"text":"By default no haptics are done by the component for the trailing action.","type":"text"},{"text":" ","type":"text"},{"text":"However you should think about cases wher you will have to make the devices vibrates.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Code samples","level":2,"type":"heading","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ The password to display and edit","    @State var password: String = \"\"","","    \/\/ A basic password input with label","    OUDSPasswordInput(label: \"Password\", password: $password)","","    \/\/ Add a leading icon and helper text to more context","    OUDSPasswordInput(label: \"Password\", password: $password, lockIcon: true, helperText: \"Your password must be between 8 and 20 characters long.\")","","    \/\/ Password with prefix","    OUDSPasswordInput(label: \"Password\", password: $password, prefix: \"CORP-\")","","    \/\/ Make password visible","    OUDSPasswordInput(label: \"Password\", password: $password, isHiddenPassword: .constant(false))"]},{"type":"heading","text":"Design documentation","anchor":"Design-documentation","level":2},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-password-input"}]},{"anchor":"Themes-rendering","type":"heading","level":2,"text":"Themes rendering"},{"level":3,"type":"heading","text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_passwordInput_Orange"}]},{"type":"heading","text":"Orange Compact","anchor":"Orange-Compact","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_passwordInput_OrangeCompact"}]},{"type":"head