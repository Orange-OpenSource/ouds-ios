"text":"As it is based on the ","type":"text"},{"type":"codeVoice","code":"OUDSTextInput"},{"text":",  it offers same layout and the same elements of configuration.","type":"text"}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudspasswordinput"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSPasswordInput","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"text":"Layout","type":"heading","anchor":"Layout","level":2},{"inlineContent":[{"text":"Passwords input is based on several configurable UI elements:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"label"}]},{"type":"text","text":": It is used to describe the purpose of the input."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"placeholder"}]},{"type":"text","text":":  A prefix is not common and is discouraged in a Password Input component. In very specific cases, it can provide"},{"type":"text","text":" "},{"type":"text","text":"context or format requirements (e.g., “DEV-” for test accounts, “admin-” as a pattern to define an admin password)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"lock icon"}]},{"type":"text","text":": it helps to reinforce the security context."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Helper text"}]},{"type":"text","text":":  A supporting text conveys additional information about the password field."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Outlined style","type":"heading","anchor":"Outlined-style","level":2},{"inlineContent":[{"text":"By ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["   \/\/ An outlined text input","   OUDSPasswordInput(label: \"Your password\", password: $password, isOutlined: true)","","   \/\/ With a localizable from a bundle","   OUDSPasswordInput(LocalizedStringKey(\"password_label\"), bundle: Bundle.module, password: $password)"],"syntax":"swift"},{"text":"Rounded layout","type":"heading","anchor":"Rounded-layout","level":3},{"inlineContent":[{"text":"As the","type":"text"},{"code":" OUDSTextInput","type":"codeVoice"},{"text":", rounded corners can be enabled or disabled using the ","type":"text"},{"code":"hasRoundedTextInputs","type":"codeVoice"},{"text":" values of the ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration.","type":"text"}],"type":"paragraph"},{"text":"Status","type":"heading","anchor":"Status","level":2},{"inlineContent":[{"text":"As ","type":"text"},{"code":"OUDSPasswordInput","type":"codeVoice"},{"text":" is based on the","type":"text"},{"code":" OUDSTextInput","type":"codeVoice"},{"text":", all the status are the same and have the same behavior available here ","type":"text"},{"code":"OUDSTextInput.Status","type":"codeVoice"}],"type":"paragraph"},{"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations","level":2},{"inlineContent":[{"text":"By default no haptics are done by the component for the trailing action.","type":"text"},{"text":" ","type":"text"},{"text":"However you should think about cases wher you will have to make the devices vibrates.","type":"text"},{"text":" ","type":"text"},{"text":"You can refer to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Code samples","type":"heading","anchor":"Code-samples","level":2},{"type":"codeListing","code":["    \/\/ The password to display and edit","    @State var password: String = \"\"","","    \/\/ A basic password input with label","    OUDSPasswordInput(label: \"Password\", password: $password)","","    \/\/ Add a leading icon and helper text to more context","    OUDSPasswordInput(label: \"Password\", password: $password, lockIcon: true, helperText: \"Your password must be between 8 and 20 characters long.\")","","    \/\/ Password with prefix","    OUDSPasswordInput(label: \"Password\", password: $password, prefix: \"CORP-\")","","    \/\/ Make password visible","    OUDSPasswordInput(label: \"Password\", password: $password, isHiddenPassword: .constant(false))"],"syntax":"swift"},{"text":"Design documentation","type":"heading","anchor":"Design-documentation","level":2},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-password-input"}],"type":"paragraph"},{"text":"Themes rendering","type":"heading","anchor":"Themes-rendering","level":2},{"text":"Orange","type":"heading","anchor":"Orange","level":3},{"inlineContent":[{"type":"image","identifier":"component_passwordInput_Orange"}],"type":"paragraph"},{"text":"Orange Compact","type":"heading","anchor":"Orange-Compact","level":3},{"inlineContent":[{"type":"image","identifier":"component_passwordInput_OrangeCompact"}],"type":"parag