ext":"label","type":"text"}]},{"type":"text","text":": It is used to describe the purpose of the input."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"placeholder","type":"text"}]},{"type":"text","text":":  A prefix is not common and is discouraged in a Password Input component. In very specific cases, it can provide"},{"type":"text","text":" "},{"type":"text","text":"context or format requirements (e.g., “DEV-” for test accounts, “admin-” as a pattern to define an admin password)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"lock icon","type":"text"}]},{"type":"text","text":": it helps to reinforce the security context."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper text","type":"text"}]},{"type":"text","text":":  A supporting text conveys additional information about the password field."}],"type":"paragraph"}]}]},{"level":2,"text":"Outlined style","type":"heading","anchor":"Outlined-style"},{"inlineContent":[{"text":"By ","type":"text"},{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look.","type":"text"}],"type":"paragraph"},{"code":["   \/\/ An outlined text input","   OUDSPasswordInput(label: \"Your password\", password: $password, isOutlined: true)","","   \/\/ With a localizable from a bundle","   OUDSPasswordInput(LocalizedStringKey(\"password_label\"), bundle: Bundle.module, password: $password)"],"type":"codeListing","syntax":"swift"},{"level":3,"text":"Rounded layout","type":"heading","anchor":"Rounded-layout"},{"inlineContent":[{"text":"As the","type":"text"},{"type":"codeVoice","code":" OUDSTextInput"},{"text":", rounded corners can be enabled or disabled using the ","type":"text"},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"text":" values of the "