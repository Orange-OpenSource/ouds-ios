{"kind":"symbol","topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPasswordInput\/init(_:tableName:bundle:password:isHiddenPassword:placeholder:prefix:lockIcon:helperText:isOutlined:constrainedMaxWidth:status:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPasswordInput\/init(label:password:isHiddenPassword:placeholder:prefix:lockIcon:helperText:isOutlined:constrainedMaxWidth:status:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPasswordInput\/body"],"generated":true,"anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPasswordInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPasswordInput\/View-Implementations"],"generated":true,"anchor":"Default-Implementations"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPasswordInput","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSPasswordInput","kind":"identifier"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"text":"Layout","type":"heading","level":2,"anchor":"Layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Passwords input is based on several configurable UI elements:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"label","type":"text"}]},{"type":"text","text":": It is used to describe the purpose of the input."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"placeholder","type":"text"}]},{"type":"text","text":":  A prefix is not common and is discouraged in a Password Input component. In very specific cases, it can provide"},{"type":"text","text":" "},{"type":"text","text":"context or format requirements (e.g., “DEV-” for test accounts, “admin-” as a pattern to define an admin password)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"lock icon","type":"text"}]},{"type":"text","text":": it helps to reinforce the security context."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper text","type":"text"}]},{"type":"text","text":":  A supporting text conveys additional information about the password field."}]}]}]},{"text":"Outlined style","type":"heading","level":2,"anchor":"Outlined-style"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By "},{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look."}]},{"type":"codeListing","syntax":"swift","code":["   \/\/ An outlined text input","   OUDSPasswordInput(label: \"Your password\", password: $password, isOutlined: true)","","   \/\/ With a localizable from a bundle","   OUDSPasswordInput(LocalizedStringKey(\"password_label\"), bundle: Bundle.module, password: $password)"]},{"text":"Rounded layout","type":"heading","level":3,"anchor":"Rounded-layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As the"},{"type":"codeVoice","code":" OUDSTextInput"},{"type":"text","text":", rounded corners can be enabled or disabled using the "},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration."}]},{"text":"Status","type":"heading","level":2,"anchor":"Status"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As "},{"type":"codeVoice","code":"OUDSPasswordInput"},{"type":"text","text":" is based on the"},{"type":"codeVoice","code":" OUDSTextInput"},{"type":"text","text":", all the status are the same and have the same behavior available here "},{"type":"codeVoice","code":"OUDSTextInput.Status"}]},{"text":"Accessibility considerations","type":"heading","level":2,"anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default no haptics are done by the component for the trailing action."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases wher you will have to make the devices vibrates."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","isActive":true},{"type":"text","text":"."}]},{"text":"Code samples","type":"heading","level":2,"anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ The password to display and edit","    @State var password: String = \"\"","","    \/\/ A basic password input with label","    OUDSPasswordInput(label: \"Password\", password: $password)","","    \/\/ Add a leading icon and helper text to more context","    OUDSPasswordInput(label: \"Password\", password: $password, lockIcon: true, helperText: \"Your password must be between 8 and 20 characters long.\")","","    \/\/ Password with prefix","    OUDSPasswordInput(label: \"Password\", password: $password, prefix: \"CORP-\")","","    \/\/ Make password visible","    OUDSPasswordInput(label: \"Password\", password: $password, isHiddenPassword: .constant(false))"]},{"te