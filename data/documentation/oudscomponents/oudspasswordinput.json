":"text","text":": it helps to reinforce the security context."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Helper text"}]},{"type":"text","text":":  A supporting text conveys additional information about the password field."}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Outlined style","anchor":"Outlined-style"},{"type":"paragraph","inlineContent":[{"text":"By ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look.","type":"text"}]},{"code":["   \/\/ An outlined text input","   OUDSPasswordInput(label: \"Your password\", password: $password, isOutlined: true)","","   \/\/ With a localizable from a bundle","   OUDSPasswordInput(LocalizedStringKey(\"password_label\"), bundle: Bundle.module, password: $password)"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"Rounded layout","anchor":"Rounded-layout"},{"type":"paragraph","inlineContent":[{"text":"As the","type":"text"},{"type":"codeVoice","code":" OUDSTextInput"},{"text":", rounded corners can be enabled or disabled using the ","type":"text"},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"text":" values of the ","type":"text"},{"type":"codeVoice","code":"Tuning"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration.","type":"text"}]},{"level":2,"type":"heading","text":"Status","anchor":"Status"},{"type":"paragraph","inlineContent":[{"text":"As ","type":"text"},{"type":"codeVoice","code":"OUDSPasswordInput"},{"text":" is based on the","type":"text"},{"type":"codeVoice","code":" OUDSTextInput"},{"text":", all the status are the same and have the same behavior available here ","type":"text"},{"type":"codeVoice","code":"OUDSTextInput.Status"}]},{"level":2,"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"text":"By default no haptics are done by the component for the trailing action.","type":"text"},{"text":" ","type":"text"},{"text":"However you should think about cases wher you will have to make the devices vibrates.","type":"text"},{"text":" ","type":"text"},{"text":"You can refer to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},{"text":".","type":"text"}]},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"code":["    \/\/ The password to display and edit","    @State var password: String = \"\"","","    \/\/ A basic password input with label","    OUDSPasswordInput(label: \"Password\", password: $password)","","    \/\/ Add a leading icon and helper text to more context","    OUDSPasswordInput(label: \"Password\", password: $password, lockIcon: true, helperText: \"Your password must be between 8 and 20 characters long.\")","","    \/\/ Password with prefix","    OUDSPasswordInput(label: \"Password\", password: $password, prefix: \"CORP-\")","","    \/\/ Make password visible","    OUDSPasswordInput(label: \"Password\", password: $password, isHiddenPassword: .constant(false))"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-password-input","isActive":true,"type":"reference"}]},{"level":2,"type":"heading","anchor":"Themes-rendering","text":"Themes rendering"},{"level":3,"type":"heading","text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_passwordInput_Orange","type":"image"}]},{"type":"heading","text":"Orange Compact","level":3,"anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_passwordInput_OrangeCompact","type":"image"