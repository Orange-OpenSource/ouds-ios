{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"abstract":[{"text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices.","type":"text"},{"text":" ","type":"text"},{"text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets.","type":"text"}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"role":"symbol","symbolKind":"struct","externalID":"s:14OUDSComponents16OUDSCheckboxItemV","modules":[{"name":"Components"}],"title":"OUDSCheckboxItem","roleHeading":"Structure","platforms":[{"introducedAt":"15.0","beta":false,"deprecated":false,"name":"iOS","unavailable":false},{"introducedAt":"13.0","beta":false,"deprecated":false,"name":"macOS","unavailable":false},{"introducedAt":"16.0","beta":false,"deprecated":false,"name":"tvOS","unavailable":false},{"introducedAt":"1.0","beta":false,"deprecated":false,"name":"visionOS","unavailable":false},{"introducedAt":"11.0","beta":false,"deprecated":false,"name":"watchOS","unavailable":false}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}]},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(_:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(_:tableName:bundle:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"text":"Layouts","anchor":"Layouts","type":"heading","level":2},{"inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"reversed"}],"type":"strong"},{"type":"text","text":": like the "},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}],"type":"paragraph"}]}]},{"text":"Indicator states","level":2,"type":"heading","anchor":"Indicator-states"},{"inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"selected","type":"text"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"If you are looking for a checkbox component with three states, use instead ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Particular cases","anchor":"Particular-cases","type":"heading","level":2},{"inlineContent":[{"text":"An ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In addition, the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations"},{"inlineContent":[{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}],"type":"paragraph"},{"text":"Forbidden by design","type":"heading","anchor":"Forbidden-by-design","level":2},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}],"type":"strong"}],"type":"paragraph"},{"text":"Code samples","anchor":"Code-samples","type":"heading","level":2},{"syntax":"swift","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","","    \/\/ Localizable from bundle can also be used","    OUDSCheckboxItem(LocalizedStringKey(\"agree_terms\"), bundle: Bundle.module, isOn: $isOn)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Bazinga!\", isOn: $isOn, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, a description and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     description: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     isError: true,","                     errorText: \"Something wrong\",","                     hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing"},{"inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(\"Cocorico !\",","                     isOn: $selection,","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"],"type":"codeListing"},{"text":"Suggestions","level":2,"type":"heading","anchor":"Suggestions"},{"inlineContent":[{"text":"According to the ","type":"text"},{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","type":"reference"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"the checkbox by default must be used in unselected state.","type":"text"}],"type":"paragraph"},{"text":"Design documentation","anchor":"Design-documentation","type":"heading","level":2},{"inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"overridingTitle":"unified-design-system.orange.com","overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}]}],"type":"paragraph"},{"text":"Themes rendering","anchor":"Themes-rendering","type":"heading","level":2},{"text":"Orange","anchor":"Orange","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Orange"}],"type":"paragraph"},{"text":"Orange Compact","anchor":"Orange-Compact","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_OrangeCompact"}],"type":"paragraph"},{"text":"Sosh","anchor":"Sosh","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Sosh"}],"type":"paragraph"},{"text":"Wireframe","anchor":"Wireframe","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_checkboxItem_Wireframe","type":"image"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"2.4.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"style":"note","name":"Version","type":"aside"},{"content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}],"style":"note","name":"Since","type":"aside"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/View-Implementations":{"type":"topic","url":"\/documentation\/oudscomponents\/oudscheckboxitem\/view-implementations","kind":"article","title":"View Implementations","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","abstract":[],"role":"collectionGroup"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem":{"url":"\/documentation\/oudscomponents\/oudscheckboxitem","abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"kind":"symbol","role":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"tex