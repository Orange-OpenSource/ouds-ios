aram"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"action","kind":"externalParam"},{"text":": (() -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":")?)","kind":"text"}],"title":"init(isOn:label:helper:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:action:)","abstract":[{"text":"Creates a checkbox with label and optional helper text, icon, divider.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudscheckboxitem\/init(ison:label:helper:icon:flipicon:isreversed:iserror:errortext:isreadonly:hasdivider:action:)","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"type":"topic","abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"controls","type":"text"}],"type":"strong"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"inputs","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"title":"Controls","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls","url":"\/documentation\/oudscomponents\/controls","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"kind":"article","role":"article"},"component_checkboxItem_Sosh":{"identifier":"component_checkboxItem_Sosh","alt":"A checkbox item component in light and dark mode with Sosh theme","variants":[{"url":"\/images\/OUDSComponents\/component_checkboxItem_Sosh.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxIndeterminate":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxIndeterminate"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","title":"OUDSCheckboxIndeterminate","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind"