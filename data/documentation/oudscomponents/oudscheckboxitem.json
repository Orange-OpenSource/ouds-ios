{"metadata":{"modules":[{"name":"Components"}],"platforms":[{"name":"iOS","unavailable":false,"beta":false,"deprecated":false,"introducedAt":"15.0"},{"name":"macOS","unavailable":false,"beta":false,"deprecated":false,"introducedAt":"13.0"},{"name":"tvOS","unavailable":false,"beta":false,"deprecated":false,"introducedAt":"16.0"},{"name":"visionOS","unavailable":false,"beta":false,"deprecated":false,"introducedAt":"1.0"},{"name":"watchOS","unavailable":false,"beta":false,"deprecated":false,"introducedAt":"11.0"}],"externalID":"s:14OUDSComponents16OUDSCheckboxItemV","role":"symbol","roleHeading":"Structure","symbolKind":"struct","title":"OUDSCheckboxItem","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxItem"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","interfaceLanguage":"swift"},"abstract":[{"text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices.","type":"text"},{"text":" ","type":"text"},{"text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OUDSCheckboxItem","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"anchor":"Layouts","level":2,"type":"heading","text":"Layouts"},{"inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"reversed","type":"text"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"text":" layout but with a trailing checkbox indicator and a leading optional image","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Indicator-states","level":2,"type":"heading","text":"Indicator states"},{"inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"unselected","type":"text"}],"type":"strong"},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"If you are looking for a checkbox component with three states, use instead ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Particular cases","level":2,"anchor":"Particular-cases","type":"heading"},{"inlineContent":[{"text":"An ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In addition, the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."}],"type":"paragraph"},{"inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}],"type":"paragraph"},{"text":"Accessibility considerations","type":"heading","level":2,"anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}]},{"level":2,"text":"Forbidden by design","anchor":"Forbidden-by-design","type":"heading"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}],"type":"strong"}],"type":"paragraph"},{"level":2,"text":"Code samples","anchor":"Code-samples","type":"heading"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","","    \/\/ Localizable from bundle can also be used","    OUDSCheckboxItem(LocalizedStringKey(\"agree_terms\"), bundle: Bundle.module, isOn: $isOn)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Bazinga!\", isOn: $isOn, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, a description and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     description: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     isError: true,","                     errorText: \"Something wrong\",","                     hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(\"Cocorico !\",","                     isOn: $selection,","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"]},{"level":2,"text":"Suggestions","anchor":"Suggestions","type":"heading"},{"inlineContent":[{"type":"text","text":"According to the "},{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}],"type":"paragraph"},{"level":2,"text":"Design documentation","anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitle":"unified-design-system.orange.com","overridingTitleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"isActive":true}],"type":"paragraph"},{"level":2,"text":"Themes rendering","anchor":"Themes-rendering","type":"heading"},{"level":3,"text":"Orange","anchor":"Orange","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Orange"}]},{"text":"Orange Compact","type":"heading","anchor":"Orange-Compact","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_checkboxItem_OrangeCompact","type":"image"}]},{"text":"Sosh","type":"heading","anchor":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Sosh"}]},{"text":"Wireframe","type":"heading","anchor":"Wireframe","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Wireframe"}]},{"type":"aside","style":"note","name":"Version","content":[{"inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}]}]}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"kind":"symbol","topicSections":[{"identifiers":