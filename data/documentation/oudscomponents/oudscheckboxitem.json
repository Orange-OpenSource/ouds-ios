"text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"isOn"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI7BindingV","text":"Binding"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"label"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"helper"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"icon"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI5ImageV","text":"Image"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"flipIcon"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"isReversed"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"isError"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"isReadOnly"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"hasDivider"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":")"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"kind":"symbol","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"type":"topic","role":"collection","url":"\/documentation\/oudscomponents","title":"OUDSComponents","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem":{"title":"OUDSCheckboxItem","role":"symbol","type":"topic","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxItem"}],"url":"\/documentation\/oudscomponents\/oudscheckboxitem","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"text":" proposes layouts to add in your views some checkboxes components with labels and icons.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a checkbox with only an indicator prefer instead ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"text":".","type":"text"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/body":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body","url":"\/documentation\/oudscomponents\/oudscheckboxitem\/body","type":"topic","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"abstract":[],"title":"body","kind":"symbol"},"doc://OUDSComponents/s8SendableP":{"identifier":"doc:\/\/OUDSComponents\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"doc://OUDSComponents/7SwiftUI4Vi