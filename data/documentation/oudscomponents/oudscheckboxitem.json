{"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true,"type":"reference"},{"text":" proposes layouts to add in your views some checkboxes components with labels and icons.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a checkbox with only an indicator prefer instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true,"type":"reference"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Layouts","type":"heading","anchor":"Layouts","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"reversed"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"text":" layout but with a trailing checkbox indicator and a leading optional image","type":"text"}]}]}]},{"text":"Indicator states","type":"heading","anchor":"Indicator-states","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"If you are looking for a checkbox component with three states, use instead ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","type":"reference"},{"text":".","type":"text"}]},{"text":"Particular cases","type":"heading","anchor":"Particular-cases","level":2},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}]},{"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait."}]},{"text":"Forbidden by design","type":"heading","anchor":"Forbidden-by-design","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}]},{"text":"Code samples","type":"heading","anchor":"Code-samples","level":2},{"syntax":"swift","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Bazinga!\", helper: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(isOn: $isOn,","                     label: \"We live in a fabled world\",","                     helper: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):"}]},{"syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(isOn: $selection,","                     labelText: \"Cocorico !\",","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"],"type":"codeListing"},{"text":"Design documentation","type":"heading","anchor":"Design-documentation","level":2},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","isActive":true}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}],"name":"Since"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"metadata":{"title":"OUDSCheckboxItem","modules":[{"name":"OUDSComponents"}],"externalID":"s:14OUDSComponents16OUDSCheckboxItemV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"role":"symbol","roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxItem"}],"symbolKind":"struct"},"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:label:helper:icon:flipIcon:isReversed:isError:isReadOnly:hasDivider:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"],"generated":true,"anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/OUDSComponents\/docum