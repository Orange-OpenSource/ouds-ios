{"abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"text":" proposes layouts to add in your views some checkboxes components with labels and icons.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a checkbox with only an indicator prefer instead ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"text":".","type":"text"}],"kind":"symbol","topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:label:helper:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:action:)"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"],"anchor":"Instance-Properties","generated":true},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"],"anchor":"Default-Implementations","generated":true}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"Components"}],"platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"15.0"},{"name":"macOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"15.0"},{"name":"tvOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"16.0"},{"name":"visionOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"1.0"},{"name":"watchOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"11.0"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxItem"}],"roleHeading":"Structure","symbolKind":"struct","title":"OUDSCheckboxItem","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"role":"symbol","externalID":"s:14OUDSComponents16OUDSCheckboxItemV"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"platforms":["macOS"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"text":"Layouts","anchor":"Layouts","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"reversed"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"text":" layout but with a trailing checkbox indicator and a leading optional image","type":"text"}]}]}],"type":"unorderedList"},{"text":"Indicator states","anchor":"Indicator-states","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"If you are looking for a checkbox component with three states, use instead "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Particular cases","anchor":"Particular-cases","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"An "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In addition, the "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}],"type":"paragraph"},{"text":"Accessibility considerations","anchor":"Accessibility-considerations","type":"heading","level":2},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands."}],"type":"paragraph"},{"text":"Forbidden by design","anchor":"Forbidden-by-design","type":"heading","level":2},{"inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}],"type":"strong"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}],"type":"strong"}],"type":"paragraph"},{"text":"Code samples","anchor":"Code-samples","type":"heading","level":2},{"code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Bazinga!\", helper: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(isOn: $isOn,","                     label: \"We live in a fabled world\",","                     helper: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItem(isOn: $isOn,","                     label: \"We live in a fabled world\",","                     isError: true,","                     errorText: \"Something wrong\",","                     hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(isOn: $selection,","                     labelText: \"Cocorico !\",","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"text":"Suggestions","anchor":"Suggestions","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"According to the "},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox\/b\/6578e5\/t\/3dd013a529","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}],"type":"paragraph"},{"text":"Design documentation","anchor":"Design-documentation","type":"heading","level":2},{"inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","type":"reference","isActive":true}],"type":"paragraph"},{"text":"Themes rendering","anchor":"Themes-rendering","type":"heading","level":2},{"text":"Orange","anchor":"Orange","type":"heading","level":3},{"inlineContent":[{"identifier":"component_checkboxItem_Orange","type":"image"}],"type":"paragraph"},{"text":"Orange Business Tools","anchor":"Orange-Business-Tools","type":"heading","level":3},{"inlineContent":[{"identifier":"component_checkboxItem_OrangeBusinessTools","type":"image"}],"type":"paragraph"},{"text":"Sosh","anchor":"Sosh","type":"heading","level":3},{"inlineContent":[{"identifier":"component_checkboxItem_Sosh","type":"image"}],"type":"paragraph"},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":3},{"inlineContent":[{"identifier":"component_checkboxItem_Wireframe","type":"image"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"2.3.0 (Figma component design version)"}],"type":"paragraph"}],"style":"note","name":"Version","type":"aside"},{"content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}],"style":"note","name":"Since","type":"aside"}],"kind":"content"}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"references":{"https://unified-design-system.orange.com/472794e18/p/23f1c1-checkbox":{"type":"link","title":"unified-design-system.orange.com","url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}]},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"role":"article","abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"controls"}]},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"inputs"}]},{"text":".","type":"text"}],"url":"\/documentation\/oudscomponents\/controls","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"title":"Controls","type":"topic","kind":"article"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/View-Implementations":{"url":"\/documentation\/oudscomponents\/oudscheckboxitem\/view-implementatio