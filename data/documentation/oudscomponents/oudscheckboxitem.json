{"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSCheckboxItem","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"platforms":[{"introducedAt":"15.0","unavailable":false,"name":"iOS","beta":false,"deprecated":false},{"introducedAt":"13.0","unavailable":false,"beta":false,"deprecated":false,"name":"macOS"},{"introducedAt":"16.0","unavailable":false,"name":"tvOS","beta":false,"deprecated":false},{"introducedAt":"1.0","unavailable":false,"beta":false,"deprecated":false,"name":"visionOS"},{"introducedAt":"11.0","unavailable":false,"beta":false,"deprecated":false,"name":"watchOS"}],"roleHeading":"Structure","title":"OUDSCheckboxItem","modules":[{"name":"Components"}],"role":"symbol","symbolKind":"struct","externalID":"s:14OUDSComponents16OUDSCheckboxItemV"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(_:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(_:tableName:bundle:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:label:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"]},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSCheckboxItem"}],"languages":["swift"],"platforms":["macOS"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"anchor":"Layouts","level":2,"type":"heading","text":"Layouts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"reversed"}]},{"text":": like the ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Indicator-states","level":2,"type":"heading","text":"Indicator states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"If you are looking for a checkbox component with three states, use instead "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Particular-cases","type":"heading","text":"Particular cases"},{"inlineContent":[{"type":"text","text":"An "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In addition, the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as disabled."}]},{"inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"type":"text","text":" "},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"type":"text","text":" "},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"type":"text","text":" "},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands."}],"type":"paragraph"},{"anchor":"Forbidden-by-design","type":"heading","text":"Forbidden by design","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}],"type":"strong"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}],"type":"strong"}]},{"level":2,"type":"heading","anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","","    \/\/ Localizable from bundle can also be used","    OUDSCheckboxItem(LocalizedStringKey(\"agree_terms\"), bundle: Bundle.module, isOn: $isOn)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Bazinga!\", isOn: $isOn, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, a description and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     description: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     isError: true,","                     errorText: \"Something wrong\",","                     hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(\"Cocorico !\",","                     isOn: $selection,","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"]},{"level":2,"anchor":"Suggestions","type":"heading","text":"Suggestions"},{"inlineContent":[{"text":"According to the ","type":"text"},{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"type":"reference"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"the checkbox by default must be used in unselected state.","type":"text"}],"type":"paragraph"},{"text":"Design documentation","level":2,"type":"heading","anchor":"Design-documentation"},{"inlineContent":[{"isActive":true,"overridingTitle":"unified-design-system.orange.com","overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox"}],"type":"paragraph"},{"anchor":"Themes-rendering","level":2,"type":"heading","text":"Themes rendering"},{"anchor":"Orange","level":3,"type":"heading","text":"Orange"},{"inlineContent":[{"identifier":"component_checkboxItem_Orange","type":"image"}],"type":"paragraph"},{"anchor":"Orange-Compact","level":3,"type":"heading","text":"Orange Compact"},{"inlineContent":[{"identifier":"component_checkboxItem_OrangeCompact","type":"image"}],"type":"paragraph"},{"anchor":"Sosh","level":3,"type":"heading","text":"Sosh"},{"inlineContent":[{"identifier":"component_checkboxItem_Sosh","type":"image"}],"type":"paragraph"},{"anchor":"Wireframe","level":3,"type":"heading","text":"Wireframe"},{"inlineContent":[{"identifier":"component_checkboxItem_Wireframe","type":"image"}],"type":"paragraph"},{"name":"Version","content":[{"inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}],"type":"paragraph"}],"type":"aside","style":"note"},{"name":"Since","content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"}],"kind":"content"}],"kind":"symbol","abstract":[{"text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem":{"url":"\/documentation\/oudscomponents\/oudscheckboxitem","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxItem"}],"title":"OUDSCheckboxItem","abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"text":" ","type":"text"},{"text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","role":"symbol","type":"topic","kind":"symbol"},"doc://OUDSComponents/7SwiftUI4ViewP":