{"metadata":{"platforms":[{"name":"iOS","deprecated":false,"beta":false,"unavailable":false,"introducedAt":"15.0"},{"deprecated":false,"name":"macOS","beta":false,"introducedAt":"13.0","unavailable":false},{"unavailable":false,"name":"tvOS","introducedAt":"16.0","beta":false,"deprecated":false},{"deprecated":false,"name":"visionOS","beta":false,"introducedAt":"1.0","unavailable":false},{"deprecated":false,"introducedAt":"11.0","unavailable":false,"beta":false,"name":"watchOS"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxItem"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"title":"OUDSCheckboxItem","symbolKind":"struct","roleHeading":"Structure","externalID":"s:14OUDSComponents16OUDSCheckboxItemV","role":"symbol","modules":[{"name":"Components"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices.","type":"text"},{"text":" ","type":"text"},{"text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(_:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:label:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"anchor":"Initializers","title":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"text":"Layouts","level":2,"type":"heading","anchor":"Layouts"},{"inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"reversed","type":"text"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"text":" layout but with a trailing checkbox indicator and a leading optional image","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"text":"Indicator states","type":"heading","anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"unselected","type":"text"}],"type":"strong"},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"If you are looking for a checkbox component with three states, use instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"text":"Particular cases","anchor":"Particular-cases","level":2,"type":"heading"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In addition, the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands."}]},{"level":2,"text":"Forbidden by design","type":"heading","anchor":"Forbidden-by-design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"level":2,"text":"Code samples","type":"heading","anchor":"Code-samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Bazinga!\", isOn: $isOn, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, a description and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     description: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     isError: true,","                     errorText: \"Something wrong\",","                     hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(\"Cocorico !\",","                     isOn: $selection,","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"]},{"level":2,"text":"Suggestions","type":"heading","anchor":"Suggestions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the "},{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}]},{"anchor":"Design-documentation","type":"heading","level":2,"text":"Design documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"type":"reference","isActive":true,"overridingTitle":"unified-design-system.orange.com"}]},{"anchor":"Themes-rendering","type":"heading","level":2,"text":"Themes rendering"},{"anchor":"Orange","type":"heading","level":3,"text":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Orange"}]},{"anchor":"Orange-Compact","type":"heading","level":3,"text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_OrangeCompact"}]},{"anchor":"Sosh","type":"heading","level":3,"text":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Sosh"}]},{"type":"heading","level":3,"text":"Wireframe","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Wireframe"}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}]}],"name":"Version","style":"note"},{"type":"aside","content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}],"name":"Since","style":"note"}]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"url":"\/documentation\/oudscomponents\/controls","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"title":"Controls","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls","type":"topic","role":"article","kind":"article","abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"controls"}],"type":"strong"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"inputs"}],"type":"strong"},{"text":".","type":"text"}]},"ic_folder_categories.png":{"type":"image","identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"alt":null},"doc://OUDSComponents/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"component_checkboxItem_OrangeCompact":{"type":"image","alt":"A checkbox item component in light and dark modes with Orange Compact theme","identifier":"component_checkboxItem_OrangeCompact","variants":[