{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"platforms":["macOS"]}]},{"content":[{"level":2,"anchor":"Layouts","type":"heading","text":"Layouts"},{"inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"reversed"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Indicator-states","type":"heading","text":"Indicator states"},{"inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"If you are looking for a checkbox component with three states, use instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Particular-cases","type":"heading","text":"Particular cases"},{"inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}],"type":"paragraph"},{"level":2,"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait."}],"type":"paragraph"},{"level":2,"anchor":"Forbidden-by-design","type":"heading","text":"Forbidden by design"},{"inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}],"type":"strong"}],"type":"paragraph"},{"level":2,"anchor":"Code-samples","type":"heading","text":"Code samples"},{"code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Bazinga!\", helper: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(isOn: $isOn,","                     label: \"We live in a fabled world\",","                     helper: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):","type":"text"}],"type":"paragraph"},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(isOn: $selection,","                     labelText: \"Cocorico !\",","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Design-documentation","type":"heading","text":"Design documentation"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","isActive":true}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}],"style":"note","type":"aside","name":"Since"}],"kind":"content"}],"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" proposes layouts to add in your views some checkboxes components with labels and icons."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with only an indicator prefer instead "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"type":"text","text":"."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"title":"OUDSCheckboxItem","externalID":"s:14OUDSComponents16OUDSCheckboxItemV","modules":[{"name":"OUDSComponents"}],"navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"roleHeading":"Structure","role":"symbol","symbolKind":"struct"},"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:label:helper:icon:flipIcon:isReversed:isError:isReadOnly:hasDivider:)"]},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"]},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"]}],"references":{"doc://OUDSComponents/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/OUDSComponents\/s8SendableP"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxIndeterminate":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","role":"symbol","type":"topic","title":"OUDSCheckboxIndeterminate","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate"},{"type":"text","text":" proposes layout to add in your views a lonely checkbox, without labels, texts nor icons components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with additional texts and icon, prefer instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":"."}],"navigatorTitle":[{"text":"OUDSCheckboxIndeterminate","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudscheckboxindeterminate","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxIndeterminate","kind":"identifier"}]},"https://unified-design-system.orange.com/472794e18/p/23f1c1-checkbox":{"titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"type":"link","title":"unified-design-system.orange.com","url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox"},"doc://OUDSComponents/7SwiftUI4ViewP":{"type":"unresolvable","title":"SwiftUICore.View","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckbox":{"role":"symbol","kind":"symbol","title":"OUDSCheckbox","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","url":"\/documentation\/oudscomponents\/oudscheckbox","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckbox"}],"abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","type":"reference"},{"text":" proposes layout to add in your views a lonely checkbox, without labels, texts nor icons components.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a checkbox with additional texts and icon, prefer instead ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":".","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSCheckbox"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/View-Implementations":{"url":"\/documentation\/oudscomponents\/oudscheckboxitem\/view-implementations","abstract":[],"role":"collectionGroup","title":"View Implementations","type":"topic","kind":"article","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"},"doc://OUDSComponents/documentation/OUDSComponents":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","url":"\/documentation\/oudscomponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"title":"OUDSComponents","type":"topic","role":"collection","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/init(isOn:label:helper:icon:flipIcon:i