{"kind":"symbol","sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices.","type":"text"},{"text":" ","type":"text"},{"text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"text":"Layouts","level":2,"type":"heading","anchor":"Layouts"},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"reversed"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}],"type":"paragraph"}]}]},{"text":"Indicator states","level":2,"type":"heading","anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"unselected"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"If you are looking for a checkbox component with three states, use instead ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","type":"reference"},{"text":".","type":"text"}]},{"text":"Particular cases","level":2,"type":"heading","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In addition, the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}]},{"text":"Rich text","level":2,"type":"heading","anchor":"Rich-text"},{"type":"paragraph","inlineContent":[{"text":"Rich text can only be used for error messages.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Strong text can be used sparingly to highlight key information within the content.","type":"text"},{"text":" ","type":"text"},{"text":"No other text styles should be used.","type":"text"},{"text":" ","type":"text"},{"text":"Underlined text must not be applied manually (e.g. in error message), as it is commonly associated with hyperlinks and may mislead users.","type":"text"}]},{"text":"Accessibility considerations","level":2,"type":"heading","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"text":"Always check the results of rich text mode with high contrast, light and dark modes, and Voice Over vocalization.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}]},{"text":"Forbidden by design","level":2,"type":"heading","anchor":"Forbidden-by-design"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}],"type":"strong"}]},{"text":"Code samples","level":2,"type":"heading","anchor":"Code-samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","","    \/\/ Localizable from bundle can also be used","    OUDSCheckboxItem(LocalizedStringKey(\"agree_terms\"), bundle: Bundle.module, isOn: $isOn)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Bazinga!\", isOn: $isOn, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, a description and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     description: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItem(\"We live in a fabled world\",","                     isOn: $isOn,","                     isError: true,","                     errorText: \"Something wrong\",","                     hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(\"Hello world\", isOn: $isOn, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(\"Cocorico !\",","                     isOn: $selection,","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"]},{"anchor":"Suggestions","text":"Suggestions","level":2,"type":"heading"},{"inlineContent":[{"text":"According to the ","type":"text"},{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","type":"reference","isActive":true},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"the checkbox by default must be used in unselected state.","type":"text"}],"type":"paragraph"},{"anchor":"Design-documentation","type":"heading","level":2,"text":"Design documentation"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitle":"unified-design-system.orange.com","overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"type":"reference","isActive":true}],"type":"paragraph"},{"anchor":"Themes-rendering","text":"Themes rendering","level":2,"type":"heading"},{"anchor":"Orange","text":"Orange","level":3,"type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Orange"}],"type":"paragraph"},{"anchor":"Orange-Compact","type":"heading","level":3,"text":"Orange Compact"},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_OrangeCompact"}],"type":"paragraph"},{"text":"Sosh","level":3,"type":"heading","anchor":"Sosh"},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Sosh"}],"type":"paragraph"},{"text":"Wireframe","level":3,"type":"heading","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Wireframe"}]},{"content":[{"inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Version"},{"content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(_:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action: