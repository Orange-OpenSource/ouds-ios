:[{"type":"text","text":"Creates a checkbox with label and optional helper text, icon, divider."}],"kind":"symbol","type":"topic","url":"\/documentation\/oudscomponents\/oudscheckboxitem\/init(ison:label:helper:icon:flipicon:isreversed:iserror:isreadonly:hasdivider:)"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxIndeterminate":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxIndeterminate","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","title":"OUDSCheckboxIndeterminate","url":"\/documentation\/oudscomponents\/oudscheckboxindeterminate","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","type":"reference","isActive":true},{"type":"text","text":" proposes layout to add in your views a lonely checkbox, without labels, texts nor icons components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with additional texts and icon, prefer instead "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"type":"text","text":"."}],"navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxIndeterminate"}],"type":"topic","kind":"symbol","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItemIndeterminate":{"kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxItemIndeterminate"}],"type":"topic","title":"OUDSCheckboxItemIndeterminate","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItemIndeterminate"}],"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},{"type":"text","text":" proposes layouts to add in your views some checkboxes components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with only an indicator prefer instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate"},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/oudscheckboxitemindeterminate","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/View-Implementations":{"role":"collectionGroup","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","url":"\/documentation\/oudscomponents\/oudscheckboxitem\/view-implementations","type":"topic","kind":"article","abstract":[],"title":"View Implementations"},"https://unified-design-system.orange.com/472794e18/p/23f1c1-checkbox":{"titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"type":"link","title":"unified-design-system.orange.com","url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckbox":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSCheckbox","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudscheckbox","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","type":"reference","isActive":true},{"type":"text","text":" proposes layout to add in your views a lonely checkbox, without labels, texts nor icons components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with additional texts and icon, prefer instead "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChe