{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" proposes layouts to add in your views some checkboxes components with labels and icons.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a checkbox with only an indicator prefer instead ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","type":"reference"},{"text":".","type":"text"}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:label:helper:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:action:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"]},{"title":"Default Implementations","anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"level":2,"text":"Layouts","type":"heading","anchor":"Layouts"},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"reversed"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}]}]}],"type":"unorderedList"},{"level":2,"text":"Indicator states","type":"heading","anchor":"Indicator-states"},{"inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"unselected"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you are looking for a checkbox component with three states, use instead "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true},{"type":"text","text":"."}]},{"type":"heading","anchor":"Particular-cases","text":"Particular cases","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, the "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}]},{"text":"Accessibility considerations","anchor":"Accessibility-considerations","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands."}]},{"text":"Forbidden by design","anchor":"Forbidden-by-design","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"text":"Code samples","anchor":"Code-samples","type":"heading","level":2},{"type":"codeListing","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Bazinga!\", helper: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(isOn: $isOn,","                     label: \"We live in a fabled world\",","                     helper: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItem(isOn: $isOn,","                     label: \"We live in a fabled world\",","                     isError: true,","                     errorText: \"Something wrong\",","                     hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(isOn: $selection,","                     labelText: \"Cocorico !\",","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"text":"Suggestions","anchor":"Suggestions","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"According to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox\/b\/6578e5\/t\/3dd013a529"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the checkbox by default must be used in unselected state.","type":"text"}]},{"text":"Design documentation","anchor":"Design-documentation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","isActive":true}]},{"anchor":"Themes-rendering","type":"heading","level":2,"text":"Themes rendering"},{"anchor":"Orange","type":"heading","level":3,"text":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Orange"}],"type":"paragraph"},{"anchor":"Orange-Business-Tools","type":"heading","level":3,"text":"Orange Business Tools"},{"inlineContent":[{"identifier":"component_checkboxItem_OrangeBusinessTools","type":"image"}],"type":"paragraph"},{"text":"Sosh","anchor":"Sosh","type":"heading","level":3},{"inlineContent":[{"identifier":"component_checkboxItem_Sosh","type":"image"}],"type":"paragraph"},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":3},{"inlineContent":[{"identifier":"component_checkboxItem_Wireframe","type":"image"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"2.3.0 (Figma component design version)","type":"text"}]}],"style":"note","type":"aside","name":"Version"},{"style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}],"type":"aside"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"metadata":{"roleHeading":"Structure","modules":[{"name":"Components"}],"navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"title":"OUDSCheckboxItem","platforms":[{"introducedAt":"15.0","beta":false,"deprecated":false,"unavailable":false,"name":"iOS"},{"introducedAt":"15.0","beta":false,"deprecated":false,"unavailable":false,"name":"macOS"},{"introducedAt":"16.0","beta":false,"deprecated":false,"unavailable":false,"name":"tvOS"},{"introducedAt":"1.0","beta":false,"deprecated":false,"unavailable":false,"name":"visionOS"},{"introducedAt":"11.0","beta":false,"deprecated":false,"unavailable":false,"name":"watchOS"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"externalID":"s:14OUDSComponents16OUDSCheckboxItemV","role":"symbol","symbolKind":"struct"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSComponents/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"type":"image"},"https://unified-design-system.orange.com/472794e18/p/23f1c1-checkbox/b/6578e5/t/3dd013a529":{"titleInlineContent":[{"type":"text","text":"documentation"}],"url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox\/b\/6578e5\/t\/3dd013a529","type":"link","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox\/b\/6578e5\/t\/3dd013a529","title":"documentation"},"https://unified-design-system.orange.com/472794e18/p/23f1c1-checkbox":{"titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","type":"link","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","title":"unified-design-system.orange.com"},"doc://OUDSComponents/s8SendableP":{"identifi