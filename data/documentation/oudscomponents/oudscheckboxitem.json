"kind":"externalParam","text":"hasDivider"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":")"}],"abstract":[{"text":"Creates a checkbox with label and optional helper text, icon, divider.","type":"text"}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"kind":"symbol","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"type":"text","text":" proposes layouts to add in your views some checkboxes components with labels and icons."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with only an indicator prefer instead "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","type":"reference","isActive":true},{"type":"text","text":"."}],"role":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","title":"OUDSCheckboxItem","url":"\/documentation\/oudscomponents\/oudscheckboxitem","navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxItem"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/body":{"abstract":[],"url":"\/documentation\/oudscomponents\/oudscheckboxitem\/body","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier","text":"View"}],"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body","title":"body"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItemIndeterminate":{"kind":"s