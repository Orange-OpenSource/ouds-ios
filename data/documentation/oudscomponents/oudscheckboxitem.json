{"kind":"symbol","variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"text":" proposes layouts to add in your views some checkboxes components with labels and icons.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a checkbox with only an indicator prefer instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","type":"reference","isActive":true},{"text":".","type":"text"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"modules":[{"name":"Components"}],"title":"OUDSCheckboxItem","externalID":"s:14OUDSComponents16OUDSCheckboxItemV","symbolKind":"struct","roleHeading":"Structure","platforms":[{"deprecated":false,"beta":false,"name":"iOS","introducedAt":"15.0","unavailable":false},{"deprecated":false,"beta":false,"name":"macOS","introducedAt":"15.0","unavailable":false},{"deprecated":false,"beta":false,"name":"tvOS","introducedAt":"16.0","unavailable":false},{"deprecated":false,"beta":false,"name":"visionOS","introducedAt":"1.0","unavailable":false},{"deprecated":false,"beta":false,"name":"watchOS","introducedAt":"11.0","unavailable":false}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxItem"}]},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:label:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"],"generated":true,"anchor":"Instance-Properties"},{"anchor":"Default-Implementations","generated":true,"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"]}],"sections":[],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"content":[{"level":2,"text":"Layouts","type":"heading","anchor":"Layouts"},{"inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"reversed"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Indicator states","type":"heading","anchor":"Indicator-states"},{"inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"unselected","type":"text"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"If you are looking for a checkbox component with three states, use instead ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Particular cases","level":2,"anchor":"Particular-cases","type":"heading"},{"inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In addition, the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations","type":"heading"},{"inlineContent":[{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Forbidden by design","anchor":"Forbidden-by-design","type":"heading"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}],"type":"strong"}],"type":"paragraph"},{"text":"Code samples","level":2,"anchor":"Code-samples","type":"heading"},{"syntax":"swift","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Bazinga!\", description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, a description and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItem(isOn: $isOn,","                     label: \"We live in a fabled world\",","                     description: \"Of dreaming boys and wide-eyed girls\",","                     isReversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItem(isOn: $isOn,","                     label: \"We live in a fabled world\",","                     isError: true,","                     errorText: \"Something wrong\",","                     hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(isOn: $isOn, label: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing"},{"inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItem(isOn: $selection,","                     label: \"Cocorico !\",","                     icon: Image(systemName: \"figure.handball\"),","                     flipIcon: layoutDirection == .rightToLeft,","                     isInversed: layoutDirection == .rightToLeft)"],"type":"codeListing"},{"text":"Suggestions","level":2,"anchor":"Suggestions","type":"heading"},{"inlineContent":[{"text":"According to the ","type":"text"},{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the checkbox by default must be used in unselected state.","type":"text"}],"type":"paragraph"},{"text":"Design documentation","level":2,"anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"overridingTitle":"unified-design-system.orange.com","type":"reference"}],"type":"paragraph"},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"text":"Orange","level":3,"anchor":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_checkboxItem_Orange","type":"image"}],"type":"paragraph"},{"text":"Orange Business Tools","level":3,"anchor":"Orange-Business-Tools","type":"heading"},{"inlineContent":[{"identifier":"component_checkboxItem_OrangeBusinessTools","type":"image"}],"type":"paragraph"},{"text":"Sosh","level":3,"anchor":"Sosh","type":"heading"},{"inlineContent":[{"identifier":"component_checkboxItem_Sosh","type":"image"}],"type":"paragraph"},{"text":"Wireframe","level":3,"anchor":"Wireframe","type":"heading"},{"inlineContent":[{"identifier":"component_checkboxItem_Wireframe","type":"image"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"2.4.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"name":"Version","style":"note","type":"aside"},{"content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}],"name":"Since","style":"note","type":"aside"}],"kind":"content"}],"references":{"component_checkboxItem_OrangeBusinessTools":{"alt":"A checkbox item component in light and dark modes with Orange Business Tools theme","variants":[{"url":"\/images\/OUDSComponents\/component_checkboxItem_OrangeBusinessTools.png","traits":["1x","light"]}],"identifier":"component_checkboxItem_OrangeBusinessTools","type":"image"},"component_checkboxItem_Orange":{"alt":"A checkbox item component in light and dark modes with Orange theme","variants":[{"url":"\/images\/OUDSComponents\/component_checkboxItem_Orange.png","traits":["1x","light"]}],"identifier":"component_checkboxItem_Orange","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/init(isOn:label:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)":{"title":"init(isOn:label:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","kind":"symbol","abstract":[{"text":"Creates a checkbox with label and optional helper text, icon, divider.","type":"text"}],"url":"\/documentation\/oudscomponent