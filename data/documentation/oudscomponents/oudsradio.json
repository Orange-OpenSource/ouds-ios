{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"type":"text","text":"Radio button is a UI element that allows to select a single option from a set of mutually exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Radio button that does not show icon or text, provides greater flexibility when creating other components that require a Radio button to be displayed."}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/oudscomponents\/oudsradio"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio\/init(isOn:accessibilityLabel:isError:isReadOnly:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio\/init(isOn:accessibilityLabel:tableName:bundle:isError:isReadOnly:)"],"anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio\/body"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio\/View-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadio","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"type":"heading","text":"Particular cases","level":2,"anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."}]},{"level":2,"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also the component must be instanciated with a string parameter used as accessibility label."},{"type":"text","text":" "},{"type":"text","text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by "},{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for radio."},{"type":"text","text":" "},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}]},{"type":"heading","text":"Cases forbidden by design","level":2,"anchor":"Cases-forbidden-by-design"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error or read only situation and a disabled component."}]}],"type":"paragraph"},{"anchor":"Code-samples","text":"Code samples","level":2,"type":"heading"},{"syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A simple radio, no error, not in read only mode","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple radio, but is an error context","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true)","","    \/\/ Never disable an error-related radio button as it will crash","    \/\/ This is forbidden by design!","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true).disabled(true) \/\/ fatal error"],"type":"codeListing"},{"anchor":"Design-documentation","text":"Design documentation","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-radio-button","isActive":true}]},{"level":2,"type":"heading","text":"Themes rendering","anchor":"Themes-rendering"},{"anchor":"Orange","type":"heading","level":3,"text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_radio_Orange","type":"image"}]},{"level":3,"type":"heading","text":"Orange Compact","anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radio_OrangeCompact"}]},{"level":3,"type":"heading","text":"Sosh","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radio_Sosh"}]},{"anchor":"Wireframe","type":"heading","level":3,"text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_radio_Wireframe","type":"image"}]},{"type":"aside","style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}]}]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"metadata":{"role":"symbol","modules":[{"name":"Components"}],"symbolKind":"struct","title":"OUDS