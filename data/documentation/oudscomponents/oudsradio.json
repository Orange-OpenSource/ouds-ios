{"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","interfaceLanguage":"swift"},"metadata":{"platforms":[{"unavailable":false,"beta":false,"introducedAt":"15.0","name":"iOS","deprecated":false},{"unavailable":false,"beta":false,"introducedAt":"13.0","name":"macOS","deprecated":false},{"unavailable":false,"beta":false,"introducedAt":"16.0","name":"tvOS","deprecated":false},{"unavailable":false,"beta":false,"introducedAt":"1.0","name":"visionOS","deprecated":false},{"unavailable":false,"beta":false,"introducedAt":"11.0","name":"watchOS","deprecated":false}],"externalID":"s:14OUDSComponents9OUDSRadioV","title":"OUDSRadio","navigatorTitle":[{"text":"OUDSRadio","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadio","kind":"identifier"}],"symbolKind":"struct","roleHeading":"Structure","modules":[{"name":"Components"}],"role":"symbol"},"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"abstract":[{"text":"Radio button is a UI element that allows to select a single option from a set of mutually exclusive choices.","type":"text"},{"text":" ","type":"text"},{"text":"Radio button that does not show icon or text, provides greater flexibility when creating other components that require a Radio button to be displayed.","type":"text"}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSRadio"}],"platforms":["macOS"],"languages":["swift"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Particular-cases","text":"Particular cases"},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."}],"type":"paragraph"},{"type":"heading","anchor":"Accessibility-considerations","level":2,"text":"Accessibility considerations"},{"inlineContent":[{"type":"text","text":"Note also the component must be instanciated with a string parameter used as accessibility label."},{"type":"text","text":" "},{"type":"text","text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by "},{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for radio.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Cases-forbidden-by-design","level":2,"text":"Cases forbidden by design"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error or read only situation and a disabled component."}]}],"type":"paragraph"},{"type":"heading","anchor":"Code-samples","level":2,"text":"Code samples"},{"type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/