"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"}],"type":"paragraph"},{"anchor":"Code-samples","level":2,"text":"Code samples","type":"heading"},{"syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A simple radio, no error, not in read only mode","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple radio, but is an error context","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true)","","    \/\/ Never disable an error-related radio button as it will crash","    \/\/ This is forbidden by design!","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true).disabled(true) \/\/ fatal error"],"type":"codeListing"},{"anchor":"Design-documentation","level":2,"text":"Design documentation","type":"heading"},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button"}],"type":"paragraph"},{"name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"references":{"doc://OUDSComponents/s8SendableP":{"identifier":"doc:\/\/OUDSComponents\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"doc://OUDSComponents/documentation/OUDSComponents":{"kind":"symbol","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"type":"topic","role":"collection","url":"\/documentation\/oudscomponents","title":"OUDSComponents","identifier":"doc:\/\/OUDSComponents\/documentation\/O