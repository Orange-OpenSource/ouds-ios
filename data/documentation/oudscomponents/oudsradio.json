xt"},{"text":"No accessibility identifier is defined in OUDSThemesContract side as this value remains in the users hands.","type":"text"}]},{"type":"heading","text":"Cases forbidden by design","anchor":"Cases-forbidden-by-design","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]}]},{"type":"heading","text":"Code samples","anchor":"Code-samples","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A simple radio, no error, not in read only mode","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple radio, but is an error context","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true)","","    \/\/ Never disable an error-related radio button as it will crash","    \/\/ This is forbidden by design!","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true).disabled(true) \/\/ fatal error"]},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button","isActive":true,"type":"reference"}]},{"type":"heading","level":2,"text":"Themes rendering","anchor":"Themes-rendering"},{"type":"heading","level":3,"text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_radio_Orange","type":"image"}]},{"type":"heading","level":3,"text":"Orange Business Tools","anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radio_OrangeBusinessTools"}]},{"level":3,"text":"Sosh","type":"heading","anchor":"Sosh"},{"inlineContent":[{"type":"image","identifier":"component_radio_Sos