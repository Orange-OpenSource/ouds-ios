bility reasons. This label will be vocalized by ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for radio.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}]},{"text":"Cases forbidden by design","level":2,"anchor":"Cases-forbidden-by-design","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error or read only situation and a disabled component.","type":"text"}]}]},{"text":"Code samples","level":2,"anchor":"Code-samples","type":"heading"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A simple radio, no error, not in read only mode","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple radio, but is an error context","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true)","","    \/\/ Never disable an error-related radio button as it will crash","    \/\/ This is forbidden by design!","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true).disabled(true) \/\/ fatal error"]},{"text":"Design documentation","level":2,"type":"heading","anchor":"Design-documentation"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-radio-button","isActive":true}],"type":"paragraph"},{"anchor":"Themes-rendering","type":"heading","text":"Themes rendering","level":2},{"text":"Orange","level":3,"type":"heading","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_r