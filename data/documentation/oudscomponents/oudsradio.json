ystem does not allow to have both an error or read only situation and a disabled component.","type":"text"}],"type":"strong"}],"type":"paragraph"},{"anchor":"Code-samples","type":"heading","level":2,"text":"Code samples"},{"code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A simple radio, no error, not in read only mode","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple radio, but is an error context","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true)","","    \/\/ Never disable an error-related radio button as it will crash","    \/\/ This is forbidden by design!","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"anchor":"Design-documentation","level":2,"text":"Design documentation","type":"heading"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-radio-button"}],"type":"paragraph"},{"anchor":"Themes-rendering","type":"heading","level":2,"text":"Themes rendering"},{"anchor":"Orange","type":"heading","text":"Orange","level":3},{"inlineContent":[{"identifier":"component_radio_Orange","type":"image"}],"type":"paragraph"},{"anchor":"Orange-Business-Tools","type":"heading","level":3,"text":"Orange Business Tools"},{"inlineContent":[{"identifier":"component_radio_OrangeBusinessTools","type":"image"}],"type":"paragraph"},{"anchor":"Sosh","type":"heading","level":3,"text":"Sosh"},{"inlineContent":[{"type":"image","identifier":"component_radio_Sosh"}],"type":"paragraph"},{"anchor":"Wireframe","type":"heading","level":3,"text":"Wireframe"},{"inlineContent":[{"type":"image","identifier":"component_radio_Wireframe"}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"