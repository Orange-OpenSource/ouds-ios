{"sections":[],"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","type":"reference","isActive":true},{"text":" proposes layout to add in your views a lonely radio, without labels, texts nor icons radios components","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a radio with additional texts and icon, prefer instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"text":".","type":"text"}],"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio\/init(isOn:accessibilityLabel:isError:)"]},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio\/body"]},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio\/View-Implementations"]}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadio","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Particular cases","level":2,"anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","type":"reference","isActive":true},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look-and-feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"}]},{"type":"heading","text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also the component must be instanciated with a string parameter used as accessibility label."},{"type":"text","text":" "},{"type":"text","text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for radio."}]},{"type":"heading","text":"Cases forbidden by design","level":2,"anchor":"Cases-forbidden-by-design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]}]},{"type":"heading","text":"Code samples","level":2,"anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A simple radio, no error, not in read only mode","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple radio, but is an error context","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true)","","    \/\/ Never disable an error-related radio button as it will crash","    \/\/ This is forbidden by design!","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true).disabled(true) \/\/ fatal error"]},{"type":"heading","text":"Design documentation","level":2,"anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button","isActive":true,"type":"reference"}]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}],"name":"Since"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/oudscomponents\/oudsradio"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"symbolKind":"struct","role":"symbol","roleHeading":"Structure","navigatorTitle":[{"text":"OUDSRadio","kind":"identifier"}],"title":"OUDSRadio","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadio","kind":"identifier"}],"externalID":"s:14OUDSComponents9OUDSRadioV","modules":[{"name":"OUDSComponents"}]},"kind":"symbol","references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadio":{"type":"topic","title":"OUDSRadio","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio"},{"type":"text","text":" proposes layout to add in your views a lonely radio, without labels, texts nor icons radios components"},{"type":"text","text":" "},{"type":"text","text":"If you want to use a radio with additional texts and icon, prefer instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSCom