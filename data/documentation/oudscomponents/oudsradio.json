{"metadata":{"platforms":[{"unavailable":false,"introducedAt":"15.0","deprecated":false,"name":"iOS","beta":false},{"unavailable":false,"introducedAt":"13.0","deprecated":false,"name":"macOS","beta":false},{"unavailable":false,"introducedAt":"16.0","deprecated":false,"name":"tvOS","beta":false},{"unavailable":false,"introducedAt":"1.0","deprecated":false,"name":"visionOS","beta":false},{"unavailable":false,"introducedAt":"11.0","deprecated":false,"name":"watchOS","beta":false}],"role":"symbol","roleHeading":"Structure","title":"OUDSRadio","symbolKind":"struct","modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents9OUDSRadioV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadio"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSRadio"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadio","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Particular cases","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","isActive":true,"type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look-and-feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"}]},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for radio.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}]},{"type":"heading","level":2,"text":"Cases forbidden by design","anchor":"Cases-forbidden-by-design"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error or read only situation and a disabled component."}],"type":"strong"}]},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A simple radio, no error, not in read only mode","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple radio, but is an error context","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true)","","    \/\/ Never disable an error-related radio button as it will crash","    \/\/ This is forbidden by design!","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true).disabled(true) \/\/ fatal error"]},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-radi