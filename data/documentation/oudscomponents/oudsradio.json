{"kind":"symbol","metadata":{"modules":[{"name":"Components"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadio"}],"symbolKind":"struct","roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"OUDSRadio"}],"platforms":[{"unavailable":false,"beta":false,"introducedAt":"15.0","deprecated":false,"name":"iOS"},{"unavailable":false,"beta":false,"introducedAt":"13.0","deprecated":false,"name":"macOS"},{"unavailable":false,"beta":false,"introducedAt":"16.0","deprecated":false,"name":"tvOS"},{"unavailable":false,"beta":false,"introducedAt":"1.0","deprecated":false,"name":"visionOS"},{"unavailable":false,"beta":false,"introducedAt":"11.0","deprecated":false,"name":"watchOS"}],"role":"symbol","externalID":"s:14OUDSComponents9OUDSRadioV","title":"OUDSRadio"},"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadio","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Particular cases","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","isActive":true,"type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look-and-feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"}]},{"text":"Accessibility considerations","anchor":"Accessibility-considerations","level":2,"type":"heading"},{"inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for radio.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}],"type":"paragraph"},{"anchor":"Cases-forbidden-by-design","text":"Cases forbidden by design","level":2,"type":"heading"},{"inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error or read only situation and a disabled component.","type":"text"}],"type":"strong"}],"type":"paragraph"},{"anchor":"Code-samples","text":"Code samples","level":2,"type":"heading"},{"syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A simple radio, no error, not in read only mode","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple radio, but is an error context","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true)","","    \/\/ Never disable an error-related radio button as it will crash","    \/\/ This is forbidden by design!","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true).disabled(true) \/\/ fatal error"],"type":"codeListing"},{"anchor":"Design-documentation","text":"Design documentation","level":2,"type":"heading"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-radio-button","isActive":true,"type":"reference"}],"type":"paragraph"},{"anchor":"Themes-rendering","text":"Themes rendering","level":2,"type":"heading"},{"text":"Orange","anchor":"Orange","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_radio_Orange","type":"image"}],"type":"paragraph"},{"anchor":"Orange-Compact","text":"Orange Compact","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_radio_OrangeCompact","type":"image"}],"type":"paragraph"},{"anchor":"Sosh","text":"Sosh","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_radio_Sosh","type":"image"}],"type":"paragraph"},{"anchor":"Wireframe","text":"Wireframe","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_radio_Wireframe","type":"image"}],"type":"paragraph"},{"name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.4.0 (Figma component design version)"}]}],"style":"note","type":"aside"},{"style":"note","content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}],"name":"Since","type":"aside"}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsradio"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"type":"text","text":"Radio button is a UI element that allows to select a single option from a set of mutually exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Radio button that does not show icon or text, provides greater flexibility when creating other compo