 some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTabBar":{"url":"\/documentation\/oudscomponents\/oudstabbar","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","title":"OUDSTabBar","abstract":[{"type":"text","text":"The Tab bar is a system navigation component with a position which can vary depending to the OS."},{"type":"text","text":" "},{"type":"text","text":"The tab bar can be found at the bottom of the screen for iOS. It can vary for iPadOS."},{"text":" ","type":"text"},{"type":"text","text":"It allows users to switch between the sections of an app."},{"type":"text","text":" "},{"type":"text","text":"Each tab can be represented by a label, optionally paired with an icon, and maintains persistent visibility across top-level destinations."}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"OUDSTabBar","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTabBar","kind":"identifier"}],"type":"topic"}}}