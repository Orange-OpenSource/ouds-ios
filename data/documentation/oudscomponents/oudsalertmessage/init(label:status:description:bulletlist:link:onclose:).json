t":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Label displayed in the alert message. Main message that should be short, clear, and readable at a glance."}]}]},{"name":"status","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The status of the alert message. Its background color and its icon color are based on this status. There are two types of statuses (see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus"},{"type":"text","text":")"}]}]},{"name":"description","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional supplementary text in an alert message. Use only when additional detail or guidance is needed beyond the label. It should remain"},{"type":"text","text":" "},{"type":"text","text":"short, clear and scannable, helping the user to understand what happened and what he can do next."}]}]},{"name":"bulletList","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional list of bullet points to be displayed in the alert message following the label or the optional "},{"code":"description","type":"codeVoice"},{"type":"text","text":"."}]}]},{"name":"link","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional link to be displayed in the alert message. It can be used to trigger an action."}]}]},{"name":"onClose","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An optional callback invoked when the close button is clicked. If "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", the close button is not displayed and the alert message"},{"type":"text","text":" "},{"type":"text","text":"remains visible until the context changes (e.g., the issue is resolved, the screen is refreshed). Otherwise, the alert message is dismissable and"},{"type":"text","text":" "},{"type":"text","text":"includes a close button, allowing the user to dismiss it when he has acknowledged the message.  Some alerts must remain visible to ensure"},{"type":"text","text":" "},{"type":"text","text":"user is aware of important information; others can be closed to reduce visual clutter."}]}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Use the "},{"code":"View\/disabled(_:)","type":"codeVoice"},{"type":"text","text":" method to have component in disabled state."}],"type":"paragraph"},{"syntax":"swift","code":["    OUDSAlertMessage(label: \"Success! Your form was submitted.\", status: .positive)"],"type":"codeListing"}]}],"abstract":[{"text":"Creates a alert message.","type":"text"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsalertmessage\/init(label:status:description:bulletlist:link:onclose:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage\/init(label:status:description:bulletList:link:onClose:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage"]]},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertMessage/init(label:status:description:bulletList:link:onClose:)":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage\/init(label:status:description:bulletList:link:onClose:)","type":"topic","url":"\/documentation\/oudscomponents\/oudsalertmessage\/init(label:status:description:bulletlist:link:onclose:)","role":"symbol","title":"init(label:status:description:bulletList:link:onClose:)","abstract":[{"type":"text","text":"Creates a alert message."}],"kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"label"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"S