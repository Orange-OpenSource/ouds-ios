ragraph","inlineContent":[{"type":"text","text":"An optional callback invoked when the close button is clicked. If "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", the close button is not displayed and the alert message"},{"type":"text","text":" "},{"type":"text","text":"remains visible until the context changes (e.g., the issue is resolved, the screen is refreshed). Otherwise, the alert message is dismissable and"},{"type":"text","text":" "},{"type":"text","text":"includes a close button, allowing the user to dismiss it when he has acknowledged the message.  Some alerts must remain visible to ensure"},{"type":"text","text":" "},{"type":"text","text":"user is aware of important information; others can be closed to reduce visual clutter."}]}]}],"kind":"parameters"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"code":"View\/disabled(_:)","type":"codeVoice"},{"text":" method to have component in disabled state.","type":"text"}]},{"syntax":"swift","code":["    OUDSAlertMessage(label: \"Success! Your form was submitted.\", status: .positive)"],"type":"codeListing"}],"kind":"content"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertMessage/Link":{"type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage\/Link","role":"symbol","abstract":[{"type":"text","text":"Used to describe the link display in the "},{"type":"codeVoice","code":"OUDSAlertMessage"}],"title":"OUDSAlertMessage.Link","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Link","kind":"identifier"}],"navigatorTitle":[{"text":"Link","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsalertmessage\/link"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertMessage":{"title":"OUDSAlertMessage","url":"\/documentation\/oudscomponents\/oudsalertmessage","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertMessage","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSAlertMessage"}],"abstract":[{"type":"text","text":"Alert message is a UI element that displays system feedback, status changes or required action; throughout detailed, prominent, persistent and actionable"},{"type":"text","text":" "},{"type":"text","text":"communication. Alert message includes functional icon and semantic colour, and may include as well a close button and\/or action link."},{"type":"text","text":" "},{"type":"text","text":"Alert Message does not disappear automatically and remains visible until dismissed or resolved by the user."}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"title":"Components","role":"collection","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"type":"topic","url":"\/documentation\/oudscomponents","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSInlineAlert":{"navigatorTitle":[{"text":"OUDSInlineAlert","kind":"identifier"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSInlineAlert"}],"abstract":[{"text":"Inline alert is a lightweight UI element, placed in the content flow, that displays information, system feedback,","type":"text"},{"text":" ","type":"text"},{"text":"status changes throughout short, prominent, persistent and no