{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"metadata":{"modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents14OUDSBulletListV","roleHeading":"Structure","title":"OUDSBulletList","platforms":[{"name":"iOS","deprecated":false,"introducedAt":"15.0","unavailable":false,"beta":false},{"name":"macOS","introducedAt":"13.0","unavailable":false,"deprecated":false,"beta":false},{"name":"tvOS","deprecated":false,"introducedAt":"16.0","unavailable":false,"beta":false},{"name":"visionOS","deprecated":false,"introducedAt":"1.0","unavailable":false,"beta":false},{"name":"watchOS","deprecated":false,"introducedAt":"11.0","unavailable":false,"beta":false}],"role":"symbol","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSBulletList","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSBulletList","kind":"identifier"}]},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList","interfaceLanguage":"swift"},"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsbulletlist"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Bullet list is a UI element that helps to view in related individual text items grouped together; items usually starting with a number or a bullet.","type":"text"},{"text":" ","type":"text"},{"text":"Bullet list is also known as ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Unordered list"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Ordered list"}]},{"type":"text","text":" and is not an interactive element by default."}],"topicSections":[{"anchor":"Structures","generated":true,"title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Item"]},{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/init(type:textStyle:isBold:items:)"]},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/body"]},{"title":"Enumerations","generated":true,"anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/TextStyle","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Type","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedAsset"]},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay"]},{"content":[{"text":"Types","level":2,"anchor":"Types","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Three types are proposed:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Unordered (by default)","type":"text"}]},{"type":"text","text":": Collects related items that don’t need to be in a specific order or sequence."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Ordered","type":"text"}]},{"type":"text","text":": Collects related items with numeric order or sequence."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Bare","type":"text"}]},{"type":"text","text":": An unordered list without any bullets or alphanumeric sequence."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Types can be mixed in list, but must be identical for the same ","type":"text"},{"code":"OUDSBulletList.NestedLevel","type":"codeVoice"},{"text":".","type":"text"}]},{"text":"Levels","level":2,"anchor":"Levels","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Lists can include nested items to indicate hierarchy or subcategories, with indentation distinguishing each level.","type":"text"},{"text":" ","type":"text"},{"text":"Arrange ordered list items logically, such as ranking by importance, highest to lowest values, or in alphabetical \/ numeric order.","type":"text"},{"text":" ","type":"text"},{"text":"Three levels are maximum.","type":"text"}]},{"text":"Text Style","level":2,"anchor":"Text-Style","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"List can be used with different font sizes:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Body Large"}],"type":"strong"},{"type":"text","text":": If the text accompanying the list component is the Body Large text. This variant is designed for more visual, engaging experiences."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Body Medium"}],"type":"strong"},{"type":"text","text":": If the text accompanying the list component is the Body Medium text. This variant is best suited for functional, task-oriented experiences."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Cases forbidden by design","level":2,"anchor":"Cases-forbidden-by-design","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"it is not allowed to have a depth of items greater than 3","type":"text"}]}]},{"text":"Internationalisation considerations","level":2,"anchor":"Internationalisation-considerations","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"For latin-based speaking countries, like France, Spain, United Kingdom or Belgium, the european “arabic” numbers are used for the first level of depth","type":"text"},{"text":" ","type":"text"},{"text":"of the ordered bullet list. For the second and third levels, the european alphabets are used with upper and lower case values.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"However for countries speaking arabic, these rules can’t be applied. Indeed, there is no notion of upper and lower case characters in arabic alphabet.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the numbers in use (i.e. the european “arabic” numbers like “1, 2, 3”) are accepted in arabic countries, even if the “true arabic” numbers (like “ ٢ ٣ ١”) are used","type":"text"},{"text":" ","type":"text"},{"text":"in middle-east arabic countries and for official documents.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Thus the OUDS ordered bullet list will use “european” numbers for first level, and arabic alphabets for second and third levels."}]},{"text":"Code samples","level":2,"anchor":"Code-samples","type":"heading"},{"code":["       \/\/ 1. Unordered list with bullets","       OUDSBulletList {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 1.1. Item of Unordered list with bullet as tick, a text style","       \/\/ body medium and text bold","       OUDSBulletList(type: .unordered(asset: .tick),","                      textStyle: .bodyMedium,","                      isBold: true)  {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 2. Bare list with 3 items","       OUDSBulletList(type: .bare) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3. Ordered list with 3 items","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3.1. Ordered list with 3 items in first level,","       \/\/ and one item as sub item (second level),","       \/\/ and 2 items as sub item in (third level)","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\") {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ Same Bullet list but items in third level with free icon as bullet","       let icon = Image(decorative: \"ic_heart\")","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\", subListType: .unordered(asset: .icon(icon))) {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }"],"type":"codeListing","syntax":"swift"},{"text":"Rich text recommendations","level":2,"anchor":"Rich-text-recommendations","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Rich text can be applied for bullet list whatever the "},{"type":"codeVoice","code":"isBold"},{"type":"text","text":" flag is."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Strong text can be used sparingly within alert messages to highlight key information."},{"type":"text","text":" "},{"type":"text","text":"Underlined text must not be used for emphasis, as it is commonly associated with links."},{"type":"text","text":" "},{"type":"text","text":"Underlined links must be bold."},{"type":"text","text":" "},{"type":"text","text":"If a hyperlink is needed within the content, the underlined style should be used."},{"type":"text","text":" "},{"type":"text","text":"Italic should be used with care, some brands do not allow it like Orange brand."},{"type":"text","text":" "},{"type":"text","text":"No other text styles should be used."}]},{"text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always check the results of rich text mode with high contrast, light and dark modes, and Voice Over vocalization."}]},{"text":"Design documentation","level":2,"anchor":"Design-documentation","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-bullet-list","type":"reference","isActive":true}]},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"text":"Orange","level":3,"anchor":"Orange","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_Orange","type":"image"}]},{"text":"Orange Compact","level":3,"anchor":"Orange-Compact","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_OrangeCompact","type":"image"}]},{"text":"Sosh","level":3,"anchor":"Sosh","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_bullet_list_Sosh"}],"type":"paragraph"},{"text":"Wireframe"