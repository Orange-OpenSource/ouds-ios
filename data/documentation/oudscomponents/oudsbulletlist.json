{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"kind":"symbol","abstract":[{"text":"Bullet list is a UI element that helps to view in related individual text items grouped together; items usually starting with a number or a bullet.","type":"text"},{"text":" ","type":"text"},{"text":"Bullet list is also known as ","type":"text"},{"inlineContent":[{"type":"text","text":"Unordered list"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"text":"Ordered list","type":"text"}],"type":"emphasis"},{"text":" and is not an interactive element by default.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"platforms":[{"deprecated":false,"unavailable":false,"name":"iOS","beta":false,"introducedAt":"15.0"},{"deprecated":false,"unavailable":false,"name":"macOS","beta":false,"introducedAt":"13.0"},{"deprecated":false,"unavailable":false,"name":"tvOS","beta":false,"introducedAt":"16.0"},{"deprecated":false,"unavailable":false,"name":"visionOS","beta":false,"introducedAt":"1.0"},{"deprecated":false,"unavailable":false,"name":"watchOS","beta":false,"introducedAt":"11.0"}],"title":"OUDSBulletList","symbolKind":"struct","modules":[{"name":"Components"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSBulletList"}],"roleHeading":"Structure","role":"symbol","externalID":"s:14OUDSComponents14OUDSBulletListV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSBulletList"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList"},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Item"],"anchor":"Structures","generated":true,"title":"Structures"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/init(type:textStyle:isBold:items:)"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/body"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedIcon"],"anchor":"Type-Aliases","generated":true,"title":"Type Aliases"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/TextStyle","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Type","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedAsset"],"anchor":"Enumerations","generated":true,"title":"Enumerations"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSBulletList"}],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay"],"kind":"mentions"},{"content":[{"type":"heading","level":2,"text":"Types","anchor":"Types"},{"type":"paragraph","inlineContent":[{"text":"Three types are proposed:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Unordered (by default)","type":"text"}]},{"text":": Collects related items that don’t need to be in a specific order or sequence.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Ordered"}],"type":"strong"},{"type":"text","text":": Collects related items with numeric order or sequence."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Bare"}]},{"text":": An unordered list without any bullets or alphanumeric sequence.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Types can be mixed in list, but must be identical for the same ","type":"text"},{"code":"OUDSBulletList.NestedLevel","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"Levels","anchor":"Levels","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lists can include nested items to indicate hierarchy or subcategories, with indentation distinguishing each level."},{"type":"text","text":" "},{"text":"Arrange ordered list items logically, such as ranking by importance, highest to lowest values, or in alphabetical \/ numeric order.","type":"text"},{"text":" ","type":"text"},{"text":"Three levels are maximum.","type":"text"}]},{"anchor":"Text-Style","level":2,"text":"Text Style","type":"heading"},{"inlineContent":[{"type":"text","text":"List can be used with different font sizes:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Body Large"}]},{"type":"text","text":": If the text accompanying the list component is the Body Large text. This variant is designed for more visual, engaging experiences."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Body Medium","type":"text"}],"type":"strong"},{"type":"text","text":": If the text accompanying the list component is the Body Medium text. This variant is best suited for functional, task-oriented experiences."}]}]}],"type":"unorderedList"},{"text":"Cases forbidden by design","anchor":"Cases-forbidden-by-design","type":"heading","level":2},{"inlineContent":[{"inlineContent":[{"type":"text","text":"it is not allowed to have a depth of items greater than 3"}],"type":"strong"}],"type":"paragraph"},{"level":2,"text":"Internationalisation considerations","type":"heading","anchor":"Internationalisation-considerations"},{"inlineContent":[{"text":"For latin-based speaking countries, like France, Spain, United Kingdom or Belgium, the european “arabic” numbers are used for the first level of depth","type":"text"},{"type":"text","text":" "},{"text":"of the ordered bullet list. For the second and third levels, the european alphabets are used with upper and lower case values.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"However for countries speaking arabic, these rules can’t be applied. Indeed, there is no notion of upper and lower case characters in arabic alphabet."},{"type":"text","text":" "},{"type":"text","text":"In addition, the numbers in use (i.e. the european “arabic” numbers like “1, 2, 3”) are accepted in arabic countries, even if the “true arabic” numbers (like “ ٢ ٣ ١”) are used"},{"text":" ","type":"text"},{"text":"in middle-east arabic countries and for official documents.","type":"text"},{"text":" ","type":"text"},{"text":"Thus the OUDS ordered bullet list will use “european” numbers for first level, and arabic alphabets for second and third levels.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Code-samples","text":"Code samples"},{"syntax":"swift","type":"codeListing","code":["       \/\/ 1. Unordered list with bullets","       OUDSBulletList {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 1.1. Item of Unordered list with bullet as tick, a text style","       \/\/ body medium and text bold","       OUDSBulletList(type: .unordered(asset: .tick),","                      textStyle: .bodyMedium,","                      isBold: true)  {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 2. Bare list with 3 items","       OUDSBulletList(type: .bare) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3. Ordered list with 3 items","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3.1. Ordered list with 3 items in first level,","       \/\/ and one item as sub item (second level),","       \/\/ and 2 items as sub item in (third level)","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\") {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ Same Bullet list but items in third level with free icon as bullet","       let icon = Image(decorative: \"ic_heart\")","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\", subListType: .unordered(asset: .icon(icon))) {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }"]},{"level":2,"text":"Design documentation","type":"heading","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-bullet-list"}]},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"anchor":"Orange","type":"heading","level":3,"text":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_bullet_list_Orange"}]},{"anchor":"Orange-Compact","type":"heading","text":"Orange Compact","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_bullet_list_OrangeCompact"}]},{"level":3,"text":"Sosh","anchor":"Sosh","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_bullet_list_Sosh"}]},{"level":3,"text":"Wireframe","type":"heading","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_Wireframe","type":"image"}]},{"name":"Version","content":[{"type":"paragraph","inlineContent":[{"text":"1.0.0 (Figma component design version)","type":"text"}]}],"style":"note","type":"aside"},{"name":"Since","content":[{"inlineContent":[{"text":"1.2.0","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsbulletlist"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSBulletList/UnorderedAsset":{"title":"OUDSBulletList.UnorderedAsset","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnorderedAsset","kind":"identifier"}],"role":"symbol","url":"\/documentation\/oudscomponents\/oudsbulletlist\/unorderedasset","navigatorTitle":[{"text":"UnorderedAsset","kind":"identifier"}],"abstract":[{"text":"The type of asset in the unordered list","type":"text"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedAsset"},"doc://OUDSComponents/documentati