{"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}],"title":"OUDSBulletList","externalID":"s:14OUDSComponents14OUDSBulletListV","role":"symbol","navigatorTitle":[{"text":"OUDSBulletList","kind":"identifier"}],"modules":[{"name":"Components"}],"symbolKind":"struct","roleHeading":"Structure","platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"15.0"},{"name":"macOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"13.0"},{"name":"tvOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"16.0"},{"deprecated":false,"unavailable":false,"name":"visionOS","beta":false,"introducedAt":"1.0"},{"deprecated":false,"unavailable":false,"name":"watchOS","beta":false,"introducedAt":"11.0"}]},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList","interfaceLanguage":"swift"},"topicSections":[{"title":"Structures","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Item"],"anchor":"Structures"},{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/init(type:textStyle:isBold:items:)"]},{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/body"],"anchor":"Instance-Properties"},{"title":"Enumerations","anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/TextStyle","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Type","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedAsset"],"generated":true},{"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations"],"generated":true}],"abstract":[{"type":"text","text":"Bullet list is a UI element that helps to view in related individual text items grouped together; items usually starting with a number or a bullet."},{"type":"text","text":" "},{"type":"text","text":"Bullet list is also known as "},{"inlineContent":[{"text":"Unordered list","type":"text"}],"type":"emphasis"},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"text":"Ordered list","type":"text"}]},{"type":"text","text":" and is not an interactive element by default."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbulletlist"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay"]},{"content":[{"type":"heading","text":"Types","anchor":"Types","level":2},{"inlineContent":[{"text":"Three types are proposed:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Unordered (by default)","type":"text"}]},{"text":": Collects related items that don’t need to be in a specific order or sequence.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Ordered"}]},{"type":"text","text":": Collects related items with numeric order or sequence."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Bare"}]},{"type":"text","text":": An unordered list without any bullets or alphanumeric sequence."}]}]}]},{"inlineContent":[{"type":"text","text":"Types can be mixed in list, but must be identical for the same "},{"type":"codeVoice","code":"OUDSBulletList.NestedLevel"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Levels","type":"heading","anchor":"Levels","level":2},{"inlineContent":[{"text":"Lists can include nested items to indicate hierarchy or subcategories, with indentation distinguishing each level.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Arrange ordered list items logically, such as ranking by importance, highest to lowest values, or in alphabetical \/ numeric order."},{"text":" ","type":"text"},{"type":"text","text":"Three levels are maximum."}],"type":"paragraph"},{"anchor":"Text-Style","type":"heading","text":"Text Style","level":2},{"inlineContent":[{"text":"List can be used with different font sizes:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Body Large"}]},{"type":"text","text":": If the text accompanying the list component is the Body Large text. This variant is designed for more visual, engaging experiences."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Body Medium"}]},{"type":"text","text":": If the text accompanying the list component is the Body Medium text. This variant is best suited for functional, task-oriented experiences."}]}]}]},{"anchor":"Cases-forbidden-by-design","type":"heading","text":"Cases forbidden by design","level":2},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"it is not allowed to have a depth of items greater than 3"}]}],"type":"paragraph"},{"type":"heading","text":"Internationalisation considerations","level":2,"anchor":"Internationalisation-considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For latin-based speaking countries, like France, Spain, United Kingdom or Belgium, the european “arabic” numbers are used for the first level of depth"},{"type":"text","text":" "},{"type":"text","text":"of the ordered bullet list. For the second and third levels, the european alphabets are used with upper and lower case values."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"However for countries speaking arabic, these rules can’t be applied. Indeed, there is no notion of upper and lower case characters in arabic alphabet."},{"type":"text","text":" "},{"type":"text","text":"In addition, the numbers in use (i.e. the european “arabic” numbers like “1, 2, 3”) are accepted in arabic countries, even if the “true arabic” numbers (like “ ٢ ٣ ١”) are used"},{"type":"text","text":" "},{"type":"text","text":"in middle-east arabic countries and for official documents."},{"type":"text","text":" "},{"type":"text","text":"Thus the OUDS ordered bullet list will use “european” numbers for first level, and arabic alphabets for second and third levels."}]},{"text":"Code samples","level":2,"type":"heading","anchor":"Code-samples"},{"syntax":"swift","type":"codeListing","code":["       \/\/ 1. Unordered list with bullets","       OUDSBulletList {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 1.1. Item of Unordered list with bullet as tick, a text style","       \/\/ body medium and text bold","       OUDSBulletList(type: .unordered(asset: .tick),","                      textStyle: .bodyMedium,","                      isBold: true)  {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 2. Bare list with 3 items","       OUDSBulletList(type: .bare) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3. Ordered list with 3 items","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3.1. Ordered list with 3 items in first level,","       \/\/ and one item as sub item (second level),","       \/\/ and 2 items as sub item in (third level)","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\") {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ Same Bullet list but items in third level with free icon as bullet","       let icon = Image(decorative: \"ic_heart\")","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\", subListType: .unordered(asset: .icon(icon))) {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }"]},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-bullet-list","type":"reference","isActive":true}]},{"text":"Themes rendering","level":2,"type":"heading","anchor":"Themes-rendering"},{"type":"heading","text":"Orange","level":3,"anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_bullet_list_Orange"}]},{"type":"heading","text":"Orange Compact","level":3,"anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_OrangeCompact","type":"image"}]},{"type":"heading","text":"Sosh","level":3,"anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_Sosh","type":"image"}]},{"type":"heading","text":"Wireframe","level":3,"anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_Wireframe","type":"image"}]},{"content":[{"inlineContent":[{"type":"text","text":"1.0.0 (Figma component design version)"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Version"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.2.0"}]}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"component_bullet_list_Sosh":{"type":"image","identifier":"component_bullet_list_Sosh","alt":"A bullet list component in light and dark modes with Sosh theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_bullet_list_Sosh.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBulletList/body":{"kind":"symbol","type":"topic","title":"body","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/body","abstract":[],"url":"\/documentation\/oudscomponents\/oudsbulletlist\/body","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"body"},{"text":": ","kind":"text"},{"kind":"keyword","text":"some"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI4ViewP","kind":