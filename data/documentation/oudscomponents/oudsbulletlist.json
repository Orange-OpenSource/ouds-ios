{"metadata":{"roleHeading":"Structure","externalID":"s:14OUDSComponents14OUDSBulletListV","platforms":[{"introducedAt":"15.0","unavailable":false,"deprecated":false,"beta":false,"name":"iOS"},{"introducedAt":"13.0","unavailable":false,"deprecated":false,"beta":false,"name":"macOS"},{"introducedAt":"16.0","unavailable":false,"deprecated":false,"beta":false,"name":"tvOS"},{"introducedAt":"1.0","unavailable":false,"deprecated":false,"beta":false,"name":"visionOS"},{"introducedAt":"11.0","unavailable":false,"deprecated":false,"beta":false,"name":"watchOS"}],"role":"symbol","symbolKind":"struct","title":"OUDSBulletList","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSBulletList","kind":"identifier"}],"modules":[{"name":"Components"}]},"kind":"symbol","abstract":[{"text":"Bullet list is a UI element that helps to view in related individual text items grouped together; items usually starting with a number or a bullet.","type":"text"},{"text":" ","type":"text"},{"text":"Bullet list is also known as ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Unordered list"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Ordered list"}]},{"text":" and is not an interactive element by default.","type":"text"}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Item"],"generated":true,"anchor":"Structures"},{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/init(type:textStyle:isBold:items:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/body"],"generated":true,"anchor":"Instance-Properties"},{"title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/TextStyle","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Type","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedAsset"],"generated":true,"anchor":"Enumerations"},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations"],"generated":true,"anchor":"Default-Implementations"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"kind":"text","text":" "},{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSBulletList","kind":"identifier"}]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay"],"kind":"mentions"},{"content":[{"level":2,"type":"heading","anchor":"Types","text":"Types"},{"inlineContent":[{"type":"text","text":"Three types are proposed:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Unordered (by default)"}]},{"text":": Collects related items that don’t need to be in a specific order or sequence.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Ordered","type":"text"}]},{"type":"text","text":": Collects related items with numeric order or sequence."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Bare","type":"text"}]},{"type":"text","text":": An unordered list without any bullets or alphanumeric sequence."}]}]}]},{"inlineContent":[{"type":"text","text":"Types can be mixed in list, but must be identical for the same "},{"code":"OUDSBulletList.NestedLevel","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Levels","text":"Levels"},{"inlineContent":[{"type":"text","text":"Lists can include nested items to indicate hierarchy or subcategories, with indentation distinguishing each level."},{"type":"text","text":" "},{"type":"text","text":"Arrange ordered list items logically, such as ranking by importance, highest to lowest values, or in alphabetical \/ numeric order."},{"type":"text","text":" "},{"type":"text","text":"Three levels are maximum."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Text-Style","text":"Text Style"},{"inlineContent":[{"type":"text","text":"List can be used with different font sizes:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Body Large","type":"text"}]},{"type":"text","text":": If the text accompanying the list component is the Body Large text. This variant is designed for more visual, engaging experiences."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Body Medium","type":"text"}],"type":"strong"},{"type":"text","text":": If the text accompanying the list component is the Body Medium text. This variant is best suited for functional, task-oriented experiences."}]}]}]},{"level":2,"type":"heading","anchor":"Cases-forbidden-by-design","text":"Cases forbidden by design"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"it is not allowed to have a depth of items greater than 3"}]}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Internationalisation-considerations","text":"Internationalisation considerations"},{"inlineContent":[{"text":"For latin-based speaking countries, like France, Spain, United Kingdom or Belgium, the european “arabic” numbers are used for the first level of depth","type":"text"},{"text":" ","type":"text"},{"text":"of the ordered bullet list. For the second and third levels, the european alphabets are used with upper and lower case values.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"However for countries speaking arabic, these rules can’t be applied. Indeed, there is no notion of upper and lower case characters in arabic alphabet.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the numbers in use (i.e. the european “arabic” numbers like “1, 2, 3”) are accepted in arabic countries, even if the “true arabic” numbers (like “ ٢ ٣ ١”) are used","type":"text"},{"text":" ","type":"text"},{"text":"in middle-east arabic countries and for official documents.","type":"text"},{"text":" ","type":"text"},{"text":"Thus the OUDS ordered bullet list will use “european” numbers for first level, and arabic alphabets for second and third levels.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Code-samples","text":"Code samples"},{"syntax":"swift","code":["       \/\/ 1. Unordered list with bullets","       OUDSBulletList {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 1.1. Item of Unordered list with bullet as tick, a text style","       \/\/ body medium and text bold","       OUDSBulletList(type: .unordered(asset: .tick),","                      textStyle: .bodyMedium,","                      isBold: true)  {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 2. Bare list with 3 items","       OUDSBulletList(type: .bare) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3. Ordered list with 3 items","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3.1. Ordered list with 3 items in first level,","       \/\/ and one item as sub item (second level),","       \/\/ and 2 items as sub item in (third level)","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\") {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ Same Bullet list but items in third level with free icon as bullet","       let icon = Image(decorative: \"ic_heart\")","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\", subListType: .unordered(asset: .icon(icon))) {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }"],"type":"codeListing"},{"level":2,"type":"heading","anchor":"Design-documentation","text":"Design documentation"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-bullet-list","isActive":true,"type":"reference"}],"type":"paragraph"},{"level":2,"type":"heading"