{"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay"]},{"content":[{"text":"Types","level":2,"type":"heading","anchor":"Types"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Three types are proposed:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Unordered (by default)"}]},{"text":": Collects related items that don’t need to be in a specific order or sequence.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Ordered"}],"type":"strong"},{"type":"text","text":": Collects related items with numeric order or sequence."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Bare","type":"text"}]},{"type":"text","text":": An unordered list without any bullets or alphanumeric sequence."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Types can be mixed in list, but must be identical for the same ","type":"text"},{"type":"codeVoice","code":"OUDSBulletList.NestedLevel"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Levels","anchor":"Levels"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lists can include nested items to indicate hierarchy or subcategories, with indentation distinguishing each level."},{"type":"text","text":" "},{"type":"text","text":"Arrange ordered list items logically, such as ranking by importance, highest to lowest values, or in alphabetical \/ numeric order."},{"type":"text","text":" "},{"type":"text","text":"Three levels are maximum."}]},{"type":"heading","level":2,"text":"Text Style","anchor":"Text-Style"},{"type":"paragraph","inlineContent":[{"type":"text","text":"List can be used with different font sizes:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Body Large"}]},{"type":"text","text":": If the text accompanying the list component is the Body Large text. This variant is designed for more visual, engaging experiences."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Body Medium"}],"type":"strong"},{"text":": If the text accompanying the list component is the Body Medium text. This variant is best suited for functional, task-oriented experiences.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Cases-forbidden-by-design","level":2,"text":"Cases forbidden by design","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"it is not allowed to have a depth of items greater than 3","type":"text"}]}]},{"anchor":"Internationalisation-considerations","level":2,"text":"Internationalisation considerations","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For latin-based speaking countries, like France, Spain, United Kingdom or Belgium, the european “arabic” numbers are used for the first level of depth"},{"type":"text","text":" "},{"type":"text","text":"of the ordered bullet list. For the second and third levels, the european alphabets are used with upper and lower case values."}]},{"type":"paragraph","inlineContent":[{"text":"However for countries speaking arabic, these rules can’t be applied. Indeed, there is no notion of upper and lower case characters in arabic alphabet.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the numbers in use (i.e. the european “arabic” numbers like “1, 2, 3”) are accepted in arabic countries, even if the “true arabic” numbers (like “ ٢ ٣ ١”) are used","type":"text"},{"text":" ","type":"text"},{"text":"in middle-east arabic countries and for official documents.","type":"text"},{"text":" ","type":"text"},{"text":"Thus the OUDS ordered bullet list will use “european” numbers for first level, and arabic alphabets for second and third levels.","type":"text"}]},{"text":"Code samples","type":"heading","level":2,"anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["       \/\/ 1. Unordered list with bullets","       OUDSBulletList {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 1.1. Item of Unordered list with bullet as tick, a text style","       \/\/ body medium and text bold","       OUDSBulletList(type: .unordered(asset: .tick),","                      textStyle: .bodyMedium,","                      isBold: true)  {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 2. Bare list with 3 items","       OUDSBulletList(type: .bare) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3. Ordered list with 3 items","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3.1. Ordered list with 3 items in first level,","       \/\/ and one item as sub item (second level),","       \/\/ and 2 items as sub item in (third level)","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\") {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ Same Bullet list but items in third level with free icon as bullet","       let icon = Image(decorative: \"ic_heart\")","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\", subListType: .unordered(asset: .icon(icon))) {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }"]},{"text":"Design documentation","type":"heading","level":2,"anchor":"Design-documentation"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-bullet-list","isActive":true}],"type":"paragraph"},{"level":2,"text":"Themes rendering","anchor":"Themes-rendering","type":"heading"},{"level":3,"text":"Orange","anchor":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_bullet_list_Orange","type":"image"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Orange-Compact","text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_bullet_list_OrangeCompact"}]},{"type":"heading","anchor":"Sosh","text":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_bullet_list_Sosh"}]},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"component_bullet_list_Wireframe"}],"type":"paragraph"},{"type":"aside","style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.0.0 (Figma component design version)"}]}]},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.2.0"}]}]}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbulletlist"]}],"topicSections":[{"title":"Structures","generated":true,"anchor":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Item"]},{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/init(type:textStyle:isBold:items:)"]},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/body"]},{"title":"Enumerations","generated":true,"anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/TextStyle","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Type","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedAsset"]},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations"]}],"metadata":{"platforms":[{"beta":false,"introducedAt":"15.0","unavailable":false,"name":"iOS","deprecated":false},{"beta":false,"introducedAt":"13.0","unavailable":false,"name":"macOS","deprecated":false},{"beta":false,"introducedAt":"16.0","unavailable":false,"name":"tvOS","deprecated":false},{"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false,"unavailable":false},{"beta":false,"name":"watchOS","introducedAt":"11.0","deprecated":false,"unavailable":false}],"role":"symbol","externalID":"s:14OUDSComp