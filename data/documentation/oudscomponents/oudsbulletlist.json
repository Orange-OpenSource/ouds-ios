me":"watchOS","deprecated":false,"beta":false}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}],"title":"OUDSBulletList","roleHeading":"Structure","externalID":"s:14OUDSComponents14OUDSBulletListV","modules":[{"name":"Components"}],"symbolKind":"struct","role":"symbol","navigatorTitle":[{"text":"OUDSBulletList","kind":"identifier"}]},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList"},"abstract":[{"type":"text","text":"Bullet list is a UI element that helps to view in related individual text items grouped together; items usually starting with a number or a bullet."},{"type":"text","text":" "},{"type":"text","text":"Bullet list is also known as "},{"type":"emphasis","inlineContent":[{"text":"Unordered list","type":"text"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"text":"Ordered list","type":"text"}]},{"type":"text","text":" and is not an interactive element by default."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OUDSBulletList","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay"],"kind":"mentions"},{"content":[{"type":"heading","text":"Types","anchor":"Types","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Three types are proposed:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Unordered (by default)","type":"text"}],"type":"strong"},{"type":"text","text":": Collects related items that don’t need to be in a specific order or sequence."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Ordered"}]},{"type":"text","text":": Collects related items with numeric order or sequence."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Bare"}]},{"text":": An unordered list without any bullets or alphanumeric sequence.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Types can be mixed in list, but must be identical for the same "},{"type":"codeVoice","code":"OUDSBulletList.NestedLevel"},{"type":"text","text":"."}]},{"anchor":"Levels","level":2,"text":"Levels","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lists can include nested items to indicate hierarchy or subcategories, with indentation distinguishing each level."},{"text":" ","type":"text"},{"type":"text","text":"Arrange ordered list items logically, such as ranking by importance, highest to lowest values, or in alphabetical \/ numeric order."},{"text":" ","type":"text"},{"type":"text","text":"Three levels are maximum."}]},{"level":2,"type":"heading","anchor":"Text-Style","text":"Text Style"},{"inlineContent":[{"text":"List can be used with different font sizes:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Body Large"}]},{"type":"text","text":": If the text accompanying the list component is the Body Large text. This variant is designed for more visual, engaging experiences."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Body Medium"}],"type":"strong"},{"type":"text","text":": If the text accompanying the list component is the Body Medium text. This variant is best suited for functional, task-oriented experiences."}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Cases-forbidden-by-design","text":"Cases forbidden by design"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"it is not allowed to have a depth of items greater than 3"}],"type":"strong"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Internationalisation-considerations","text":"Internationalisation considerations"},{"inlineContent":[{"text":"For latin-based speaking countries, like France, Spain, United Kingdom or Belgium, the european “arabic” numbers are used for the first level of depth","type":"text"},{"text":" ","type":"text"},{"text":"of the ordered bullet list. For the second and third levels, the european alphabets are used with upper and lower case values.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"However for countries speaking arabic, these rules can’t be applied. Indeed, there is no notion of upper and lower case characters in arabic alphabet.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the numbers in use (i.e. the european “arabic” numbers like “1, 2, 3”) are accepted in arabic countries, even if the “true arabic” numbers (like “ ٢ ٣ ١”) are used","type":"text"},{"text":" ","type":"text"},{"text":"in middle-east arabic countries and for official documents.","type":"text"},{"text":" ","type":"text"},{"text":"Thus the OUDS ordered bullet list will use “european” numbers for first level, and arabic alphabets for second and third levels.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"code":["       \/\/ 1. Unordered list with bullets","       OUDSBulletList {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 1.1. Item of Unordered list with bullet as tick, a text style","       \/\/ body medium and text bold","       OUDSBulletList(type: .unordered(asset: .tick),","                      textStyle: .bodyMedium,","                      isBold: true)  {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 2. Bare list with 3 items","       OUDSBulletList(type: .bare) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3. Ordered list with 3 items","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3.1. Ordered list with 3 items in first level,","       \/\/ and one item as sub item (second level),","       \/\/ and 2 items as sub item in (third level)","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\") {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ Same Bullet list but items in third level with free icon as bullet","       let icon = Image(decorative: \"ic_heart\")","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\", subListType: .unordered(asset: .icon(icon))) {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-bullet-list","isActive":true,"type":"reference"}]},{"type":"heading","level":2,"text":"Themes rendering","anchor":"Themes-rendering"},{"type":"heading","level":3,"text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_Orange","type":"image"}]},{"type":"heading","level":3,"text":"Orange Business Tools","anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_OrangeCompact","type":"image"}]},{"level":3,"type":"heading","text":"Sosh","anchor":"Sosh"},{"inlineContent":[{"identifier":"component_bullet_list_Sosh","type":"image"}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_Wireframe","type":"image"}]},{"name":"Version","type":"aside","content":[{"inlineContent":[{"type":"text","text":"1.0.0 (Figma component design version)"}],"type":"paragraph"}],"style":"note"},{"name":"Since","type":"aside","content":[{"inlineContent":[{"type":"text","text":"1.2.0"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbulletlist"]}],"references":{"doc://OUDSComponents/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype","type":"unresolvable"},"component_bullet_list_Sosh":{"alt":"A bullet list component in light and dark modes with Sosh theme","identifier":"component_bullet_list_Sosh","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_bullet_list_Sosh.png"}],"type":"image"},"component_bullet_list_Wireframe":{"alt":"A bullet list component in light and dark modes with Wireframe theme","identifier":"component_bullet_list_Wireframe","variants":[{"traits":["1x","light"],"url"