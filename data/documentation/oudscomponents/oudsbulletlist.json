{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList"},"metadata":{"platforms":[{"introducedAt":"15.0","unavailable":false,"deprecated":false,"beta":false,"name":"iOS"},{"introducedAt":"13.0","unavailable":false,"deprecated":false,"beta":false,"name":"macOS"},{"introducedAt":"16.0","unavailable":false,"deprecated":false,"beta":false,"name":"tvOS"},{"introducedAt":"1.0","unavailable":false,"deprecated":false,"beta":false,"name":"visionOS"},{"introducedAt":"11.0","unavailable":false,"deprecated":false,"beta":false,"name":"watchOS"}],"externalID":"s:14OUDSComponents14OUDSBulletListV","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}],"title":"OUDSBulletList","modules":[{"name":"Components"}],"role":"symbol","navigatorTitle":[{"text":"OUDSBulletList","kind":"identifier"}],"roleHeading":"Structure"},"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"abstract":[{"text":"Bullet list is a UI element that helps to view in related individual text items grouped together; items usually starting with a number or a bullet.","type":"text"},{"text":" ","type":"text"},{"text":"Bullet list is also known as ","type":"text"},{"inlineContent":[{"text":"Unordered list","type":"text"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"Ordered list"}],"type":"emphasis"},{"text":" and is not an interactive element by default.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/oudscomponents\/oudsbulletlist"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay"]},{"kind":"content","content":[{"type":"heading","text":"Types","anchor":"Types","level":2},{"inlineContent":[{"text":"Three types are proposed:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Unordered (by default)"}]},{"text":": Collects related items that don’t need to be in a specific order or sequence.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Ordered","type":"text"}]},{"type":"text","text":": Collects related items with numeric order or sequence."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Bare"}],"type":"strong"},{"text":": An unordered list without any bullets or alphanumeric sequence.","type":"text"}]}]}]},{"inlineContent":[{"text":"Types can be mixed in list, but must be identical for the same ","type":"text"},{"type":"codeVoice","code":"OUDSBulletList.NestedLevel"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"Levels","type":"heading","anchor":"Levels"},{"inlineContent":[{"type":"text","text":"Lists can include nested items to indicate hierarchy or subcategories, with indentation distinguishing each level."},{"type":"text","text":" "},{"type":"text","text":"Arrange ordered list items logically, such as ranking by importance, highest to lowest values, or in alphabetical \/ numeric order."},{"type":"text","text":" "},{"type":"text","text":"Three levels are maximum."}],"type":"paragraph"},{"level":2,"text":"Text Style","type":"heading","anchor":"Text-Style"},{"inlineContent":[{"type":"text","text":"List can be used with different font sizes:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Body Large","type":"text"}]},{"text":": If the text accompanying the list component is the Body Large text. This variant is designed for more visual, engaging experiences.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Body Medium"}],"type":"strong"},{"text":": If the text accompanying the list component is the Body Medium text. This variant is best suited for functional, task-oriented experiences.","type":"text"}]}]}]},{"level":2,"text":"Cases forbidden by design","type":"heading","anchor":"Cases-forbidden-by-design"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"it is not allowed to have a depth of items greater than 3","type":"text"}]}],"type":"paragraph"},{"level":2,"type":"heading","text":"Internationalisation considerations","anchor":"Internationalisation-considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For latin-based speaking countries, like France, Spain, United Kingdom or Belgium, the european “arabic” numbers are used for the first level of depth"},{"type":"text","text":" "},{"type":"text","text":"of the ordered bullet list. For the second and third levels, the european alphabets are used with upper and lower case values."}]},{"type":"paragraph","inlineContent":[{"text":"However for countries speaking arabic, these rules can’t be applied. Indeed, there is no notion of upper and lower case characters in arabic alphabet.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the numbers in use (i.e. the european “arabic” numbers like “1, 2, 3”) are accepted in arabic countries, even if the “true arabic” numbers (like “ ٢ ٣ ١”) are used","type":"text"},{"text":" ","type":"text"},{"text":"in middle-east arabic countries and for official documents.","type":"text"},{"text":" ","type":"text"},{"text":"Thus the OUDS ordered bullet list will use “european” numbers for first level, and arabic alphabets for second and third levels.","type":"text"}]},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"code":["       \/\/ 1. Unordered list with bullets","       OUDSBulletList {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 1.1. Item of Unordered list with bullet as tick, a text style","       \/\/ body medium and text bold","       OUDSBulletList(type: .unordered(asset: .tick),","                      textStyle: .bodyMedium,","                      isBold: true)  {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 2. Bare list with 3 items","       OUDSBulletList(type: .bare) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3. Ordered list with 3 items","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3.1. Ordered list with 3 items in first level,","       \/\/ and one item as sub item (second level),","       \/\/ and 2 items as sub item in (third level)","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\") {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ Same Bullet list but items in third level with free icon as bullet","       let icon = Image(decorative: \"ic_heart\")","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\", subListType: .unordered(asset: .icon(icon))) {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-bullet-list","isActive":true}]},{"level":2,"type":"heading","text":"Themes rendering","anchor":"Themes-rendering"},{"level":3,"type":"heading","text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_Orange","type":"image"}]},{"level":3,"type":"heading","text":"Orange Business Tools","anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_OrangeCompact","type":"image"}]},{"level":3,"type":"heading","text":"Sosh","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_Sosh","type":"image"}]},{"level":3,"type":"heading","text":"Wireframe","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_bullet_list_Wireframe","type":"image"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"1.0.0 (Figma component design version)","type":"text"}]}],"type":"aside","style":"note","name":"Version"},{"content":[{"inlineContent":[{"type":"text","text":"1.2.0"}],"type":"paragraph"}],"style":"note","name":"Since","type":"aside"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSC