{"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay"]},{"kind":"content","content":[{"text":"Types","anchor":"Types","level":2,"type":"heading"},{"inlineContent":[{"text":"Three types are proposed:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Unordered (by default)","type":"text"}]},{"type":"text","text":": Collects related items that don’t need to be in a specific order or sequence."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Ordered","type":"text"}]},{"type":"text","text":": Collects related items with numeric order or sequence."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Bare","type":"text"}]},{"type":"text","text":": An unordered list without any bullets or alphanumeric sequence."}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Types can be mixed in list, but must be identical for the same ","type":"text"},{"type":"codeVoice","code":"OUDSBulletList.NestedLevel"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Levels","anchor":"Levels","level":2,"type":"heading"},{"inlineContent":[{"text":"Lists can include nested items to indicate hierarchy or subcategories, with indentation distinguishing each level.","type":"text"},{"text":" ","type":"text"},{"text":"Arrange ordered list items logically, such as ranking by importance, highest to lowest values, or in alphabetical \/ numeric order.","type":"text"},{"text":" ","type":"text"},{"text":"Three levels are maximum.","type":"text"}],"type":"paragraph"},{"text":"Text Style","anchor":"Text-Style","level":2,"type":"heading"},{"inlineContent":[{"text":"List can be used with different font sizes:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Body Large","type":"text"}]},{"type":"text","text":": If the text accompanying the list component is the Body Large text. This variant is designed for more visual, engaging experiences."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Body Medium","type":"text"}]},{"type":"text","text":": If the text accompanying the list component is the Body Medium text. This variant is best suited for functional, task-oriented experiences."}]}]}],"type":"unorderedList"},{"text":"Cases forbidden by design","anchor":"Cases-forbidden-by-design","level":2,"type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"it is not allowed to have a depth of items greater than 3","type":"text"}]}],"type":"paragraph"},{"text":"Internationalisation considerations","anchor":"Internationalisation-considerations","level":2,"type":"heading"},{"inlineContent":[{"text":"For latin-based speaking countries, like France, Spain, United Kingdom or Belgium, the european “arabic” numbers are used for the first level of depth","type":"text"},{"text":" ","type":"text"},{"text":"of the ordered bullet list. For the second and third levels, the european alphabets are used with upper and lower case values.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However for countries speaking arabic, these rules can’t be applied. Indeed, there is no notion of upper and lower case characters in arabic alphabet."},{"type":"text","text":" "},{"text":"In addition, the numbers in use (i.e. the european “arabic” numbers like “1, 2, 3”) are accepted in arabic countries, even if the “true arabic” numbers (like “ ٢ ٣ ١”) are used","type":"text"},{"text":" ","type":"text"},{"text":"in middle-east arabic countries and for official documents.","type":"text"},{"text":" ","type":"text"},{"text":"Thus the OUDS ordered bullet list will use “european” numbers for first level, and arabic alphabets for second and third levels.","type":"text"}]},{"anchor":"Code-samples","text":"Code samples","type":"heading","level":2},{"syntax":"swift","code":["       \/\/ 1. Unordered list with bullets","       OUDSBulletList {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 1.1. Item of Unordered list with bullet as tick, a text style","       \/\/ body medium and text bold","       OUDSBulletList(type: .unordered(asset: .tick),","                      textStyle: .bodyMedium,","                      isBold: true)  {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 2. Bare list with 3 items","       OUDSBulletList(type: .bare) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3. Ordered list with 3 items","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3.1. Ordered list with 3 items in first level,","       \/\/ and one item as sub item (second level),","       \/\/ and 2 items as sub item in (third level)","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\") {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ Same Bullet list but items in third level with free icon as bullet","       let icon = Image(decorative: \"ic_heart\")","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\", subListType: .unordered(asset: .icon(icon))) {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }"],"type":"codeListing"},{"anchor":"Design-documentation","text":"Design documentation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-bullet-list"}]},{"text":"Themes rendering","type":"heading","level":2,"anchor":"Themes-rendering"},{"text":"Orange","type":"heading","level":3,"anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_bullet_list_Orange"}]},{"text":"Orange Compact","type":"heading","level":3,"anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_bullet_list_OrangeCompact"}]},{"anchor":"Sosh","text":"Sosh","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_bullet_list_Sosh"}]},{"anchor":"Wireframe","text":"Wireframe","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"component_bullet_list_Wireframe"}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"1.0.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"name":"Version"},{"content":[{"inlineContent":[{"text":"1.2.0","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Since"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbulletlist"]}],"topicSections":[{"generated":true,"anchor":"Structures","title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Item"]},{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/init(type:textStyle:isBold:items:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/body"]},{"generated":true,"anchor":"Type-Aliases","title":"Type Aliases","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedIcon"]},{"generated":true,"anchor":"Enumerations","title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/TextStyle","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Type","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedAsset"]},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList"},"metadata":{"symbolKind":"struct","navigatorTitle":[{"text":"OUDSBulletList","kind":"identifier"}],"roleHeading":"Structure","role":"symbol","title":"OUDSBulletList","platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"15.0"},{"n