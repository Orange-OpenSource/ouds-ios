on/OUDSComponents/ContentDisplay":{"url":"\/documentation\/oudscomponents\/contentdisplay","kind":"article","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay","title":"Content Display","abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"content display"}]},{"text":".","type":"text"}],"role":"article","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"identifier":"ic_folder_categories.png","type":"card"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBulletList/UnorderedAsset":{"url":"\/documentation\/oudscomponents\/oudsbulletlist\/unorderedasset","kind":"symbol","type":"topic","navigatorTitle":[{"text":"UnorderedAsset","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedAsset","title":"OUDSBulletList.UnorderedAsset","abstract":[{"text":"The type of asset in the unordered list","type":"text"}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnorderedAsset","kind":"identifier"}]},"component_bullet_list_OrangeCompact":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_bullet_list_OrangeCompact.png"}],"identifier":"component_bullet_list_OrangeCompact","type":"image","alt":"A bullet list component in light and dark modes with Orange Compact theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBulletList":{"navigatorTitle":[{"text":"OUDSBulletList","kind":"identifier"}],"kind":"symbol","title":"OUDSBulletList","url":"\/documentation\/oudscomponents\/oudsbulletlist","role":"symbol","abstract":[{"text":"Bullet list is a UI element that helps to view in related individual text items grouped together; items usually starting with a number or a bullet.","type":"text"},{"text":" ","type":"text"},{"text":"Bullet list is also known as ","type":"text"},{"inlineContent":[{"text":"Unordered list","type":"text"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"text":"Ordered list","type":"text"}],"type":"emphasis"},{"text":" and is not an interactive element by default.","type":"text"}],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBulletList/Item":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Item","abstract":[{"type":"text","text":"The item of bullet list with text and optional sub items."}],"type":"topic","url":"\/documentation\/oudscomponents\/oudsbulletlist\/item","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Item"}],"navigatorTitle":[{"text":"Item","kind":"identifier"}],"title":"OUDSBulletList.Item"},"component_bullet_list_Wireframe":{"variants":[{"url":"\/images\/OUDSComponents\/component_bullet_list_Wireframe.png","traits":["1x","light"]}],"identifier":"component_bullet_list_Wireframe","type":"image","alt":"A bullet list component in light and dark modes with Wireframe theme"},"doc://OUDSComponents/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"component_bullet_list_Orange":{"variants":[{"url":"\/images\/OUDSComponents\/component_bullet_list_Orange.png","traits":["1x","light"]}],"identifier":"component_bullet_list_Orange","type":"image","alt":"A bullet list component in light and dark modes with Orange theme"}}}