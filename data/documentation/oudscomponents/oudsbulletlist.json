{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"type":"text","text":"Bullet list is a UI element that helps to view in related individual text items grouped together; items usually starting with a number or a bullet."},{"type":"text","text":" "},{"type":"text","text":"Bullet list is also known as "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Unordered list"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"text":"Ordered list","type":"text"}]},{"type":"text","text":" and is not an interactive element by default."}],"sections":[],"metadata":{"symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSBulletList"}],"externalID":"s:14OUDSComponents14OUDSBulletListV","modules":[{"name":"Components"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSBulletList"}],"title":"OUDSBulletList","platforms":[{"name":"iOS","unavailable":false,"beta":false,"introducedAt":"15.0","deprecated":false},{"name":"macOS","unavailable":false,"beta":false,"introducedAt":"13.0","deprecated":false},{"name":"tvOS","unavailable":false,"beta":false,"introducedAt":"16.0","deprecated":false},{"name":"visionOS","unavailable":false,"beta":false,"introducedAt":"1.0","deprecated":false},{"name":"watchOS","unavailable":false,"beta":false,"introducedAt":"11.0","deprecated":false}],"role":"symbol","roleHeading":"Structure"},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList","interfaceLanguage":"swift"},"kind":"symbol","relationshipsSections":[{"title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships"}],"topicSections":[{"title":"Structures","anchor":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Item"],"generated":true},{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/init(type:textStyle:isBold:items:)"],"generated":true},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/body"],"generated":true},{"title":"Type Aliases","anchor":"Type-Aliases","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedIcon"],"generated":true},{"title":"Enumerations","anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/TextStyle","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/Type","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/UnorderedAsset"],"generated":true},{"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBulletList\/View-Implementations"],"generated":true}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsbulletlist"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSBulletList","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/ContentDisplay"],"kind":"mentions"},{"content":[{"level":2,"text":"Types","type":"heading","anchor":"Types"},{"inlineContent":[{"text":"Three types are proposed:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Unordered (by default)"}],"type":"strong"},{"text":": Collects related items that don’t need to be in a specific order or sequence.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Ordered","type":"text"}]},{"text":": Collects related items with numeric order or sequence.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Bare","type":"text"}]},{"type":"text","text":": An unordered list without any bullets or alphanumeric sequence."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Types can be mixed in list, but must be identical for the same ","type":"text"},{"code":"OUDSBulletList.NestedLevel","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Levels","anchor":"Levels"},{"inlineContent":[{"text":"Lists can include nested items to indicate hierarchy or subcategories, with indentation distinguishing each level.","type":"text"},{"text":" ","type":"text"},{"text":"Arrange ordered list items logically, such as ranking by importance, highest to lowest values, or in alphabetical \/ numeric order.","type":"text"},{"text":" ","type":"text"},{"text":"Three levels are maximum.","type":"text"}],"type":"paragraph"},{"anchor":"Text-Style","type":"heading","level":2,"text":"Text Style"},{"inlineContent":[{"type":"text","text":"List can be used with different font sizes:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Body Large","type":"text"}]},{"text":": If the text accompanying the list component is the Body Large text. This variant is designed for more visual, engaging experiences.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Body Medium","type":"text"}]},{"type":"text","text":": If the text accompanying the list component is the Body Medium text. This variant is best suited for functional, task-oriented experiences."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Cases-forbidden-by-design","type":"heading","level":2,"text":"Cases forbidden by design"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"it is not allowed to have a depth of items greater than 3","type":"text"}]}],"type":"paragraph"},{"anchor":"Internationalisation-considerations","type":"heading","level":2,"text":"Internationalisation considerations"},{"inlineContent":[{"type":"text","text":"For latin-based speaking countries, like France, Spain, United Kingdom or Belgium, the european “arabic” numbers are used for the first level of depth"},{"type":"text","text":" "},{"type":"text","text":"of the ordered bullet list. For the second and third levels, the european alphabets are used with upper and lower case values."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"However for countries speaking arabic, these rules can’t be applied. Indeed, there is no notion of upper and lower case characters in arabic alphabet."},{"type":"text","text":" "},{"type":"text","text":"In addition, the numbers in use (i.e. the european “arabic” numbers like “1, 2, 3”) are accepted in arabic countries, even if the “true arabic” numbers (like “ ٢ ٣ ١”) are used"},{"type":"text","text":" "},{"type":"text","text":"in middle-east arabic countries and for official documents."},{"type":"text","text":" "},{"type":"text","text":"Thus the OUDS ordered bullet list will use “european” numbers for first level, and arabic alphabets for second and third levels."}],"type":"paragraph"},{"level":2,"text":"Code samples","anchor":"Code-samples","type":"heading"},{"syntax":"swift","code":["       \/\/ 1. Unordered list with bullets","       OUDSBulletList {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 1.1. Item of Unordered list with bullet as tick, a text style","       \/\/ body medium and text bold","       OUDSBulletList(type: .unordered(asset: .tick),","                      textStyle: .bodyMedium,","                      isBold: true)  {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 2. Bare list with 3 items","       OUDSBulletList(type: .bare) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3. Ordered list with 3 items","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\")","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ 3.1. Ordered list with 3 items in first level,","       \/\/ and one item as sub item (second level),","       \/\/ and 2 items as sub item in (third level)","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\") {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }","","       \/\/ Same Bullet list but items in third level with free icon as bullet","       let icon = Image(decorative: \"ic_heart\")","       OUDSBulletList(type: .ordered) {","           OUDSBulletList.Item(\"Label 1\") {","               OUDSBulletList.Item(\"Label 1.1\", subListType: .unordered(asset: .icon(icon))) {","                   OUDSBulletList.Item(\"Label 1.1.1\")","                   OUDSBulletList.Item(\"Label 1.1.2\")","               }","           }","           OUDSBulletList.Item(\"Label 2\")","           OUDSBulletList.Item(\"Label 3\")","       }"],"type":"codeListing"},{"level":2,"text":"Design documentation","anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-bullet-list","type":"reference"}],"type":"paragraph"},{"level":2,"text":"Themes rendering","anchor":"Themes-rendering","type":"heading"},{"level":3,"text":"Orange","anchor":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_bullet_list_Orange","type":"image"}],"type":"paragraph"},{"level":3,"text":"Orange Compact","anchor":"Orange-Compact","type":"heading"},{"inlineContent":[{"identifier":"component_bullet_list_OrangeCompact","type":"image"}],"type":"paragraph"},{"level":3,"text":"Sosh","anchor":"Sosh","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_bullet_list_Sosh"}],"type":"paragraph"},{"level":3,"text":"Wireframe","anchor":"Wireframe","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_bullet_list_Wireframe"}],"type":"paragraph"},{"style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.0.0 (Figma component design version)"}]}],"type":"aside"},{"style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.2.0"}]}],"type":"aside"}],"kind":"content"}],"references":{"doc://OUDSComponents/s8SendableP":{"title":"Swift.Sendable","identifier":"doc:\/\/OUDSComponents\/s8SendableP","type":"unresolvable"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSBulletList/Item":{"navigatorTitle":[{"kind":"identifier","text":"Item"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Item"}],"abstract":[{"text":"The item of bullet list with text and optional sub items.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudsbulletlist\/item","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSBu