ilterChip","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":" will use several elements to describe the component."},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"type":"text","text":" "},{"type":"text","text":"However if defined in the "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPickerData","type":"reference","isActive":true},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."}],"type":"paragraph"},{"type":"heading","text":"Code samples","level":2,"anchor":"Code-samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define the elements to display in filter chip using OUDSChipPickerData.","    enum Drink: String, CaseIterable {","        case virginHolyLava, ipaBeer, mineralWater","    }","","    var someDataToPopulate: [OUDSChipPickerData<Drink>] {","        [","            OUDSChipPickerData(tag: Drink.virginHolyLava,","                               layout: .textAndIcon(\"Virgin Holy Lava\", icon: Image(systemName: \"flame\")),","","            OUDSChipPickerData(tag: Dring.ipaBeer,","                               layout: .textAndIcon(\"IPA Beer\", icon: Image(systemName: \"dog.fill\")),","","            OUDSChipPickerData(tag: Drink.mineralWater,","                               layout: .textAndIcon(\"Mineral water\", icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/\/ Single selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: Drink = .mineralWater","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selection: $selection, chips: someDataToPopulate)","","    \/\/\/ Multiple selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [Drink] = [.mineralWater]","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selections: $selections, chips: someDataToPopulate)"]},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no online specification as this component is not an official OUDS one."}]},{"type":"heading","level":2,"text":"Theme rendering","anchor":"Theme-rendering"},{"anchor":"Orange","type":"heading","text":"Orange","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_chipPicker_Orange","type":"image"}]},{"type":"heading","level":3,"text":"Orange Compact","anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_chipPicker_OrangeCompact","type":"image"}]},{"anchor":"Sosh","type":"heading","text":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_chipPicker_Sosh","type":"image"}]},{"anchor":"Wireframe","type":"heading","text":"Wireframe","level":3},{"inlineContent":[{"identifier":"component_chipPicker_Wireframe","type":"image"}],"type":"paragraph"},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.17.0","type":"text"}]}]}]}],"sections":[],"variants":[{"paths":["\/documentation\/oudscomponents\/oudschippicker"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"title":"Controls","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"ca