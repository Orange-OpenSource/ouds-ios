{"kind":"symbol","topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selection:chips:itemsSpacing:)-7xdsd","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selection:chips:itemsSpacing:)-8w8zd","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selections:chips:itemsSpacing:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:tableName:bundle:selection:chips:itemsSpacing:)-2l8cv","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:tableName:bundle:selection:chips:itemsSpacing:)-7905f","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:tableName:bundle:selections:chips:itemsSpacing:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/body"],"generated":true,"anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/View-Implementations"],"generated":true,"anchor":"Default-Implementations"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSChipPicker"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Tag"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Tag"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:SH","text":"Hashable"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each chip contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose choosen values through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSFilterChip","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"level":2,"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"type":"text","text":" will use several elements to describe the component."},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"type":"text","text":" "},{"type":"text","text":"However if defined in the "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPickerData","isActive":true,"type":"reference"},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."}]},{"type":"heading","level":2,"anchor":"Code-samples","text":"Code samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define the elements to display in filter chip using OUDSChipPickerData.","    enum Drink: String, CaseIterable {","        case virginHolyLava, ipaBeer, mineralWater","    }","","    var someDataToPopulate: [OUDSChipPickerData<Drink>] {","        [","            OUDSChipPickerData(tag: Drink.virginHolyLava,","                               layout: .textAndIcon(\"Virgin Holy Lava\", icon: Image(systemName: \"flame\")),","","            OUDSChipPickerData(tag: Dring.ipaBeer,","                               layout: .textAndIcon(\"IPA Beer\", icon: Image(systemName: \"dog.fill\")),","","            OUDSChipPickerData(tag: Drink.mineralWater,","                               layout: .textAndIcon(\"Mineral water\", icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/\/ Single selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: Drink = .mineralWater","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selection: $selection, chips: someDataToPopulate)","","    \/\/\/ Multiple selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [Drink] = [.mineralWater]","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selections: $selections, chips: someDataToPopulate)"]},{"level":2,"type":"heading","anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no online specification as this component is not an official OUDS one."}]},{"level":2,"type":"heading","text":"Theme rendering","anchor":"Theme-rendering"},{"level":3,"type":"heading","text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_chipPicker_Orange"}]},{"type":"heading","level":3,"anchor":"Orange-Compact","text":"Orange Compact"},{"type":"paragraph","inlineContent