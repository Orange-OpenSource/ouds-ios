{"abstract":[{"text":"A picker allowing to expose several ","type":"text"},{"inlineContent":[{"type":"text","text":"filter chips"}],"type":"emphasis"},{"text":" and proposing two kinds of selection:","type":"text"}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"variants":[{"paths":["\/documentation\/oudscomponents\/oudschippicker"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSChipPicker"}],"symbolKind":"struct","roleHeading":"Structure","role":"symbol","navigatorTitle":[{"text":"OUDSChipPicker","kind":"identifier"}],"modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents14OUDSChipPickerV","title":"OUDSChipPicker"},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selection:chips:itemsSpacing:)-7xdsd","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selection:chips:itemsSpacing:)-8w8zd","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selections:chips:itemsSpacing:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/body"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/View-Implementations"],"title":"Default Implementations","generated":true,"anchor":"Default-Implementations"}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSChipPicker"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Tag"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Tag"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:SH","text":"Hashable"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"single","type":"text"}],"type":"strong"},{"type":"text","text":": used to select only one option within the others"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"multiple","type":"text"}],"type":"strong"},{"type":"text","text":": used to select several options within the others"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each chip contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose choosen values through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSFilterChip","isActive":true},{"type":"text","text":"."}]},{"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"type":"text","text":" will use several elements to describe the component."},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"type":"text","text":" "},{"type":"text","text":"However if defined in the "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPickerData","isActive":true,"type":"reference"},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."}]},{"anchor":"Code-samples","type":"heading","text":"Code samples","level":2},{"type":"codeListing","code":["    \/\/ Define the elements to display in filter chip using OUDSChipPickerData.","    enum Drink: String, CaseIterable {","        case virginHolyLava, ipaBeer, mineralWater","    }","","    var someDataToPopulate: [OUDSChipPickerData<Drink>] {","        [","            OUDSChipPickerData(tag: Drink.virginHolyLava,","                               layout: .textAndIcon(\"Virgin Holy Lava\", icon: Image(systemName: \"flame\")),","","            OUDSChipPickerData(tag: Dring.ipaBeer,","                               layout: .textAndIcon(\"IPA Beer\", icon: Image(systemName: \"dog.fill\")),","","            OUDSChipPickerData(tag: Drink.mineralWater,","                               layout: .textAndIcon(\"Mineral water\", icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/\/ Single selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: Drink = .mineralWater","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selection: $selection, chips: someDataToPopulate)","","    \/\/\/ Multiple selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [Drink] = [.mineralWater]","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selections: $selections, chips: someDataToPopulate)"],"syntax":"swift"},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"text":"There is no online specification as this component is not an official OUDSThemesContract one.","type":"text"}]},{"anchor":"Theme-rendering","type":"heading","text":"Theme rendering","level":2},{"anchor":"Orange","type":"heading","text":"Orange","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_chipPicker_Orange","type":"image"}]},{"anchor":"Orange-Business-Tools","type":"heading","text":"Orange Business Tools","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_chipPicker_OrangeBusinessTools"}]},{"anchor":"Sosh","type":"heading","text":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_chipPicker_Sosh"}]},{"anchor":"Wireframe","type":"heading","text":"Wireframe","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_chipPicker_Wireframe"}]},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.17.0"}]}]}],"kind":"content"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSChipPicker/init(title:selections:chips:itemsSpacing:)":{"abstract":[{"type":"text","text":"Defines the multiple selection picker view which displays using "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSFilterChip","isActive":true},{"type":"text","text":" view the "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPickerData","isActive":true