he component."},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"type":"text","text":" "},{"type":"text","text":"However if defined in the "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPickerData","isActive":true},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define the elements to display in filter chip using OUDSChipPickerData.","    enum Drink: String, CaseIterable {","        case virginHolyLava, ipaBeer, mineralWater","    }","","    var someDataToPopulate: [OUDSChipPickerData<Drink>] {","        [","            OUDSChipPickerData(tag: Drink.virginHolyLava,","                               layout: .textAndIcon(\"Virgin Holy Lava\", icon: Image(systemName: \"flame\")),","","            OUDSChipPickerData(tag: Dring.ipaBeer,","                               layout: .textAndIcon(\"IPA Beer\", icon: Image(systemName: \"dog.fill\")),","","            OUDSChipPickerData(tag: Drink.mineralWater,","                               layout: .textAndIcon(\"Mineral water\", icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/\/ Single selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: Drink = .mineralWater","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selection: $selection, chips: someDataToPopulate)","","    \/\/\/ Multiple selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [Drink] = [.mineralWater]","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selections: $selections, chips: someDataToPopulate)"]},{"level":2,"type":"heading","anchor":"Design-documentation","text":"Design documentation"},{"inlineContent":[{"text":"There is no online specification as this component is not an official OUDS one.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Theme rendering","type":"heading","anchor":"Theme-rendering"},{"level":3,"text":"Orange","type":"heading","anchor":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_chipPicker_Orange"}],"type":"paragraph"},{"level":3,"text":"Orange Compact","type":"heading","anchor":"Orange-Compact"},{"inlineContent":[{"type":"image","identifier":"component_chipPicker_OrangeCompact"}],"type":"paragraph"},{"level":3,"text":"Sosh","type":"heading","anchor":"Sosh"},{"inlineContent":[{"type":"image","identifier":"component_chipPicker_Sosh"}],"type":"paragraph"},{"level":3,"text":"Wireframe","type":"heading","anchor":"Wireframe"},{"inlineContent":[{"type":"image","identifier":"component_chipPicker_Wireframe"}],"type":"paragraph"},{"name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.17.0"}]}],"style":"note","type":"aside"}]}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","title":"Conforms To"}],"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"A picker allowing to expose several "},{"inlineContent":[{"type":"text","text":"filter chips"}],"type":"emphasis"},{"type":"text","text":" and proposing single or multiple selections."}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSChipPicker/init(title:selection:chips:itemsSpacing:)-8w8zd":{"type":"topic","role":"symbol","kind":"sym