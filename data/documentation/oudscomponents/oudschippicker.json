{"abstract":[{"text":"A picker allowing to expose several ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"filter chips"}]},{"text":" and proposing two kinds of selection:","type":"text"}],"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selection:chips:itemsSpacing:)-7xdsd","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selection:chips:itemsSpacing:)-8w8zd","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selections:chips:itemsSpacing:)"]},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/body"]},{"title":"Default Implementations","anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/View-Implementations"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSChipPicker","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Tag","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Tag","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Hashable","kind":"typeIdentifier","preciseIdentifier":"s:SH"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"single","type":"text"}]},{"type":"text","text":": used to select only one option within the others"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"multiple"}],"type":"strong"},{"type":"text","text":": used to select several options within the others"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each chip contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose choosen values through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSFilterChip"},{"type":"text","text":"."}]},{"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"type":"text","text":" will use several elements to describe the component."},{"type":"text","text":" "},{"text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used.","type":"text"},{"text":" ","type":"text"},{"text":"However if defined in the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPickerData","type":"reference","isActive":true},{"text":" the items inside the picker will have such accessibility identifiers.","type":"text"}]},{"anchor":"Code-samples","type":"heading","text":"Code samples","level":2},{"type":"codeListing","code":["    \/\/ Define the elements to display in filter chip using OUDSChipPickerData.","    enum Drink: String, CaseIterable {","        case virginHolyLava, ipaBeer, mineralWater","    }","","    var someDataToPopulate: [OUDSChipPickerData<Drink>] {","        [","            OUDSChipPickerData(tag: Drink.virginHolyLava,","                               layout: .textAndIcon(\"Virgin Holy Lava\", icon: Image(systemName: \"flame\")),","","            OUDSChipPickerData(tag: Dring.ipaBeer,","                               layout: .textAndIcon(\"IPA Beer\", icon: Image(systemName: \"dog.fill\")),","","            OUDSChipPickerData(tag: Drink.mineralWater,","                               layout: .textAndIcon(\"Mineral water\", icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/\/ Single selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: Drink = .mineralWater","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selection: $selection, chips: someDataToPopulate)","","    \/\/\/ Multiple selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [Drink] = [.mineralWater]","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selections: $selections, chips: someDataToPopulate)"],"syntax":"swift"},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no online specification as this component is not an official OUDS one."}]},{"anchor":"Theme-rendering","type":"heading","text":"Theme rendering","level":2},{"anchor":"Orange","type":"heading","text":"Orange","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_chipPicker_Orange","type":"image"}]},{"anchor":"Orange-Business-Tools","type":"heading","level":3,"text":"Orange Business Tools"},{"type":"paragraph","inlineContent":[{"identifier":"component_chipPicker_OrangeBusinessTools","type":"image"}]},{"anchor":"Sosh","type":"heading","level":3,"text":"Sosh"},{"inlineContent":[{"identifier":"component_chipPicker_Sosh","type":"image"}],"type":"paragraph"},{"anchor":"Wireframe","type":"heading","level":3,"text":"Wireframe"},{"inlineContent":[{"identifier":"component_chipPicker_Wireframe","type":"image"}],"type":"paragraph"},{"name":"Since","type":"aside","style":"note","content":[{"inlineContent":[{"text":"0.17.0","type":"text"}],"type":"paragraph"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudschippicker"]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"kind":"symbol","metadata":{"title":"OUDSChipPicker","modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSChipPicker","kind":"identifier"}],"symbolKind":"struct","navigatorTitle":[{"text":"OUDSChipPicker","kind":"identifier"}],"externalID":"s:14OUDSComponents14OUDSChipPickerV","platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"introducedAt":"15.0","beta":false},{"name":"macOS","deprecated":false,"unavailable":false,"introducedAt":"15.0","beta":false},{"name":"visionOS","deprecated":false,"unavailable":false,"introducedAt":"1.0","beta":false}],"roleHeading":"Structure","role":"symbol"},"references":{"doc://OUDSComponents/documentation/OUDSComponents":{"title":"Components","kind":"symbol","role":"collection","url":"\/docu