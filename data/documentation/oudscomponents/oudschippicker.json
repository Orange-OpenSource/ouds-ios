{"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selection:chips:itemsSpacing:)-7xdsd","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selection:chips:itemsSpacing:)-8w8zd","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/init(title:selections:chips:itemsSpacing:)"]},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/body"]},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker\/View-Implementations"]}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudschippicker"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPicker"},"sections":[],"abstract":[{"type":"text","text":"A picker allowing to expose several "},{"type":"emphasis","inlineContent":[{"text":"filter chips","type":"text"}]},{"type":"text","text":" and proposing two kinds of selection:"}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSChipPicker","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Tag","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Tag","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Hashable","preciseIdentifier":"s:SH","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"single"}]},{"type":"text","text":": used to select only one option within the others"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"multiple","type":"text"}]},{"text":": used to select several options within the others","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Each chip contains a “tag”, i.e. a supposed to be unique value.","type":"text"},{"text":" ","type":"text"},{"text":"The picker will expose choosen values through this “tag”.","type":"text"},{"text":" ","type":"text"},{"text":"It has also some configuration elements which will override the one applied to nested ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSFilterChip","type":"reference","isActive":true},{"text":".","type":"text"}]},{"level":2,"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component."},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"type":"text","text":" "},{"type":"text","text":"However if defined in the "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPickerData","type":"reference","isActive":true},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."}]},{"level":2,"text":"Code samples","type":"heading","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define the elements to display in filter chip using OUDSChipPickerData.","    enum Drink: String, CaseIterable {","        case virginHolyLava, ipaBeer, mineralWater","    }","","    var someDataToPopulate: [OUDSChipPickerData<Drink>] {","        [","            OUDSChipPickerData(tag: Drink.virginHolyLava,","                               layout: .textAndIcon(\"Virgin Holy Lava\", icon: Image(systemName: \"flame\")),","","            OUDSChipPickerData(tag: Dring.ipaBeer,","                               layout: .textAndIcon(\"IPA Beer\", icon: Image(systemName: \"dog.fill\")),","","            OUDSChipPickerData(tag: Drink.mineralWater,","                               layout: .textAndIcon(\"Mineral water\", icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/\/ Single selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: Drink = .mineralWater","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selection: $selection, chips: someDataToPopulate)","","    \/\/\/ Multiple selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [Drink] = [.mineralWater]","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selections: $selections, chips: someDataToPopulate)"]},{"level":2,"text":"Design documentation","type":"heading","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"text":"There is no online specification as this component is not an official OUDSThemesContract one.","type":"text"}]},{"level":2,"text":"Theme rendering","type":"heading","anchor":"Theme-rendering"},{"level":3,"text":"Orange","type":"heading","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_chipPicker_Orange"}]},{"level":3,"text":"Orange Business Tools","type":"heading","anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"identifier":"component_chipPicker_OrangeBusinessTools","type":"image"}]},{"level":3,"text":"Sosh","type":"heading","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_chipPicker_Sosh"}]},{"level":3,"text":"Wireframe","type":"heading","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_chipPicker_Wireframe"}]},{"name":"Since","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"0.17.0"}],"type":"paragraph"}]}],"kind":"content"}],"metadata":{"externalID":"s:14OUDSComponents14OUDSChipPickerV","modules":[{"name":"Components"}],"role":"symbol","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSChipPicker","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSChipPicker","kind":"identifier"}],"symbolKind":"struct","title":"OUDSChipPicker"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSFilterChip":{"url":"\/documentation\/oudscomponents\/oudsfilterchip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSFilterChip"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSFilterChip","abstract":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSFilterChip","isActive":true},{"type":"text","text":" is a compact UI element used in a design system to represent a filter option that can be selected or deselected by the user."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Filter chips","type":"text"}]},{"type":"text","text":" allow users to refine content or data by applying one or more filters in a visually accessible and interactive way."},{"type":"text","text":" "},{"type":"text","text":"This version of the "},{"type":"emphasis","inlineContent":[{"text":"filter chip","type":"text"}]},{"type":"text","text":" uses the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"text only"}]},{"type":"text","text":" layout which displays only text, offering a clean and minimalistic look."},{"type":"text","text":" "},{"type":"text","text":"Other layouts are available for this component like: "},{"type":"emphasis","inlineContent":[{"text":"text + icon","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"icon only","type":"text"}]},{"text":".","type":"text"}],"kind":"symbol","type":"topic","title":"OUDSFilterChip","navigatorTitle":[{"kind":"identifier","text":"OUDSFilterChip"}],"role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"role":"collection","title":"Components","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"type":"topic","url":"\/documentation\/oudscomponents","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSChipPicker/body":{"role":"symbol","type":"topic","url":"\/documentation\/oudscomponents\/oudschippicker\/body","fragments":[{