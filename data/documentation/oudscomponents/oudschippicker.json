{"abstract":[{"text":"A picker allowing to expose several ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"filter chips"}]},{"text":" and proposing single or multiple selections.","type":"text"}],"kind":"symbol","metadata":{"title":"OUDSChipPicker","navigatorTitle":[{"text":"OUDSChipPicker","kind":"identifier"}],"modules":[{"name":"Components"}],"role":"symbol","symbolKind":"struct","externalID":"s:14OUDSComponents14OUDSChipPickerV","platforms":[{"introducedAt":"15.0","unavailable":false,"name":"iOS","deprecated":false,"beta":false},{"unavailable":false,"deprecated":false,"introducedAt":"13.0","beta":false,"name":"macOS"},{"unavailable":false,"deprecated":false,"introducedAt":"1.0","beta":false,"name":"visionOS"}],"roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSChipPicker","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSChipPicker","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Tag","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Tag","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Hashable","kind":"typeIdentifier","preciseIdentifier":"s:SH"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"Each chip contains a “tag”, i.e. a supposed to be unique value.","type":"text"},{"text":" ","type":"text"},{"text":"The picker will expose choosen values through this “tag”.","type":"text"},{"text":" ","type":"text"},{"text":"It has also some configuration elements which will override the one applied to nested ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSFilterChip","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Accessibility-considerations","text":"Accessibility considerations","type":"heading","level":2},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":" will use several elements to describe the component.","type":"text"},{"text":" ","type":"text"},{"text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used.","type":"text"},{"text":" ","type":"text"},{"text":"However if defined in the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPickerData","type":"reference","isActive":true},{"text":" the items inside the picker will have such accessibility identifiers.","type":"text"}],"type":"paragraph"},{"text":"Code samples","type":"heading","anchor":"Code-samples","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define the elements to display in filter chip using OUDSChipPickerData.","    enum Drink: String, CaseIterable {","        case virginHolyLava, ipaBeer, mineralWater","    }","","    var someDataToPopulate: [OUDSChipPickerData<Drink>] {","        [","            OUDSChipPickerData(tag: Drink.virginHolyLava,","                               layout: .textAndIcon(\"Virgin Holy Lava\", icon: Image(systemName: \"flame\")),","","            OUDSChipPickerData(tag: Dring.ipaBeer,","                               layout: .textAndIcon(\"IPA Beer\", icon: Image(systemName: \"dog.fill\")),","","            OUDSChipPickerData(tag: Drink.mineralWater,","                               layout: .textAndIcon(\"Mineral water\", icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/\/ Single selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: Drink = .mineralWater","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selection: $selection, chips: someDataToPopulate)","","    \/\/\/ Multiple selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [Drink] = [.mineralWater]","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selections: $selections, chips: someDataToPopulate)"]},{"text":"Design documentation","type":"heading","anchor":"Design-documentation","level":2},{"type":"paragraph","inlineContent":[{"text":"There is no online specification as this component is not an official OUDS one.","type":"text"}]},{"text":"Theme rendering","type":"heading","anchor":"Theme-rendering","level":2},{"text":"Orange","type":"heading","anchor":"Orange","level":3},{"inlineContent":[{"identifier":"component_chipPicker_Orange","type":"image"}],"type":"paragraph"},{"level":3,"text":"Orange Compact","type":"heading","anchor":"Orange-Compact"},{"inlineContent":[{"identifier":"component_chipPicker_OrangeCompact","type":"image"}],"type":"paragraph"},{"anchor":"Sosh","text":"Sosh","type":"heading","level":3},{"inlineContent":[{"identifier":"component_chipPicker_Sosh","type":"image"}],"type":"paragraph"},{"level":3,"text":"Wireframe","type":"heading","anchor":"Wireframe"},{"inlineContent":[{"identifier":"component_chipPicker_Wireframe","type":"image"}],"type":"paragraph"},{"name":"Since","type":"aside","content":[{"inlineContent":[{"text":"0.17.0","type":"text"}],"type":"paragraph"}],"style":"note