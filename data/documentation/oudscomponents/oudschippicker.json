identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSFilterChip","type":"reference","isActive":true},{"text":".","type":"text"}]},{"level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations","type":"heading"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"type":"text","text":" will use several elements to describe the component."},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"type":"text","text":" "},{"type":"text","text":"However if defined in the "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSChipPickerData","isActive":true},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."}]},{"level":2,"text":"Code samples","anchor":"Code-samples","type":"heading"},{"syntax":"swift","code":["    \/\/ Define the elements to display in filter chip using OUDSChipPickerData.","    enum Drink: String, CaseIterable {","        case virginHolyLava, ipaBeer, mineralWater","    }","","    var someDataToPopulate: [OUDSChipPickerData<Drink>] {","        [","            OUDSChipPickerData(tag: Drink.virginHolyLava,","                               layout: .textAndIcon(\"Virgin Holy Lava\", icon: Image(systemName: \"flame\")),","","            OUDSChipPickerData(tag: Dring.ipaBeer,","                               layout: .textAndIcon(\"IPA Beer\", icon: Image(systemName: \"dog.fill\")),","","            OUDSChipPickerData(tag: Drink.mineralWater,","                               layout: .textAndIcon(\"Mineral water\", icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/\/ Single selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: Drink = .mineralWater","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selection: $selection, chips: someDataToPopulate)","","    \/\/\/ Multiple selection case","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selections: [Drink] = [.mineralWater]","","    \/\/ Here the picker with title, selection and data","    OUDSChipPicker(title: \"Select a drink\", selections: $selections, chips: someDataToPopulate)"],"type":"codeListing"},{"level":2,"text":"Design documentation","anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"type":"text","text":"There is no online specification as this component is not an official OUDS one."}],"type":"paragraph"},{"level":2,"text":"Theme rendering","anchor":"Theme-rendering","type":"heading"},{"level":3,"text":"Orange","anchor":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_chipPicker_Orange","type":"image"}],"type":"paragraph"},{"level":3,"text":"Orange Compact","anchor":"Orange-Compact","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_chipPicker_OrangeCompact"}],"type":"paragraph"},{"level":3,"text":"Sosh","anchor":"Sosh","type":"heading"},{"inlineContent":[{"identifier":"component_chipPicker_Sosh","type":"image"}],"type":"paragraph"},{"level":3,"text":"Wireframe","anchor":"Wireframe","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_chipPicker_Wireframe"}],"type":"paragraph"},{"name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.17.0"}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSChipPicker","kind":"identifier"}],"symbolKind":"struct","externalID":"s:14OUDSComponents14OUDSChipPickerV","role":"symbol","modules":[{"name":"Compo