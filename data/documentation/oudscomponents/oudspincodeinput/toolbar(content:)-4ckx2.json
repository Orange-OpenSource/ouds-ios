/toolbar(content:)-4ckx2","title":"toolbar(content:)"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSPinCodeInput":{"navigatorTitle":[{"text":"OUDSPinCodeInput","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSPinCodeInput","kind":"identifier"}],"abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"type":"text","text":"such as a four, six or eight-digit personal identification number (PIN)."},{"type":"text","text":" "},{"type":"text","text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,"},{"type":"text","text":" "},{"type":"text","text":"while supporting smooth keyboard navigation and secured input masking if needed."}],"role":"symbol","url":"\/documentation\/oudscomponents\/oudspincodeinput","kind":"symbol","type":"topic","title":"OUDSPinCodeInput","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"type":"topic","title":"Components","role":"collection"}}}