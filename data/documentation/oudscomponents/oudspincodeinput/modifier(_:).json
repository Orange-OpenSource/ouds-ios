,"abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"type":"text","text":"such as a four, six or eight-digit personal identification number (PIN)."},{"type":"text","text":" "},{"type":"text","text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,"},{"type":"text","text":" "},{"type":"text","text":"while supporting smooth keyboard navigation and secured input masking if needed."}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput"},"doc://OUDSComponents/documentation/OUDSComponents":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"type":"topic","url":"\/documentation\/oudscomponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"title":"Components","kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"ic_folder_categories.png":{"alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png","type":"image"}}}