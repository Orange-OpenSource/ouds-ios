Value","anchor":"return-value","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"A view that hides or not the tab bar and propagates the hidden state to "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" overlay items."}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use this modifier instead of "},{"type":"codeVoice","code":".toolbar(for:)"},{"type":"text","text":" "},{"type":"text","text":"whenever a view inside a "},{"type":"codeVoice","code":"NavigationStack"},{"type":"text","text":" embedded in an "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" needs to hide"},{"type":"text","text":" "},{"type":"text","text":"the tab bar. Without this modifier, "},{"code":"OUDSTabBar","type":"codeVoice"},{"type":"text","text":" cannot detect the visibility change"},{"type":"text","text":" "},{"type":"text","text":"and its overlay elements remain visible on top of the content. This helper must be used for"},{"type":"text","text":" "},{"type":"text","text":"apps with nested views and tab bars."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Otherwise for simple app "},{"code":".toolbar(for:)","type":"codeVoice"},{"type":"text","text":" is enough."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct DetailView: View {","    var body: some View {","        Text(\"Detail\")","            .tabBar(isHidden: true)","    }","}"]}],"kind":"content"}],"abstract":[{"text":"Hides or not the native tab bar ","type":"text"},{"inlineContent":[{"type":"text","text":"and"}],"type":"strong"},{"text":" signals ","type":"text"},{"type":"codeVoice","code":"OUDSTabBar"},{"text":" to hide (or not) its overlay elements","type":"text"},{"text":" ","type":"text"},{"text":"(selected tab indicator and top divider) in sync.","type":"text"}],"variants":[{"paths":["\/documentation\/oudscomponents\/o