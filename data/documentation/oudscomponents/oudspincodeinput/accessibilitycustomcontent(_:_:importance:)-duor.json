"doc://OUDSComponents/documentation/OUDSComponents/OUDSPinCodeInput":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"type":"text","text":"such as a four, six or eight-digit personal identification number (PIN)."},{"type":"text","text":" "},{"type":"text","text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,"},{"type":"text","text":" "},{"type":"text","text":"while supporting smooth keyboard navigation and secured input masking if needed."}],"title":"OUDSPinCodeInput","url":"\/documentation\/oudscomponents\/oudspincodeinput","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSPinCodeInput"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSPinCodeInput"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","role":"collection","type":"topic","kind":"symbol"}}}