},{"text":" ","kind":"text"},{"text":"OUDSPinCodeInput","kind":"identifier"}],"abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"type":"text","text":"such as a four, six or eight-digit personal identification number (PIN)."},{"type":"text","text":" "},{"type":"text","text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,"},{"type":"text","text":" "},{"type":"text","text":"while supporting smooth keyboard navigation and secured input masking if needed."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","role":"collection","type":"topic","title":"Components","images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","identifier":"ic_folder_categories.png","alt":null}}}