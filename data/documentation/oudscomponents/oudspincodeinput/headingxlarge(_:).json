 "},{"type":"text","text":"Because "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"type":"topic","url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"title":"OUDSTheme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSPinCodeInput":{"navigatorTitle":[{"kind":"identifier","text":"OUDSPinCodeInput"}],"kind":"symbol","title":"OUDSPinCodeInput","url":"\/documentation\/oudscomponents\/oudspincodeinput","role":"symbol","abstract":[{"text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,","type":"text"},{"text":" ","type":"text"},{"text":"such as a four, six or eight-digit personal identification number (PIN).","type":"text"},{"text":" ","type":"text"},{"text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,","type":"text"},{"text":" ","type":"text"},{"text":"while supporting smooth keyboard navigation and secured input masking if needed.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSPinCodeInput"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","abstract":[{"type