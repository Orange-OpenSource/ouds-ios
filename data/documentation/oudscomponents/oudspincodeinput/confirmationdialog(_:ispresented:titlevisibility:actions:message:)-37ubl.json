"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSPinCodeInput":{"abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"text":"such as a four, six or eight-digit personal identification number (PIN).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,"},{"type":"text","text":" "},{"type":"text","text":"while supporting smooth keyboard navigation and secured input masking if needed."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSPinCodeInput"}],"url":"\/documentation\/oudscomponents\/oudspincodeinput","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSPinCodeInput"}],"title":"OUDSPinCodeInput","type":"topic","role":"symbol"}}}