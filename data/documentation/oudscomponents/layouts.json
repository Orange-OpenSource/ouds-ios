nents/documentation/OUDSComponents/OUDSLink":{"navigatorTitle":[{"text":"OUDSLink","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudslink","role":"symbol","type":"topic","title":"OUDSLink","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLink","kind":"identifier"}],"abstract":[{"type":"text","text":"Link is a UI element that allows to navigate from one location to another, either within the same page or across different pages in the same resource,"},{"type":"text","text":" "},{"type":"text","text":"or to an external resource."},{"type":"text","text":" "},{"type":"text","text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"navigatorTitle":[{"text":"OUDSVerticalDivider","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsverticaldivider","role":"symbol","type":"topic","title":"OUDSVerticalDivider","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSVerticalDivider","kind":"identifier"}],"abstract":[{"text":"Divider is a UI element that allows to structure the content by visually separating the content zones.","type":"text"},{"text":" ","type":"text"},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"text":" ","type":"text"},{"text":"A vertical Divider is used to separate content laid out side by side (","type":"text"},{"type":"codeVoice","code":"HStack"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"The divider can be colored using dedicated ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference","isActive":true},{"text":" colors.","type":"text"},{"text":" ","type":"text"},{"text":"The thickness (width) is fixed by dedicated token from ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"navigatorTitle":[{"text":"OUDSDividerColor","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsdividercolor","role":"symbol","type":"topic","title":"OUDSDividerColor","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSDividerColor","kind":"identifier"}],"abstract":[{"text":"List of colors available for dividers (i.e. ","type":"text"},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"OUDSVerticalDivider"},{"text":")","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","kind":"symbol"},"component_coloredSurface_OrangeCompact":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_OrangeCompact.png"}],"identifier":"component_coloredSurface_OrangeCompact","alt":"A colored surface with text, button and link in light and dark modes with Orange Compact theme","type":"image"},"https://accessibilite.numerique.gouv.fr/":{"title":"Référentiel Général d’Amélioration de l’Accessibilité","url":"https:\/\/accessibilite.numerique.gouv.fr\/","identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"type":"link"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSHorizontalDivider":{"navigatorTitle":[{"text":"OUDSHorizontalDivider","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudshorizontaldivider","role":"symbol","type":"topic","title":"OUDSHorizontalDivider","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSHorizontalDivider","kind":"identifier"}],"abstract":[{"text":"Divider is a UI element that allows to structure the content by visually separating the content zones.","type":"text"},{"text":" ","type":"text"},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"text":" ","type":"text"},{"text":"A horizontal Divider is used to separate content laid out one under the other (","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"The divider can be colored using dedicated ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference","isActive":true},{"text":" colors.","type":"text"},{"text":" ","type":"text"},{"text":"The thickness (height) is fixed by dedicated token from ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"url":"\/documentation\/oudscomponents\/oudscoloredsurface","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"topic","abstract":[{"type":"text","text":"Used to define if a content is used on a colored surface."}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSColoredSurface","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSColoredSurface","kind":"identifier"}],"title":"OUDSColoredSurface"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","role":"collection","type":"topic","title":"Components","images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"component_horizontalDivider_OrangeCompact":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_OrangeCompact.png"}],"identifier":"component_horizontalDivider_OrangeCompact","alt":"An horizontal divider in light and dark modes with Orange Compact theme","type":"image"},"component_horizontalDivider_Wireframe":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Wireframe.png"}],"identifier":"component_horizontalDivider_Wireframe","alt":"An horizontal divider in light and dark modes with Wireframe theme","type":"image"},"component_horizontalDivider_Sosh":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Sosh.png"}],"identifier":"component_horizontalDivider_Sosh","alt":"An horizontal divider in light and dark modes with Sosh theme","type":"image"},"component_verticalDivider_OrangeCompact":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_OrangeCompact.png"}],"identifier":"component_verticalDivider_OrangeCompact","alt":"An vertical divider in light and dark modes with Orange Compact theme","type":"image"},"component_coloredSurface_Sosh":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_Sosh.png"}],"identifier":"component_coloredSurface_Sosh","alt":"A colored surface with text, button and link in light and dark modes with Sosh theme","type":"image"},"component_coloredSurface_Wireframe":{"identifier":"component_coloredSurface_Wireframe","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Wireframe.png","traits":["1x","light"]}],"alt":"A colored surface with text, button and link in light and dark modes with Wireframe theme"},"component_horizontalDivider_Orange":{"identifier":"component_horizontalDivider_Orange","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Orange.png"}],"alt":"An horizontal divider in light and dark modes with Orange theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"url":"\/documentation\/oudscomponents\/oudsbutton","kind":"symbol","abstract":[{"text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action.","type":"text"},{"text":" ","type":"text"},{"text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis.","type":"text"}],"role":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"title":"OUDSButton","navigatorTitle":[{"kind":"identifier","text":"OUDSButton"}]}}}