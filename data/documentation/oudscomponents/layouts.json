{"kind":"article","identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"anchor":"Colored-Surface","level":3,"text":"Colored Surface","type":"heading"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Wireframe"}]}]}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":") are automatically adjusted if they are placed on "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"inlineContent":[{"type":"text","text":"Mono"}],"type":"emphasis"},{"type":"text","text":" suffix (for instance "},{"inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}],"type":"emphasis"},{"type":"text","text":" of "},{"inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}],"type":"emphasis"},{"type":"text","text":")."}],"type":"paragraph"},{"anchor":"How-it-works","level":4,"text":"How it works","type":"heading"},{"inlineContent":[{"type":"text","text":"According to the color, the "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"text":": to inform a component it is placed on colored surface even if the mono is off","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"How-to-use","level":4,"text":"How to use","type":"heading"},{"code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"syntax":"swift","type":"codeListing"},{"anchor":"Debuging-contrast-ratios","level":4,"text":"Debuging contrast ratios","type":"heading"},{"inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"isActive":true,"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr\/"},{"type":"text","text":", also named “RGAA”."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some components like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":" can be used on "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Get the environement variable defined by the colored surface containing the applied color","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In the component implementation, add a line of code comparing the color to test and that surface","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call","type":"text"}]}]}],"type":"unorderedList"},{"code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"syntax":"swift","type":"codeListing"},{"anchor":"Divider","level":3,"text":"Divider","type":"heading"},{"anchor":"How-it-works","level":4,"text":"How it works","type":"heading"},{"inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider"},{"text":": to separate elements stacked vertically (e.g. in ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider"},{"text":": to separate elements stacked horizontally (e.g. in `HStack)","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"code":"OUDSDividerColor","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Horizontal","level":5,"text":"Horizontal","type":"heading"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}]}]}],"type":"tabNavigator"},{"anchor":"Vertical","level":5,"text":"Vertical","type":"heading"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}]}]}],"type":"tabNavigator"},{"anchor":"How-to-use","level":4,"text":"How to use","type":"heading"},{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"syntax":"swift","type":"codeListing"}]}],"sections":[],"metadata":{"modules":[{"name":"Components"}],"role":"article","roleHeading":"Article","title":"Layouts","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"layouts"}],"type":"strong"},{"text":".","type":"text"}],"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"component_horizontalDivider_Sosh":{"type":"image","identifier":"component_horizontalDivider_Sosh","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Sosh.png"}],"alt":"An horizontal divider in light and dark modes with Sosh theme"},"component_horizontalDivider_Orange":{"type":"image","identifier":"component_horizontalDivider_Orange","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Orange.png"}],"alt":"An horizontal divider in light and dark modes with Orange theme"},"component_verticalDivider_Orange":{"type":"image","identifier":"component_verticalDivider_Orange","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Orange.png"}],"alt":"An vertical divider in light and dark modes with Orange theme"},"component_coloredSurface_Sosh":{"type":"image","identifier":"component_coloredSurface_Sosh","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_Sosh.png"}],"alt":"A colored surface with text, button and link in light and dark modes with Sosh theme"},"ic_folder_categories.png":{"type":"image","identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"alt":null},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","navigatorTitle":[{"text":"OUDSVerticalDivider","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsverticaldivider","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSVerticalDivider","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"text":" ","type":"text"},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"text":").","type":"text"},{"type":"text","text":" "},{"text":"The divider can be colored using dedicated ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor"},{"type":"text","text":" colors."},{"text":" ","type":"text"},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"}],"kind":"symbol","title":"OUDSVerticalDivider","role":"symbol"},"component_horizontalDivider_OrangeCompact":{"type":"image","identifier":"component_horizontalDivider_OrangeCompact","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_OrangeCompact.png"}],"alt":"An horizontal divider in light and dark modes with Orange Compact theme"},"component_coloredSurface_Orange":{"type":"image","identifier":"component_coloredSurface_Orange","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_Orange.png"}],"alt":"A colored surface with text, button and link in light and dark modes with Orange theme"},"component_horizontalDivider_Wireframe":{"type":"image","identifier":"component_horizontalDivider_Wireframe","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Wireframe.png"}],"alt":"An horizontal divider in light and dark modes with Wireframe theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"title":"OUDSDividerColor","role":"symbol","abstract":[{"type":"text","text":"List of colors available for dividers (i.e. "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" or "},{"type":"codeVoice","code":"OUDSVerticalDivider"},{"type":"text","text":")"}],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","url":"\/documentation\/oudscomponents\/oudsdividercolor","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSDividerColor","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"OUDSDividerColor","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","title":"OUDSButton","url":"\/documentation\/oudscomponents\/oudsbutton","abstract":[{"type":"text","text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action."},{"type":"text","text":" "},{"type":"text","text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis."}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSButton"}]},"component_coloredSurface_OrangeCompact":{"type":"image","identifier":"component_coloredSurface_OrangeCompact","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_colo