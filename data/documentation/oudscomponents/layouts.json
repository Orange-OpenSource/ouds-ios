"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"type":"topic","title":"Components","role":"collection"},"component_horizontalDivider_Wireframe":{"identifier":"component_horizontalDivider_Wireframe","type":"image","alt":"An horizontal divider in light and dark mode with Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Wireframe.png","traits":["1x","light"]}]},"https://accessibilite.numerique.gouv.fr/":{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","url":"https:\/\/accessibilite.numerique.gouv.fr\/","type":"link","title":"Référentiel Général d’Amélioration de l’Accessibilité","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}]}}}