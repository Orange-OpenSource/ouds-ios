{"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"layouts"}]},{"type":"text","text":"."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"heading","level":3,"text":"Colored Surface","anchor":"Colored-Surface"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeCompact"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Wireframe"}]}],"title":"Wireframe"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":") are automatically adjusted if they are placed on "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Mono"}]},{"text":" suffix (for instance ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}]},{"text":" of ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}]},{"type":"text","text":")."}]},{"type":"heading","level":4,"text":"How it works","anchor":"How-it-works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the color, the "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"oudsUseMonochrome","type":"codeVoice"},{"type":"text","text":": to inform a component that needs to use mono version of tokens"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}]}]}]},{"anchor":"How-to-use","level":4,"type":"heading","text":"How to use"},{"syntax":"swift","type":"codeListing","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"]},{"anchor":"Debuging-contrast-ratios","level":4,"type":"heading","text":"Debuging contrast ratios"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","type":"reference","isActive":true},{"type":"text","text":", also named “RGAA”."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some components like "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":" can be used on "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Get the environement variable defined by the colored surface containing the applied color","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call","type":"text"}]}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"]},{"type":"heading","level":3,"text":"Divider","anchor":"Divider"},{"type":"heading","level":4,"text":"How it works","anchor":"How-it-works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider"},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true,"type":"reference"},{"text":": to separate elements stacked horizontally (e.g. in `HStack)","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"type":"codeVoice","code":"OUDSDividerColor"},{"type":"text","text":"."}]},{"type":"heading","level":5,"text":"Horizontal","anchor":"Horizontal"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_OrangeCompact","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Sosh"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Wireframe","type":"image"}]}],"title":"Wireframe"}]},{"type":"heading","level":5,"text":"Vertical","anchor":"Vertical"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_OrangeCompact","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Wireframe","type":"image"}]}],"title":"Wireframe"}]},{"type":"heading","level":4,"text":"How to use","anchor":"How-to-use"},{"type":"codeListing","syntax":"swift","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"]}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"title":"Layouts","roleHeading":"Article","modules":[{"name":"Components"}],"role":"article","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}]},"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"references":{"component_verticalDivider_Sosh":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Sosh.png"}],"identifier":"component_verticalDivider_Sosh","alt":"An vertical divider in light and dark modes with Sosh theme"},"component_coloredSurface_Orange":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_Orange.png"}],"identifier":"component_coloredSurface_Orange","alt":"A colored surface with text, button and link in light and dark modes with Orange theme"},"component_verticalDivider_Wireframe":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Wireframe.png"}],"identifier":"component_verticalDivider_Wireframe","alt":"An vertical divider in light and dark modes with Wireframe theme"},"component_horizontalDivider_Orange":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Orange.png"}],"identifier":"component_horizontalDivider_Orange","alt":"An horizontal divider in light and dark modes with Orange theme"},"component_coloredSurface_Sosh":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_Sosh.png"}],"identifier":"component_coloredSurface_Sosh","alt":"A colored surface with text, button and link in light and dark modes with Sosh theme"},"component_horizontalDivider_Wireframe":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Wireframe.png"}],"identifier":"component_horizontalDivider_Wireframe","alt":"An horizontal divider in light and dark modes with Wireframe theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"code":"HStack","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference"},{"text":" colors.","type":"text"},{"type":"text","text":" "},{"text":"The thickness (width) is fixed by dedicated token from ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","url":"\/documentation\/oudscomponents\/oudsverticaldivider","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSVerticalDivider"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","kind":"symbol","title":"OUDSVerticalDivider","role":"symbol","navigatorTitle":[{"text":"OUDSVerticalDivider","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"OUDSDividerColor"}],"kind":