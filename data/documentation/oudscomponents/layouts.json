{"sections":[],"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"layouts","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"anchor":"Colored-Surface","type":"heading","level":3,"text":"Colored Surface"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}]}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeBusinessTools"}]}]},{"title":"Sosh","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Sosh","type":"image"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Wireframe"}]}]}]},{"inlineContent":[{"text":"Colored backgrounds use surface colors to maximize the contrast with content.","type":"text"},{"text":" ","type":"text"},{"text":"The colors of several OUDS components (for instance ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"text":" or ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"text":") are automatically adjusted if they are placed on ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"To do so, some tokens associated with these specific colors can be customized and are identified with the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Mono"}]},{"text":" suffix (for instance ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}]},{"text":" of ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OrangeThemeButtonComponentTokensProvider","type":"text"}]},{"text":").","type":"text"}],"type":"paragraph"},{"anchor":"How-it-works","type":"heading","level":4,"text":"How it works"},{"inlineContent":[{"text":"According to the color, the ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":" component adds in SwiftUI environment two flags:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"oudsUseMonochrome","type":"codeVoice"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"oudsOnColoredSurface","type":"codeVoice"},{"text":": to inform a component it is placed on colored surface even if the mono is off","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"How-to-use","type":"heading","level":4,"text":"How to use"},{"type":"codeListing","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .oudsForegroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .oudsForegroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .oudsColoredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"syntax":"swift"},{"anchor":"Debuging-contrast-ratios","type":"heading","level":4,"text":"Debuging contrast ratios"},{"inlineContent":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","isActive":true},{"text":", also named “RGAA”.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"inlineContent":[{"text":"Some components like ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true,"type":"reference"},{"text":" can be used on ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true,"type":"reference"},{"text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Get the environement variable defined by the colored surface containing the applied color"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"codeListing","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"syntax":"swift"},{"anchor":"Divider","type":"heading","level":3,"text":"Divider"},{"anchor":"How-it-works","type":"heading","level":4,"text":"How it works"},{"inlineContent":[{"text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true,"type":"reference"},{"text":": to separate elements stacked horizontally (e.g. in `HStack)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"A divider can be colored using color enumerated in the ","type":"text"},{"type":"codeVoice","code":"OUDSDividerColor"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Horizontal","type":"heading","level":5,"text":"Horizontal"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}]}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_OrangeBusinessTools"}],"type":"paragraph"}],"title":"Orange Business Tools"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"inlineContent":[{"identifier":"component_horizontalDivider_Wireframe","type":"image"}],"type":"paragraph"}],"title":"Wireframe"}]},{"anchor":"Vertical","type":"heading","level":5,"text":"Vertical"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}]}]},{"title":"Orange Business Tools","content":[{"inlineContent":[{"identifier":"component_verticalDivider_OrangeBusinessTools","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}],"type":"paragraph"}]}]},{"anchor":"How-to-use","type":"heading","level":4,"text":"How to use"},{"type":"tabNavigator","tabs":[{"title":"SwiftUI","content":[{"type":"codeListing","syntax":"swift","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"]}]},{"title":"UIKit (experimental)","content":[{"code":["import OUDSComponentsUIKit","    ","\/\/ Add a vertical divider between items","OUDSUIKit.createVerticalDivider(color: .brandPrimary)","    ","\/\/ Add an horizontal divider between items","OUDSUIKit.createHorizontalDivider(color: .brandPrimary)"],"syntax":"swift","type":"codeListing"}]}]}]}],"metadata":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"modules":[{"name":"Components"}],"roleHeading":"Article","title":"Layouts","role":"article"},"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://OUDSComponents/documentation/OUDSComponents":{"role":"collection","title":"Components","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"type":"topic","url":"\/documentation\/oudscomponents","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"type":"topic","title":"OUDSButton","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"t