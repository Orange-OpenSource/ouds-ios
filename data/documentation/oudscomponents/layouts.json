onents/OUDSLink":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Link is a UI element that allows to navigate from one location to another, either within the same page or across different pages in the same resource,"},{"type":"text","text":" "},{"type":"text","text":"or to an external resource."},{"type":"text","text":" "},{"type":"text","text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically."}],"title":"OUDSLink","url":"\/documentation\/oudscomponents\/oudslink","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLink","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSLink","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action."},{"type":"text","text":" "},{"type":"text","text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis."}],"title":"OUDSButton","url":"\/documentation\/oudscomponents\/oudsbutton","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSButton"}]},"component_verticalDivider_Wireframe":{"type":"image","alt":"An vertical divider in light and dark modes with Wireframe theme","identifier":"component_verticalDivider_Wireframe","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Wireframe.png","traits":["1x","light"]}]},"component_coloredSurface_Wireframe":{"type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Wireframe.png","traits":["1x"