{"metadata":{"role":"article","title":"Layouts","modules":[{"name":"Components"}],"images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"roleHeading":"Article"},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/layouts"]}],"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"layouts"}]},{"type":"text","text":"."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"heading","level":3,"text":"Colored Surface","anchor":"Colored-Surface"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeCompact"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}]},{"inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":") are automatically adjusted if they are placed on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"inlineContent":[{"text":"Mono","type":"text"}],"type":"emphasis"},{"type":"text","text":" suffix (for instance "},{"inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}],"type":"emphasis"},{"text":" of ","type":"text"},{"inlineContent":[{"text":"OrangeThemeButtonComponentTokensProvider","type":"text"}],"type":"emphasis"},{"text":").","type":"text"}],"type":"paragraph"},{"anchor":"How-it-works","type":"heading","level":4,"text":"How it works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the color, the "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":" component adds in SwiftUI environment two flags:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"oudsOnColoredSurface","type":"codeVoice"},{"text":": to inform a component it is placed on colored surface even if the mono is off","type":"text"}]}]}]},{"type":"heading","text":"How to use","level":4,"anchor":"How-to-use"},{"type":"codeListing","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .oudsForegroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .oudsForegroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .oudsColoredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"syntax":"swift"},{"type":"heading","level":4,"anchor":"Debuging-contrast-ratios","text":"Debuging contrast ratios"},{"inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"isActive":true,"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr\/"},{"type":"text","text":", also named “RGAA”."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some components like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"text":" or ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"text":" can be used on ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Get the environement variable defined by the colored surface containing the applied color","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"syntax":"swift"},{"text":"Divider","level":3,"type":"heading","anchor":"Divider"},{"text":"How it works","level":4,"type":"heading","anchor":"How-it-works"},{"type":"paragraph","inlineContent":[{"text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true,"type":"reference"},{"text":": to separate elements stacked vertically (e.g. in ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","type":"reference"},{"text":": to separate elements stacked horizontally (e.g. in `HStack)","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"A divider can be colored using color enumerated in the ","type":"text"},{"type":"codeVoice","code":"OUDSDividerColor"},{"text":".","type":"text"}],"type":"paragraph"},{"level":5,"type":"heading","text":"Horizontal","anchor":"Horizontal"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}]}]},{"title":"Orange Compact","content":[{"inlineContent":[{"identifier":"component_horizontalDivider_OrangeCompact","type":"image"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Sosh","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"anchor":"Vertical","type":"heading","text":"Vertical","level":5},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}]}]},{"title":"Orange Compact","content":[{"inlineContent":[{"identifier":"component_verticalDivider_OrangeCompact","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}]}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}],"type":"paragraph"}]}]},{"text":"How to use","level":4,"type":"heading","anchor":"How-to-use"},{"type":"tabNavigator","tabs":[{"title":"SwiftUI","content":[{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"type":"codeListing","syntax":"swift"}]}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"kind":"article","references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSVerticalDivider"}],"title":"OUDSVerticalDivider","url":"\/documentation\/oudscomponents\/oudsverticaldivider","role":