:"symbol","title":"OUDSLink","navigatorTitle":[{"text":"OUDSLink","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLink","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"navigatorTitle":[{"text":"OUDSColoredSurface","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSColoredSurface","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudscoloredsurface","type":"topic","role":"symbol","title":"OUDSColoredSurface","abstract":[{"text":"Used to define if a content is used on a colored surface.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},"component_verticalDivider_OrangeCompact":{"type":"image","identifier":"component_verticalDivider_OrangeCompact","alt":"An vertical divider in light and dark modes with Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_OrangeCompact.png","traits":["1x","light"]}]}}}