tifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSVerticalDivider","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/oudscomponents\/oudsverticaldivider","title":"OUDSVerticalDivider","role":"symbol","navigatorTitle":[{"text":"OUDSVerticalDivider","kind":"identifier"}],"abstract":[{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"code":"HStack","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."}]},"component_verticalDivider_Orange":{"type":"image","alt":"An vertical divider in light and dark mode with Orange theme","identifier":"component_verticalDivider_Orange","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Orange.png"}]},"component_verticalDivider_Wireframe":{"type":"image","alt":"An vertical divider in light and dark mode with Wireframe theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Wireframe.png"}],"identifier":"component_verticalDivider_Wireframe"},"component_verticalDivider_OrangeBusinessTools":{"type":"image","alt":"An vertical divider in light and dark mode with Orange Business Tools theme","identifier":"component_verticalDivider_OrangeBusinessTools","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_OrangeBusinessTools.png"}]},"component_coloredSurface_Orange":{"type":"image","alt":"A colored surface with text, bu