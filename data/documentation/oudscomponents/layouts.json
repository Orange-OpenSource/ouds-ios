{"metadata":{"roleHeading":"Article","role":"article","title":"Layouts","modules":[{"name":"Components"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}]},"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/layouts"]}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"anchor":"Colored-Surface","text":"Colored Surface","type":"heading","level":3},{"tabs":[{"content":[{"inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeCompact"}],"type":"paragraph"}],"title":"Orange Compact"},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Sosh","type":"image"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Wireframe"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"text":"Colored backgrounds use surface colors to maximize the contrast with content.","type":"text"},{"text":" ","type":"text"},{"text":"The colors of several OUDS components (for instance ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"text":" or ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"text":") are automatically adjusted if they are placed on ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"To do so, some tokens associated with these specific colors can be customized and are identified with the ","type":"text"},{"inlineContent":[{"text":"Mono","type":"text"}],"type":"emphasis"},{"text":" suffix (for instance ","type":"text"},{"inlineContent":[{"text":"colorBgDefaultEnabledMono","type":"text"}],"type":"emphasis"},{"text":" of ","type":"text"},{"inlineContent":[{"text":"OrangeThemeButtonComponentTokensProvider","type":"text"}],"type":"emphasis"},{"text":").","type":"text"}],"type":"paragraph"},{"anchor":"How-it-works","text":"How it works","type":"heading","level":4},{"inlineContent":[{"text":"According to the color, the ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":" component adds in SwiftUI environment two flags:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"text":": to inform a component it is placed on colored surface even if the mono is off","type":"text"}]}]}]},{"anchor":"How-to-use","text":"How to use","type":"heading","level":4},{"syntax":"swift","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"type":"codeListing"},{"anchor":"Debuging-contrast-ratios","text":"Debuging contrast ratios","type":"heading","level":4},{"inlineContent":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","type":"reference","isActive":true},{"text":", also named “RGAA”.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Some components like ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"text":" or ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"text":" can be used on ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To do that, some steps must be followed in your component implementation:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Get the environement variable defined by the colored surface containing the applied color","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In the component implementation, add a line of code comparing the color to test and that surface","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call","type":"text"}]}]}]},{"syntax":"swift","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"type":"codeListing"},{"anchor":"Divider","text":"Divider","type":"heading","level":3},{"anchor":"How-it-works","text":"How it works","type":"heading","level":4},{"inlineContent":[{"text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true},{"text":": to separate elements stacked vertically (e.g. in ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true},{"text":": to separate elements stacked horizontally (e.g. in `HStack)","type":"text"}]}]}]},{"inlineContent":[{"text":"A divider can be colored using color enumerated in the ","type":"text"},{"type":"codeVoice","code":"OUDSDividerColor"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Horizontal","text":"Horizontal","type":"heading","level":5},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_OrangeCompact"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Sosh"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"anchor":"Vertical","text":"Vertical","type":"heading","level":5},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_OrangeCompact"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"anchor":"How-to-use","text":"How to use","type":"heading","level":4},{"syntax":"swift","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"layouts","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"component_verticalDivider_Sosh":{"alt":"An vertical divider in light and dark modes with Sosh theme","identifier":"component_verticalDivider_Sosh","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Sosh.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"role":"symbol","navigatorTitle":[{"text":"OUDSLink","kind":"identifier"}],"title":"OUDSLink","kind":"symbol","abstract":[{"text":"Link is a UI element that allows to navigate from one location to another, either within the same page or across different pages in the same resource,","type":"text"},{"text":" ","type":"text"},{"text":"or to an external resource.","type":"text"},{"text":" ","type":"text"},{"text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","url":"\/documentation\/oudscomponents\/oudslink","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLink","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"role":"symbol","navigatorTitle":[{"text":"OUDSVerticalDivider","kind":"identifier"}],"title":"OUDSVerticalDivider","type":"topic","abstract":[{"tex