{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"modules":[{"name":"Components"}],"roleHeading":"Article","title":"Layouts","role":"article","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}]},"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"sections":[],"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"layouts"}],"type":"strong"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"heading","anchor":"Colored-Surface","text":"Colored Surface","level":3},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"identifier":"component_coloredSurface_OrangeCompact","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Sosh","type":"image"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Wireframe","type":"image"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"type":"text","text":") are automatically adjusted if they are placed on "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"inlineContent":[{"text":"Mono","type":"text"}],"type":"emphasis"},{"text":" suffix (for instance ","type":"text"},{"inlineContent":[{"text":"colorBgDefaultEnabledMono","type":"text"}],"type":"emphasis"},{"text":" of ","type":"text"},{"inlineContent":[{"text":"OrangeThemeButtonComponentTokensProvider","type":"text"}],"type":"emphasis"},{"type":"text","text":")."}]},{"level":4,"text":"How it works","anchor":"How-it-works","type":"heading"},{"inlineContent":[{"type":"text","text":"According to the color, the "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"oudsUseMonochrome","type":"codeVoice"},{"type":"text","text":": to inform a component that needs to use mono version of tokens"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"oudsOnColoredSurface","type":"codeVoice"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}]}]}],"type":"unorderedList"},{"level":4,"text":"How to use","anchor":"How-to-use","type":"heading"},{"syntax":"swift","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .oudsForegroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .oudsForegroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .oudsColoredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"type":"codeListing"},{"level":4,"text":"Debuging contrast ratios","anchor":"Debuging-contrast-ratios","type":"heading"},{"inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","isActive":true,"type":"reference"},{"type":"text","text":", also named “RGAA”."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some components like "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"type":"text","text":" can be used on "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Get the environement variable defined by the colored surface containing the applied color"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"swift","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"type":"codeListing"},{"level":3,"text":"Divider","anchor":"Divider","type":"heading"},{"level":4,"text":"How it works","anchor":"How-it-works","type":"heading"},{"inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true,"type":"reference"},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true,"type":"reference"},{"type":"text","text":": to separate elements stacked horizontally (e.g. in `HStack)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"code":"OUDSDividerColor","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":5,"text":"Horizontal","anchor":"Horizontal","type":"heading"},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_horizontalDivider_Orange","type":"image"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"identifier":"component_horizontalDivider_OrangeCompact","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"identifier":"component_horizontalDivider_Sosh","type":"image"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"inlineContent":[{"identifier":"component_horizontalDivider_Wireframe","type":"image"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"level":5,"text":"Vertical","anchor":"Vertical","type":"heading"},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_verticalDivider_Orange","type":"image"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"identifier":"component_verticalDivider_OrangeCompact","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"identifier":"component_verticalDivider_Sosh","type":"image"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"inlineContent":[{"identifier":"component_verticalDivider_Wireframe","type":"image"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"level":4,"text":"How to use","anchor":"How-to-use","type":"heading"},{"tabs":[{"title":"SwiftUI","content":[{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"type":"codeListing","syntax":"swift"}]}],"type":"tabNavigator"}]}],"references":{"component_verticalDivider_OrangeCompact":{"identifier":"component_verticalDivider_OrangeCompact","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_OrangeCompact.png","traits":["1x","light"]}],"type":"image","alt":"An vertical divider in light and dark modes with Orange Compact theme"},"component_coloredSurface_Wireframe":{"identifier":"component_coloredSurface_Wireframe","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Wireframe.png","traits":["1x","light"]}],"type":"image","alt":"A colored surface with text, button and link in light and dark modes with Wireframe theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","title":"OUDSLink","url":"\/documentation\/oudscomponents\/oudslink","navigatorTitle":[{"kind":"identifier","text":"OUDSLink"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSLink"}],"abstract":[{"type":"text","text":"Link is a UI element that allows to navigate from one location to another, either within the same page or across different pages in the same resource,"},{"type":"text","text":" "},{"type":"text","text":"or to an external resource."},{"type":"text","text":" "},{"type":"text","text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically."},{"type":"text","text":" "},{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true,"type":"reference"},{"type":"text","text":" proposes layout with text only or text with icon."},{"type":"text","text":" "},{"type":"text","text":"It also proposes layout to navigate forward or backward. The link can be displayed in "},{"code":"small","type":"codeVoice"},{"type":"text","text":" or "},{"code":"default","type":"codeVoice"},{"text":" size.","type":"text"}],"type":"topic"},"component_horizontalDivider_OrangeCompact":{"identifier":"component_horizontalDivider_OrangeCompact","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_OrangeCompact.png","traits":["1x","light"]}],"type":"image","alt":"An horizontal divider in light and dark modes with Orange Compact theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"role":"symbol","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"OUDSVerticalDivider"}],"abstract":[{"text":"Divider is a UI element that allows to structure the content by visually separating the content zones.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"text":" ","type":"text"},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"text":"The divider can be colored using dedicated ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true},{"text":" colors.","type":"text"},{"type":"text","text":" "},{"text":"The thickness (width) is fixed by dedicated token from ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","url":"\/documentation\/oudscomponents\/oudsverticaldivider","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSVerticalDivider"}],"title":"OUDSVerticalDivider"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","url":"\/documentation\/oudscomponents\/oudscoloredsurface","role":"symbol","title":"OUDSColoredSurface","navigatorTitle":[{"kind":"identifier","text":"OUDSColoredSurface"}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSColoredSurface"}],"abstract":[{"text":"Used to define if a content is used on a colored surface.","type":"text"}],"kind":"symbol"},"component_coloredSurface_Sosh":{"identifier":"component_coloredSurface_Sosh","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Sosh.png","traits":["1x","light"]}],"type":"image","alt":"A colored surface with text, button and link in light and dark modes with Sosh theme"},"component_coloredSurface_OrangeCompact":{"identifier":"component_coloredSurface_OrangeCompact","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_OrangeCompact.png","traits":["1x","light"]}],"type":"image","alt":"A colored surface with text, button and link in light and dark modes with Orange Compact theme"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","alt":null},"component_verticalDivider_Orange":{"identifier":"component_verticalDivider_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Orange.png","traits":["1x","light"]}],"type":"image","alt":"An vertical divider in light and dark modes with Orange theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","url":"\/documentation\/oudscomponents\/oudsdividercolor","role":"symbol","title":"OUDSDividerColor","navigatorTitle":[{"kind":"identifier","text":"OUDSDividerColor"}],"type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSDividerColor"}],"abstract":[{"type":"text","text":"List of colors available for dividers (i.e. "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" or "},{"type":"codeVoice","code":"OUDSVerticalDivider"},{"type":"text","text":")"}],"kind":"symbol"},"component_verticalDivider_Wireframe":{"identifier":"component_verticalDivider_Wireframe","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Wireframe.png","traits":["1x","light"]}],"type":"image","alt":"An vertical divider in light and dark modes with Wireframe theme"},"component_coloredSurface_Orange":{"identifier":"component_coloredSurface_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Orange.png","traits":["1x","light"]}],"type":"image","alt":"A colored surface with text, button and link in light and dark modes with Orange theme"},"component_verticalDivider_Sosh":{"identifier":"component_verticalDivider_Sosh","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Sosh.png","traits":["1x","light"]}],"type":"image","alt":"An vertical divider in light and dark modes with Sosh theme"},"doc://OUDSComponents/documentation/OUDSComponents":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","url":"\/documentation\/oudscomponents","role":"collection","title":"Components","type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"role":"symbol","kind":"symbol","type":"topic","navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"abstract":[{"type":"text","text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action."},{"type":"text","text":" "},{"type":"text","text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","url":"\/documentation\/oudscomponents\/oudsbutton","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"title":"OUDSButton"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSHorizontalDivider":{"url":"\/documentation\/oudscomponents\/oudshorizontaldivider","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","role":"symbol","title":"OUDSHorizontalDivider","navigatorTitle":[{"text":"OUDSHorizontalDivider","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSHorizontalDivider","kind":"identifier"}],"abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A horizontal Divider is used to separate content laid out one under the other ("},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (height) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"kind":"symbol"},"component_horizontalDivider_Orange":{"identifier":"component_horizontalDivider_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Orange.png","traits":["1x","light"]}],"type":"image","alt":"An horizontal divider in light and dark modes with Orange theme"},"component_horizontalDivider_Wireframe":{"identifier":"component_horizontalDivider_Wireframe","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Wireframe.png","traits":["1x","light"]}],"type":"image","alt":"An horizontal divider in light and dark modes with Wireframe theme"},"https://accessibilite.numerique.gouv.fr/":{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","type":"link","title":"Référentiel Général d’Amélioration de l’Accessibilité","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}],"url":"https:\/\/accessibilite.numerique.gouv.fr\/"},"component_horizontalDivider_Sosh":{"identifier":"component_horizontalDivider_Sosh","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Sosh.png","traits":["1x","light"]}],"type":"image","alt":"An horizontal divider in light and dark modes with Sosh theme"}}}