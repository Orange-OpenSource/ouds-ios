{"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"sections":[],"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"layouts","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"metadata":{"title":"Layouts","roleHeading":"Article","modules":[{"name":"OUDSComponents"}],"role":"article"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"text":"Colored Surface","anchor":"Colored-Surface","level":3,"type":"heading"},{"inlineContent":[{"text":"Colored backgrounds use surface colors to maximize the contrast with content.","type":"text"},{"text":" ","type":"text"},{"text":"The colors of several OUDS components (for instance ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference"},{"text":") are automatically adjusted if they are placed on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"To do so, some tokens associated with these specific colors can be customized and are identified with the ","type":"text"},{"inlineContent":[{"text":"Mono","type":"text"}],"type":"emphasis"},{"text":" suffix (for instance ","type":"text"},{"inlineContent":[{"text":"buttonColorBgDefaultEnabledMono","type":"text"}],"type":"emphasis"},{"text":" of ","type":"text"},{"inlineContent":[{"text":"OrangeThemeButtonComponentTokensProvider","type":"text"}],"type":"emphasis"},{"text":").","type":"text"}],"type":"paragraph"},{"text":"How it works","anchor":"How-it-works","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"According to the color, the "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"oudsUseMonochrome","type":"codeVoice"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}]}]}],"type":"unorderedList"},{"text":"How to use","anchor":"How-to-use","level":4,"type":"heading"},{"syntax":"swift","code":["    \/\/ The folowing view has a colored background \"modeOnStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.modeOnStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .oudsForegroundColor(theme.colors.colorContentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .oudsForegroundColor(theme.colors.colorContentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .oudsColoredSurface(theme.colorModes.modeOnStatusPositiveEmphasized)"],"type":"codeListing"},{"text":"Divider","anchor":"Divider","level":3,"type":"heading"},{"text":"How it works","anchor":"How-it-works","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" To separate elements stacked vertivally (VStask)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"OUDSVerticalDivider","type":"codeVoice"},{"text":" To separate elements stacked Horizontally (HStask).","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"type":"codeVoice","code":"OUDSDividerColor"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"How to use","anchor":"How-to-use","level":4,"type":"heading"},{"syntax":"swift","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello wolrd!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello wolrd!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","references":{"doc://OUDSComponents/documentation/OUDSComponents":{"kind":"symbol","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"type":"topic","role":"collection","url":"\/documentation\/oudscomponents","title":"OUDSComponents","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSColoredSurface","kind":"identifier"}],"title":"OUDSColoredSurface","navigatorTitle":[{"text":"OUDSColoredSurface","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/oudscomponents\/oudscoloredsurface","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Used to define if a content is used on a colored surface."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","title":"OUDSLink","url":"\/documentation\/oudscomponents\/oudslink","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":" proposes layout with text only or text with icon."},{"type":"text","text":" "},{"type":"text","text":"It also proposes layout to navigate forward or backward. The link can be displayed in "},{"type":"codeVoice","code":"small"},{"type":"text","text":" or "},{"type":"codeVoice","code":"default"},{"type":"text","text":" size."}],"type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLink","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSLink","kind":"identifier"}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"navigatorTitle":[{"kind":"identifier","text":"OUDSButton"}],"title":"OUDSButton","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"url":"\/documentation\/oudscomponents\/oudsbutton","role":"symbol","type":"topic","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"text":" proposes layout with text only, icon only or text with icon.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"}}}