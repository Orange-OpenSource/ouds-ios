{"metadata":{"title":"Layouts","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"modules":[{"name":"Components"}],"roleHeading":"Article","role":"article"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"layouts"}]},{"type":"text","text":"."}],"kind":"article","identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"anchor":"Colored-Surface","type":"heading","level":3,"text":"Colored Surface"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Wireframe"}]}]}]},{"inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":") are automatically adjusted if they are placed on "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Mono"}]},{"type":"text","text":" suffix (for instance "},{"type":"emphasis","inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}]},{"type":"text","text":" of "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}]},{"type":"text","text":")."}],"type":"paragraph"},{"anchor":"How-it-works","type":"heading","level":4,"text":"How it works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the color, the "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"type":"text","text":": to inform a component that needs to use mono version of tokens"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}]}]}],"type":"unorderedList"},{"anchor":"How-to-use","type":"heading","level":4,"text":"How to use"},{"syntax":"swift","type":"codeListing","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"]},{"anchor":"Debuging-contrast-ratios","type":"heading","level":4,"text":"Debuging contrast ratios"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/"},{"type":"text","text":", also named “RGAA”."}]},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some components like "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":" can be used on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}]},{"inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the environement variable defined by the colored surface containing the applied color"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call"}]}]}],"type":"unorderedList"},{"type":"codeListing","syntax":"swift","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"]},{"anchor":"Divider","type":"heading","level":3,"text":"Divider"},{"anchor":"How-it-works","type":"heading","level":4,"text":"How it works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true},{"type":"text","text":": to separate elements stacked horizontally (e.g. in `HStack)"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"type":"codeVoice","code":"OUDSDividerColor"},{"type":"text","text":"."}]},{"level":5,"type":"heading","anchor":"Horizontal","text":"Horizontal"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}]}]}]},{"level":5,"type":"heading","anchor":"Vertical","text":"Vertical"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}]}]}]},{"level":4,"type":"heading","anchor":"How-to-use","text":"How to use"},{"syntax":"swift","type":"codeListing","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"]}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSVerticalDivider"}],"kind":"symbol","title":"OUDSVerticalDivider","abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"text":").","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","navigatorTitle":[{"kind":"identifier","text":"OUDSVerticalDivider"}],"url":"\/documentation\/oudscomponents\/oudsverticaldivider","role":"symbol"},"component_coloredSurface_OrangeCompact":{"type":"image","identifier":"component_coloredSurface_OrangeCompact","alt":"A colored surface with text, button and link in light and dark modes with Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_OrangeCompact.png","traits":["1x","light"]}]},"component_horizontalDivider_Sosh":{"type":"image","alt":"An horizontal divider in light and dark modes with Sosh theme","identifier":"component_horizontalDivider_Sosh","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Sosh.png","traits":["1x","light"]}]},"component_verticalDivider_OrangeCompact":{"type":"image","alt":"An vertical divider in light and dark modes with Orange Compact theme","identifier":"component_verticalDivider_OrangeCompact","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_OrangeCompact.png","traits":["1x","light"]}]},"component_coloredSurface_Orange":{"type":"image","identifier":"component_coloredSurface_Orange","alt":"A colored surface with text, button and link in light and dark modes with Orange theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_Orange.png"}]},"component_horizontalDivider_Orange":{"type":"image","alt":"An horizontal divider in light and dark modes with Orange theme","identifier":"component_horizontalDivider_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Orange.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSColoredSurface"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSColoredSurface"}],"title":"OUDSColoredSurface","abstract":[{"text":"Used to define if a content is used on a colored surface.","type"