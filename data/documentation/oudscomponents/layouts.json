{"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"Components"}],"title":"Layouts","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"type":"card","identifier":"ic_folder_categories.png"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts"},"kind":"article","variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"layouts"}],"type":"strong"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"heading","level":3,"text":"Colored Surface","anchor":"Colored-Surface"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}],"type":"paragraph"}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeBusinessTools"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Wireframe","type":"image"}]}],"title":"Wireframe"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":") are automatically adjusted if they are placed on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"inlineContent":[{"type":"text","text":"Mono"}],"type":"emphasis"},{"type":"text","text":" suffix (for instance "},{"inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}],"type":"emphasis"},{"type":"text","text":" of "},{"inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}],"type":"emphasis"},{"type":"text","text":")."}]},{"anchor":"How-it-works","type":"heading","text":"How it works","level":4},{"inlineContent":[{"type":"text","text":"According to the color, the "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"type":"text","text":": to inform a component that needs to use mono version of tokens"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","anchor":"How-to-use","text":"How to use","level":4},{"syntax":"swift","type":"codeListing","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .oudsForegroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .oudsForegroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .oudsColoredSurface(theme.colorModes.onStatusPositiveEmphasized)"]},{"level":4,"text":"Debuging contrast ratios","type":"heading","anchor":"Debuging-contrast-ratios"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","isActive":true,"type":"reference"},{"type":"text","text":", also named “RGAA”."}]},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"text":" ","type":"text"},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some components like "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":" can be used on "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the environement variable defined by the colored surface containing the applied color"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"]},{"level":3,"type":"heading","text":"Divider","anchor":"Divider"},{"level":4,"type":"heading","text":"How it works","anchor":"How-it-works"},{"inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true,"type":"reference"},{"type":"text","text":": to separate elements stacked horizontally (e.g. in `HStack)"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"type":"codeVoice","code":"OUDSDividerColor"},{"text":".","type":"text"}]},{"text":"Horizontal","type":"heading","anchor":"Horizontal","level":5},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}],"type":"paragraph"}]},{"title":"Orange Business Tools","content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_OrangeBusinessTools"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Sosh"}],"type":"paragraph"}],"title":"Sosh"},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}],"type":"paragraph"}]}]},{"level":5,"anchor":"Vertical","type":"heading","text":"Vertical"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}],"type":"paragraph"}],"title":"Orange"},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_OrangeBusinessTools","type":"image"}]}]},{"title":"Sosh","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}],"type":"paragraph"}]}]},{"anchor":"How-to-use","type":"heading","text":"How to use","level":4},{"type":"tabNavigator","tabs":[{"content":[{"syntax":"swift","type":"codeListing","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"]}],"title":"SwiftUI"},{"title":"UIKit (experimental)","content":[{"type":"codeListing","syntax":"swift","code":["import OUDSComponentsUIKit","    ","\/\/ Add a vertical divider between items","OUDSUIKit.createVerticalDivider(color: .brandPrimary)","    ","\/\/ Add an horizontal divider between items","OUDSUIKit.createHorizontalDivider(color: .brandPrimary)"]}]}]}]}],"sections":[],"references":{"doc://OUDSComponents/documentation/OUDSComponents":{"title":"Components","kind":"symbol","role":"collection","url":"\/documentation\/oudscomponents","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}]},"component_horizontalDivider_OrangeBusinessTools":{"type":"image","identifier":"component_horizontalDivider_OrangeBusinessTools","alt":"An horizontal divider in light and dark modes with Orange Business Tools theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSCompo