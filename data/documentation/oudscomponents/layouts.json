{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/layouts"]}],"metadata":{"role":"article","roleHeading":"Article","title":"Layouts","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"modules":[{"name":"Components"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"text":"Colored Surface","type":"heading","level":3,"anchor":"Colored-Surface"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeCompact"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Wireframe","type":"image"}]}]}]},{"inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":") are automatically adjusted if they are placed on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Mono"}]},{"type":"text","text":" suffix (for instance "},{"type":"emphasis","inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}]},{"type":"text","text":" of "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}]},{"type":"text","text":")."}],"type":"paragraph"},{"type":"heading","level":4,"text":"How it works","anchor":"How-it-works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the color, the "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"oudsUseMonochrome","type":"codeVoice"},{"type":"text","text":": to inform a component that needs to use mono version of tokens"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"text":": to inform a component it is placed on colored surface even if the mono is off","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":4,"text":"How to use","anchor":"How-to-use"},{"code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":4,"text":"Debuging contrast ratios","anchor":"Debuging-contrast-ratios"},{"inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","type":"reference","isActive":true},{"type":"text","text":", also named “RGAA”."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"inlineContent":[{"text":"Some components like ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"text":" or ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"text":" can be used on ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To do that, some steps must be followed in your component implementation:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Get the environement variable defined by the colored surface containing the applied color","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call"}]}]}],"type":"unorderedList"},{"type":"codeListing","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"syntax":"swift"},{"level":3,"type":"heading","anchor":"Divider","text":"Divider"},{"level":4,"type":"heading","anchor":"How-it-works","text":"How it works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","type":"reference","isActive":true},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true},{"type":"text","text":": to separate elements stacked horizontally (e.g. in `HStack)"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"A divider can be colored using color enumerated in the ","type":"text"},{"code":"OUDSDividerColor","type":"codeVoice"},{"text":".","type":"text"}]},{"level":5,"type":"heading","anchor":"Horizontal","text":"Horizontal"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_horizontalDivider_Orange","type":"image"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_OrangeCompact"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Sosh"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Wireframe","type":"image"}]}],"title":"Wireframe"}]},{"text":"Vertical","level":5,"type":"heading","anchor":"Vertical"},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_verticalDivider_Orange","type":"image"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"identifier":"component_verticalDivider_OrangeCompact","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}]}]}],"type":"tabNavigator"},{"text":"How to use","level":4,"type":"heading","anchor":"How-to-use"},{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"sections":[],"kind":"article","identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"layouts"}],"type":"strong"},{"text":".","type":"text"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"url":"\/documentation\/oudscomponents","kind":"symbol","type":"topic","role":"collection","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}]},"component_coloredSurface_Wireframe":{"variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Wireframe.png","traits":["1x","light"]}],"identifier":"component_coloredSurface_Wireframe","alt":"A colored surface with text, button and link in light and dark modes with Wireframe theme","type":"image"},"ic_folder_categories.png":{"type":"image","variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png","alt":null},"component_verticalDivider_Orange":{"variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Orange.png","traits":["1x","light"]}],"identifier":"component_verticalDivider_Orange","alt":"An vertical divider in light and dark modes with Orange theme","type":"image"},"component_horizontalDivider_Wireframe":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Wireframe.png"}],"identifier":"component_horizontalDivider_Wireframe","alt":"An horizontal divider in light and dark modes with Wireframe theme"},"component_coloredSurface_Orange":{"type":"image","alt":"A colored surface with text, button and link in light and dark modes with Orange theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_Orange.png"}],"identifier":"component_coloredSurface_Orange"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"kind":"symbol","url":"\/documentation\/oudscomponents\/oudslink","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLink","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"Link is a UI element that allows to navigate from one location to another, either within the same page or across different pages in the same resource,"},{"type":"text","text":" "},{"type":"text","text":"or to an external resource."},{"type":"text","text":" "},{"type":"text","text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically."}],"navigatorTitle":[{"text":"OUDSLink","kind":"identifier"}],"title":"OUDSLink","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},"component_verticalDivider_OrangeCompact":{"variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_OrangeCompact.png","traits":["1x","light"]}],"identifier":"component_verticalDivider_OrangeCompact","type":"image","alt":"An vertical divider in light and dark modes with Orange Compact theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSDividerColor"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSDividerColor"}],"type":"topic","abstract":[{"type":"text","text":"List of colors available for dividers (i.e. "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" or "},{"type":"codeVoice","code":"OUDSVerticalDivider"},{"type":"text","text":")"}],"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","kind":"symbol","url":"\/documentation\/oudscomponents\/oudsdividercolor","title":"OUDSDividerColor"},"component_horizontalDivider_Sosh":{"alt":"An horizontal divider in light and dark modes with Sosh theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Sosh.png"}],"identifier":"component_horizontalDivider_Sosh","type":"image"},"https://accessibilite.numerique.gouv.fr/":{"url":"https:\/\/accessibilite.numerique.gouv.fr\/","title":"Référentiel Général d’Amélioration de l’Accessibilité","identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","type":"link","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}]},"component_coloredSurface_OrangeCompact":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_OrangeCompact.png"}],"alt":"A colored surface with text, button and link in light and dark modes with Orange Compact theme","identifier":"component_coloredSurface_OrangeCompact","type":"image"},"component_horizontalDivider_OrangeCompact":{"type":"image","identifier":"component_horizontalDivider_OrangeCompact","alt":"An horizontal divider in light and dark modes with Orange Compact theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_OrangeCompact.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSVerticalDivider","kind":"identifier"}],"abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor"},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","kind":"symbol","url":"\/documentation\/oudscomponents\/oudsverticaldivider","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","title":"OUDSVerticalDivider","role":"symbol","navigatorTitle":[{"text":"OUDSVerticalDivider","kind":"identifier"}]},"component_verticalDivider_Wireframe":{"identifier":"component_verticalDivider_Wireframe","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Wireframe.png","traits":["1x","light"]}],"type":"image","alt":"An vertical divider in light and dark modes with Wireframe theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"title":"OUDSColoredSurface","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSColoredSurface","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","abstract":[{"text":"Used to define if a content is used on a colored surface.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSColoredSurface"}],"type":"topic","kind":"symbol","url":"\/documentation\/oudscomponents\/oudscoloredsurface"},"component_horizontalDivider_Orange":{"variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Orange.png","traits":["1x","light"]}],"alt":"An horizontal divider in light and dark modes with Orange theme","identifier":"component_horizontalDivider_Orange","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSButton"}],"url":"\/documentation\/oudscomponents\/oudsbutton","kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","title":"OUDSButton","abstract":[{"type":"text","text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action."},{"text":" ","type":"text"},{"type":"text","text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis."}],"navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSHorizontalDivider":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSHorizontalDivider","kind":"identifier"}],"type":"topic","kind":"symbol","url":"\/documentation\/oudscomponents\/oudshorizontaldivider","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","title":"OUDSHorizontalDivider","abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A horizontal Divider is used to separate content laid out one under the other ("},{"code":"VStack","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true,"type":"reference"},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (height) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"navigatorTitle":[{"text":"OUDSHorizontalDivider","kind":"identifier"}]},"component_verticalDivider_Sosh":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Sosh.png"}],"type":"image","identifier":"component_verticalDivider_Sosh","alt":"An vertical divider in light and dark modes with Sosh theme"},"component_coloredSurface_Sosh":{"variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Sosh.png","traits":["1x","light"]}],"type":"image","identifier":"component_coloredSurface_Sosh","alt":"A colored surface with text, button and link in light and dark modes with Sosh theme"}}}