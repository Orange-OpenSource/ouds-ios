ce,"},{"type":"text","text":" "},{"type":"text","text":"or to an external resource."},{"type":"text","text":" "},{"type":"text","text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically."}],"navigatorTitle":[{"text":"OUDSLink","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","url":"\/documentation\/oudscomponents\/oudslink","role":"symbol","title":"OUDSLink"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSHorizontalDivider":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSHorizontalDivider"}],"abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A horizontal Divider is used to separate content laid out one under the other ("},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true,"type":"reference"},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (height) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"navigatorTitle":[{"kind":"identifier","text":"OUDSHorizontalDivider"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","url":"\/documentation\/oudscomponents\/oudshorizontaldivider","role":"symbol","title":"OUDSHorizontalDivider"},"doc://OUDSComponents/documentation/OUDSComponents":{"kind":"symbol","role":"collection","title":"Components","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","type":"topic","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"url":"\/documentation\/oudscomponents","images":[{"type":"icon","identifier":"ic_folder_categories.png"}]},"https://accessibilite.numerique.gouv.fr/":{"type":"link","identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","title":"Référentiel Général d’Amélioration de l’Accessibilité","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}],"url":"https:\/\/accessibilite.numerique.gouv.fr\/"},"component_verticalDivider_Sosh":{"type":"image","identifier":"component_verticalDivider_Sosh","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Sosh.png"}],"alt":"An vertical divider in light and dark modes with Sosh theme"}}}