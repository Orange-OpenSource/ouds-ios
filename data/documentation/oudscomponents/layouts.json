{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"roleHeading":"Article","role":"article","title":"Layouts","modules":[{"name":"OUDSComponents"}]},"kind":"article","sections":[],"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"text":"layouts","type":"text"}]},{"type":"text","text":"."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"level":3,"text":"Colored Surface","anchor":"Colored-Surface","type":"heading"},{"inlineContent":[{"text":"Colored backgrounds use surface colors to maximize the contrast with content.","type":"text"},{"text":" ","type":"text"},{"text":"The colors of several OUDS components (for instance ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true,"type":"reference"},{"type":"text","text":") are automatically adjusted if they are placed on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"inlineContent":[{"type":"text","text":"Mono"}],"type":"emphasis"},{"text":" suffix (for instance ","type":"text"},{"inlineContent":[{"type":"text","text":"buttonColorBgDefaultEnabledMono"}],"type":"emphasis"},{"text":" of ","type":"text"},{"inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}],"type":"emphasis"},{"text":").","type":"text"}],"type":"paragraph"},{"level":4,"type":"heading","text":"How it works","anchor":"How-it-works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the color, the "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"type":"text","text":": to inform a component that needs to use mono version of tokens"}]}]},{"content":[{"inlineContent":[{"code":"oudsOnColoredSurface","type":"codeVoice"},{"text":": to inform a component it is placed on colored surface even if the mono is off","type":"text"}],"type":"paragraph"}]}]},{"level":4,"type":"heading","text":"How to use","anchor":"How-to-use"},{"type":"codeListing","code":["    \/\/ The folowing view has a colored background \"modeOnStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.modeOnStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .oudsForegroundColor(theme.colors.colorContentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .oudsForegroundColor(theme.colors.colorContentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .oudsColoredSurface(theme.colorModes.modeOnStatusPositiveEmphasized)"],"syntax":"swift"},{"level":3,"type":"heading","text":"Divider","anchor":"Divider"},{"level":4,"type":"heading","text":"How it works","anchor":"How-it-works"},{"type":"paragraph","inlineContent":[{"text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" To separate elements stacked vertivally (VStask)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"OUDSVerticalDivider","type":"codeVoice"},{"text":" To separate elements stacked Horizontally (HStask).","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"type":"codeVoice","code":"OUDSDividerColor"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"How to use","type":"heading","level":4,"anchor":"How-to-use"},{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello wolrd!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello wolrd!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"type":"codeListing","syntax":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/layouts"]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSColoredSurface","kind":"identifier"}],"title":"OUDSColoredSurface","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSColoredSurface"}],"abstract":[{"type":"text","text":"Used to define if a content is used on a colored surface."}],"role":"symbol","url":"\/documentation\/oudscomponents\/oudscoloredsurface","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","role":"symbol","url":"\/documentation\/oudscomponents\/oudsbutton","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"kind":"symbol","title":"OUDSButton","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" proposes layout with text only, icon only or text with icon."}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":" proposes layout with text only or text with icon."},{"type":"text","text":" "},{"type":"text","text":"It also proposes layout to navigate forward or backward. The link can be displayed in "},{"type":"codeVoice","code":"small"},{"type":"text","text":" or "},{"type":"codeVoice","code":"default"},{"type":"text","text":" size."}],"navigatorTitle":[{"kind":"identifier","text":"OUDSLink"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","title":"OUDSLink","url":"\/documentation\/oudscomponents\/oudslink","role":"symbol","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSLink"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"title":"OUDSComponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"role":"collection","type":"topic","url":"\/documentation\/oudscomponents","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","kind":"symbol"}}}