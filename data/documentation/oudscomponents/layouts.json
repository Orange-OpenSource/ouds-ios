{"metadata":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"type":"card","identifier":"ic_folder_categories.png"}],"role":"article","title":"Layouts","modules":[{"name":"Components"}],"roleHeading":"Article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/layouts"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"layouts"}]},{"text":".","type":"text"}],"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"text":"Colored Surface","anchor":"Colored-Surface","level":3,"type":"heading"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Wireframe"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Colored backgrounds use surface colors to maximize the contrast with content.","type":"text"},{"text":" ","type":"text"},{"text":"The colors of several OUDS components (for instance ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"text":" or ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"text":") are automatically adjusted if they are placed on ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"To do so, some tokens associated with these specific colors can be customized and are identified with the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Mono","type":"text"}]},{"text":" suffix (for instance ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"colorBgDefaultEnabledMono","type":"text"}]},{"text":" of ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OrangeThemeButtonComponentTokensProvider","type":"text"}]},{"text":").","type":"text"}]},{"text":"How it works","anchor":"How-it-works","level":4,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"According to the color, the ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":" component adds in SwiftUI environment two flags:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"type":"text","text":": to inform a component that needs to use mono version of tokens"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}]}]}],"type":"unorderedList"},{"text":"How to use","anchor":"How-to-use","level":4,"type":"heading"},{"code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"type":"codeListing","syntax":"swift"},{"text":"Debuging contrast ratios","anchor":"Debuging-contrast-ratios","level":4,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","isActive":true,"type":"reference"},{"type":"text","text":", also named “RGAA”."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some components like "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"text":" can be used on ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Get the environement variable defined by the colored surface containing the applied color","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"In the component implementation, add a line of code comparing the color to test and that surface","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"]},{"type":"heading","level":3,"text":"Divider","anchor":"Divider"},{"text":"How it works","type":"heading","level":4,"anchor":"How-it-works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","type":"reference","isActive":true},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"type":"codeVoice","code":"VStack"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","type":"reference","isActive":true},{"text":": to separate elements stacked horizontally (e.g. in `HStack)","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"type":"codeVoice","code":"OUDSDividerColor"},{"type":"text","text":"."}]},{"text":"Horizontal","type":"heading","level":5,"anchor":"Horizontal"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_OrangeCompact","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}]}]}],"type":"tabNavigator"},{"anchor":"Vertical","level":5,"type":"heading","text":"Vertical"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}]}]}]},{"anchor":"How-to-use","level":4,"type":"heading","text":"How to use"},{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"kind":"article","references":{"component_coloredSurface_Wireframe":{"type":"image","identifier":"component_coloredSurface_Wireframe","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Wireframe.png","traits":["1x","light"]}],"alt":"A colored surface with text, button and link in light and dark modes with Wireframe theme"},"component_verticalDivider_Orange":{"alt":"An vertical divider in light and dark modes with Orange theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Orange.png"}],"type":"image","identifier":"component_verticalDivider_Orange"},"https://accessibilite.numerique.gouv.fr/":{"url":"https:\/\/accessibilite.numerique.gouv.fr\/","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","title":"Référentiel Général d’Amélioration de l’Accessibilité","type":"link"},"ic_folder_categories.png":{"alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","identifier":"ic_folder_categories.png"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","abstract":[{"type":"text","text":"Divider is a UI element that allow