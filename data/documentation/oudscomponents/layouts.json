s":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","identifier":"ic_folder_categories.png","alt":null},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"navigatorTitle":[{"text":"OUDSVerticalDivider","kind":"identifier"}],"abstract":[{"text":"A vertical Divider is used to separate content laid out side by side (","type":"text"},{"code":"HStack","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"The divider can be colored using dedicated ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true,"type":"reference"},{"text":" colors.","type":"text"},{"text":" ","type":"text"},{"text":"The thickness (width) is fixed by dedicated token from ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"}],"url":"\/documentation\/oudscomponents\/oudsverticaldivider","role":"symbol","title":"OUDSVerticalDivider","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","kind":"symbol","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSVerticalDivider","kind":"identifier"}]},"component_verticalDivider_Wireframe":{"variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Wireframe.png","traits":["1x","light"]}],"type":"image","identifier":"component_verticalDivider_Wireframe","alt":"An vertical divider in light and dark modes with Wireframe theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","title":"OUDSLink","navigatorTitle":[{"kind":"identifier","text":"OUDSLink"}],"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":" proposes layout 