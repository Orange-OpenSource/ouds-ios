{"metadata":{"role":"article","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"modules":[{"name":"Components"}],"title":"Layouts","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"text":"layouts","type":"text"}]},{"type":"text","text":"."}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"text":"Colored Surface","type":"heading","anchor":"Colored-Surface","level":3},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeCompact"}]}],"title":"Orange Compact"},{"title":"Sosh","content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Wireframe"}]}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"type":"text","text":") are automatically adjusted if they are placed on "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"type":"emphasis","inlineContent":[{"text":"Mono","type":"text"}]},{"type":"text","text":" suffix (for instance "},{"type":"emphasis","inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}]},{"type":"text","text":" of "},{"type":"emphasis","inlineContent":[{"text":"OrangeThemeButtonComponentTokensProvider","type":"text"}]},{"type":"text","text":")."}]},{"level":4,"text":"How it works","anchor":"How-it-works","type":"heading"},{"inlineContent":[{"type":"text","text":"According to the color, the "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"oudsUseMonochrome","type":"codeVoice"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}]}]}]},{"anchor":"How-to-use","type":"heading","level":4,"text":"How to use"},{"code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"type":"codeListing","syntax":"swift"},{"anchor":"Debuging-contrast-ratios","type":"heading","level":4,"text":"Debuging contrast ratios"},{"inlineContent":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","isActive":true,"type":"reference"},{"text":", also named “RGAA”.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some components like "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":" can be used on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}],"type":"paragraph"},{"inlineContent":[{"text":"To do that, some steps must be followed in your component implementation:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the environement variable defined by the colored surface containing the applied color"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In the component implementation, add a line of code comparing the color to test and that surface","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call","type":"text"}]}]}],"type":"unorderedList"},{"type":"codeListing","syntax":"swift","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"]},{"text":"Divider","level":3,"anchor":"Divider","type":"heading"},{"text":"How it works","level":4,"anchor":"How-it-works","type":"heading"},{"inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","type":"reference"},{"text":": to separate elements stacked vertically (e.g. in ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true},{"type":"text","text":": to separate elements stacked horizontally (e.g. in `HStack)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"type":"codeVoice","code":"OUDSDividerColor"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Horizontal","type":"heading","level":5,"anchor":"Horizontal"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_OrangeCompact","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Sosh","type":"image"}]}],"title":"Sosh"},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}],"type":"paragraph"}]}]},{"level":5,"type":"heading","anchor":"Vertical","text":"Vertical"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_OrangeCompact"}]}],"title":"Orange Compact"},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Wireframe","type":"image"}]}]}]},{"level":4,"anchor":"How-to-use","type":"heading","text":"How to use"},{"type":"codeListing","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/layouts"]}],"sections":[],"references":{"component_horizontalDivider_OrangeCompact":{"type":"image","identifier":"component_horizontalDivider_OrangeCompact","alt":"An horizontal divider in light and dark modes with Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_OrangeCompact.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"navigatorTitle":[{"kind":"identifier","text":"OUDSVerticalDivider"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSVerticalDivider"}],"url":"\/documentation\/oudscomponents\/oudsverticaldivider","type":"topic","role":"symbol","title":"OUDSVerticalDivider","abstract":[{"text":"Divider is a UI element that allows to structure the content by visually separating the content zones.","type":"text"},{"text":" ","type":"text"},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"text":" ","type":"text"},{"text":"A vertical Divider is used to separate content laid out side by side (","type":"text"},{"type":"codeVoice","code":"HStack"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"The divider can be colored using dedicated ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference","isActive":true},{"text":" colors.","type":"text"},{"text":" ","type":"text"},{"text":"The thickness (width) is fixed by dedicated token from ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider"},"component_coloredSurface_OrangeCompact":{"identifier":"component_coloredSurface_OrangeCompact","alt":"A colored surface with text, button and link in light and dark modes with Orange Compact theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_OrangeCompact.png"}],"type":"image"},"component_verticalDivider_Wireframe":{"identifier":"component_verticalDivider_Wireframe","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Wireframe.png"}],"alt":"An vertical divider in light and dark modes with Wireframe theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSHorizontalDivider":{"navigatorTitle":[{"kind":"identifier","text":"OUDSHorizontalDivider"}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSHorizontalDivider"}],"abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A horizontal Divider is used to separate content laid out one under the other ("},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (height) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"kind":"symbol","title":"OUDSHorizontalDivider","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","url":"\/documentation\/oudscomponents\/oudshorizontaldivider","role":"symbol"},"component_coloredSurface_Sosh":{"identifier":"component_coloredSurface_Sosh","alt":"A colored surface with text, button and link in light and dark modes with Sosh theme","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Sosh.png","traits":["1x","light"]}]},"component_coloredSurface_Orange":{"type":"image","identifier":"component_coloredSurface_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Orange.png","traits":["1x","light"]}],"alt":"A colored surface with text, button and link in light and dark modes with Orange theme"},"component_coloredSurface_Wireframe":{"type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Wireframe.png","traits":["1x","light"]}],"identifier":"component_coloredSurface_Wireframe","alt":"A colored surface with text, button and link in light and dark modes with Wireframe theme"},"component_horizontalDivider_Sosh":{"type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Sosh.png","traits":["1x","light"]}],"identifier":"component_horizontalDivider_Sosh","alt":"An horizontal divider in light and dark modes with Sosh theme"},"component_verticalDivider_Sosh":{"type":"image","identifier":"component_verticalDivider_Sosh","alt":"An vertical divider in light and dark modes with Sosh theme","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Sosh.png","traits":["1x","light"]}]},"component_horizontalDivider_Orange":{"type":"image","identifier":"component_horizontalDivider_Orange","alt":"An horizontal divider in light and dark modes with Orange theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Orange.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"url":"\/documentation\/oudscomponents\/oudsbutton","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"OUDSButton"}],"role":"symbol","abstract":[{"type":"text","text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action."},{"type":"text","text":" "},{"type":"text","text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis."}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","title":"OUDSButton"},"doc://OUDSComponents/documentation/OUDSComponents":{"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol","url":"\/documentation\/oudscomponents","type":"topic","role":"collection","title":"Components","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"ic_folder_categories.png":{"type":"image","alt":null,"identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"url":"\/documentation\/oudscomponents\/oudsdividercolor","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"