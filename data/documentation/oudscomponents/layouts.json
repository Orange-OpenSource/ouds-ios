rColor","type":"reference","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."}],"title":"OUDSVerticalDivider","url":"\/documentation\/oudscomponents\/oudsverticaldivider","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSVerticalDivider"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSVerticalDivider"}],"role":"symbol"},"component_coloredSurface_Sosh":{"type":"image","alt":"A colored surface with text, button and link in light and dark modes with Sosh theme","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Sosh.png","traits":["1x","light"]}],"identifier":"component_coloredSurface_Sosh"},"component_coloredSurface_Wireframe":{"type":"image","alt":"A colored surface with text, button and link in light and dark modes with Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Wireframe.png","traits":["1x","light"]}],"identifier":"component_coloredSurface_Wireframe"}}}