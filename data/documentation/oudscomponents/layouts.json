{"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"kind":"article","metadata":{"roleHeading":"Article","title":"Layouts","modules":[{"name":"Components"}],"role":"article","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}]},"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"text":"layouts","type":"text"}]},{"type":"text","text":"."}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"anchor":"Colored-Surface","type":"heading","level":3,"text":"Colored Surface"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_OrangeCompact","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Wireframe","type":"image"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Colored backgrounds use surface colors to maximize the contrast with content.","type":"text"},{"text":" ","type":"text"},{"text":"The colors of several OUDS components (for instance ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference"},{"text":") are automatically adjusted if they are placed on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"To do so, some tokens associated with these specific colors can be customized and are identified with the ","type":"text"},{"inlineContent":[{"text":"Mono","type":"text"}],"type":"emphasis"},{"text":" suffix (for instance ","type":"text"},{"inlineContent":[{"text":"colorBgDefaultEnabledMono","type":"text"}],"type":"emphasis"},{"text":" of ","type":"text"},{"inlineContent":[{"text":"OrangeThemeButtonComponentTokensProvider","type":"text"}],"type":"emphasis"},{"text":").","type":"text"}]},{"anchor":"How-it-works","type":"heading","level":4,"text":"How it works"},{"type":"paragraph","inlineContent":[{"text":"According to the color, the ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":" component adds in SwiftUI environment two flags:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"oudsUseMonochrome","type":"codeVoice"},{"type":"text","text":": to inform a component that needs to use mono version of tokens"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"oudsOnColoredSurface","type":"codeVoice"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}]}]}]},{"anchor":"How-to-use","type":"heading","level":4,"text":"How to use"},{"code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"syntax":"swift","type":"codeListing"},{"anchor":"Debuging-contrast-ratios","type":"heading","level":4,"text":"Debuging contrast ratios"},{"type":"paragraph","inlineContent":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","type":"reference"},{"text":", also named “RGAA”.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Some components like ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference"},{"text":" can be used on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference"},{"text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To do that, some steps must be followed in your component implementation:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the environement variable defined by the colored surface containing the applied color"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call"}]}]}]},{"code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"syntax":"swift","type":"codeListing"},{"anchor":"Divider","type":"heading","level":3,"text":"Divider"},{"anchor":"How-it-works","type":"heading","level":4,"text":"How it works"},{"type":"paragraph","inlineContent":[{"text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true,"type":"reference"},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true,"type":"reference"},{"type":"text","text":": to separate elements stacked horizontally (e.g. in `HStack)"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"A divider can be colored using color enumerated in the ","type":"text"},{"code":"OUDSDividerColor","type":"codeVoice"},{"text":".","type":"text"}]},{"anchor":"Horizontal","type":"heading","level":5,"text":"Horizontal"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Orange","type":"image"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_OrangeCompact","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Wireframe","type":"image"}]}]}]},{"anchor":"Vertical","type":"heading","level":5,"text":"Vertical"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Orange","type":"image"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_OrangeCompact","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Wireframe","type":"image"}]}]}]},{"anchor":"How-to-use","type":"heading","level":4,"text":"How to use"},{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"syntax":"swift","type":"codeListing"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"references":{"component_coloredSurface_OrangeCompact":{"variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_OrangeCompact.png","traits":["1x","light"]}],"identifier":"component_coloredSurface_OrangeCompact","type":"image","alt":"A colored surface with text, button and link in light and dark modes with Orange Compact theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"type":"topic","abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text",