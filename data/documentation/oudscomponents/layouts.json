{"metadata":{"role":"article","modules":[{"name":"Components"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"roleHeading":"Article","title":"Layouts"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"kind":"article","abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"layouts"}],"type":"strong"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"text":"Colored Surface","level":3,"anchor":"Colored-Surface","type":"heading"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}]}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_OrangeBusinessTools","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Wireframe","type":"image"}]}]}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":") are automatically adjusted if they are placed on "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"inlineContent":[{"type":"text","text":"Mono"}],"type":"emphasis"},{"type":"text","text":" suffix (for instance "},{"inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}],"type":"emphasis"},{"type":"text","text":" of "},{"inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}],"type":"emphasis"},{"type":"text","text":")."}],"type":"paragraph"},{"text":"How it works","level":4,"anchor":"How-it-works","type":"heading"},{"inlineContent":[{"type":"text","text":"According to the color, the "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"oudsUseMonochrome","type":"codeVoice"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"oudsOnColoredSurface","type":"codeVoice"},{"text":": to inform a component it is placed on colored surface even if the mono is off","type":"text"}]}]}],"type":"unorderedList"},{"text":"How to use","level":4,"anchor":"How-to-use","type":"heading"},{"syntax":"swift","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .oudsForegroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .oudsForegroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .oudsColoredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"type":"codeListing"},{"text":"Debuging contrast ratios","level":4,"anchor":"Debuging-contrast-ratios","type":"heading"},{"inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","isActive":true},{"type":"text","text":", also named “RGAA”."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some components like "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":" can be used on "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Get the environement variable defined by the colored surface containing the applied color","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In the component implementation, add a line of code comparing the color to test and that surface","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call","type":"text"}]}]}],"type":"unorderedList"},{"syntax":"swift","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"type":"codeListing"},{"text":"Divider","level":3,"anchor":"Divider","type":"heading"},{"text":"How it works","level":4,"anchor":"How-it-works","type":"heading"},{"inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","type":"reference"},{"text":": to separate elements stacked vertically (e.g. in ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","type":"reference"},{"text":": to separate elements stacked horizontally (e.g. in `HStack)","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"code":"OUDSDividerColor","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Horizontal","level":5,"anchor":"Horizontal","type":"heading"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Orange","type":"image"}]}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_OrangeBusinessTools","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Wireframe","type":"image"}]}]}],"type":"tabNavigator"},{"text":"Vertical","level":5,"anchor":"Vertical","type":"heading"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Orange","type":"image"}]}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_OrangeBusinessTools","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Wireframe","type":"image"}]}]}],"type":"tabNavigator"},{"text":"How to use","level":4,"anchor":"How-to-use","type":"heading"},{"tabs":[{"title":"SwiftUI","content":[{"type":"codeListing","syntax":"swift","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"]}]},{"title":"UIKit (experimental)","content":[{"type":"codeListing","syntax":"swift","code":["import OUDSComponentsUIKit","    ","\/\/ Add a vertical divider between items","OUDSUIKit.createVerticalDivider(color: .brandPrimary)","    ","\/\/ Add an horizontal divider between items","OUDSUIKit.createHorizontalDivider(color: .brandPrimary)"]}]}],"type":"tabNavigator"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/layouts"]}],"references":{"component_horizontalDivider_Sosh":{"variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Sosh.png","traits":["1x","light"]}],"type":"image","identifier":"component_horizontalDivider_Sosh","alt":"An horizontal divider in light and dark modes with Sosh theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"url":"\/documentation\/oudscomponents\/oudscoloredsurface","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSColoredSurface","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSColoredSurface","kind":"identifier"}],"type":"topic","title":"OUDSColoredSurface","abstract":[{"text":"Used to define if a content is used on a colored surface.","type":"text"}],"kind":"symbol"},"component_coloredSurface_So