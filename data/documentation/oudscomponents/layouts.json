d it communicates its interactive nature visually and semantically.","type":"text"}],"type":"topic","url":"\/documentation\/oudscomponents\/oudslink","kind":"symbol","title":"OUDSLink","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLink","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSLink","kind":"identifier"}],"role":"symbol"},"component_verticalDivider_OrangeCompact":{"type":"image","alt":"An vertical divider in light and dark modes with Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_OrangeCompact.png","traits":["1x","light"]}],"identifier":"component_verticalDivider_OrangeCompact"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"navigatorTitle":[{"kind":"identifier","text":"OUDSDividerColor"}],"title":"OUDSDividerColor","type":"topic","role":"symbol","url":"\/documentation\/oudscomponents\/oudsdividercolor","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","abstract":[{"type":"text","text":"List of colors available for dividers (i.e. "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" or "},{"type":"codeVoice","code":"OUDSVerticalDivider"},{"type":"text","text":")"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSDividerColor"}]},"component_verticalDivider_Sosh":{"type":"image","alt":"An vertical divider in light and dark modes with Sosh theme","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Sosh.png","traits":["1x","light"]}],"identifier":"component_verticalDivider_Sosh"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","abstract":[{"text":"Used to define if a content is used on a colored surface.","type":"text"}],"type":"topic","url":"\/documentation\/oudscomponents\/oudscolor