{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"layouts"}],"type":"strong"},{"text":".","type":"text"}],"kind":"article","metadata":{"roleHeading":"Article","title":"Layouts","role":"article","modules":[{"name":"Components"}],"images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}]},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"text":"Colored Surface","anchor":"Colored-Surface","level":3,"type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_Orange"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeCompact"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"type":"text","text":") are automatically adjusted if they are placed on "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Mono"}]},{"type":"text","text":" suffix (for instance "},{"type":"emphasis","inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}]},{"type":"text","text":" of "},{"type":"emphasis","inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}]},{"type":"text","text":")."}],"type":"paragraph"},{"text":"How it works","anchor":"How-it-works","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"According to the color, the "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"type":"text","text":": to inform a component that needs to use mono version of tokens"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"How to use","anchor":"How-to-use","level":4,"type":"heading"},{"code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"type":"codeListing","syntax":"swift"},{"text":"Debuging contrast ratios","anchor":"Debuging-contrast-ratios","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","type":"reference","isActive":true},{"type":"text","text":", also named “RGAA”."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some components like "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"type":"text","text":" can be used on "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference","isActive":true},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Get the environement variable defined by the colored surface containing the applied color"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"type":"codeListing","syntax":"swift"},{"text":"Divider","anchor":"Divider","level":3,"type":"heading"},{"text":"How it works","anchor":"How-it-works","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true},{"type":"text","text":": to separate elements stacked horizontally (e.g. in `HStack)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"type":"codeVoice","code":"OUDSDividerColor"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Horizontal","anchor":"Horizontal","level":5,"type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_OrangeCompact"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Sosh"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"text":"Vertical","anchor":"Vertical","level":5,"type":"heading"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_OrangeCompact"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}],"type":"paragraph"}]}]},{"text":"How to use","anchor":"How-to-use","level":4,"type":"heading"},{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"component_horizontalDivider_Wireframe":{"type":"image","identifier":"component_horizontalDivider_Wireframe","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_horizontalDivider_Wireframe.png"}],"alt":"An horizontal divider in light and dark modes with Wireframe theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"url":"\/documentation\/oudscomponents\/oudslink","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","navigatorTitle":[{"text":"OUDSLink","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSLink","kind":"identifier"}],"kind":"symbol","title":"OUDSLink","abstract":[{"type":"text","text":"Link is a UI element that allows to navigate from one location to another, either within the same page or across different pages in the same resource,"},{"type":"text","text":" "},{"type":"text","text":"or to an external resource."},{"type":"text","text":" "},{"type":"text","text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically."}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSButton":{"kind":"symbol","abstract":[{"type":"text","text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action."},{"type":"text","text":" "},{"type":"text","text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis."}],"url":"\/documentation\/oudscomponents\/oudsbutton","type":"topic","title":"OUDSButton","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","role":"symbol"},"component_coloredSurface_OrangeCompact":{"type":"image","identifier":"component_coloredSurface_OrangeCompact","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_OrangeCompact.png"}],"alt":"A colored surface with text, button and link in light and dark modes with Orange Compact theme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSColoredSurface":{"kind":"symbol","type":"topic","abstract":[{"text":"Used to define if a content is used on a colored surface.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudscoloredsurface","title":"OUDSColoredSurface","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSColoredSurface","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSColoredSurface","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"kind":"symbol","type":"topic","url":"\/documentation\/oudscomponents\/oudsdividercolor","abstract":[{"type":"text","text":"List of colors available for dividers (i.e. "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" or "},{"type":"codeVoice","code":"OUDSVerticalDivider"},{"type":"text","text":")"}],"title":"OUDSDividerColor","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSDividerColor","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSDividerColor","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","role":"symbol"},"component_coloredSurface_Orange":{"type":"image","identifier":"component_coloredSurface_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Orange.png","traits":["1x","light"]}],"alt":"A colored surface with text, button and link in light and dark modes with Orange theme"},"component_horizontalDivider_OrangeCompact":{"alt":"An horizontal divider in light and dark modes with Orange Compact theme","type":"image","identifier":"component_horizontalDivider_OrangeCompact","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_OrangeCompact.png","traits":["1x","light"]}]},"component_horizontalDivider_Orange":{"alt":"An horizontal divider in light and dark modes with Orange theme","type":"image","identifier":"component_horizontalDivider_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Orange.png","traits":["1x","light"]}]},"https://accessibilite.numerique.gouv.fr/":{"title":"Référentiel Général d’Amélioration de l’Accessibilité","type":"link","titleInlineContent":[{"type":"text","text":"Référentiel Général d’Amélioration de l’Accessibilité"}],"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","url":"https:\/\/accessibilite.numerique.gouv.fr\/"},"component_verticalDivider_Orange":{"alt":"An vertical divider in light and dark modes with Orange theme","type":"image","identifier":"component_verticalDivider_Orange","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Orange.png","traits":["1x","light"]}]},"component_coloredSurface_Wireframe":{"alt":"A colored surface with text, button and link in light and dark modes with Wireframe theme","type":"image","identifier":"component_coloredSurface_Wireframe","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Wireframe.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"kind":"symbol","type":"topic","url":"\/documentation\/oudscomponents\/oudsverticaldivider","abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"title":"OUDSVerticalDivider","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSVerticalDivider","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSVerticalDivider","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"kind":"symbol","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"url":"\/documentation\/oudscomponents","type":"topic","title":"Components","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","role":"collection"},"component_coloredSurface_Sosh":{"alt":"A colored surface with text, button and link in light and dark modes with Sosh theme","type":"image","identifier":"component_coloredSurface_Sosh","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_Sosh.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSHorizontalDivider":{"title":"OUDSHorizontalDivider","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","kind":"symbol","abstract":[{"text":"Divider is a UI element that allows to structure the content by visually separating the content zones.","type":"text"},{"text":" ","type":"text"},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"text":" ","type":"text"},{"text":"A horizontal Divider is used to separate content laid out one under the other (","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"The divider can be colored using dedicated ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true,"type":"reference"},{"text":" colors.","type":"text"},{"text":" ","type":"text"},{"text":"The thickness (height) is fixed by dedicated token from ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSHorizontalDivider","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSHorizontalDivider","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudshorizontaldivider","role":"symbol","type":"topic"},"component_horizontalDivider_Sosh":{"alt":"An horizontal divider in light and dark modes with Sosh theme","type":"image","identifier":"component_horizontalDivider_Sosh","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_Sosh.png","traits":["1x","light"]}]},"component_verticalDivider_Wireframe":{"alt":"An vertical divider in light and dark modes with Wireframe theme","type":"image","identifier":"component_verticalDivider_Wireframe","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Wireframe.png","traits":["1x","light"]}]},"component_verticalDivider_OrangeCompact":{"alt":"An vertical divider in light and dark modes with Orange Compact theme","type":"image","identifier":"component_verticalDivider_OrangeCompact","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_OrangeCompact.png","traits":["1x","light"]}]},"ic_folder_categories.png":{"alt":null,"type":"image","identifier":"ic_folder_categories.png","variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]},"component_verticalDivider_Sosh":{"alt":"An vertical divider in light and dark modes with Sosh theme","type":"image","identifier":"component_verticalDivider_Sosh","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Sosh.png","traits":["1x","light"]}]}}}