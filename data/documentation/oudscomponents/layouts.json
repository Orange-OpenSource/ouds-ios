{"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"Components"}],"images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"roleHeading":"Article","role":"article","title":"Layouts"},"abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"layouts"}]},{"text":".","type":"text"}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"anchor":"Colored-Surface","text":"Colored Surface","level":3,"type":"heading"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_OrangeCompact","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}]}],"title":"Sosh"},{"title":"Wireframe","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Wireframe","type":"image"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Colored backgrounds use surface colors to maximize the contrast with content.","type":"text"},{"type":"text","text":" "},{"text":"The colors of several OUDS components (for instance ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference"},{"type":"text","text":" or "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference"},{"type":"text","text":") are automatically adjusted if they are placed on "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"inlineContent":[{"type":"text","text":"Mono"}],"type":"emphasis"},{"type":"text","text":" suffix (for instance "},{"inlineContent":[{"type":"text","text":"colorBgDefaultEnabledMono"}],"type":"emphasis"},{"type":"text","text":" of "},{"inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}],"type":"emphasis"},{"type":"text","text":")."}]},{"type":"heading","anchor":"How-it-works","level":4,"text":"How it works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the color, the "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":" component adds in SwiftUI environment two flags:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"text":": to inform a component it is placed on colored surface even if the mono is off","type":"text"}]}]}]},{"anchor":"How-to-use","type":"heading","text":"How to use","level":4},{"code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"syntax":"swift","type":"codeListing"},{"level":4,"type":"heading","text":"Debuging contrast ratios","anchor":"Debuging-contrast-ratios"},{"inlineContent":[{"type":"text","text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services."},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","type":"reference"},{"type":"text","text":", also named “RGAA”."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some components like "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference"},{"type":"text","text":" or "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference"},{"type":"text","text":" can be used on "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","type":"reference"},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To do that, some steps must be followed in your component implementation:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Get the environement variable defined by the colored surface containing the applied color"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call"}],"type":"paragraph"}]}]},{"code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"syntax":"swift","type":"codeListing"},{"level":3,"type":"heading","text":"Divider","anchor":"Divider"},{"level":4,"type":"heading","text":"How it works","anchor":"How-it-works"},{"inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","isActive":true},{"type":"text","text":": to separate elements stacked horizontally (e.g. in `HStack)"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"A divider can be colored using color enumerated in the "},{"code":"OUDSDividerColor","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Horizontal","type":"heading","text":"Horizontal","level":5},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_OrangeCompact"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Sosh"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"level":5,"type":"heading","text":"Vertical","anchor":"Vertical"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_Orange","type":"image"}]}]},{"title":"Orange Compact","content":[{"inlineContent":[{"identifier":"component_verticalDivider_OrangeCompact","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"inlineContent":[{"identifier":"component_verticalDivider_Wireframe","type":"image"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"level":4,"type":"heading","text":"How to use","anchor":"How-to-use"},{"code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"syntax":"swift","type":"codeListing"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"navigatorTitle":[{"kind":"identifier","text":"OUDSVerticalDivider"}],"kind":"symbol","title":"OUDSVerticalDivider","url":"\/documentation\/oudscomponents\/oudsverticaldivider","role":"symbol","abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"text":" ","type":"text"},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"text":" ","type":"text"},{"text":"A vertical Divider is used to separate content laid out side by side (","type":"text"},{"code":"HStack","type":"codeVoice"},{"text":").","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference"},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OUDSVerticalDivider","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","abstract":[{"text":"List of colors available for dividers (i.e. ","type":"text"},{"code":"OUDSHorizontalDivider","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"OUDSVerticalDivider","type":"codeVoice"},{"text":")","type":"text"}],"url":"\/documentation\/oudscomponents\/oudsdividercolor","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSDividerColor"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSDividerColor"}],"title":"OUDSDividerColor"},"component_horizontalDivider_OrangeCompact":{"identifier":"component_horizontalDivider_OrangeCompact","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_OrangeCompact.png","traits":["1x","light"]}],"type":"image","alt":"An horizontal divider in light and dark modes with Orange Compact theme"},"component_coloredSurface_Wireframe":{"identifier":"component_coloredSurface_Wireframe","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_Wireframe.png"}],"alt":"A colored surface with text, button and link in light and dark modes with Wireframe theme","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"role":"collection","images":[{"identifier":"ic_folder_categories.png","type":"icon"}]},"component_coloredSurface_Orange":{"identifier":"component_coloredSurface_Orange","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_Orange.png"}],"alt":"A colored surface with text, button and link in light and dark modes with Orange theme","type":"image"},"component_coloredSurface_OrangeCompact":{"identifier":"component_coloredSurface_OrangeCompact","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_coloredSurface_OrangeCompact.png"}],"alt":"A colored surface with text, button and link in light and dark modes with Orange Compact theme","type":"image"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"alt":null,"type":"image"},"component_verticalDivider_Orange":{"identifier":"component_verticalDivider_Orange","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_verticalDivider_Orange.png"}],"alt":"An vertical divider in light and dark modes with Orange theme","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","abstract":[{"type":"text","text":"Link is a UI element that allows to navigate from one location to another, either within the same page or across different pages in the same resource,"},{"type":"text","text":" "},{"type":"text","text":"or to an external resource."},{"type":"text","text":" "},{"type":"text","text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically."}],"url":"\/documentation\/oudscomponents\/oudslink","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSLink"}],"navigatorTitle":[{"kind":"identifier","text":"O