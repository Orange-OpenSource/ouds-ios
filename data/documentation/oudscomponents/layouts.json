ponent_coloredSurface_Orange.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSHorizontalDivider":{"abstract":[{"text":"Divider is a UI element that allows to structure the content by visually separating the content zones.","type":"text"},{"text":" ","type":"text"},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"text":" ","type":"text"},{"text":"A horizontal Divider is used to separate content laid out one under the other (","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"The divider can be colored using dedicated ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","type":"reference","isActive":true},{"text":" colors.","type":"text"},{"text":" ","type":"text"},{"text":"The thickness (height) is fixed by dedicated token from ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"}],"role":"symbol","type":"topic","title":"OUDSHorizontalDivider","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","url":"\/documentation\/oudscomponents\/oudshorizontaldivider","navigatorTitle":[{"kind":"identifier","text":"OUDSHorizontalDivider"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSHorizontalDivider"}],"kind":"symbol"},"component_verticalDivider_Wireframe":{"identifier":"component_verticalDivider_Wireframe","alt":"An vertical divider in light and dark modes with Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_verticalDivider_Wireframe.png","traits":["1x","light"]}],"type":"image"}}}