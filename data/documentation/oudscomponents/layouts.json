{"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"Components"}],"title":"Layouts","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}]},"sections":[],"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"text":"layouts","type":"text"}]},{"type":"text","text":"."}],"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"text":"Colored Surface","anchor":"Colored-Surface","type":"heading","level":3},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Orange","type":"image"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"identifier":"component_coloredSurface_OrangeCompact","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Sosh","type":"image"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"inlineContent":[{"identifier":"component_coloredSurface_Wireframe","type":"image"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"text":"Colored backgrounds use surface colors to maximize the contrast with content.","type":"text"},{"text":" ","type":"text"},{"text":"The colors of several OUDS components (for instance ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"text":" or ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"text":") are automatically adjusted if they are placed on ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"To do so, some tokens associated with these specific colors can be customized and are identified with the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Mono","type":"text"}]},{"text":" suffix (for instance ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"colorBgDefaultEnabledMono","type":"text"}]},{"text":" of ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"OrangeThemeButtonComponentTokensProvider","type":"text"}]},{"text":").","type":"text"}]},{"text":"How it works","anchor":"How-it-works","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"text":"According to the color, the ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":" component adds in SwiftUI environment two flags:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"text":": to inform a component it is placed on colored surface even if the mono is off","type":"text"}],"type":"paragraph"}]}]},{"text":"How to use","anchor":"How-to-use","type":"heading","level":4},{"type":"codeListing","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .foregroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .foregroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .coloredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"syntax":"swift"},{"text":"Debuging contrast ratios","anchor":"Debuging-contrast-ratios","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"text":" ","type":"text"},{"text":"This is for example the case for France with the ","type":"text"},{"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/","isActive":true,"type":"reference"},{"text":", also named “RGAA”.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron).","type":"text"},{"text":" ","type":"text"},{"text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Some components like ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true,"type":"reference"},{"text":" can be used on ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true,"type":"reference"},{"text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To do that, some steps must be followed in your component implementation:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Get the environement variable defined by the colored surface containing the applied color","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"In the component implementation, add a line of code comparing the color to test and that surface","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"],"syntax":"swift"},{"text":"Divider","anchor":"Divider","type":"heading","level":3},{"text":"How it works","anchor":"How-it-works","type":"heading","level":4},{"type":"paragraph","inlineContent":[{"text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","type":"reference"},{"text":": to separate elements stacked vertically (e.g. in ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","type":"reference"},{"text":": to separate elements stacked horizontally (e.g. in `HStack)","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"A divider can be colored using color enumerated in the ","type":"text"},{"code":"OUDSDividerColor","type":"codeVoice"},{"text":".","type":"text"}]},{"text":"Horizontal","anchor":"Horizontal","type":"heading","level":5},{"tabs":[{"content":[{"inlineContent":[{"identifier":"component_horizontalDivider_Orange","type":"image"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"identifier":"component_horizontalDivider_OrangeCompact","type":"image"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"identifier":"component_horizontalDivider_Sosh","type":"image"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"identifier":"component_horizontalDivider_Wireframe","type":"image"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"text":"Vertical","anchor":"Vertical","type":"heading","level":5},{"tabs":[{"content":[{"inlineContent":[{"identifier":"component_verticalDivider_Orange","type":"image"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"identifier":"component_verticalDivider_OrangeCompact","type":"image"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"identifier":"component_verticalDivider_Sosh","type":"image"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"identifier":"component_verticalDivider_Wireframe","type":"image"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"text":"How to use","anchor":"How-to-use","type":"heading","level":4},{"type":"codeListing","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"],"syntax":"swift"}],"kind":"content"}],"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/layouts"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"references":{"ic_folder_categories.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png"},"https://accessibilite.numerique.gouv.fr/":{"title":"Référentiel Général d’Amélioration de l’Accessibilité","type":"link","titleInlineContent":[{"text":"Référentiel Général d’Amélioration de l’Accessibilité","type":"text"}],"url":"https:\/\/accessibilite.numerique.gouv.fr\/","identifier":"https:\/\/accessibilite.numerique.gouv.fr\/"},"component_coloredSurface_OrangeCompact":{"type":"image","alt":"A colored surface with text, button and link in light and dark modes with Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_coloredSurface_OrangeCompact.png","traits":["1x","light"]}],"identifier":"component_coloredSurface_OrangeCompact"},"component_horizontalDivider_OrangeCompact":{"type":"image","alt":"An horizontal divider in light and dark modes with Orange Compact theme","variants":[{"url":"\/images\/OUDSComponents\/component_horizontalDivider_OrangeCompact.png","traits":["1x","light"]}],"identifier":"component_horizontalDivider_OrangeCompact"},"component_horizontalDivider_Orange":{"type":"image","alt":"An horizontal divider in light and dark modes with Orange theme","variants":[{"url":"\/images\/OUDSComponents\/compone