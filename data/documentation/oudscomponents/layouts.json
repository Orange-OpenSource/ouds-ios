{"variants":[{"paths":["\/documentation\/oudscomponents\/layouts"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"Layouts","role":"article","modules":[{"name":"Components"}],"images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"roleHeading":"Article"},"kind":"article","hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"level":3,"anchor":"Colored-Surface","text":"Colored Surface","type":"heading"},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_Orange"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"image","identifier":"component_coloredSurface_OrangeBusinessTools"}],"type":"paragraph"}],"title":"Orange Business Tools"},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_coloredSurface_Sosh"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_coloredSurface_Wireframe","type":"image"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"Colored backgrounds use surface colors to maximize the contrast with content."},{"type":"text","text":" "},{"type":"text","text":"The colors of several OUDS components (for instance "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true},{"type":"text","text":") are automatically adjusted if they are placed on "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"To do so, some tokens associated with these specific colors can be customized and are identified with the "},{"type":"emphasis","inlineContent":[{"text":"Mono","type":"text"}]},{"text":" suffix (for instance ","type":"text"},{"inlineContent":[{"text":"colorBgDefaultEnabledMono","type":"text"}],"type":"emphasis"},{"text":" of ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OrangeThemeButtonComponentTokensProvider"}]},{"type":"text","text":")."}],"type":"paragraph"},{"anchor":"How-it-works","level":4,"type":"heading","text":"How it works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the color, the "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":" component adds in SwiftUI environment two flags:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsUseMonochrome"},{"text":": to inform a component that needs to use mono version of tokens","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"oudsOnColoredSurface"},{"type":"text","text":": to inform a component it is placed on colored surface even if the mono is off"}]}]}],"type":"unorderedList"},{"type":"heading","level":4,"anchor":"How-to-use","text":"How to use"},{"syntax":"swift","code":["    \/\/ The folowing view has a colored background \"onStatusPositiveEmphasized\" with","    \/\/ - a text with the color adapted according to the adjusted colorScheme      ","    \/\/ - a button that uses the mono version of tokens","","    \/\/ As view","    OUDSColoredSurface(color: theme.colorModes.onStatusPositiveEmphasized) {","        VStack {","            Text(\"Status Positive Emphasized\")","            .oudsForegroundColor(theme.colors.contentDefault)","","            OUDSButton(text: \"Button\") {}","        }","    }","","    \/\/ As view modifier","","    VStack {","        Text(\"Status Positive Emphasized\")","        .oudsForegroundColor(theme.colors.contentDefault)","","        OUDSButton(text: \"Button\") {}","    }","    .oudsColoredSurface(theme.colorModes.onStatusPositiveEmphasized)"],"type":"codeListing"},{"type":"heading","anchor":"Debuging-contrast-ratios","text":"Debuging contrast ratios","level":4},{"type":"paragraph","inlineContent":[{"text":"Some countries set up new laws so as to force companies to have a better accessibility of their digital services.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is for example the case for France with the "},{"type":"reference","isActive":true,"identifier":"https:\/\/accessibilite.numerique.gouv.fr\/"},{"type":"text","text":", also named “RGAA”."}]},{"inlineContent":[{"type":"text","text":"The WCAG specifications, for AA level, defines a contrast ratio of 4.5:1 for textual elements (i.e. texts), and 3:1 for non-textual elements (i.e. link’s chevron)."},{"type":"text","text":" "},{"type":"text","text":"However it is highly recommended for mobile devices to reach AAA level because of the screen sizes and luminosity issues, i.e. 7:1 for texts and 4.5:1 for non-textual elements."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some components like "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"text":" or ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":" can be used on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface"},{"type":"text","text":" ; thus in that case we can know the surface color for a given component on it, and compute the contrast ratio, and in the end display or not warnings."}]},{"type":"paragraph","inlineContent":[{"text":"To do that, some steps must be followed in your component implementation:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Rise the flag to allow debugging (e.g. i #DEBUG mode)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Get the environement variable defined by the colored surface containing the applied color"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the component implementation, add a line of code comparing the color to test and that surface"}]}]},{"content":[{"inlineContent":[{"text":"Then keep an eye on your logs ; warnings will be added there if WCAG 2.1 3:1, 4.5:1 or 7:1 ratios are not reached, depending to the methods you call","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Rise the flag","#if DEBUG","OUDSWCAG21Ratios.oudsDebugWCAG21Colors = true","#endif","","\/\/ Supposing we are in your component View \/ ViewModifer struct","","\/\/ Get the applied surface color","@Environment(\\.oudsSurfaceColor) var surfaceColor","","\/\/ In the function defining the color to apply, add the line below","\/\/ where colorTokenToApply is the color to apply from a theme:","","\/\/ Non-textual components, in AA","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .nonTextual)","","\/\/ Textual components and AAA to check","OUDSWCAG21Ratio.debugContrastRatio(colorToApply, surfaceColor, .AAA)"]},{"type":"heading","level":3,"text":"Divider","anchor":"Divider"},{"level":4,"anchor":"How-it-works","type":"heading","text":"How it works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A divider is used to separate content elements in a view. Two kinds of divider are proposed:"}]},{"items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","isActive":true},{"type":"text","text":": to separate elements stacked vertically (e.g. in "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider"},{"text":": to separate elements stacked horizontally (e.g. in `HStack)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"A divider can be colored using color enumerated in the ","type":"text"},{"code":"OUDSDividerColor","type":"codeVoice"},{"text":".","type":"text"}]},{"level":5,"anchor":"Horizontal","type":"heading","text":"Horizontal"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Orange"}]}]},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_OrangeBusinessTools","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_horizontalDivider_Sosh","type":"image"}]}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_horizontalDivider_Wireframe"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"level":5,"type":"heading","text":"Vertical","anchor":"Vertical"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Orange"}]}],"title":"Orange"},{"title":"Orange Business Tools","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_verticalDivider_OrangeBusinessTools","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_verticalDivider_Sosh"}]}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_verticalDivider_Wireframe"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"type":"heading","anchor":"How-to-use","text":"How to use","level":4},{"type":"tabNavigator","tabs":[{"title":"SwiftUI","content":[{"syntax":"swift","type":"codeListing","code":["\/\/ Add a vertical divider between items","HStack {","    Text(\"Hello world!\")","    OUDSVerticalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}","","\/\/ Add an horizontal divider between items","VStack {","    Text(\"Hello world!\")","    OUDSHorizontalDivider(color: .brandPrimary)","    Text(\"Happy to see you\")","}"]}]},{"title":"UIKit (experimental)","content":[{"syntax":"swift","type":"codeListing","code":["import OUDSComponentsUIKit","    ","\/\/ Add a vertical divider between items","OUDSUIKit.createVerticalDivider(color: .brandPrimary)","    ","\/\/ Add an horizontal divider between items","OUDSUIKit.createHorizontalDivider(color: .brandPrimary)"]}]}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","interfaceLanguage":"swift"},"sections":[],"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"layouts","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSVerticalDivider":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSVerticalDivider","abstract":[{"type":"text","text":"A vertical Divider is used to separate content laid out side by side ("},{"type":"codeVoice","code":"HStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (width) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"kind":"symbol","navigatorTitle":[{"text":"OUDSVerticalDivider","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword