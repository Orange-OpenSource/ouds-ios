{"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstextinput"]}],"topicSections":[{"title":"Structures","anchor":"Structures","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Helperlink","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/TrailingAction"]},{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)"]},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/body"]},{"title":"Enumerations","anchor":"Enumerations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Status","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Style"]},{"title":"Default Implementations","anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations"]}],"kind":"symbol","metadata":{"title":"OUDSTextInput","symbolKind":"struct","navigatorTitle":[{"text":"OUDSTextInput","kind":"identifier"}],"modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents13OUDSTextInputV","platforms":[{"unavailable":false,"deprecated":false,"beta":false,"name":"iOS","introducedAt":"15.0"},{"unavailable":false,"deprecated":false,"beta":false,"name":"macOS","introducedAt":"15.0"},{"unavailable":false,"deprecated":false,"beta":false,"name":"visionOS","introducedAt":"1.0"}],"roleHeading":"Structure","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextInput","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextInput","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"type":"text","text":"It provides a visual and interactive affordance for text entry while supporting labels, placeholders, icons and helper messages."}],"type":"paragraph"},{"text":"Layout","type":"heading","level":2,"anchor":"Layout"},{"inlineContent":[{"type":"text","text":"Text input is based on several configurable UI elements:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"label","type":"text"}]},{"text":": It is used to describe the purpose of the input.","type":"text"},{"text":" ","type":"text"},{"text":"In some UI contexts, especially when space is limited or when the input is part of a compact layout (search bars, filters, inline forms), the label can be hidden.","type":"text"},{"text":" ","type":"text"},{"text":"However, hiding the label should only be done if the purpose of the input remains clear thanks to a placeholder or contextual icon","type":"text"},{"text":" ","type":"text"},{"text":"and if the label is still accessible to screen readers","type":"text"},{"text":" ","type":"text"},{"text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"placeholder","type":"text"}]},{"text":": if the text of the text input is empty a placeholder provides a hint or guidance inside the field to suggest expected input.","type":"text"},{"text":" ","type":"text"},{"text":"A prefix and a suffix can be added to give more context.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"leading icon","type":"text"}]},{"text":": it helps indicate the purpose of the input (magnifying glass for search, envelope for email, phone device for phone number).","type":"text"},{"text":" ","type":"text"},{"text":"Only use a leading icon if it adds clear functional or contextual value.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"trailing action","type":"text"}]},{"text":": it is used to provide actions related to the field: clear input, toggle password visibility, open a date picker, etc.","type":"text"},{"text":" ","type":"text"},{"text":"Can also indicate status or feedback (error checkmark, loading spinner).","type":"text"}],"type":"paragraph"}]}]},{"text":"Outlined style","type":"heading","level":2,"anchor":"Outlined-style"},{"inlineContent":[{"type":"text","text":"By "},{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for dense layouts or to enhance visibility."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When "},{"type":"strong","inlineContent":[{"text":"outlined","type":"text"}]},{"type":"text","text":", the text input is a minimalist design with a transparent background and a visible stroke outlining the field."},{"type":"text","text":" "},{"type":"text","text":"This style may be interesting for contexts other than form pages:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"When inputs need to feel lightweight and unobtrusive","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"In a header (search field)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"In a selection\/filtering feature in a product catalog","type":"text"}],"type":"paragraph"}]}]},{"code":["   \/\/ An outlined text input","   OUDSTextInput(label: \"Label\", text: $text, isOutlined: true)"],"type":"codeListing","syntax":"swift"},{"text":"Rounded layout","type":"heading","level":3,"anchor":"Rounded-layout"},{"inlineContent":[{"type":"text","text":"Text input can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To activate the rounded button behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration (if the theme exposes this property at init)."},{"type":"text","text":" "},{"type":"text","text":"Some themes do not have this flexibility like "},{"type":"codeVoice","code":"SoshTheme"},{"type":"text","text":" and "},{"type":"codeVoice","code":"WireframeTheme"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Status","type":"heading","level":2,"anchor":"Status"},{"inlineContent":[{"type":"text","text":"Five status are proposed for all layouts:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default (by default)","type":"text"}]},{"text":": Default neutral appearance, whether empty or filled.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to click, focus, and type freely without restrictions.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"error","type":"text"}]},{"text":": The ","type":"text"},{"type":"codeVoice","code":"error"},{"text":" status indicates that the user input does not meet validation rules or","type":"text"},{"text":" ","type":"text"},{"text":"expected formatting. It provides immediate visual feedback, typically through a red border,","type":"text"},{"text":" ","type":"text"},{"text":"error icon, and a clear, accessible error message positioned below the input. The error messages replaces the helper text.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"loading","type":"text"}]},{"text":": The ","type":"text"},{"type":"codeVoice","code":"loading"},{"text":" state indicates that the system is processing or retrieving data","type":"text"},{"text":" ","type":"text"},{"text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"readOnly","type":"text"}]},{"text":" :The","type":"text"},{"type":"codeVoice","code":"readOnly"},{"text":", lets the text visible but not editable","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"disabled","type":"text"}]},{"text":": In ","type":"text"},{"type":"codeVoice","code":"disabled"},{"text":" status, the field is non-interactive and grayed out to indicate it cannot be changed.","type":"text"},{"text":" ","type":"text"},{"text":"Note the SwiftUI ","type":"text"},{"type":"codeVoice","code":"View.disabled()"},{"text":" is ignored.","type":"text"}],"type":"paragraph"}]}]},{"text":"Helpers","type":"heading","level":2,"anchor":"Helpers"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper text","type":"text"}]},{"text":":  A supporting text conveys additional information about the input field,","type":"text"},{"text":" ","type":"text"},{"text":"such as how it will be used. It should ideally only take up a single line, though may wrap","type":"text"},{"text":" ","type":"text"},{"text":"to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper link","type":"text"}]},{"text":": If the helper text is not sufficient, it’s possible to offer the user","type":"text"},{"text":" ","type":"text"},{"text":"an additional help link (the link can be external or open a modal).","type":"text"}],"type":"paragraph"}]}]},{"text":"Accessibility considerations","type":"heading","level":2,"anchor":"Accessibility-considerations"},{"inlineContent":[{"type":"text","text":"By default no haptics are done by the component for the trailing action."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases wher you will have to make the devices vibrates."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Mandatory field indication","type":"heading","level":2,"anchor":"Mandatory-field-indication"},{"inlineContent":[{"type":"text","text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"UI rendering of the asterisk must be done with "},{"type":"emphasis","inlineContent":[{"text":"fbold font weight","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"negative content color","type":"text"}]},{"type":"text","text":" (red-."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If there is only one field in the formular, or if the mandatory nature is obvious (such as login\/password),"},{"type":"text","text":" "},{"type":"text","text":"no mention is necessary since the fields are essential to the formular’s functionality."}],"type":"paragraph"},{"text":"Code samples","type":"heading","level":2,"anchor":"Code-samples"},{"code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextInput(label: \"Email\", text: $text)","","    \/\/ Empty text with placeholder and suffix","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\")","","    \/\/ Empty text with prefix and suffix","    OUDSTextInput(label: \"Email\", text: $text, prefix: \"Distance\", suffix: \"km\")","","    \/\/ Add a leading icon for more context","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\", leadingIcon: Image(systemName: \"envelope\"))","","    \/\/ Add a trailing button with local image namde \"ic_cross\" for additional action","    let trailingAction = OUDSTextInput.TrailingAction(icon: Image(\"ic_cross\"), actionHint: \"Delete\") { text = \"\" }","    OUDSTextInput(label: \"Email\", text: $text, trailingAction: trailingAction)","","    \/\/ With helper text","    OUDSTextInput(label: \"Email\",","                  text: $text,","                  placeholder: \"firstName.lastName\",","                  suffix: \"@orange.com\",","                  helperText: \"The email will be automatically completed with @orange.com\")","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextInput.HelperLink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextInput(label: \"Label\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSTextInput(label: \"Label\", text: $text, flipLeadingIcon: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"text":"Design documentation","type":"heading","level":2,"anchor":"Design-documentation"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-input"}],"type":"paragraph"},{"text":"Themes rendering","type":"heading","level":2,"anchor":"Themes-rendering"},{"text":"Orange","type":"heading","level":3,"anchor":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_textInput_Orange"}],"type":"paragraph"},{"text":"Orange Business Tools","type":"heading","level":3,"anchor":"Orange-Business-Tools"},{"inlineContent":[{"type":"image","identifier":"component_textInput_OrangeBusinessTools"}],"type":"paragraph"},{"text":"Sosh","type":"heading","level":3,"anchor":"Sosh"},{"inlineContent":[{"type":"image","identifier":"component_textInput_Sosh"}],"type":"paragraph"},{"text":"Wireframe","type":"heading","level":3,"anchor":"Wireframe"},{"inlineContent":[{"type":"image","identifier":"component_textInput_Wireframe"}],"type":"paragraph"},{"name":"Version","content":[{"type":"paragraph","inlineContent":[{"text":"1.3.0 (Figma component design version)","type":"text"}]}],"type":"aside","style":"note"},{"name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.20.0","type":"text"}]}],"type":"aside","style":"note"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput","isActive":true},{"type":"text","text":" is a user interface component that allows users to enter, edit, or select"},{"text":" ","type":"text"},{"text":"single-line textual data. It’s one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries.","type":"text"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/body":{"role":"symbol","kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeI