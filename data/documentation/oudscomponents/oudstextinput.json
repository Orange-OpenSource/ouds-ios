n\/OUDSComponents\/OUDSTextInput\/Helperlink","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Helperlink","kind":"identifier"}],"abstract":[{"type":"text","text":"Used to describe the helper link above the helper text."}]},"component_textInput_Sosh":{"identifier":"component_textInput_Sosh","variants":[{"url":"\/images\/OUDSComponents\/component_textInput_Sosh.png","traits":["1x","light"]}],"type":"image","alt":"A text input component in light and dark modes with Sosh theme"},"https://developer.apple.com/design/human-interface-guidelines/playing-haptics":{"title":"Human Interface Guidelines of Apple","titleInlineContent":[{"type":"text","text":"Human Interface Guidelines of Apple"}],"url":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","type":"link","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},"doc://OUDSComponents/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/Style":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Style","kind":"identifier"}],"type":"topic","title":"OUDSTextInput.Style","abstract":[{"text":"The prefered style of the text input","type":"text"}],"url":"\/documentation\/oudscomponents\/oudstextinput\/style","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"Style","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Style"},"component_textInput_OrangeBusinessTools":{"alt":"A text input component in light and dark modes with Orange Business Tools theme","variants":[{"url":"\/images\/OUDSComponents\/component_textInput_OrangeBusinessTools.png","traits":["1x","light"]}],"type":"image","identifier":"component_textInput_OrangeBusinessTools"},"ic_folder_categories.png":{"variants":[{"u