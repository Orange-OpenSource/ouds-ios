scomponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","role":"collection","images":[{"identifier":"ic_folder_categories.png","type":"icon"}]},"doc://OUDSComponents/7SwiftUI4ViewP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","title":"SwiftUICore.View"}}}