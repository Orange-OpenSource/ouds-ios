ion\/OUDSComponents","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}]},"doc://OUDSComponents/7SwiftUI4ViewP":{"type":"unresolvable","title":"SwiftUICore.View","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP"},"component_textInput_Orange":{"alt":"A text input component in light and dark modes with Orange theme","variants":[{"url":"\/images\/OUDSComponents\/component_textInput_Orange.png","traits":["1x","light"]}],"type":"image","identifier":"component_textInput_Orange"},"component_textInput_Wireframe":{"type":"image","identifier":"component_textInput_Wireframe","alt":"A text input component in light and dark modes with Wireframe theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_textInput_Wireframe.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/View-Implementations":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations","kind":"article","role":"collectionGroup","title":"View Implementations","url":"\/documentation\/oudscomponents\/oudstextinput\/view-implementations","abstract":[],"type":"topic"}}}