{"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextInput"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"It provides a visual and interactive affordance for text entry while supporting labels, placeholders, icons and helper messages."}],"type":"paragraph"},{"anchor":"Layout","text":"Layout","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Text input is based on several configurable UI elements:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"label"}]},{"type":"text","text":": It is used to describe the purpose of the input."},{"type":"text","text":" "},{"type":"text","text":"In some UI contexts, especially when space is limited or when the input is part of a compact layout (search bars, filters, inline forms), the label can be hidden."},{"type":"text","text":" "},{"type":"text","text":"However, hiding the label should only be done if the purpose of the input remains clear thanks to a placeholder or contextual icon"},{"type":"text","text":" "},{"type":"text","text":"and if the label is still accessible to screen readers"},{"type":"text","text":" "},{"type":"text","text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"placeholder"}]},{"type":"text","text":": if the text of the text input is empty a placeholder provides a hint or guidance inside the field to suggest expected input."},{"type":"text","text":" "},{"type":"text","text":"A prefix and a suffix can be added to give more context."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"leading icon"}],"type":"strong"},{"text":": it helps indicate the purpose of the input (magnifying glass for search, envelope for email, phone device for phone number).","type":"text"},{"text":" ","type":"text"},{"text":"Only use a leading icon if it adds clear functional or contextual value.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"trailing action","type":"text"}]},{"type":"text","text":": it is used to provide actions related to the field: clear input, toggle password visibility, open a date picker, etc."},{"type":"text","text":" "},{"type":"text","text":"Can also indicate status or feedback (error checkmark, loading spinner)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Outlined-style","text":"Outlined style","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"By "},{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for dense layouts or to enhance visibility."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When "},{"type":"strong","inlineContent":[{"text":"outlined","type":"text"}]},{"type":"text","text":", the text input is a minimalist design with a transparent background and a visible stroke outlining the field."},{"type":"text","text":" "},{"type":"text","text":"This style may be interesting for contexts other than form pages:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"When inputs need to feel lightweight and unobtrusive"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"In a header (search field)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In a selection\/filtering feature in a product catalog"}]}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["   \/\/ An outlined text input","   OUDSTextInput(label: \"Label\", text: $text, isOutlined: true)"]},{"anchor":"Rounded-layout","text":"Rounded layout","type":"heading","level":3},{"inlineContent":[{"text":"Text input can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities.","type":"text"},{"text":" ","type":"text"},{"text":"For standard or business-oriented journeys, keep the default corners.","type":"text"},{"text":" ","type":"text"},{"text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To activate the rounded button behavior, set to true the ","type":"text"},{"code":"hasRoundedTextInputs","type":"codeVoice"},{"text":" values of the ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"text":" ","type":"text"},{"text":"Some themes do not have this flexibility like ","type":"text"},{"code":"SoshTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"WireframeTheme","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Status","text":"Status","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Five status are proposed for all layouts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default (by default)"}]},{"type":"text","text":": Default neutral appearance, whether empty or filled."},{"type":"text","text":" "},{"type":"text","text":"It allows users to click, focus, and type freely without restrictions."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"error"}]},{"type":"text","text":": The "},{"code":"error","type":"codeVoice"},{"type":"text","text":" status indicates that the user input does not meet validation rules or"},{"type":"text","text":" "},{"type":"text","text":"expected formatting. It provides immediate visual feedback, typically through a red border,"},{"type":"text","text":" "},{"type":"text","text":"error icon, and a clear, accessible error message positioned below the input. The error messages replaces the helper text."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"loading","type":"text"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"loading","type":"codeVoice"},{"text":" state indicates that the system is processing or retrieving data","type":"text"},{"text":" ","type":"text"},{"text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"readOnly","type":"text"}],"type":"strong"},{"type":"text","text":" :The"},{"code":"readOnly","type":"codeVoice"},{"type":"text","text":", lets the text visible but not editable"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"disabled"}],"type":"strong"},{"type":"text","text":": In "},{"code":"disabled","type":"codeVoice"},{"type":"text","text":" status, the field is non-interactive and grayed out to indicate it cannot be changed."},{"type":"text","text":" "},{"type":"text","text":"Note the SwiftUI "},{"code":"View.disabled()","type":"codeVoice"},{"type":"text","text":" is ignored."}]}]}],"type":"unorderedList"},{"anchor":"Helpers","text":"Helpers","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Helper text"}],"type":"strong"},{"text":":  A supporting text conveys additional information about the input field,","type":"text"},{"text":" ","type":"text"},{"text":"such as how it will be used. It should ideally only take up a single line, though may wrap","type":"text"},{"text":" ","type":"text"},{"text":"to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper link","type":"text"}]},{"type":"text","text":": If the helper text is not sufficient, it’s possible to offer the user"},{"type":"text","text":" "},{"type":"text","text":"an additional help link (the link can be external or open a modal)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Accessibility-considerations","text":"Accessibility considerations","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"By default no haptics are done by the component for the trailing action."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases wher you will have to make the devices vibrates."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Code-samples","text":"Code samples","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextInput(label: \"Email\", text: $text)","","    \/\/ Empty text with placeholder and suffix","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\")","","    \/\/ Empty text with prefix and suffix","    OUDSTextInput(label: \"Email\", text: $text, prefix: \"Distance\", suffix: \"km\")","","    \/\/ Add a leading icon for more context","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\", leadingIcon: Image(systemName: \"envelope\"))","","    \/\/ Add a trailing button with local image namde \"ic_cross\" for additional action","    let trailingAction = OUDSTextInput.TrailingAction(icon: Image(\"ic_cross\"), accessibilityLabel: \"Delete\") { text = \"\" }","    OUDSTextInput(label: \"Email\", text: $text, trailingAction: trailingAction)","","    \/\/ With helper text","    OUDSTextInput(label: \"Email\",","                  text: $text,","                  placeholder: \"firstName.lastName\",","                  suffix: \"@orange.com\",","                  helperText: \"The email will be automatically completed with @orange.com\")","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextInput.HelperLink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextInput(label: \"Label\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)"]},{"anchor":"Design-documentation","text":"Design documentation","type":"heading","level":2},{"inlineContent":[{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com","isActive":true}],"type":"paragraph"},{"anchor":"Themes-rendering","text":"Themes rendering","type":"heading","level":2},{"anchor":"Orange","text":"Orange","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"component_textInput_Orange"}],"type":"paragraph"},{"anchor":"Orange-Business-Tools","text":"Orange Business Tools","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"component_textInput_OrangeBusinessTools"}],"type":"paragraph"},{"anchor":"Sosh","text":"Sosh","type":"heading","level":3},{"inlineContent":[{"identifier":"component_textInput_Sosh","type":"image"}],"type":"paragraph"},{"anchor":"Wireframe","text":"Wireframe","type":"heading","level":3},{"inlineContent":[{"type":"image","identifier":"component_textInput_Wireframe"}],"type":"paragraph"},{"style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.3.0 (Figma component design version)"}]}],"type":"aside"},{"style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.20.0"}]}],"type":"aside"}]}],"metadata":{"title":"OUDSTextInput","externalID":"s:14OUDSComponents13OUDSTextInputV","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextInput","kind":"identifier"}],"modules":[{"name":"Components"}],"symbolKind":"struct","role":"symbol","navigatorTitle":[{"text":"OUDSTextInput","kind":"identifier"}]},"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput","isActive":true,"type":"reference"},{"text":" is a user interface component that allows users to enter, edit, or select","type":"text"},{"text":" ","type":"text"},{"text":"single-line textual data. It’s one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documen