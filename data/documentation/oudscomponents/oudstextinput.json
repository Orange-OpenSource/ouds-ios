{"sections":[],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstextinput"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput","type":"reference"},{"text":" is a user interface component that allows users to enter, edit, or select","type":"text"},{"text":" ","type":"text"},{"text":"single-line textual data. It’s one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Helperlink","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/TrailingAction"],"generated":true,"anchor":"Structures","title":"Structures"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:status:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/body"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Status","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Style"],"generated":true,"anchor":"Enumerations","title":"Enumerations"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"kind":"symbol","metadata":{"navigatorTitle":[{"kind":"identifier","text":"OUDSTextInput"}],"title":"OUDSTextInput","roleHeading":"Structure","platforms":[{"beta":false,"name":"iOS","unavailable":false,"introducedAt":"15.0","deprecated":false},{"beta":false,"name":"macOS","unavailable":false,"introducedAt":"15.0","deprecated":false},{"beta":false,"name":"visionOS","unavailable":false,"introducedAt":"1.0","deprecated":false}],"symbolKind":"struct","modules":[{"name":"Components"}],"role":"symbol","externalID":"s:14OUDSComponents13OUDSTextInputV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextInput"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextInput"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"It provides a visual and interactive affordance for text entry while supporting labels, placeholders, icons and helper messages."}],"type":"paragraph"},{"anchor":"Layout","type":"heading","text":"Layout","level":2},{"type":"paragraph","inlineContent":[{"text":"Text input is based on several configurable UI elements:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"label"}],"type":"strong"},{"text":": It is used to describe the purpose of the input.","type":"text"},{"text":" ","type":"text"},{"text":"In some UI contexts, especially when space is limited or when the input is part of a compact layout (search bars, filters, inline forms), the label can be hidden.","type":"text"},{"text":" ","type":"text"},{"text":"However, hiding the label should only be done if the purpose of the input remains clear thanks to a placeholder or contextual icon","type":"text"},{"text":" ","type":"text"},{"text":"and if the label is still accessible to screen readers","type":"text"},{"text":" ","type":"text"},{"text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"placeholder"}]},{"text":": if the text of the text input is empty a placeholder provides a hint or guidance inside the field to suggest expected input.","type":"text"},{"text":" ","type":"text"},{"text":"A prefix and a suffix can be added to give more context.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"leading icon"}],"type":"strong"},{"type":"text","text":": it helps indicate the purpose of the input (magnifying glass for search, envelope for email, phone device for phone number)."},{"text":" ","type":"text"},{"text":"Only use a leading icon if it adds clear functional or contextual value.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"trailing action"}]},{"type":"text","text":": it is used to provide actions related to the field: clear input, toggle password visibility, open a date picker, etc."},{"type":"text","text":" "},{"text":"Can also indicate status or feedback (error checkmark, loading spinner).","type":"text"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","anchor":"Outlined-style","text":"Outlined style"},{"type":"paragraph","inlineContent":[{"text":"By ","type":"text"},{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"type":"text","text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look."},{"text":" ","type":"text"},{"text":"Best suited for dense layouts or to enhance visibility.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"type":"strong","inlineContent":[{"text":"outlined","type":"text"}]},{"type":"text","text":", the text input is a minimalist design with a transparent background and a visible stroke outlining the field."},{"type":"text","text":" "},{"type":"text","text":"This style may be interesting for contexts other than form pages:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"When inputs need to feel lightweight and unobtrusive","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In a header (search field)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In a selection\/filtering feature in a product catalog"}]}]}]},{"syntax":"swift","code":["   \/\/ An outlined text input","   OUDSTextInput(label: \"Label\", text: $text, isOutlined: true)"],"type":"codeListing"},{"type":"heading","anchor":"Rounded-layout","text":"Rounded layout","level":3},{"inlineContent":[{"type":"text","text":"Text input can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"text":"For standard or business-oriented journeys, keep the default corners.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To activate the rounded button behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"text":" object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration (if the theme exposes this property at init)."},{"type":"text","text":" "},{"text":"Some themes do not have this flexibility like ","type":"text"},{"code":"SoshTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"WireframeTheme","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","text":"Status","anchor":"Status","level":2},{"inlineContent":[{"text":"Five status are proposed for all layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default (by default)"}]},{"type":"text","text":": Default neutral appearance, whether empty or filled."},{"type":"text","text":" "},{"type":"text","text":"It allows users to click, focus, and type freely without restrictions."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"error"}],"type":"strong"},{"type":"text","text":": The "},{"type":"codeVoice","code":"error"},{"type":"text","text":" status indicates that the user input does not meet validation rules or"},{"type":"text","text":" "},{"type":"text","text":"expected formatting. It provides immediate visual feedback, typically through a red border,"},{"type":"text","text":" "},{"type":"text","text":"error icon, and a clear, accessible error message positioned below the input. The error messages replaces the helper text."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"loading","type":"text"}],"type":"strong"},{"type":"text","text":": The "},{"type":"codeVoice","code":"loading"},{"type":"text","text":" state indicates that the system is processing or retrieving data"},{"type":"text","text":" "},{"type":"text","text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"readOnly"}]},{"type":"text","text":" :The"},{"code":"readOnly","type":"codeVoice"},{"type":"text","text":", lets the text visible but not editable"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"disabled"}]},{"type":"text","text":": In "},{"type":"codeVoice","code":"disabled"},{"type":"text","text":" status, the field is non-interactive and grayed out to indicate it cannot be changed."},{"type":"text","text":" "},{"type":"text","text":"Note the SwiftUI "},{"type":"codeVoice","code":"View.disabled()"},{"type":"text","text":" is ignored."}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Helpers","anchor":"Helpers","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Helper text","type":"text"}],"type":"strong"},{"type":"text","text":":  A supporting text conveys additional information about the input field,"},{"type":"text","text":" "},{"type":"text","text":"such as how it will be used. It should ideally only take up a single line, though may wrap"},{"type":"text","text":" "},{"type":"text","text":"to multiple lines if required, and be either persistently visible or visible only on focus."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Helper link","type":"text"}],"type":"strong"},{"type":"text","text":": If the helper text is not sufficient, it’s possible to offer the user"},{"type":"text","text":" "},{"type":"text","text":"an additional help link (the link can be external or open a modal)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Accessibility-considerations","text":"Accessibility considerations","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"By default no haptics are done by the component for the trailing action."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases wher you will have to make the devices vibrates."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Mandatory field indication","anchor":"Mandatory-field-indication","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”"}],"type":"paragraph"},{"inlineContent":[{"text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular.","type":"text"},{"text":" ","type":"text"},{"text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"UI rendering of the asterisk must be done with ","type":"text"},{"inlineContent":[{"type":"text","text":"fbold font weight"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"negative content color"}],"type":"emphasis"},{"text":" (red-.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If there is only one field in the formular, or if the mandatory nature is obvious (such as login\/password),","type":"text"},{"text":" ","type":"text"},{"text":"no mention is necessary since the fields are essential to the formular’s functionality.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Code-samples","type":"heading","text":"Code samples"},{"code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextInput(label: \"Email\", text: $text)","","    \/\/ Empty text with placeholder and suffix","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\")","","    \/\/ Empty text with prefix and suffix","    OUDSTextInput(label: \"Email\", text: $text, prefix: \"Distance\", suffix: \"km\")","","    \/\/ Add a leading icon for more context","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\", leadingIcon: Image(systemName: \"envelope\"))","","    \/\/ Add a trailing button with local image namde \"ic_cross\" for additional action","    let trailingAction = OUDSTextInput.TrailingAction(icon: Image(\"ic_cross\"), accessibilityLabel: \"Delete\") { text = \"\" }","    OUDSTextInput(label: \"Email\", text: $text, trailingAction: trailingAction)","","    \/\/ With helper text","    OUDSTextInput(label: \"Email\",","                  text: $text,","                  placeholder: \"firstName.lastName\",","                  suffix: \"@orange.com\",","                  helperText: \"The email will be automatically completed with @orange.com\")","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextInput.HelperLink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextInput(label: \"Label\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSTextInput(label: \"Label\", text: $text, flipLeadingIcon: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Design-documentation","type":"heading","text":"Design documentation"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com","isActive":true}],"type":"paragraph"},{"level":2,"anchor":"Themes-rendering","type":"heading","text":"Themes rendering"},{"level":3,"anchor":"Orange","type":"heading","text":"Orange"},{"inlineContent":[{"identifier":"component_textInput_Orange","type":"image"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Orange Business Tools","anchor":"Orange-Business-Tools"},{"inlineContent":[{"type":"image","identifier":"component_textInput_OrangeBusinessTools"}],"type":"paragraph"},{"level":3,"text":"Sosh","type":"heading","anchor":"Sosh"},{"inlineContent":[{"identifier":"component_textInput_Sosh","type":"image"}],"type":"paragraph"},{"level":3,"text":"Wireframe","type":"heading","anchor":"Wireframe"},{"inlineContent":[{"identifier":"component_textInput_Wireframe","type":"image"}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"1.3.0 (Figma component design version)","type":"text"}]}],"name":"Version","type":"aside"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.20.0"}]}],"name":"Since","type":"aside"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput"},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"https://unified-design-system.orange.com":{"identifier":"https:\/\/unified-design-system.orange.com","url":"https:\/\/unified-design-system.orange.com","type":"link","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"title":"unified-design-system.orange.com"},"doc://OUDSComponents/s16SendableMetatypeP":{"identif