{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextInput"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"It provides a visual and interactive affordance for text entry while supporting labels, placeholders, icons and helper messages."}],"type":"paragraph"},{"type":"heading","anchor":"Layout","level":2,"text":"Layout"},{"inlineContent":[{"type":"text","text":"Text input is based on several configurable UI elements:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"label"}],"type":"strong"},{"text":": It is used to describe the purpose of the input.","type":"text"},{"text":" ","type":"text"},{"text":"In some UI contexts, especially when space is limited or when the input is part of a compact layout (search bars, filters, inline forms), the label can be hidden.","type":"text"},{"text":" ","type":"text"},{"text":"However, hiding the label should only be done if the purpose of the input remains clear thanks to a placeholder or contextual icon","type":"text"},{"text":" ","type":"text"},{"text":"and if the label is still accessible to screen readers","type":"text"},{"type":"text","text":" "},{"text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"placeholder","type":"text"}],"type":"strong"},{"type":"text","text":": if the text of the text input is empty a placeholder provides a hint or guidance inside the field to suggest expected input."},{"type":"text","text":" "},{"type":"text","text":"A prefix and a suffix can be added to give more context."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"leading icon","type":"text"}],"type":"strong"},{"type":"text","text":": it helps indicate the purpose of the input (magnifying glass for search, envelope for email, phone device for phone number)."},{"type":"text","text":" "},{"type":"text","text":"Only use a leading icon if it adds clear functional or contextual value."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"trailing action"}],"type":"strong"},{"type":"text","text":": it is used to provide actions related to the field: clear input, toggle password visibility, open a date picker, etc."},{"type":"text","text":" "},{"type":"text","text":"Can also indicate status or feedback (error checkmark, loading spinner)."}],"type":"paragraph"}]}]},{"anchor":"Outlined-style","level":2,"type":"heading","text":"Outlined style"},{"inlineContent":[{"type":"text","text":"By "},{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"type":"text","text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for dense layouts or to enhance visibility."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"inlineContent":[{"type":"text","text":"outlined"}],"type":"strong"},{"text":", the text input is a minimalist design with a transparent background and a visible stroke outlining the field.","type":"text"},{"type":"text","text":" "},{"text":"This style may be interesting for contexts other than form pages:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"When inputs need to feel lightweight and unobtrusive"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"In a header (search field)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"In a selection\/filtering feature in a product catalog"}],"type":"paragraph"}]}]},{"type":"codeListing","code":["   \/\/ An outlined text input","   OUDSTextInput(label: \"Label\", text: $text, isOutlined: true)"],"syntax":"swift"},{"type":"heading","level":3,"text":"Rounded layout","anchor":"Rounded-layout"},{"inlineContent":[{"type":"text","text":"Text input can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To activate the rounded button behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"type":"text","text":" values of the "},{"code":"Tuning","type":"codeVoice"},{"type":"text","text":" object"},{"text":" ","type":"text"},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Some themes do not have this flexibility like "},{"type":"codeVoice","code":"SoshTheme"},{"type":"text","text":" and "},{"type":"codeVoice","code":"WireframeTheme"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Status","level":2,"type":"heading","text":"Status"},{"inlineContent":[{"type":"text","text":"Five status are proposed for all layouts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"default (by default)","type":"text"}],"type":"strong"},{"type":"text","text":": Default neutral appearance, whether empty or filled."},{"type":"text","text":" "},{"type":"text","text":"It allows users to click, focus, and type freely without restrictions."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"error","type":"text"}],"type":"strong"},{"text":": The ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" status indicates that the user input does not meet validation rules or"},{"text":" ","type":"text"},{"text":"expected formatting. It provides immediate visual feedback, typically through a red border,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"error icon, and a clear, accessible error message positioned below the input. The error messages replaces the helper text."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"loading","type":"text"}],"type":"strong"},{"text":": The ","type":"text"},{"type":"codeVoice","code":"loading"},{"text":" state indicates that the system is processing or retrieving data","type":"text"},{"text":" ","type":"text"},{"text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"readOnly","type":"text"}]},{"text":" :The","type":"text"},{"type":"codeVoice","code":"readOnly"},{"text":", lets the text visible but not editable","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"disabled","type":"text"}],"type":"strong"},{"type":"text","text":": In "},{"type":"codeVoice","code":"disabled"},{"type":"text","text":" status, the field is non-interactive and grayed out to indicate it cannot be changed."},{"text":" ","type":"text"},{"type":"text","text":"Note the SwiftUI "},{"type":"codeVoice","code":"View.disabled()"},{"type":"text","text":" is ignored."}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Helpers","anchor":"Helpers"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Helper text"}],"type":"strong"},{"text":":  A supporting text conveys additional information about the input field,","type":"text"},{"text":" ","type":"text"},{"text":"such as how it will be used. It should ideally only take up a single line, though may wrap","type":"text"},{"text":" ","type":"text"},{"text":"to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper link","type":"text"}]},{"text":": If the helper text is not sufficient, it’s possible to offer the user","type":"text"},{"text":" ","type":"text"},{"text":"an additional help link (the link can be external or open a modal).","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Accessibility-considerations","level":2,"type":"heading","text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default no haptics are done by the component for the trailing action."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases wher you will have to make the devices vibrates."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":2,"anchor":"Mandatory-field-indication","text":"Mandatory field indication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"UI rendering of the asterisk must be done with "},{"inlineContent":[{"type":"text","text":"fbold font weight"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"negative content color"}],"type":"emphasis"},{"type":"text","text":" (red-."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is only one field in the formular, or if the mandatory nature is obvious (such as login\/password),"},{"type":"text","text":" "},{"type":"text","text":"no mention is necessary since the fields are essential to the formular’s functionality."}]},{"type":"heading","level":2,"anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextInput(label: \"Email\", text: $text)","","    \/\/ Empty text with placeholder and suffix","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\")","","    \/\/ Empty text with prefix and suffix","    OUDSTextInput(label: \"Email\", text: $text, prefix: \"Distance\", suffix: \"km\")","","    \/\/ Add a leading icon for more context","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\", leadingIcon: Image(systemName: \"envelope\"))","","    \/\/ Add a trailing button with local image namde \"ic_cross\" for additional action","    let trailingAction = OUDSTextInput.TrailingAction(icon: Image(\"ic_cross\"), accessibilityLabel: \"Delete\") { text = \"\" }","    OUDSTextInput(label: \"Email\", text: $text, trailingAction: trailingAction)","","    \/\/ With helper text","    OUDSTextInput(label: \"Email\",","                  text: $text,","                  placeholder: \"firstName.lastName\",","                  suffix: \"@orange.com\",","                  helperText: \"The email will be automatically completed with @orange.com\")","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextInput.HelperLink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextInput(label: \"Label\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSTextInput(label: \"Label\", text: $text, flipLeadingIcon: layoutDirection == .rightToLeft)"]},{"type":"heading","level":2,"anchor":"Design-documentation","text":"Design documentation"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com","isActive":true}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Themes-rendering","text":"Themes rendering"},{"anchor":"Orange","level":3,"type":"heading","text":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_textInput_Orange"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Orange Business Tools","anchor":"Orange-Business-Tools"},{"inlineContent":[{"type":"image","identifier":"component_textInput_OrangeBusinessTools"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Sosh","anchor":"Sosh"},{"inlineContent":[{"type":"image","identifier":"component_textInput_Sosh"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Wireframe","anchor":"Wireframe"},{"inlineContent":[{"type":"image","identifier":"component_textInput_Wireframe"}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"1.3.0 (Figma component design version)"}],"type":"paragraph"}],"name":"Version"},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"0.20.0"}],"type":"paragraph"}],"name":"Since"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Helperlink","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/TrailingAction"],"generated":true,"title":"Structures","anchor":"Structures"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:status:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/body"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Status","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Style"],"generated":true,"title":"Enumerations","anchor":"Enumerations"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations"],"