ntifier":"ic_folder_categories.png","type":"icon"}],"url":"\/documentation\/oudscomponents","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"type":"topic","title":"Components","role":"collection"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/TrailingAction":{"navigatorTitle":[{"kind":"identifier","text":"TrailingAction"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/TrailingAction","kind":"symbol","url":"\/documentation\/oudscomponents\/oudstextinput\/trailingaction","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"TrailingAction"}],"type":"topic","abstract":[{"text":"Used to describe the trailing action of the text input","type":"text"}],"role":"symbol","title":"OUDSTextInput.TrailingAction"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/Helperlink":{"navigatorTitle":[{"text":"Helperlink","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Helperlink","kind":"symbol","url":"\/documentation\/oudscomponents\/oudstextinput\/helperlink","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Helperlink","kind":"identifier"}],"type":"topic","abstract":[{"text":"Used to describe the helper link above the helper text.","type":"text"}],"role":"symbol","title":"OUDSTextInput.Helperlink"},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"role":"article","abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"controls"}]},{"text":" and 