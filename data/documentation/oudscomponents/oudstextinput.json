ingle-line textual data. It’s one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries."}],"navigatorTitle":[{"text":"OUDSTextInput","kind":"identifier"}],"role":"symbol","url":"\/documentation\/oudscomponents\/oudstextinput","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextInput","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/Status":{"type":"topic","kind":"symbol","url":"\/documentation\/oudscomponents\/oudstextinput\/status","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Status","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Status","abstract":[{"type":"text","text":"Define all available status for the text input"}],"role":"symbol","navigatorTitle":[{"text":"Status","kind":"identifier"}],"title":"OUDSTextInput.Status"},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"kind":"article","abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"text":"controls","type":"text"}]},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"inputs"}]},{"text":".","type":"text"}],"url":"\/documentation\/oudscomponents\/controls","type":"topic","role":"article","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"title":"Controls","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"},"component_textInput_Wireframe":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_textInput_Wireframe.png"}],"identifier":"component_textInput_Wireframe","alt":"A text input component in light and dark mode with Wireframe theme","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/TrailingAction":{"url":"\/documenta