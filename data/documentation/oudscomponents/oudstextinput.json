"trailingAction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"OUDSTextInput","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"TrailingAction","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV14TrailingActionV"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"helperText"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"helperLink"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"OUDSTextInput","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Helperlink","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV10HelperlinkV"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"isOutlined"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":", "},{"kind":"externalParam","text":"constrainedMaxWidth"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":", "},{"kind":"externalParam","text":"status"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"OUDSTextInput","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Status","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV6StatusO"},{"kind":"text","text":")"}],"role":"symbol","abstract":[{"type":"text","text":"Creates a text input."}],"kind":"symbol","url":"\/documentation\/oudscomponents\/oudstextinput\/init(label:text:placeholder:prefix:suffix:leadingicon:flipleadingicon:trailingaction:helpertext:helperlink:isoutlined:constrainedmaxwidth:status:)","title":"init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","type":"topic"},"component_textInput_Sosh":{"type":"image","identifier":"component_textInput_Sosh","alt":"A text input component in light and dark modes with Sosh theme","variants":[{"url":"\/images\/OUDSComponents\/component_textInput_Sosh.png","traits":["1x","light"]}]},"component_textInput_Wireframe":{"type":"image","identifier":"component_textInput_Wireframe","alt":"A text input component in light and dark modes with Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_textInput_Wireframe.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents":{"role":"collection","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","kind":"symbol","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"type":"topic","title":"Components","url":"\/documentation\/oudscomponents"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput":{"title":"OUDSTextInput","type":"topic","navigatorTitle":[{"text":"OUDSTextInput","kind":"identifier"}],"kind":"symbol","role":"symbol","abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput","type":"reference"},{"text":" is a user interface component that allows users to enter, edit, or select","type":"text"},{"text":" ","type":"text"},{"text":"single-line textual data. It’s one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudstextinput","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextInput","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput"},"doc://OUDSComponents/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s8SendableP","title":"Swift.Sendable"},"doc://OUDSComponents/7SwiftUI4ViewP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","title":"SwiftUICore.View"},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"controls"}]},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"type":"text","text":"inputs"}]},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/controls","role":"article","title":"Controls","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls","kind":"article","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}]},"ic_folder_categories.png":{"type":"image","identifier":"ic_folder_categories.png","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/Helperlink":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Helperlink"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Helperlink","kind":"symbol","type":"topic","abstract":[{"text":"Used to describe the helper link above the helper text.","type":"text"}],"title":"OUDSTextInput.Helperlink","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Helperlink"}],"url":"\/documentation\/oudscomponents\/oudstextinput\/helperlink"},"component_textInput_OrangeBusinessTools":{"type":"image","identifier":"component_textInput_OrangeBusinessTools","alt":"A text input component in light and dark modes with Orange Business Tools theme","variants":[{"url":"\/images\/OUDSComponents\/component_textInput_OrangeBusinessTools.png","traits":["1x","light"]}]},"doc://OUDSComponents/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/Style":{"role":"symbol","navigatorTitle":[{"text":"Style","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Style","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The prefered style of the text input"}],"title":"OUDSTextInput.Style","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Style","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudstextinput\/style"},"https://developer.apple.com/design/human-interface-guidelines/playing-haptics":{"type":"link","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","title":"Human Interface Guidelines of Apple","titleInlineContent":[{"type":"text","text":"Human Interface Guidelines of Apple"}],"url":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"}}}