ts\/OUDSTextInput\/body","kind":"symbol","abstract":[]},"https://developer.apple.com/design/human-interface-guidelines/playing-haptics":{"titleInlineContent":[{"type":"text","text":"Human Interface Guidelines of Apple"}],"type":"link","url":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","title":"Human Interface Guidelines of Apple","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextInput"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSTextInput"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput","url":"\/documentation\/oudscomponents\/oudstextinput","type":"topic","abstract":[{"text":"Text input is a UI element that allows to enter, edit, or select single-line textual data.","type":"text"},{"text":" ","type":"text"},{"text":"Text input is one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries.","type":"text"},{"text":" ","type":"text"},{"text":"It provides a visual and interactive affordance for text entry while supporting labels, placeholders, icons, descriptions, and validation feedback.","type":"text"}],"kind":"symbol","title":"OUDSTextInput"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)":{"type":"topic","title":"init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","url":"\/documentation\/oudscomponents\/oudstextinput\/init(label:text:placeholder:prefix:suffix:leadingicon:flipleadingicon:trailingaction:helpertext:helperlink:i