tifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"leadingIcon"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI5ImageV","text":"Image"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"flipLeadingIcon"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"trailingAction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV","text":"OUDSTextInput"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV14TrailingActionV","text":"TrailingAction"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"helperText"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"helperLink"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV","text":"OUDSTextInput"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV10HelperlinkV","text":"Helperlink"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"isOutlined"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"constrainedMaxWidth"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"status"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"OUDSTextInput","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Status","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV6StatusO"},{"kind":"text","text":"