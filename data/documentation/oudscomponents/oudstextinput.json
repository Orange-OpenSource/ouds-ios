":"s:SS"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"helperLink"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"OUDSTextInput","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Helperlink","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV10HelperlinkV"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"isOutlined"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":", "},{"kind":"externalParam","text":"constrainedMaxWidth"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":", "},{"kind":"externalParam","text":"status"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"OUDSTextInput","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Status","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV6StatusO"},{"kind":"text","text":")"}],"type":"topic","role":"symbol","url":"\/documentation\/oudscomponents\/oudstextinput\/init(_:tablename:bundle:text:placeholder:prefix:suffix:leadingicon:flipleadingicon:trailingaction:helpertext:helperlink:isoutlined:constrainedmaxwidth:status:)","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)":{"abstract":[{"text":"Creates a text input.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","title":"init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"label"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"text"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Binding","preciseIdentifier":"s:7SwiftUI7BindingV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"placeholder"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"prefix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"suffix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"leadingIcon"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Image","preciseIdentifier":"s:7SwiftUI5ImageV"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"flipLeadingIcon"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":", "},{"kind":"externalParam","text":"trailingAction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"OUDSTextInput","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"TrailingAction","preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV14TrailingActionV"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"helperText"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"helperLink"},{"kind":"text","text":": "},{"kind":"type