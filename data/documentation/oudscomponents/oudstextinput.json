{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"text":"Text input is a UI element that allows to enter, edit, or select single-line textual data.","type":"text"},{"text":" ","type":"text"},{"text":"Text input is one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries.","type":"text"},{"text":" ","type":"text"},{"text":"It provides a visual and interactive affordance for text entry while supporting labels, placeholders, icons, descriptions, and validation feedback.","type":"text"}],"sections":[],"metadata":{"externalID":"s:14OUDSComponents13OUDSTextInputV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSTextInput"}],"title":"OUDSTextInput","modules":[{"name":"Components"}],"platforms":[{"deprecated":false,"name":"iOS","introducedAt":"15.0","unavailable":false,"beta":false},{"introducedAt":"13.0","deprecated":false,"name":"macOS","unavailable":false,"beta":false},{"deprecated":false,"name":"visionOS","introducedAt":"1.0","beta":false,"unavailable":false}],"role":"symbol","symbolKind":"struct","roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"OUDSTextInput"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput"},"kind":"symbol","relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"topicSections":[{"title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Helperlink","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/TrailingAction"],"generated":true,"anchor":"Structures"},{"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(_:tableName:bundle:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)"],"title":"Initializers","generated":true},{"anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/body"],"title":"Instance Properties"},{"anchor":"Enumerations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Status"],"title":"Enumerations"},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations"],"anchor":"Default-Implementations"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstextinput"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextInput","kind":"identifier"}]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"text":"Layout","anchor":"Layout","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Text input is based on several configurable UI elements:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"label","type":"text"}],"type":"strong"},{"text":": It is used to describe the purpose of the input.","type":"text"},{"text":" ","type":"text"},{"text":"In some UI contexts, especially when space is limited or when the input is part of a compact layout (search bars, filters, inline forms), the label can be hidden.","type":"text"},{"text":" ","type":"text"},{"text":"However, hiding the label should only be done if the purpose of the input remains clear thanks to a placeholder or contextual icon","type":"text"},{"text":" ","type":"text"},{"text":"and if the label is still accessible to screen readers","type":"text"},{"type":"text","text":" "},{"text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"placeholder","type":"text"}]},{"type":"text","text":": if the text of the text input is empty a placeholder provides a hint or guidance inside the field to suggest expected input."},{"text":" ","type":"text"},{"text":"A prefix and a suffix can be added to give more context.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"leading icon"}]},{"text":": it helps indicate the purpose of the input (magnifying glass for search, envelope for email, phone device for phone number).","type":"text"},{"type":"text","text":" "},{"text":"Only use a leading icon if it adds clear functional or contextual value.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"trailing action"}],"type":"strong"},{"type":"text","text":": it is used to provide actions related to the field: clear input, toggle password visibility, open a date picker, etc."},{"text":" ","type":"text"},{"text":"Can also indicate status or feedback (error checkmark, loading spinner).","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","text":"Outlined style","anchor":"Outlined-style","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By "},{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look."},{"text":" ","type":"text"},{"type":"text","text":"Best suited for dense layouts or to enhance visibility."}]},{"inlineContent":[{"text":"When ","type":"text"},{"inlineContent":[{"type":"text","text":"outlined"}],"type":"strong"},{"text":", the text input is a minimalist design with a transparent background and a visible stroke outlining the field.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This style may be interesting for contexts other than form pages:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"When inputs need to feel lightweight and unobtrusive"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In a header (search field)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"In a selection\/filtering feature in a product catalog"}],"type":"paragraph"}]}]},{"code":["   \/\/ An outlined text input","   OUDSTextInput(label: \"Label\", text: $text, isOutlined: true)","","   \/\/ With a localizable and a bundle","   OUDSTextInput(LocalizedStringKey(\"label_wording\"), bundle: Bundle.module, text: $text)"],"type":"codeListing","syntax":"swift"},{"anchor":"Rounded-layout","type":"heading","text":"Rounded layout","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Text input can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To activate the rounded corner behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration (if the theme exposes this property at init)."},{"type":"text","text":" "},{"type":"text","text":"Some themes do not have this flexibility like "},{"type":"codeVoice","code":"SoshTheme"},{"type":"text","text":" and "},{"type":"codeVoice","code":"WireframeTheme"},{"type":"text","text":"."}]},{"anchor":"Status","type":"heading","text":"Status","level":2},{"type":"paragraph","inlineContent":[{"text":"Five status are proposed for all layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"default (by default)","type":"text"}],"type":"strong"},{"text":": Default neutral appearance, whether empty or filled.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to click, focus, and type freely without restrictions.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"error","type":"text"}],"type":"strong"},{"type":"text","text":": The "},{"code":"error","type":"codeVoice"},{"type":"text","text":" status indicates that the user input does not meet validation rules or"},{"type":"text","text":" "},{"type":"text","text":"expected formatting. It provides immediate visual feedback, typically through a red border,"},{"type":"text","text":" "},{"type":"text","text":"error icon, and a clear, accessible error message positioned below the input. The error messages replaces the helper text."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"loading","type":"codeVoice"},{"text":" state indicates that the system is processing or retrieving data","type":"text"},{"text":" ","type":"text"},{"text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"readOnly"}]},{"type":"text","text":" :The"},{"type":"codeVoice","code":"readOnly"},{"type":"text","text":", lets the text visible but not editable"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"disabled"}]},{"type":"text","text":": In "},{"type":"codeVoice","code":"disabled"},{"type":"text","text":" status, the field is non-interactive and grayed out to indicate it cannot be changed."},{"type":"text","text":" "},{"type":"text","text":"Note the SwiftUI "},{"type":"codeVoice","code":"View.disabled()"},{"type":"text","text":" is ignored."}],"type":"paragraph"}]}]},{"anchor":"Helpers","type":"heading","text":"Helpers","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper text","type":"text"}]},{"text":":  A supporting text conveys additional information about the input field,","type":"text"},{"text":" ","type":"text"},{"text":"such as how it will be used. It should ideally only take up a single line, though may wrap","type":"text"},{"text":" ","type":"text"},{"text":"to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Helper link","type":"text"}],"type":"strong"},{"type":"text","text":": If the helper text is not sufficient, it’s possible to offer the user"},{"type":"text","text":" "},{"type":"text","text":"an additional help link (the link can be external or open a modal)."}]}]}]},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"inlineContent":[{"type":"text","text":"By default no haptics are done by the component for the trailing action."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases wher you will have to make the devices vibrates."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Mandatory field indication","anchor":"Mandatory-field-indication"},{"inlineContent":[{"text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular.","type":"text"},{"text":" ","type":"text"},{"text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular.","type":"text"},{"text":" ","type":"text"},{"text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"UI rendering of the asterisk must be done with "},{"type":"emphasis","inlineContent":[{"type":"text","text":"bold font weight"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"negative content color","type":"text"}]},{"text":" (red on light backgrounds).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed."}],"type":"paragraph"},{"inlineContent":[{"text":"If there is only one field in the formular, or if the mandatory nature is obvious (such as login\/password),","type":"text"},{"text":" ","type":"text"},{"text":"no mention is necessary since the fields are essential to the formular’s functionality.","type":"text"}],"type":"paragraph"},{"anchor":"Code-samples","type":"heading","text":"Code samples","level":2},{"code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextInput(label: \"Email\", text: $text)","","    \/\/ Empty text with placeholder and suffix","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\")","","    \/\/ Empty text with prefix and suffix","    OUDSTextInput(label: \"Email\", text: $text, prefix: \"Distance\", suffix: \"km\")","","    \/\/ Add a leading icon for more context","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\", leadingIcon: Image(systemName: \"envelope\"))","","    \/\/ Add a trailing button with local image namde \"ic_cross\" for additional action","    let trailingAction = OUDSTextInput.TrailingAction(icon: Image(\"ic_cross\"), actionHint: \"Delete\") { text = \"\" }","    OUDSTextInput(label: \"Email\", text: $text, trailingAction: trailingAction)","","    \/\/ With helper text","    OUDSTextInput(label: \"Email\",","                  text: $text,","                  placeholder: \"firstName.lastName\",","                  suffix: \"@orange.com\",","                  helperText: \"The email will be automatically completed with @orange.com\")","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextInput.HelperLink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextInput(label: \"Label\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}],"type":"paragraph"},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSTextInput(label: \"Label\", text: $text, flipLeadingIcon: layoutDirection == .rightToLeft)"],"syntax":"swift","type":"codeListing"},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-input","isActive":true,"type":"reference"}],"type":"paragraph"},{"anchor":"Themes-rendering","type":"heading","text":"Themes rendering","level":2},{"anchor":"Orange","type":"heading","text":"Orange","level":3},{"inlineContent":[{"identifier":"component_textInput_Orange","type":"image"}],"type":"paragraph"},{"anchor":"Orange-Compact","type":"heading","text":"Orange Compact","level":3},{"inlineContent":[{"type":"image","identifier":"component_textInput_OrangeCompact"}],"type":"paragraph"},{"anchor":"Sosh","type":"heading","text":"Sosh","level":3},{"inlineContent":[{"type":"image","identifier":"component_textInput_Sosh"}],"type":"paragraph"},{"anchor":"Wireframe","type":"heading","text":"Wireframe","level":3},{"inlineContent":[{"type":"image","identifier":"component_textInput_Wireframe"}],"type":"paragraph"},{"style":"note","type":"aside","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.3.0 (Figma component design version)"}]}]},{"style":"note","type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.20.0"}]}]}],"kind":"content"}],"references":{"doc://OUDSComponents/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/OUDSComponents\/s8SendableP"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/init(label:text:placeholder:prefix:suffix:leadi