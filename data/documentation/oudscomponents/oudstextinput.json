put/body":{"kind":"symbol","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI4ViewP","text":"View","kind":"typeIdentifier"}],"title":"body","abstract":[],"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/body","url":"\/documentation\/oudscomponents\/oudstextinput\/body"},"component_textInput_OrangeCompact":{"identifier":"component_textInput_OrangeCompact","alt":"A text input component in light and dark modes with Orange Compact theme","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_textInput_OrangeCompact.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput":{"kind":"symbol","title":"OUDSTextInput","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSTextInput"}],"type":"topic","navigatorTitle":[{"text":"OUDSTextInput","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudstextinput","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput","role":"symbol","abstract":[{"text":"Text input is a UI element that allows to enter, edit, or select single-line textual data.","type":"text"},{"text":" ","type":"text"},{"text":"Text input is one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries.","type":"text"},{"text":" ","type":"text"},{"text":"It provides a visual and interactive affordance for text entry while supporting labels, placeholders, icons, descriptions, and validation feedback.","type":"text"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/Status":{"abstract":[{"text":"Define all available status for the text input","type":"text"}],"role":"symbol","type":"topic","title":"OUDSTextInpu