{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput"},"metadata":{"modules":[{"name":"Components"}],"role":"symbol","title":"OUDSTextInput","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextInput"}],"platforms":[{"introducedAt":"15.0","name":"iOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"13.0","name":"macOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"1.0","name":"visionOS","deprecated":false,"unavailable":false,"beta":false}],"externalID":"s:14OUDSComponents13OUDSTextInputV","symbolKind":"struct","roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"OUDSTextInput"}]},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Text input is a UI element that allows to enter, edit, or select single-line textual data."},{"type":"text","text":" "},{"type":"text","text":"Text input is one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries."},{"type":"text","text":" "},{"type":"text","text":"It provides a visual and interactive affordance for text entry while supporting labels, placeholders, icons, descriptions, and validation feedback."}],"topicSections":[{"anchor":"Structures","title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Helperlink","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/TrailingAction"],"generated":true},{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(_:tableName:bundle:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/body"],"generated":true},{"anchor":"Enumerations","title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Status"],"generated":true},{"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations"],"generated":true}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextInput","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"content":[{"anchor":"Layout","type":"heading","level":2,"text":"Layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Text input is based on several configurable UI elements:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"label","type":"text"}],"type":"strong"},{"text":": It is used to describe the purpose of the input.","type":"text"},{"text":" ","type":"text"},{"text":"In some UI contexts, especially when space is limited or when the input is part of a compact layout (search bars, filters, inline forms), the label can be hidden.","type":"text"},{"text":" ","type":"text"},{"text":"However, hiding the label should only be done if the purpose of the input remains clear thanks to a placeholder or contextual icon","type":"text"},{"text":" ","type":"text"},{"text":"and if the label is still accessible to screen readers","type":"text"},{"text":" ","type":"text"},{"text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"placeholder"}],"type":"strong"},{"text":": if the text of the text input is empty a placeholder provides a hint or guidance inside the field to suggest expected input.","type":"text"},{"text":" ","type":"text"},{"text":"A prefix and a suffix can be added to give more context.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"leading icon","type":"text"}]},{"text":": it helps indicate the purpose of the input (magnifying glass for search, envelope for email, phone device for phone number).","type":"text"},{"text":" ","type":"text"},{"text":"Only use a leading icon if it adds clear functional or contextual value.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"trailing action","type":"text"}]},{"text":": it is used to provide actions related to the field: clear input, toggle password visibility, open a date picker, etc.","type":"text"},{"text":" ","type":"text"},{"text":"Can also indicate status or feedback (error checkmark, loading spinner).","type":"text"}]}]}]},{"text":"Outlined style","anchor":"Outlined-style","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By "},{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look."},{"text":" ","type":"text"},{"text":"Best suited for dense layouts or to enhance visibility.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"inlineContent":[{"type":"text","text":"outlined"}],"type":"strong"},{"type":"text","text":", the text input is a minimalist design with a transparent background and a visible stroke outlining the field."},{"type":"text","text":" "},{"type":"text","text":"This style may be interesting for contexts other than form pages:"}]},{"items":[{"content":[{"inlineContent":[{"text":"When inputs need to feel lightweight and unobtrusive","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In a header (search field)"}]}]},{"content":[{"inlineContent":[{"text":"In a selection\/filtering feature in a product catalog","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["   \/\/ An outlined text input","   OUDSTextInput(label: \"Label\", text: $text, isOutlined: true)","","   \/\/ With a localizable and a bundle","   OUDSTextInput(LocalizedStringKey(\"label_wording\"), bundle: Bundle.module, text: $text)"]},{"text":"Rounded layout","anchor":"Rounded-layout","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Text input can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities.","type":"text"},{"text":" ","type":"text"},{"text":"For standard or business-oriented journeys, keep the default corners.","type":"text"},{"text":" ","type":"text"},{"text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To activate the rounded corner behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"text":" ","type":"text"},{"text":"Some themes do not have this flexibility like ","type":"text"},{"code":"SoshTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"WireframeTheme","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Status","anchor":"Status"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Five status are proposed for all layouts:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"default (by default)","type":"text"}],"type":"strong"},{"type":"text","text":": Default neutral appearance, whether empty or filled."},{"type":"text","text":" "},{"type":"text","text":"It allows users to click, focus, and type freely without restrictions."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"error"}]},{"text":": The ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" status indicates that the user input does not meet validation rules or","type":"text"},{"text":" ","type":"text"},{"text":"expected formatting. It provides immediate visual feedback, typically through a red border,","type":"text"},{"text":" ","type":"text"},{"text":"error icon, and a clear, accessible error message positioned below the input. The error messages replaces the helper text.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"loading"}]},{"type":"text","text":": The "},{"type":"codeVoice","code":"loading"},{"type":"text","text":" state indicates that the system is processing or retrieving data"},{"text":" ","type":"text"},{"text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"readOnly","type":"text"}]},{"type":"text","text":" :The"},{"code":"readOnly","type":"codeVoice"},{"type":"text","text":", lets the text visible but not editable"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"disabled","type":"text"}],"type":"strong"},{"text":": In ","type":"text"},{"code":"disabled","type":"codeVoice"},{"text":" status, the field is non-interactive and grayed out to indicate it cannot be changed.","type":"text"},{"text":" ","type":"text"},{"text":"Note the SwiftUI ","type":"text"},{"code":"View.disabled()","type":"codeVoice"},{"text":" is ignored.","type":"text"}],"type":"paragraph"}]}]},{"level":2,"anchor":"Helpers","text":"Helpers","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Helper text"}]},{"text":":  A supporting text conveys additional information about the input field,","type":"text"},{"text":" ","type":"text"},{"text":"such as how it will be used. It should ideally only take up a single line, though may wrap","type":"text"},{"text":" ","type":"text"},{"text":"to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper link","type":"text"}]},{"type":"text","text":": If the helper text is not sufficient, it’s possible to offer the user"},{"type":"text","text":" "},{"type":"text","text":"an additional help link (the link can be external or open a modal)."}]}]}],"type":"unorderedList"},{"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"text":"By default no haptics are done by the component for the trailing action.","type":"text"},{"text":" ","type":"text"},{"text":"However you should think about cases wher you will have to make the devices vibrates.","type":"text"},{"text":" ","type":"text"},{"text":"You can refer to the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},{"text":".","type":"text"}]},{"text":"Mandatory field indication","type":"heading","anchor":"Mandatory-field-indication","level":2},{"type":"paragraph","inlineContent":[{"text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular.","type":"text"},{"text":" ","type":"text"},{"text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular.","type":"text"},{"text":" ","type":"text"},{"text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"UI rendering of the asterisk must be done with ","type":"text"},{"inlineContent":[{"text":"bold font weight","type":"text"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"negative content color"}],"type":"emphasis"},{"text":" (red on light backgrounds).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed."}]},{"type":"paragraph","inlineContent":[{"text":"If there is only one field in the formular, or if the mandatory nature is obvious (such as login\/password),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"no mention is necessary since the fields are essential to the formular’s functionality."}]},{"text":"Code samples","type":"heading","anchor":"Code-samples","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextInput(label: \"Email\", text: $text)","","    \/\/ Empty text with placeholder and suffix","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\")","","    \/\/ Empty text with prefix and suffix","    OUDSTextInput(label: \"Email\", text: $text, prefix: \"Distance\", suffix: \"km\")","","    \/\/ Add a leading icon for more context","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\", leadingIcon: Image(systemName: \"envelope\"))","","    \/\/ Add a trailing button with local image namde \"ic_cross\" for additional action","    let trailingAction = OUDSTextInput.TrailingAction(icon: Image(\"ic_cross\"), actionHint: \"Delete\") { text = \"\" }","    OUDSTextInput(label: \"Email\", text: $text, trailingAction: trailingAction)","","    \/\/ With helper text","    OUDSTextInput(label: \"Email\",","                  text: $text,","                  placeholder: \"firstName.lastName\",","                  suffix: \"@orange.com\",","                  helperText: \"The email will be automatically completed with @orange.com\")","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextInput.HelperLink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextInput(label: \"Label\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSTextInput(label: \"Label\", text: $text, flipLeadingIcon: layoutDirection == .rightToLeft)"]},{"type":"heading","level":2,"anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-input"}]},{"type":"heading","level":2,"anchor":"Themes-rendering","text":"Themes rendering"},{"type":"heading","level":3,"anchor":"Orange","text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_textInput_Orange","type":"image"}]},{"type":"heading","level":3,"anchor":"Orange-Compact","text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_textInput_OrangeCompact","type":"image"}]},{"type":"heading","level":3,"anchor":"Sosh","text":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_textInput_Sosh","type":"image"}]},{"type":"heading","level":3,"anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_textInput_Wireframe"}]},{"type":"aside","name":"Version","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.3.0 (Figma component design version)"}]}]},{"type":"aside","name":"Since","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"0.20.0","type":"text"}]}]}],"kind":"content"}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/oudscomponents\/oudstextinput"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextInput/Helperlink":{"role":"symbol","url":"\/documentation\/oudscomponents\/oudstextinput\/helperlink","abstract":[{"text":"Used to describe the helper link above the helper text.","type":"