{"metadata":{"platforms":[{"unavailable":false,"beta":false,"name":"iOS","introducedAt":"15.0","deprecated":false},{"unavailable":false,"beta":false,"name":"macOS","introducedAt":"13.0","deprecated":false},{"introducedAt":"1.0","name":"visionOS","deprecated":false,"unavailable":false,"beta":false}],"symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextInput"}],"modules":[{"name":"Components"}],"roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"OUDSTextInput"}],"externalID":"s:14OUDSComponents13OUDSTextInputV","title":"OUDSTextInput","role":"symbol"},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput"},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextInput"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"content":[{"level":2,"text":"Layout","type":"heading","anchor":"Layout"},{"inlineContent":[{"text":"Text input is based on several configurable UI elements:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"label","type":"text"}]},{"type":"text","text":": It is used to describe the purpose of the input."},{"type":"text","text":" "},{"type":"text","text":"In some UI contexts, especially when space is limited or when the input is part of a compact layout (search bars, filters, inline forms), the label can be hidden."},{"type":"text","text":" "},{"type":"text","text":"However, hiding the label should only be done if the purpose of the input remains clear thanks to a placeholder or contextual icon"},{"type":"text","text":" "},{"type":"text","text":"and if the label is still accessible to screen readers"},{"type":"text","text":" "},{"type":"text","text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"placeholder","type":"text"}],"type":"strong"},{"type":"text","text":": if the text of the text input is empty a placeholder provides a hint or guidance inside the field to suggest expected input."},{"text":" ","type":"text"},{"text":"A prefix and a suffix can be added to give more context.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"leading icon"}],"type":"strong"},{"text":": it helps indicate the purpose of the input (magnifying glass for search, envelope for email, phone device for phone number).","type":"text"},{"text":" ","type":"text"},{"text":"Only use a leading icon if it adds clear functional or contextual value.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"trailing action"}],"type":"strong"},{"text":": it is used to provide actions related to the field: clear input, toggle password visibility, open a date picker, etc.","type":"text"},{"text":" ","type":"text"},{"text":"Can also indicate status or feedback (error checkmark, loading spinner).","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"text":"Outlined style","type":"heading","anchor":"Outlined-style"},{"inlineContent":[{"text":"By ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for dense layouts or to enhance visibility.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When ","type":"text"},{"inlineContent":[{"type":"text","text":"outlined"}],"type":"strong"},{"text":", the text input is a minimalist design with a transparent background and a visible stroke outlining the field.","type":"text"},{"text":" ","type":"text"},{"text":"This style may be interesting for contexts other than form pages:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When inputs need to feel lightweight and unobtrusive","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In a header (search field)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In a selection\/filtering feature in a product catalog","type":"text"}]}]}],"type":"unorderedList"},{"code":["   \/\/ An outlined text input","   OUDSTextInput(label: \"Label\", text: $text, isOutlined: true)"],"type":"codeListing","syntax":"swift"},{"level":3,"text":"Rounded layout","type":"heading","anchor":"Rounded-layout"},{"inlineContent":[{"text":"Text input can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities.","type":"text"},{"text":" ","type":"text"},{"text":"For standard or business-oriented journeys, keep the default corners.","type":"text"},{"text":" ","type":"text"},{"text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To activate the rounded corner behavior, set to true the ","type":"text"},{"code":"hasRoundedTextInputs","type":"codeVoice"},{"text":" values of the ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"text":" ","type":"text"},{"text":"Some themes do not have this flexibility like ","type":"text"},{"code":"SoshTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"WireframeTheme","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"Status","type":"heading","anchor":"Status"},{"inlineContent":[{"text":"Five status are proposed for all layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default (by default)"}],"type":"strong"},{"text":": Default neutral appearance, whether empty or filled.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to click, focus, and type freely without restrictions.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"error"}],"type":"strong"},{"text":": The ","type":"text"},{"type":"codeVoice","code":"error"},{"text":" status indicates that the user input does not meet validation rules or","type":"text"},{"text":" ","type":"text"},{"text":"expected formatting. It provides immediate visual feedback, typically through a red border,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"error icon, and a clear, accessible error message positioned below the input. The error messages replaces the helper text."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"loading","type":"text"}],"type":"strong"},{"type":"text","text":": The "},{"code":"loading","type":"codeVoice"},{"type":"text","text":" state indicates that the system is processing or retrieving data"},{"type":"text","text":" "},{"type":"text","text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"readOnly","type":"text"}],"type":"strong"},{"text":" :The","type":"text"},{"type":"codeVoice","code":"readOnly"},{"text":", lets the text visible but not editable","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"disabled","type":"text"}],"type":"strong"},{"text":": In ","type":"text"},{"type":"codeVoice","code":"disabled"},{"text":" status, the field is non-interactive and grayed out to indicate it cannot be changed.","type":"text"},{"text":" ","type":"text"},{"text":"Note the SwiftUI ","type":"text"},{"type":"codeVoice","code":"View.disabled()"},{"text":" is ignored.","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Helpers","anchor":"Helpers"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Helper text"}]},{"type":"text","text":":  A supporting text conveys additional information about the input field,"},{"text":" ","type":"text"},{"text":"such as how it will be used. It should ideally only take up a single line, though may wrap","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to multiple lines if required, and be either persistently visible or visible only on focus."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper link","type":"text"}]},{"type":"text","text":": If the helper text is not sufficient, it’s possible to offer the user"},{"type":"text","text":" "},{"type":"text","text":"an additional help link (the link can be external or open a modal)."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"text":"By default no haptics are done by the component for the trailing action.","type":"text"},{"text":" ","type":"text"},{"text":"However you should think about cases wher you will have to make the devices vibrates.","type":"text"},{"text":" ","type":"text"},{"text":"You can refer to the ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","type":"reference"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Mandatory field indication","anchor":"Mandatory-field-indication"},{"inlineContent":[{"text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular.","type":"text"},{"type":"text","text":" "},{"text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular.","type":"text"},{"type":"text","text":" "},{"text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"UI rendering of the asterisk must be done with ","type":"text"},{"inlineContent":[{"type":"text","text":"bold font weight"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"negative content color"}],"type":"emphasis"},{"text":" (red on light backgrounds).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If there is only one field in the formular, or if the mandatory nature is obvious (such as login\/password),","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"no mention is necessary since the fields are essential to the formular’s functionality."}],"type":"paragraph"},{"anchor":"Code-samples","level":2,"text":"Code samples","type":"heading"},{"syntax":"swift","code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextInput(label: \"Email\", text: $text)","","    \/\/ Empty text with placeholder and suffix","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\")","","    \/\/ Empty text with prefix and suffix","    OUDSTextInput(label: \"Email\", text: $text, prefix: \"Distance\", suffix: \"km\")","","    \/\/ Add a leading icon for more context","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\", leadingIcon: Image(systemName: \"envelope\"))","","    \/\/ Add a trailing button with local image namde \"ic_cross\" for additional action","    let trailingAction = OUDSTextInput.TrailingAction(icon: Image(\"ic_cross\"), actionHint: \"Delete\") { text = \"\" }","    OUDSTextInput(label: \"Email\", text: $text, trailingAction: trailingAction)","","    \/\/ With helper text","    OUDSTextInput(label: \"Email\",","                  text: $text,","                  placeholder: \"firstName.lastName\",","                  suffix: \"@orange.com\",","                  helperText: \"The email will be automatically completed with @orange.com\")","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextInput.HelperLink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextInput(label: \"Label\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSTextInput(label: \"Label\", text: $text, flipLeadingIcon: layoutDirection == .rightToLeft)"],"type":"codeListing"},{"anchor":"Design-documentation","level":2,"text":"Design documentation","type":"heading"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-input"}],"type":"paragraph"},{"anchor":"Themes-rendering","level":2,"text":"Themes rendering","type":"heading"},{"anchor":"Orange","level":3,"text":"Orange","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_textInput_Orange"}],"type":"paragraph"},{"anchor":"Orange-Compact","level":3,"text":"Orange Compact","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_textInput_OrangeCompact"}],"type":"paragraph"},{"anchor":"Sosh","level":3,"text":"Sosh","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_textInput_Sosh"}],"type":"paragraph"},{"anchor":"Wireframe","level":3,"text":"Wireframe","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_textInput_Wireframe"}],"type":"paragraph"},{"style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.3.0 (Figma component design version)"}]}],"type":"aside"},{"style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.20.0"}]}],"type":"aside"}],"kind":"content"}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Helperlink","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/TrailingAction"],"generated":true,"title":"Structures","anchor":"Structures"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:c