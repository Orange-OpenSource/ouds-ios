entifier","text":"OUDSTextInput"},{"kind":"text","text":"."},{"preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV10HelperlinkV","kind":"typeIdentifier","text":"Helperlink"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"isOutlined"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"status"},{"kind":"text","text":": "},{"preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV","kind":"typeIdentifier","text":"OUDSTextInput"},{"kind":"text","text":"."},{"preciseIdentifier":"s:14OUDSComponents13OUDSTextInputV6StatusO","kind":"typeIdentifier","text":"Status"},{"kind":"text","text":")"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:status:)"},"component_textInput_Orange":{"identifier":"component_textInput_Orange","alt":"A text input component in light and dark mode with Orange theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_textInput_Orange.png"}],"type":"image"}}}