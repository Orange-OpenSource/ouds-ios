{"sections":[],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextInput"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"Layout","level":2,"type":"heading","text":"Layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Text input is based on several configurable UI elements:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"label"}]},{"type":"text","text":": It is used to describe the purpose of the input."},{"type":"text","text":" "},{"type":"text","text":"In some UI contexts, especially when space is limited or when the input is part of a compact layout (search bars, filters, inline forms), the label can be hidden."},{"type":"text","text":" "},{"type":"text","text":"However, hiding the label should only be done if the purpose of the input remains clear thanks to a placeholder or contextual icon"},{"type":"text","text":" "},{"type":"text","text":"and if the label is still accessible to screen readers"},{"type":"text","text":" "},{"type":"text","text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"placeholder"}]},{"type":"text","text":": if the text of the text input is empty a placeholder provides a hint or guidance inside the field to suggest expected input."},{"type":"text","text":" "},{"type":"text","text":"A prefix and a suffix can be added to give more context."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"leading icon"}]},{"type":"text","text":": it helps indicate the purpose of the input (magnifying glass for search, envelope for email, phone device for phone number)."},{"type":"text","text":" "},{"type":"text","text":"Only use a leading icon if it adds clear functional or contextual value."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"trailing action"}]},{"type":"text","text":": it is used to provide actions related to the field: clear input, toggle password visibility, open a date picker, etc."},{"type":"text","text":" "},{"type":"text","text":"Can also indicate status or feedback (error checkmark, loading spinner)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Outlined-style","level":2,"type":"heading","text":"Outlined style"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By "},{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":", the input is with a subtle background fill and invisible bottom border, creating a softer and more contained look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for dense layouts or to enhance visibility."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"strong","inlineContent":[{"type":"text","text":"outlined"}]},{"type":"text","text":", the text input is a minimalist design with a transparent background and a visible stroke outlining the field."},{"type":"text","text":" "},{"type":"text","text":"This style may be interesting for contexts other than form pages:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"When inputs need to feel lightweight and unobtrusive"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"In a header (search field)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"In a selection\/filtering feature in a product catalog"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"swift","type":"codeListing","code":["   \/\/ An outlined text input","   OUDSTextInput(label: \"Label\", text: $text, isOutlined: true)","","   \/\/ With a localizable and a bundle","   OUDSTextInput(LocalizedStringKey(\"label_wording\"), bundle: Bundle.module, text: $text)"]},{"anchor":"Rounded-layout","level":3,"type":"heading","text":"Rounded layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Text input can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To activate the rounded corner behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedTextInputs"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration (if the theme exposes this property at init)."},{"type":"text","text":" "},{"type":"text","text":"Some themes do not have this flexibility like "},{"type":"codeVoice","code":"SoshTheme"},{"type":"text","text":" and "},{"type":"codeVoice","code":"WireframeTheme"},{"type":"text","text":"."}]},{"anchor":"Status","level":2,"type":"heading","text":"Status"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Five status are proposed for all layouts:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default (by default)"}]},{"type":"text","text":": Default neutral appearance, whether empty or filled."},{"type":"text","text":" "},{"type":"text","text":"It allows users to click, focus, and type freely without restrictions."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"error"}]},{"type":"text","text":": The "},{"type":"codeVoice","code":"error"},{"type":"text","text":" status indicates that the user input does not meet validation rules or"},{"type":"text","text":" "},{"type":"text","text":"expected formatting. It provides immediate visual feedback, typically through a red border,"},{"type":"text","text":" "},{"type":"text","text":"error icon, and a clear, accessible error message positioned below the input. The error messages replaces the helper text."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"loading"}]},{"type":"text","text":": The "},{"type":"codeVoice","code":"loading"},{"type":"text","text":" state indicates that the system is processing or retrieving data"},{"type":"text","text":" "},{"type":"text","text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"readOnly"}]},{"type":"text","text":" :The"},{"type":"codeVoice","code":"readOnly"},{"type":"text","text":", lets the text visible but not editable"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"disabled"}]},{"type":"text","text":": In "},{"type":"codeVoice","code":"disabled"},{"type":"text","text":" status, the field is non-interactive and grayed out to indicate it cannot be changed."},{"type":"text","text":" "},{"type":"text","text":"Note the SwiftUI "},{"type":"codeVoice","code":"View.disabled()"},{"type":"text","text":" is ignored."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Helpers","level":2,"type":"heading","text":"Helpers"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Helper text"}]},{"type":"text","text":":  A supporting text conveys additional information about the input field,"},{"type":"text","text":" "},{"type":"text","text":"such as how it will be used. It should ideally only take up a single line, though may wrap"},{"type":"text","text":" "},{"type":"text","text":"to multiple lines if required, and be either persistently visible or visible only on focus."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Helper link"}]},{"type":"text","text":": If the helper text is not sufficient, it’s possible to offer the user"},{"type":"text","text":" "},{"type":"text","text":"an additional help link (the link can be external or open a modal)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Accessibility-considerations","level":2,"type":"heading","text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default no haptics are done by the component for the trailing action."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases wher you will have to make the devices vibrates."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","type":"reference","isActive":true},{"type":"text","text":"."}]},{"anchor":"Mandatory-field-indication","level":2,"type":"heading","text":"Mandatory field indication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"UI rendering of the asterisk must be done with "},{"type":"emphasis","inlineContent":[{"type":"text","text":"bold font weight"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"negative content color"}]},{"type":"text","text":" (red on light backgrounds)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is only one field in the formular, or if the mandatory nature is obvious (such as login\/password),"},{"type":"text","text":" "},{"type":"text","text":"no mention is necessary since the fields are essential to the formular’s functionality."}]},{"anchor":"Rich-text","level":2,"type":"heading","text":"Rich text"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Rich text can be used for error and helper texts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Strong text can be used sparingly to highlight key information within the content."},{"type":"text","text":" "},{"type":"text","text":"No other text styles should be used."},{"type":"text","text":" "},{"type":"text","text":"Underlined text must not be applied manually (e.g. in error message), as it is commonly associated with hyperlinks and may mislead users."}]},{"anchor":"Code-samples","level":2,"type":"heading","text":"Code samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextInput(label: \"Email\", text: $text)","","    \/\/ Empty text with placeholder and suffix","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\")","","    \/\/ Empty text with prefix and suffix","    OUDSTextInput(label: \"Email\", text: $text, prefix: \"Distance\", suffix: \"km\")","","    \/\/ Add a leading icon for more context","    OUDSTextInput(label: \"Email\", text: $text, placeholder: \"firstName.lastName\", suffix: \"@orange.com\", leadingIcon: Image(systemName: \"envelope\"))","","    \/\/ Add a trailing button with local image namde \"ic_cross\" for additional action","    let trailingAction = OUDSTextInput.TrailingAction(icon: Image(\"ic_cross\"), actionHint: \"Delete\") { text = \"\" }","    OUDSTextInput(label: \"Email\", text: $text, trailingAction: trailingAction)","","    \/\/ With helper text","    OUDSTextInput(label: \"Email\",","                  text: $text,","                  placeholder: \"firstName.lastName\",","                  suffix: \"@orange.com\",","                  helperText: \"The email will be automatically completed with @orange.com\")","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextInput.HelperLink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextInput(label: \"Label\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSTextInput(label: \"Label\", text: $text, flipLeadingIcon: layoutDirection == .rightToLeft)"]},{"anchor":"Design-documentation","level":2,"type":"heading","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-input","type":"reference","isActive":true}]},{"anchor":"Themes-rendering","level":2,"type":"heading","text":"Themes rendering"},{"anchor":"Orange","level":3,"type":"heading","text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_textInput_Orange","type":"image"}]},{"anchor":"Orange-Compact","level":3,"type":"heading","text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_textInput_OrangeCompact","type":"image"}]},{"anchor":"Sosh","level":3,"type":"heading","text":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_textInput_Sosh","type":"image"}]},{"anchor":"Wireframe","level":3,"type":"heading","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_textInput_Wireframe","type":"image"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.4.0 (Figma component design version)"}]}],"type":"aside","style":"note","name":"Version"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.20.0"}]}],"type":"aside","style":"note","name":"Since"}]}],"kind":"symbol","abstract":[{"text":"Text input is a UI element that allows to enter, edit, or select single-line textual data.","type":"text"},{"text":" ","type":"text"},{"text":"Text input is one of the most fundamental form elements used to capture user input such as names, emails, passwords, or search queries.","type":"text"},{"text":" ","type":"text"},{"text":"It provides a visual and interactive affordance for text entry while supporting labels, placeholders, icons, descriptions, and validation feedback.","type":"text"}],"topicSections":[{"anchor":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Helperlink","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/TrailingAction"],"generated":true,"title":"Structures"},{"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(_:tableName:bundle:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)-30mt9","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(_:tableName:bundle:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)-a4u5","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)-1pe0w","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/init(label:text:placeholder:prefix:suffix:leadingIcon:flipLeadingIcon:trailingAction:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)-8b5ox"],"generated":true,"title":"Initializers"},{"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/body"],"generated":true,"title":"Instance Properties"},{"title":"Enumerations","anchor":"Enumerations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/Status"]},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput\/View-Implementations"],"generated":true,"title":"Default Implementations"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstextinput"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextInput","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"Components"}],"symbolKind":"struct","title":"OUDSTextInput","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextInput","kind":"identifier"}],"roleHeading":"Structure","role":"symbol","externalID":"s:14OUDSComponents13OUDSTextInputV","platforms":[{"introducedAt":"15.0","deprecated":false,"beta":false,"unavailable":false,"name":"iOS"},{"introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false,"name":"macOS"},{"introducedAt":"1.0","deprecated":false,"beta":false,"unavailable":false,"name":"visionOS"}],"navigatorTitle":[{"text":"OUDSTextInput","kind":"identifier"}]},"references":{"component_textInput_Orange":{"alt":"A text input component in light and dark modes with Orange theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_textInput_Orange.png"}],"type":"image","identifier":"component_textInput_Orange"},"https://r.orange.fr/r/S-ouds-doc-text-input":{"type":"link","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-input","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-input","title":"unified-design-system.orange.com"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"type":"topic","title":"Component