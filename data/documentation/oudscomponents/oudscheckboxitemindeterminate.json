{"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},"sections":[],"abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(_:selection:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/body"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations"],"title":"Default Implementations","generated":true,"anchor":"Default-Implementations"}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Layouts","text":"Layouts"},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"inverse","type":"text"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Indicator-states","text":"Indicator states"},{"type":"paragraph","inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"indeterminate","type":"text"}]},{"type":"text","text":": mike a prefilled or preticked checkbox, the user did not do anything on it yet"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"If you need a checkbox with only two states to manage use instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"level":2,"type":"heading","anchor":"Particular-cases","text":"Particular cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true,"type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In addition, the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true,"type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet","type":"text"},{"text":" ","type":"text"},{"text":"but this component must not be considered as disabled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}]},{"level":2,"type":"heading","anchor":"Accessibility-considerations","text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"}]},{"level":2,"type":"heading","anchor":"Forbidden-by-design","text":"Forbidden by design"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}],"type":"strong"}]},{"level":2,"type":"heading","anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Bazinga!\", selection: $selection, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  description: \"Of dreaming boys and wide-eyed girls\",","                                  isReversed: true,","                                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  isError: true,","                                  errorText: \"Something wrong\",","                                  hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","        .disabled(true)","","    \/\/ A leading checkbox with a label and and icon but with the icon flipped vertically","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"type":"paragraph","inlineContent":[{"text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: layoutDirection == .rightToLeft,","                                  isReversed: layoutDirection == .rightToLeft)"]},{"level":2,"type":"heading","anchor":"Suggestions","text":"Suggestions"},{"type":"paragraph","inlineContent":[{"text":"According to the ","type":"text"},{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the checkbox by default must be used in unselected state.","type":"text"}]},{"level":2,"type":"heading","anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"type":"reference","overridingTitle":"unified-design-system.orange.com","overridingTitleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}]}]},{"level":2,"type":"heading","anchor":"Themes-rendering","text":"Themes rendering"},{"level":3,"type":"heading","anchor":"Orange","text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_checkboxItem_Orange","type":"image"}]},{"level":3,"type":"heading","anchor":"Orange-Compact","text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_checkboxItem_OrangeCompact","type":"image"}]},{"level":3,"type":"heading","anchor":"Sosh","text":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_checkboxItem_Sosh","type":"image"}]},{"level":3,"type":"heading","anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_checkboxItem_Wireframe","type":"image"}]},{"type":"aside","style":"note","name":"Version","content":[{"inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}]}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitemindeterminate"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","roleHeading":"Structure","platforms":[{"deprecated":false,"beta":false,"unavailable":false,"name":"iOS","introducedAt":"15.0"},{"deprecated":false,"beta":false,"unavailable":false,"name":"macOS","introducedAt":"13.0"},{"deprecated":false,"beta":false,"unavailable":false,"name":"tvOS","introducedAt":"16.0"},{"deprecated":false,"beta":false,"unavailable":false,"name":"visionOS","introducedAt":"1.0"},{"deprecated":false,"beta":false,"unavailable":false,"name":"watchOS","introducedAt":"11.0"}],"externalID":"s:14OUDSComponents29OUDSCheckboxItemIndeterminateV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"modules":[{"name":"Components"}],"navigatorTitle":[{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"title":"OUDSCheckboxItemIndeterminate","symbolKind":"struct"},"references":{"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewMo