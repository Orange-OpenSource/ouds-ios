boxIndicatorStateO","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"label","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"helper","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"icon","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Image","preciseIdentifier":"s:7SwiftUI5ImageV","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"flipIcon","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"isReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"isError","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"isReadOnly","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"hasDivider","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":")","kind":"text"}],"kind":"symbol","url":"\/documentation\/oudscomponents\/oudscheckboxitemindeterminate\/init(selection:label:helper:icon:flipicon:isreversed:iserror:isreadonly:hasdivider:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(selection:label:helper:icon:flipIcon:isReversed:isError:isReadOnly:hasDivider:)","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckbox":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSCheckbox","kind":"identifier"}],"url":"\/documentatio