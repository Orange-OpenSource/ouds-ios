e a checkbox with additional texts and icon, prefer instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true,"type":"reference"},{"text":".","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxIndeterminate","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSCheckboxIndeterminate","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem":{"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" proposes layouts to add in your views some checkboxes components with labels and icons."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with only an indicator prefer instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"type":"text","text":"."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"title":"OUDSCheckboxItem","url":"\/documentation\/oudscomponents\/oudscheckboxitem","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","kind":"symbol"}}}