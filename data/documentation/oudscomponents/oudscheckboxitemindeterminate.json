{"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitemindeterminate"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(_:selection:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"title":"Initializers","generated":true},{"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/body"],"title":"Instance Properties","generated":true},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations"],"title":"Default Implementations","generated":true}],"metadata":{"title":"OUDSCheckboxItemIndeterminate","role":"symbol","roleHeading":"Structure","externalID":"s:14OUDSComponents29OUDSCheckboxItemIndeterminateV","symbolKind":"struct","navigatorTitle":[{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"platforms":[{"unavailable":false,"introducedAt":"15.0","name":"iOS","beta":false,"deprecated":false},{"unavailable":false,"introducedAt":"13.0","name":"macOS","beta":false,"deprecated":false},{"unavailable":false,"introducedAt":"16.0","name":"tvOS","beta":false,"deprecated":false},{"unavailable":false,"introducedAt":"1.0","name":"visionOS","beta":false,"deprecated":false},{"unavailable":false,"introducedAt":"11.0","name":"watchOS","beta":false,"deprecated":false}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"modules":[{"name":"Components"}]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"level":2,"anchor":"Layouts","type":"heading","text":"Layouts"},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"inverse"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Indicator-states","type":"heading","text":"Indicator states"},{"inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"unselected"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"indeterminate"}]},{"type":"text","text":": mike a prefilled or preticked checkbox, the user did not do anything on it yet"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"If you need a checkbox with only two states to manage use instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Particular-cases","type":"heading","text":"Particular cases"},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In addition, the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet"},{"type":"text","text":" "},{"type":"text","text":"but this component must not be considered as disabled."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}],"type":"paragraph"},{"level":2,"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait."}],"type":"paragraph"},{"level":2,"anchor":"Forbidden-by-design","type":"heading","text":"Forbidden by design"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}],"type":"paragraph"},{"level":2,"anchor":"Code-samples","type":"heading","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Bazinga!\", selection: $selection, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  description: \"Of dreaming boys and wide-eyed girls\",","                                  isReversed: true,","                                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  isError: true,","                                  errorText: \"Something wrong\",","                                  hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","        .disabled(true)","","    \/\/ A leading checkbox with a label and and icon but with the icon flipped vertically","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"inlineContent":[{"type":"text","text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: layoutDirection == .rightToLeft,","                                  isReversed: layoutDirection == .rightToLeft)"]},{"level":2,"anchor":"Suggestions","type":"heading","text":"Suggestions"},{"inlineContent":[{"type":"text","text":"According to the "},{"type":"reference","isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}],"type":"paragraph"},{"level":2,"anchor":"Design-documentation","type":"heading","text":"Design documentation"},{"inlineContent":[{"overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"type":"reference","isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitle":"unified-design-system.orange.com"}],"type":"paragraph"},{"level":2,"anchor":"Themes-rendering","type":"heading","text":"Themes rendering"},{"level":3,"anchor":"Orange","type":"heading","text":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Orange"}],"type":"paragraph"},{"level":3,"anchor":"Orange-Compact","type":"heading","text":"Orange Compact"},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_OrangeCompact"}],"type":"paragraph"},{"level":3,"anchor":"Sosh","type":"heading","text":"Sosh"},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Sosh"}],"type":"paragraph"},{"level":3,"anchor":"Wireframe","type":"heading","text":"Wireframe"},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Wireframe"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"2.4.0 (Figma component design version)","type":"text"}]}],"type":"aside","style":"note","name":"Version"},{"content":[{"type":"paragraph","inlineContent":[{"text":"0.12.0","type":"text"}]}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","kind":"relationships"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"kind":"article","role":"article","title":"Controls","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls","type":"topic","url":"\/documentation\/oudscomponents\/controls","abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"controls","type":"text"}],"type":"strong"},{"text":" 