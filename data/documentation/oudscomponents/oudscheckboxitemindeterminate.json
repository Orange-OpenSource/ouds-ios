{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitemindeterminate"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Layouts","anchor":"Layouts"},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"inverse"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}]}]}]},{"type":"heading","level":2,"text":"Indicator states","anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"unselected"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"indeterminate"}]},{"type":"text","text":": mike a prefilled or preticked checkbox, the user did not do anything on it yet"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"If you need a checkbox with only two states to manage use instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"text":"Particular cases","level":2,"type":"heading","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, the "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet"},{"type":"text","text":" "},{"type":"text","text":"but this component must not be considered as disabled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}]},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"}]},{"type":"heading","level":2,"text":"Forbidden by design","anchor":"Forbidden-by-design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Bazinga!\", selection: $selection, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  description: \"Of dreaming boys and wide-eyed girls\",","                                  isReversed: true,","                                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  isError: true,","                                  errorText: \"Something wrong\",","                                  hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","        .disabled(true)","","    \/\/ A leading checkbox with a label and and icon but with the icon flipped vertically","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: layoutDirection == .rightToLeft,","                                  isReversed: layoutDirection == .rightToLeft)"]},{"type":"heading","level":2,"text":"Suggestions","anchor":"Suggestions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the "},{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}]},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"overridingTitle":"unified-design-system.orange.com"}]},{"type":"heading","level":2,"text":"Themes rendering","anchor":"Themes-rendering"},{"type":"heading","level":3,"text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Orange"}]},{"type":"heading","level":3,"text":"Orange Compact","anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_OrangeCompact"}]},{"type":"heading","level":3,"text":"Sosh","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Sosh"}]},{"type":"heading","level":3,"text":"Wireframe","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkboxItem_Wireframe"}]},{"type":"aside","style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}]}]},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(_:selection:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"g