{"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(_:selection:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(selection:label:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/body"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"metadata":{"role":"symbol","platforms":[{"unavailable":false,"beta":false,"name":"iOS","introducedAt":"15.0","deprecated":false},{"unavailable":false,"beta":false,"name":"macOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"tvOS","introducedAt":"16.0","deprecated":false},{"unavailable":false,"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false},{"unavailable":false,"beta":false,"name":"watchOS","introducedAt":"11.0","deprecated":false}],"symbolKind":"struct","navigatorTitle":[{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"modules":[{"name":"Components"}],"roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"externalID":"s:14OUDSComponents29OUDSCheckboxItemIndeterminateV","title":"OUDSCheckboxItemIndeterminate"},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItemIndeterminate"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"text":"Layouts","type":"heading","level":2,"anchor":"Layouts"},{"inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"inverse"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"text":" layout but with a trailing checkbox indicator and a leading optional image","type":"text"}],"type":"paragraph"}]}]},{"text":"Indicator states","type":"heading","level":2,"anchor":"Indicator-states"},{"inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"indeterminate"}],"type":"strong"},{"text":": mike a prefilled or preticked checkbox, the user did not do anything on it yet","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"If you need a checkbox with only two states to manage use instead ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Particular cases","type":"heading","level":2,"anchor":"Particular-cases"},{"inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In addition, the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet","type":"text"},{"text":" ","type":"text"},{"text":"but this component must not be considered as disabled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}],"type":"paragraph"},{"text":"Accessibility considerations","type":"heading","level":2,"anchor":"Accessibility-considerations"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"}],"type":"paragraph"},{"text":"Forbidden by design","type":"heading","level":2,"anchor":"Forbidden-by-design"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}],"type":"strong"}],"type":"paragraph"},{"text":"Code samples","type":"heading","level":2,"anchor":"Code-samples"},{"type":"codeListing","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Bazinga!\", selection: $selection, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  description: \"Of dreaming boys and wide-eyed girls\",","                                  isReversed: true,","                                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  isError: true,","                                  errorText: \"Something wrong\",","                                  hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","        .disabled(true)","","    \/\/ A leading checkbox with a label and and icon but with the icon flipped vertically","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):"}],"type":"paragraph"},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: layoutDirection == .rightToLeft,","                                  isReversed: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"text":"Suggestions","type":"heading","level":2,"anchor":"Suggestions"},{"inlineContent":[{"type":"text","text":"According to the "},{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}],"type":"paragraph"},{"text":"Design documentation","type":"heading","level":2,"anchor":"Design-documentation"},{"inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"overridingTitle":"unified-design-system.orange.com","type":"reference"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Themes rendering","anchor":"Themes-rendering"},{"text":"Orange","type":"heading","level":3,"anchor":"Orange"},{"inlineContent":[{"identifier":"component_checkboxItem_Orange","type":"image"}],"type":"paragraph"},{"anchor":"Orange-Compact","level":3,"text":"Orange Compact","type":"heading"},{"inlineContent":[{"identifier":"component_checkboxItem_OrangeCompact","type":"image"}],"type":"paragraph"},{"anchor":"Sosh","level":3,"text":"Sosh","type":"heading"},{"inlineContent":[{"identifier":"component_checkboxItem_Sosh","type":"image"}],"type":"paragraph"},{"anchor":"Wireframe","level":3,"text":"Wireframe","type":"heading"},{"inlineContent":[{"identifier":"component_checkboxItem_Wireframe","type":"image"}],"type":"paragraph"},{"style":"note","name":"Version","content":[{"inlineContent":[{"text":"2.4.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"type":"aside"},{"style":"note","type":"aside","name":"Since","content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}]}]}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","interfaceLanguage":"swift"},"abstract":[{"text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices.","type":"text"},{"text":" ","type":"text"},{"text":"Checkbox item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets.","type":"text"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitemindeterminate"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"https://r.orange.fr/r/S-ouds-doc-checkbox":{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","titleInlineContent":[{"text":"doc