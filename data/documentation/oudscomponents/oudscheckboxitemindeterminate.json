xt":"isReversed"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"isError"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"isReadOnly"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"hasDivider"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":")"}]},"doc://OUDSComponents/7SwiftUI4ViewP":{"title":"SwiftUICore.View","type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP"},"https://unified-design-system.orange.com/472794e18/p/23f1c1-checkbox":{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","type":"link","title":"unified-design-system.orange.com","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxIndeterminate":{"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","isActive":true},{"type":"text","text":" proposes layout to add in your views a lonely checkbox, without labels, texts nor icons components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with additional texts and icon, prefer instead "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"type":"text","text":"."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","url":"\/documentation\/oudscomponents\/oudscheckboxindeterminate","title"