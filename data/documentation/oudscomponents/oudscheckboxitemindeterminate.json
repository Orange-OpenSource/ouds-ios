{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"text":"Layouts","type":"heading","anchor":"Layouts","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"inverse"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Indicator states","type":"heading","anchor":"Indicator-states","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"selected","type":"text"}],"type":"strong"},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"indeterminate"}]},{"type":"text","text":": mike a prefilled or preticked checkbox, the user did not do anything on it yet"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"If you need a checkbox with only two states to manage use instead "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Particular cases","anchor":"Particular-cases"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","type":"reference","isActive":true},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"type":"text","text":" "},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In addition, the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true,"type":"reference"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet"},{"text":" ","type":"text"},{"text":"but this component must not be considered as disabled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"text":" ","type":"text"},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait."}],"type":"paragraph"},{"level":2,"anchor":"Forbidden-by-design","type":"heading","text":"Forbidden by design"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}],"type":"strong"}],"type":"paragraph"},{"level":2,"anchor":"Code-samples","type":"heading","text":"Code samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true)","","    \/\/ A leading checkbox with a label and a description as helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Bazinga!\", selection: $selection, description: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The reversed layout will be used here.","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  description: \"Of dreaming boys and wide-eyed girls\",","                                  isReversed: true,","                                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSCheckboxItemIndeterminate(\"We live in a fabled world\",","                                  selection: $selection,","                                  isError: true,","                                  errorText: \"Something wrong\",","                                  hasDivider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection)","        .disabled(true)","","    \/\/ A leading checkbox with a label and and icon but with the icon flipped vertically","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItemIndeterminate(\"Hello world\", selection: $selection, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"inlineContent":[{"text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSCheckboxItemIndeterminate(\"Cocorico !\",","                                  selection: $selection,","                                  icon: Image(systemName: \"figure.handball\"),","                                  flipIcon: layoutDirection == .rightToLeft,","                                  isReversed: layoutDirection == .rightToLeft)"]},{"type":"heading","anchor":"Suggestions","text":"Suggestions","level":2},{"inlineContent":[{"type":"text","text":"According to the "},{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}],"type":"paragraph"},{"type":"heading","anchor":"Design-documentation","text":"Design documentation","level":2},{"inlineContent":[{"overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"isActive":true,"type":"reference","overridingTitle":"unified-design-system.orange.com","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox"}],"type":"paragraph"},{"type":"heading","anchor":"Themes-rendering","text":"Themes rendering","level":2},{"type":"heading","anchor":"Orange","text":"Orange","level":3},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Orange"}],"type":"paragraph"},{"type":"heading","anchor":"Orange-Compact","text":"Orange Compact","level":3},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_OrangeCompact"}],"type":"paragraph"},{"type":"heading","anchor":"Sosh","text":"Sosh","level":3},{"inlineContent":[{"type":"image","identifier":"component_checkboxItem_Sosh"}],"type":"paragraph"},{"text":"Wireframe","type":"heading","anchor":"Wireframe","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_checkboxItem_Wireframe","type":"image"}]},{"type":"aside","style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}]}]},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.12.0","type":"text"}]}]}]}],"topicSections":[{"anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(_:selection:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(selection:label:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"title":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/body"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndet