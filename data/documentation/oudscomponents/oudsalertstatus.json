rand-related icons to enhance recognition or storytelling."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Functional statuses communicate specific system statuses, results, or user feedback:"},{"type":"text","text":" "},{"type":"text","text":"Each variant conveys a clear semantic meaning and must always be paired with its dedicated functional icon to ensure clarity and accessibility."},{"type":"text","text":" "},{"type":"text","text":"Use functional alerts to inform user about state changes, confirmations, or issues that are directly connected to system logic or user actions."},{"type":"text","text":" "},{"type":"text","text":"These messages carry functional meaning and help guide user response or acknowledgment."}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsalertstatus"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"The status of the alerts.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage"},{"text":" background color and its icon color are based on this status.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInlineAlert"},{"text":" icon and text color are based on this status.","type":"text"}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"kind":"symbol","sections":[],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/warning":{"title":"OUDSAlertStatus.warning","fragments":[{"