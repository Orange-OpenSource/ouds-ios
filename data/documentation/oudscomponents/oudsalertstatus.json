omponents\/documentation\/OUDSComponents","url":"\/documentation\/oudscomponents","role":"collection","title":"Components","type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus":{"type":"topic","url":"\/documentation\/oudscomponents\/oudsalertstatus","title":"OUDSAlertStatus","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSAlertStatus"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus","abstract":[{"type":"text","text":"The status of the alerts."},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage"},{"text":" background color and its icon color are based on this status.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInlineAlert"},{"type":"text","text":" icon and text color are based on this status."}],"kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSAlertStatus"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/positive":{"type":"topic","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/positive","abstract":[{"text":"Positive status indicates that a task or process has been completed successfully. These alerts reassure users and confirm that no further action is needed.","type":"text"},{"text":" ","type":"text"},{"text":"This status displays a dedicated default icon.","type":"text"}],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"positive"}],"title":"OUDSAlertStatus.positive","kind":"symbol","url":"\/documentation\/oudscomponents\/oudsalertstatus\/positive"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/info":{"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"info"}],"title":"OUDSAlertStatus.info","url":"\/documentation\/oudscomponents\/oudsalertstatus\/info","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/info","abstract":[{"type":"text","text":"Info status is used to share neutral system information or service updates that do not require immediate action. Ideal for background processes or status"},{"text":" ","type":"text"},{"type":"text","text":"messages where users simply need to stay informed."},{"text":" ","type":"text"},{"text":"This status displays a dedicated default icon.","type":"text"}],"role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSInlineAlert":{"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInlineAlert","title":"OUDSInlineAlert","url":"\/documentation\/oudscomponents\/oudsinlinealert","navigatorTitle":[{"kind":"identifier","text":"OUDSInlineAlert"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSInlineAlert"}],"abstract":[{"text":"Inline alert is a lightweight UI element, placed in the content flow, that displays information, system feedback,","type":"text"},{"text":" ","type":"text"},{"text":"status changes throughout short, prominent, persistent and non actionable communication. Inline alert includes functional","type":"text"},{"text":" ","type":"text"},{"text":"icon and semantic colour, and does not include a close button and\/or action link. Inline alert does not disappear and remains visible.","type":"text"}],"type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/warning":{"type":"topic","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/warning","abstract":[{"text":"Used to draw attention to potential issues or upcoming changes that might affect the user’s service or experience. Warnings encourage awareness but","type":"text"},{"text":" ","type":"text"},{"text":"typically do not block actions.","type":"text"},{"text":" ","type":"text"},{"text":"This status displays a dedicated default icon.","type":"text"}],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"warning"}],"title":"OUDSAlertStatus.warning","kind":"symbol","url":"\/documentation\/oudscomponents\/oudsalertstatus\/warning"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertMessage":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertMessage","kind":"identifier"}],"title":"OUDSAlertMessage","url":"\/documentation\/oudscomponents\/oudsalertmessage","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage","abstract":[{"type":"text","text":"Alert message is a UI element that displays system feedback, status changes or required action; throughout detailed, prominent, persistent and actionable"},{"text":" ","type":"text"},{"text":"communication. Alert message includes functional icon and semantic colour, and may include as well a close button and\/or action link.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Alert Message does not disappear automatically and remains visible until dismissed or resolved by the user."}],"role":"symbol","navigatorTitle":[{"text":"OUDSAlertMessage","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/negative":{"fragments":[{"kind":"keyword","