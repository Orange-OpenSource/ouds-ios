 prevents the user from proceeding until it is resolved. These alerts remain visible until","type":"text"},{"text":" ","type":"text"},{"text":"the problem is fixed or dismissed by the user.","type":"text"},{"text":" ","type":"text"},{"text":"This status displays a dedicated default icon.","type":"text"}],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"negative","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsalertstatus\/negative","title":"OUDSAlertStatus.negative","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/negative","role":"symbol","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/info":{"kind":"symbol","abstract":[{"text":"Info status is used to share neutral system information or service updates that do not require immediate action. Ideal for background processes or status","type":"text"},{"text":" ","type":"text"},{"text":"messages where users simply need to stay informed.","type":"text"},{"text":" ","type":"text"},{"text":"This status displays a dedicated default icon.","type":"text"}],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"info","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsalertstatus\/info","title":"OUDSAlertStatus.info","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/info","role":"symbol","type":"topic"}}}