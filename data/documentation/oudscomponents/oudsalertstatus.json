{"abstract":[{"type":"text","text":"The status of the alerts."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage","type":"reference","isActive":true},{"type":"text","text":" background color and its icon color are based on this status."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInlineAlert","type":"reference","isActive":true},{"type":"text","text":" icon and text color are based on this status."}],"topicSections":[{"generated":true,"title":"Enumeration Cases","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/accent(icon:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/info","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/negative","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/neutral(icon:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/positive","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/warning"],"anchor":"Enumeration-Cases"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP"]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsalertstatus"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertStatus","kind":"identifier"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"There are two types of statuses:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Non-functional statuses used for informational or decorative alert messages."},{"type":"text","text":" "},{"type":"text","text":"They provide context or highlight content without implying a specific state, system event, or user action."},{"type":"text","text":" "},{"type":"text","text":"These alerts are not tied to UX patterns such as success, error, or warning, and may use contextual or brand-related icons to enhance recognition or storytelling."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Functional statuses communicate specific system statuses, results, or user feedback:"},{"type":"text","text":" "},{"type":"text","text":"Each variant conveys a clear semantic meaning and must always be paired with its dedicated functional icon to ensure clarity and accessibility."},{"type":"text","text":" "},{"type":"text","text":"Use functional alerts to inform user about state changes, confirmations, or issues that are directly connected to system logic or user actions."},{"type":"text","text":" "},{"type":"text","text":"These messages carry functional meaning and help guide user response or acknowledgment."}],"type":"paragraph"}]}]}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus"},"kind":"symbol","metadata":{"navigatorTitle":[{"kind":"identifier","text":"OUDSAlertStatus"}],"modules":[{"name":"Components"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertStatus","kind":"identifier"}],"roleHeading":"Enumeration","title":"OUDSAlertStatus","symbolKind":"enum","externalID":"s:14OUDSComponents15OUDSAlertStatusO","role":"symbol"},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/warning":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/warning","abstract":[{"text":"Used to draw attention to potential issues or upcoming changes that might affect the user’s service or experience. Warnings encourage awareness but","type":"text"},{"text":" ","type":"text"},{"text":"typically do not block actions.","type":"text"},{"text":" ","type":"text"},{"text":"This status displays a dedicated default icon.","type":"text"}],"title":"OUDSAlertStatus.warning","url":"\/documentation\/oudscomponents\/oudsalertstatus\/warning","kind":"symbol","type":"topic","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"warning","kind":"identifier"}],"role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/info":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/info","abstract":[{"type":"text","text":"Info status is used to share neutral system information or service updates that do not require immediate action. Ideal for background processes or status"},{"type":"text","text":" "},{"type":"text","text":"messages where users simply need to stay informed."},{"type":"text","text":" "},{"type":"text","text":"This status displays a dedicated default icon."}],"title":"OUDSAlertStatus.info","url":"\/documentation\/oudscomponents\/oudsalertstatus\/info","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"info"}],"role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/neutral(icon:)":{"role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"neutral","kind":"identifier"},{"text":"(","kind":"text"},{"text":"icon","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"OUDSIcon","kind":"typeIdentifier","preciseIdentifier":"s:14OUDSComponents8OUDSIconV"},{"text":"?)","kind":"text"}],"title":"OUDSAlertStatus.neutral(icon:)","url":"\/documentation\/oudscomponents\/oudsalertstatus\/neutral(icon:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/neutral(icon:)","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Neutral status can be used as a generic informative alert without semantic meaning or colour association."},{"type":"text","text":" "},{"type":"text","text":"Suitable for a wide range of contexts — such as tips, general information, or descriptive labels — where"},{"type":"text","text":" "},{"type":"text","text":"no specific feedback or urgency is required. Appropriate for help sections, dashboards, or onboarding flows."}]},"doc://OUDSComponents/s8SendableP":{"identifier":"doc:\/\/OUDSComponents\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"doc://OUDSComponents/documentation/OUDSComponents":{"type":"topic","kind":"symbol","url":"\/documentation\/oudscomponents","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"role":"collection","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","images":[{"identifier":"ic_folder_categories.png","type":"icon"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/positive":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/positive","abstract":[{"text":"Positive status indicates that a task or process has been completed successfully. These alerts reassure users and confirm that no further action is needed.","type":"text"},{"text":" ","type":"text"},{"text":"This status displays a dedicated default icon.","type":"text"}],"title":"OUDSAlertStatus.positive","url":"\/documentation\/oudscomponents\/oudsalertstatus\/positive","kind":"symbol","type":"topic","fragments":[{"text