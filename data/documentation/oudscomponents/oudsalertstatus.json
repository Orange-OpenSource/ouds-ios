"\/documentation\/oudscomponents","kind":"symbol","type":"topic","role":"collection","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/info":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/info","abstract":[{"type":"text","text":"Info status is used to share neutral system information or service updates that do not require immediate action. Ideal for background processes or status"},{"type":"text","text":" "},{"type":"text","text":"messages where users simply need to stay informed."},{"type":"text","text":" "},{"type":"text","text":"This status displays a dedicated default icon."}],"role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"info"}],"kind":"symbol","title":"OUDSAlertStatus.info","url":"\/documentation\/oudscomponents\/oudsalertstatus\/info","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/warning":{"abstract":[{"text":"Used to draw attention to potential issues or upcoming changes that might affect the user’s service or experience. Warnings encourage awareness but","type":"text"},{"text":" ","type":"text"},{"text":"typically do not block actions.","type":"text"},{"text":" ","type":"text"},{"text":"This status displays a dedicated default icon.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudsalertstatus\/warning","kind":"symbol","title":"OUDSAlertStatus.warning","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/warning","fragments":[{"kind":"keyword","text":"