{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"type":"text","text":"The status of the alerts."},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage","type":"reference"},{"text":" background color and its icon color are based on this status.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInlineAlert","type":"reference"},{"text":" icon and text color are based on this status.","type":"text"}],"sections":[],"metadata":{"symbolKind":"enum","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertStatus","kind":"identifier"}],"externalID":"s:14OUDSComponents15OUDSAlertStatusO","navigatorTitle":[{"text":"OUDSAlertStatus","kind":"identifier"}],"role":"symbol","roleHeading":"Enumeration","modules":[{"name":"Components"}],"title":"OUDSAlertStatus"},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/accent(icon:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/info","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/negative","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/neutral(icon:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/positive","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/warning"],"anchor":"Enumeration-Cases","title":"Enumeration Cases","generated":true}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus"},"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsalertstatus"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertStatus","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"There are two types of statuses:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Non-functional statuses used for informational or decorative alert messages.","type":"text"},{"text":" ","type":"text"},{"text":"They provide context or highlight content without implying a specific state, system event, or user action.","type":"text"},{"text":" ","type":"text"},{"text":"These alerts are not tied to UX patterns such as success, error, or warning, and may use contextual or brand-related icons to enhance recognition or storytelling.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Functional statuses communicate specific system statuses, results, or user feedback:"},{"type":"text","text":" "},{"type":"text","text":"Each variant conveys a clear semantic meaning and must always be paired with its dedicated functional icon to ensure clarity and accessibility."},{"type":"text","text":" "},{"type":"text","text":"Use functional alerts to inform user about state changes, confirmations, or issues that are directly connected to system logic or user actions."},{"type":"text","text":" "},{"type":"text","text":"These messages carry functional meaning and help guide user response or acknowledgment."}],"type":"paragraph"}]}]}]}],"references":{"doc://OUDSComponents/s8SendableP":{"title":"Swift.Sendable","type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s8SendableP"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertMessage":{"title":"OUDSAlertMessage","url":"\/documentation\/oudscomponents\/oudsalertmessage","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertMessage","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSAlertMessage"}],"abstract":[{"type":"text","text":"Alert message is a UI element that displays system feedback, status changes or required action; throughout detailed, prominent, persistent and actionable"},{"type":"text","text":" "},{"type":"text","text":"communication. Alert message includes functional icon and semantic colour, and may include as well a close button and\/or action link."},{"type":"text","text":" "},{"type":"text","text":"Alert Message does not disappear automatically and remains visible until dismissed or resolved by the user."}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"title":"Components","role":"collection","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"type":"topic","url":"\/documentation\/oudscomponents","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/accent(icon:)":{"abstract":[{"type":"text","text":"Accent status uses brand colours to draw attention to promotional or highlighted information while remaining non-critical. Ideal for marketing content,"},{"type":"text","text":" "},{"type":"text","text":"announcements, or feature highlights, where you want to subtly engage users without introducing functional semantics. Ideal for promotional banners,"},{"type":"text","text":" "},{"type":"text","text":"product updates, or customer engagement moments."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/accent(icon:)","title":"OUDSAlertStatus.accent(icon:)","url":"\/documentation\/oudscomponents\/oudsalertstatus\/accent(icon:)","type":"topic","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"accent","kind":"identifier"},{"text":"(","kind":"text"},{"text":"icon","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"OUDSIcon","kind":"typeIdentifier","preciseIdentifier":"s:14OUDSComponents8OUDSIconV"},{"text":"?)","kind":"text"}]},"doc://OUDSComponents/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/positive":{"url":"\/documentation\/oudscomponents\/oudsalertstatus\/positive","kind":"symbol","abstract":[{"type":"text","text":"Positive status indicates that a task or process has been completed successfully. These alerts reassure users and confirm that no further action is needed."},{"type":"text","text":" "},{"type":"text","text":"This status displays a dedicated default icon."}],"type":"topic","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"positive","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/positive","title":"OUDSAlertStatus.positive"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/negative":{"role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"negative","kind":"identifier"}],"abstract":[{"type":"text","text":"Negative status communicates a critical issue or error that prevents the user from proceeding until it is resolved. These alerts remain visible until"},{"type":"text","text":" "},{"type":"text","text":"the problem is fixed or dismissed by the user."},{"type":"text","text":" "},{"type":"text","text":"This status displays a dedicated default icon."}],"url":"\/documentation\/oudscomponents\/oudsalertstatus\/negative","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/negative","type":"topic","title":"OUDSAlertStatus.negative"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus":{"title":"OUDSAlertStatus","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSAlertStatus","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudscomponents\/oudsalertstatus","kind":"symbol","navigatorTitle":[{"text":"OUDSAlertStatus","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus","abstract":[{"type":"text","text":"The status of the alerts."},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertMessage"},{"text":" background color and its icon color are based on this status.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInlineAlert","type":"reference"},{"text":" icon and text color are based on this status.","type":"text"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/warning":{"abstract":[{"type":"text","text":"Used to draw attention to potential issues or upcoming changes that might affect the user’s service or experience. Warnings encourage awareness but"},{"type":"text","text":" "},{"text":"typically do not block actions.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This status displays a dedicated default icon."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/warning","title":"OUDSAlertStatus.warning","url":"\/documentation\/oudscomponents\/oudsalertstatus\/warning","type":"topic","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"warning","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSInlineAlert":{"navigatorTitle":[{"text":"OUDSInlineAlert","kind":"identifier"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSInlineAlert"}],"abstract":[{"text":"Inline alert is a lightweight UI element, placed in the content flow, that displays information, system feedback,","type":"text"},{"text":" ","type":"text"},{"text":"status changes throughout short, prominent, persistent and non actionable communication. Inline alert includes functional","type":"text"},{"type":"text","text":" "},{"type":"text","text":"icon and semantic colour, and does not include a close button and\/or action link. Inline alert does not disappear and remains visible."}],"url":"\/documentation\/oudscomponents\/oudsinlinealert","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSInlineAlert","type":"topic","title":"OUDSInlineAlert"},"ic_folder_categories.png":{"alt":null,"type":"image","identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/neutral(icon:)":{"url":"\/documentation\/oudscomponents\/oudsalertstatus\/neutral(icon:)","abstract":[{"type":"text","text":"Neutral status can be used as a generic informative alert without semantic meaning or colour association."},{"type":"text","text":" "},{"type":"text","text":"Suitable for a wide range of contexts — such as tips, general information, or descriptive labels — where"},{"type":"text","text":" "},{"type":"text","text":"no specific feedback or urgency is required. Appropriate for help sections, dashboards, or onboarding flows."}],"type":"topic","kind":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"neutral","kind":"identifier"},{"text":"(","kind":"text"},{"text":"icon","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"OUDSIcon","preciseIdentifier":"s:14OUDSComponents8OUDSIconV","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/neutral(icon:)","title":"OUDSAlertStatus.neutral(icon:)"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSAlertStatus/info":{"type":"topic","abstract":[{"text":"Info status is used to share neutral system information or service updates that do not require immediate action. Ideal for background processes or status","type":"text"},{"text":" ","type":"text"},{"text":"messages where users simply need to stay informed.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This status displays a dedicated default icon."}],"role":"symbol","url":"\/documentation\/oudscomponents\/oudsalertstatus\/info","title":"OUDSAlertStatus.info","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSAlertStatus\/info","kind":"symbol","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"info"}]}}}