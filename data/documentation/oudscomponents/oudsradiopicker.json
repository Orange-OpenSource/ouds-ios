{"kind":"symbol","relationshipsSections":[{"title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsradiopicker"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"A picker allowing to expose several radio buttons and choose only one within the others."},{"text":" ","type":"text"},{"text":"Each radio button contains a “tag”, i.e. a supposed to be unique value.","type":"text"},{"text":" ","type":"text"},{"text":"The picker will expose the choosen value through this “tag”.","type":"text"},{"text":" ","type":"text"},{"text":"It has also some configuration elements which will override the one applied to nested ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference"},{"text":" (divider, read only and error mode, layout and outlined)","type":"text"}],"metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioPicker"}],"roleHeading":"Structure","platforms":[{"beta":false,"deprecated":false,"introducedAt":"15.0","name":"iOS","unavailable":false},{"beta":false,"deprecated":false,"introducedAt":"13.0","name":"macOS","unavailable":false},{"beta":false,"deprecated":false,"introducedAt":"1.0","name":"visionOS","unavailable":false}],"modules":[{"name":"Components"}],"role":"symbol","externalID":"s:14OUDSComponents15OUDSRadioPickerV","title":"OUDSRadioPicker","symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"OUDSRadioPicker"}]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioPicker"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Tag"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Tag"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"Hashable","preciseIdentifier":"s:SH"}]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"anchor":"Accessibility-considerations","type":"heading","level":2,"text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom radio trait."},{"text":" ","type":"text"},{"text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"However if defined in the "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData","type":"reference"},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."}]},{"type":"heading","text":"Forbidden by design","anchor":"Forbidden-by-design","level":2},{"type":"paragraph","inlineContent":[{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference"},{"type":"text","text":" in both an error situation and a read only state."},{"text":" ","type":"text"},{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference"},{"text":" in both an error situation and a disabled state.","type":"text"},{"text":" ","type":"text"},{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference"},{"text":" in both a read only and a disabled state.","type":"text"}]},{"anchor":"Code-samples","type":"heading","level":2,"text":"Code samples"},{"code":["    \/\/ Define the elements to display in radio buttons using OUDSRadioPickerData.","    \/\/ This object has the same properties as the OUDSRadioItem,","    \/\/ and some of them are optional withdefault values set","    var someDataToPopulate: [OUDSRadioPickerData<String>] {","        [","            OUDSRadioPickerData<String>(tag: \"Choice_1\",","                                        label: \"Virgin Holy Lava\",","                                        extraLabel: \"Very spicy\",","                                        description: \"No alcohol, only tasty flavors\",","                                        icon: Image(systemName: \"flame\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_2\",","                                        label: \"IPA beer\",","                                        description: \"From Brewdog company\",","                                        icon: Image(systemName: \"dog.fill\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_3\",","                                        label: \"Mineral water\",","                                        icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: String = \"Choice_1\"","","    \/\/ Here the picker is vertical","    OUDSRadioPicker(selection: $selection, radios: someDataToPopulate)","","    \/\/ The picker can apply some settings to all its radio buttons.","    \/\/ It can be also horitzontal with a scroll indicator.","    \/\/ Here all the the radio buttons are in read only mode and use reversed layout.","    OUDSRadioPicker(selection: $selection,","                    radios: someDataToPopulate,","                    isReversed: true,","                    isReadOnly: true,","                    placement: .horitzontal(true))"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Design-documentation","level":2,"text":"Design documentation"},{"type":"paragraph","inlineContent":[{"text":"There is no online specification as this component is not an official OUDS one","type":"text"}]},{"type":"heading","anchor":"Theme-rendering","level":2,"text":"Theme rendering"},{"anchor":"Orange","text":"Orange","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioPicker_Orange","type":"image"}]},{"anchor":"Orange-Compact","text":"Orange Compact","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_radioPicker_OrangeCompact","type":"image"}],"type":"paragraph"},{"type":"heading","anchor":"Sosh","level":3,"text":"Sosh"},{"inlineContent":[{"type":"image","identifier":"component_radioPicker_Sosh"}],"type":"paragraph"},{"level":3,"text":"Wireframe","type":"heading","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioPicker_Wireframe","type":"image"}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"text":"0.14.0","type":"text"}],"type":"paragraph"}],"name":"Since"}],"kind":"content"}],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker\/init(selection:radios:placement:isOutlined:isReversed:isError:isReadOnly:hasDivider:itemsSpacing:)"],"anchor":"Initializers"},{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\