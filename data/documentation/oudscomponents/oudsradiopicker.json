{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioPicker"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Tag"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Tag"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"Hashable","preciseIdentifier":"s:SH"}],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"Accessibility-considerations","level":2,"type":"heading","text":"Accessibility considerations"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom radio trait."},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"type":"text","text":" "},{"type":"text","text":"However if defined in the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData"},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."}],"type":"paragraph"},{"anchor":"Forbidden-by-design","level":2,"type":"heading","text":"Forbidden by design"},{"type":"paragraph","inlineContent":[{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference"},{"type":"text","text":" in both an error situation and a read only state."},{"type":"text","text":" "},{"type":"text","text":"The design system does not allow to have "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"type":"text","text":" in both an error situation and a disabled state."},{"type":"text","text":" "},{"type":"text","text":"The design system does not allow to have "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"type":"text","text":" in both a read only and a disabled state."}]},{"anchor":"Code-samples","level":2,"type":"heading","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define the elements to display in radio buttons using OUDSRadioPickerData.","    \/\/ This object has the same properties as the OUDSRadioItem,","    \/\/ and some of them are optional withdefault values set","    var someDataToPopulate: [OUDSRadioPickerData<String>] {","        [","            OUDSRadioPickerData<String>(tag: \"Choice_1\",","                                        label: \"Virgin Holy Lava\",","                                        additionalLabel: \"Very spicy\",","                                        helper: \"No alcohol, only tasty flavors\",","                                        icon: Image(systemName: \"flame\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_2\",","                                        label: \"IPA beer\",","                                        helper: \"From Brewdog company\",","                                        icon: Image(systemName: \"dog.fill\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_3\",","                                        label: \"Mineral water\",","                                        icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: String = \"Choice_1\"","","    \/\/ Here the picker is vertical","    OUDSRadioPicker(selection: $selection, radios: someDataToPopulate)","","    \/\/ The picker can apply some settings to all its radio buttons.","    \/\/ It can be also horitzontal with a scroll indicator.","    \/\/ Here all the the radio buttons are in read only mode and use reversed layout.","    OUDSRadioPicker(selection: $selection,","                    radios: someDataToPopulate,","                    isReversed: true,","                    isReadOnly: true,","                    placement: .horitzontal(true))"]},{"anchor":"Design-documentation","level":2,"type":"heading","text":"Design documentation"},{"inlineContent":[{"type":"text","text":"There is no online specification as this component is not an official OUDS one"}],"type":"paragraph"},{"level":2,"anchor":"Theme-rendering","text":"Theme rendering","type":"heading"},{"type":"heading","level":3,"text":"Orange","anchor":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_radioPicker_Orange"}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Orange-Business-Tools","text":"Orange Business Tools"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioPicker_OrangeBusinessTools","type":"image"}]},{"anchor":"Sosh","level":3,"type":"heading","text":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radioPicker_Sosh"}]},{"anchor":"Wireframe","level":3,"type":"heading","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioPicker_Wireframe","type":"image"}]},{"name":"Since","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"0.14.0"}],"type":"paragraph"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker"},"hierarchy