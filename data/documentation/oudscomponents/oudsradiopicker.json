ioItem"},{"type":"text","text":" in both an error situation and a read only state."},{"type":"text","text":" "},{"type":"text","text":"The design system does not allow to have "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" in both an error situation and a disabled state."},{"type":"text","text":" "},{"text":"The design system does not allow to have ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"text":" in both a read only and a disabled state.","type":"text"}]},{"text":"Code samples","type":"heading","level":2,"anchor":"Code-samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define the elements to display in radio buttons using OUDSRadioPickerData.","    \/\/ This object has the same properties as the OUDSRadioItem,","    \/\/ and some of them are optional withdefault values set","    var someDataToPopulate: [OUDSRadioPickerData<String>] {","        [","            OUDSRadioPickerData<String>(tag: \"Choice_1\",","                                        label: \"Virgin Holy Lava\",","                                        additionalLabel: \"Very spicy\",","                                        helper: \"No alcohol, only tasty flavors\",","                                        icon: Image(systemName: \"flame\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_2\",","                                        label: \"IPA beer\",","                                        helper: \"From Brewdog company\",","                                        icon: Image(systemName: \"dog.fill\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_3\",","                                        label: \"Mineral water\",","                                        icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: String = \"Choice_1\"","","    \/\/ Here the picker is vertical","    OUDSRadioPicker(selection: $selection, radios: someDataToPopulate)","","    \/\/ The picker can apply some settings to all its radio buttons.","    \/\/ It can be also horitzontal with a scroll indicator.","    \/\/ Here all the the radio buttons are in read only mode and use reversed layout.","    OUDSRadioPicker(selection: $selection,","                    radios: someDataToPopulate,","                    isReversed: true,","                    isReadOnly: true,","                    placement: .horitzontal(true))"]},{"text":"Design documentation","type":"heading","level":2,"anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"text":"There is no online specification as this component is not an official OUDSThemesContract one","type":"text"}]},{"text":"Theme rendering","type":"heading","level":2,"anchor":"Theme-rendering"},{"text":"Orange","type":"heading","level":3,"anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioPicker_Orange","type":"image"}]},{"text":"Orange Business Tools","type":"heading","level":3,"anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioPicker_OrangeBusinessTools","type":"image"}]},{"text":"Sosh","type":"heading","level":3,"anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radioPicker_Sosh"}]},{"text":"Wireframe","type":"heading","level":3,"anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioPicker_Wireframe","type":"image"}]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.14.0"}],"type":"paragraph"}]}]}],"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponen