 error situation and a read only state.","type":"text"},{"text":" ","type":"text"},{"text":"The design system does not allow to have ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"text":" in both an error situation and a disabled state.","type":"text"},{"text":" ","type":"text"},{"text":"The design system does not allow to have ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"text":" in both a read only and a disabled state.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Code samples","anchor":"Code-samples","type":"heading"},{"code":["    \/\/ Define the elements to display in radio buttons using OUDSRadioPickerData.","    \/\/ This object has the same properties as the OUDSRadioItem,","    \/\/ and some of them are optional withdefault values set","    var someDataToPopulate: [OUDSRadioPickerData<String>] {","        [","            OUDSRadioPickerData<String>(tag: \"Choice_1\",","                                        label: \"Virgin Holy Lava\",","                                        extraLabel: \"Very spicy\",","                                        description: \"No alcohol, only tasty flavors\",","                                        icon: Image(systemName: \"flame\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_2\",","                                        label: \"IPA beer\",","                                        description: \"From Brewdog company\",","                                        icon: Image(systemName: \"dog.fill\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_3\",","                                        label: \"Mineral water\",","                                        icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: String = \"Choice_1\"","","    \/\/ Here the picker is vertical","    OUDSRadioPicker(selection: $selection, radios: someDataToPopulate)","","    \/\/ The picker can apply some settings to all its radio buttons.","    \/\/ It can be also horitzontal with a scroll indicator.","    \/\/ Here all the the radio buttons are in read only mode and use reversed layout.","    OUDSRadioPicker(selection: $selection,","                    radios: someDataToPopulate,","                    isReversed: true,","                    isReadOnly: true,","                    placement: .horitzontal(true))"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Design documentation","anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"text":"There is no online specification as this component is not an official OUDS one","type":"text"}],"type":"paragraph"},{"level":2,"text":"Theme rendering","anchor":"Theme-rendering","type":"heading"},{"level":3,"text":"Orange","anchor":"Orange","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_radioPicker_Orange"}],"type":"paragraph"},{"level":3,"text":"Orange Compact","anchor":"Orange-Compact","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_radioPicker_OrangeCompact"}],"type":"paragraph"},{"level":3,"text":"Sosh","anchor":"Sosh","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_radioPicker_Sosh"}],"type":"paragraph"},{"level":3,"text":"Wireframe","anchor":"Wireframe","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_radioPicker_Wireframe"}],"type":"paragraph"},{"name":"Since","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.14.0"}]}],"type":"aside"}]}],"kind":"symbol","topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker\/init(selecti