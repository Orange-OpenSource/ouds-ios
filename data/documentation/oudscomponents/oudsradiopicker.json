,"text":" "},{"type":"text","text":"However if defined in the "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData","isActive":true},{"type":"text","text":" the items inside the picker will have such accessibility identifiers."}],"type":"paragraph"},{"anchor":"Forbidden-by-design","level":2,"type":"heading","text":"Forbidden by design"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The design system does not allow to have "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":" in both an error situation and a read only state."},{"type":"text","text":" "},{"type":"text","text":"The design system does not allow to have "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":" in both an error situation and a disabled state."},{"type":"text","text":" "},{"type":"text","text":"The design system does not allow to have "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":" in both a read only and a disabled state."}]},{"type":"heading","anchor":"Code-samples","level":2,"text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define the elements to display in radio buttons using OUDSRadioPickerData.","    \/\/ This object has the same properties as the OUDSRadioItem,","    \/\/ and some of them are optional withdefault values set","    var someDataToPopulate: [OUDSRadioPickerData<String>] {","        [","            OUDSRadioPickerData<String>(tag: \"Choice_1\",","                                        label: \"Virgin Holy Lava\",","                                        extraLabel: \"Very spicy\",","                                        description: \"No alcohol, only tasty flavors\",","                                        icon: Image(systemName: \"flame\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_2\",","                                        label: \"IPA beer\",","                                        description: \"From Brewdog company\",","                                        icon: Image(systemName: \"dog.fill\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_3\",","                                        label: \"Mineral water\",","                                        icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: String = \"Choice_1\"","","    \/\/ Here the picker is vertical","    OUDSRadioPicker(selection: $selection, radios: someDataToPopulate)","","    \/\/ The picker can apply some settings to all its radio buttons.","    \/\/ It can be also horitzontal with a scroll indicator.","    \/\/ Here all the the radio buttons are in read only mode and use reversed layout.","    OUDSRadioPicker(selection: $selection,","                    radios: someDataToPopulate,","                    isReversed: true,","                    isReadOnly: true,","                    placement: .horitzontal(true))"]},{"type":"heading","anchor":"Design-documentation","level":2,"text":"Design documentation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no online specification as this component is not an official OUDS one"}]},{"type":"heading","anchor":"Theme-rendering","level":2,"text":"Theme rendering"},{"type":"heading","anchor":"Orange","level":3,"text":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radioPicker_Orange"}]},{"type":"heading","anchor":"Orange-Compact","level":3,"text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radioPicker_OrangeCompact