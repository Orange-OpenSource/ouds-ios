{"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioPicker","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Tag","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Tag","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SH","text":"Hashable","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations","level":2},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom radio trait."},{"type":"text","text":" "},{"type":"text","text":"The picker itself does no have any defined accessiiblity value, label or identifier ; it remains in the users hands to define which one will be used."},{"text":" ","type":"text"},{"text":"However if defined in the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPickerData","type":"reference"},{"text":" the items inside the picker will have such accessibility identifiers.","type":"text"}]},{"text":"Forbidden by design","type":"heading","anchor":"Forbidden-by-design","level":2},{"inlineContent":[{"text":"The design system does not allow to have ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"text":" in both an error situation and a read only state.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The design system does not allow to have "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference"},{"type":"text","text":" in both an error situation and a disabled state."},{"text":" ","type":"text"},{"text":"The design system does not allow to have ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"text":" in both a read only and a disabled state.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define the elements to display in radio buttons using OUDSRadioPickerData.","    \/\/ This object has the same properties as the OUDSRadioItem,","    \/\/ and some of them are optional withdefault values set","    var someDataToPopulate: [OUDSRadioPickerData<String>] {","        [","            OUDSRadioPickerData<String>(tag: \"Choice_1\",","                                        label: \"Virgin Holy Lava\",","                                        extraLabel: \"Very spicy\",","                                        description: \"No alcohol, only tasty flavors\",","                                        icon: Image(systemName: \"flame\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_2\",","                                        label: \"IPA beer\",","                                        description: \"From Brewdog company\",","                                        icon: Image(systemName: \"dog.fill\")),","","            OUDSRadioPickerData<String>(tag: \"Choice_3\",","                                        label: \"Mineral water\",","                                        icon: Image(systemName: \"waterbottle.fill\")),","        ]","    }","","    \/\/ Prepare the selection, with a value previously selected","    \/\/ Use the data and the binding for the picker.","    @State var selection: String = \"Choice_1\"","","    \/\/ Here the picker is vertical","    OUDSRadioPicker(selection: $selection, radios: someDataToPopulate)","","    \/\/ The picker can apply some settings to all its radio buttons.","    \/\/ It can be also horitzontal with a scroll indicator.","    \/\/ Here all the the radio buttons are in read only mode and use reversed layout.","    OUDSRadioPicker(selection: $selection,","                    radios: someDataToPopulate,","                    isReversed: true,","                    isReadOnly: true,","                    placement: .horitzontal(true))"]},{"anchor":"Design-documentation","text":"Design documentation","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"There is no online specification as this component is not an official OUDS one","type":"text"}]},{"type":"heading","level":2,"anchor":"Theme-rendering","text":"Theme rendering"},{"anchor":"Orange","type":"heading","level":3,"text":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_radioPicker_Orange"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Orange Compact","anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioPicker_OrangeCompact","type":"image"}]},{"level":3,"type":"heading","text":"Sosh","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioPicker_Sosh","type":"image"}]},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":3},{"inlineContent":[{"identifier":"component_radioPicker_Wireframe","type":"image"}],"type":"paragraph"},{"name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.14.0"}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"metadata":{"modules":[{"