{"kind":"symbol","metadata":{"platforms":[{"beta":false,"name":"iOS","unavailable":false,"introducedAt":"15.0","deprecated":false},{"name":"macOS","deprecated":false,"beta":false,"introducedAt":"13.0","unavailable":false},{"beta":false,"name":"visionOS","unavailable":false,"introducedAt":"1.0","deprecated":false}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSRadioPicker"}],"symbolKind":"struct","roleHeading":"Structure","modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents15OUDSRadioPickerV","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSRadioPicker"}],"title":"OUDSRadioPicker"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"A picker allowing to expose several radio buttons and choose only one within the others."},{"type":"text","text":" "},{"type":"text","text":"Each radio button contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen value through this “tag”."},{"text":" ","type":"text"},{"text":"It has also some configuration elements which will override the one applied to nested ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker\/init(selection:radios:placement:isOutlined:isReversed:isError:isReadOnly:hasDivider:itemsSpacing:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker\/body"]},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSC