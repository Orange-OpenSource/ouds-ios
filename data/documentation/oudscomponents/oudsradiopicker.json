{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsradiopicker"]}],"abstract":[{"type":"text","text":"A picker allowing to expose several radio buttons and choose only one within the others."},{"type":"text","text":" "},{"type":"text","text":"Each radio button contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen value through this “tag”."},{"text":" ","type":"text"},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"text":" (divider, read only and error mode, layout and outlined)","type":"text"}],"topicSections":[{"generated":true,"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker\/init(selection:radios:placement:isOutlined:isReversed:isError:isReadOnly:hasDivider:itemsSpacing:)"],"anchor":"Initializers"},{"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker\/body"],"title":"Instance Properties","generated":true},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker\/View-Implementations"],"title":"Default Implementations","generated":true}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"title":"OUDSRadioPicker","roleHeading":"Structure","symbolKind":"struct","platforms":[{"name":"iOS","introducedAt":"15.0","deprecated":false,"unavailable":false,"beta":false},{"name":"macOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"visionOS","intr