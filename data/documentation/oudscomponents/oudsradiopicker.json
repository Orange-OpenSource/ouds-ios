{"variants":[{"paths":["\/documentation\/oudscomponents\/oudsradiopicker"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"roleHeading":"Structure","externalID":"s:14OUDSComponents15OUDSRadioPickerV","title":"OUDSRadioPicker","symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"OUDSRadioPicker"}],"role":"symbol","modules":[{"name":"Components"}],"platforms":[{"introducedAt":"15.0","unavailable":false,"deprecated":false,"beta":false,"name":"iOS"},{"introducedAt":"13.0","unavailable":false,"deprecated":false,"beta":false,"name":"macOS"},{"introducedAt":"1.0","unavailable":false,"deprecated":false,"beta":false,"name":"visionOS"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioPicker"}]},"abstract":[{"type":"text","text":"A picker allowing to expose several radio buttons and choose only one within the others."},{"type":"text","text":" "},{"type":"text","text":"Each radio button contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen value through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"primaryC