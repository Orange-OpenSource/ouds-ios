{"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/init(isOn:accessibilityLabel:isError:)"],"generated":true},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/body"],"generated":true},{"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations"],"generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckbox"]}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true,"type":"reference"},{"type":"text","text":" proposes layout to add in your views a lonely checkbox, without labels, texts nor icons components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with additional texts and icon, prefer instead "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true,"type":"reference"},{"type":"text","text":"."}],"metadata":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckbox","kind":"identifier"}],"modules":[{"name":"Components"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSCheckbox"}],"symbolKind":"struct","roleHeading":"Structure","title":"OUDSCheckbox","externalID":"s:14OUDSComponents12OUDSCheckboxV"},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckbox"}]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"Indicator-states","text":"Indicator states","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"This checkbox indicator has two available states:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"unselected","type":"text"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to use a tri-state checkbox instead, refer to "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","isActive":true},{"type":"text","text":"."}]},{"anchor":"Particular-cases","text":"Particular cases","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","type":"reference","isActive":true},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look-and-feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"}]},{"anchor":"Accessibility-considerations","text":"Accessibility considerations","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDSThemesContract side as this value remains in the users hands.","type":"text"}]},{"anchor":"Cases-forbidden-by-design","text":"Cases forbidden by design","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"}]},{"anchor":"Code-samples","text":"Code samples","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have a selected checkbox","    @Published var isOn: Bool = true","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"]},{"text":"Suggestions","level":2,"type":"heading","anchor":"Suggestions"},{"type":"paragraph","inlineContent":[{"text":"According to the ","type":"text"},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/09d860-checkbox\/t\/14bf4bd854","type":"reference","isActive":true},{"text":", the checkbox by default must be used in unselected state.","type":"text"}]},{"text":"Design documentation","level":2,"type":"heading","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","type":"reference"}]},{"text":"Themes rendering","level":2,"type":"heading","anchor":"Themes-rendering"},{"text":"Orange","level":3,"type":"heading","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Orange"}]},{"text":"Orange Business Tools","level":3,"type":"heading","anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_OrangeBusinessTools"}]},{"text":"Sosh","level":3,"type":"heading","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Sosh"}]},{"text":"Wireframe","level":3,"type":"heading","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Wireframe"}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"2.3.0 (Figma component design version)","type":"text"}]}],"name":"Version"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}],"name":"Since"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","interfaceLanguage":"swift"},"references":{"doc://OUDSComponents/doc