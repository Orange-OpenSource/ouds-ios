OS","deprecated":false,"introducedAt":"1.0"},{"unavailable":false,"beta":false,"name":"watchOS","deprecated":false,"introducedAt":"11.0"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckbox"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSCheckbox"}],"modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents12OUDSCheckboxV","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckbox"}],"languages":["swift"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"type":"heading","text":"Indicator states","anchor":"Indicator-states","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This checkbox indicator has two available states:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"selected","type":"text"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to use a tri-state checkbox instead, refer to "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","isActive":true},{"type":"text","text":"."}]},{"type":"heading","text":"Particular cases","anchor":"Particular-cases","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","type":"reference","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."}]},{"level":2,"anchor":"Accessibility-considerations","text":"Accessibility considerations","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}]},{"level":2,"anchor":"Cases-forbidden-by-design","text":"Cases forbidden by design","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]}]},{"level":2,"anchor":"Code-samples","text":"Code samples","type":"heading"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have a selected checkbox","    @Published var isOn: Bool = true","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"]},{"level":2,"anchor":"Suggestions","text":"Suggestions","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"According to the ","type":"text"},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/09d860-checkbox\/t\/14bf4bd854","type":"reference","isActive":true},{"text":", the checkbox by default must be used in unselected state.","type":"text"}]},{"level":2,"anchor":"Design-documentation","text":"Design documentation","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","isActive":true,"type":"reference"}]},{"level":2,"anchor":"Themes-rendering","text":"Themes rendering","type":"heading"},{"level":3,"anchor":"Orange","text":"Orange","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Orange"}]},{"level":3,"anchor":"Orange-Business-Tools","text":"Orange Business Tools","type":"heading"},{"inlineContent":[{"identifier":"component_checkbox_OrangeBusinessTools","type":"image"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Sosh","anchor":"Sosh"},{"inlineContent":[{"type":"image","identifier":"component_checkbox_Sosh"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Wireframe","anchor":"Wireframe"},{"inlineContent":[{"identifier":"component_checkbox_Wireframe","type":"image"}],"type":"paragraph"},{"style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"text":"2.3.0 (Figma component design version)","type":"text"}]}],"type":"aside"},{"style":"note",