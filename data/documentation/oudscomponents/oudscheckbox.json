{"metadata":{"role":"symbol","title":"OUDSCheckbox","externalID":"s:14OUDSComponents12OUDSCheckboxV","navigatorTitle":[{"kind":"identifier","text":"OUDSCheckbox"}],"modules":[{"name":"Components"}],"roleHeading":"Structure","platforms":[{"beta":false,"deprecated":false,"introducedAt":"15.0","name":"iOS","unavailable":false},{"beta":false,"deprecated":false,"introducedAt":"13.0","name":"macOS","unavailable":false},{"beta":false,"deprecated":false,"introducedAt":"16.0","name":"tvOS","unavailable":false},{"beta":false,"deprecated":false,"introducedAt":"1.0","name":"visionOS","unavailable":false},{"beta":false,"deprecated":false,"introducedAt":"11.0","name":"watchOS","unavailable":false}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckbox"}],"symbolKind":"struct"},"sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Checkbox that does not show icon or text, provides greater flexibility when creating other components that require a checkbox to be displayed."}],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSCheckbox","kind":"identifier"}]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"type":"heading","text":"Indicator states","level":2,"anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This checkbox indicator has two available states:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"unselected","type":"text"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to use a tri-state checkbox instead, refer to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate"},{"type":"text","text":"."}]},{"level":2,"text":"Particular cases","anchor":"Particular-cases","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."}]},{"type":"heading","text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations"},{"inlineContent":[{"type":"text","text":"Note also the component must be instanciated with a string parameter used as accessibility label."},{"type":"text","text":" "},{"type":"text","text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by "},{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands."}],"type":"paragraph"},{"type":"heading","text":"Cases forbidden by design","level":2,"anchor":"Cases-forbidden-by-design"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error or a read only situation and a disabled component.","type":"text"}]}],"type":"paragraph"},{"type":"heading","text":"Code samples","level":2,"anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have a selected checkbox","    @Published var isOn: Bool = true","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"]},{"type":"heading","text":"Suggestions","level":2,"anchor":"Suggestions"},{"inlineContent":[{"type":"text","text":"According to the "},{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true},{"type":"text","text":", the checkbox by default must be used in un