{"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"type":"text","text":" proposes layout to add in your views a lonely checkbox, without labels, texts nor icons components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with additional texts and icon, prefer instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":"."}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},"metadata":{"externalID":"s:14OUDSComponents12OUDSCheckboxV","modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckbox","kind":"identifier"}],"symbolKind":"struct","title":"OUDSCheckbox","roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"OUDSCheckbox"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckbox"}],"languages":["swift"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"level":2,"anchor":"Indicator-states","type":"heading","text":"Indicator states"},{"inlineContent":[{"type":"text","text":"This checkbox indicator has two available states:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"If you need to use a tri-state checkbox instead, refer to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Particular-cases","type":"heading","text":"Particular cases"},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."}],"type":"paragraph"},{"level":2,"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations"},{"inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDSThemesContract side as this value remains in the users hands.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Cases-forbidden-by-design","type":"heading","text":"Cases forbidden by design"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"}],"type":"paragraph"},{"level":2,"anchor":"Code-samples","type":"heading","text":"Code samples"},{"code":["    \/\/ Supposing we have a selected checkbox","    @Published var isOn: Bool = true","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Suggestions","type":"heading","text":"Suggestions"},{"inlineContent":[{"type":"text","text":"According to the "},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/09d860-checkbox\/t\/14bf4bd854","type":"reference","isActive":true},{"type":"text","text":", the checkbox by default must be used in unselected state."}],"type":"paragraph"},{"level":2,"anchor":"Design-documentation","type":"heading","text":"Design documentation"},{"inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","type":"reference","isActive":true}],"type":"paragraph"},{"level":2,"anchor":"Themes-rendering","type":"heading","text":"Themes rendering"},{"level":3,"anchor":"Orange","type":"heading","text":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_checkbox_Orange"}],"type":"paragraph"},{"level":3,"anchor":"Orange-Business-Tools","type":"heading","text":"Orange Business Tools"},{"inlineContent":[{"identifier":"component_checkbox_OrangeBusinessTools","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Sosh","type":"heading","text":"Sosh"},{"inlineContent":[{"identifier":"component_checkbox_Sosh","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Wireframe","type":"heading","text":"Wireframe"},{"inlineContent":[{"identifier":"component_checkbox_Wireframe","type":"image"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"2.3.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Version"},{"content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckbox"]}],"kind":"symbol","topicSections":[{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/init(isOn:accessibilityLabel:isError:)"]},{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/body"]},{"anchor":"Default-Implementations","title":"Default Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations"]}],"references":{"doc://OUDSComponents/doc