{"kind":"symbol","identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","interfaceLanguage":"swift"},"sections":[],"abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Checkbox that does not show icon or text, provides greater flexibility when creating other components that require a checkbox to be displayed."}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/init(isOn:accessibilityLabel:isError:isReadOnly:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/init(isOn:accessibilityLabel:tableName:bundle:isError:isReadOnly:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/body"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckbox","kind":"identifier"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"Indicator-states","type":"heading","level":2,"text":"Indicator states"},{"inlineContent":[{"type":"text","text":"This checkbox indicator has two available states:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}]}]}]},{"inlineContent":[{"text":"If you need to use a tri-state checkbox instead, refer to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Particular-cases","type":"heading","level":2,"text":"Particular cases"},{"inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look-and-feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"}],"type":"paragraph"},{"anchor":"Accessibility-considerations","type":"heading","level":2,"text":"Accessibility considerations"},{"inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}],"type":"paragraph"},{"anchor":"Cases-forbidden-by-design","type":"heading","level":2,"text":"Cases forbidden by design"},{"inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error or a read only situation and a disabled component.","type":"text"}],"type":"strong"}],"type":"paragraph"},{"anchor":"Code-samples","type":"heading","level":2,"text":"Code samples"},{"type":"codeListing","code":["    \/\/ Supposing we have a selected checkbox","    @Published var isOn: Bool = true","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"anchor":"Suggestions","type":"heading","level":2,"text":"Suggestions"},{"inlineContent":[{"text":"According to the ","type":"text"},{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","type":"reference"},{"text":", the checkbox by default must be used in unselected state.","type":"text"}],"type":"paragraph"},{"anchor":"Design-documentation","type":"heading","level":2,"text":"Design documentation"},{"inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitle":"unified-design-system.orange.com","type":"reference"}],"type":"paragraph"},{"anchor":"Themes-rendering","type":"heading","level":2,"text":"Themes rendering"},{"anchor":"Orange","type":"heading","level":3,"text":"Orange"},{"inlineContent":[{"identifier":"component_checkbox_Orange","type":"image"}],"type":"paragraph"},{"anchor":"Orange-Compact","type":"heading","level":3,"text":"Orange Compact"},{"inlineContent":[{"identifier":"component_checkbox_OrangeCompact","type":"image"}],"type":"paragraph"},{"anchor":"Sosh","type":"heading","level":3,"text":"Sosh"},{"inlineContent":[{"identifier":"component_checkbox_Sosh","type":"image"}],"type":"paragraph"},{"anchor":"Wireframe","type":"heading","level":3,"text":"Wireframe"},{"inlineContent":[{"identifier":"component_checkbox_Wireframe","type":"image"}],"type":"paragraph"},{"name":"Version","style":"note","type":"aside","content":[{"inlineContent":[{"text":"2.4.0 (Figma component design version)","type":"text"}],"type":"paragraph"}]},{"name":"Since","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.12.0","type":"text"}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckbox"]}],"metadata":{"role":"symbol","roleHeading":"Structure","platforms":[{"beta":false,"name":"iOS","deprecated":false,"introducedAt":"15.0","unavailable":false},{"deprecated":false,"beta":false,"introducedAt":"13.0","name":"macOS","unavailable":false},{"beta":false,"name":"tvOS","deprecated":false,"introducedAt":"16.0","unavailable":false},{"beta":false,"name":"visionOS","deprecated":false,"introducedAt":"1.0","unavailable":false}