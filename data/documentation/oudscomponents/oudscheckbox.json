{"kind":"symbol","metadata":{"symbolKind":"struct","title":"OUDSCheckbox","navigatorTitle":[{"text":"OUDSCheckbox","kind":"identifier"}],"externalID":"s:14OUDSComponents12OUDSCheckboxV","platforms":[{"name":"iOS","unavailable":false,"beta":false,"introducedAt":"15.0","deprecated":false},{"introducedAt":"15.0","deprecated":false,"unavailable":false,"beta":false,"name":"macOS"},{"introducedAt":"16.0","deprecated":false,"unavailable":false,"beta":false,"name":"tvOS"},{"beta":false,"deprecated":false,"name":"visionOS","unavailable":false,"introducedAt":"1.0"},{"introducedAt":"11.0","deprecated":false,"unavailable":false,"beta":false,"name":"watchOS"}],"modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckbox","kind":"identifier"}],"roleHeading":"Structure","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","interfaceLanguage":"swift"},"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckbox"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OUDSCheckbox","kind":"identifier"}]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"Indicator-states","level":2,"type":"heading","text":"Indicator states"},{"type":"paragraph","inlineContent":[{"text":"This checkbox indicator has two available states:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"If you need to use a tri-state checkbox instead, refer to ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","type":"reference","isActive":true},{"text":".","type":"text"}]},{"level":2,"text":"Particular cases","type":"heading","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look-and-feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"}]},{"level":2,"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDSThemesContract side as this value remains in the users hands."}]},{"anchor":"Cases-forbidden-by-design","level":2,"type":"heading","text":"Cases forbidden by design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]}]},{"level":2,"text":"Code samples","type":"heading","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have a selected checkbox","    @Published var isOn: Bool = true","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"]},{"anchor":"Suggestions","level":2,"type":"heading","text":"Suggestions"},{"type":"paragraph","inlineContent":[{"text":"According to the ","type":"text"},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/09d860-checkbox\/t\/14bf4bd854","type":"reference","isActive":true},{"text":", the checkbox by default must be used in unselected state.","type":"text"}]},{"anchor":"Design-documentation","level":2,"type":"heading","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","type":"reference","isActive":true}]},{"anchor":"Themes-rendering","level":2,"type":"heading","text":"Themes rendering"},{"anchor":"Orange","level":3,"type":"heading","text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_checkbox_Orange","type":"image"}]},{"anchor":"Orange-Business-Tools","level":3,"type":"heading","text":"Orange Business Tools"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_OrangeBusinessTools"}]},{"anchor":"Sosh","level":3,"type":"heading","text":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Sosh"}]},{"anchor":"Wireframe","level":3,"type":"heading","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_checkbox_Wireframe","type":"image"}]},{"type":"aside","name":"Version","content":[{"type":"paragraph","inlineContent":[{"text":"2.3.0 (Figma component design version)","type":"text"}]}],"style":"note"},{"type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.12.0","type":"text"}]}],"style":"note"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/init(isOn:accessibilityLabel:isError:)"],"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/body"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComp