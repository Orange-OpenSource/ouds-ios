{"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckbox"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Checkbox that does not show icon or text, provides greater flexibility when creating other components that require a checkbox to be displayed."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckbox"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"content":[{"level":2,"type":"heading","text":"Indicator states","anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This checkbox indicator has two available states:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"selected","type":"text"}],"type":"strong"},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to use a tri-state checkbox instead, refer to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate"},{"type":"text","text":"."}]},{"level":2,"type":"heading","text":"Particular cases","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."}]},{"level":2,"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also the component must be instanciated with a string parameter used as accessibility label."},{"type":"text","text":" "},{"type":"text","text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by "},{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}]},{"text":"Cases forbidden by design","level":2,"anchor":"Cases-forbidden-by-design","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error or a read only situation and a disabled component."}]}]},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","code":["    \/\/ Supposing we have a selected checkbox","    @Published var isOn: Bool = true","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"level":2,"type":"heading","text":"Suggestions","anchor":"Suggestions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the "},{"type":"reference","isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox"},{"type":"text","text":", the checkbox by default must be used in unselected state."}]},{"level":2,"type":"heading","text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitle":"unified-design-system.orange.com","overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}]}]},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"text":"Orange","level":3,"anchor":"Orange","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Orange"}]},{"level":3,"type":"heading","text":"Orange Compact","anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_OrangeCompact"}]},{"level":3,"type":"heading","text":"Sosh","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Sosh"}]},{"level":3,"type":"heading","text":"Wireframe","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Wireframe"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"2.