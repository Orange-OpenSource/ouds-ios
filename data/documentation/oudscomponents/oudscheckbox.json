{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},"topicSections":[{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/init(isOn:accessibilityLabel:isError:isReadOnly:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/init(isOn:accessibilityLabel:tableName:bundle:isError:isReadOnly:)"],"title":"Initializers"},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/body"],"title":"Instance Properties"},{"generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations"],"title":"Default Implementations"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckbox"}],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"text":"Indicator states","anchor":"Indicator-states","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This checkbox indicator has two available states:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"If you need to use a tri-state checkbox instead, refer to "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Particular cases","anchor":"Particular-cases","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."}],"type":"paragraph"},{"text":"Accessibility considerations","anchor":"Accessibility-considerations","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Note also the component must be instanciated with a string parameter used as accessibility label."},{"type":"text","text":" "},{"type":"text","text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Cases forbidden by design","anchor":"Cases-forbidden-by-design"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error or a read only situation and a disabled component."}],"type":"strong"}]},{"text":"Code samples","anchor":"Code-samples","level":2,"type":"heading"},{"code":["    \/\/ Supposing we have a selected checkbox","    @Published var isOn: Bool = true","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckbox(isOn: $isOn, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"text":"Suggestions","anchor":"Suggestions","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"According to the "},{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true},{"text":", the checkbox by default must be used in unselected state.","type":"text"}],"type":"paragraph"},{"text":"Design documentation","anchor":"Design-documentation","level":2,"type":"heading"},{"inlineContent":[{"isActive":true,"overridingTitle":"unified-design-system.orange.com","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"type":"reference"}],"type":"paragraph"},{"text":"Themes rendering","anchor":"Themes-rendering","level":2,"type":"heading"},{"level":3,"text":"Orange","anchor":"Orange","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_checkbox_Orange"}],"type":"paragraph"},{"text":"Orange Compact","anchor":"Orange-Compact","level":3,"type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_checkbox_OrangeCompact"}],"type":"paragraph"},{"text":"Sosh","anchor":"Sosh","level":3,"type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_checkbox_Sosh"}],"type":"paragraph"},{"text":"Wireframe","anchor":"Wireframe","level":3,"type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_checkbox_Wireframe"}],"type":"paragraph"},{"style":"note","name":"Version","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}]}]},{"style":"note","name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}]}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckbox"]}],"kind":"symbol","metadata":{"platforms":[{"deprecated":false,"unavailable":false,"introducedAt":"15.0","beta":false,"name":"iOS"},{"deprecated":false,"unavailable":false,"introducedAt":"13.0","beta":false,"name":"macOS"},{"deprecated":false,"unavailable":false,"introducedAt":"16.0","beta":false,"name":"tvOS"},{"name":"visionOS","deprecated":false,"beta":false,"introducedAt":"1.0","unavailable":false},{"name":"watchOS","deprecated":false,"beta":false,"introducedAt":"11.0","unavailable":false}],"role":"symbol","navigatorTitle":[{"text":"OUDSCheckbox","kind":"identifier"}],"symbolKind":"struct","roleHeading":"Structure","modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents12OUDSCheckboxV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSCheckbox"}],"title":"OUDSCheckbox"},"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/