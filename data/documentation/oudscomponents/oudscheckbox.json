{"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckbox"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Checkbox that does not show icon or text, provides greater flexibility when creating other components that require a checkbox to be displayed."}],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/init(isOn:accessibilityLabel:isError:isReadOnly:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/init(isOn:accessibilityLabel:tableName:bundle:isError:isReadOnly:)"],"title":"Initializers","anchor":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/body"],"title":"Instance Properties","anchor":"Instance-Properties","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox\/View-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations","generated":true}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"navigatorTitle":[{"text":"OUDSCheckbox","kind":"identifier"}],"platforms":[{"unavailable":false,"beta":false,"name":"iOS","deprecated":false,"introducedAt":"15.0"},{"unavailable":false,"beta":false,"name":"macOS","deprecated":false,"introducedAt":"13.0"},{"beta":false,"name":"tvOS","unavailable":false,"deprecated":false,"introducedAt":"16.0"},{"beta":false,"name":"visionOS","unavailable":false,"deprecated":false,"introducedAt":"1.0"},{"beta":false,"name":"watchOS","unavailable":false,"deprecated":false,"introducedAt":"11.0"}],"role":"symbol","title":"OUDSCheckbox","external