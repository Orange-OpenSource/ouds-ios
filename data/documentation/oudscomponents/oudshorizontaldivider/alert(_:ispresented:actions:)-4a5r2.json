,"doc://OUDSComponents/documentation/OUDSComponents/OUDSHorizontalDivider":{"abstract":[{"text":"Divider is a UI element that allows to structure the content by visually separating the content zones.","type":"text"},{"text":" ","type":"text"},{"text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A horizontal Divider is used to separate content laid out one under the other ("},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor"},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (height) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSHorizontalDivider","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudshorizontaldivider","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","kind":"symbol","navigatorTitle":[{"text":"OUDSHorizontalDivider","kind":"identifier"}],"title":"OUDSHorizontalDivider","type":"topic","role":"symbol"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","type":"image","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"title":"OUDSDividerColor","kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"text":"OUDSDividerColor","kind