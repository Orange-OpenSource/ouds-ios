ation without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A horizontal Divider is used to separate content laid out one under the other ("},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true,"type":"reference"},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (height) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"navigatorTitle":[{"kind":"identifier","text":"OUDSHorizontalDivider"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","url":"\/documentation\/oudscomponents\/oudshorizontaldivider","role":"symbol","title":"OUDSHorizontalDivider"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSHorizontalDivider/bodyDefaultSmall(_:)":{"title":"bodyDefaultSmall(_:)","role":"symbol","abstract":[{"text":"Modifies the current ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" to apply a ","type":"text"},{"inlineContent":[{"type":"text","text":"body default small"}],"type":"emphasis"},{"text":" typography.","type":"text"},{"text":" ","type":"text"},{"text":"The current ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" must be given in parameter because ","type":"text"},{"code":"@Environment","type":"codeVoice"},{"text":" property cannot be accessed through an extension or inside a method.","type":"text"}],"type":"topic","url":"\/documentation\/oudscomponents\/oudshorizontaldivider\/bodydefaultsmall(_:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider\/bodyDefaultSmall(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" "