t have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"text":"to implement all tokens.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" is not a ","type":"text"},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","title":"OUDSTheme"}}}