ents/documentation/OUDSComponents/OUDSHorizontalDivider":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSHorizontalDivider"}],"abstract":[{"type":"text","text":"Divider is a UI element that allows to structure the content by visually separating the content zones."},{"type":"text","text":" "},{"type":"text","text":"Divider improves readability and content organization without introducing a stronger visual hierarchy like a heading or a container would."},{"type":"text","text":" "},{"type":"text","text":"A horizontal Divider is used to separate content laid out one under the other ("},{"type":"codeVoice","code":"VStack"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"The divider can be colored using dedicated "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","isActive":true,"type":"reference"},{"type":"text","text":" colors."},{"type":"text","text":" "},{"type":"text","text":"The thickness (height) is fixed by dedicated token from "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."}],"navigatorTitle":[{"kind":"identifier","text":"OUDSHorizontalDivider"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSHorizontalDivider","url":"\/documentation\/oudscomponents\/oudshorizontaldivider","role":"symbol","title":"OUDSHorizontalDivider"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSDividerColor":{"title":"OUDSDividerColor","role":"symbol","abstract":[{"type":"text","text":"List of colors available for dividers (i.e. "},{"type":"codeVoice","code":"OUDSHorizontalDivider"},{"type":"text","text":" or "},{"type":"codeVoice","code":"OUDSVerticalDivider"},{"type":"text","text":")"}],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSDividerColor","url":"\/documentation\/oudscomponents\/oudsdividercolor","fragments":[{"text":"enum","kin