{"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLegacyTabBarModifier\/init()"]},{"title":"Instance Methods","anchor":"Instance-Methods","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLegacyTabBarModifier\/body(content:)"]},{"title":"Default Implementations","anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLegacyTabBarModifier\/ViewModifier-Implementations"]}],"abstract":[{"type":"codeVoice","code":"ViewModifier"},{"text":" to manage an edge case about Liquid Glass configuration of Apple OS and Xcode versions.","type":"text"}],"kind":"symbol","metadata":{"role":"symbol","roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSLegacyTabBarModifier"}],"title":"OUDSLegacyTabBarModifier","navigatorTitle":[{"kind":"identifier","text":"OUDSLegacyTabBarModifier"}],"symbolKind":"struct","modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents24OUDSLegacyTabBarModifierV"},"variants":[{"paths":["\/documentation\/oudscomponents\/oudslegacytabbarmodifier"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSLegacyTabBarModifier","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If an app is compiled with Xcode 27 for iOS 27, Liquid Glass is forced by the system and considered as enabled by OUDS."},{"type":"text","text":" "},{"type":"text","text":"If an app is compiled with Xcode 26 for iOS 26, the "},{"type":"emphasis","inlineContent":[{"text":"UIDesignRequiresCompatibility","type":"text"}]},{"text":" flag is read and OUDS considers wether or not Liquid Glass is enabled.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If an app is compiled with Xcode 26 for iOS 18 and lower, Liquid Glass is considered as unavailable, disabled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The edge case is when the OS version is 27, the flag "},{"type":"emphasis","inlineContent":[{"text":"UIDesignRequiresCompatibility","type":"text"}]},{"type":"text","text":" stils exists but the app is compiled with Xcode 26."},{"type":"text","text":" "},{"type":"text","text":"This case is extreme: the system does not force Liquid Glass, the flag is here, and OUDS cannot only rely on the OS version."},{"type":"text","text":" "},{"type":"text","text":"Thus, this "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLegacyTabBarModifier"},{"type":"text","text":"  will define an environment value saying any legacy layout things (appearances, selector, divider) must be displayed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"**You must use this "},{"code":"ViewModifier","type":"codeVoice"},{"type":"text","text":" with care, and only if you are using Xcode 26 and  "},{"type":"emphasis","inlineContent":[{"text":"UIDesignRequiresCompatibility","type":"text"}]},{"type":"text","text":" to YES **."},{"type":"text","text":" "},{"type":"text","text":"Prefer build with Xcode 27 without the "},{"type":"emphasis","inlineContent":[{"text":"UIDesignRequiresCompatibility","type":"text"}]},{"type":"text","text":"  flag."}]},{"code":["  OUDSTabBar(selectedTab: ..., count: ...) { ... )","    .modifier(OUDSLegacyTabBarModifier())"],"type":"codeListing","syntax":"swift"},{"st