{"sections":[],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSTextArea"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"level":2,"text":"Layout","anchor":"Layout","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Text area is based on several configurable UI elements:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"label","type":"text"}]},{"text":": It is used to describe the purpose of the text area.","type":"text"},{"text":" ","type":"text"},{"text":"In some UI contexts, especially when space is limited or when the text area is part of a compact layout, the label can be hidden.","type":"text"},{"text":" ","type":"text"},{"text":"However, hiding the label should only be done if the purpose remains clear thanks to a placeholder or contextual icon","type":"text"},{"text":" ","type":"text"},{"text":"and if the label is still accessible to screen readers.","type":"text"},{"text":" ","type":"text"},{"text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"placeholder","type":"text"}],"type":"strong"},{"type":"text","text":": If the text of the text area is empty a placeholder provides a hint or guidance inside the field to suggest expected input."}],"type":"paragraph"}]}]},{"anchor":"Status","text":"Status","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Five status are proposed for all layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"enabled (by default)"}],"type":"strong"},{"text":": Default neutral appearance, whether empty or filled.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to click, focus, and type freely without restrictions.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"error","type":"text"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" status indicates that the user input does not meet validation rules or"},{"text":" ","type":"text"},{"text":"expected formatting. It provides immediate visual feedback, typically through a red border,","type":"text"},{"type":"text","text":" "},{"text":"an error icon, and a clear, accessible error message positioned below the text area. The error message replaces the helper text.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"loading","type":"codeVoice"},{"text":" state indicates that the system is processing or retrieving data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress."},{"type":"text","text":" "},{"text":"The field remains editable while loading.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"readOnly","type":"text"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"readOnly","type":"codeVoice"},{"text":" status lets the text visible but not editable.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"disabled","type":"text"}],"type":"strong"},{"text":": In ","type":"text"},{"code":"disabled","type":"codeVoice"},{"text":" status, the field is non-interactive and grayed out to indicate it cannot be changed.","type":"text"},{"text":" ","type":"text"},{"text":"Note the SwiftUI ","type":"text"},{"code":"View.disabled()","type":"codeVoice"},{"text":" is ignored.","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Helpers","text":"Helpers","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Helper text (plain)","type":"text"}],"type":"strong"},{"text":": A supporting text conveys additional information about the text area,","type":"text"},{"text":" ","type":"text"},{"text":"such as how it will be used. It should ideally only take up a single line, though may wrap","type":"text"},{"text":" ","type":"text"},{"text":"to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Helper text (characters max count)"}]},{"text":": Uses an internal message displaying the count of remaining characters depending to the given value.","type":"text"},{"type":"text","text":" "},{"text":"This is a specific iOS library feature with 1.4.0","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Helper link","type":"text"}],"type":"strong"},{"text":": If the helper text is not sufficient, it’s possible to offer the user","type":"text"},{"text":" ","type":"text"},{"text":"an additional help link (the link can be external or open a modal).","type":"text"}]}]}],"type":"unorderedList"},{"text":"Accessibility considerations","level":2,"type":"heading","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"text":"By default no haptics are done by the component.","type":"text"},{"text":" ","type":"text"},{"text":"However you should think about cases where you will have to make the devices vibrate.","type":"text"},{"text":" ","type":"text"},{"text":"You can refer to the ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"text":"Mandatory field indication","level":2,"type":"heading","anchor":"Mandatory-field-indication"},{"type":"paragraph","inlineContent":[{"text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular.","type":"text"},{"text":" ","type":"text"},{"text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular.","type":"text"},{"type":"text","text":" "},{"text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"UI rendering of the asterisk must be done with ","type":"text"},{"inlineContent":[{"text":"bold font weight","type":"text"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"negative content color","type":"text"}],"type":"emphasis"},{"text":" (red on light backgrounds).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed.","type":"text"}]},{"inlineContent":[{"text":"If there is only one field in the formular, or if the mandatory nature is obvious,","type":"text"},{"text":" ","type":"text"},{"text":"no mention is necessary since the fields are essential to the formular’s functionality.","type":"text"}],"type":"paragraph"},{"text":"Outlined style","type":"heading","anchor":"Outlined-style","level":2},{"inlineContent":[{"text":"By ","type":"text"},{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"text":", the text area uses a subtle background fill and a bottom border only, creating a softer and more contained look.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When ","type":"text"},{"inlineContent":[{"text":"outlined","type":"text"}],"type":"strong"},{"text":", the text area uses a transparent background and a visible stroke on all four sides.","type":"text"},{"text":" ","type":"text"},{"text":"This style may be appropriate for contexts where inputs need to feel lightweight and unobtrusive,","type":"text"},{"text":" ","type":"text"},{"text":"for example inside a card, a dialog, or a filtering panel.","type":"text"}],"type":"paragraph"},{"code":["    \/\/ An outlined text area","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"],"type":"codeListing","syntax":"swift"},{"text":"Code samples","anchor":"Code-samples","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextArea(label: \"Comments\", text: $text)","","    \/\/ Empty text with placeholder","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Describe your issue in detail\")","","    \/\/ With a plain helper text","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 placeholder: \"Describe your issue in detail\",","                 helperText: .plain(\"Maximum 500 characters.\"))","","    \/\/ With a maximum character count — the component shows \"X characters remaining\" (bold)","    \/\/ and switches to an error style when exceeded.","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 helperText: .charactersMaxCount(500))","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextArea.Helperlink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)","","    \/\/ With error status","    OUDSTextArea(label: \"Comments\", text: $text, status: .error(message: \"This field can't be empty.\"))","","    \/\/ Outlined style","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"]},{"text":"Design documentation","type":"heading","anchor":"Design-documentation","level":2},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-area","isActive":true,"type":"reference"}],"type":"paragraph"},{"text":"Themes rendering","type":"heading","anchor":"Themes-rendering","level":2},{"anchor":"Orange","text":"Orange","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_textArea_Orange"}]},{"text":"Orange Compact","level":3,"type":"heading","anchor":"Orange-Compact"},{"inlineContent":[{"type":"image","identifier":"component_textArea_OrangeCompact"}],"type":"paragraph"},{"text":"Sosh","level":3,"type":"heading","anchor":"Sosh"},{"inlineContent":[{"identifier":"component_textArea_Sosh","type":"image"}],"type":"paragraph"},{"text":"Wireframe","type":"heading","anchor":"Wireframe","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_textArea_Wireframe"}]},{"name":"Version","type":"aside","content":[{"inlineContent":[{"text":"1.1.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"style":"note"},{"content":[{"inlineContent":[{"text":"1.4.0","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Since"}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstextarea"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"topicSections":[{"title":"Structures","generated":true,"anchor":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Helperlink"]},{"generated":true,"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/init(_:tableName:bundle:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/init(label:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)"],"anchor":"Initializers"},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/body"],"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/HelperText","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Status"],"generated":true,"anchor":"Enumerations","title":"Enumerations"},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/View-Implementations"],"anchor":"Default-Implementations"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"roleHeading":"Structure","role":"symbol","externalID":"s:14OUDSComponents12OUDSTextAreaV","modules":[{"name":"Components"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSTextArea"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OUDSTextArea","kind":"identifier"}],"title":"OUDSTextArea","symbolKind":"struct","platforms":[{"beta":false,"introducedAt":"15.0","name":"iOS","deprecated":false,"unavailable":false},{"beta":false,"deprecated":false,"unavailable":false,"name":"macOS","introducedAt":"13.0"},{"beta":false,"deprecated":false,"unavailable":false,"name":"visionOS","introducedAt":"1.0"}]},"abstract":[{"text":"Text area is a UI element that allows to type, edit, or select longer blocks of textual data, such as comments, messages or descriptions;","type":"text"},{"text":" ","type":"text"},{"text":"by expanding vertically and offering more space to input text.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It provides a visual and interactive affordance for multiline text entry while supporting labels, placeholders, descriptions, and validation feedback."}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea","interfaceLanguage":"swift"},"references":{"component_textArea_Sosh":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_textArea_Sosh.png"}],"identifier":"component_textArea_Sosh","alt":"A text area component in light and dark modes with Sosh theme","type":"image"},"https://r.orange.fr/r/S-ouds-doc-text-area":{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-area","title":"unified-design-system.orange.com","titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"type":"link","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-area"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea/HelperText":{"title":"OUDSTextArea.HelperText","role":"symbol","navigatorTitle":[{"text":"HelperText","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/HelperText","kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"HelperText"}],"abstract":[{"type":"text","text":"Describes the content of the helper text displayed below the text area."}],"url":"\/documentation\/oudscomponents\/oudstextarea\/helpertext","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea/Status":{"role":