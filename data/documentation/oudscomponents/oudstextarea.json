{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextArea","kind":"identifier"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"Layout","type":"heading","text":"Layout","level":2},{"type":"paragraph","inlineContent":[{"text":"Text area is based on several configurable UI elements:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"label"}],"type":"strong"},{"text":": It is used to describe the purpose of the text area.","type":"text"},{"text":" ","type":"text"},{"text":"In some UI contexts, especially when space is limited or when the text area is part of a compact layout, the label can be hidden.","type":"text"},{"text":" ","type":"text"},{"text":"However, hiding the label should only be done if the purpose remains clear thanks to a placeholder or contextual icon","type":"text"},{"text":" ","type":"text"},{"text":"and if the label is still accessible to screen readers.","type":"text"},{"text":" ","type":"text"},{"text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"placeholder"}],"type":"strong"},{"text":": If the text of the text area is empty a placeholder provides a hint or guidance inside the field to suggest expected input.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Status","type":"heading","text":"Status","level":2},{"type":"paragraph","inlineContent":[{"text":"Five status are proposed for all layouts:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"enabled (by default)"}],"type":"strong"},{"text":": Default neutral appearance, whether empty or filled.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to click, focus, and type freely without restrictions.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"error"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" status indicates that the user input does not meet validation rules or","type":"text"},{"text":" ","type":"text"},{"text":"expected formatting. It provides immediate visual feedback, typically through a red border,","type":"text"},{"text":" ","type":"text"},{"text":"an error icon, and a clear, accessible error message positioned below the text area. The error message replaces the helper text.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"loading","type":"codeVoice"},{"text":" state indicates that the system is processing or retrieving data","type":"text"},{"text":" ","type":"text"},{"text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress.","type":"text"},{"text":" ","type":"text"},{"text":"The field remains editable while loading.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"readOnly"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"readOnly","type":"codeVoice"},{"text":" status lets the text visible but not editable.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"disabled"}],"type":"strong"},{"text":": In ","type":"text"},{"code":"disabled","type":"codeVoice"},{"text":" status, the field is non-interactive and grayed out to indicate it cannot be changed.","type":"text"},{"text":" ","type":"text"},{"text":"Note the SwiftUI ","type":"text"},{"code":"View.disabled()","type":"codeVoice"},{"text":" is ignored.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Helpers","type":"heading","text":"Helpers","level":2},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Helper text (plain)"}],"type":"strong"},{"text":": A supporting text conveys additional information about the text area,","type":"text"},{"text":" ","type":"text"},{"text":"such as how it will be used. It should ideally only take up a single line, though may wrap","type":"text"},{"text":" ","type":"text"},{"text":"to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Helper text (characters max count)"}],"type":"strong"},{"text":": Uses an internal message displaying the count of remaining characters depending to the given value.","type":"text"},{"text":" ","type":"text"},{"text":"This is a specific iOS library feature with 1.4.0","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Helper link"}],"type":"strong"},{"text":": If the helper text is not sufficient, it’s possible to offer the user","type":"text"},{"text":" ","type":"text"},{"text":"an additional help link (the link can be external or open a modal).","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations","level":2},{"type":"paragraph","inlineContent":[{"text":"By default no haptics are done by the component.","type":"text"},{"text":" ","type":"text"},{"text":"However you should think about cases where you will have to make the devices vibrate.","type":"text"},{"text":" ","type":"text"},{"text":"You can refer to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},{"text":".","type":"text"}]},{"anchor":"Mandatory-field-indication","type":"heading","text":"Mandatory field indication","level":2},{"type":"paragraph","inlineContent":[{"text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular.","type":"text"},{"text":" ","type":"text"},{"text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular.","type":"text"},{"text":" ","type":"text"},{"text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"UI rendering of the asterisk must be done with ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"bold font weight"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"negative content color"}]},{"text":" (red on light backgrounds).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If there is only one field in the formular, or if the mandatory nature is obvious,","type":"text"},{"text":" ","type":"text"},{"text":"no mention is necessary since the fields are essential to the formular’s functionality.","type":"text"}]},{"anchor":"Outlined-style","type":"heading","text":"Outlined style","level":2},{"type":"paragraph","inlineContent":[{"text":"By ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":", the text area uses a subtle background fill and a bottom border only, creating a softer and more contained look.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"outlined"}]},{"text":", the text area uses a transparent background and a visible stroke on all four sides.","type":"text"},{"text":" ","type":"text"},{"text":"This style may be appropriate for contexts where inputs need to feel lightweight and unobtrusive,","type":"text"},{"text":" ","type":"text"},{"text":"for example inside a card, a dialog, or a filtering panel.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    \/\/ An outlined text area","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"]},{"anchor":"Code-samples","type":"heading","text":"Code samples","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextArea(label: \"Comments\", text: $text)","","    \/\/ Empty text with placeholder","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Describe your issue in detail\")","","    \/\/ With a plain helper text","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 placeholder: \"Describe your issue in detail\",","                 helperText: .plain(\"Maximum 500 characters.\"))","","    \/\/ With a maximum character count — the component shows \"X characters remaining\" (bold)","    \/\/ and switches to an error style when exceeded.","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 helperText: .charactersMaxCount(500))","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextArea.Helperlink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)","","    \/\/ With error status","    OUDSTextArea(label: \"Comments\", text: $text, status: .error(message: \"This field can't be empty.\"))","","    \/\/ Outlined style","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"]},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-area"}]},{"anchor":"Themes-rendering","type":"heading","text":"Themes rendering","level":2},{"anchor":"Orange","type":"heading","text":"Orange","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_textArea_Orange"}]},{"anchor":"Orange-Compact","type":"heading","text":"Orange Compact","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_textArea_OrangeCompact"}]},{"anchor":"Sosh","type":"heading","text":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_textArea_Sosh"}]},{"anchor":"Wireframe","type":"heading","text":"Wireframe","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_textArea_Wireframe"}]},{"name":"Version","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.1.0 (Figma component design version)"}]}]},{"name":"Since","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.4.0"}]}]}]}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"abstract":[{"type":"text","text":"Text area is a UI element that allows to type, edit, or select longer blocks of textual data, such as comments, messages or descriptions;"},{"type":"text","text":" "},{"type":"text","text":"by expanding vertically and offering more space to input text."},{"type":"text","text":" "},{"type":"text","text":"It provides a visual and interactive affordance for multiline text entry while supporting labels, placeholders, descriptions, and validation feedback."}],"topicSections":[{"anchor":"Structures","title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Helperlink"],"generated":true},{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/init(_:tableName:bundle:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/init(label:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/body"],"generated":true},{"anchor":"Enumerations","title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/HelperText","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Status"],"generated":true},{"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/View-Implementations"],"generated":true}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstextarea"]}],"hierar