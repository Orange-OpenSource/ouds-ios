{"abstract":[{"text":"Text area is a UI element that allows to type, edit, or select longer blocks of textual data, such as comments, messages or descriptions;","type":"text"},{"text":" ","type":"text"},{"text":"by expanding vertically and offering more space to input text.","type":"text"},{"text":" ","type":"text"},{"text":"It provides a visual and interactive affordance for multiline text entry while supporting labels, placeholders, descriptions, and validation feedback.","type":"text"}],"topicSections":[{"title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Helperlink"],"generated":true,"anchor":"Structures"},{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/init(_:tableName:bundle:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/init(label:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/body"],"generated":true,"anchor":"Instance-Properties"},{"title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/HelperText","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Status"],"generated":true,"anchor":"Enumerations"},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/View-Implementations"],"generated":true,"anchor":"Default-Implementations"}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudstextarea"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextArea"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"text":"Layout","level":2,"anchor":"Layout","type":"heading"},{"inlineContent":[{"type":"text","text":"Text area is based on several configurable UI elements:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"label","type":"text"}],"type":"strong"},{"type":"text","text":": It is used to describe the purpose of the text area."},{"type":"text","text":" "},{"type":"text","text":"In some UI contexts, especially when space is limited or when the text area is part of a compact layout, the label can be hidden."},{"type":"text","text":" "},{"type":"text","text":"However, hiding the label should only be done if the purpose remains clear thanks to a placeholder or contextual icon"},{"type":"text","text":" "},{"type":"text","text":"and if the label is still accessible to screen readers."},{"type":"text","text":" "},{"type":"text","text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"placeholder","type":"text"}],"type":"strong"},{"type":"text","text":": If the text of the text area is empty a placeholder provides a hint or guidance inside the field to suggest expected input."}]}]}],"type":"unorderedList"},{"text":"Status","level":2,"anchor":"Status","type":"heading"},{"inlineContent":[{"type":"text","text":"Five status are proposed for all layouts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"enabled (by default)","type":"text"}],"type":"strong"},{"type":"text","text":": Default neutral appearance, whether empty or filled."},{"type":"text","text":" "},{"type":"text","text":"It allows users to click, focus, and type freely without restrictions."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"error","type":"text"}],"type":"strong"},{"type":"text","text":": The "},{"code":"error","type":"codeVoice"},{"type":"text","text":" status indicates that the user input does not meet validation rules or"},{"type":"text","text":" "},{"type":"text","text":"expected formatting. It provides immediate visual feedback, typically through a red border,"},{"type":"text","text":" "},{"type":"text","text":"an error icon, and a clear, accessible error message positioned below the text area. The error message replaces the helper text."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"loading","type":"text"}],"type":"strong"},{"type":"text","text":": The "},{"code":"loading","type":"codeVoice"},{"type":"text","text":" state indicates that the system is processing or retrieving data"},{"type":"text","text":" "},{"type":"text","text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress."},{"type":"text","text":" "},{"type":"text","text":"The field remains editable while loading."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"readOnly","type":"text"}],"type":"strong"},{"type":"text","text":": The "},{"code":"readOnly","type":"codeVoice"},{"type":"text","text":" status lets the text visible but not editable."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"disabled","type":"text"}],"type":"strong"},{"type":"text","text":": In "},{"code":"disabled","type":"codeVoice"},{"type":"text","text":" status, the field is non-interactive and grayed out to indicate it cannot be changed."},{"type":"text","text":" "},{"type":"text","text":"Note the SwiftUI "},{"code":"View.disabled()","type":"codeVoice"},{"type":"text","text":" is ignored."}]}]}],"type":"unorderedList"},{"text":"Helpers","level":2,"anchor":"Helpers","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Helper text (plain)","type":"text"}],"type":"strong"},{"type":"text","text":": A supporting text conveys additional information about the text area,"},{"type":"text","text":" "},{"type":"text","text":"such as how it will be used. It should ideally only take up a single line, though may wrap"},{"type":"text","text":" "},{"type":"text","text":"to multiple lines if required, and be either persistently visible or visible only on focus."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Helper text (characters max count)","type":"text"}],"type":"strong"},{"type":"text","text":": Uses an internal message displaying the count of remaining characters depending to the given value."},{"type":"text","text":" "},{"type":"text","text":"This is a specific iOS library feature with 1.4.0"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Helper link","type":"text"}],"type":"strong"},{"type":"text","text":": If the helper text is not sufficient, it’s possible to offer the user"},{"type":"text","text":" "},{"type":"text","text":"an additional help link (the link can be external or open a modal)."}]}]}],"type":"unorderedList"},{"text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations","type":"heading"},{"inlineContent":[{"type":"text","text":"By default no haptics are done by the component."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases where you will have to make the devices vibrate."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Mandatory field indication","level":2,"anchor":"Mandatory-field-indication","type":"heading"},{"inlineContent":[{"type":"text","text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"UI rendering of the asterisk must be done with "},{"inlineContent":[{"text":"bold font weight","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"text":"negative content color","type":"text"}],"type":"emphasis"},{"type":"text","text":" (red on light backgrounds)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If there is only one field in the formular, or if the mandatory nature is obvious,"},{"type":"text","text":" "},{"type":"text","text":"no mention is necessary since the fields are essential to the formular’s functionality."}],"type":"paragraph"},{"text":"Outlined style","level":2,"anchor":"Outlined-style","type":"heading"},{"inlineContent":[{"type":"text","text":"By "},{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"type":"text","text":", the text area uses a subtle background fill and a bottom border only, creating a softer and more contained look."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When "},{"inlineContent":[{"text":"outlined","type":"text"}],"type":"strong"},{"type":"text","text":", the text area uses a transparent background and a visible stroke on all four sides."},{"type":"text","text":" "},{"type":"text","text":"This style may be appropriate for contexts where inputs need to feel lightweight and unobtrusive,"},{"type":"text","text":" "},{"type":"text","text":"for example inside a card, a dialog, or a filtering panel."}],"type":"paragraph"},{"code":["    \/\/ An outlined text area","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"],"syntax":"swift","type":"codeListing"},{"text":"Code samples","level":2,"anchor":"Code-samples","type":"heading"},{"code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextArea(label: \"Comments\", text: $text)","","    \/\/ Empty text with placeholder","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Describe your issue in detail\")","","    \/\/ With a plain helper text","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 placeholder: \"Describe your issue in detail\",","                 helperText: .plain(\"Maximum 500 characters.\"))","","    \/\/ With a maximum character count — the component shows \"X characters remaining\" (bold)","    \/\/ and switches to an error style when exceeded.","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 helperText: .charactersMaxCount(500))","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextArea.Helperlink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)","","    \/\/ With error status","    OUDSTextArea(label: \"Comments\", text: $text, status: .error(message: \"This field can't be empty.\"))","","    \/\/ Outlined style","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"],"syntax":"swift","type":"codeListing"},{"text":"Design documentation","level":2,"anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-area","isActive":true,"type":"reference"}],"type":"paragraph"},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"text":"Orange","level":3,"anchor":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_textArea_Orange","type":"image"}],"type":"paragraph"},{"text":"Orange Compact","level":3,"anchor":"Orange-Compact","type":"heading"},{"inlineContent":[{"identifier":"component_textArea_OrangeCompact","type":"image"}],"type":"paragraph"},{"text":"Sosh","level":3,"anchor":"Sosh","type":"heading"},{"inlineContent":[{"identifier":"component_textArea_Sosh","type":"image"}],"type":"paragraph"},{"text":"Wireframe","level":3,"anchor":"Wireframe","type":"heading"},{"inlineContent":[{"identifier":"component_textArea_Wireframe","type":"image"}],"type":"paragraph"},{"style":"note","name":"Version","content":[{"inlineContent":[{"text":"1.1.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"type":"aside"},{"style":"note","name":"Since","content":[{"inlineContent":[{"text":"1.4.0","type":"text"}],"type":"paragraph"}],"type":"aside"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","u