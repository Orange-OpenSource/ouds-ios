{"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"OUDSTextArea","role":"symbol","modules":[{"name":"Components"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextArea"}],"roleHeading":"Structure","platforms":[{"deprecated":false,"name":"iOS","unavailable":false,"introducedAt":"15.0","beta":false},{"deprecated":false,"name":"macOS","unavailable":false,"introducedAt":"13.0","beta":false},{"deprecated":false,"name":"visionOS","unavailable":false,"introducedAt":"1.0","beta":false}],"externalID":"s:14OUDSComponents12OUDSTextAreaV","symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"OUDSTextArea"}]},"abstract":[{"type":"text","text":"Text area is a UI element that allows to type, edit, or select longer blocks of textual data, such as comments, messages or descriptions;"},{"type":"text","text":" "},{"type":"text","text":"by expanding vertically and offering more space to input text."},{"type":"text","text":" "},{"type":"text","text":"It provides a visual and interactive affordance for multiline text entry while supporting labels, placeholders, descriptions, and validation feedback."}],"topicSections":[{"anchor":"Structures","generated":true,"title":"Structures","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Helperlink"]},{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/init(_:tableName:bundle:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/init(label:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/body"],"anchor":"Instance-Properties","generated":true},{"title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/HelperText","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Status"],"anchor":"Enumerations","generated":true},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/View-Implementations"],"anchor":"Default-Implementations","generated":true}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea","interfaceLanguage":"swift"},"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextArea"}]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"type":"heading","text":"Layout","anchor":"Layout","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Text area is based on several configurable UI elements:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"label"}],"type":"strong"},{"text":": It is used to describe the purpose of the text area.","type":"text"},{"text":" ","type":"text"},{"text":"In some UI contexts, especially when space is limited or when the text area is part of a compact layout, the label can be hidden.","type":"text"},{"text":" ","type":"text"},{"text":"However, hiding the label should only be done if the purpose remains clear thanks to a placeholder or contextual icon","type":"text"},{"text":" ","type":"text"},{"text":"and if the label is still accessible to screen readers.","type":"text"},{"text":" ","type":"text"},{"text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"placeholder"}],"type":"strong"},{"text":": If the text of the text area is empty a placeholder provides a hint or guidance inside the field to suggest expected input.","type":"text"}]}]}]},{"type":"heading","text":"Status","anchor":"Status","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Five status are proposed for all layouts:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"enabled (by default)"}],"type":"strong"},{"text":": Default neutral appearance, whether empty or filled.","type":"text"},{"text":" ","type":"text"},{"text":"It allows users to click, focus, and type freely without restrictions.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"error"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" status indicates that the user input does not meet validation rules or","type":"text"},{"text":" ","type":"text"},{"text":"expected formatting. It provides immediate visual feedback, typically through a red border,","type":"text"},{"text":" ","type":"text"},{"text":"an error icon, and a clear, accessible error message positioned below the text area. The error message replaces the helper text.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"loading","type":"codeVoice"},{"text":" state indicates that the system is processing or retrieving data","type":"text"},{"text":" ","type":"text"},{"text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress.","type":"text"},{"text":" ","type":"text"},{"text":"The field remains editable while loading.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"readOnly"}],"type":"strong"},{"text":": The ","type":"text"},{"code":"readOnly","type":"codeVoice"},{"text":" status lets the text visible but not editable.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"disabled"}],"type":"strong"},{"text":": In ","type":"text"},{"code":"disabled","type":"codeVoice"},{"text":" status, the field is non-interactive and grayed out to indicate it cannot be changed.","type":"text"},{"text":" ","type":"text"},{"text":"Note the SwiftUI ","type":"text"},{"code":"View.disabled()","type":"codeVoice"},{"text":" is ignored.","type":"text"}]}]}]},{"type":"heading","text":"Helpers","anchor":"Helpers","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Helper text (plain)"}],"type":"strong"},{"text":": A supporting text conveys additional information about the text area,","type":"text"},{"text":" ","type":"text"},{"text":"such as how it will be used. It should ideally only take up a single line, though may wrap","type":"text"},{"text":" ","type":"text"},{"text":"to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Helper text (characters max count)"}],"type":"strong"},{"text":": Uses an internal message displaying the count of remaining characters depending to the given value.","type":"text"},{"text":" ","type":"text"},{"text":"This is a specific iOS library feature with 1.4.0","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Helper link"}],"type":"strong"},{"text":": If the helper text is not sufficient, it’s possible to offer the user","type":"text"},{"text":" ","type":"text"},{"text":"an additional help link (the link can be external or open a modal).","type":"text"}]}]}]},{"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default no haptics are done by the component."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases where you will have to make the devices vibrate."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics"},{"type":"text","text":"."}]},{"type":"heading","text":"Mandatory field indication","anchor":"Mandatory-field-indication","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"UI rendering of the asterisk must be done with "},{"type":"emphasis","inlineContent":[{"text":"bold font weight","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"negative content color","type":"text"}]},{"type":"text","text":" (red on light backgrounds)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is only one field in the formular, or if the mandatory nature is obvious,"},{"type":"text","text":" "},{"type":"text","text":"no mention is necessary since the fields are essential to the formular’s functionality."}]},{"anchor":"Outlined-style","type":"heading","level":2,"text":"Outlined style"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By "},{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":", the text area uses a subtle background fill and a bottom border only, creating a softer and more contained look."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"strong","inlineContent":[{"type":"text","text":"outlined"}]},{"type":"text","text":", the text area uses a transparent background and a visible stroke on all four sides."},{"type":"text","text":" "},{"text":"This style may be appropriate for contexts where inputs need to feel lightweight and unobtrusive,","type":"text"},{"text":" ","type":"text"},{"text":"for example inside a card, a dialog, or a filtering panel.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    \/\/ An outlined text area","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"]},{"anchor":"Rich-text","type":"heading","level":2,"text":"Rich text"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Rich text can be used for error and helper texts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Strong text can be used sparingly to highlight key information within the content."},{"text":" ","type":"text"},{"text":"No other text styles should be used.","type":"text"},{"text":" ","type":"text"},{"text":"Underlined text must not be applied manually (e.g. in error message), as it is commonly associated with hyperlinks and may mislead users.","type":"text"}]},{"anchor":"Code-samples","type":"heading","level":2,"text":"Code samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextArea(label: \"Comments\", text: $text)","","    \/\/ Empty text with placeholder","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Describe your issue in detail\")","","    \/\/ With a plain helper text","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 placeholder: \"Describe your issue in detail\",","                 helperText: .plain(\"Maximum 500 characters.\"))","","    \/\/ With a maximum character count — the component shows \"X characters remaining\" (bold)","    \/\/ and switches to an error style when exceeded.","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 helperText: .charactersMaxCount(500))","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextArea.Helperlink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)","","    \/\/ With error status","    OUDSTextArea(label: \"Comments\", text: $text, status: .error(message: \"This field can't be empty.\"))","","    \/\/ Outlined style","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"]},{"anchor":"Design-documentation","type":"heading","level":2,"text":"Design documentation"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-area","isActive":true,"type":"reference"}],"type":"paragraph"},{"anchor":"Themes-rendering","type":"heading","level":2,"text":"Themes rendering"},{"anchor":"Orange","type":"heading","level":3,"text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_textArea_Orange","type":"image"}]},{"anchor":"Orange-Compact","type":"heading","level":3,"text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_textArea_OrangeCompact","type":"image"}]},{"anchor":"Sosh","text":"Sosh","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_textArea_Sosh"}]},{"anchor":"Wireframe","text":"Wireframe","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_textArea_Wireframe","type":"image"}]},{"name":"Version","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"1.1.0 (Figma component design version)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"1.4.0","type":"text"}]}],"style":"note","name":"Since","type":"aside"}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstextarea"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea/HelperText":{"title":"OUDSTextArea.HelperText","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/HelperText","kind":"symbol","abstract":[{"text":"Describes the content of the helper text displayed below the text area.","type":"text"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"HelperText"}],"navigatorTitle":[{"kind":"identifier","text":"HelperText"}],"url":"\/documentation\/oudscomponents\/oudstextarea\/helpertext","role":"symbol","type":"topic"},"doc://OUDSComponents/docu