{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextArea"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"content":[{"anchor":"Layout","type":"heading","level":2,"text":"Layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Text area is based on several configurable UI elements:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"label"}],"type":"strong"},{"text":": It is used to describe the purpose of the text area.","type":"text"},{"type":"text","text":" "},{"text":"In some UI contexts, especially when space is limited or when the text area is part of a compact layout, the label can be hidden.","type":"text"},{"type":"text","text":" "},{"text":"However, hiding the label should only be done if the purpose remains clear thanks to a placeholder or contextual icon","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and if the label is still accessible to screen readers."},{"text":" ","type":"text"},{"type":"text","text":"Hiding a label is a design choice that must balance visual simplicity and clarity of intent, without compromising inclusiveness or form guidance."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"placeholder"}],"type":"strong"},{"type":"text","text":": If the text of the text area is empty a placeholder provides a hint or guidance inside the field to suggest expected input."}]}]}],"type":"unorderedList"},{"type":"heading","anchor":"Status","level":2,"text":"Status"},{"inlineContent":[{"type":"text","text":"Five status are proposed for all layouts:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"enabled (by default)","type":"text"}],"type":"strong"},{"type":"text","text":": Default neutral appearance, whether empty or filled."},{"type":"text","text":" "},{"type":"text","text":"It allows users to click, focus, and type freely without restrictions."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"error"}]},{"text":": The ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" status indicates that the user input does not meet validation rules or"},{"type":"text","text":" "},{"text":"expected formatting. It provides immediate visual feedback, typically through a red border,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"an error icon, and a clear, accessible error message positioned below the text area. The error message replaces the helper text."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"loading"}]},{"type":"text","text":": The "},{"type":"codeVoice","code":"loading"},{"type":"text","text":" state indicates that the system is processing or retrieving data"},{"type":"text","text":" "},{"type":"text","text":"related to the text entered. A progress indicator appears to inform the user that an action is in progress."},{"type":"text","text":" "},{"type":"text","text":"The field remains editable while loading."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"readOnly"}]},{"type":"text","text":": The "},{"type":"codeVoice","code":"readOnly"},{"type":"text","text":" status lets the text visible but not editable."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"disabled"}]},{"type":"text","text":": In "},{"type":"codeVoice","code":"disabled"},{"type":"text","text":" status, the field is non-interactive and grayed out to indicate it cannot be changed."},{"type":"text","text":" "},{"type":"text","text":"Note the SwiftUI "},{"type":"codeVoice","code":"View.disabled()"},{"type":"text","text":" is ignored."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Helpers","text":"Helpers","level":2,"type":"heading"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper text (plain)","type":"text"}]},{"type":"text","text":": A supporting text conveys additional information about the text area,"},{"text":" ","type":"text"},{"type":"text","text":"such as how it will be used. It should ideally only take up a single line, though may wrap"},{"text":" ","type":"text"},{"type":"text","text":"to multiple lines if required, and be either persistently visible or visible only on focus."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Helper text (characters max count)"}],"type":"strong"},{"type":"text","text":": Uses an internal message displaying the count of remaining characters depending to the given value."},{"type":"text","text":" "},{"type":"text","text":"This is a specific iOS library feature with 1.4.0"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Helper link","type":"text"}]},{"text":": If the helper text is not sufficient, it’s possible to offer the user","type":"text"},{"type":"text","text":" "},{"type":"text","text":"an additional help link (the link can be external or open a modal)."}]}]}]},{"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default no haptics are done by the component."},{"type":"text","text":" "},{"type":"text","text":"However you should think about cases where you will have to make the devices vibrate."},{"type":"text","text":" "},{"type":"text","text":"You can refer to the "},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","type":"reference"},{"type":"text","text":"."}]},{"text":"Mandatory field indication","level":2,"type":"heading","anchor":"Mandatory-field-indication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If all fields are mandatory (several fields present): display the message “All fields are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Do not use an asterisk at the end of each field label, nor the word “mandatory.”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If not all fields are mandatory (several fields present): display the message “All fields marked with an * are mandatory” at the top of your formular."},{"type":"text","text":" "},{"type":"text","text":"Use an asterisk (*) at the end of each mandatory field label, and ensures this is well vocalized."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"UI rendering of the asterisk must be done with "},{"inlineContent":[{"text":"bold font weight","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"text":"negative content color","type":"text"}],"type":"emphasis"},{"type":"text","text":" (red on light backgrounds)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the mention “(optional)” at the end of each optional field label. Note that this rule is not systematic, it remains an option, to be used if needed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is only one field in the formular, or if the mandatory nature is obvious,"},{"type":"text","text":" "},{"type":"text","text":"no mention is necessary since the fields are essential to the formular’s functionality."}]},{"text":"Outlined style","level":2,"type":"heading","anchor":"Outlined-style"},{"type":"paragraph","inlineContent":[{"text":"By ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":", the text area uses a subtle background fill and a bottom border only, creating a softer and more contained look.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"outlined"}]},{"text":", the text area uses a transparent background and a visible stroke on all four sides.","type":"text"},{"text":" ","type":"text"},{"text":"This style may be appropriate for contexts where inputs need to feel lightweight and unobtrusive,","type":"text"},{"text":" ","type":"text"},{"text":"for example inside a card, a dialog, or a filtering panel.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    \/\/ An outlined text area","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"]},{"text":"Rich text","level":2,"type":"heading","anchor":"Rich-text"},{"type":"paragraph","inlineContent":[{"text":"Rich text can be used for error and helper texts.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Strong text can be used sparingly to highlight key information within the content.","type":"text"},{"text":" ","type":"text"},{"text":"No other text styles should be used.","type":"text"},{"text":" ","type":"text"},{"text":"Underlined text must not be applied manually (e.g. in error message), as it is commonly associated with hyperlinks and may mislead users.","type":"text"}]},{"text":"Code samples","level":2,"type":"heading","anchor":"Code-samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ The text to display and edit","    @State var text: String = \"\"","","    \/\/ Empty text and no placeholder","    OUDSTextArea(label: \"Comments\", text: $text)","","    \/\/ Empty text with placeholder","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Describe your issue in detail\")","","    \/\/ With a plain helper text","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 placeholder: \"Describe your issue in detail\",","                 helperText: .plain(\"Maximum 500 characters.\"))","","    \/\/ With a maximum character count — the component shows \"X characters remaining\" (bold)","    \/\/ and switches to an error style when exceeded.","    OUDSTextArea(label: \"Comments\",","                 text: $text,","                 helperText: .charactersMaxCount(500))","","    \/\/ With helper link","    @Environment(\\.openURL) private var openUrl","","    let helperLink = OUDSTextArea.Helperlink(text: \"Helper Link\") {","       openUrl.callAsFunction(url)","    }","","    OUDSTextArea(label: \"Comments\", text: $text, placeholder: \"Placeholder\", helperLink: helperLink)","","    \/\/ With error status","    OUDSTextArea(label: \"Comments\", text: $text, status: .error(message: \"This field can't be empty.\"))","","    \/\/ Outlined style","    OUDSTextArea(label: \"Comments\", text: $text, isOutlined: true)"]},{"text":"Design documentation","level":2,"type":"heading","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-area","type":"reference","isActive":true}]},{"text":"Themes rendering","level":2,"type":"heading","anchor":"Themes-rendering"},{"text":"Orange","level":3,"type":"heading","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_textArea_Orange","type":"image"}]},{"text":"Orange Compact","level":3,"type":"heading","anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_textArea_OrangeCompact","type":"image"}]},{"text":"Sosh","level":3,"type":"heading","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_textArea_Sosh","type":"image"}]},{"text":"Wireframe","level":3,"type":"heading","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_textArea_Wireframe","type":"image"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.1.0 (Figma component design version)"}]}],"type":"aside","style":"note","name":"Version"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.4.0"}]}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"kind":"symbol","relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudstextarea"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextArea","kind":"identifier"}],"title":"OUDSTextArea","platforms":[{"unavailable":false,"beta":false,"introducedAt":"15.0","name":"iOS","deprecated":false},{"unavailable":false,"beta":false,"introducedAt":"13.0","name":"macOS","deprecated":false},{"unavailable":false,"beta":false,"introducedAt":"1.0","name":"visionOS","deprecated":false}],"roleHeading":"Structure","role":"symbol","symbolKind":"struct","navigatorTitle":[{"text":"OUDSTextArea","kind":"identifier"}],"externalID":"s:14OUDSComponents12OUDSTextAreaV"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"abstract":[{"text":"Text area is a UI element that allows to type, edit, or select longer blocks of textual data, such as comments, messages or descriptions;","type":"text"},{"text":" ","type":"text"},{"text":"by expanding vertically and offering more space to input text.","type":"text"},{"text":" ","type":"text"},{"text":"It provides a visual and interactive affordance for multiline text entry while supporting labels, placeholders, descriptions, and validation feedback.","type":"text"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea","interfaceLanguage":"