d":"text","text":": "},{"preciseIdentifier":"s:14OUDSComponents12OUDSTextAreaV","kind":"typeIdentifier","text":"OUDSTextArea"},{"kind":"text","text":"."},{"preciseIdentifier":"s:14OUDSComponents12OUDSTextAreaV10HelperTextO","kind":"typeIdentifier","text":"HelperText"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"helperLink"},{"kind":"text","text":": "},{"preciseIdentifier":"s:14OUDSComponents12OUDSTextAreaV","kind":"typeIdentifier","text":"OUDSTextArea"},{"kind":"text","text":"."},{"preciseIdentifier":"s:14OUDSComponents12OUDSTextAreaV10HelperlinkV","kind":"typeIdentifier","text":"Helperlink"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"isOutlined"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"constrainedMaxWidth"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"status"},{"kind":"text","text":": "},{"preciseIdentifier":"s:14OUDSComponents12OUDSTextAreaV","kind":"typeIdentifier","text":"OUDSTextArea"},{"kind":"text","text":"."},{"preciseIdentifier":"s:14OUDSComponents12OUDSTextAreaV6StatusO","kind":"typeIdentifier","text":"Status"},{"kind":"text","text":")"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/init(_:tableName:bundle:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)","url":"\/documentation\/oudscomponents\/oudstextarea\/init(_:tablename:bundle:text:placeholder:helpertext:helperlink:isoutlined:constrainedmaxwidth:status:)"},"component_textArea_Sosh":{"variants":[{"url":"\/images\/OUDSComponents\/component_textArea_Sosh.png","traits":["1x","light"]}],"type":"image","alt":"A text area component in light and dark modes with Sosh theme","identifier":"component_textArea_Sosh"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea":{"type":"topic","abstract":[{"type":"text","text":"Text area is a UI element that allows to type, edit, or select longer blocks of textual data, such as comments, messages or descriptions;"},{"type":"text","text":" "},{"type":"text","text":"by expanding vertically and offering more space to input text."},{"type":"text","text":" "},{"type":"text","text":"It provides a visual and interactive affordance for multiline text entry while supporting labels, placeholders, descriptions, and validation feedback."}],"url":"\/documentation\/oudscomponents\/oudstextarea","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTextArea"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea","kind":"symbol","title":"OUDSTextArea","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSTextArea"}]},"doc://OUDSComponents/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/OUDSComponents\/s8SendableP"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea/Helperlink":{"abstract":[{"type":"text","text":"Used to describe the helper link below the text area."}],"role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Helperlink"}],"kind":"symbol","title":"OUDSTextArea.Helperlink","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"Helperlink","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Helperlink","url":"\/documentation\/oudscomponents\/oudstextarea\/helperlink"},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"ic_folder_categories.png"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea/Status":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Status"}],"navigatorTitle":[{"kind":"identifier","text":"Status"}],"url":"\/documentation\/oudscomponents\/oudstextarea\/status","type":"topic","abstract":[{"type":"text","text":"Define all available status for the text area"}],"title":"OUDSTextArea.Status","kind":"symbol","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Status"},"component_textArea_OrangeCompact":{"variants":[{"url":"\/images\/OUDSComponents\/component_textArea_OrangeCompact.png","traits":["1x","light"]}],"type":"image","alt":"A text area component in light and dark modes with Orange Compact theme","identifier":"component_textArea_OrangeCompact"}}}