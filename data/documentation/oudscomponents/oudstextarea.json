":"body","url":"\/documentation\/oudscomponents\/oudstextarea\/body","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/body","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea","abstract":[{"type":"text","text":"Text area is a UI element that allows to type, edit, or select longer blocks of textual data, such as comments, messages or descriptions;"},{"type":"text","text":" "},{"type":"text","text":"by expanding vertically and offering more space to input text."},{"type":"text","text":" "},{"type":"text","text":"It provides a visual and interactive affordance for multiline text entry while supporting labels, placeholders, descriptions, and validation feedback."}],"type":"topic","url":"\/documentation\/oudscomponents\/oudstextarea","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTextArea","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSTextArea","kind":"identifier"}],"title":"OUDSTextArea"},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"role":"article","kind":"article","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"text":"controls","type":"text"}]},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"text":"inputs","type":"text"}]},{"text":".","type":"text"}],"type":"topic","url":"\/documentation\/oudscomponents\/controls","title":"Controls"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea/Status":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea\/Status","abstract":[{"text":"Define all available status for the text area","type":"text"}],"type":"topic","url":"\/documentation\/oudscomponents\/oudstextarea\/status","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Status"}],"navigatorTitle":[{"kind":"identifier","text":"Status"}],"title":"OUDSTextArea.Status"},"component_textArea_Wireframe":{"alt":"A text area component in light and dark modes with Wireframe theme","type":"image","variants":[{"url":"\/images\/OUDSComponents\/component_textArea_Wireframe.png","traits":["1x","light"]}],"identifier":"component_textArea_Wireframe"},"https://developer.apple.com/design/human-interface-guidelines/playing-haptics":{"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","type":"link","title":"Human Interface Guidelines of Apple","url":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/playing-haptics","titleInlineContent":[{"text":"Human Interface Guidelines of Apple","type":"text"}]},"doc://OUDSComponents/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","type":"unresolvable","title":"Swift.SendableMetatype"},"component_textArea_OrangeCompact":{"variants":[{"url":"\/images\/OUDSComponents\/component_textArea_OrangeCompact.png","traits":["1x","light"]}],"alt":"A text area component in light and dark modes with Orange Compact theme","identifier":"component_textArea_OrangeCompact","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea/HelperText":{"kind":"symbol","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Describes the content of the helper text displayed below the text area."}],"title":"OUDSTextArea.HelperText",