s\/documentation\/OUDSComponents\/OUDSTextArea","role":"symbol","url":"\/documentation\/oudscomponents\/oudstextarea","kind":"symbol","abstract":[{"text":"Text area is a UI element that allows to type, edit, or select longer blocks of textual data, such as comments, messages or descriptions;","type":"text"},{"text":" ","type":"text"},{"text":"by expanding vertically and offering more space to input text.","type":"text"},{"text":" ","type":"text"},{"text":"It provides a visual and interactive affordance for multiline text entry while supporting labels, placeholders, descriptions, and validation feedback.","type":"text"}],"type":"topic","title":"OUDSTextArea"},"doc://OUDSComponents/documentation/OUDSComponents":{"type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"role":"collection","url":"\/documentation\/oudscomponents","kind":"symbol","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSTextArea/init(label:text:placeholder:helperText:helperLink:isOutlined:constrainedMaxWidth:status:)":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"label"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"text"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI7BindingV","text":"Binding"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"placehold