ata, such as comments, messages or descriptions;","type":"text"},{"text":" ","type":"text"},{"text":"by expanding vertically and offering more space to input text.","type":"text"},{"text":" ","type":"text"},{"text":"It provides a visual and interactive affordance for multiline text entry while supporting labels, placeholders, descriptions, and validation feedback.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTextArea","kind":"symbol"},"component_textArea_Sosh":{"type":"image","identifier":"component_textArea_Sosh","variants":[{"url":"\/images\/OUDSComponents\/component_textArea_Sosh.png","traits":["1x","light"]}],"alt":"A text area component in light and dark modes with Sosh theme"},"https://r.orange.fr/r/S-ouds-doc-text-area":{"type":"link","title":"unified-design-system.orange.com","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-area","url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-text-area","titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}]},"component_textArea_Wireframe":{"type":"image","identifier":"component_textArea_Wireframe","alt":"A text area component in light and dark modes with Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_textArea_Wireframe.png","traits":["1x","light"]}]},"doc://OUDSComponents/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype","type":"unresolvable"},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"url":"\/documentation\/oudscomponents\/controls","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls","abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"text":"controls","type":"text"}],"type":"strong"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"inputs","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"role":"article","kind":"article","images":[{"identifi