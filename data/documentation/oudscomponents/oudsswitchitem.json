{"variants":[{"paths":["\/documentation\/oudscomponents\/oudsswitchitem"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(_:isOn:helper:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:)"],"title":"Initializers"},{"anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/body"],"title":"Instance Properties"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations"],"title":"Default Implementations"}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","type":"conformsTo"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem"},"kind":"symbol","sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"roleHeading":"Structure","navigatorTitle":[{"text":"OUDSSwitchItem","kind":"identifier"}],"externalID":"s:14OUDSComponents14OUDSSwitchItemV","role":"symbol","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSwitchItem","kind":"identifier"}],"platforms":[{"name":"iOS","unavailable":false,"deprecated":false,"beta":false,"introducedAt":"15.0"},{"name":"macOS","unavailable":false,"deprecated":false,"beta":false,"introducedAt":"15.0"},{"name":"tvOS","unavailable":false,"deprecated":false,"beta":false,"introducedAt":"16.0"},{"name":"visionOS","unavailable":false,"deprecated":false,"beta":false,"introducedAt":"1.0"},{"name":"watchOS","unavailable":false,"deprecated":false,"beta":false,"introducedAt":"11.0"}],"title":"OUDSSwitchItem","modules":[{"name":"Components"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","type":"reference","isActive":true},{"text":" proposes layouts to add in your views some swith components.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a switch with only an indicator, prefer instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitch","type":"reference","isActive":true},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSwitchItem","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"content":[{"text":"Layouts","anchor":"Layouts","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"inverse"}],"type":"strong"},{"type":"text","text":": like the "},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"type":"text","text":" layout but with a trailing switch indicator and a leading optional decorative icon"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Indicator states","anchor":"Indicator-states","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The switch indicator has two available states set as a boolean property that determines whether the toggle is on or off.","type":"text"}]},{"text":"Particular cases","anchor":"Particular-cases","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true,"type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In addition, the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true,"type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"},{"text":" ","type":"text"},{"text":"The switch can be also outlined in some cases.","type":"text"}]},{"text":"Accessibility considerations","anchor":"Accessibility-considerations","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom switch trait.","type":"text"}]},{"text":"Forbidden by design","anchor":"Forbidden-by-design","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}],"type":"strong"}]},{"text":"Code samples","anchor":"Code-samples","type":"heading","level":2},{"type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var isOn: Bool = false","","    \/\/ A leading switch with a label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn)","","    \/\/ A leading switch with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading switch with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, helper: \"The Beatles\")","","    \/\/ A leading switch with an additional label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, additionalLabel: \"The Beatles\", helper: \"1967\")","","    \/\/ A trailing switch with a label, an additonal label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\",","                   isOn: $isOn,","                   additionalLabel: \"The Beatles\",","                   helper: \"1967\",","                   isReversed: true,","                   icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing switch with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   helper: \"Put your hand in mine\",","                   icon: Image(decorative: \"ic_heart\"),","                   isReversed: true,","                   isError: true,","                   hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   isError: true,","                   errorText: \"Something wrong\",","                   hasDivider: true)","","    \/\/ A leading switch with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related switch as it will crash","    \/\/ This is forbidden by design!","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isReadyOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}]},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, flipLeadingIcon: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"text":"Design documentation","anchor":"Design-documentation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/18acc0-switch","isActive":true,"type":"reference"}]},{"text":"Themes rendering","anchor":"Themes-rendering","type":"heading","level":2},{"text":"Orange","anchor":"Orange","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_Orange","type":"image"}]},{"text":"Orange Business Tools","anchor":"Orange-Business-Tools","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_OrangeBusinessTools","type":"image"}]},{"text":"Sosh","anchor":"Sosh","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_Sosh","type":"image"}]},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_Wireframe","type":"image"}]},{"name":"Version","content":[{"inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"name":"Since","content":[{"inlineContent":[{"text":"0.14.0","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"}],"kind":"content"}],"references":{"https://unified-design-system.orange.com/472794e18/p/18acc0-switch":{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/18acc0-switch","titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/18acc0-switch","type":"link","title":"unified-design-system.orange.com"},"doc://OUDSComponents/documentation/OUDSComponents":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"url":"\/documentation\/oudscomponents","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and hig