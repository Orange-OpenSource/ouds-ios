{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSwitchItem","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"type":"heading","text":"Layouts","level":2,"anchor":"Layouts"},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"inverse"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"text":" layout but with a trailing switch indicator and a leading optional decorative icon","type":"text"}]}]}]},{"type":"heading","level":2,"anchor":"Indicator-states","text":"Indicator states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The switch indicator has two available states set as a boolean property that determines whether the toggle is on or off."}]},{"type":"heading","text":"Particular cases","level":2,"anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","type":"reference","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"text":" ","type":"text"},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."},{"text":" ","type":"text"},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."},{"type":"text","text":" "},{"type":"text","text":"The switch can be also outlined in some cases."}]},{"type":"heading","level":2,"anchor":"Accessibility-considerations","text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom switch trait.","type":"text"}]},{"type":"heading","level":2,"anchor":"Forbidden-by-design","text":"Forbidden by design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"type":"heading","level":2,"anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var isOn: Bool = false","","    \/\/ A leading switch with a label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn)","","    \/\/ A leading switch with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading switch with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, helper: \"The Beatles\")","","    \/\/ A leading switch with an additional label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, additionalLabel: \"The Beatles\", helper: \"1967\")","","    \/\/ A trailing switch with a label, an additonal label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\",","                   isOn: $isOn,","                   additionalLabel: \"The Beatles\",","                   helper: \"1967\",","                   isReversed: true,","                   icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing switch with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   helper: \"Put your hand in mine\",","                   icon: Image(decorative: \"ic_heart\"),","                   isReversed: true,","                   isError: true,","                   hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   isError: true,","                   errorText: \"Something wrong\",","                   hasDivider: true)","","    \/\/ A leading switch with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related switch as it will crash","    \/\/ This is forbidden by design!","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isReadyOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}]},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, flipLeadingIcon: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"type":"heading","level":2,"anchor":"Design-documentation","text":"Design documentation"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/18acc0-switch"}],"type":"paragraph"},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"text":"Orange","level":3,"anchor":"Orange","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_Orange","type":"image"}]},{"type":"heading","text":"Orange Business Tools","level":3,"anchor":"Orange-Business-Tools"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_switchItem_OrangeBusinessTools"}]},{"text":"Sosh","level":3,"anchor":"Sosh","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_Sosh","type":"image"}]},{"text":"Wireframe","anchor":"Wireframe","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_Wireframe","type":"image"}]},{"type":"aside","style":"note","name":"Version","content":[{"inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"0.14.0"}],"type":"paragraph"}]}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/oudscomponents\/oudsswitchitem"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"externalID":"s:14OUDSComponents14OUDSSwitchItemV","symbolKind":"struct","title":"OUDSSwitchItem","navigatorTitle":[{"kind":"identifier","text":"OUDSSwitchItem"}],"modules":[{"name":"Components"}],"role":"symbol","roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSwitchItem"}],"platforms":[{"unavailable":false,"deprecated":false,"beta":false,"name":"iOS","introducedAt":"15.0"},{"unavailable":false,"deprecated":false,"beta":false,"name":"macOS","introducedAt":"15.0"},{"unavailable":false,"deprecated":false,"beta":false,"name":"tvOS","introducedAt":"16.0"},{"beta":false,"deprecated":false,"name":"visionOS","unavailable":false,"introducedAt":"1.0"},{"beta":false,"deprecated":false,"name":"watchOS","unavailable":false,"introducedAt":"11.0"}]},"sections":[],"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","type":"reference","isActive":true},{"type":"text","text":" proposes layouts to add in your views some swith components."},{"text":" ","type":"text"},{"type":"text","text":"If you want to use a switch with only an indicator, prefer instead "},{"type":"reference","id