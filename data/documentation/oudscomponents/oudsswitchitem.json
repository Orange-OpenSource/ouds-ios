{"metadata":{"role":"symbol","roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSwitchItem"}],"modules":[{"name":"OUDSComponents"}],"title":"OUDSSwitchItem","externalID":"s:14OUDSComponents14OUDSSwitchItemV","navigatorTitle":[{"kind":"identifier","text":"OUDSSwitchItem"}],"symbolKind":"struct"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(isOn:label:helper:icon:flipIcon:isReversed:isError:isReadOnly:hasDivider:)"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/body"],"anchor":"Instance-Properties","generated":true},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations"],"anchor":"Default-Implementations","generated":true}],"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true},{"type":"text","text":" proposes layouts to add in your views some swith components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a switch with only an indicator, prefer instead "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitch","isActive":true},{"type":"text","text":"."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSwitchItem","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Layouts","anchor":"Layouts"},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"inverse","type":"text"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"text":" layout but with a trailing switch indicator and a leading optional decorative icon","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Indicator states","anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The switch indicator has two available states set as a boolean property that determines whether the toggle is on or off."}]},{"type":"heading","level":2,"text":"Particular cases","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"},{"text":" ","type":"text"},{"text":"The switch can be also outlined in some cases.","type":"text"}]},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom switch trait.","type":"text"}]},{"type":"heading","level":2,"text":"Forbidden by design","anchor":"Forbidden-by-design"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}],"type":"strong"}]},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var isOn: Bool = false","","    \/\/ A leading switch with a label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(isOn: $isOn, label: \"Lucy in the Sky with Diamonds\")","","    \/\/ A leading switch with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSSwitchItem(isOn: $isOn, label: \"Lucy in the Sky with Diamonds\", isReadOnly: true)","","    \/\/ A leading switch with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(isOn: $isOn, label: \"Lucy in the Sky with Diamonds\", helper: \"The Beatles\")","","    \/\/ A leading switch with an additional label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(isOn: $isOn, label: \"Lucy in the Sky with Diamonds\", additionalLabel: \"The Beatles\", helper: \"1967\")","","    \/\/ A trailing switch with a label, an additonal label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(isOn: $isOn,","                  label: \"Lucy in the Sky with Diamonds\",","                  additionalLabel: \"The Beatles\",","                  helper: \"1967\",","                  isReversed: true,","                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing switch with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(isOn: $isOn,","                  label: \"Rescue from this world!\",","                  helper: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isReversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ A leading switch with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(isOn: $isOn, label: \"Rescue from this world!\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related switch as it will crash","    \/\/ This is forbidden by design!","    OUDSSwitchItem(isOn: $isOn, label: \"Kaboom!\", isError: true).disabled(true) \/\/ fatal error","    OUDSSwitchItem(isOn: $isOn, label: \"Kaboom!\", isReadyOnly: true).disabled(true) \/\/ fatal error"]},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/","type":"reference","isActive":true}]},{"content":[{"inlineContent":[{"text":"0.14.0","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Since","style":"note"}]}],"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsswitchitem"]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSSwitchItem/init(isOn:label:helper:icon:flipIcon:isReversed:isError:isReadOnly:hasDivider:)":{"title":"init(isOn:label:helper:icon:flipIcon:isReversed:isError:isReadOnly:hasDivider:)","type":"topic","url":"\/documentation\/oudscomponents\/oudsswitchitem\/init(ison:label:helper:icon:flipicon:isreversed:iserror:isreadonly:hasdivider:)","abstract":[{"type":"text","text":"Creates a switch with label and optional helper text, icon, divider."}],"fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"isOn"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI7BindingV","text":"Binding"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"label"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"helper"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"icon"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI5ImageV","text":"Imag