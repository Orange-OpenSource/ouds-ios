{"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","interfaceLanguage":"swift"},"metadata":{"platforms":[{"introducedAt":"15.0","name":"iOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"13.0","name":"macOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"16.0","name":"tvOS","deprecated":false,"unavailable":false,"beta":false},{"deprecated":false,"beta":false,"unavailable":false,"name":"visionOS","introducedAt":"1.0"},{"beta":false,"deprecated":false,"name":"watchOS","unavailable":false,"introducedAt":"11.0"}],"title":"OUDSSwitchItem","externalID":"s:14OUDSComponents14OUDSSwitchItemV","navigatorTitle":[{"text":"OUDSSwitchItem","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSwitchItem"}],"symbolKind":"struct","roleHeading":"Structure","modules":[{"name":"Components"}],"role":"symbol"},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships"}],"abstract":[{"type":"text","text":"Switch item is a UI element that allows to toggle between two states, typically “On” and “Off”, and used to enable or disable features, options or settings."},{"type":"text","text":" "},{"type":"text","text":"Switch Item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSwitchItem"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"anchor":"Layouts","text":"Layouts","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"inverse","type":"text"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"text":" layout but with a trailing switch indicator and a leading optional decorative icon","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Indicator-states","text":"Indicator states","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The switch indicator has two available states set as a boolean property that determines whether the toggle is on or off."}]},{"anchor":"Particular-cases","text":"Particular cases","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, the "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."},{"type":"text","text":" "},{"type":"text","text":"The switch can be also outlined in some cases."}]},{"anchor":"Accessibility-considerations","text":"Accessibility considerations","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and optional texts and a custom switch trait."}]},{"anchor":"Forbidden-by-design","text":"Forbidden by design","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"anchor":"Code-samples","text":"Code samples","level":2,"type":"heading"},{"code":["    \/\/ Supposing we have an unselected state","    @Published var isOn: Bool = false","","    \/\/ A leading switch with a label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn)","","    \/\/ Localizable from bundle can also be used","    OUDSSwitchItem(LocalizedStringKey(\"notifications_setting\"), bundle: Bundle.module, isOn: $isOn)","","    \/\/ A leading switch with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading switch with a label, and a description text.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, description: \"The Beatles\")","","    \/\/ A leading switch with an additional label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, description: \"The Beatles\")","","    \/\/ A trailing switch with a label, an additional label, a description text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\",","                   isOn: $isOn,","                   description: \"The Beatles\",","                   isReversed: true,","                   icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing switch with a label, a description text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   description: \"Put your hand in mine\",","                   icon: Image(decorative: \"ic_heart\"),","                   isReversed: true,","                   isError: true,","                   hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   isError: true,","                   errorText: \"Something wrong\",","                   hasDivider: true)","","    \/\/ A leading switch with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related switch as it will crash","    \/\/ This is forbidden by design!","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isReadOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, flipLeadingIcon: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"anchor":"Rich-text","text":"Rich text","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Rich text can only be used for error messages."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Strong text can be used sparingly to highlight key information within the content."},{"type":"text","text":" "},{"type":"text","text":"No other text styles should be used."},{"type":"text","text":" "},{"type":"text","text":"Underlined text must not be applied manually (e.g. in error message), as it is commonly associated with hyperlinks and may mislead users."}]},{"anchor":"Accessibility-considerations","text":"Accessibility considerations","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always check the results of rich text mode with high contrast, light and dark modes, and Voice Over vocalization."}]},{"anchor":"Design-documentation","text":"Design documentation","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-switch","isActive":true}]},{"anchor":"Themes-rendering","text":"Themes rendering","level":2,"type":"heading"},{"anchor":"Orange","text":"Orange","level":3,"type":"heading"},{"type":"paragraph