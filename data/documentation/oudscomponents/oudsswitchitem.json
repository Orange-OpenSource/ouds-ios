{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Switch item is a UI element that allows to toggle between two states, typically “On” and “Off”, and used to enable or disable features, options or settings."},{"type":"text","text":" "},{"type":"text","text":"Switch Item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(_:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(_:tableName:bundle:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/body"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"kind":"symbol","relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"text":" ","kind":"text"},{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSSwitchItem","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Layouts","text":"Layouts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"inverse"}]},{"text":": like the ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"type":"text","text":" layout but with a trailing switch indicator and a leading optional decorative icon"}],"type":"paragraph"}]}]},{"anchor":"Indicator-states","type":"heading","level":2,"text":"Indicator states"},{"inlineContent":[{"type":"text","text":"The switch indicator has two available states set as a boolean property that determines whether the toggle is on or off."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Particular cases","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}]},{"type":"paragraph","inlineContent":[{"text":"In addition, the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"},{"text":" ","type":"text"},{"text":"The switch can be also outlined in some cases.","type":"text"}]},{"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and optional texts and a custom switch trait.","type":"text"}]},{"type":"heading","level":2,"anchor":"Forbidden-by-design","text":"Forbidden by design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var isOn: Bool = false","","    \/\/ A leading switch with a label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn)","","    \/\/ Localizable from bundle can also be used","    OUDSSwitchItem(LocalizedStringKey(\"notifications_setting\"), bundle: Bundle.module, isOn: $isOn)","","    \/\/ A leading switch with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading switch with a label, and a description text.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, description: \"The Beatles\")","","    \/\/ A leading switch with an additional label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, description: \"The Beatles\")","","    \/\/ A trailing switch with a label, an additional label, a description text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\",","                   isOn: $isOn,","                   description: \"The Beatles\",","                   isReversed: true,","                   icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing switch with a label, a description text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   description: \"Put your hand in mine\",","                   icon: Image(decorative: \"ic_heart\"),","                   isReversed: true,","                   isError: true,","                   hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   isError: true,","                   errorText: \"Something wrong\",","                   hasDivider: true)","","    \/\/ A leading switch with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related switch as it will crash","    \/\/ This is forbidden by design!","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isReadOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, flipLeadingIcon: layoutDirection == .rightToLeft)"],"type":"codeListing"},{"anchor":"Design-documentation","level":2,"text":"Design documentation","type":"heading"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-switch"}],"type":"paragraph"},{"anchor":"Themes-rendering","level":2,"text":"Themes rendering","type":"heading"},{"anchor":"Orange","level":3,"text":"Orange","type":"heading"},{"inlineContent":[{"type":"image","identifier":"component_switchItem_Orange"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Orange-Compact","text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_switchItem_OrangeCompact"}]},{"type":"heading","level":3,"text":"Sosh","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_switchItem_Sosh"}]},{"type":"heading","level":3,"text":"Wireframe","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_switchItem_Wireframe"}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"1.5.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"name":"Version"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.14.0"}]}],"name":"Since"}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsswitchitem"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSSwitchItem"}],"externalID":"s:14OUDSComponents14OUDSSwitchItemV","navigatorTitle":[{"kind":"identifier","text":"OUDSSwitchItem"}],"role":"symbol","roleHeading":"Structure","modules":[{"name":"Components"}],"platforms":[{"introducedAt":"15.0","name":"iOS","deprecated":false,"unavailable":false,"beta":false},{"beta":false,"name":"macOS","deprecated":false,"introducedAt":"13.0","unavailable":false},{"beta":false,"deprecated":false,"name":"tvOS","introducedAt":"16.0","unavailable":false},{"beta":false,"name":"visionOS","introducedAt":"1.0","unavailable":false,"deprecated":false},{"unavailable":false,"introducedAt":"11.0","name":"watchOS","deprecated":false,"beta":false}],"title":"OUDSSwitchItem"},"sections":[],"references":{"doc://OUDSComponents/s8SendableP":{"title":"Swift.Sendable","type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s8SendableP"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSwitchItem/View-Implementations":{"abstract":[],"role":"collectionGroup","kind":"article","title":"View Implementations","url":"\/documentation\/oudscomponents\/oudsswitchitem\/view-implementations","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations"},"doc://OUDSComponents/documentation/OUDSComponents":{"title":"Components","role":"collection","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"type":"topic","url":"\/documentation\/oudscomponents","kind":"symbol","identifier":"d