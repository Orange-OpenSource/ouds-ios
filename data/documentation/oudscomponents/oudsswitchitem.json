{"metadata":{"roleHeading":"Structure","modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents14OUDSSwitchItemV","platforms":[{"unavailable":false,"beta":false,"deprecated":false,"introducedAt":"15.0","name":"iOS"},{"unavailable":false,"beta":false,"deprecated":false,"introducedAt":"13.0","name":"macOS"},{"unavailable":false,"beta":false,"deprecated":false,"introducedAt":"16.0","name":"tvOS"},{"unavailable":false,"beta":false,"deprecated":false,"introducedAt":"1.0","name":"visionOS"},{"unavailable":false,"beta":false,"deprecated":false,"introducedAt":"11.0","name":"watchOS"}],"navigatorTitle":[{"text":"OUDSSwitchItem","kind":"identifier"}],"title":"OUDSSwitchItem","role":"symbol","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSwitchItem","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"abstract":[{"text":"Switch item is a UI element that allows to toggle between two states, typically “On” and “Off”, and used to enable or disable features, options or settings.","type":"text"},{"text":" ","type":"text"},{"text":"Switch Item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets.","type":"text"}],"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(_:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(_:tableName:bundle:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/body"],"generated":true},{"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations"],"generated":true}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem"},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSwitchItem","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"text":"Layouts","level":2,"anchor":"Layouts","type":"heading"},{"inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":": the component has a leading indicator, a label and optional texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"inverse"}]},{"text":": like the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"text":" layout but with a trailing switch indicator and a leading optional decorative icon","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Indicator states","level":2,"anchor":"Indicator-states","type":"heading"},{"inlineContent":[{"text":"The switch indicator has two available states set as a boolean property that determines whether the toggle is on or off.","type":"text"}],"type":"paragraph"},{"text":"Particular cases","level":2,"anchor":"Particular-cases","type":"heading"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true,"type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In addition, the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true,"type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"},{"text":" ","type":"text"},{"text":"The switch can be also outlined in some cases.","type":"text"}],"type":"paragraph"},{"text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations","type":"heading"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and optional texts and a custom switch trait.","type":"text"}],"type":"paragraph"},{"text":"Forbidden by design","level":2,"anchor":"Forbidden-by-design","type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}],"type":"paragraph"},{"text":"Code samples","level":2,"anchor":"Code-samples","type":"heading"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var isOn: Bool = false","","    \/\/ A leading switch with a label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn)","","    \/\/ Localizable from bundle can also be used","    OUDSSwitchItem(LocalizedStringKey(\"notifications_setting\"), bundle: Bundle.module, isOn: $isOn)","","    \/\/ A leading switch with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading switch with a label, and a description text.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, description: \"The Beatles\")","","    \/\/ A leading switch with an additional label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, description: \"The Beatles\")","","    \/\/ A trailing switch with a label, an additional label, a description text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\",","                   isOn: $isOn,","                   description: \"The Beatles\",","                   isReversed: true,","                   icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing switch with a label, a description text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   description: \"Put your hand in mine\",","                   icon: Image(decorative: \"ic_heart\"),","                   isReversed: true,","                   isError: true,","                   hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   isError: true,","                   errorText: \"Something wrong\",","                   hasDivider: true)","","    \/\/ A leading switch with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related switch as it will crash","    \/\/ This is forbidden by design!","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, flipLeadingIcon: layoutDirection == .rightToLeft)"]},{"text":"Design documentation","level":2,"anchor":"Design-documentation","type":"heading"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-switch","isActive":true,"type":"reference"}],"type":"paragraph"},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"text":"Orange","level":3,"anchor":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_switchItem_Orange","type":"image"}],"type":"paragraph"},{"text":"Orange Compact","level":3,"anchor":"Orange-Compact","type":"heading"},{"inlineContent":[{"identifier":"component_switchItem_OrangeCompact","type":"image"}],"type":"paragraph"},{"text":"Sosh","level":3,"anchor":"Sosh","type":"heading"},{"inlineContent":[{"identifier":"component_switchItem_Sosh","type":"image"}],"type":"paragraph"},{"text":"Wireframe","level":3,"anchor":"Wireframe","type":"heading"},{"inlineContent":[{"identifier":"component_switchItem_Wireframe","type":"image"}],"type":"paragraph"},{"name":"Version","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"1.5.0 (Figma component design version)","type":"text"}]}]},{"name":"Since","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"0.14.0","type":"text"}]}]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/oudscomponents\/oudsswitchitem"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSSwitchItem/init(_:tableName:bundle:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:)":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Creates a switch with a localized label, looking up the key in the given bundle."}],"title":"init(_:tableName:bundle:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(_:tableName:bundle:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:)","type":"topic","url":"\/documentation\/oudscomponents\/oudss