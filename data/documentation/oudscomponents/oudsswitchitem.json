{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem"},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(_:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(_:tableName:bundle:isOn:description:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:)"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/body"],"anchor":"Instance-Properties","generated":true},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations"],"anchor":"Default-Implementations","generated":true}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"platforms":[{"introducedAt":"15.0","deprecated":false,"beta":false,"unavailable":false,"name":"iOS"},{"introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false,"name":"macOS"},{"introducedAt":"16.0","deprecated":false,"beta":false,"unavailable":false,"name":"tvOS"},{"introducedAt":"1.0","deprecated":false,"beta":false,"unavailable":false,"name":"visionOS"},{"introducedAt":"11.0","deprecated":false,"beta":false,"unavailable":false,"name":"watchOS"}],"role":"symbol","modules":[{"name":"Components"}],"roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSwitchItem"}],"externalID":"s:14OUDSComponents14OUDSSwitchItemV","symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"OUDSSwitchItem"}],"title":"OUDSSwitchItem"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSwitchItem"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"type":"heading","text":"Layouts","level":2,"anchor":"Layouts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"inverse","type":"text"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"text":" layout but with a trailing switch indicator and a leading optional decorative icon","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Indicator states","level":2,"anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The switch indicator has two available states set as a boolean property that determines whether the toggle is on or off."}]},{"type":"heading","text":"Particular cases","level":2,"anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, the "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."},{"type":"text","text":" "},{"type":"text","text":"The switch can be also outlined in some cases."}]},{"type":"heading","text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and optional texts and a custom switch trait."}]},{"type":"heading","text":"Forbidden by design","level":2,"anchor":"Forbidden-by-design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}]},{"type":"heading","text":"Code samples","level":2,"anchor":"Code-samples"},{"type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var isOn: Bool = false","","    \/\/ A leading switch with a label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn)","","    \/\/ Localizable from bundle can also be used","    OUDSSwitchItem(LocalizedStringKey(\"notifications_setting\"), bundle: Bundle.module, isOn: $isOn)","","    \/\/ A leading switch with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading switch with a label, and a description text.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, description: \"The Beatles\")","","    \/\/ A leading switch with an additional label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, description: \"The Beatles\")","","    \/\/ A trailing switch with a label, an additional label, a description text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\",","                   isOn: $isOn,","                   description: \"The Beatles\",","                   isReversed: true,","                   icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing switch with a label, a description text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   description: \"Put your hand in mine\",","                   icon: Image(decorative: \"ic_heart\"),","                   isReversed: true,","                   isError: true,","                   hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   isError: true,","                   errorText: \"Something wrong\",","                   hasDivider: true)","","    \/\/ A leading switch with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related switch as it will crash","    \/\/ This is forbidden by design!","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isReadOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, flipLeadingIcon: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"type":"heading","text":"Design documentation","level":2,"anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-switch","isActive":true}]},{"type":"heading","text":"Themes rendering","level":2,"anchor":"Themes-rendering"},{"type":"heading","text":"Orange","level":3,"anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_switchItem_Orange"}]},{"type":"heading","text":"Orange Compact","level":3,"anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_switchItem_OrangeCompact"}]},{"type":"heading","text":"Sosh","level":3,"anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_switchItem_Sosh"}]},{"type":"heading","text":"Wireframe","level":3,"anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_switchItem_Wireframe"}]},{"type":"aside","name":"Version","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"1.5.0 (Figma component design version)","type":"text"}]}]},{"type":"aside","name":"Since","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"0.14.0","type":"text"}]}]}]}],"kind":"symbol","abstract":[{"type":"text","text":"Switch item is a UI element that allows to toggle between two states, typically “On” and “Off”, and used to enable or disable features, options or settings."},{"type":"text","text":" "},{"type":"text","text":"Switch Item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsswitchitem"]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSSwitchItem/body":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/body","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}],"type":"topic","kind":"symbol","abstract":[],"url":"\/documentation\/oudscomponents\/oudsswitchitem\/body","title":"body"},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"kind":"article","role":"article","title":"Controls","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponen