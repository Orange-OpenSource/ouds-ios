{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem"},"sections":[],"abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem"},{"text":" proposes layouts to add in your views some swith components.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a switch with only an indicator, prefer instead ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitch"},{"text":".","type":"text"}],"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/init(_:isOn:helper:icon:flipIcon:isReversed:isError:errorText:isReadOnly:hasDivider:)"]},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/body"]},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem\/View-Implementations"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSwitchItem"}],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"type":"heading","text":"Layouts","anchor":"Layouts","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"inverse"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing switch indicator and a leading optional decorative icon"}],"type":"paragraph"}]}]},{"type":"heading","text":"Indicator states","anchor":"Indicator-states","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The switch indicator has two available states set as a boolean property that determines whether the toggle is on or off."}]},{"type":"heading","text":"Particular cases","anchor":"Particular-cases","level":2},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","isActive":true,"type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In addition, the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSwitchItem","type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"},{"text":" ","type":"text"},{"text":"The switch can be also outlined in some cases.","type":"text"}]},{"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom switch trait.","type":"text"}]},{"type":"heading","text":"Forbidden by design","anchor":"Forbidden-by-design","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"type":"heading","text":"Code samples","anchor":"Code-samples","level":2},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var isOn: Bool = false","","    \/\/ A leading switch with a label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn)","","    \/\/ A leading switch with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, isReadOnly: true)","","    \/\/ A leading switch with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, helper: \"The Beatles\")","","    \/\/ A leading switch with an additional label.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\", isOn: $isOn, additionalLabel: \"The Beatles\", helper: \"1967\")","","    \/\/ A trailing switch with a label, an additonal label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Lucy in the Sky with Diamonds\",","                   isOn: $isOn,","                   additionalLabel: \"The Beatles\",","                   helper: \"1967\",","                   isReversed: true,","                   icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing switch with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   helper: \"Put your hand in mine\",","                   icon: Image(decorative: \"ic_heart\"),","                   isReversed: true,","                   isError: true,","                   hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSSwitchItem(\"Rescue from this world!\",","                   isOn: $isOn,","                   isError: true,","                   errorText: \"Something wrong\",","                   hasDivider: true)","","    \/\/ A leading switch with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSSwitchItem(\"Rescue from this world!\", isOn: $isOn)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related switch as it will crash","    \/\/ This is forbidden by design!","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isError: true).disabled(true) \/\/ fatal error","    OUDSSwitchItem(\"Kaboom!\", isOn: $isOn, isReadyOnly: true).disabled(true) \/\/ fatal error"]},{"type":"heading","text":"Design documentation","anchor":"Design-documentation","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/18acc0-switch"}]},{"type":"heading","text":"Themes rendering","anchor":"Themes-rendering","level":2},{"type":"heading","text":"Orange","anchor":"Orange","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_Orange","type":"image"}]},{"type":"heading","text":"Orange Business Tools","anchor":"Orange-Business-Tools","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_OrangeBusinessTools","type":"image"}]},{"type":"heading","text":"Sosh","anchor":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_switchItem_Sosh","type":"image"}]},{"type":"heading","text":"Wireframe","anchor":"Wireframe","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_switchItem_Wireframe"}]},{"type":"aside","name":"Version","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}]}]},{"type":"aside","name":"Since","style":"note","content":[{"inlineContent":[{"text":"0.14.0","type":"text"}],"type":"paragraph"}]}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/oudscomponents\/oudsswitchitem"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","metadata":{"navigatorTitle":[{"text":"OUDSSwitchItem","kind":"identifier"}],"modules":[{"name":"Components"}],"title":"OUDSSwitchItem","externalID":"s:14OUDSComponents14OUDSSwitchItemV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSwitchItem","kind":"identifier"}],"roleHeading":"Structure","role":"symbol","symbolKind":"struct"},"relationshipsSections":[{"kind":"r