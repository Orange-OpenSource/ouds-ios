{"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:label:additionalLabel:helper:icon:flipIcon:isOutlined:isReversed:isError:isReadOnly:hasDivider:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:tag:label:additionalLabel:helper:icon:flipIcon:isOutlined:isReversed:isError:isReadOnly:hasDivider:action:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/body"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" proposes layouts to add in your views some radios components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a radio with only an indicator, prefer instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio"},{"type":"text","text":"."}],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"metadata":{"roleHeading":"Structure","modules":[{"name":"OUDSComponents"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSRadioItem"}],"role":"symbol","title":"OUDSRadioItem","externalID":"s:14OUDSComponents13OUDSRadioItemV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioItem"}],"symbolKind":"struct"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioItem"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Tag"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Tag"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:SH","text":"Hashable"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Layouts","level":2,"anchor":"Layouts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"reversed","type":"text"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":" layout but with a trailing radio indicator and a leading optional decorative icon"}]}]}]},{"type":"heading","text":"Indicator states","level":2,"anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"text":"The radio indicator has two available states:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the radio is filled with a filled circle, the user has made the action to select the radio"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the radio is empty, does not contain anything, the user has made the action to unselect or did not select yet the radio","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Generic typed","level":2,"anchor":"Generic-typed"},{"type":"paragraph","inlineContent":[{"text":"The radio button can be associated to a specifc type for its ","type":"text"},{"inlineContent":[{"type":"text","text":"tag"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Indeed a radio button alone with this layout is not that much usefull, and should be associated to a ","type":"text"},{"inlineContent":[{"text":"tag","type":"text"}],"type":"emphasis"},{"text":" which will permit a ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"to provide the selected value for a group of radio buttons.","type":"text"}]},{"type":"heading","text":"Particular cases","level":2,"anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"},{"text":" ","type":"text"},{"text":"The radio can be also outlined in some cases.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}]},{"type":"heading","text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom radio trait."}]},{"type":"heading","text":"Forbidden by design","level":2,"anchor":"Forbidden-by-design"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"},{"text":" ","type":"text"},{"inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}],"type":"strong"}]},{"type":"heading","text":"Code samples","level":2,"anchor":"Code-samples"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"text":"can be used outside a dedicated picker, thus it does not need any tag and associated type.","type":"text"}]},{"type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A leading radio with a label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\")","","    \/\/ A leading radio with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\", isReadOnly: true)","","    \/\/ A leading radio with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\", helper: \"The Beatles\")","","    \/\/ A leading radio with an additional label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\", additionalLabel: \"The Beatles\", helper: \"1967\")","","    \/\/ A trailing radio with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The reversed layout will be used here.","    OUDSRadioItem(isOn: $selection,","                  label: \"Rescue from this world!\",","                  helper: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isReversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ A leading radio with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Rescue from this world!\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related radio as it will crash","    \/\/ This is forbidden by design!","    OUDSRadioItem(isOn: $selection, label: \"Kaboom!\", isError: true).disabled(true) \/\/ fatal error","    OUDSRadioItem(isOn: $selection, label: \"Kaboom!\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you want to manage the RTL mode quite easily and switch your layouts (flip image, indicator in RTL leading i.e. in the right):","type":"text"}]},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSRadioItem(isOn: $selection,","                  labelText: \"Cocorico !\",","                  icon: Image(systemName: \"figure.handball\"),","                  flipIcon: layoutDirection == .rightToLeft,","                  isInversed: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However if the "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"type":"text","text":" should be used inside a "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","type":"reference","isActive":true},{"type":"text","text":" for example, it must contain a tag and an associated type."},{"type":"text","text":" "},{"type":"text","text":"The tag will be the value returned by the picked, and must be an "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":"."}]},{"type":"codeListing","code":["    OUDSRadioItem<String>(isOn: $selection,","                          tag: \"Choice_1\",","                          label: \"Virgin Holy Lava\",","                          additionalLabel: \"Very spicy\",","                          helper: \"No alcohol, only tasty flavors\",","                          icon: Image(systemName: \"flame\")"],"syntax":"swift"},{"type":"heading","text":"Design documentation","level":2,"anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button","isActive":true}]},{"type":"aside","content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}],"name":"Since","style":"note"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsradioitem"]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadio":{"type":"topic","title":"OUDSRadio","url":"\/documentation\/oudscomponents\/oudsradio","abstract":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","isActive":true},{"text":" proposes layout to add in your views a lonely radio, without labels, texts nor icons radios components","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a radio with additional texts and icon, prefer instead ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"text":".","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadio","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","navigatorTitle":[{"text":"OUDSRadio","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem":{"navigatorTitle":[{"kind":"identifier","text":"OUDSRadioItem"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioItem"}],"url":"\/documentation\/oudscomponents\/oudsradioitem","role":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" proposes layouts to add in your views some radios components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a radio with only an indicator, prefer instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio"},{"type":"text","text":"."}],"title":"OUDSRadioItem","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem/View-Implementations":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","url":"\/documentation\/oudscomponents\/oudsradioitem\/view-implementations","kind":"article","title":"View Implementations","abstract":[],"type":"topic","role":"collectionGroup"},"doc://OUDSComponents/documentation/OUDSComponents":{"title":"OUDSComponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"role":"collection","type":"topic","url":"\/documentation\/oudscomponents","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","kind":"symbol"},"doc://OUDSComponents/s8SendableP":{"identifier":"doc:\/\/OUDSComponents\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"doc://OUDSComponents/7SwiftUI4ViewP":{"identifier":