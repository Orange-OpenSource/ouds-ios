io","abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","type":"reference"},{"text":" proposes layout to add in your views a lonely radio, without labels, texts nor icons radios components","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a radio with additional texts and icon, prefer instead ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference"},{"text":".","type":"text"}],"navigatorTitle":[{"text":"OUDSRadio","kind":"identifier"}],"title":"OUDSRadio","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSRadio","kind":"identifier"}],"kind":"symbol","role":"symbol"},"doc://OUDSComponents/s8SendableP":{"identifier":"doc:\/\/OUDSComponents\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"doc://OUDSComponents/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","type":"unresolvable","title":"Swift.SendableMetatype"},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"kind":"article","abstract":[{"text":"Some components can be used for ","type":"text"},{"type":"strong","inlineContent":[{"text":"controls","type":"text"}]},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"inputs"}]},{"text":".","type":"text"}],"url":"\/documentation\/oudscomponents\/controls","type":"topic","role":"article","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"title":"Controls","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem/init(isOn:label:additionalLabel:helper:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:action:)":{"kind":"symbol","type":"topic","title":"init(isOn:label:additiona