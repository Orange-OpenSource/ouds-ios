s a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen value through this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","title":"OUDSRadioPicker","navigatorTitle":[{"kind":"identifier","text":"OUDSRadioPicker"}],"role":"symbol","type":"topic","url":"\/documentation\/oudscomponents\/oudsradiopicker"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem/View-Implementations":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","url":"\/documentation\/oudscomponents\/oudsradioitem\/view-implementations","kind":"article","type":"topic","role":"collectionGroup","title":"View Implementations","abstract":[]},"https://unified-design-system.orange.com/472794e18/p/90c467-radio-button":{"title":"unified-design-system.orange.com","titleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}],"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button","url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button","type":"link"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem/body":{"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/body","abstract":[],"title":"body","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"body"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentif