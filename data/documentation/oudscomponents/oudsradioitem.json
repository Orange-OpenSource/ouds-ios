{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsradioitem"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","kind":"relationships"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"roleHeading":"Structure","title":"OUDSRadioItem","externalID":"s:14OUDSComponents13OUDSRadioItemV","symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"OUDSRadioItem"}],"role":"symbol","modules":[{"name":"Components"}],"platforms":[{"introducedAt":"15.0","unavailable":false,"deprecated":false,"beta":false,"name":"iOS"},{"beta":false,"name":"macOS","introducedAt":"13.0","unavailable":false,"deprecated":false},{"beta":false,"name":"tvOS","introducedAt":"16.0","unavailable":false,"deprecated":false},{"beta":false,"name":"visionOS","introducedAt":"1.0","unavailable":false,"deprecated":false},{"beta":false,"name":"watchOS","introducedAt":"11.0","unavailable":false,"deprecated":false}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSRadioItem","kind":"identifier"}]},"abstract":[{"text":"Radio button item is a UI element that allows to select a single option from a set of mutually exclusive choices.","type":"text"},{"type":"text","text":" "},{"text":"Radio button item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"}]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"text":"Layouts","level":2,"anchor":"Layouts","type":"heading"},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":": the component has a leading indicator, a label and optional texts, and an optional trailing decorative icon"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"reversed"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing radio indicator and a leading optional decorative icon"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"anchor":"Indicator-states","type":"heading","text":"Indicator states"},{"inlineContent":[{"type":"text","text":"The radio indicator has two available states:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the radio is filled with a filled circle, the user has made the action to select the radio"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"unselected"}]},{"type":"text","text":": the radio is empty, does not contain anything, the user has made the action to unselect or did not select yet the radio"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","anchor":"Particular-cases","text":"Particular cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."},{"type":"text","text":" "},{"type":"text","text":"The radio can be also outlined in some cases."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}]},{"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and optional texts and a custom radio trait."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands."}]},{"text":"Forbidden by design","type":"heading","anchor":"Forbidden-by-design","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"text":"Code samples","type":"heading","anchor":"Code-samples","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"type":"text","text":"can be used outside a dedicated picker, thus it does not need any tag and associated type."}]},{"code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A leading radio with a label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection)","","    \/\/ Localizable from bundle can also be used","    OUDSRadioItem(LocalizedStringKey(\"option_label\"), bundle: Bundle.module, isOn: $selection)","","    \/\/ A leading radio with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, isReadOnly: true)","","    \/\/ A leading radio with a label, and an additional label but without text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, extraLabel: \"The Beatles\")","","    \/\/ A leading radio with an additional label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, extraLabel: \"The Beatles\", description: \"1967\")","","    \/\/ A trailing radio with a label, a description, an icon, a divider and is about an error.","    \/\/ The reversed layout will be used here.","    OUDSRadioItem(\"Rescue from this world!\",","                  isOn: $selection,","                  description: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isReversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSRadioItem(\"Rescue from this world!\",","                  isOn: $selection,","                  isError: true,","                  errorText: \"Something wrong\",","                  hasDivider: true)","","    \/\/ A leading radio with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Rescue from this world!\", isOn: $selection)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related radio as it will crash","    \/\/ This is forbidden by design!","    OUDSRadioItem(\"Kaboom!\", isOn: $selection, isError: true).disabled(true) \/\/ fatal error","    OUDSRadioItem(\"Kaboom!\", isOn: $selection, isReadOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}]},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSRadioItem(\"Cocorico !\",","                  isOn: $selection,","                  icon: Image(systemName: \"figure.handball\"),","                  flipIcon: layoutDirection == .rightToLeft,","                  isInversed: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"text":"Design documentation","anchor":"Design-documentation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-radio-button","type":"reference","isActive":true}]},{"text":"Themes rendering","anchor":"Themes-rendering","type":"heading","level":2},{"level":3,"type":"heading","anchor":"Orange","text":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radioItem_Orange"}]},{"text":"Orange Compact","anchor":"Orange-Compact","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radioItem_OrangeCompact"}]},{"level":3,"type":"heading","anchor":"Sosh","text":"Sosh"},{"inlineContent":[{"identifier":"component_radioItem_Sosh","type":"image"}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Wireframe","type":"image"}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}]}],"type":"aside","name":"Version"},{"name":"Since","type":"aside","style":"note","content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}]}]}],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(_:isOn:extraLabel:description:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(_:tableName:bundle:isOn:extraLabel:description:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"anchor":"Initializers","title":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/body"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations"],"title":"Default Implementations","generated":true}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"title":"Controls","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"type":"topic","role":"article","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls","url":"\/documentation\/oudscomponents\/controls","abstract":[{"type":"text","text":"Some components can be used for "},{"inlineContent":[{"text":"controls","type":"text"}],"type":"strong"},{"type":"text","text":" and "},{"inlineContent":[{"text":"inputs","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"kind":"article"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioPicker":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioPicker","abstract":[{"text":"A picker allowing to expose several radio buttons and choose only one within the others.","type":"text"},{"text":" ","type":"text"},{"text":"Each radio button contains a “tag”, i.e. a supposed to be unique value.","type":"text"},{"text":" ","type":"text"},{"text":"The picker will expose the choosen value through this “tag”.","ty