{"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioItem"}]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"anchor":"Layouts","level":2,"text":"Layouts","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"reversed"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"text":" layout but with a trailing radio indicator and a leading optional decorative icon","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Indicator-states","level":2,"text":"Indicator states","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The radio indicator has two available states:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"text":": the radio is filled with a filled circle, the user has made the action to select the radio","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the radio is empty, does not contain anything, the user has made the action to unselect or did not select yet the radio","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Particular-cases","level":2,"text":"Particular cases","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In addition, the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"},{"text":" ","type":"text"},{"text":"The radio can be also outlined in some cases.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"text":" ","type":"text"},{"text":"to have for example the indicator in trailing position for LTR mode and vice versa.","type":"text"},{"text":" ","type":"text"},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"text":" ","type":"text"},{"text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is.","type":"text"},{"text":" ","type":"text"},{"text":"It prevents the user do implement its own rules to flip or not image.","type":"text"}]},{"anchor":"Accessibility-considerations","level":2,"text":"Accessibility considerations","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom radio trait.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDSThemesContract side as this value remains in the users hands.","type":"text"}]},{"anchor":"Forbidden-by-design","level":2,"text":"Forbidden by design","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}]},{"anchor":"Code-samples","level":2,"text":"Code samples","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"text":"can be used outside a dedicated picker, thus it does not need any tag and associated type.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A leading radio with a label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\")","","    \/\/ A leading radio with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\", isReadOnly: true)","","    \/\/ A leading radio with a label, and an additional label but without text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\", additionalLabel: \"The Beatles\")","","    \/\/ A leading radio with an additional label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Lucy in the Sky with Diamonds\", additionalLabel: \"The Beatles\", helper: \"1967\")","","    \/\/ A trailing radio with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The reversed layout will be used here.","    OUDSRadioItem(isOn: $selection,","                  label: \"Rescue from this world!\",","                  helper: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isReversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSRadioItem(isOn: $selection,","                  label: \"Rescue from this world!\",","                  isError: true,","                  errorText: \"Something wrong\",","                  hasDivider: true)","","    \/\/ A leading radio with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, label: \"Rescue from this world!\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related radio as it will crash","    \/\/ This is forbidden by design!","    OUDSRadioItem(isOn: $selection, label: \"Kaboom!\", isError: true).disabled(true) \/\/ fatal error","    OUDSRadioItem(isOn: $selection, label: \"Kaboom!\", isReadyOnly: true).disabled(true) \/\/ fatal error"]},{"type":"paragraph","inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSRadioItem(isOn: $selection,","                  labelText: \"Cocorico !\",","                  icon: Image(systemName: \"figure.handball\"),","                  flipIcon: layoutDirection == .rightToLeft,","                  isInversed: layoutDirection == .rightToLeft)"]},{"anchor":"Design-documentation","level":2,"text":"Design documentation","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/90c467-radio-button","type":"reference","isActive":true}]},{"anchor":"Themes-rendering","level":2,"text":"Themes rendering","type":"heading"},{"anchor":"Orange","level":3,"text":"Orange","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Orange","type":"image"}]},{"anchor":"Orange-Business-Tools","level":3,"text":"Orange Business Tools","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_OrangeBusinessTools","type":"image"}]},{"anchor":"Sosh","level":3,"text":"Sosh","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Sosh","type":"image"}]},{"anchor":"Wireframe","level":3,"text":"Wireframe","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Wireframe","type":"image"}]},{"style":"note","name":"Version","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"1.3.0 (Figma component design version)","type":"text"}]}]},{"style":"note","name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.12.0","type":"text"}]}]}]}],"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","type":"reference","isActive":true},{"text":" proposes layouts to add in your views some radios components.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a radio with only an indicator, prefer instead ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","type":"reference","isActive":true},{"text":".","type":"text"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"}],"role":"symbol","modules":[{"name":"Components"}],"title":"OUDSRadioItem","platforms":[{"beta":false,"introducedAt":"15.0","deprecated":false,"unavailable":false,"name":"iOS"},{"beta":false,"introducedAt":"15.0","deprecated":false,"unavailable":false,"name":"macOS"},{"beta":false,"introducedAt":"16.0","deprecated":false,"unavailable":false,"name":"tvOS"},{"beta":false,"introducedAt":"1.0","deprecated":false,"unavailable":false,"name":"visionOS"},{"beta":false,"introducedAt":"11.0","deprecated":false,"unavailable":false,"name":"watchOS"}],"externalID":"s:14OUDSComponents13OUDSRadioItemV","navigatorTitle":[{"text":"OUDSRadioItem","kind":"identifier"}],"symbolKind":"struct"},"topicSections":[{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:label:additionalLabel:helper:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:action:)"],"anchor":"Initializers","title":"