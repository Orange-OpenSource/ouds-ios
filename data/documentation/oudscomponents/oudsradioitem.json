{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"text":"Radio button item is a UI element that allows to select a single option from a set of mutually exclusive choices.","type":"text"},{"text":" ","type":"text"},{"text":"Radio button item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets.","type":"text"}],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships"}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioItem"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"text":"Layouts","level":2,"anchor":"Layouts","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"text":": the component has a leading indicator, a label and optional texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"reversed","type":"text"}]},{"text":": like the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"text":" layout but with a trailing radio indicator and a leading optional decorative icon","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Indicator states","level":2,"anchor":"Indicator-states","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The radio indicator has two available states:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"text":": the radio is filled with a filled circle, the user has made the action to select the radio","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"text":": the radio is empty, does not contain anything, the user has made the action to unselect or did not select yet the radio","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Particular cases","level":2,"anchor":"Particular-cases","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, the "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."},{"type":"text","text":" "},{"type":"text","text":"The radio can be also outlined in some cases."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}]},{"text":"Accessibility considerations","level":2,"anchor":"Accessibility-considerations","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and optional texts and a custom radio trait."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands."}]},{"text":"Forbidden by design","level":2,"anchor":"Forbidden-by-design","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}]},{"text":"Code samples","level":2,"anchor":"Code-samples","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"type":"text","text":"can be used outside a dedicated picker, thus it does not need any tag and associated type."}]},{"code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A leading radio with a label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection)","","    \/\/ Localizable from bundle can also be used","    OUDSRadioItem(LocalizedStringKey(\"option_label\"), bundle: Bundle.module, isOn: $selection)","","    \/\/ A leading radio with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, isReadOnly: true)","","    \/\/ A leading radio with a label, and an additional label but without text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, extraLabel: \"The Beatles\")","","    \/\/ A leading radio with an additional label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, extraLabel: \"The Beatles\", description: \"1967\")","","    \/\/ A trailing radio with a label, a description, an icon, a divider and is about an error.","    \/\/ The reversed layout will be used here.","    OUDSRadioItem(\"Rescue from this world!\",","                  isOn: $selection,","                  description: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isReversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSRadioItem(\"Rescue from this world!\",","                  isOn: $selection,","                  isError: true,","                  errorText: \"Something wrong\",","                  hasDivider: true)","","    \/\/ A leading radio with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Rescue from this world!\", isOn: $selection)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related radio as it will crash","    \/\/ This is forbidden by design!","    OUDSRadioItem(\"Kaboom!\", isOn: $selection, isError: true).disabled(true) \/\/ fatal error","    OUDSRadioItem(\"Kaboom!\", isOn: $selection, isReadOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSRadioItem(\"Cocorico !\",","                  isOn: $selection,","                  icon: Image(systemName: \"figure.handball\"),","                  flipIcon: layoutDirection == .rightToLeft,","                  isInversed: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"text":"Design documentation","level":2,"anchor":"Design-documentation","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-radio-button","isActive":true,"type":"reference"}]},{"text":"Themes rendering","level":2,"anchor":"Themes-rendering","type":"heading"},{"text":"Orange","level":3,"anchor":"Orange","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Orange","type":"image"}]},{"text":"Orange Compact","level":3,"anchor":"Orange-Compact","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_OrangeCompact","type":"image"}]},{"text":"Sosh","level":3,"anchor":"Sosh","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Sosh","type":"image"}]},{"text":"Wireframe","level":3,"anchor":"Wireframe","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Wireframe","type":"image"}]},{"name":"Version","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}]}],"style":"note"},{"name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"0.12.0","type":"text"}]}],"style":"note"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsradioitem"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"}],"role":"symbol","roleHeading":"Structure","externalID":"s:14OUDSComponents13OUDSRadioItemV","symbolKind":"struct","title":"OUDSRadioItem","navigatorTitle":[{"text":"OUDSRadioItem","kind":"identifier"}],"platforms":[{"name":"iOS","unavailable":false,"introducedAt":"15.0","beta":false,"deprecated":false},{"name":"macOS","unavailable":false,"introducedAt":"13.0","beta":false,"deprecated":false},{"name":"tvOS","unavailable":false,"introducedAt":"16.0","beta":false,"deprecated":false},{"name":"visionOS","unavailable":false,"introducedAt":"1.0","beta":false,"deprecated":false},{"name":"watchOS","unavailable":false,"introducedAt":"11.0","beta":false,"deprecated":false}]},"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(_:isOn:extraLabel:descrip