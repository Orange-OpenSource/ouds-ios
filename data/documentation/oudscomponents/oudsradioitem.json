{"sections":[],"abstract":[{"type":"text","text":"Radio button item is a UI element that allows to select a single option from a set of mutually exclusive choices."},{"text":" ","type":"text"},{"type":"text","text":"Radio button item covers a wider range of contexts by allowing to toggle the visibility of additional text labels and icon assets."}],"metadata":{"symbolKind":"struct","title":"OUDSRadioItem","role":"symbol","modules":[{"name":"Components"}],"navigatorTitle":[{"text":"OUDSRadioItem","kind":"identifier"}],"externalID":"s:14OUDSComponents13OUDSRadioItemV","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSRadioItem","kind":"identifier"}],"roleHeading":"Structure","platforms":[{"name":"iOS","introducedAt":"15.0","beta":false,"deprecated":false,"unavailable":false},{"unavailable":false,"introducedAt":"13.0","beta":false,"deprecated":false,"name":"macOS"},{"name":"tvOS","introducedAt":"16.0","beta":false,"deprecated":false,"unavailable":false},{"unavailable":false,"introducedAt":"1.0","beta":false,"deprecated":false,"name":"visionOS"},{"name":"watchOS","introducedAt":"11.0","beta":false,"deprecated":false,"unavailable":false}]},"kind":"symbol","relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(_:isOn:extraLabel:description:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(_:tableName:bundle:isOn:extraLabel:description:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:label:extraLabel:description:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"]},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/body"],"generated":true},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSRadioItem"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Layouts","text":"Layouts"},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"text":": the component has a leading indicator, a label and optional texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"reversed"}]},{"text":": like the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"text":" layout but with a trailing radio indicator and a leading optional decorative icon","type":"text"}]}]}],"type":"unorderedList"},{"text":"Indicator states","type":"heading","anchor":"Indicator-states","level":2},{"type":"paragraph","inlineContent":[{"text":"The radio indicator has two available states:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"selected","type":"text"}],"type":"strong"},{"type":"text","text":": the radio is filled with a filled circle, the user has made the action to select the radio"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"unselected","type":"text"}],"type":"strong"},{"text":": the radio is empty, does not contain anything, the user has made the action to unselect or did not select yet the radio","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Particular-cases","text":"Particular cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."},{"type":"text","text":" "},{"type":"text","text":"The radio can be also outlined in some cases."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"type":"text","text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed."},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}]},{"type":"heading","anchor":"Accessibility-considerations","text":"Accessibility considerations","level":2},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and optional texts and a custom radio trait."},{"type":"text","text":" "},{"type":"text","text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands."}]},{"type":"heading","anchor":"Forbidden-by-design","text":"Forbidden by design","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"type":"heading","level":2,"anchor":"Code-samples","text":"Code samples"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":"can be used outside a dedicated picker, thus it does not need any tag and associated type."}]},{"syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A leading radio with a label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection)","","    \/\/ Localizable from bundle can also be used","    OUDSRadioItem(LocalizedStringKey(\"option_label\"), bundle: Bundle.module, isOn: $selection)","","    \/\/ A leading radio with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, isReadOnly: true)","","    \/\/ A leading radio with a label, and an additional label but without text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, extraLabel: \"The Beatles\")","","    \/\/ A leading radio with an additional label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, extraLabel: \"The Beatles\", description: \"1967\")","","    \/\/ A trailing radio with a label, a description, an icon, a divider and is about an error.","    \/\/ The reversed layout will be used here.","    OUDSRadioItem(\"Rescue from this world!\",","                  isOn: $selection,","                  description: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isReversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSRadioItem(\"Rescue from this world!\",","                  isOn: $selection,","                  isError: true,","                  errorText: \"Something wrong\",","                  hasDivider: true)","","    \/\/ A leading radio with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Rescue from this world!\", isOn: $selection)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related radio as it will crash","    \/\/ This is forbidden by design!","    OUDSRadioItem(\"Kaboom!\", isOn: $selection, isError: true).disabled(true) \/\/ fatal error","    OUDSRadioItem(\"Kaboom!\", isOn: $selection, isReadOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSRadioItem(\"Cocorico !\",","                  isOn: $selection,","                  icon: Image(systemName: \"figure.handball\"),","                  flipIcon: layoutDirection == .rightToLeft,","                  isInversed: layoutDirection == .rightToLeft)"]},{"type":"heading","anchor":"Design-documentation","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-radio-button","type":"reference"}]},{"anchor":"Themes-rendering","type":"heading","level":2,"text":"Themes rendering"},{"anchor":"Orange","type":"heading","level":3,"text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Orange","type":"image"}]},{"anchor":"Orange-Compact","type":"heading","level":3,"text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_OrangeCompact","type":"image"}]},{"anchor":"Sosh","type":"heading","level":3,"text":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radioItem_Sosh"}]},{"anchor":"Wireframe","type":"heading","level":3,"text":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_radioItem_Wireframe"}]},{"name":"Version","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.4.0 (Figma component design version)"}]}],"style":"note"},{"name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}],"style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsradioitem"]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSRadioItem/init(isOn:label:extraLabel:description:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)":{"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"isOn","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Binding","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI7BindingV"},{"text":"<","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":">, ","kind":"text"},{"text":"label","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"extraLabel","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"?, ","kind":"text"},{"text":"description","kind":"externalPara