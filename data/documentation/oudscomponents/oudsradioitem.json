{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(_:isOn:extraLabel:description:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:label:extraLabel:description:icon:flipIcon:isOutlined:isReversed:isError:errorText:isReadOnly:hasDivider:constrainedMaxWidth:action:)"],"title":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/body"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"Layouts","level":2,"text":"Layouts","type":"heading"},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"type":"text","text":": the component has a leading indicator, a label and optional texts, and an optional trailing decorative icon"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"reversed","type":"text"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"text":" layout but with a trailing radio indicator and a leading optional decorative icon","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","anchor":"Indicator-states","level":2,"text":"Indicator states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The radio indicator has two available states:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the radio is filled with a filled circle, the user has made the action to select the radio"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"unselected"}]},{"text":": the radio is empty, does not contain anything, the user has made the action to unselect or did not select yet the radio","type":"text"}]}]}]},{"level":2,"type":"heading","anchor":"Particular-cases","text":"Particular cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In that case if the component displayed an icon, this icon will be replaced automatically by an error icon.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In addition, the ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true,"type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as disabled."},{"type":"text","text":" "},{"type":"text","text":"The radio can be also outlined in some cases."}]},{"type":"paragraph","inlineContent":[{"text":"The component does not follow the right-to-left (RTL) \/ left-to-right (LTR) mode returned by the system as it could have some meaning","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to have for example the indicator in trailing position for LTR mode and vice versa."},{"type":"text","text":" "},{"text":"However, if the component has an icon in leading position (RTL mode) or in trailing position (LTR), the content of the icon is never changed.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It could lead to a loss of meaning or semantics in the icon. Thus a specific flag can be used to flip the icon content whatever the layout direction is."},{"type":"text","text":" "},{"type":"text","text":"It prevents the user do implement its own rules to flip or not image."}]},{"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and optional texts and a custom radio trait.","type":"text"},{"text":" ","type":"text"},{"text":"No accessibility identifier is defined in OUDS side as this value remains in the users hands.","type":"text"}]},{"type":"heading","text":"Forbidden by design","anchor":"Forbidden-by-design","level":2},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}],"type":"paragraph"},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"text":"can be used outside a dedicated picker, thus it does not need any tag and associated type.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A leading radio with a label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection)","","    \/\/ A leading radio with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, isReadOnly: true)","","    \/\/ A leading radio with a label, and an additional label but without text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, extraLabel: \"The Beatles\")","","    \/\/ A leading radio with an additional label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Lucy in the Sky with Diamonds\", isOn: $selection, extraLabel: \"The Beatles\", description: \"1967\")","","    \/\/ A trailing radio with a label, a description, an icon, a divider and is about an error.","    \/\/ The reversed layout will be used here.","    OUDSRadioItem(\"Rescue from this world!\",","                  isOn: $selection,","                  description: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isReversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ If on error, add an error message can help user to understand error context","    OUDSRadioItem(\"Rescue from this world!\",","                  isOn: $selection,","                  isError: true,","                  errorText: \"Something wrong\",","                  hasDivider: true)","","    \/\/ A leading radio with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSRadioItem(\"Rescue from this world!\", isOn: $selection)","        .disabled(true)","","    \/\/ Never disable a read only or an error-related radio as it will crash","    \/\/ This is forbidden by design!","    OUDSRadioItem(\"Kaboom!\", isOn: $selection, isError: true).disabled(true) \/\/ fatal error","    OUDSRadioItem(\"Kaboom!\", isOn: $selection, isReadOnly: true).disabled(true) \/\/ fatal error"]},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSRadioItem(\"Cocorico !\",","                  isOn: $selection,","                  icon: Image(systemName: \"figure.handball\"),","                  flipIcon: layoutDirection == .rightToLeft,","                  isInversed: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"type":"heading","anchor":"Design-documentation","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-radio-button"}]},{"level":2,"anchor":"Themes-rendering","type":"heading","text":"Themes rendering"},{"level":3,"anchor":"Orange","type":"heading","text":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_radioItem_Orange"}],"type":"paragraph"},{"anchor":"Orange-Compact","type":"heading","text":"Orange Compact","level":3},{"inlineContent":[{"type":"image","identifier":"component_radioItem_OrangeCompact"}],"type":"paragraph"},{"level":3,"anchor":"Sosh","text":"Sosh","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Sosh","type":"image"}]},{"level":3,"anchor":"Wireframe","type":"heading","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_radioItem_Wireframe","type":"image"}]},{"name":"Version","type":"aside","style":"note","content":[{"inlineContent":[{"text":"1.4.0 (Figma component design version)","type":"text"}],"type":"paragraph"}]},{"name":"Since","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}],"type":"aside"}]}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsradioitem"]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"}],"roleHeading":"Structure","role":"symbol","externalID":"s:14OUDSComponents13OUDSRadioItemV","navigatorTitle":[{"kind":"identifier","text":"OUDSRadioItem"}],"title":"OUDSRadioItem","symbolKind":"struct","modules":[{"name":"Components"}],"platforms":[{"name":"iOS","introducedAt":"15.0","deprecated":false,"unavailable":false,"beta":false},{"deprecated":false,"introducedAt":"13.0"