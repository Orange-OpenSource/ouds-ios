hancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","role":"collection","type":"topic","kind":"symbol"},"ic_folder_categories.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"alt":null,"identifier":"ic_folder_categories.png","type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/labelModerateLarge(_:)":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Modifies the current "},{"type":"codeVoice","code":"View"},{"type":"text","text":" to apply a "},{"type":"emphasis","inlineContent":[{"text":"label moderate large","type":"text"}]},{"type":"text","text":" typography."},{"type":"text","text":" "},{"type":"text","text":"The current "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" must be given in parameter because "},{"type":"codeVoice","code":"@Environment"},{"type