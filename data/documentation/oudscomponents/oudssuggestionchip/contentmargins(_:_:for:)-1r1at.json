nput or context,","type":"text"},{"text":" ","type":"text"},{"text":"and is commonly used to capture filtering decisions.","type":"text"},{"text":" ","type":"text"},{"text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}],"role":"symbol","url":"\/documentation\/oudscomponents\/oudssuggestionchip","navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSuggestionChip","kind":"identifier"}]}}}