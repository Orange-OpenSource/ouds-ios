":"A "},{"inlineContent":[{"text":"suggestion chip","type":"text"}],"type":"emphasis"},{"type":"text","text":" is a compact UI element used to present recommended or predictive options based on user input or context."},{"type":"text","text":" "},{"type":"text","text":"This version of the "},{"inlineContent":[{"type":"text","text":"suggestion chip"}],"type":"emphasis"},{"type":"text","text":" uses the "},{"inlineContent":[{"type":"text","text":"text only"}],"type":"emphasis"},{"type":"text","text":" layout which displays only text, offering a clean and minimalistic look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."},{"type":"text","text":" "},{"type":"text","text":"Other layouts are available for this component like: "},{"inlineContent":[{"text":"text + icon","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"icon only"}],"type":"emphasis"},{"type":"text","text":"."}],"kind":"symbol","type":"topic","role":"symbol","title":"OUDSSuggestionChip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"type":"image"},"doc://OUDSComponents/documentation/OUDSComponents":{"role":"collection","url":"\/documentation\/oudscomponents","images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"kind":"symbol","title":"Components","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"code":"View","type":"codeVoice"},