ry-based filters that do not require additional visual elements."}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}]}}}