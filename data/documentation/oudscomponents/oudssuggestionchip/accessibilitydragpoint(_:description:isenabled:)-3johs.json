tifier"}],"type":"topic","abstract":[{"text":"Chips help people enter information, make selections, filter content, or trigger actions.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"A ","type":"text"},{"inlineContent":[{"type":"text","text":"suggestion chip"}],"type":"emphasis"},{"text":" is a compact UI element used to present recommended or predictive options based on user input or context.","type":"text"},{"text":" ","type":"text"},{"text":"This version of the ","type":"text"},{"inlineContent":[{"type":"text","text":"suggestion chip"}],"type":"emphasis"},{"text":" uses the ","type":"text"},{"inlineContent":[{"type":"text","text":"text only"}],"type":"emphasis"},{"text":" layout which displays only text, offering a clean and minimalistic look.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"},{"text":" ","type":"text"},{"text":"Other layouts are available for this component like: ","type":"text"},{"inlineContent":[{"type":"text","text":"text + icon"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"icon only"}],"type":"emphasis"},{"text":".","type":"text"}],"role":"symbol","title":"OUDSSuggestionChip"},"doc://OUDSComponents/documentation/OUDSComponents":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"url":"\/documentation\/oudscomponents","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and high