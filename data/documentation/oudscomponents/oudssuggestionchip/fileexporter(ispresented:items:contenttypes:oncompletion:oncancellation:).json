xt":"Other layouts are available for this component like: "},{"type":"emphasis","inlineContent":[{"text":"text + icon","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"icon only","type":"text"}]},{"type":"text","text":"."}],"type":"topic"},"ic_folder_categories.png":{"type":"image","identifier":"ic_folder_categories.png","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","title":"Components","kind":"symbol","role":"collection","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"type":"topic","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"}}}