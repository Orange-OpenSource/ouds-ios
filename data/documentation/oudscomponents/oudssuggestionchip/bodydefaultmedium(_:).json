":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"kind":"symbol","title":"OUDSSuggestionChip","abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","role":"collection","type":"topic","kind":"symbol"},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","identifier":"ic_folder_categories.png","alt":null},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/bodyDefaultMedium(_:)":{"title":"bodyDefaultMedium(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"bodyDefaultMedium","kind":"identifier"},{"text":"(","kind":"text"},{"text":"OUDSTheme","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract9OUDSThemeC"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"abstract":[{"text":"Modifies the current ","type":"text"