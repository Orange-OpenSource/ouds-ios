\/oudscomponents\/oudssuggestionchip\/fileexporter(ispresented:documents:contenttypes:oncompletion:oncancellation:)-qfxx","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","role":"collection","type":"topic","kind":"symbol"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","type":"image","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"kind":"symbol","title":"OUDSSuggestionChip","abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol"}}}