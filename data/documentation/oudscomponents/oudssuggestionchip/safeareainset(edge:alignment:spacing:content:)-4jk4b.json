ocumentation/OUDSComponents/OUDSSuggestionChip":{"role":"symbol","url":"\/documentation\/oudscomponents\/oudssuggestionchip","abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"type":"topic","title":"OUDSSuggestionChip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip"},"doc://OUDSComponents/documentation/OUDSComponents":{"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol","url":"\/documentation\/oudscomponents","type":"topic","role":"collection","title":"Components","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"ic_folder_categories.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\