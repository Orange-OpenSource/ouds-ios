hip\/accessibilityidentifier(_:)"},"doc://OUDSComponents/documentation/OUDSComponents":{"type":"topic","url":"\/documentation\/oudscomponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","role":"collection","images":[{"identifier":"ic_folder_categories.png","type":"icon"}]},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"title":"OUDSSuggestionChip","role":"symbol","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"url":"\/documentation\/oudscomponents\/ouds