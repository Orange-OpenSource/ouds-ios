umentation\/oudscomponents\/oudssuggestionchip\/accessibilityinputlabels(_:)-21ouq","title":"accessibilityInputLabels(_:)"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"type":"topic","abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","kind":"symbol","title":"OUDSSuggestionChip","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"type":"topic","url":"\/documentation\/oudscomponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"title":"Components","kind":"symbol","role":"collection","identifier":"doc:\/\/OUDSCompo