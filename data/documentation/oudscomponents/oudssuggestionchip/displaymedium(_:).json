d be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" is not a ","type":"text"},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","title":"OUDSTheme"},"ic_folder_categories.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"identifier":"ic_folder_categories.png","alt":null,"type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSuggestionChip","kind":"identifier"}],"abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"text":" ","type":"text"},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"text":" ","type":"text"},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"text":" ","type":"text"},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol","title":"OUDSSuggestionChip"}}}