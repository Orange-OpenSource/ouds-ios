ts\/documentation\/OUDSComponents\/OUDSSuggestionChip\/headingLarge(_:)","kind":"symbol","role":"symbol","type":"topic","title":"headingLarge(_:)","url":"\/documentation\/oudscomponents\/oudssuggestionchip\/headinglarge(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"headingLarge","kind":"identifier"},{"text":"(","kind":"text"},{"text":"OUDSTheme","preciseIdentifier":"s:18OUDSThemesContract9OUDSThemeC","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSSuggestionChip"}],"abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"text":" ","type":"text"},{"text":"and is commonly used to capture filtering decisions.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"text":" ","type":"text"},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","type":"topic","title":"OUDSSuggestionChip"},"doc://OUDSComponents/documentation/OUDSComponents":{"title":