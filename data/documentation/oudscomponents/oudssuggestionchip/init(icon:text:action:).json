,"type":"image"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","abstract":[{"text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,","type":"text"},{"text":" ","type":"text"},{"text":"and is commonly used to capture filtering decisions.","type":"text"},{"text":" ","type":"text"},{"text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}],"type":"topic","url":"\/documentation\/oudscomponents\/oudssuggestionchip","kind":"symbol","title":"OUDSSuggestionChip","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSuggestionChip","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/init(icon:text:action:)":{"title":"init(icon:text:action:)","type":"topic","role":"symbol","url":"\/documentation\/oudscomponents\/oudssuggestionchip\/init(icon:text:action:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/init(icon:text:action:)","abstract":[{"type":"text","text":"Creates a chip with text and icon."}],"kind":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"icon","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI5ImageV","text":"Image","kind":"typeIdentifier"},{"text":", ",