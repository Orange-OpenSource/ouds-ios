igatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"type":"topic","abstract":[{"type":"text","text":"Chips help people enter information, make selections, filter content, or trigger actions."},{"type":"text","text":" "},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"suggestion chip"}]},{"text":" is a compact UI element used to present recommended or predictive options based on user input or context.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This version of the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"suggestion chip"}]},{"type":"text","text":" uses the "},{"inlineContent":[{"type":"text","text":"text only"}],"type":"emphasis"},{"type":"text","text":" layout which displays only text, offering a clean and minimalistic look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."},{"type":"text","text":" "},{"type":"text","text":"Other layouts are available for this component like: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"text + icon"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"icon only"}]},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"role":"symbol","kind":"symbol"}}}