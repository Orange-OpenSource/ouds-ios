ionchip","title":"OUDSSuggestionChip","abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"role":"symbol","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/toolbarBackground(_:for:)-7dgqc":{"title":"toolbarBackground(_:for:)","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/toolbarBackground(_:for:)-7dgqc","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"toolbarBackground"},{"kind":"text","text":"("},{"preciseIdentifier":"s:7SwiftUI10VisibilityO","kind":"typeIdentifier","text":"Visibility"},{"kind":"text","text":", "},{"text":"for","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ToolbarPlacement","preciseIdentifier":"s:7SwiftUI16ToolbarPlacementV","kind":"typeIdentifier"},{"text":"...) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"deprecated":true,"abstract":[],"url":"\/documentation\/oudscomponents\/oudssuggestionchip\/toolbarbackground(_:for:)-7dgqc","type":"topic","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"abstract":[{"type":"text