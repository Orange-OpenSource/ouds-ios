ent recommended or predictive options based on user input or context.","type":"text"},{"text":" ","type":"text"},{"text":"This version of the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"suggestion chip"}]},{"text":" uses the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"text only"}]},{"text":" layout which displays only text, offering a clean and minimalistic look.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"},{"text":" ","type":"text"},{"text":"Other layouts are available for this component like: ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"text + icon"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"icon only"}]},{"text":".","type":"text"}],"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip"}}}