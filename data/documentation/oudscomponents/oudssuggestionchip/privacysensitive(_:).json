\/oudssuggestionchip\/privacysensitive(_:)","title":"privacySensitive(_:)"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"type":"topic","abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","kind":"symbol","title":"OUDSSuggestionChip","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}]}}}