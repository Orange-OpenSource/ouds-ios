agments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/accessibilityActions(_:)":{"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/accessibilityActions(_:)","title":"accessibilityActions(_:)","url":"\/documentation\/oudscomponents\/oudssuggestionchip\/accessibilityactions(_:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"accessibilityActions"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Content"},{"kind":"text","text":">(() -> "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}],"abstract":[],"type":"topic"},"ic_folder_categories.png":{"alt":null,"identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"type":"image"}}}