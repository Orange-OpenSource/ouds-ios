on chip","type":"text"}]},{"type":"text","text":" is a compact UI element used to present recommended or predictive options based on user input or context."},{"type":"text","text":" "},{"type":"text","text":"This version of the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"suggestion chip"}]},{"text":" uses the ","type":"text"},{"inlineContent":[{"type":"text","text":"text only"}],"type":"emphasis"},{"text":" layout which displays only text, offering a clean and minimalistic look.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."},{"type":"text","text":" "},{"type":"text","text":"Other layouts are available for this component like: "},{"type":"emphasis","inlineContent":[{"text":"text + icon","type":"text"}]},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"icon only"}],"type":"emphasis"},{"type":"text","text":"."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSSuggestionChip"}],"kind":"symbol","type":"topic"},"ic_folder_categories.png":{"type":"image","alt":null,"identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}]},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"type":"topic","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"kind":"symbol","role":"symbol","title":"OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}]}}}