rties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"type":"text","text":"theme contract"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" is not a ","type":"text"},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"text":" class, its type cannot be seen as ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSuggestionChip","kind":"identifier"}],"kind":"symbol","title":"OUDSSuggestionChip","abstract":[{"text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,","type":"text"},{"text":" ","type":"text"},{"text":"and is commonly used to capture filtering decisions.","type":"text"},{"text":" ","type":"text"},{"text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}]},"ic_folder_categories.png":{"type":"image","identifier":"ic_folder_categories.png","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]}}}