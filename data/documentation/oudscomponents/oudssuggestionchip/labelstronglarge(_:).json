{"abstract":[{"type":"text","text":"Modifies the current "},{"code":"View","type":"codeVoice"},{"type":"text","text":" to apply a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"label strong large"}]},{"type":"text","text":" typography."},{"type":"text","text":" "},{"type":"text","text":"The current "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" must be given in parameter because "},{"code":"@Environment","type":"codeVoice"},{"type":"text","text":" property cannot be accessed through an extension or inside a method."}],"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"labelStrongLarge"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"theme"},{"kind":"text","text":": "},{"preciseIdentifier":"s:18OUDSThemesContract9OUDSThemeC","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","kind":"typeIdentifier","text":"OUDSTheme"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier","text":"View"},{"kind":"text","text":"\n"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" to use to load the current font family and the suitable font semantic token."}]}],"name":"theme"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The current "},{"code":"View","type":"codeVoice"},{"type":"text","text":"