:"text","text":"theme contract"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" is not a ","type":"text"},{"inlineContent":[{"type":"text","text":"final"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","title":"OUDSTheme"}}}