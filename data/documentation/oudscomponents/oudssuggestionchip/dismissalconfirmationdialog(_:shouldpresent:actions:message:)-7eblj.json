ailable for this component like: "},{"inlineContent":[{"text":"text + icon","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"icon only"}],"type":"emphasis"},{"type":"text","text":"."}],"kind":"symbol","type":"topic","role":"symbol","title":"OUDSSuggestionChip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip"}}}