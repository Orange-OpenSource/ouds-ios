 list of selectable movie times, or a serie of email contacts."},{"text":" ","type":"text"},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol","title":"OUDSSuggestionChip"},"doc://OUDSComponents/documentation/OUDSComponents":{"kind":"symbol","role":"collection","title":"Components","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","type":"topic","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"url":"\/documentation\/oudscomponents","images":[{"type":"icon","identifier":"ic_folder_categories.png"}]},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"alt":null,"type":"image"}}}