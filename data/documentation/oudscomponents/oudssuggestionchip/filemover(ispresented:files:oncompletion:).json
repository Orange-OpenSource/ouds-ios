ed filters that do not require additional visual elements."}],"navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol","title":"OUDSSuggestionChip"},"ic_folder_categories.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"type":"image","alt":null,"identifier":"ic_folder_categories.png"}}}