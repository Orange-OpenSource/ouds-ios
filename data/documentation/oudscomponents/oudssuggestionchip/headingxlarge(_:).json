":"text"},{"text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"title":"OUDSSuggestionChip"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","abstract":[{"type":"text","text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor."},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"code":"class","type":"codeVoice"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"type":"topic","url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"title":"OUDSTheme"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"role":"collection","images":[{"identifier":"ic_folder_categories.png","type":"icon"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/headingXLarge(_:)":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/headingXLarge(_:)","title":"headingXLarge(_:)","url":"\/documentation\/oudscomponents\/oudssuggestionchip\/headingxlarge(_:)","abstract":[{"type":"text","text":"Modifies the current "},{"type":"codeVoice","code":"View"},{"type":"text","text":" to apply a "},{"inlineContent":[{"text":"heading x large","type":"text"}],"type":"emphasis"},{"type":"text","text":" typography."},{"type":"text","te