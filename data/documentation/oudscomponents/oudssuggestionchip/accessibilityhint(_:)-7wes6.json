ements."}],"type":"topic","role":"symbol"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","type":"image","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]}}}