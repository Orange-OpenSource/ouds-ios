ip"}],"type":"emphasis"},{"text":" uses the ","type":"text"},{"inlineContent":[{"type":"text","text":"text only"}],"type":"emphasis"},{"text":" layout which displays only text, offering a clean and minimalistic look.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"},{"text":" ","type":"text"},{"text":"Other layouts are available for this component like: ","type":"text"},{"inlineContent":[{"type":"text","text":"text + icon"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"icon only"}],"type":"emphasis"},{"text":".","type":"text"}],"role":"symbol","title":"OUDSSuggestionChip"}}}