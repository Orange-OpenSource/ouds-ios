hancing usability.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"title":"OUDSSuggestionChip"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/labelModerateMedium(_:)":{"url":"\/documentation\/oudscomponents\/oudssuggestionchip\/labelmoderatemedium(_:)","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/labelModerateMedium(_:)","title":"labelModerateMedium(_:)","abstract":[{"type":"text","text":"Modifies the current "},{"type":"codeVoice","code":"View"},{"type":"text","text":" to apply a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"label moderate medium"}]},{"type":"text","text":" typography."},{"type":"text","text":" "},{"type":"text","text":"The current "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" must be given in parameter because "},{"type":"codeVoice","code":"@Environment"},{"text":" property cannot be accessed through an extension or inside a method.","type":"text"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelModerateMedium","kind":"identifier"},{"text":"(","kind":"text"},{"text":"OUDSTheme","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract9OUDSThemeC"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseId