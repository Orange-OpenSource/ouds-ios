ties of an overridable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"type":"text","text":"object oriented paradigm"}],"type":"emphasis"},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" is not a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"OUDSTheme","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","title":"OUDSSuggestionChip","navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"type":"topic","abstract":[{"type":"text","text":"Chips help people enter information, make selections, filter content, or trigger actions."},{"type":"text","text":" "},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"suggestion chip"}]},{"text":" is a compact UI element used to present recommended or predictive options based on user input or context.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This version of the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"suggestion chip"}]},{"type":"text","text":" uses the "},{"inlineContent":[{"type":"text","text":"text only"}],"type":"emphasis"},{"type":"text","text":" layout which displays only text, offering a clean and minimalistic look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."},{"type":"text","text":" "},{"type":"text","text":"Other layouts are available for this component like: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"text + icon"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"icon only"}]},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"role":"symbol","kind":"symbol"},"ic_folder_categories.png":{"alt":null,"type":"image","identifier":"ic_folder_categories.png","variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]}}}