{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"abstract":[{"type":"text","text":"Hides the native tab bar "},{"type":"strong","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" signals "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" to hide its overlay elements"},{"type":"text","text":" "},{"type":"text","text":"(selected tab indicator and top divider) in sync."}],"kind":"symbol","metadata":{"platforms":[{"name":"iOS","beta":false,"deprecated":false,"unavailable":false,"introducedAt":"16.0"}],"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"Components","relatedModules":["SwiftUICore"]}],"title":"hideTabBar()","extendedModule":"SwiftUICore","externalID":"s:7SwiftUI4ViewP14OUDSComponentsE10hideTabBarQryF::SYNTHESIZED::s:14OUDSComponents18OUDSSuggestionChipV","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hideTabBar"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hideTabBar"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"},{"kind":"text","text":"\n"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that hides the tab bar and propagates the hidden state to "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" overlay items."}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier instead of "},{"type":"codeVoice","code":".toolbar(.hidden, for: .tabBar)"},{"type":"text","text":" "},{"type":"text","text":"whenever a view inside a "},{"type":"codeVoice","code":"NavigationStack"},{"type":"text","text":" embedded in an "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" needs to hide"},{"type":"text","text":" "},{"type":"text","text":"the tab bar. Without this modifier, "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" cannot detect the visibility change"},{"type":"text","text":" "},{"type":"text","text":"and its overlay elements remain visible on top of the content. This helper must be used for"},{"type":"text","text":" "},{"type":"text","text":"apps with nested views and tab bars."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Otherwise for simple app "},{"type":"codeVoice","code":".toolbar(.hidden, for: .tabBar)"},{"type":"text","text":" is enough."}]},{"syntax":"swift","type":"codeListing","code":["struct DetailView: View {","    var body: some View {","        Text(\"Detail\")","            .hideTabBar()","    }","}"]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/hideTabBar()"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudssuggestionchip\/hidetabbar()"]}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/hideTabBar()":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hideTabBar"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}],"abstract":[{"type":"text","text":"Hides the native tab bar "},{"type":"strong","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" signals "},{"type":"codeVoice","code":"OUDSTabBar"},{"type":"text","text":" to hide its overlay elements"},{"type":"text","text":" "},{"type":"text","text":"(selected tab indicator and top divider) in sync."}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/hideTabBar()","title":"hideTabBar()","type":"topic","url":"\/documentation\/oudscomponents\/oudssuggestionchip\/hidetabbar()","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSuggestionChip","kind":"identifier"}],"kind":"symbol","title":"OUDSSuggestionChip","abstract":[{"text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,","type":"text"},{"text":" ","type":"text"},{"text":"and is commonly used to capture filtering decisions.","type":"text"},{"text":" ","type":"text"},{"text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"kind":"symbol","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"url":"\/documentation\/oudscomponents","type":"topic","title":"Components","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","role":"collection"},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image","identifier":"ic_folder_categories.png","alt":null}}}