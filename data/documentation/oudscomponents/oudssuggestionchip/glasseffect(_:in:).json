w","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"title":"glassEffect(_:in:)"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","abstract":[{"text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,","type":"text"},{"text":" ","type":"text"},{"text":"and is commonly used to capture filtering decisions.","type":"text"},{"text":" ","type":"text"},{"text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"title":"OUDSSuggestionChip"},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","type":"topic","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"role":"collection","images":[{"identifier":"ic_folder_categories.png","typ