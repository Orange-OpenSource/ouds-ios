ocumentation/OUDSComponents/OUDSSuggestionChip":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSuggestionChip","kind":"identifier"}],"abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"text":" ","type":"text"},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"text":" ","type":"text"},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"text":" ","type":"text"},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol","title":"OUDSSuggestionChip"},"doc://OUDSComponents/documentation/OUDSComponents":{"kind":"symbol","role":"collection","title":"Components","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","type":"topic","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"url":"\/documentation\/oudscomponents","images":[{"type":"icon","identifier":"ic_folder_categories.png"}]}}}