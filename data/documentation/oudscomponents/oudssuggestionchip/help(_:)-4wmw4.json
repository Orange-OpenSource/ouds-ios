":"text"},{"text":"and is commonly used to capture filtering decisions.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"text":" ","type":"text"},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","type":"topic","title":"OUDSSuggestionChip"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/help(_:)-4wmw4":{"kind":"symbol","url":"\/documentation\/oudscomponents\/oudssuggestionchip\/help(_:)-4wmw4","type":"topic","abstract":[],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"help","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"S"},{"text":">(","kind":"text"},{"kind":"typeIdentifier","text":"S"},{"text":") -> ","kind":"text"},{"kind":"keyword","text":"some"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/help(_:)-4wmw4","title":"help(_:)"}}}