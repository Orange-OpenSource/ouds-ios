,{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"role":"symbol","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents":{"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"role":"collection","type":"topic","title":"Components","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","kind":"symbol","url":"\/documentation\/oudscomponents"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/labelStrongSmall(_:)":{"abstract":[{"type":"text","text":"Modifies the current "},{"code":"View","type":"codeVoice"},{"type":"text","text":" to apply a "},{"type":"emphasis","inlineContent":[{"text":"label strong small","type":"text"}]},{"type":"text","text":" typography."},{"type":"text","text":" "},{"type":"text","text":"The current "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" must be given in parameter because "},{"code":"@Environment","type":"codeVoice"},{"type":"text","text":" property cannot be accessed through an extension or inside a method."}],"role":"symbol","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"te