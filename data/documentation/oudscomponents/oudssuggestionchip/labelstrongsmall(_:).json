xt","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}],"kind":"symbol"},"ic_folder_categories.png":{"alt":null,"type":"image","identifier":"ic_folder_categories.png","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/labelStrongSmall(_:)":{"type":"topic","url":"\/documentation\/oudscomponents\/oudssuggestionchip\/labelstrongsmall(_:)","title":"labelStrongSmall(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelStrongSmall","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:18OUDSThemesContract9OUDSThemeC","text":"OUDSTheme","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:7SwiftUI4ViewP","text":"View","kind":"typeIdentifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/labelStrongSmall(_:)","abstract":[{"text":"Modifies the current ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" to apply a ","type":"text"},{"inlineContent":[{"text":"label strong small","type":"text"}],"type":"emphasis"},{"text":" typography.","type":"text"},{"text":" ","type":"text"},{"text":"The current ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" must be given in parameter because ","type":"text"},{"code":"@Environment","type":"codeVoice"},{"text":" property cannot be accessed through an extension or inside a method.","type":"text"}],"kind":"symbol","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","url":"\/documentation\/oudscomponents","role":"collection","title":"Components","type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","title":"OUDSTheme","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true,"type":"reference"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"kind":"symbol"}}}