 properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"text":", or ","type":"text"},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"type":"topic","url":"\/documentation\/oudsthemescontract\/oudstheme","kind":"symbol","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","title":"OUDSTheme","role":"symbol","navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"kind":"symbol","url":"\/documentation\/oudscomponents\/oudssuggestionchip","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"role":"symbol","abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"title":"OUDSSuggestionChip","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip"},"ic_folder_categories.png":{"type":"image","identifier":"ic_folder_categories.png","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}]}}}