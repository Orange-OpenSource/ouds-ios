nents":{"kind":"symbol","images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"url":"\/documentation\/oudscomponents","type":"topic","title":"Components","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","role":"collection"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"url":"\/documentation\/oudscomponents\/oudssuggestionchip","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","navigatorTitle":[{"text":"OUDSSuggestionChip","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSSuggestionChip","kind":"identifier"}],"kind":"symbol","title":"OUDSSuggestionChip","abstract":[{"text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,","type":"text"},{"text":" ","type":"text"},{"text":"and is commonly used to capture filtering decisions.","type":"text"},{"text":" ","type":"text"},{"text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}]},"ic_folder_categories.png":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"identifier":"ic_folder_categories.png"}}}