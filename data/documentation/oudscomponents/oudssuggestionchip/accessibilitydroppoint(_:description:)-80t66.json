","text":"Chips help people enter information, make selections, filter content, or trigger actions."},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"A ","type":"text"},{"inlineContent":[{"text":"suggestion chip","type":"text"}],"type":"emphasis"},{"text":" is a compact UI element used to present recommended or predictive options based on user input or context.","type":"text"},{"text":" ","type":"text"},{"text":"This version of the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"suggestion chip","type":"text"}]},{"type":"text","text":" uses the "},{"type":"emphasis","inlineContent":[{"text":"text only","type":"text"}]},{"text":" layout which displays only text, offering a clean and minimalistic look.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."},{"type":"text","text":" "},{"type":"text","text":"Other layouts are available for this component like: "},{"type":"emphasis","inlineContent":[{"text":"text + icon","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"icon only","type":"text"}]},{"type":"text","text":"."}],"type":"topic"},"ic_folder_categories.png":{"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png","type":"image","alt":null}}}