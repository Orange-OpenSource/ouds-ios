phasis"},{"type":"text","text":" uses the "},{"type":"emphasis","inlineContent":[{"text":"text only","type":"text"}]},{"type":"text","text":" layout which displays only text, offering a clean and minimalistic look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."},{"type":"text","text":" "},{"type":"text","text":"Other layouts are available for this component like: "},{"type":"emphasis","inlineContent":[{"text":"text + icon","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"icon only","type":"text"}]},{"type":"text","text":"."}],"type":"topic","title":"OUDSSuggestionChip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip"}}}