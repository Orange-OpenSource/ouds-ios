kind":"text"},{"text":"OUDSSuggestionChip","kind":"identifier"}],"kind":"symbol","title":"OUDSSuggestionChip","abstract":[{"text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,","type":"text"},{"text":" ","type":"text"},{"text":"and is commonly used to capture filtering decisions.","type":"text"},{"text":" ","type":"text"},{"text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability.","type":"text"},{"text":" ","type":"text"},{"text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts.","type":"text"},{"text":" ","type":"text"},{"text":"Best suited for category-based filters that do not require additional visual elements.","type":"text"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/accessibilityValue(_:isEnabled:)-1b6kl":{"url":"\/documentation\/oudscomponents\/oudssuggestionchip\/accessibilityvalue(_:isenabled:)-1b6kl","role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/accessibilityValue(_:isEnabled:)-1b6kl","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"accessibilityValue","kind":"identifier"},{"text":"(","kind":"text"},{"text":"LocalizedStringResource","kind":"typeIdentifier","preciseIdentifier":"s:10Foundation23LocalizedStringResourceV"},{"text":", ","kind":"text"},{"text":"isEnabled","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"text":"ModifiedContent","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI15ModifiedContentV"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"AccessibilityAttachmentModifier","kind