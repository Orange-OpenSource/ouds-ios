type":"text"},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"type":"topic","role":"symbol"},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"type":"image"}}}