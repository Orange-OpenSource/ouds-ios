"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The current ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" but with new typography applied","type":"text"}]}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/headingMedium(_:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudssuggestionchip\/headingmedium(_:)"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","metadata":{"modules":[{"name":"Components","relatedModules":["SwiftUICore"]}],"externalID":"s:7SwiftUI4ViewP14OUDSComponentsE13headingMediumyQr18OUDSThemesContract9OUDSThemeCF::SYNTHESIZED::s:14OUDSComponents18OUDSSuggestionChipV","roleHeading":"Instance Method","title":"headingMedium(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"headingMedium","kind":"identifier"},{"text":"(","kind":"text"},{"text":"OUDSTheme","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract9OUDSThemeC"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"symbolKind":"method","role":"symbol","extendedModule":"SwiftUICore"},"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip":{"navigatorTitle":[{"kind":"identifier","text":"OUDSSuggestionChip"}],"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSSuggestionChip"}],"url":"\/documentation\/oudscomponents\/oudssuggestionchip","title":"OUDSSuggestionChip","abstract":[{"type":"text","text":"Suggestion chip is a UI element that allows to present recommended or predictive options based on user’s input or context,"},{"type":"text","text":" "},{"type":"text","text":"and is commonly used to capture filtering decisions."},{"type":"text","text":" "},{"type":"text","text":"Suggestion chip is typically non-selected by default and can be tapped or clicked to apply the suggestion, streamlining input and enhancing usability."},{"type":"text","text":" "},{"type":"text","text":"Chips can show multiple interactive elements together in the same area, such as a list of selectable movie times, or a serie of email contacts."},{"type":"text","text":" "},{"type":"text","text":"Best suited for category-based filters that do not require additional visual elements."}],"role":"symbol","type":"topic"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"type":"topic","abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"text":" ","type":"text"},{"text":"A Swift ","type":"text"},{"code":"class","type":"codeVoice"},{"text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"object oriented paradigm"}]},{"type":"text","text":", or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme contract"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","navigatorTitle":[{"text":"OUDSTheme","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","title":"OUDSTheme"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSSuggestionChip/headingMedium(_:)":{"abstract":[{"text":"Modifies the current ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" to apply a ","type":"text"},{"inlineContent":[{"text":"heading medium","type":"text"}],"type":"emphasis"},{"text":" typography.","type":"text"},{"text":" ","type":"text"},{"text":"The current ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" must be given in parameter because ","type":"text"},{"code":"@Environment","type":"codeVoice"},{"text":" property cannot be accessed through an extension or inside a method.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSSuggestionChip\/headingMedium(_:)","title":"headingMedium(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"headingMedium"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract9OUDSThemeC","text":"OUDSTheme"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP","text":"View"}],"type":"topic","kind":"symbol","url":"\/documentation\/oudscomponents\/oudssuggestionchip\/headingmedium(_:)","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"abstra