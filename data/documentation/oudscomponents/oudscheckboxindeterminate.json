"."},{"type":"text","text":" "},{"type":"text","text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox."}]},{"level":2,"type":"heading","text":"Cases forbidden by design","anchor":"Cases-forbidden-by-design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]}]},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"]},{"level":2,"type":"heading","text":"Suggestions","anchor":"Suggestions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the "},{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}]},{"level":2,"type":"heading","text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"overridingTitleInlineContent":[{