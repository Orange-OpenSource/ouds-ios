{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxIndeterminate"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"anchor":"Indicator-states","type":"heading","level":2,"text":"Indicator states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"unselected"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"indeterminate"}]},{"type":"text","text":": like a prefilled or preticked checkbox, the user did not do anything on it yet"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"In you are looking for a checkbox with only two possible values, refer to "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Particular-cases","type":"heading","level":2,"text":"Particular cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."}]},{"anchor":"Accessibility-considerations","type":"heading","level":2,"text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also the component must be instanciated with a string parameter used as accessibility label."},{"type":"text","text":" "},{"type":"text","text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox."}]},{"anchor":"Cases-forbidden-by-design","type":"heading","level":2,"text":"Cases forbidden by design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]}]},{"anchor":"Code-samples","type":"heading","level":2,"text":"Code samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"]},{"anchor":"Suggestions","type":"heading","level":2,"text":"Suggestions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the "},{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}]},{"anchor":"Design-documentation","type":"heading","level":2,"text":"Design documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","overridingTitle":"unified-design-system.orange.com","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"isActive":true}]},{"anchor":"Themes-rendering","type":"heading","level":2,"text":"Themes rendering"},{"anchor":"Orange","type":"heading","level":3,"text":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Orange"}]},{"anchor":"Orange-Business-Tools","type":"heading","level":3,"text":"Orange Business Tools"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_OrangeBusinessTools"}]},{"anchor":"Sosh","type":"heading","level":3,"text":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Sosh"}]},{"anchor":"Wireframe","type":"heading","level":3,"text":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Wireframe"}]},{"name":"Version","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}]}]},{"name":"Since","style":"note","type":"aside","content":[{"