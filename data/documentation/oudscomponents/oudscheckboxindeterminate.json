n\/OUDSComponents\/OUDSCheckboxIndeterminate\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/View-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"abstract":[{"text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices.","type":"text"},{"text":" ","type":"text"},{"text":"Checkbox that does not show icon or text, provides greater flexibility when creating other components that require a checkbox to be displayed.","type":"text"}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxindeterminate"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxIndeterminate","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"content":[{"level":2,"anchor":"Indicator-states","text":"Indicator states","type":"heading"},{"inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"unselected"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{