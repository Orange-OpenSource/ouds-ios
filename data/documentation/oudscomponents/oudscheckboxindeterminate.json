{"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/init(selection:accessibilityLabel:isError:)"]},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/body"]},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/View-Implementations"]}],"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxIndeterminate"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"Indicator-states","text":"Indicator states","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"indeterminate","type":"text"}]},{"type":"text","text":": like a prefilled or preticked checkbox, the user did not do anything on it yet"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"In you are looking for a checkbox with only two possible values, refer to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"text":".","type":"text"}]},{"anchor":"Particular-cases","text":"Particular cases","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."}]},{"anchor":"Accessibility-considerations","text":"Accessibility considerations","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox.","type":"text"}]},{"anchor":"Cases-forbidden-by-design","text":"Cases forbidden by design","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"}]},{"anchor":"Code-samples","text":"Code samples","type":"heading","level":2},{"code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"anchor":"Suggestions","text":"Suggestions","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the "},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox\/b\/6578e5\/t\/3dd013a529","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}]},{"anchor":"Design-documentation","text":"Design documentation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","isActive":true,"type":"reference"}]},{"anchor":"Themes-rendering","text":"Themes rendering","type":"heading","level":2},{"anchor":"Orange","text":"Orange","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_checkbox_Orange","type":"image"}]},{"anchor":"Orange-Business-Tools","text":"Orange Business Tools","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component