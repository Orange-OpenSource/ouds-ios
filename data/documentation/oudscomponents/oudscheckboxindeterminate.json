CheckboxIndeterminate"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"type":"text","text":" "},{"type":"text","text":"Checkbox that does not show icon or text, provides greater flexibility when creating other components that require a checkbox to be displayed."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxIndeterminate"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"level":2,"text":"Indicator states","type":"heading","anchor":"Indicator-states"},{"inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"selected"}],"type":"strong"},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"indeterminate"}],"type":"strong"},{"text":": like a prefilled or preticked checkbox, the user did not do anything on it yet","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"In you are looking for a checkbox with only two possible values, refer to ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Particular cases","level":2,"type":"heading","anchor":"Particular-cases"},{"inlineContent":[{"text":"An ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","isActive":true,"type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look-and-feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"}],"type":"paragraph"},{"text":"Accessibility considerations","level":2,"type":"heading","anchor":"Accessibility-considerations"},{"inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox.","type":"text"}],"type":"paragraph"},{"text":"Cases forbidden by design","level":2,"type":"heading","anchor":"Cases-forbidden-by-design"},{"inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"}],"type":"paragraph"},{"text":"Code samples","level":2,"type":"heading","anchor":"Code-samples"},{"syntax":"swift","type":"codeListi