ype":"text","text":": like a prefilled or preticked checkbox, the user did not do anything on it yet"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"In you are looking for a checkbox with only two possible values, refer to "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Particular-cases","text":"Particular cases","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","isActive":true},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."}],"type":"paragraph"},{"anchor":"Accessibility-considerations","text":"Accessibility considerations","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Note also the component must be instanciated with a string parameter used as accessibility label."},{"type":"text","text":" "},{"type":"text","text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox."}],"type":"paragraph"},{"anchor":"Cases-forbidden-by-design","text":"Cases forbidden by design","level":2,"type":"heading"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled compon