{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"kind":"symbol","metadata":{"navigatorTitle":[{"kind":"identifier","text":"OUDSCheckboxIndeterminate"}],"modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSCheckboxIndeterminate"}],"title":"OUDSCheckboxIndeterminate","roleHeading":"Structure","platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"15.0"},{"name":"macOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"13.0"},{"name":"tvOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"16.0"},{"name":"visionOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"1.0"},{"name":"watchOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"11.0"}],"externalID":"s:14OUDSComponents25OUDSCheckboxIndeterminateV","role":"symbol","symbolKind":"struct"},"sections":[],"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxindeterminate"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Checkbox that does not show icon or text, provides greater flexibility when creating other components that require a checkbox to be displayed."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxIndeterminate","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"type":"heading","level":2,"text":"Indicator states","anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"indeterminate","type":"text"}]},{"text":": like a prefilled or preticked checkbox, the user did not do anything on it yet","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In you are looking for a checkbox with only two possible values, refer to "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Particular cases","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"}]},{"type":"heading","anchor":"Accessibility-considerations","level":2,"text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"inlineContent":[{"text":"Voice Over","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox.","type":"text"}]},{"type":"heading","level":2,"text":"Cases forbidden by design","anchor":"Cases-forbidden-by-design"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"}]},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"type":"heading","level":2,"text":"Suggestions","anchor":"Suggestions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the "},{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the checkbox by default must be used in unselected state."}]},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","overridingTitle":"unified-design-system.orange.com","overridingTitleInlineContent":[{"text":"unified-design-system.orange.com","type":"text"}]}]},{"type":"heading","level":2,"text":"Themes rendering","anchor":"Themes-rendering"},{"type":"heading","level":3,"text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Orange"}]},{"type":"heading","anchor":"Orange-Compact","level":3,"text":"Orange Compact"},{"inlineContent":[{"type":"image","identifier":"component_checkbox_OrangeCompact"}],"type":"paragraph"},{"level":3,"text":"Sosh","type":"heading","anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_checkbox_Sosh","type":"image"}]},{"type":"heading","anchor":"Wireframe","level":3,"text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_checkbox_Wireframe","type":"image"}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}],"type":"paragraph"}],"name":"Version"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}],"name":"Since"}],"kind":"content"}],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/init(selection:accessibilityLabel:isError:isReadOnly:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/init(selection:accessibilityLabel:tableName:bundle:isError:isReadOnly:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"identifiers":["doc:\/\/OUDSCompo