{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"abstract":[{"type":"text","text":"Checkbox is a UI element that allows to select multiple options from a set of mutually non exclusive choices."},{"text":" ","type":"text"},{"text":"Checkbox that does not show icon or text, provides greater flexibility when creating other components that require a checkbox to be displayed.","type":"text"}],"topicSections":[{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/init(selection:accessibilityLabel:isError:isReadOnly:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/init(selection:accessibilityLabel:tableName:bundle:isError:isReadOnly:)"]},{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/body"]},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate\/View-Implementations"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OUDSCheckboxIndeterminate","kind":"identifier"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Indicator-states","text":"Indicator states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"unselected","type":"text"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"indeterminate"}],"type":"strong"},{"type":"text","text":": like a prefilled or preticked checkbox, the user did not do anything on it yet"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In you are looking for a checkbox with only two possible values, refer to "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true},{"type":"text","text":"."}]},{"type":"heading","text":"Particular cases","anchor":"Particular-cases","level":2},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","type":"reference"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."}]},{"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"text":"Note also the component must be instanciated with a string parameter used as accessibility label.","type":"text"},{"text":" ","type":"text"},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"inlineContent":[{"type":"text","text":"Voice Over"}],"type":"emphasis"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for checkbox.","type":"text"}]},{"type":"heading","text":"Cases forbidden by design","anchor":"Cases-forbidden-by-design","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]}]},{"type":"heading","text":"Code samples","anchor":"Code-samples","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A simple checkbox, no error, not in read only mode","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple checkbox, but is an error context","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true)","","    \/\/ Never disable an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxIndeterminate(selection: $selection, accessibilityLabel: \"The cake is a lie\"), isError: true).disabled(true) \/\/ fatal error"]},{"type":"heading","text":"Suggestions","anchor":"Suggestions","level":2},{"type":"paragraph","inlineContent":[{"text":"According to the ","type":"text"},{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","type":"reference","isActive":true},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the checkbox by default must be used in unselected state.","type":"text"}]},{"type":"heading","text":"Design documentation","anchor":"Design-documentation","level":2},{"type":"paragraph","inlineContent":[{"overridingTitle":"unified-design-system.orange.com","type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-checkbox","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}]}]},{"type":"heading","level":2,"text":"Themes rendering","anchor":"Themes-rendering"},{"type":"heading","level":3,"text":"Orange","anchor":"Orange"},{"inlineContent":[{"type":"image","identifier":"component_checkbox_Orange"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Orange Compact","anchor":"Orange-Compact"},{"inlineContent":[{"identifier":"component_checkbox_OrangeCompact","type":"image"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Sosh","anchor":"Sosh"},{"inlineContent":[{"identifier":"component_checkbox_Sosh","type":"image"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Wireframe","anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_checkbox_Wireframe"}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"2.4.0 (Figma component design version)"}]}],"name":"Version"},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}],"name":"Since"}]}],"metadata":{"title":"OUDSCheckboxIndeterminate","roleHeading":"Structure","symbolKind":"struct","role":"symbol","platforms":[{"introducedAt":"15.0","deprecated":false,"unavailable":false,"beta":false,"name":"iOS"},{"beta":false,"unavailable":false,"deprecated":false,"introducedAt":"13.0","name":"macOS"},{"unavailable":false,"introducedAt":"16.0","name":"tvOS","deprecated":false,"beta":false},{"unavailable":false,"deprecated":false,"beta":false,"introducedAt":"1.0","name":"visionOS"},{"introducedAt":"11.0","deprecated":false,"unavailable":false