{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudspincodeinput"]}],"abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"type":"text","text":"such as a four, six or eight-digit personal identification number (PIN)."},{"type":"text","text":" "},{"type":"text","text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,"},{"type":"text","text":" "},{"type":"text","text":"while supporting smooth keyboard navigation and secured input masking if needed."}],"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:isOutlined:status:autofocus:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:tableName:bundle:isOutlined:status:autofocus:)"]},{"anchor":"Instance-Properties","generated":true,"title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/body"]},{"anchor":"Type-Properties","generated":true,"title":"Type Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter"]},{"anchor":"Enumerations","generated":true,"title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Length","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Status"]},{"anchor":"Default-Implementations","generated":true,"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/View-Implementations"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput"},"sections":[],"metadata":{"title":"OUDSPinCodeInput","role":"symbol","roleHeading":"Structure","externalID":"s:14OUDSComponents16OUDSPinCodeInputV","symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"OUDSPinCodeInput"}],"platforms":[{"beta":false,"unavailable":false,"name":"iOS","deprecated":false,"introducedAt":"15.0"},{"beta":false,"unavailable":false,"name":"visionOS","deprecated":false,"introducedAt":"1.0"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSPinCodeInput"}],"modules":[{"name":"Components"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSPinCodeInput","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"type":"heading","level":2,"anchor":"Layouts","text":"Layouts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"outlined"}]},{"type":"text","text":" layout: A minimalist input with a transparent background and a visible stroke outlining the field."},{"type":"text","text":" "},{"type":"text","text":"This style may be interesting for contexts other than form pages, e.g. when inputs need to feel lightweight and unobtrusive,"},{"type":"text","text":" "},{"type":"text","text":"in a header (search field), or in a selection\/filtering feature in a product catalog"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"not outlined"}]},{"type":"text","text":" (default): An input with a subtle background fill and visible bottom border, creating a softer and more contained look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for dense layouts or to enhance visibility."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component provides 3 layouts for the input: 4 boxes, 6 boxes or 8 boxes."}]},{"type":"paragraph","inlineContent":[{"text":"A helper text can be used to support text to convey additional information about the input field, such as how it will be used.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It should ideally only take up a single line, though may wrap to multiple lines if required, and be either persistently visible or visible only on focus."}]},{"anchor":"Error-status","level":2,"text":"Error status","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Error status indicates that the user input does not meet validation rules or expected formatting."},{"type":"text","text":" "},{"type":"text","text":"It provides immediate visual feedback, typically through a red border, error icon, and a clear, accessible error message positioned below the input (mandatory)."},{"type":"text","text":" "},{"type":"text","text":"This state helps users quickly identify and correct mistakes by explaining what went wrong and, when possible, how to fix it."},{"type":"text","text":" "},{"type":"text","text":"The input remains editable, encouraging users to revise their input without starting over."},{"type":"text","text":" "},{"type":"text","text":"The error state must be triggered by an explicit validation (submission, API response), and not in real time with each keystroke."},{"type":"text","text":" "},{"type":"text","text":"This can occur either because the entered code does not match the expected code, because the user entered an expired or already used code,"},{"type":"text","text":" "},{"type":"text","text":"or finally if the maximum number of attempts has been exceeded."}]},{"type":"heading","level":2,"anchor":"Specific-design-guidelines","text":"Specific design guidelines"},{"inlineContent":[{"type":"text","text":"In the context of a PIN code input, in addition to the input’s “Error” UI rendering, it is essential to also include an “Alert” component"},{"type":"text","text":" "},{"type":"text","text":"(also in its “Error” status) in the interface."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Particular cases","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","type":"reference"},{"type":"text","text":" component supports autofill feature of values like OTP code."},{"text":" ","type":"text"},{"type":"text","text":"For example if the user receives a message with inside a code the system can extract, the keyboard can suggest to the user to fill it."},{"text":" ","type":"text"},{"type":"text","text":"If the digits fits the component, it will be filled."},{"text":" ","type":"text"},{"type":"text","text":"If the digits are longer, they will be truncated."},{"text":" ","type":"text"},{"type":"text","text":"If the digits are shorter, they will be filled, letting other fields empty."}]},{"inlineContent":[{"type":"text","text":"The copy\/paste feature is also available and has the same behavior."}],"type":"paragraph"},{"anchor":"Technical-considerations","level":2,"text":"Technical considerations","type":"heading"},{"inlineContent":[{"type":"text","text":"For some cases, on phones screens or with 8 boxes in iPhone, you may need to use a "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":" to embed the component and let user move it."}],"type":"paragraph"},{"syntax":"swift","code":["ScrollView(.horizontal) {","    OUDSPinCodeInput($value,","                     length: .eight,","                     helperText: \"Enter your secret code sent to your phone\")","}"],"type":"codeListing"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Note also the exposed "},{"type":"emphasis","inlineContent":[{"text":"value","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":" will be updated when all digits are written."}],"type":"strong"}],"type":"paragraph"},{"type":"heading","anchor":"Accessibility-considerations","level":2,"text":"Accessibility considerations"},{"inlineContent":[{"type":"text","text":"The content of the fields is vocalized by Voice Over; the placeholders (defined in "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter","isActive":true},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"are not vocalized to let users know what they wrote."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The component gets only numeric values, not letters or symbols, only numbers."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Depending on the component configuration, autofocus can still be used when the component appears, and focus is moved to the next field as digits are entered."},{"type":"text","text":" "},{"type":"text","text":"For example if Voice Over is enavled, the autoficus is disabled."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The component and its digit fields are vocalized with internal wording.","type":"text"}]},{"inlineContent":[{"text":"When using the error status, provide a clear, concise error message explaining what went wrong and, when possible, how to fix it","type":"text"},{"type":"text","text":" "},{"text":"(for example: ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"“The code you entered is invalid. Try again.”","type":"text"}]},{"text":").","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Use helper text to communicate additional guidance (for example: ","type":"text"},{"inlineContent":[{"text":"“Check the 6‑digit code sent by SMS”","type":"text"}],"type":"emphasis"},{"type":"text","text":"), and keep this text short so it remains easy to vocalize"},{"text":" ","type":"text"},{"type":"text","text":"and understand."}]},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","code":["    \/\/ The value with the code","    @State private var pinCode: String = \"\"","","    \/\/ By default, the PIN code input displays only 6 boxes","    OUDSPinCodeInput($pinCode)","","    \/\/ It can have also up 4 or 8 boxes, with an helper text","    OUDSPinCodeInput($pinCode, length: .eight, helperText: \"Enter your 8 secret digits\")","","    \/\/ The component can be used in error contexts","    OUDSPinCodeInput($pinCode, length: .six, status: .error(message: \"The OTP code you entered is not correct\"))"],"syntax":"swift"},{"type":"heading","anchor":"Design-documentation","level":2,"text":"Design documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-pin-code-input","isActive":true}]},{"type":"heading","level":2,"anchor":"Themes-rendering","text":"Themes rendering"},{"type":"heading","anchor":"Orange","level":3,"text":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_pinCodeInput_Orange"}]},{"type":"heading","anchor":"Orange-Compact","level":3,"text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_pinCodeInput_OrangeCompact"}]},{"type":"heading","anchor":"Sosh","level":3,"text":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_pinCodeInput_Sosh"}]},{"type":"heading","anchor":"Wireframe","level":3,"text":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_pinCodeInput_Wireframe"}]},{"type":"aside","style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.2.0 (Figma component design version)"}]}]},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.4.0"}]}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSPinCodeInput/init(_:length:helperText:isOutlined:status:autofocus:)":{"kind":"symbol","role":"symbol","title":"init(_:length:helperText:isOutlined:status:autofocus:)","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:isOutlined:status:autofocus:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:7SwiftUI7BindingV","text":"Binding","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"length","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:14OUDSComponents16OUDSPinCodeInputV","text":"OUDSPinCodeInput","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:14OUDSCompon