{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput"},"metadata":{"platforms":[{"beta":false,"deprecated":false,"name":"iOS","unavailable":false,"introducedAt":"15.0"},{"beta":false,"deprecated":false,"name":"visionOS","unavailable":false,"introducedAt":"1.0"}],"title":"OUDSPinCodeInput","externalID":"s:14OUDSComponents16OUDSPinCodeInputV","navigatorTitle":[{"kind":"identifier","text":"OUDSPinCodeInput"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSPinCodeInput"}],"symbolKind":"struct","roleHeading":"Structure","modules":[{"name":"Components"}],"role":"symbol"},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","type":"conformsTo"}],"abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"type":"text","text":"such as a four, six or eight-digit personal identification number (PIN)."},{"type":"text","text":" "},{"type":"text","text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,"},{"type":"text","text":" "},{"type":"text","text":"while supporting smooth keyboard navigation and secured input masking if needed."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSPinCodeInput","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Layouts","text":"Layouts"},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"outlined","type":"text"}],"type":"emphasis"},{"type":"text","text":" layout: A minimalist input with a transparent background and a visible stroke outlining the field."},{"type":"text","text":" "},{"type":"text","text":"This style may be interesting for contexts other than form pages, e.g. when inputs need to feel lightweight and unobtrusive,"},{"type":"text","text":" "},{"type":"text","text":"in a header (search field), or in a selection\/filtering feature in a product catalog"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"not outlined","type":"text"}]},{"type":"text","text":" (default): An input with a subtle background fill and visible bottom border, creating a softer and more contained look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for dense layouts or to enhance visibility."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component provides 3 layouts for the input: 4 boxes, 6 boxes or 8 boxes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A helper text can be used to support text to convey additional information about the input field, such as how it will be used."},{"type":"text","text":" "},{"type":"text","text":"It should ideally only take up a single line, though may wrap to multiple lines if required, and be either persistently visible or visible only on focus."}]},{"level":2,"type":"heading","text":"Error status","anchor":"Error-status"},{"type":"paragraph","inlineContent":[{"text":"The Error status indicates that the user input does not meet validation rules or expected formatting.","type":"text"},{"text":" ","type":"text"},{"text":"It provides immediate visual feedback, typically through a red border, error icon, and a clear, accessible error message positioned below the input (mandatory).","type":"text"},{"text":" ","type":"text"},{"text":"This state helps users quickly identify and correct mistakes by explaining what went wrong and, when possible, how to fix it.","type":"text"},{"text":" ","type":"text"},{"text":"The input remains editable, encouraging users to revise their input without starting over.","type":"text"},{"text":" ","type":"text"},{"text":"The error state must be triggered by an explicit validation (submission, API response), and not in real time with each keystroke.","type":"text"},{"text":" ","type":"text"},{"text":"This can occur either because the entered code does not match the expected code, because the user entered an expired or already used code,","type":"text"},{"text":" ","type":"text"},{"text":"or finally if the maximum number of attempts has been exceeded.","type":"text"}]},{"level":2,"type":"heading","text":"Specific design guidelines","anchor":"Specific-design-guidelines"},{"type":"paragraph","inlineContent":[{"text":"In the context of a PIN code input, in addition to the input’s “Error” UI rendering, it is essential to also include an “Alert” component","type":"text"},{"text":" ","type":"text"},{"text":"(also in its “Error” status) in the interface.","type":"text"}]},{"level":2,"type":"heading","text":"Particular cases","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","isActive":true,"type":"reference"},{"text":" component supports autofill feature of values like OTP code.","type":"text"},{"text":" ","type":"text"},{"text":"For example if the user receives a message with inside a code the system can extract, the keyboard can suggest to the user to fill it.","type":"text"},{"text":" ","type":"text"},{"text":"If the digits fits the component, it will be filled.","type":"text"},{"text":" ","type":"text"},{"text":"If the digits are longer, they will be truncated.","type":"text"},{"text":" ","type":"text"},{"text":"If the digits are shorter, they will be filled, letting other fields empty.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The copy\/paste feature is also available and has the same behavior.","type":"text"}]},{"level":2,"type":"heading","text":"Technical considerations","anchor":"Technical-considerations"},{"type":"paragraph","inlineContent":[{"text":"For some cases, on phones screens or with 8 boxes in iPhone, you may need to use a ","type":"text"},{"type":"codeVoice","code":"ScrollView"},{"text":" to embed the component and let user move it.","type":"text"}]},{"type":"codeListing","code":["ScrollView(.horizontal) {","    OUDSPinCodeInput($value,","                     length: .eight,","                     helperText: \"Enter your secret code sent to your phone\")","}"],"syntax":"swift"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Note also the exposed "},{"type":"emphasis","inlineContent":[{"type":"text","text":"value"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":" will be updated when all digits are written."}]}],"type":"paragraph"},{"type":"heading","anchor":"Accessibility-considerations","level":2,"text":"Accessibility considerations"},{"inlineContent":[{"text":"The content of the fields is vocalized by Voice Over; the placeholders (defined in ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","type":"reference","isActive":true},{"text":" and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter","type":"reference"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"are not vocalized to let users know what they wrote.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The component gets only numeric values, not letters or symbols, only numbers."}],"type":"paragraph"},{"inlineContent":[{"text":"Depending on the component configuration, autofocus can still be used when the component appears, and focus is moved to the next field as digits are entered.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For example if Voice Over is enavled, the autoficus is disabled."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The component and its digit fields are vocalized with internal wording."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When using the error status, provide a clear, concise error message explaining what went wrong and, when possible, how to fix it"},{"type":"text","text":" "},{"type":"text","text":"(for example: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"“The code you entered is invalid. Try again.”"}]},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Use helper text to communicate additional guidance (for example: ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"“Check the 6‑digit code sent by SMS”","type":"text"}]},{"type":"text","text":"), and keep this text short so it remains easy to vocalize"},{"type":"text","text":" "},{"type":"text","text":"and understand."}]},{"level":2,"type":"heading","text":"Rich text","anchor":"Rich-text"},{"inlineContent":[{"type":"text","text":"Rich text can be used for error and helper texts."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Strong text can be used sparingly to highlight key information within the content."},{"text":" ","type":"text"},{"text":"No other text styles should be used.","type":"text"},{"text":" ","type":"text"},{"text":"Underlined text must not be applied manually (e.g. in error message), as it is commonly associated with hyperlinks and may mislead users.","type":"text"}],"type":"paragraph"},{"text":"Code samples","type":"heading","anchor":"Code-samples","level":2},{"syntax":"swift","code":["    \/\/ The value with the code","    @State private var pinCode: String = \"\"","","    \/\/ By default, the PIN code input displays only 6 boxes","    OUDSPinCodeInput($pinCode)","","    \/\/ It can have also up 4 or 8 boxes, with an helper text","    OUDSPinCodeInput($pinCode, length: .eight, helperText: \"Enter your 8 secret digits\")","","    \/\/ The component can be used in error contexts","    OUDSPinCodeInput($pinCode, length: .six, status: .error(message: \"The OTP code you entered is not correct\"))"],"type":"codeListing"},{"text":"Design documentation","type":"heading","anchor":"Design-documentation","level":2},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-pin-code-input","isActive":true,"type":"reference"}],"type":"paragraph"},{"text":"Themes rendering","type":"heading","anchor":"Themes-rendering","level":2},{"text":"Orange","anchor":"Orange","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_pinCodeInput_Orange","type":"image"}],"type":"paragraph"},{"text":"Orange Compact","anchor":"Orange-Compact","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_pinCodeInput_OrangeCompact","type":"image"}],"type":"paragraph"},{"type":"heading","anchor":"Sosh","level":3,"text":"Sosh"},{"inlineContent":[{"identifier":"component_pinCodeInput_Sosh","type":"image"}],"type":"paragraph"},{"anchor":"Wireframe","type":"heading","level":3,"text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_pinCodeInput_Wireframe","type":"image"}]},{"type":"aside","style":"note","name":"Version","content":[{"inlineContent":[{"type":"text","text":"1.2.0 (Figma component design version)"}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"Since","content":[{"inlineContent":[{"type":"text","text":"1.4.0"}],"type":"paragraph"}]}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/oudscomponents\/oudspincodeinput"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:isOutlined:status:autofocus:)-7brty","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:isOutlined:status:autofocus:)-7czhh","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:tableName:bundle:isOutlined:status:autofocus:)"],"anchor":"Initializers","title":"Initializers","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/body"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter"],"anchor":"Type-Properties","generated":true,"title":"Type Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Length","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Status"],"anchor":"Enumerations","generated":true,"title":"Enumerations"},{"title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/View-Implementations"],"generated":true,"anchor":"Default-Implementations"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"references":{"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","type":"topic","kind":"symbol","identifier":"doc:\/