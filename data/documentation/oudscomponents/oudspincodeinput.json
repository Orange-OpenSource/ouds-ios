{"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput"},"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:isOutlined:status:autofocus:)-7brty","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:isOutlined:status:autofocus:)-7czhh","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:tableName:bundle:isOutlined:status:autofocus:)"],"title":"Initializers","generated":true},{"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/body"],"title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter"],"title":"Type Properties","generated":true,"anchor":"Type-Properties"},{"anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Length","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Status"],"title":"Enumerations","generated":true},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/View-Implementations"],"title":"Default Implementations","generated":true,"anchor":"Default-Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSPinCodeInput","kind":"identifier"}],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"]},{"kind":"content","content":[{"text":"Layouts","level":2,"anchor":"Layouts","type":"heading"},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"outlined","type":"text"}]},{"text":" layout: A minimalist input with a transparent background and a visible stroke outlining the field.","type":"text"},{"text":" ","type":"text"},{"text":"This style may be interesting for contexts other than form pages, e.g. when inputs need to feel lightweight and unobtrusive,","type":"text"},{"text":" ","type":"text"},{"text":"in a header (search field), or in a selection\/filtering feature in a product catalog","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"not outlined"}],"type":"emphasis"},{"type":"text","text":" (default): An input with a subtle background fill and visible bottom border, creating a softer and more contained look."},{"text":" ","type":"text"},{"type":"text","text":"Best suited for dense layouts or to enhance visibility."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The component provides 3 layouts for the input: 4 boxes, 6 boxes or 8 boxes.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A helper text can be used to support text to convey additional information about the input field, such as how it will be used.","type":"text"},{"text":" ","type":"text"},{"text":"It should ideally only take up a single line, though may wrap to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}]},{"anchor":"Error-status","text":"Error status","level":2,"type":"heading"},{"inlineContent":[{"text":"The Error status indicates that the user input does not meet validation rules or expected formatting.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It provides immediate visual feedback, typically through a red border, error icon, and a clear, accessible error message positioned below the input (mandatory)."},{"type":"text","text":" "},{"type":"text","text":"This state helps users quickly identify and correct mistakes by explaining what went wrong and, when possible, how to fix it."},{"type":"text","text":" "},{"text":"The input remains editable, encouraging users to revise their input without starting over.","type":"text"},{"type":"text","text":" "},{"text":"The error state must be triggered by an explicit validation (submission, API response), and not in real time with each keystroke.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This can occur either because the entered code does not match the expected code, because the user entered an expired or already used code,"},{"text":" ","type":"text"},{"text":"or finally if the maximum number of attempts has been exceeded.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"Specific design guidelines","anchor":"Specific-design-guidelines"},{"inlineContent":[{"text":"In the context of a PIN code input, in addition to the input’s “Error” UI rendering, it is essential to also include an “Alert” component","type":"text"},{"text":" ","type":"text"},{"text":"(also in its “Error” status) in the interface.","type":"text"}],"type":"paragraph"},{"anchor":"Particular-cases","text":"Particular cases","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput"},{"type":"text","text":" component supports autofill feature of values like OTP code."},{"type":"text","text":" "},{"text":"For example if the user receives a message with inside a code the system can extract, the keyboard can suggest to the user to fill it.","type":"text"},{"text":" ","type":"text"},{"text":"If the digits fits the component, it will be filled.","type":"text"},{"text":" ","type":"text"},{"text":"If the digits are longer, they will be truncated.","type":"text"},{"text":" ","type":"text"},{"text":"If the digits are shorter, they will be filled, letting other fields empty.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The copy\/paste feature is also available and has the same behavior."}],"type":"paragraph"},{"anchor":"Technical-considerations","text":"Technical considerations","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For some cases, on phones screens or with 8 boxes in iPhone, you may need to use a "},{"code":"ScrollView","type":"codeVoice"},{"text":" to embed the component and let user move it.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["ScrollView(.horizontal) {","    OUDSPinCodeInput($value,","                     length: .eight,","                     helperText: \"Enter your secret code sent to your phone\")","}"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Note also the exposed ","type":"text"},{"inlineContent":[{"text":"value","type":"text"}],"type":"emphasis"},{"text":" ","type":"text"},{"code":"Binding","type":"codeVoice"},{"text":" will be updated when all digits are written.","type":"text"}]}]},{"anchor":"Accessibility-considerations","text":"Accessibility considerations","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The content of the fields is vocalized by Voice Over; the placeholders (defined in "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"are not vocalized to let users know what they wrote."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component gets only numeric values, not letters or symbols, only numbers."}]},{"type":"paragraph","inlineContent":[{"text":"Depending on the component configuration, autofocus can still be used when the component appears, and focus is moved to the next field as digits are entered.","type":"text"},{"text":" ","type":"text"},{"text":"For example if Voice Over is enavled, the autoficus is disabled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The component and its digit fields are vocalized with internal wording.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When using the error status, provide a clear, concise error message explaining what went wrong and, when possible, how to fix it","type":"text"},{"text":" ","type":"text"},{"text":"(for example: ","type":"text"},{"inlineContent":[{"text":"“The code you entered is invalid. Try again.”","type":"text"}],"type":"emphasis"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use helper text to communicate additional guidance (for example: ","type":"text"},{"inlineContent":[{"text":"“Check the 6‑digit code sent by SMS”","type":"text"}],"type":"emphasis"},{"text":"), and keep this text short so it remains easy to vocalize","type":"text"},{"text":" ","type":"text"},{"text":"and understand.","type":"text"}]},{"type":"heading","level":2,"text":"Rich text","anchor":"Rich-text"},{"type":"paragraph","inlineContent":[{"text":"Rich text can be used for error and helper texts.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Strong text can be used sparingly to highlight key information within the content.","type":"text"},{"type":"text","text":" "},{"text":"No other text styles should be used.","type":"text"},{"type":"text","text":" "},{"text":"Underlined text must not be applied manually (e.g. in error message), as it is commonly associated with hyperlinks and may mislead users.","type":"text"}]},{"text":"Code samples","anchor":"Code-samples","level":2,"type":"heading"},{"type":"codeListing","syntax":"swift","code":["    \/\/ The value with the code","    @State private var pinCode: String = \"\"","","    \/\/ By default, the PIN code input displays only 6 boxes","    OUDSPinCodeInput($pinCode)","","    \/\/ It can have also up 4 or 8 boxes, with an helper text","    OUDSPinCodeInput($pinCode, length: .eight, helperText: \"Enter your 8 secret digits\")","","    \/\/ The component can be used in error contexts","    OUDSPinCodeInput($pinCode, length: .six, status: .error(message: \"The OTP code you entered is not correct\"))"]},{"type":"heading","anchor":"Design-documentation","level":2,"text":"Design documentation"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-pin-code-input","type":"reference","isActive":true}],"type":"paragraph"},{"text":"Themes rendering","anchor":"Themes-rendering","level":2,"type":"heading"},{"text":"Orange","anchor":"Orange","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_pinCodeInput_Orange","type":"image"}],"type":"paragraph"},{"text":"Orange Compact","anchor":"Orange-Compact","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_pinCodeInput_OrangeCompact","type":"image"}],"type":"paragraph"},{"text":"Sosh","anchor":"Sosh","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_pinCodeInput_Sosh","type":"image"}],"type":"paragraph"},{"text":"Wireframe","anchor":"Wireframe","level":3,"type":"heading"},{"inlineContent":[{"identifier":"component_pinCodeInput_Wireframe","type":"image"}],"type":"paragraph"},{"style":"note","name":"Version","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.2.0 (Figma component design version)"}]}]},{"style":"note","name":"Since","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.4.0"}]}]}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudspincodeinput"]}],"kind":"symbol","metadata":{"platforms":[{"deprecated":false,"introducedAt":"15.0","name":"iOS","unavailable":false,"beta":false},{"beta":false,"introducedAt":"1.0","name":"visionOS","deprecated":false,"unavailable":false}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OUDSPinCodeInput"}],"symbolKind":"struct","roleHeading":"Structure","externalID":"s:14OUDSComponents16OUDSPinCodeInputV","modules":[{"name":"Components"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSPinCodeInput","kind":"identifier"}],"title":"OUDSPinCodeInput"},"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"text":"such as a four, six or eight-digit personal identification number (PIN).","type":"text"},{"type":"text","text":" "},{"text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,","type":"text"},{"type":"text","text":" "},{"text":"while supporting smooth keyboard navigation and secured input masking if needed.","type":"text"}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUDSPinCodeInput/init(_:length:helperText:isOutlined:status:autofocus:)-7brty":{"url":"\/docu