porting smooth keyboard navigation and secured input masking if needed."}],"role":"symbol","url":"\/documentation\/oudscomponents\/oudspincodeinput","kind":"symbol","type":"topic","title":"OUDSPinCodeInput","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput"},"doc://OUDSComponents/s8SendableP":{"identifier":"doc:\/\/OUDSComponents\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"doc://OUDSComponents/documentation/OUDSComponents/Controls":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"title":"Controls","type":"topic","kind":"article","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls","url":"\/documentation\/oudscomponents\/controls","role":"article","abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"text":"controls","type":"text"}]},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"type":"text","text":"inputs"}]},{"text":".","type":"text"}]},"doc://OUDSComponents/7SwiftUI4ViewP":{"identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","type":"unresolvable","title":"SwiftUICore.View"},"doc://OUDSComponents/s16SendableMetatypeP":{"identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","type":"unresolvable","title":"Swift.SendableMetatype"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSPinCodeInput/Status":{"kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Status","title":"OUDSPinCodeInput.Status","abstract":[{"type":"text","text":"Define all available status for the PIN code input"}],"type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Status"}],"navigatorTitle":[{"kind":"identifier","text":"Status"}],"url":"\/documentation\/oudscomponents\/oudspincodeinput\/status"},"doc://OUDSComponents/documentation/OU