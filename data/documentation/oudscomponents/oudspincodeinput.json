ponents\/oudspincodeinput","role":"symbol","abstract":[{"text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,","type":"text"},{"text":" ","type":"text"},{"text":"such as a four, six or eight-digit personal identification number (PIN).","type":"text"},{"text":" ","type":"text"},{"text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,","type":"text"},{"text":" ","type":"text"},{"text":"while supporting smooth keyboard navigation and secured input masking if needed.","type":"text"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSPinCodeInput"}]}}}