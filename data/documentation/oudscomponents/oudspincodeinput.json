{"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSPinCodeInput"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Controls"],"kind":"mentions"},{"content":[{"level":2,"anchor":"Layouts","type":"heading","text":"Layouts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"outlined"}],"type":"emphasis"},{"text":" layout: A minimalist input with a transparent background and a visible stroke outlining the field.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This style may be interesting for contexts other than form pages, e.g. when inputs need to feel lightweight and unobtrusive,"},{"type":"text","text":" "},{"type":"text","text":"in a header (search field), or in a selection\/filtering feature in a product catalog"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"not outlined"}]},{"type":"text","text":" (default): An input with a subtle background fill and visible bottom border, creating a softer and more contained look."},{"type":"text","text":" "},{"text":"Best suited for dense layouts or to enhance visibility.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component provides 3 layouts for the input: 4 boxes, 6 boxes or 8 boxes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A helper text can be used to support text to convey additional information about the input field, such as how it will be used."},{"type":"text","text":" "},{"text":"It should ideally only take up a single line, though may wrap to multiple lines if required, and be either persistently visible or visible only on focus.","type":"text"}]},{"level":2,"anchor":"Error-status","type":"heading","text":"Error status"},{"type":"paragraph","inlineContent":[{"text":"The Error status indicates that the user input does not meet validation rules or expected formatting.","type":"text"},{"text":" ","type":"text"},{"text":"It provides immediate visual feedback, typically through a red border, error icon, and a clear, accessible error message positioned below the input (mandatory).","type":"text"},{"text":" ","type":"text"},{"text":"This state helps users quickly identify and correct mistakes by explaining what went wrong and, when possible, how to fix it.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The input remains editable, encouraging users to revise their input without starting over."},{"type":"text","text":" "},{"type":"text","text":"The error state must be triggered by an explicit validation (submission, API response), and not in real time with each keystroke."},{"type":"text","text":" "},{"text":"This can occur either because the entered code does not match the expected code, because the user entered an expired or already used code,","type":"text"},{"type":"text","text":" "},{"text":"or finally if the maximum number of attempts has been exceeded.","type":"text"}]},{"level":2,"type":"heading","text":"Specific design guidelines","anchor":"Specific-design-guidelines"},{"type":"paragraph","inlineContent":[{"text":"In the context of a PIN code input, in addition to the input’s “Error” UI rendering, it is essential to also include an “Alert” component","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(also in its “Error” status) in the interface."}]},{"level":2,"anchor":"Particular-cases","type":"heading","text":"Particular cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput"},{"type":"text","text":" component supports autofill feature of values like OTP code."},{"type":"text","text":" "},{"text":"For example if the user receives a message with inside a code the system can extract, the keyboard can suggest to the user to fill it.","type":"text"},{"text":" ","type":"text"},{"text":"If the digits fits the component, it will be filled.","type":"text"},{"text":" ","type":"text"},{"text":"If the digits are longer, they will be truncated.","type":"text"},{"text":" ","type":"text"},{"text":"If the digits are shorter, they will be filled, letting other fields empty.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The copy\/paste feature is also available and has the same behavior."}]},{"level":2,"anchor":"Technical-considerations","type":"heading","text":"Technical considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For some cases, on phones screens or with 8 boxes in iPhone, you may need to use a "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":" to embed the component and let user move it."}]},{"type":"codeListing","code":["ScrollView(.horizontal) {","    OUDSPinCodeInput($value,","                     length: .eight,","                     helperText: \"Enter your secret code sent to your phone\")","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Note also the exposed "},{"type":"emphasis","inlineContent":[{"type":"text","text":"value"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":" will be updated when all digits are written."}]}]},{"level":2,"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The content of the fields is vocalized by Voice Over; the placeholders (defined in "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter","isActive":true},{"text":")","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are not vocalized to let users know what they wrote."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component gets only numeric values, not letters or symbols, only numbers."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Depending on the component configuration, autofocus can still be used when the component appears, and focus is moved to the next field as digits are entered."},{"text":" ","type":"text"},{"text":"For example if Voice Over is enavled, the autoficus is disabled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component and its digit fields are vocalized with internal wording."}]},{"type":"paragraph","inlineContent":[{"text":"When using the error status, provide a clear, concise error message explaining what went wrong and, when possible, how to fix it","type":"text"},{"text":" ","type":"text"},{"text":"(for example: ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"“The code you entered is invalid. Try again.”"}]},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use helper text to communicate additional guidance (for example: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"“Check the 6‑digit code sent by SMS”"}]},{"type":"text","text":"), and keep this text short so it remains easy to vocalize"},{"type":"text","text":" "},{"type":"text","text":"and understand."}]},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","code":["    \/\/ The value with the code","    @State private var pinCode: String = \"\"","","    \/\/ By default, the PIN code input displays only 6 boxes","    OUDSPinCodeInput($pinCode)","","    \/\/ It can have also up 4 or 8 boxes, with an helper text","    OUDSPinCodeInput($pinCode, length: .eight, helperText: \"Enter your 8 secret digits\")","","    \/\/ The component can be used in error contexts","    OUDSPinCodeInput($pinCode, length: .six, status: .error(message: \"The OTP code you entered is not correct\"))"],"syntax":"swift"},{"text":"Design documentation","type":"heading","anchor":"Design-documentation","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-pin-code-input"}]},{"text":"Themes rendering","type":"heading","anchor":"Themes-rendering","level":2},{"text":"Orange","type":"heading","anchor":"Orange","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_pinCodeInput_Orange"}]},{"text":"Orange Compact","type":"heading","anchor":"Orange-Compact","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_pinCodeInput_OrangeCompact"}]},{"text":"Sosh","type":"heading","anchor":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_pinCodeInput_Sosh"}]},{"text":"Wireframe","type":"heading","anchor":"Wireframe","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_pinCodeInput_Wireframe"}]},{"type":"aside","style":"note","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.2.0 (Figma component design version)"}]}]},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"1.4.0"}]}]}],"kind":"content"}],"metadata":{"externalID":"s:14OUDSComponents16OUDSPinCodeInputV","platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"15.0"},{"introducedAt":"1.0","name":"visionOS","beta":false,"deprecated":false,"unavailable":false}],"roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSPinCodeInput","kind":"identifier"}],"symbolKind":"struct","navigatorTitle":[{"text":"OUDSPinCodeInput","kind":"identifier"}],"title":"OUDSPinCodeInput","role":"symbol","modules":[{"name":"Components"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput"},"schemaVersion":{"minor":3,"patch":0,"major":0},"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:isOutlined:status:autofocus:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:tableName:bundle:isOutlined:status:autofocus:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/body"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter"],"generated":true,"title":"Type Properties","anchor":"Type-Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Length","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Status"],"generated":true,"title":"Enumerations","anchor":"Enumerations"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPi