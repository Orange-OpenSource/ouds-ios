{"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudspincodeinput"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"title":"OUDSPinCodeInput","symbolKind":"struct","role":"symbol","roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSPinCodeInput"}],"externalID":"s:14OUDSComponents16OUDSPinCodeInputV","platforms":[{"introducedAt":"15.0","beta":false,"name":"iOS","deprecated":false,"unavailable":false},{"introducedAt":"1.0","beta":false,"name":"visionOS","deprecated":false,"unavailable":false}],"navigatorTitle":[{"kind":"identifier","text":"OUDSPinCodeInput"}],"modules":[{"name":"Components"}]},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:isOutlined:status:autofocus:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/init(_:length:helperText:tableName:bundle:isOutlined:status:autofocus:)"]},{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/body"]},{"anchor":"Type-Properties","title":"Type Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter"]},{"anchor":"Enumerations","title":"Enumerations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Length","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/Status"]},{"anchor":"Default-Implementations","title":"Default Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/View-Implementations"]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSPinCodeInput","kind":"identifier"}]}]},{"content":[{"anchor":"Layouts","level":2,"type":"heading","text":"Layouts"},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"outlined","type":"text"}],"type":"emphasis"},{"type":"text","text":" layout: A minimalist input with a transparent background and a visible stroke outlining the field."},{"type":"text","text":" "},{"type":"text","text":"This style may be interesting for contexts other than form pages, e.g. when inputs need to feel lightweight and unobtrusive,"},{"type":"text","text":" "},{"type":"text","text":"in a header (search field), or in a selection\/filtering feature in a product catalog"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"not outlined","type":"text"}],"type":"emphasis"},{"type":"text","text":" (default): An input with a subtle background fill and visible bottom border, creating a softer and more contained look."},{"type":"text","text":" "},{"type":"text","text":"Best suited for dense layouts or to enhance visibility."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component provides 3 layouts for the input: 4 boxes, 6 boxes or 8 boxes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A helper text can be used to support text to convey additional information about the input field, such as how it will be used."},{"type":"text","text":" "},{"type":"text","text":"It should ideally only take up a single line, though may wrap to multiple lines if required, and be either persistently visible or visible only on focus."}]},{"level":2,"type":"heading","anchor":"Error-status","text":"Error status"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Error status indicates that the user input does not meet validation rules or expected formatting."},{"type":"text","text":" "},{"type":"text","text":"It provides immediate visual feedback, typically through a red border, error icon, and a clear, accessible error message positioned below the input (mandatory)."},{"type":"text","text":" "},{"type":"text","text":"This state helps users quickly identify and correct mistakes by explaining what went wrong and, when possible, how to fix it."},{"type":"text","text":" "},{"type":"text","text":"The input remains editable, encouraging users to revise their input without starting over."},{"type":"text","text":" "},{"type":"text","text":"The error state must be triggered by an explicit validation (submission, API response), and not in real time with each keystroke."},{"type":"text","text":" "},{"type":"text","text":"This can occur either because the entered code does not match the expected code, because the user entered an expired or already used code,"},{"type":"text","text":" "},{"type":"text","text":"or finally if the maximum number of attempts has been exceeded."}]},{"level":2,"type":"heading","anchor":"Specific-design-guidelines","text":"Specific design guidelines"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the context of a PIN code input, in addition to the input’s “Error” UI rendering, it is essential to also include an “Alert” component"},{"type":"text","text":" "},{"type":"text","text":"(also in its “Error” status) in the interface."}]},{"level":2,"type":"heading","anchor":"Particular-cases","text":"Particular cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","type":"reference","isActive":true},{"type":"text","text":" component supports autofill feature of values like OTP code."},{"type":"text","text":" "},{"type":"text","text":"For example if the user receives a message with inside a code the system can extract, the keyboard can suggest to the user to fill it."},{"type":"text","text":" "},{"type":"text","text":"If the digits fits the component, it will be filled."},{"type":"text","text":" "},{"type":"text","text":"If the digits are longer, they will be truncated."},{"type":"text","text":" "},{"type":"text","text":"If the digits are shorter, they will be filled, letting other fields empty."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The copy\/paste feature is also available and has the same behavior."}]},{"level":2,"type":"heading","anchor":"Technical-considerations","text":"Technical considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For some cases, on phones screens or with 8 boxes in iPhone, you may need to use a "},{"code":"ScrollView","type":"codeVoice"},{"type":"text","text":" to embed the component and let user move it."}]},{"type":"codeListing","syntax":"swift","code":["ScrollView(.horizontal) {","    OUDSPinCodeInput($value,","                     length: .eight,","                     helperText: \"Enter your secret code sent to your phone\")","}"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Note also the exposed "},{"inlineContent":[{"type":"text","text":"value"}],"type":"emphasis"},{"type":"text","text":" "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":" will be updated when all digits are written."}],"type":"strong"}]},{"level":2,"type":"heading","anchor":"Accessibility-considerations","text":"Accessibility considerations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The content of the fields is vocalized by Voice Over; the placeholders (defined in "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/obfuscationCharacter","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput\/placeholderCharacter","type":"reference","isActive":true},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"are not vocalized to let users know what they wrote."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component gets only numeric values, not letters or symbols, only numbers."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Depending on the component configuration, autofocus can still be used when the component appears, and focus is moved to the next field as digits are entered."},{"type":"text","text":" "},{"type":"text","text":"For example if Voice Over is enavled, the autoficus is disabled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component and its digit fields are vocalized with internal wording."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using the error status, provide a clear, concise error message explaining what went wrong and, when possible, how to fix it"},{"type":"text","text":" "},{"type":"text","text":"(for example: "},{"inlineContent":[{"type":"text","text":"“The code you entered is invalid. Try again.”"}],"type":"emphasis"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use helper text to communicate additional guidance (for example: "},{"inlineContent":[{"type":"text","text":"“Check the 6‑digit code sent by SMS”"}],"type":"emphasis"},{"type":"text","text":"), and keep this text short so it remains easy to vocalize"},{"type":"text","text":" "},{"type":"text","text":"and understand."}]},{"level":2,"type":"heading","anchor":"Code-samples","text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ The value with the code","    @State private var pinCode: String = \"\"","","    \/\/ By default, the PIN code input displays only 6 boxes","    OUDSPinCodeInput($pinCode)","","    \/\/ It can have also up 4 or 8 boxes, with an helper text","    OUDSPinCodeInput($pinCode, length: .eight, helperText: \"Enter your 8 secret digits\")","","    \/\/ The component can be used in error contexts","    OUDSPinCodeInput($pinCode, length: .six, status: .error(message: \"The OTP code you entered is not correct\"))"]},{"level":2,"type":"heading","anchor":"Design-documentation","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-pin-code-input","type":"reference","isActive":true}]},{"level":2,"type":"heading","anchor":"Themes-rendering","text":"Themes rendering"},{"level":3,"type":"heading","anchor":"Orange","text":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_pinCodeInput_Orange","type":"image"}]},{"level":3,"type":"heading","anchor":"Orange-Compact","text":"Orange Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_pinCodeInput_OrangeCompact","type":"image"}]},{"level":3,"type":"heading","anchor":"Sosh","text":"Sosh"},{"type":"paragraph","inlineContent":[{"identifier":"component_pinCodeInput_Sosh","type":"image"}]},{"level":3,"type":"heading","anchor":"Wireframe","text":"Wireframe"},{"type":"paragraph","inlineContent":[{"identifier":"component_pinCodeInput_Wireframe","type":"image"}]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"1.2.0 (Figma component design version)"}],"type":"paragraph"}],"style":"note","name":"Version"},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"1.4.0"}],"type":"paragraph"}],"style":"note","name":"Since"}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"type":"text","text":"such as a four, six or eight-digit personal identification number (PIN)."},{"type":"text","text":" "},{"type":"text","text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,"},{"type":"text","text":" "},{"type":"text","text":"while supporting smooth keyboard navigation and secured input masking if needed."}],"references":{"component_pinCodeInput_Orange":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_pinCodeInput_Orange.png"}],"identifier":"component_pinCodeInput_Orange","alt":"A PIN code input component in light and dark modes with Orange theme","type":"image"},"doc://OUDSComponents/7SwiftUI4ViewP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/7SwiftUI4ViewP","title":"SwiftUICore.View"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSPinCodeInput":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"PIN code input is a UI element that allows to capture short, fixed-length numeric codes, typically for authentication or confirmation purposes,"},{"type":"text","text":" "},{"type":"text","text":"such as a four, six or eight-digit personal identification number (PIN)."},{"type":"text","text":" "},{"type":"text","text":"PIN code input is presented as a series of individual input fields or boxes, each representing a single digit, to enhance readability and encourage accurate input,"},{"type":"text","text":" "},{"type":"text","text":"while supporting smooth keyboard navigation and secured input masking if needed."}],"title":"OUDSPinCodeInput","url":"\/documentation\/oudscomponents\/oudspincodeinput","type":"topic","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSPinCodeInput","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSPinCodeInput"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSPinCodeInput"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"url":"\/documentation\/oudscomponents","title":"Components","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","role":"collection","type":"topic","kind":"symbol"},"component_pinCodeInput_Wireframe":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_pinCodeInput_Wireframe.png"}],"type":"image","identifier":"component_pinCodeInput_Wireframe","alt":"A PIN code input component in light and dark modes with Wireframe theme"},"doc://OUDSComponents/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/OUDSComponents\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"https://r.orange.fr/r/S-ouds-doc-pin-code-input":{"url":"https:\/\/r.orange.fr\/r\/S-ouds-doc-pin-code-input","type":"link","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-pin-code-input","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"title":"unified-design-system.orange.com"},"doc://OUDSComponents/documentation/OUDSComponents