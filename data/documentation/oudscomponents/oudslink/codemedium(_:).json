me to be derivated and be overriden."},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","type":"reference"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"code":"Sendable","type":"codeVoice"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSTheme"}],"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","kind":"symbol","title":"OUDSTheme","type":"topic","role":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink/codeMedium(_:)":{"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink\/codeMedium(_:)","abstract":[{"type":"text","text":"Modifies the current "},{"type":"codeVoice","code":"View"},{"type":"text","text":" to apply a "},{"inlineContent":[{"text":"code medium","type":"text"}],"type":"emphasis"},{"type":"text","text":" typography."},{"type":"text","text":" "},{"type":"text","text":"The current "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" must be given in parameter because "},{"type":"codeVoice","code":"@Environment"},{"type":"text","text":" property cannot be accessed through an extension or inside a method."}],"url":"\/documentation\/oudscomponents\/oudslink\/codemedium