omponents","type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","title":"OUDSLink","url":"\/documentation\/oudscomponents\/oudslink","navigatorTitle":[{"kind":"identifier","text":"OUDSLink"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSLink"}],"abstract":[{"type":"text","text":"Link is a UI element that allows to navigate from one location to another, either within the same page or across different pages in the same resource,"},{"type":"text","text":" "},{"type":"text","text":"or to an external resource."},{"type":"text","text":" "},{"type":"text","text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically."},{"type":"text","text":" "},{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true,"type":"reference"},{"type":"text","text":" proposes layout with text only or text with icon."},{"type":"text","text":" "},{"type":"text","text":"It also proposes layout to navigate forward or backward. The link can be displayed in "},{"code":"small","type":"codeVoice"},{"type":"text","text":" or "},{"code":"default","type":"codeVoice"},{"text":" size.","type":"text"}],"type":"topic"}}}