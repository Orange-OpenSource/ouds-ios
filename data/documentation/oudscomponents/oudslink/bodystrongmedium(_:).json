declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The current ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" to use to load the current font family and the suitable font semantic token.","type":"text"}]}],"name":"theme"}]},{"content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The current "},{"code":"View","type":"codeVoice"},{"type":"text","text":" but with new typography applied"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"]]},"abstract":[{"type":"text","text":"Modifies the current "},{"type":"codeVoice","code":"View"},{"type":"text","text":" to apply a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"body strong medium"}]},{"type":"text","text":" typography."},{"type":"text","text":" "},{"type":"text","text":"The current "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" must be given in parameter because "},{"type":"codeVoice","code":"@Environment"},{"type":"text","text":" property cannot be accessed through an extension or inside a method."}],"sections":[],"references":{"doc://OUDSComponents/documentation/OUDSComponents":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","url":"\/documentation\/oudscomponents","role":"collection","title":"Components","type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink":{"role":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","title":"OUDSLink","url":"\/documentation\/oudscomponents\/oudslink","navigatorTitle":[{"kind":"identifier","text":"OUDSLink"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSLink"}],"abstract":[{"type":"text","text":"Link is a UI element that allows to navigate from one location to another, either within the same page or across different pages in the same resource,"},{"type":"text","text":" "},{"type":"text","text":"or to an external resource."},{"type":"text","text":" "},{"type":"text","text":"Link’s primary function is navigation and it communicates its interactive nature visually and semantically."},{"type":"text","text":" "},{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","isActive":true,"type":"reference"},{"type":"text","text":" proposes layout with text only or text with icon."},{"type":"text","text":" "},{"type":"text","text":"It also proposes layout to navigate forward or backward. The link can be displayed in "},{"code":"small","type":"codeVoice"},{"type":"text","text":" or "},{"code":"default","type":"codeVoice"},{"text":" size.","type":"text"}],"type":"topic"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","title":"OUDSTheme","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true,"type":"reference"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"kind":"symbol"},"ic_folder_categories.png":{"type":"image","identifier":"ic_folder_categories.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}]},"doc://OUDSComponents/documentation/OUDSComponents/OUDSLink/bodyStrongMedium(_:)":{"type":"topic","url":"\/documentation\/oudscomponents\/oudslink\/bodystrongmedium(_:)","title":"bodyStrongMedium(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"bodyStrongMedium"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSThemesContract9OUDSThemeC","text":"OUDSTheme"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifie