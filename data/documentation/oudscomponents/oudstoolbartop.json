constraints"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To be sure for iOS 18 and lower the back buttton and text have the good color, in your main view apply the following accent color:"}]},{"type":"codeListing","syntax":"swift","code":["    struct AppMainView: View {","        var body: some View {","            ContentView()","                .accentColor(theme.colors.contentDefault)","        }","    }"]},{"type":"heading","anchor":"Platform-considerations","text":"Platform considerations","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The component is available on iOS, iPadOS, and visionOS","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The component is not available for watchOS, tvOS and macOS","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Code-sample","text":"Code sample","level":2},{"type":"codeListing","syntax":"swift","code":["    ContentView()","        .toolBarTop(\"Title\",","            leadingItems: {","                OUDSToolBarItem(navigation: .back())","            },","            trailingItems: {","                OUDSToolBarItem(label: \"Label\") { \/* Action to process *\/ }","                OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","            }","        )"]},{"type":"heading","anchor":"Design-documentation","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-ios-tool-bar-top","type":"reference"}]},{"type":"heading","anchor":"Themes-rendering","text":"Themes rendering","level":2},{"level":3,"anchor":"Liquid-Glass","type":"heading","text":"Liquid Glass"},{"type":"heading","anchor":"Orange","text":"Orange","level":4},{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier"