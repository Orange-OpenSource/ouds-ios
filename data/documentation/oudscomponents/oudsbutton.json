{"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbutton"]}],"topicSections":[{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:flipIcon:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:icon:flipIcon:appearance:style:action:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"],"generated":true,"anchor":"Enumerations","title":"Enumerations"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"kind":"symbol","metadata":{"title":"OUDSButton","symbolKind":"struct","navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"modules":[{"name":"Components"}],"externalID":"s:14OUDSComponents10OUDSButtonV","platforms":[{"introducedAt":"15.0","deprecated":false,"unavailable":false,"name":"iOS","beta":false},{"introducedAt":"15.0","deprecated":false,"unavailable":false,"name":"macOS","beta":false},{"introducedAt":"16.0","deprecated":false,"unavailable":false,"name":"tvOS","beta":false},{"introducedAt":"1.0","deprecated":false,"unavailable":false,"name":"visionOS","beta":false},{"introducedAt":"11.0","deprecated":false,"unavailable":false,"name":"watchOS","beta":false}],"roleHeading":"Structure","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"]},{"kind":"content","content":[{"type":"heading","anchor":"Appearances","text":"Appearances","level":2},{"type":"paragraph","inlineContent":[{"text":"Five appearances are proposed for all layouts:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"default (by default)"}],"type":"strong"},{"type":"text","text":": Default buttons are used for actions which are not mandatory or essential for the user."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"strong","type":"text"}],"type":"strong"},{"text":": Should be singular and prominent, limited to one per view.","type":"text"},{"text":" ","type":"text"},{"text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"brand"}],"type":"strong"},{"type":"text","text":": A brand primary color alternative to the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"strong"}]},{"type":"text","text":" button."},{"type":"text","text":" "},{"type":"text","text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"type":"codeVoice","code":"OUDSButton.Appearance.Brand"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"minimal","type":"text"}],"type":"strong"},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"negative"}],"type":"strong"},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"type":"text","text":" "},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"type":"codeVoice","code":"OUDSButton.Appearance.Negative"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\") { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"]},{"type":"heading","level":2,"text":"Styles","anchor":"Styles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two style are available:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default (by default)","type":"text"}]},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for  states "},{"type":"emphasis","inlineContent":[{"text":"disabled","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"pressed","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"hovered","type":"text"}]},{"type":"text","text":" or normal (i.e. "},{"type":"emphasis","inlineContent":[{"text":"enabled","type":"text"}]},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"loading","type":"text"}],"type":"strong"},{"type":"text","text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data."}]}]}]},{"type":"heading","anchor":"Rounded-layout","text":"Rounded layout","level":2},{"type":"paragraph","inlineContent":[{"text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities.","type":"text"},{"text":" ","type":"text"},{"text":"For standard or business-oriented journeys, keep the default corners.","type":"text"},{"text":" ","type":"text"},{"text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To activate the rounded button behavior, set to true the ","type":"text"},{"type":"codeVoice","code":"hasRoundedButtons"},{"text":" values of the ","type":"text"},{"type":"codeVoice","code":"Tuning"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"text":" ","type":"text"},{"text":"Some themes do not have this flexibility like ","type":"text"},{"type":"codeVoice","code":"SoshTheme"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"WireframeTheme"},{"text":".","type":"text"}]},{"type":"heading","anchor":"Colored-surface","text":"Colored surface","level":2},{"type":"paragraph","inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface."}]}]},{"type":"heading","anchor":"Specific-behavior","text":"Specific behavior","level":2},{"type":"paragraph","inlineContent":[{"text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move.","type":"text"},{"text":" ","type":"text"},{"text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move.","type":"text"}]},{"type":"heading","anchor":"Design-documentation","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-button"}]},{"type":"heading","anchor":"Themes-rendering","text":"Themes rendering","level":2},{"type":"heading","anchor":"Orange","text":"Orange","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Orange"}]},{"type":"heading","anchor":"Orange-Business-Tools","text":"Orange Business Tools","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_OrangeBusinessTools"}]},{"type":"heading","anchor":"Sosh","text":"Sosh","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Sosh"}]},{"type":"heading","anchor":"Wireframe","text":"Wireframe","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Wireframe"}]},{"style":"note","type":"aside","name":"Version","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"3.2.0 (Figma component design version)"}]}]},{"style":"note","type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.10.0"}]}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" proposes layout with text only, icon only or text with icon."}],"r