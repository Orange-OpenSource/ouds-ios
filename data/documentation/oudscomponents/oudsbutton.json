{"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true,"type":"reference"},{"type":"text","text":" proposes layout with text only, icon only or text with icon."}],"sections":[],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbutton"]}],"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:flipIcon:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:icon:flipIcon:appearance:style:action:)"]},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"]},{"title":"Enumerations","anchor":"Enumerations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"]},{"title":"Default Implementations","anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"]}],"kind":"symbol","metadata":{"title":"OUDSButton","navigatorTitle":[{"kind":"identifier","text":"OUDSButton"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"roleHeading":"Structure","symbolKind":"struct","externalID":"s:14OUDSComponents10OUDSButtonV","modules":[{"name":"Components"}],"role":"symbol","platforms":[{"introducedAt":"15.0","beta":false,"name":"iOS","deprecated":false,"unavailable":false},{"introducedAt":"15.0","beta":false,"name":"macOS","deprecated":false,"unavailable":false},{"introducedAt":"16.0","beta":false,"name":"tvOS","deprecated":false,"unavailable":false},{"introducedAt":"1.0","beta":false,"name":"visionOS","deprecated":false,"unavailable":false},{"introducedAt":"11.0","beta":false,"name":"watchOS","deprecated":false,"unavailable":false}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"]},{"kind":"content","content":[{"anchor":"Appearances","level":2,"type":"heading","text":"Appearances"},{"inlineContent":[{"type":"text","text":"Five appearances are proposed for all layouts:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default (by default)","type":"text"}],"type":"strong"},{"text":": Default buttons are used for actions which are not mandatory or essential for the user.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"strong","type":"text"}],"type":"strong"},{"text":": Should be singular and prominent, limited to one per view.","type":"text"},{"text":" ","type":"text"},{"text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"brand","type":"text"}],"type":"strong"},{"text":": A brand primary color alternative to the ","type":"text"},{"inlineContent":[{"text":"strong","type":"text"}],"type":"emphasis"},{"text":" button.","type":"text"},{"text":" ","type":"text"},{"text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces.","type":"text"},{"text":" ","type":"text"},{"text":"A button with ","type":"text"},{"code":"OUDSButton.Appearance.Brand","type":"codeVoice"},{"text":" appearance is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"minimal","type":"text"}],"type":"strong"},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"negative","type":"text"}],"type":"strong"},{"text":": Negative buttons should be used sparingly to warn of a destructive action,","type":"text"},{"text":" ","type":"text"},{"text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog.","type":"text"},{"text":" ","type":"text"},{"text":"A button with ","type":"text"},{"code":"OUDSButton.Appearance.Negative","type":"codeVoice"},{"text":" appearance is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Code-samples","level":2,"type":"heading","text":"Code samples"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\") { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }"]},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"]},{"anchor":"Styles","level":2,"type":"heading","text":"Styles"},{"inlineContent":[{"type":"text","text":"Two style are available:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default (by default)","type":"text"}],"type":"strong"},{"text":": used in the normal usage of button. The aspect of the button changes for  states ","type":"text"},{"inlineContent":[{"text":"disabled","type":"text"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"text":"pressed","type":"text"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"text":"hovered","type":"text"}],"type":"emphasis"},{"text":" or normal (i.e. ","type":"text"},{"inlineContent":[{"text":"enabled","type":"text"}],"type":"emphasis"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"loading","type":"text"}],"type":"strong"},{"text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Rounded-layout","level":2,"type":"heading","text":"Rounded layout"},{"inlineContent":[{"type":"text","text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To activate the rounded button behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedButtons"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration (if the theme exposes this property at init)."},{"type":"text","text":" "},{"type":"text","text":"Some themes do not have this flexibility like "},{"type":"codeVoice","code":"SoshTheme"},{"type":"text","text":" and "},{"type":"codeVoice","code":"WireframeTheme"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Colored-surface","level":2,"type":"heading","text":"Colored surface"},{"inlineContent":[{"type":"text","text":"If button is placed on colored surface using "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface.","type":"text"}]}],"type":"paragraph"},{"anchor":"Specific-behavior","level":2,"type":"heading","text":"Specific behavior"},{"inlineContent":[{"type":"text","text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move."},{"type":"text","text":" "},{"type":"text","text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move."}],"type":"paragraph"},{"anchor":"Design-documentation","level":2,"type":"heading","text":"Design documentation"},{"inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/48a788-button","isActive":true,"type":"reference"}],"type":"paragraph"},{"anchor":"Themes-rendering","level":2,"type":"heading","text":"Themes rendering"},{"anchor":"Orange","level":3,"type":"heading","text":"Orange"},{"inlineContent":[{"identifier":"component_button_Orange","type":"image"}],"type":"paragraph"},{"anchor":"Orange-Business-Tools","level":3,"type":"heading","text":"Orange Business Tools"},{"inlineContent":[{"identifier":"component_button_OrangeBusinessTools","type":"image"}],"type":"paragraph"},{"anchor":"Sosh","level":3,"type":"heading","text":"Sosh"},{"inlineContent":[{"identifier":"component_button_Sosh","type":"image"}],"type":"paragraph"},{"anchor":"Wireframe","level":3,"type":"heading","text":"Wireframe"},{"inlineContent":[{"identifier":"component_button_Wireframe","type":"image"}],"type":"paragraph"},{"name":"Version","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"3.2.0 (Figma component design version)","type":"text"}]}]},{"name":"Since","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"0.10.0","type":"text"}]}]}]}],"schemaVersion":{"majo