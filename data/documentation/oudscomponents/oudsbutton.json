\/OUDSButton\/init(icon:accessibilityLabel:tableName:bundle:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:icon:flipIcon:appearance:style:isFullWidth:action:)"],"anchor":"Initializers"},{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"anchor":"Instance-Properties"},{"title":"Enumerations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"],"anchor":"Enumerations"},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"],"anchor":"Default-Implementations"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbutton"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"],"kind":"mentions"},{"kind":"content","content":[{"type":"heading","anchor":"Appearances","text":"Appearances","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Five appearances are proposed for all layouts:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default (by default)"}]},{"type":"text","text":": Default buttons are used for actions which are not mandatory or essential for the user."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"strong"}],"type":"strong"},{"type":"text","text":": Should be singular and prominent, limited to one per view."},{"type":"text","text":" "},{"type":"text","text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"brand"}]},{"type":"text","text":": A brand primary color alternative to the "},{"inlineContent":[{"type":"text","text":"strong"}],"type":"emphasis"},{"type":"text","text":" button."},{"type":"text","text":" "},{"type":"text","text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces."},{"type":"text","text":" "},{"text":"A button with ","type":"text"},{"code":"OUDSButton.Appearance.Brand","type":"codeVoice"},{"text":" appearance is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"minimal"}],"type":"strong"},{"type":"text","text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"negative"}]},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"type":"text","text":" "},{"text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"A button with "},{"code":"OUDSButton.Appearance.Negative","type":"codeVoice"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"anchor":"Code-samples","type":"heading","level":2,"text":"Code samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\") { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance and button taking full width","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong, isFullWidth: true) { \/* the action to process *\/ }","","    \/\/ Localizable from bundle can also be used","    OUDSButton(LocalizedStringKey(\"validate_button\"), bundle: Bundle.module, appearance: .strong) { }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"]},{"anchor":"Styles","type":"heading","level":2,"text":"Styles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two style are available:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default (by default)"}],"type":"strong"},{"text":": used in the normal usage of button. The aspect of the button changes for  states ","type":"text"},{"inlineContent":[{"text":"disabled","type":"text"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"pressed"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"hovered"}],"type":"emphasis"},{"text":" or normal (i.e. ","type":"text"},{"inlineContent":[{"type":"text","text":"enabled"}],"type":"emphasis"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data.","type":"text"}]}]}]},{"type":"heading","anchor":"Rounded-layout","level":2,"text":"Rounded layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}]},{"type":"paragraph","inlineContent":[{"text":"To activate the rounded button behavior, set to true the ","type":"text"},{"type":"codeVoice","code":"hasRoundedButtons"},{"text":" values of the ","type":"text"},{"type":"codeVoice","code":"Tuning"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"text":" ","type":"text"},{"text":"Some themes do not have this flexibility like ","type":"text"},{"type":"codeVoice","code":"SoshTheme"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"WireframeTheme"},{"text":".","type":"text"}]},{"type":"heading","anchor":"Colored-surface","level":2,"text":"Colored surface"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If button is placed on colored surface using "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface."}],"type":"strong"}]},{"type":"heading","anchor":"Specific-behavior","level":2,"text":"Specific behavior"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move."},{"type":"text","text":" "},{"type":"text","text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move."}]},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-button","isActive":true,"type":"reference"}],"type":"paragraph"},{"text":"Themes rendering","type":"heading","level":2,"anchor":"Themes-rendering"},{"text":"Orange","type":"heading","level":3,"anchor":"Orange"},{"inlineContent":[{"type":"image"