{"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/oudscomponents\/oudsbutton"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" proposes layout with text only, icon only or text with icon."}],"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:flipIcon:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:icon:flipIcon:appearance:style:action:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"]},{"generated":true,"anchor":"Enumerations","title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"]},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"]}],"kind":"symbol","metadata":{"modules":[{"name":"Components"}],"platforms":[{"unavailable":false,"introducedAt":"15.0","deprecated":false,"beta":false,"name":"iOS"},{"unavailable":false,"introducedAt":"15.0","deprecated":false,"beta":false,"name":"macOS"},{"unavailable":false,"introducedAt":"16.0","deprecated":false,"beta":false,"name":"tvOS"},{"unavailable":false,"introducedAt":"1.0","deprecated":false,"beta":false,"name":"visionOS"},{"unavailable":false,"introducedAt":"11.0","deprecated":false,"beta":false,"name":"watchOS"}],"symbolKind":"struct","externalID":"s:14OUDSComponents10OUDSButtonV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"title":"OUDSButton","navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"roleHeading":"Structure","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"]},{"kind":"content","content":[{"text":"Appearances","level":2,"type":"heading","anchor":"Appearances"},{"type":"paragraph","inlineContent":[{"text":"Five appearances are proposed for all layouts:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"default (by default)","type":"text"}],"type":"strong"},{"text":": Default buttons are used for actions which are not mandatory or essential for the user.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"strong","type":"text"}],"type":"strong"},{"text":": Should be singular and prominent, limited to one per view.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"brand"}],"type":"strong"},{"text":": A brand primary color alternative to the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"strong","type":"text"}]},{"text":" button.","type":"text"},{"type":"text","text":" "},{"text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces.","type":"text"},{"type":"text","text":" "},{"text":"A button with ","type":"text"},{"type":"codeVoice","code":"OUDSButton.Appearance.Brand"},{"text":" appearance is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"minimal"}],"type":"strong"},{"type":"text","text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"negative","type":"text"}]},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"type":"text","text":" "},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"type":"codeVoice","code":"OUDSButton.Appearance.Negative"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Code samples","anchor":"Code-samples","type":"heading"},{"code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\")) { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}],"type":"paragraph"},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Styles","anchor":"Styles","type":"heading"},{"inlineContent":[{"text":"Two style are available:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default (by default)","type":"text"}]},{"text":": used in the normal usage of button. The aspect of the button changes for  states ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"disabled"}]},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"pressed","type":"text"}]},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"hovered","type":"text"}]},{"text":" or normal (i.e. ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"enabled"}]},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data.","type":"text"}],"type":"paragraph"}]}]},{"text":"Rounded layout","type":"heading","level":2,"anchor":"Rounded-layout"},{"type":"paragraph","inlineContent":[{"text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities.","type":"text"},{"text":" ","type":"text"},{"text":"For standard or business-oriented journeys, keep the default corners.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}]},{"type":"paragraph","inlineContent":[{"text":"To activate the rounded button behavior, set to true the ","type":"text"},{"type":"codeVoice","code":"hasRoundedButtons"},{"text":" values of the ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"text":" ","type":"text"},{"text":"Some themes do not have this flexibility like ","type":"text"},{"code":"SoshTheme","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"WireframeTheme","type":"codeVoice"},{"text":".","type":"text"}]},{"text":"Colored surface","type":"heading","level":2,"anchor":"Colored-surface"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If button is placed on colored surface using "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface."}]}],"type":"paragraph"},{"level":2,"text":"Specific behavior","type":"heading","anchor":"Specific-behavior"},{"inlineContent":[{"type":"text","text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move."},{"type":"text","text":" "},{"type":"text","text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move."}],"type":"paragraph"},{"level":2,"text":"Design documentation","type":"heading","anchor":"Design-documentation"},{"inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/48a788-button","isActive":true,"type":"reference"}],"type":"paragraph"},{"level":2,"text":"Themes rendering","type":"heading","anchor":"Themes-rendering"},{"level":3,"text":"Orange","type":"heading","anchor":"Orange"},{"inlineContent":[{"identifier":"component_button_Orange","type":"image"}],"type":"paragraph"},{"level":3,"text":"Orange Business Tools","type":"heading","anchor":"Orange-Business-Tools"},{"inlineContent":[{"identifier":"component_button_OrangeBusinessTools","type":"image"}],"type":"paragraph"},{"type":"heading","text":"Sosh","level":3,"anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Sosh"}]},{"type":"heading","text":"Wireframe","level":3,"anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Wireframe"}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"3.2.0 (Figma component design version)","type":"text"}]}],"name":"Version","style":"note"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.10.0"}]}],"name":"Since","style":"note"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","interfaceLanguage":"swift"},"sections":[],"references":{"doc://OUDSComponent