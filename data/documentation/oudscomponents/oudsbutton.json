{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbutton"]}],"abstract":[{"type":"text","text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action."},{"type":"text","text":" "},{"type":"text","text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis."}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo"}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","interfaceLanguage":"swift"},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"title":"OUDSButton","symbolKind":"struct","modules":[{"name":"Components"}],"platforms":[{"beta":false,"introducedAt":"15.0","deprecated":false,"unavailable":false,"name":"iOS"},{"beta":false,"introducedAt":"13.0","deprecated":false,"unavailable":false,"name":"macOS"},{"beta":false,"introducedAt":"16.0","deprecated":false,"unavailable":false,"name":"tvOS"},{"beta":false,"introducedAt":"1.0","deprecated":false,"unavailable":false,"name":"visionOS"},{"beta":false,"introducedAt":"11.0","deprecated":false,"unavailable":false,"name":"watchOS"}],"externalID":"s:14OUDSComponents10OUDSButtonV"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"anchor":"Initializers","title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(_:tableName:bundle:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(_:tableName:bundle:icon:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:tableName:bundle:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:icon:flipIcon:appearance:style:isFullWidth:action:)"]},{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"]},{"anchor":"Enumerations","title":"Enumerations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"]},{"anchor":"Default-Implementations","title":"Default Implementations","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"]},{"kind":"content","content":[{"anchor":"Appearances","level":2,"type":"heading","text":"Appearances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Five appearances are proposed for all layouts:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default (by default)","type":"text"}]},{"type":"text","text":": Default buttons are used for actions which are not mandatory or essential for the user."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"strong","type":"text"}]},{"text":": Should be singular and prominent, limited to one per view.","type":"text"},{"text":" ","type":"text"},{"text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"brand","type":"text"}]},{"type":"text","text":": A brand primary color alternative to the "},{"type":"emphasis","inlineContent":[{"text":"strong","type":"text"}]},{"type":"text","text":" button."},{"type":"text","text":" "},{"type":"text","text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"type":"codeVoice","code":"OUDSButton.Appearance.Brand"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"minimal"}]},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"negative"}]},{"text":": Negative buttons should be used sparingly to warn of a destructive action,","type":"text"},{"text":" ","type":"text"},{"text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog.","type":"text"},{"text":" ","type":"text"},{"text":"A button with ","type":"text"},{"code":"OUDSButton.Appearance.Negative","type":"codeVoice"},{"text":" appearance is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\") { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance and button taking full width","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong, isFullWidth: true) { \/* the action to process *\/ }","","    \/\/ Localizable from bundle can also be used","    OUDSButton(LocalizedStringKey(\"validate_button\"), bundle: Bundle.module, appearance: .strong) { }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}]},{"type":"codeListing","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"],"syntax":"swift"},{"type":"heading","level":2,"text":"Styles","anchor":"Styles"},{"type":"paragraph","inlineContent":[{"text":"Two style are available:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default (by default)"}]},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for  states "},{"type":"emphasis","inlineContent":[{"type":"text","text":"disabled"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"pressed"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"hovered"}]},{"type":"text","text":" or normal (i.e. "},{"inlineContent":[{"type":"text","text":"enabled"}],"type":"emphasis"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"loading","type":"text"}]},{"text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Rounded layout","anchor":"Rounded-layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To activate the rounded button behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedButtons"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration (if the theme exposes this property at init)."},{"type":"text","text":" "},{"type":"text","text":"Some themes do not have this flexibility like "},{"type":"codeVoice","code":"SoshTheme"},{"type":"text","text":" and "},{"type":"codeVoice","code":"WireframeTheme"},{"type":"text","text":"."}]},{"text":"Colored surface","level":2,"type":"heading","anchor":"Colored-surface"},{"inlineContent":[{"type":"text","text":"If button is placed on colored surface using "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface."}]}],"type":"paragraph"},{"text":"Specific behavior","level":2,"type":"heading","anchor":"Specific-behavior"},{"inlineContent":[{"type":"text","text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move."},{"type":"text","text":" "},{"type":"text","text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move."}],"type":"paragraph"},{"text":"Design documentation","level":2,"type":"heading","anchor":"Design-documentation"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-button","type":"reference","isActive":true}],"type":"paragraph"},{"text":"Themes rendering","level":2,"type":"heading","anchor":"Themes-rendering"},{"level":3,"text":"Orange","anchor":"Orange","type":"heading"},{"inlineContent":