{"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","sections":[],"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"symbolKind":"struct","role":"symbol","externalID":"s:14OUDSComponents10OUDSButtonV","roleHeading":"Structure","title":"OUDSButton","modules":[{"name":"Components"}],"platforms":[{"name":"iOS","deprecated":false,"beta":false,"unavailable":false,"introducedAt":"15.0"},{"name":"macOS","deprecated":false,"beta":false,"unavailable":false,"introducedAt":"13.0"},{"name":"tvOS","deprecated":false,"beta":false,"unavailable":false,"introducedAt":"16.0"},{"name":"visionOS","deprecated":false,"beta":false,"unavailable":false,"introducedAt":"1.0"},{"name":"watchOS","deprecated":false,"beta":false,"unavailable":false,"introducedAt":"11.0"}],"navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}]},"abstract":[{"type":"text","text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action."},{"type":"text","text":" "},{"type":"text","text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis."}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(_:tableName:bundle:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(_:tableName:bundle:icon:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:tableName:bundle:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:icon:flipIcon:appearance:style:isFullWidth:action:)"],"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"],"anchor":"Enumerations","title":"Enumerations"},{"generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"languages":["swift"],"platforms":["macOS"]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"],"kind":"mentions"},{"content":[{"anchor":"Appearances","text":"Appearances","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Five appearances are proposed for all layouts:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default (by default)"}],"type":"strong"},{"text":": Default buttons are used for actions which are not mandatory or essential for the user.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"strong"}],"type":"strong"},{"text":": Should be singular and prominent, limited to one per view.","type":"text"},{"text":" ","type":"text"},{"text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"brand"}],"type":"strong"},{"text":": A brand primary color alternative to the ","type":"text"},{"inlineContent":[{"type":"text","text":"strong"}],"type":"emphasis"},{"text":" button.","type":"text"},{"text":" ","type":"text"},{"text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces.","type":"text"},{"text":" ","type":"text"},{"text":"A button with ","type":"text"},{"code":"OUDSButton.Appearance.Brand","type":"codeVoice"},{"text":" appearance is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"minimal"}],"type":"strong"},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"negative"}],"type":"strong"},{"text":": Negative buttons should be used sparingly to warn of a destructive action,","type":"text"},{"text":" ","type":"text"},{"text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog.","type":"text"},{"text":" ","type":"text"},{"text":"A button with ","type":"text"},{"code":"OUDSButton.Appearance.Negative","type":"codeVoice"},{"text":" appearance is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Code-samples","text":"Code samples","type":"heading","level":2},{"code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\") { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance and button taking full width","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong, isFullWidth: true) { \/* the action to process *\/ }","","    \/\/ Localizable from bundle can also be used","    OUDSButton(LocalizedStringKey(\"validate_button\"), bundle: Bundle.module, appearance: .strong) { }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}]},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"anchor":"Styles","text":"Styles","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two style are available:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default (by default)"}],"type":"strong"},{"text":": used in the normal usage of button. The aspect of the button changes for  states ","type":"text"},{"inlineContent":[{"type":"text","text":"disabled"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"pressed"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"hovered"}],"type":"emphasis"},{"text":" or normal (i.e. ","type":"text"},{"inlineContent":[{"type":"text","text":"enabled"}],"type":"emphasis"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Rounded-layout","text":"Rounded layout","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To activate the rounded button behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedButtons"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration (if the theme exposes this property at init)."},{"type":"text","text":" "},{"type":"text","text":"Some themes do not have this flexibility like "},{"type":"codeVoice","code":"SoshTheme"},{"type":"text","text":" and "},{"type":"codeVoice","code":"WireframeTheme"},{"type":"text","text":"."}]},{"anchor":"Colored-surface","text":"Colored surface","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If button is placed on colored surface using "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface."}],"type":"strong"}]},{"anchor":"Specific-behavior","text":"Specific behavior","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move."},{"type":"text","text":" "},{"type":"text","text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move."}]},{"anchor":"Design-documentation","text":"Design documentation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-button","type":"reference"}]},{"anchor":"Themes-rendering","text":"Themes rendering","type":"heading","level":2},{"anchor":"Orange","text":"Orange","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_button_Orange","type":"image"}]},{"anchor":"Orange-Compact","text":"Orange Compact","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_button_OrangeCompact","type":"image"}]},{"anchor":"Sosh","text":"Sosh","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"identifier":"component_button_Sosh","type":"image"}]},{"anchor":"Wireframe","text":"Wireframe","type":"heading","level":3},{