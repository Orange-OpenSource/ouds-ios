{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},"abstract":[{"text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confirming an action.","type":"text"},{"text":" ","type":"text"},{"text":"Button appears in different layouts, styles and states to indicate hierarchy or emphasis.","type":"text"}],"kind":"symbol","metadata":{"roleHeading":"Structure","modules":[{"name":"Components"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"title":"OUDSButton","symbolKind":"struct","externalID":"s:14OUDSComponents10OUDSButtonV","platforms":[{"introducedAt":"15.0","deprecated":false,"name":"iOS","beta":false,"unavailable":false},{"name":"macOS","introducedAt":"13.0","unavailable":false,"beta":false,"deprecated":false},{"introducedAt":"16.0","deprecated":false,"name":"tvOS","beta":false,"unavailable":false},{"name":"visionOS","introducedAt":"1.0","unavailable":false,"beta":false,"deprecated":false},{"introducedAt":"11.0","deprecated":false,"name":"watchOS","beta":false,"unavailable":false}],"navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}]},"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(_:tableName:bundle:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(_:tableName:bundle:icon:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:tableName:bundle:flipIcon:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:isFullWidth:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:icon:flipIcon:appearance:style:isFullWidth:action:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"generated":true},{"title":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"],"generated":true,"anchor":"Enumerations"},{"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"],"generated":true}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"text":" ","kind":"text"},{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSButton"}]}]},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"],"kind":"mentions"},{"content":[{"text":"Appearances","type":"heading","anchor":"Appearances","level":2},{"inlineContent":[{"type":"text","text":"Five appearances are proposed for all layouts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default (by default)"}]},{"type":"text","text":": Default buttons are used for actions which are not mandatory or essential for the user."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"strong"}]},{"type":"text","text":": Should be singular and prominent, limited to one per view."},{"type":"text","text":" "},{"type":"text","text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"brand"}]},{"type":"text","text":": A brand primary color alternative to the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"strong"}]},{"type":"text","text":" button."},{"type":"text","text":" "},{"type":"text","text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Appearance.Brand","type":"codeVoice"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"minimal"}]},{"type":"text","text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"negative","type":"text"}]},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"type":"text","text":" "},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"type":"codeVoice","code":"OUDSButton.Appearance.Negative"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"Code samples","anchor":"Code-samples"},{"syntax":"swift","code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\") { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance and button taking full width","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong, isFullWidth: true) { \/* the action to process *\/ }","","    \/\/ Localizable from bundle can also be used","    OUDSButton(LocalizedStringKey(\"validate_button\"), bundle: Bundle.module, appearance: .strong) { }"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}]},{"syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"],"type":"codeListing"},{"text":"Styles","level":2,"anchor":"Styles","type":"heading"},{"inlineContent":[{"type":"text","text":"Two style are available:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default (by default)"}]},{"text":": used in the normal usage of button. The aspect of the button changes for  states ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"disabled"}]},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"pressed"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"hovered","type":"text"}]},{"text":" or normal (i.e. ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"enabled","type":"text"}]},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"loading","type":"text"}]},{"type":"text","text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data."}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Rounded layout","anchor":"Rounded-layout"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"text":"For standard or business-oriented journeys, keep the default corners.","type":"text"},{"text":" ","type":"text"},{"text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To activate the rounded button behavior, set to true the ","type":"text"},{"code":"hasRoundedButtons","type":"codeVoice"},{"text":" values of the ","type":"text"},{"code":"Tuning","type":"codeVoice"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"text":" ","type":"text"},{"text":"Some themes do not have this flexibility like ","type":"text"},{"code":"SoshTheme","type":"codeVoice"},{"type":"text","text":" and "},{"code":"WireframeTheme","type":"codeVoice"},{"type":"text","text":"."}]},{"level":2,"type":"heading","text":"Colored surface","anchor":"Colored-surface"},{"type":"paragraph","inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface."}]}],"type":"paragraph"},{"text":"Specific behavior","level":2,"anchor":"Specific-behavior","type":"heading"},{"inlineContent":[{"type":"text","text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move."},{"type":"text","text":" "},{"type":"text","text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move."}],"type":"paragraph"},{"text":"Design documentation","level":2,"anchor":"Design-documentation","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-button","type":"reference","isActive":true}]},{"level":2,"type":"heading","text":"Themes rendering","anchor":"Themes-rendering"},{"level":3,"type":"heading","text":"Orange","anchor":"Orange"},{"type":"paragraph","inlineContent":[{"identifier":"component_button_Orange","type":"image"}]},{"level":3,"type":"heading","text":"Orange Compact","anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"identifier":"component_button_OrangeCompact","type":"image"}]},{"level":3,"ty