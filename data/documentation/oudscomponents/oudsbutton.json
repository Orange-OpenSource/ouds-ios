{"kind":"symbol","topicSections":[{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:flipIcon:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:icon:flipIcon:appearance:style:action:)"],"title":"Initializers"},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"title":"Instance Properties"},{"generated":true,"anchor":"Enumerations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"],"title":"Enumerations"},{"generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"],"title":"Default Implementations"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Appearances","anchor":"Appearances"},{"type":"paragraph","inlineContent":[{"text":"Five appearances are proposed for all layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"default (by default)","type":"text"}],"type":"strong"},{"type":"text","text":": Default buttons are used for actions which are not mandatory or essential for the user."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"strong","type":"text"}],"type":"strong"},{"type":"text","text":": Should be singular and prominent, limited to one per view."},{"type":"text","text":" "},{"type":"text","text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"brand","type":"text"}],"type":"strong"},{"type":"text","text":": A brand primary color alternative to the "},{"inlineContent":[{"text":"strong","type":"text"}],"type":"emphasis"},{"type":"text","text":" button."},{"type":"text","text":" "},{"type":"text","text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Appearance.Brand","type":"codeVoice"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"minimal","type":"text"}],"type":"strong"},{"type":"text","text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"negative","type":"text"}],"type":"strong"},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"type":"text","text":" "},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Appearance.Negative","type":"codeVoice"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]}]},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\")) { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }"]},{"type":"paragraph","inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"]},{"type":"heading","level":2,"text":"Styles","anchor":"Styles"},{"type":"paragraph","inlineContent":[{"text":"Two style are available:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"default (by default)","type":"text"}],"type":"strong"},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for  states "},{"inlineContent":[{"text":"disabled","type":"text"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"pressed"}],"type":"emphasis"},{"text":", ","type":"text"},{"inlineContent":[{"text":"hovered","type":"text"}],"type":"emphasis"},{"text":" or normal (i.e. ","type":"text"},{"inlineContent":[{"text":"enabled","type":"text"}],"type":"emphasis"},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"loading","type":"text"}]},{"text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Rounded layout","anchor":"Rounded-layout"},{"inlineContent":[{"type":"text","text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"text":" ","type":"text"},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"text":" ","type":"text"},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}],"type":"paragraph"},{"inlineContent":[{"text":"To activate the rounded button behavior, set to true the ","type":"text"},{"type":"codeVoice","code":"hasRoundedButtons"},{"text":" values of the ","type":"text"},{"type":"codeVoice","code":"Tuning"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in your theme configuration (if the theme exposes this property at init)."},{"text":" ","type":"text"},{"type":"text","text":"Some themes do not have this flexibility like "},{"code":"SoshTheme","type":"codeVoice"},{"type":"text","text":" and "},{"code":"WireframeTheme","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"Colored surface","type":"heading","anchor":"Colored-surface"},{"inlineContent":[{"type":"text","text":"If button is placed on colored surface using "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface."}],"type":"strong"}],"type":"paragraph"},{"text":"Specific behavior","anchor":"Specific-behavior","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move."},{"type":"text","text":" "},{"type":"text","text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move."}],"type":"paragraph"},{"text":"Design documentation","anchor":"Design-documentation","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/48a788-button","type":"reference","isActive":true}]},{"text":"Themes rendering","anchor":"Themes-rendering","level":2,"type":"heading"},{"text":"Orange","anchor":"Orange","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"component_button_Orange","type":"image"}]},{"anchor":"Orange-Business-Tools","level":3,"type":"heading","text":"Orange Business Tools"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_OrangeBusinessTools"}]},{"type":"heading","anchor":"Sosh","level":3,"text":"Sosh"},{"inlineContent":[{"identifier":"compone