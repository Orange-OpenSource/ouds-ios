{"abstract":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"type":"text","text":" proposes layout with text only, icon only or text with icon."}],"kind":"symbol","sections":[],"metadata":{"externalID":"s:14OUDSComponents10OUDSButtonV","title":"OUDSButton","symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"OUDSButton"}],"role":"symbol","roleHeading":"Structure","modules":[{"name":"Components"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"]},{"kind":"content","content":[{"level":2,"anchor":"Appearances","type":"heading","text":"Appearances"},{"inlineContent":[{"text":"Five appearances are proposed for all layouts:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default (by default)"}]},{"text":": Default buttons are used for actions which are not mandatory or essential for the user.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"strong"}],"type":"strong"},{"text":": Should be singular and prominent, limited to one per view.","type":"text"},{"text":" ","type":"text"},{"text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"brand","type":"text"}]},{"text":": A brand primary color alternative to the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"strong"}]},{"text":" button.","type":"text"},{"text":" ","type":"text"},{"text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces.","type":"text"},{"text":" ","type":"text"},{"text":"A button with ","type":"text"},{"code":"OUDSButton.Appearance.Brand","type":"codeVoice"},{"text":" appearance is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"minimal","type":"text"}]},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"negative","type":"text"}],"type":"strong"},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"type":"text","text":" "},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"type":"codeVoice","code":"OUDSButton.Appearance.Negative"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}]}]}]},{"level":2,"anchor":"Code-samples","type":"heading","text":"Code samples"},{"code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\")) { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(icon: Image(\"ic_heart\"), text: \"Validate\", appearance: .strong) { \/* the action to process *\/ }"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Styles","type":"heading","text":"Styles"},{"inlineContent":[{"text":"Two style are available:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default (by default)","type":"text"}]},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for  states "},{"type":"emphasis","inlineContent":[{"type":"text","text":"disabled"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"pressed"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"hovered"}]},{"type":"text","text":" or normal (i.e. "},{"type":"emphasis","inlineContent":[{"text":"enabled","type":"text"}]},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"loading"}]},{"type":"text","text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data."}],"type":"paragraph"}]}]},{"level":2,"anchor":"Rounded-layout","type":"heading","text":"Rounded layout"},{"inlineContent":[{"text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities.","type":"text"},{"text":" ","type":"text"},{"text":"For standard or business-oriented journeys, keep the default corners.","type":"text"},{"text":" ","type":"text"},{"text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To activate the rounded button behavior, set to true the "},{"type":"codeVoice","code":"hasRoundedButtons"},{"type":"text","text":" values of the "},{"type":"codeVoice","code":"Tuning"},{"type":"text","text":" object"},{"type":"text","text":" "},{"type":"text","text":"in your theme configuration (if the theme exposes this property at init)."},{"type":"text","text":" "},{"type":"text","text":"Some themes do not have this flexibility like "},{"type":"codeVoice","code":"SoshTheme"},{"type":"text","text":" and "},{"type":"codeVoice","code":"WireframeTheme"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Colored-surface","type":"heading","text":"Colored surface"},{"inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface."}],"type":"strong"}],"type":"paragraph"},{"level":2,"anchor":"Specific-behavior","type":"heading","text":"Specific behavior"},{"inlineContent":[{"type":"text","text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move."},{"type":"text","text":" "},{"type":"text","text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move."}],"type":"paragraph"},{"level":2,"anchor":"Design-documentation","type":"heading","text":"Design documentation"},{"inlineContent":[{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/48a788-button","type":"reference","isActive":true}],"type":"paragraph"},{"level":2,"anchor":"Themes-rendering","type":"heading","text":"Themes rendering"},{"level":3,"anchor":"Orange","type":"heading","text":"Orange"},{"inlineContent":[{"identifier":"component_button_Orange","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Orange-Business-Tools","type":"heading","text":"Orange Business Tools"},{"inlineContent":[{"type":"image","identifier":"component_button_OrangeBusinessTools"}],"type":"paragraph"},{"level":3,"anchor":"Sosh","type":"heading","text":"Sosh"},{"inlineContent":[{"identifier":"component_button_Sosh","type":"image"}],"type":"paragraph"},{"level":3,"anchor":"Wireframe","type":"heading","text":"Wireframe"},{"inlineContent":[{"type":"image","identifier":"component_button_Wireframe"}],"type":"paragraph"},{"style":"note","name":"Version","content":[{"inlineContent":[{"type":"text","text":"3.2.0 (Figma component design version)"}],"type":"paragraph"}],"type":"aside"},{"style":"note","name":"Since","content":[{"inlineContent":[{"text":"0.10.0","type":"text"}],"type":"paragraph"}],"type":"aside"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:text:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:action:)"],"anchor":"Initializers"},{"title":"Instance Properties","generated":true,"identifiers"