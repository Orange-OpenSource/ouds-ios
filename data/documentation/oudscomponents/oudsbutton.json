{"metadata":{"title":"OUDSButton","symbolKind":"struct","navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"modules":[{"name":"Components"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OUDSButton","kind":"identifier"}],"roleHeading":"Structure","externalID":"s:14OUDSComponents10OUDSButtonV","platforms":[{"unavailable":false,"beta":false,"name":"iOS","deprecated":false,"introducedAt":"15.0"},{"unavailable":false,"beta":false,"name":"macOS","deprecated":false,"introducedAt":"15.0"},{"unavailable":false,"beta":false,"name":"tvOS","deprecated":false,"introducedAt":"16.0"},{"unavailable":false,"beta":false,"name":"visionOS","deprecated":false,"introducedAt":"1.0"},{"unavailable":false,"beta":false,"name":"watchOS","deprecated":false,"introducedAt":"11.0"}],"role":"symbol"},"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","interfaceLanguage":"swift"},"abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference"},{"type":"text","text":" proposes layout with text only, icon only or text with icon."}],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:accessibilityLabel:flipIcon:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:appearance:style:action:)","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:icon:flipIcon:appearance:style:action:)"],"anchor":"Initializers"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Appearance","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"],"generated":true,"anchor":"Enumerations","title":"Enumerations"},{"identifiers":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/OUDSComponents\/s8SendableP","doc:\/\/OUDSComponents\/s16SendableMetatypeP","doc:\/\/OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"],"kind":"mentions"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Appearances","anchor":"Appearances"},{"inlineContent":[{"text":"Five appearances are proposed for all layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"default (by default)","type":"text"}],"type":"strong"},{"type":"text","text":": Default buttons are used for actions which are not mandatory or essential for the user."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"strong","type":"text"}],"type":"strong"},{"type":"text","text":": Should be singular and prominent, limited to one per view."},{"type":"text","text":" "},{"type":"text","text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"brand","type":"text"}],"type":"strong"},{"type":"text","text":": A brand primary color alternative to the "},{"inlineContent":[{"text":"strong","type":"text"}],"type":"emphasis"},{"type":"text","text":" button."},{"type":"text","text":" "},{"type":"text","text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Appearance.Brand","type":"codeVoice"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"minimal","type":"text"}],"type":"strong"},{"type":"text","text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"negative","type":"text"}],"type":"strong"},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"type":"text","text":" "},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Appearance.Negative","type":"codeVoice"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\") { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):"}],"type":"paragraph"},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"level":2,"anchor":"Styles","type":"heading","text":"Styles"},{"inlineContent":[{"type":"text","text":"Two style are available:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default (by default)","type":"text"}]},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for  states "},{"type":"emphasis","inlineContent":[{"type":"text","text":"disabled"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"pressed","type":"text"}]},{"type":"text","text":", "},{"inlineContent":[{"text":"hovered","type":"text"}],"type":"emphasis"},{"type":"text","text":" or normal (i.e. "},{"inlineContent":[{"type":"text","text":"enabled"}],"type":"emphasis"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"type":"text","text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data."}]}]}],"type":"unorderedList"},{"level":2,"text":"Rounded layout","anchor":"Rounded-layout","type":"heading"},{"inlineContent":[{"type":"text","text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities."},{"type":"text","text":" "},{"type":"text","text":"For standard or business-oriented journeys, keep the default corners."},{"type":"text","text":" "},{"type":"text","text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To activate the rounded button behavior, set to true the "},{"code":"hasRoundedButtons","type":"codeVoice"},{"type":"text","text":" values of the "},{"code":"Tuning","type":"codeVoice"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Some themes do not have this flexibility like "},{"code":"SoshTheme","type":"codeVoice"},{"type":"text","text":" and "},{"code":"WireframeTheme","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"text":"Colored surface","anchor":"Colored-surface","type":"heading"},{"inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface."}]}],"type":"paragraph"},{"level":2,"text":"Specific behavior","anchor":"Specific-behavior","type":"heading"},{"inlineContent":[{"text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move.","type":"text"},{"type":"text","text":" "},{"text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move.","type":"text"}],"type":"paragraph"},{"text":"Design documentation","type":"heading","level":2,"anchor":"Design-documentation"},{"inlineContent":[{"identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-button","type":"reference","isActive":true}],"type":"paragraph"},{"level":2,"text":"Themes rendering","anchor":"Themes-rendering","type":"heading"},{"level":3,"text":"Orange","anchor":"Orange","type":"heading"},{"inlineContent":[{"identifier":"component_button_Orange","type":"image"}],"type":"paragraph"},{"level":3,"text":"Orange Business Tools","anchor":"Orange-Business-Tools","type":"heading"},{"inlineContent":[{"identifier":"component_button_OrangeBusinessTools","type":"image"}],"type":"paragraph"},{"level":3,"text":"Sosh","anchor":"Sosh","type":"heading"},{"inlineContent":[{"identifier":"component_button_Sosh","type":"image"}],"type":"paragraph"},{"level":3,"text":"Wireframe","anchor":"Wireframe","type":"heading"},{"inlineContent":[{"identifier":"component_button_Wireframe","type":"image"}],"type":"paragraph"},{"name":"Version","style":"note","content":[{"inlineContent":[{"text":"3.2.0 (Figma component design version)","type":"text"}],"type":"paragraph"}],"type":"aside"},{"name":"Since","style":"note","content":[{"inlineContent":[{"text":"0.10.0","type":"text"}],"type":"paragraph"}],"type":"aside"}]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbutton"]}],"kind":"symbol","r