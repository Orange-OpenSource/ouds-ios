{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"mentions","mentions":["doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Layouts","doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"]},{"kind":"content","content":[{"text":"Appearances","type":"heading","anchor":"Appearances","level":2},{"type":"paragraph","inlineContent":[{"text":"Five appearances are proposed for all layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default (by default)","type":"text"}]},{"type":"text","text":": Default buttons are used for actions which are not mandatory or essential for the user."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"strong","type":"text"}]},{"type":"text","text":": Should be singular and prominent, limited to one per view."},{"type":"text","text":" "},{"type":"text","text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc. It is a “call for action”."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"brand","type":"text"}]},{"type":"text","text":": A brand primary color alternative to the "},{"type":"emphasis","inlineContent":[{"text":"strong","type":"text"}]},{"type":"text","text":" button."},{"type":"text","text":" "},{"type":"text","text":"To be used sparingly for high-value specific actions or to visually anchor a brand moment. Do not use it as the default primary button in your interfaces."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"type":"codeVoice","code":"OUDSButton.Appearance.Brand"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"minimal"}]},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"negative"}]},{"text":": Negative buttons should be used sparingly to warn of a destructive action,","type":"text"},{"text":" ","type":"text"},{"text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"A button with "},{"code":"OUDSButton.Appearance.Negative","type":"codeVoice"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"text":"Code samples","anchor":"Code-samples","level":2,"type":"heading"},{"code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\") { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative,  style: .default) { \/* the action to process *\/ }","    \/\/ Or simpler","    OUDSButton(text: \"Delete\", appearance: .negative) { \/* the action to process *\/ }","","    \/\/ A loading button","    OUDSButton(text: \"Delete\", style: .loading) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong) { \/* the action to process *\/ }","","    \/\/ Text and icon with strong appearance and button taking full width","    OUDSButton(text: \"Validate\", icon: Image(\"ic_heart\"), appearance: .strong, isFullWidth: true) { \/* the action to process *\/ }","","    \/\/ Localizable from bundle can also be used","    OUDSButton(LocalizedStringKey(\"validate_button\"), bundle: Bundle.module, appearance: .strong) { }"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"If you need to flip your icon depending to the layout direction or not (e.g. if RTL mode lose semantics  \/ meanings):","type":"text"}],"type":"paragraph"},{"code":["    @Environment(\\.layoutDirection) var layoutDirection","","    OUDSButton(text: \"Button\",","               icon: Image(systemName: \"figure.handball\"),","               flipIcon: layoutDirection == .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"text":"Styles","type":"heading","level":2,"anchor":"Styles"},{"type":"paragraph","inlineContent":[{"text":"Two style are available:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default (by default)"}]},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for  states "},{"type":"emphasis","inlineContent":[{"type":"text","text":"disabled"}]},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"pressed"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"text":"hovered","type":"text"}],"type":"emphasis"},{"text":" or normal (i.e. ","type":"text"},{"inlineContent":[{"type":"text","text":"enabled"}],"type":"emphasis"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Rounded-layout","text":"Rounded layout","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Buttons can have rounded layouts to be favored in more emotional, immersive contexts or those tied to specific visual identities.","type":"text"},{"text":" ","type":"text"},{"text":"For standard or business-oriented journeys, keep the default corners.","type":"text"},{"text":" ","type":"text"},{"text":"This evolution addresses the need for flexibility in adapting the design to some brand contexts.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To activate the rounded button behavior, set to true the ","type":"text"},{"type":"codeVoice","code":"hasRoundedButtons"},{"text":" values of the ","type":"text"},{"type":"codeVoice","code":"Tuning"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"text":"in your theme configuration (if the theme exposes this property at init).","type":"text"},{"text":" ","type":"text"},{"text":"Some themes do not have this flexibility like ","type":"text"},{"type":"codeVoice","code":"SoshTheme"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"WireframeTheme"},{"text":".","type":"text"}]},{"anchor":"Colored-surface","text":"Colored surface","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If button is placed on colored surface using "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrome mode."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Remark: Today it is not allowed to place a Negative nor a Brand button on a colored surface.","type":"text"}]}]},{"anchor":"Specific-behavior","text":"Specific behavior","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For accessibility reasons, if the system settings for reducing motion is enabled, the loading indicator does not move."},{"type":"text","text":" "},{"type":"text","text":"For ecodesign reasons, if the device is in low power mode, the loading indicator does not move."}]},{"text":"Design documentation","type":"heading","level":2,"anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/r.orange.fr\/r\/S-ouds-doc-button","isActive":true}]},{"text":"Themes rendering","type":"heading","level":2,"anchor":"Themes-rendering"},{"text":"Orange","type":"heading","level":3,"anchor":"Orange"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Orange"}]},{"text":"Orange Compact","type":"heading","level":3,"anchor":"Orange-Compact"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_OrangeCompact"}]},{"text":"Sosh","type":"heading","level":3,"anchor":"Sosh"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Sosh"}]},{"text":"Wireframe","type":"heading","level":3,"anchor":"Wireframe"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Wireframe"}]},{"type":"aside","name":"Version","content":[{"type":"paragraph","inlineContent":[{"text":"3.2.0 (Figma component design version)","type":"text"}]}],"style":"note"},{"type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.10.0","type":"text"}]}],"style":"note"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbutton"]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","interfaceLanguage":"swift"},"abstract":[{"text":"Button is a UI element that triggers an action or event, and is used to initiate tasks or confi