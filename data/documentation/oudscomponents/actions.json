{"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"actions"}]},{"type":"text","text":"."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"heading","level":3,"anchor":"Buttons","text":"Buttons"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Orange"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_OrangeCompact"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Sosh"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_button_Wireframe"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference"},{"type":"text","text":" proposes layout with text only, icon only or text and icon."},{"type":"text","text":" "},{"type":"text","text":"Four hierarchies are proposed for all layouts: "},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"strong"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"minimal"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"negative"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Two style are available: "},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"loading"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If button is placed on colored surface using "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Appearance.Negative","type":"codeVoice"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"tabNavigator","tabs":[{"title":"SwiftUI","content":[{"type":"codeListing","syntax":"swift","code":["\/\/ Icon only with default appearance","OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","","\/\/ Text only with negative appearance","OUDSButton(text: \"Delete\", appearance: .negative) {}"]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For accessibility reasons, if the user in the system settings toggles the option to reduce the animations, the loading indicator will be frozen to be more comfortable for the user."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For ecodesign reasons, if the user toggles the low power mode, the loading indicator will be frozen to prevent the CPU to work and waste energy."}]}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/oudscomponents\/actions"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","sections":[],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"metadata":{"images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"modules":[{"name":"Components"}],"roleHeading":"Article","role":"article","title":"Actions"},"references":{"doc: