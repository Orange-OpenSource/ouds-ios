tomatically adjusted to switch to monochrom."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Appearance.Negative","type":"codeVoice"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative) {}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"For accessibility reasons, if the user in the system settings toggles the option to reduce the animations, the loading indicator will be frozen to be more comfortable for the user."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For ecodesign reasons, if the user toggles the low power mode, the loading indicator will be frozen to prevent the CPU to work and waste energy."}],"type":"paragraph"}]}],"metadata":{"title":"Actions","roleHeading":"Article","role":"article","modules":[{"name":"Components"}],"images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"kind":"article","variants":[{"paths":["\/documentation\/oudscomponents\/actions"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"},"abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"actions"}],"type":"strong"},{"text":".","type":"text"}],"references":{"component_button_OrangeCompact":{"identifier":"compon