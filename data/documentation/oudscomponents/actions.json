{"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Actions"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"anchor":"Buttons","type":"heading","level":3,"text":"Buttons"},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"type":"image","identifier":"component_button_Orange"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"type":"image","identifier":"component_button_OrangeCompact"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"type":"image","identifier":"component_button_Sosh"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_button_Wireframe"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" proposes layout with text only, icon only or text and icon."},{"type":"text","text":" "},{"type":"text","text":"Four hierarchies are proposed for all layouts: "},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"strong","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"minimal","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"negative","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Two style are available: "},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"loading","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If button is placed on colored surface using "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"type":"codeVoice","code":"OUDSButton.Appearance.Negative"},{"type":"text","text":" appearance is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}]},{"syntax":"swift","type":"codeListing","code":["    \/\/ Icon only with default appearance","    OUDSButton(icon: Image(\"ic_heart\"), accessibilityLabel: \"Like\", appearance: .default) { \/* the action to process *\/ }","","    \/\/ Text only with negative appearance","    OUDSButton(text: \"Delete\", appearance: .negative) {}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For accessibility reasons, if the user in the system settings toggles the option to reduce the animations, the loading indicator will be frozen to be more comfortable for the user."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For ecodesign reasons, if the user toggles the low power mode, the loading indicator will be frozen to prevent the CPU to work and waste energy."}]}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/actions"]}],"kind":"article","metadata":{"modules":[{"name":"Components"}],"roleHeading":"Article","title":"Actions","images":[{"type":"icon","identifier":"ic_folder_categories.png"},{"type":"card","identifier":"ic_folder_categories.png"}],"role":"article"},"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"actions"}]},{"type":"text","text":"."}],"references":{"doc://OUDSComponents/documentation/OUDSComponents/OUD