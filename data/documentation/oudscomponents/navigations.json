a default size","OUDSLink(text: \"Back\", indicator: .back, size: .default) { \/* the action to process *\/ }"]},{"type":"heading","text":"Tab bars","anchor":"Tab-bars","level":3},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}]}],"title":"Orange (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image"}]}],"title":"Sosh (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"}]}],"title":"Wireframe (Liquid Glass)"}]},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Orange_dark","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Sosh_dark","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Wireframe_dark","type":"image"}]}],"title":"Wireframe"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar"},{"type":"text","text":" provides a native SwiftUI "},{"type":"codeVoice","code":"TabView"},{"type":"text","text":" with use of OUDS effects and styles."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar"},{"type":"text","text":" lets users define their own hierarchy of views associated to tab items."}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Use the OUDS tab bar to wrap tab bar items and associated views.","\/\/ Declare a @State to hold the selected tab index, then pass it as a binding.","@State private var selectedTab = 0","","OUDSTabBar(selectedTab: $selectedTab, count: 3) {","        ","    \/\/ Add the views with the SwiftUI tab item and labels","    \/\/ No need to define colors, everything is done inside OUDSTabBar","    SomeView()","        .tabItem {","            Label(\"Label 1\", image: \"image_1\")","        }","        .tag(0)","    OtherView()","        .tabItem {","            Label(\"Label 2\", image: \"image_2\")","        }","        .tag(1)","    LastView()","        .tabItem {","            Label(\"Label 3\", image: \"image_3\")","        }","        .tag(2)","}"]},{"type":"heading","text":"Toolbars","anchor":"Toolbars","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The toolbars components provide top and bottom navigation bars. They rely on SwiftUI toolbars and expose OUDS styles."},{"type":"text","text":" "},{"type":"text","text":"Top toolbars provide a title and optional subtitle, while bottom toolbars focus on actions."}]},{"type":"paragraph","inlineContent":[{"text":"There are different style depending to Liquid Glass (iOS 26+) or not (iOS 18 and older).","type":"text"}]},{"anchor":"Top-toolbar","type":"heading","level":4,"text":"Top toolbar"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Orange_dark"}]}],"title":"Orange (Liquid Glass)"},{"title":"Orange Compact (Liquid Glass)","content":[{"inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_dark","type":"image"}],"type":"paragraph"}]},{"title":"Sosh (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_LiquidGlass_Sosh_dark","type":"image"}]}]},{"content":[{"inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_dark","type":"image"}],"type":"paragraph"}],"title":"Wireframe (Liquid Glass)"}]},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_Orange_dark","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_OrangeCompact_dark"}]}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_Wireframe_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_Wireframe_dark","type":"image"}]}],"title":"Wireframe"}]},{"code":["\/\/ Apply once on the root NavigationStack to style the system navigation bar","NavigationStack {","    SomeView()","        .toolBarTop(\"Title\",","                    leadingItems: {","                        \/\/ Back button — system dismiss is automatic, no closure needed","                        OUDSToolBarItem(navigation: .back())","                    },","                    trailingItems: {","                        OUDSToolBarItem(label: \"Label\") { \/* Action to process *\/ }","                        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","                    })","}",".oudsNavigationBarAppearance() \/\/ required — apply on the NavigationStack, not on the child view","","\/\/ Close button — .close takes NO closure, dismiss is handled automatically","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .close)","                })","","\/\/ Back button with a visible label (label text is ignored on iOS 26+ \/ Liquid Glass)","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Cancel\"))","                })","","\/\/ Back button with custom action executed before automatic dismiss","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Back\") { saveDraft() })","                })","","\/\/ On iOS ≤ 18, add on the root view to color the system back-button chevron correctly",".accentColor(theme.colors.contentDefault)"],"syntax":"swift","type":"codeListing"},{"anchor":"Bottom-toolbar","type":"heading","level":4,"text":"Bottom toolbar"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_LiquidGlass_Orange_dark","type":"image"}]}],"title":"Orange (Liquid Glass)"},{"title":"Orange Compact (Liquid Glass)","content":[{"inlineContent":[{"identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_dark","type":"image"}],"type":"paragraph"}]},{"title":"Sosh (Liquid Glass)","content":[{"inlineContent":[{"identifier":"component_toolBarBottom_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_LiquidGlass_Sosh_dark","type":"image"}],"type":"paragraph"}]},{"title":"Wireframe (Liquid Glass)","content":[{"inlineContent":[{"identifier":"component_toolBarBottom_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_LiquidGlass_Wireframe_dark","type":"image"}],"type":"paragraph"}]}]},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_Orange_dark","type":"image"}]}]},{"title":"Orange Compact","content":[{"inlineContent":[{"identifier":"component_toolBarBottom_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_OrangeCompact_dark","type":"image"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_Sosh_light"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_Sosh_dark","type":"image"}],"type":"paragraph"}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_Wireframe_dark","type":"image"}]}]}]},{"code":["\/\/ Leading + trailing split — works on all supported OS versions","SomeView()","    .toolBarBottom(leadingItems: {","        OUDSToolBarItem(label: \"Some label\") { \/* Action to process *\/ }","    }, trailingItems: {","        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","    })","","\/\/ Grouped \/ centered — meaningful on iOS 26+ (Liquid Glass) only","\/\/ On earlier OS versions the system splits the items into leading\/trailing positions.","SomeView()","    .toolBarBottom(groupedItems: {","        OUDSToolBarItem(label: \"Save\") { \/* Action to process *\/ }","        OUDSToolBarItem(icon: Image(decorative: \"ic_delete\"), accessibilityLabel: \"Delete\") { \/* Action to process *\/ }","    })"],"syntax":"swift","type":"codeListing"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"type":"text","text":"navigation"}]},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/oudscomponents\/navigations"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations","interfaceLanguage":"swift"},"kind":"article","references":{"component_tabBar_OrangeCompact_light":{"type":"image","alt":"A tab bar component without Liquid Glass in light mode with Orange Compact theme","identifier":"component_tabBar_OrangeCompact_light","variants":[{"url":"\/images\/OUDSComponents\/component_tabBar_OrangeCompact_light.png","traits":["1x","light"]}]},"component_toolBarBottom_OrangeCompact_light":{"type":"image","alt":"