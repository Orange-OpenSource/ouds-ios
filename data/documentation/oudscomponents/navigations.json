xt"},{"type":"codeVoice","code":"default"},{"text":" size.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Text only in small size","OUDSLink(text: \"Feedback\", size: .small) { \/* the action to process *\/ }","","\/\/ Text and icon in default size","OUDSLink(text: \"Feedback\", icon: Image(\"ic_heart\"), size: .default) { \/* the action to process *\/ }","","\/\/ Navigate to previous page with link in a default size","OUDSLink(text: \"Back\", indicator: .back, size: .default) { \/* the action to process *\/ }"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"Tab bars","anchor":"Tab-bars"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}]}],"title":"Orange (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image"}]}],"title":"Sosh (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"}]}],"title":"Wireframe (Liquid Glass)"}],"type":"tabNavigator"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_Orange_dark","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_Sosh_dark","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Wireframe_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_Wireframe_dark","type":"image"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","isActive":true,"type":"reference"},{"text":" provides a native SwiftUI ","type":"text"},{"type":"codeVoice","code":"TabView"},{"text":" with use of OUDS effects and styles.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","isActive":true,"type":"reference"},{"text":" lets users define their own hierarchy of views associated to tab items.","type":"text"}],"type":"paragraph"},{"code":["\/\/ Use the OUDS tab bar to wrap tab bar items and associated views.","\/\/ Declare a @State to hold the selected tab index, then pass it as a binding.","@State private var selectedTab = 0","","OUDSTabBar(selectedTab: $selectedTab, count: 3) {","        ","    \/\/ Add the views with the SwiftUI tab item and labels","    \/\/ No need to define colors, everything is done inside OUDSTabBar","    SomeView()","        .tabItem {","            Label(\"Label 1\", image: \"image_1\")","        }","        .tag(0)","    OtherView()","        .tabItem {","            Label(\"Label 2\", image: \"image_2\")","        }","        .tag(1)","    LastView()","        .tabItem {","            Label(\"Label 3\", image: \"image_3\")","        }","        .tag(2)","}"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"Toolbars","anchor":"Toolbars"},{"inlineContent":[{"text":"The toolbars components provide top and bottom navigation bars. They rely on SwiftUI toolbars and expose OUDS styles.","type":"text"},{"text":" ","type":"text"},{"text":"Top toolbars (","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSToolBarTop","isActive":true,"type":"reference"},{"text":") provide a title and optional subtitle, while bottom toolbars (","type":"text"},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSToolBarBottom","isActive":true,"type":"reference"},{"text":") focus on actions.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"There are different style depending to Liquid Glass (iOS 26+) or not (iOS 18 and older).","type":"text"}],"type":"paragraph"},{"level":4,"type":"heading","text":"Top toolbar","anchor":"Top-toolbar"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_LiquidGlass_Orange_dark","type":"image"}]}],"title":"Orange (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_LiquidGlass_Sosh_dark","type":"image"}]}],"title":"Sosh (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_dark","type":"image"}]}],"title":"Wireframe (Liquid Glass)"}],"type":"tabNavigator"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_Orange_dark","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_Sosh_dark","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_Wireframe_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_Wireframe_dark","type":"image"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"code":["\/\/ Apply once on the root NavigationStack to style the system navigation bar","NavigationStack {","    SomeView()","        .toolBarTop(\"Title\",","                    leadingItems: {","                        \/\/ Back button — system dismiss is automatic, no closure needed","                        OUDSToolBarItem(navigation: .back())","                    },","                    trailingItems: {","                        OUDSToolBarItem(label: \"Label\") { \/* Action to process *\/ }","                        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","                    })","}",".oudsNavigationBarAppearance() \/\/ required — apply on the NavigationStack, not on the child view","","\/\/ Close button — .close takes NO closure, dismiss is handled automatically","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .close)","                })","","\/\/ Back button with a visible label (label text is ignored on iOS 26+ \/ Liquid Glass)","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Cancel\"))","                })","","\/\/ Back button with custom action executed before automatic dismiss","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Back\") { saveDraft() })","                })","","\/\/ On iOS ≤ 18, add on the root view to color the system back-button chevron correctly",".accentColor(theme.colors.contentDefault)"],"type":"codeListing","syntax":"swift"},{"level":4,"type":"heading","text":"Bottom toolbar","anchor":"Bottom-toolbar"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_LiquidGlass_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarBottom_LiquidGlass_Orange_dark","type":"image"}]}],"title":"Orange (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_LiquidGlass_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarBottom_LiquidGlass_Sosh_dark","type":"image"}]}],"title":"Sosh (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_LiquidGlass_Wireframe_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarBottom_LiquidGlass_Wireframe_dark","type":"image"}]}],"title":"Wireframe (Liquid Glass)"}],"type":"tabNavigator"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarBottom_Orange_dark","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarBottom_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarBottom_Sosh_dark","type":"image"}]}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_Wireframe_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarBottom_Wireframe_dark","type":"image"}]}],"title":"Wireframe"}],"type":"tabNavigator"},{"code":["\/\/ Leading + trailing split — works on all supported OS versions","SomeView()","    .toolBarBottom(leadingItems: {","        OUDSToolBarItem(label: \"Some label\") { \/* Action to process *\/ }","    }, trailingItems: {","        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","    })","","\/\/ Grouped \/ centered — meaningful on iOS 26+ (Liquid Glass) only","\/\/ On earlier OS versions the system splits the items into leading\/trailing positions.","SomeView()","    .toolBarBottom(groupedItems: {","        OUDSToolBarItem(label: \"Save\") { \/* Action to process *\/ }","        OUDSToolBarItem(icon: Image(decorative: \"ic_delete\"), accessibilityLabel: \"Delete\") { \/* Action to process *\/ }","    })"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"references":{"component_link_OrangeCompact":{"alt":"A link component in light and dark m