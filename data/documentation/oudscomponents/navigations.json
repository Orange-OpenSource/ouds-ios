fault) { \/* the action to process *\/ }"]},{"type":"heading","level":3,"anchor":"Tab-bars","text":"Tab bars"},{"type":"tabNavigator","tabs":[{"title":"Orange (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_dark"}]}]},{"title":"Orange Compact (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark"}]}]},{"title":"Sosh (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark"}]}]},{"title":"Wireframe (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark"}]}]}]},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Orange_dark"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_OrangeCompact_dark"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Sosh_dark"}]}]},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Wireframe_dark"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","type":"reference","isActive":true},{"type":"text","text":" provides a native SwiftUI "},{"type":"codeVoice","code":"TabView"},{"type":"text","text":" with use of OUDS effects and styles."},{"type":"text","text":" "},{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","type":"reference","isActive":true},{"type":"text","text":" lets users define their own hierarchy of views associated to tab items."}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Use the OUDS tab bar to wrap tab bar items and associated views.","\/\/ Declare a @State to hold the selected tab index, then pass it as a binding.","@State private var selectedTab = 0","","OUDSTabBar(selectedTab: $selectedTab, count: 3) {","        ","    \/\/ Add the views with the SwiftUI tab item and labels","    \/\/ No need to define colors, everything is done inside OUDSTabBar","    SomeView()","        .tabItem {","            Label(\"Label 1\", image: \"image_1\")","        }","        .tag(0)","    OtherView()","        .tabItem {","            Label(\"Label 2\", image: \"image_2\")","        }","        .tag(1)","    LastView()","        .tabItem {","            Label(\"Label 3\", image: \"image_3\")","        }","        .tag(2)","}"]},{"type":"heading","level":3,"anchor":"Toolbars","text":"Toolbars"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The toolbars components provide top and bottom navigation bars. They rely on SwiftUI toolbars and expose OUDS styles."},{"type":"text","text":" "},{"type":"text","text":"Top toolbars provide a title and optional subtitle, while bottom toolbars focus on actions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are different style depending to Liquid Glass (iOS 26+) or not (iOS 18 and older)."}]},{"type":"heading","level":4,"anchor":"Top-toolbar","text":"Top toolbar"},{"type":"tabNavigator","tabs":[{"title":"Orange (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Orange_dark"}]}]},{"title":"Orange Compact (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_dark"}]}]},{"title":"Sosh (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Sosh_dark"}]}]},{"title":"Wireframe (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Wireframe_dark"}]}]}]},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Orange_dark"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_OrangeCompact_dark"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Sosh_dark"}]}],"title":"Sosh"},{"title":"Wireframe","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Wireframe_dark"}]}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Apply once on the root NavigationStack to style the system navigation bar","NavigationStack {","    SomeView()","        .toolBarTop(\"Title\",","                    leadingItems: {","                        \/\/ Back button — system dismiss is automatic, no closure needed","                        OUDSToolBarItem(navigation: .back())","                    },","                    trailingItems: {","                        OUDSToolBarItem(label: \"Label\") { \/* Action to process *\/ }","                        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","                    })","}",".oudsNavigationBarAppearance() \/\/ required — apply on the NavigationStack, not on the child view","","\/\/ Close button — .close takes NO closure, dismiss is handled automatically","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .close)","                })","","\/\/ Back button with a visible label (label text is ignored on iOS 26+ \/ Liquid Glass)","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Cancel\"))","                })","","\/\/ Back button with custom action executed before automatic dismiss","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Back\") { saveDraft() })","                })","","\/\/ On iOS ≤ 18, add on the root view to color the system back-button chevron correctly",".accentColor(theme.colors.contentDefault)"]},{"type":"heading","level":4,"anchor":"Bottom-toolbar","text":"Bottom toolbar"},{"type":"tabNavigator","tabs":[{"title":"Orange (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Orange_dark"}]}]},{"title":"Orange Compact (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_dark"}]}]},{"title":"Sosh (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Sosh_dark"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Wireframe_dark"}]}],"title":"Wireframe (Liquid Glass)"}]},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_Orange_dark"}]}]},{"title":"Orange Compact","content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_OrangeCompact_dark"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh"},{"title":"Wir