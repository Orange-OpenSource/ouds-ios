{"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"text":"Links","anchor":"Links","level":3,"type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_link_Orange"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_link_OrangeCompact"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_link_Sosh"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_link_Wireframe"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"type":"text","text":" proposes layout with text only or text with icon."},{"type":"text","text":" "},{"type":"text","text":"It also proposes layout to navigate forward or backward."},{"type":"text","text":" "},{"type":"text","text":"The link can be displayed in "},{"type":"codeVoice","code":"small"},{"type":"text","text":" or "},{"type":"codeVoice","code":"default"},{"type":"text","text":" size."}],"type":"paragraph"},{"code":["\/\/ Text only in small size","OUDSLink(text: \"Feedback\", size: .small) { \/* the action to process *\/ }","","\/\/ Text and icon in default size","OUDSLink(text: \"Feedback\", icon: Image(\"ic_heart\"), size: .default) { \/* the action to process *\/ }","","\/\/ Navigate to previous page with link in a default size","OUDSLink(text: \"Back\", indicator: .back, size: .default) { \/* the action to process *\/ }"],"type":"codeListing","syntax":"swift"},{"text":"Tab bars","anchor":"Tab-bars","level":3,"type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Orange_dark"}],"type":"paragraph"}],"title":"Orange (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark"}],"type":"paragraph"}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark"}],"type":"paragraph"}],"title":"Wireframe (Liquid Glass)"}],"type":"tabNavigator"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Orange_dark"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_OrangeCompact_dark"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Wireframe_dark"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","type":"reference","isActive":true},{"type":"text","text":" provides a native SwiftUI "},{"type":"codeVoice","code":"TabView"},{"type":"text","text":" with use of OUDS effects and styles."},{"type":"text","text":" "},{"type":"text","text":"The "},{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","type":"reference","isActive":true},{"type":"text","text":" lets users define their own hierarchy of views associated to tab items."}],"type":"paragraph"},{"code":["\/\/ Use the OUDS tab bar to wrap tab bar items and associated views.","\/\/ Declare a @State to hold the selected tab index, then pass it as a binding.","@State private var selectedTab = 0","","OUDSTabBar(selectedTab: $selectedTab, count: 3) {","        ","    \/\/ Add the views with the SwiftUI tab item and labels","    \/\/ No need to define colors, everything is done inside OUDSTabBar","    SomeView()","        .tabItem {","            Label(\"Label 1\", image: \"image_1\")","        }","        .tag(0)","    OtherView()","        .tabItem {","            Label(\"Label 2\", image: \"image_2\")","        }","        .tag(1)","    LastView()","        .tabItem {","            Label(\"Label 3\", image: \"image_3\")","        }","        .tag(2)","}"],"type":"codeListing","syntax":"swift"},{"text":"Toolbars","anchor":"Toolbars","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The toolbars components provide top and bottom navigation bars. They rely on SwiftUI toolbars and expose OUDS styles."},{"type":"text","text":" "},{"type":"text","text":"Top toolbars provide a title and optional subtitle, while bottom toolbars focus on actions."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"There are different style depending to Liquid Glass (iOS 26+) or not (iOS 18 and older)."}],"type":"paragraph"},{"text":"Top toolbar","anchor":"Top-toolbar","level":4,"type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Orange_dark"}],"type":"paragraph"}],"title":"Orange (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_dark"}],"type":"paragraph"}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Wireframe_dark"}],"type":"paragraph"}],"title":"Wireframe (Liquid Glass)"}],"type":"tabNavigator"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Orange_dark"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_OrangeCompact_dark"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Wireframe_dark"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"code":["\/\/ Apply once on the root NavigationStack to style the system navigation bar","NavigationStack {","    SomeView()","        .toolBarTop(\"Title\",","                    leadingItems: {","                        \/\/ Back button — system dismiss is automatic, no closure needed","                        OUDSToolBarItem(navigation: .back())","                    },","                    trailingItems: {","                        OUDSToolBarItem(label: \"Label\") { \/* Action to process *\/ }","                        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","                    })","}",".oudsNavigationBarAppearance() \/\/ required — apply on the NavigationStack, not on the child view","","\/\/ Close button — .close takes NO closure, dismiss is handled automatically","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .close)","                })","","\/\/ Back button with a visible label (label text is ignored on iOS 26+ \/ Liquid Glass)","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Cancel\"))","                })","","\/\/ Back button with custom action executed before automatic dismiss","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Back\") { saveDraft() })","                })","","\/\/ On iOS ≤ 18, add on the root view to color the system back-button chevron correctly",".accentColor(theme.colors.contentDefault)"],"type":"codeListing","syntax":"swift"},{"text":"Bottom toolbar","anchor":"Bottom-toolbar","level":4,"type":"heading"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Orange_dark"}],"type":"paragraph"}],"title":"Orange (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_dark"}],"type":"paragraph"}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Wireframe_dark"}],"type":"paragraph"}],"title":"Wireframe (Liquid Glass)"}],"type":"tabNavigator"},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_Orange_dark"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_OrangeCompact_dark"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_Wireframe_dark"}],"type":"paragraph"}],"title":"Wireframe"}],"type":"tabNavigator"},{"code":["\/\/ Leading + trailing split — works on all supported OS versions","SomeView()","    .toolBarBottom(leadingItems: {","        OUDSToolBarItem(label: \"Some label\") { \/* Action to process *\/ }","    }, trailingItems: {","        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","    })","","\/\/ Grouped \/ centered — meaningful on iOS 26+ (Liquid Glass) only","\/\/ On earlier OS versions the system splits the items into leading\/trailing positions.","SomeView()","    .toolBarBottom(groupedItems: {","        OUDSToolBarItem(label: \"Save\") { \/* Action to process *\/ }","        OUDSToolBarItem(icon: Image(decorative: \"ic_delete\"), accessibilityLabel: \"Delete\") { \/* Action to process *\/ }","    })"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/navigations"]}],"kind":"article","sections":[],"abstract":[{"type":"text","text":"Some components can be used for "},{"type":"strong","inlineContent":[{"text":"navigation","type":"text"}]},{"type":"text","text":"."}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"Components"}],"title":"Navigations","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"roleHeading":"Article","role":"article"},"references":{"component_toolBarTop_LiquidGlass_OrangeCompact_dark":{"identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_dark","type":"image","alt":"A toolbar top component with Liquid Glass in dark mode with Orange Compact theme","variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_toolBarTop_LiquidGlass_OrangeCompact_dark.png"}]},"component_toolBarBottom