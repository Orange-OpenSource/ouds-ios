fault size","OUDSLink(text: \"Feedback\", icon: Image(\"ic_heart\"), size: .default) { \/* the action to process *\/ }","","\/\/ Navigate to previous page with link in a default size","OUDSLink(text: \"Back\", indicator: .back, size: .default) { \/* the action to process *\/ }"],"syntax":"swift","type":"codeListing"},{"text":"Tab bars","level":3,"anchor":"Tab-bars","type":"heading"},{"tabs":[{"title":"Orange (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}]}]},{"title":"Orange Compact (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image"}]}]},{"title":"Sosh (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image"}]}]},{"title":"Wireframe (Liquid Glass)","content":[{"inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_LiquidGlass_Wireframe_dark"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Orange_dark"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Sosh_dark","type":"image"}]}],"title":"Sosh"},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_Wireframe_dark"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","type":"reference"},{"type":"text","text":" provides a native SwiftUI "},{"code":"TabView","type":"codeVoice"},{"type":"text","text":" with use of OUDS effects and styles."},{"type":"text","text":" "},{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","type":"reference"},{"type":"text","text":" lets users define their own hierarchy of views associated to tab items."}],"type":"paragraph"},{"code":["\/\/ Use the OUDS tab bar to wrap tab bar items and associated views.","\/\/ Declare a @State to hold the selected tab index, then pass it as a binding.","@State private var selectedTab = 0","","OUDSTabBar(selectedTab: $selectedTab, count: 3) {","        ","    \/\/ Add the views with the SwiftUI tab item and labels","    \/\/ No need to define colors, everything is done inside OUDSTabBar","    SomeView()","        .tabItem {","            Label(\"Label 1\", image: \"image_1\")","        }","        .tag(0)","    OtherView()","        .tabItem {","            Label(\"Label 2\", image: \"image_2\")","        }","        .tag(1)","    LastView()","        .tabItem {","            Label(\"Label 3\", image: \"image_3\")","        }","        .tag(2)","}"],"syntax":"swift","type":"codeListing"},{"text":"Toolbars","level":3,"anchor":"Toolbars","type":"heading"},{"inlineContent":[{"type":"text","text":"The toolbars components provide top and bottom navigation bars. They rely on SwiftUI toolbars and expose OUDS styles."},{"type":"text","text":" "},{"text":"Top toolbars provide a title and optional subtitle, while bottom toolbars focus on actions.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"There are different style depending to Liquid Glass (iOS 26+) or not (iOS 18 and older)."}],"type":"paragraph"},{"level":4,"anchor":"Top-toolbar","type":"heading","text":"Top toolbar"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_LiquidGlass_Orange_dark","type":"image"}],"type":"paragraph"}],"title":"Orange (Liquid Glass)"},{"content":[{"inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_dark","type":"image"}],"type":"paragraph"}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_LiquidGlass_Sosh_dark","type":"image"}],"type":"paragraph"}],"title":"Sosh (Liquid Glass)"},{"content":[{"inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_dark","type":"image"}],"type":"paragraph"}],"title":"Wireframe (Liquid Glass)"}]},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"identifier":"component_toolBarTop_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_Orange_dark","type":"image"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"inlineContent":[{"identifier":"component_toolBarTop_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_OrangeCompact_dark","type":"image"}],"type":"paragraph"}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"identifier":"component_toolBarTop_Sosh_light","type":"image"},{"text":" ","type":"text"},{"type":"image","identifier":"component_toolBarTop_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Wireframe_dark"}],"type":"paragraph"}],"title":"Wireframe"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Apply once on the root NavigationStack to style the system navigation bar","NavigationStack {","    SomeView()","        .toolBarTop(\"Title\",","                    leadingItems: {","                        \/\/ Back button — system dismiss is automatic, no closure needed","                        OUDSToolBarItem(navigation: .back())","                    },","                    trailingItems: {","                        OUDSToolBarItem(label: \"Label\") { \/* Action to process *\/ }","                        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","                    })","}",".oudsNavigationBarAppearance() \/\/ required — apply on the NavigationStack, not on the child view","","\/\/ Close button — .close takes NO closure, dismiss is handled automatically","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .close)","                })","","\/\/ Back button with a visible label (label text is ignored on iOS 26+ \/ Liquid Glass)","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Cancel\"))","                })","","\/\/ Back button with custom action executed before automatic dismiss","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Back\") { saveDraft() })","                })","","\/\/ On iOS ≤ 18, add on the root view to color the system back-button chevron correctly",".accentColor(theme.colors.contentDefault)"]},{"anchor":"Bottom-toolbar","text":"Bottom toolbar","type":"heading","level":4},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Orange_dark"}],"type":"paragraph"}],"title":"Orange (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_dark"}],"type":"paragraph"}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh (Liquid Glass)"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Wireframe_dark"}],"type":"paragraph"}],"title":"Wireframe (Liquid Glass)"}]},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_Orange_dark","type":"image"}]}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarBottom_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_Sosh_dark"}],"type":"paragraph"}],"title":"Sosh"},{"title":"Wireframe","content":[{"inlineContent":[{"identifier":"component_toolBarBottom_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"type":"image","identifier":"component_toolBarBottom_Wireframe_dark"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Leading + trailing split — works on all supported OS versions","SomeView()","    .toolBarBottom(leadingItems: {","        OUDSToolBarItem(label: \"Some label\") { \/* Action to process *\/ }","    }, trailingItems: {","        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","    })","","\/\/ Grouped \/ centered — meaningful on iOS 26+ (Liquid Glass) only","\/\/ On earlier OS versions the system splits the items into leading\/trailing positions.","SomeView()","    .toolBarBottom(groupedItems: {","        OUDSToolBarItem(label: \"Save\") { \/* Action to process *\/ }","        OUDSToolBarItem(icon: Image(decorative: \"ic_delete\"), accessibilityLabel: \"Delete\") { \/* Action to process *\/ }","    })"]}]}],"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/navigations"]}],"hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"references":{"component_toolBarBottom_LiquidGlass_Wireframe_light":{"identifier":"component_toolBarBottom_LiquidGlass_Wireframe_light","type":"image","alt":"A toolbar bottom component with Liquid Glass in light mode with Wireframe theme","variants":[{"url":"\/images\/OUDSComponents\/component_toolBarBottom_LiquidGlass_Wireframe_light.png","traits":["1x","light"]}]},"component_toolBarTop_Liq