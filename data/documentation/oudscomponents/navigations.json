xt"},{"type":"image","identifier":"component_tabBar_Wireframe_dark"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","isActive":true},{"type":"text","text":" provides a native SwiftUI "},{"type":"codeVoice","code":"TabView"},{"text":" with use of OUDS effects and styles.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","isActive":true},{"type":"text","text":" lets users define their own hierarchy of views associated to tab items."}]},{"syntax":"swift","code":["\/\/ Use the OUDS tab bar to wrap tab bar items and associated views.","\/\/ Declare a @State to hold the selected tab index, then pass it as a binding.","@State private var selectedTab = 0","","OUDSTabBar(selectedTab: $selectedTab, count: 3) {","        ","    \/\/ Add the views with the SwiftUI tab item and labels","    \/\/ No need to define colors, everything is done inside OUDSTabBar","    SomeView()","        .tabItem {","            Label(\"Label 1\", image: \"image_1\")","        }","        .tag(0)","    OtherView()","        .tabItem {","            Label(\"Label 2\", image: \"image_2\")","        }","        .tag(1)","    LastView()","        .tabItem {","            Label(\"Label 3\", image: \"image_3\")","        }","        .tag(2)","}"],"type":"codeListing"},{"type":"heading","level":3,"text":"Toolbars","anchor":"Toolbars"},{"inlineContent":[{"text":"The toolbars components provide top and bottom navigation bars. They rely on SwiftUI toolbars and expose OUDS styles.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Top toolbars provide a title and optional subtitle, while bottom toolbars focus on actions."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"There are different style depending to Liquid Glass (iOS 26+) or not (iOS 18 and older).","type":"text"}]},{"level":4,"text":"Top toolbar","type":"heading","anchor":"Top-toolbar"},{"tabs":[{"title":"Orange (Liquid Glass)","content":[{"inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Orange_light","type":"image"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Orange_dark"}],"type":"paragraph"}]},{"title":"Orange Compact (Liquid Glass)","content":[{"inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_dark","type":"image"}],"type":"paragraph"}]},{"title":"Sosh (Liquid Glass)","content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Sosh_dark"}],"type":"paragraph"}]},{"title":"Wireframe (Liquid Glass)","content":[{"inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_dark","type":"image"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"tabs":[{"title":"Orange","content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Orange_dark"}],"type":"paragraph"}]},{"title":"Orange Compact","content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_OrangeCompact_dark"}],"type":"paragraph"}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_Sosh_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_Sosh_dark","type":"image"}]}]},{"title":"Wireframe","content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_Wireframe_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Wireframe_dark"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"code":["\/\/ Apply once on the root NavigationStack to style the system navigation bar","NavigationStack {","    SomeView()","        .toolBarTop(\"Title\",","                    leadingItems: {","                        \/\/ Back button — system dismiss is automatic, no closure needed","                        OUDSToolBarItem(navigation: .back())","                    },","                    trailingItems: {","                        OUDSToolBarItem(label: \"Label\") { \/* Action to process *\/ }","                        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","                    })","}",".oudsNavigationBarAppearance() \/\/ required — apply on the NavigationStack, not on the child view","","\/\/ Close button — .close takes NO closure, dismiss is handled automatically","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .close)","                })","","\/\/ Back button with a visible label (label text is ignored on iOS 26+ \/ Liquid Glass)","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Cancel\"))","                })","","\/\/ Back button with custom action executed before automatic dismiss","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Back\") { saveDraft() })","                })","","\/\/ On iOS ≤ 18, add on the root view to color the system back-button chevron correctly",".accentColor(theme.colors.contentDefault)"],"type":"codeListing","syntax":"swift"},{"type":"heading",