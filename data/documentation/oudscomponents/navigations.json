{"metadata":{"title":"Navigations","images":[{"identifier":"ic_folder_categories.png","type":"icon"},{"identifier":"ic_folder_categories.png","type":"card"}],"modules":[{"name":"Components"}],"roleHeading":"Article","role":"article"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Some components can be used for "},{"inlineContent":[{"text":"navigation","type":"text"}],"type":"strong"},{"type":"text","text":"."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/navigations"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/Navigations"},"kind":"article","hierarchy":{"paths":[["doc:\/\/OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"heading","level":3,"text":"Links","anchor":"Links"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_link_Orange"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_link_OrangeCompact"}]}],"title":"Orange Compact"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_link_Sosh"}]}],"title":"Sosh"},{"content":[{"inlineContent":[{"identifier":"component_link_Wireframe","type":"image"}],"type":"paragraph"}],"title":"Wireframe"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference"},{"text":" proposes layout with text only or text with icon.","type":"text"},{"text":" ","type":"text"},{"text":"It also proposes layout to navigate forward or backward.","type":"text"},{"text":" ","type":"text"},{"text":"The link can be displayed in ","type":"text"},{"code":"small","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"default","type":"codeVoice"},{"type":"text","text":" size."}]},{"syntax":"swift","code":["\/\/ Text only in small size","OUDSLink(text: \"Feedback\", size: .small) { \/* the action to process *\/ }","","\/\/ Text and icon in default size","OUDSLink(text: \"Feedback\", icon: Image(\"ic_heart\"), size: .default) { \/* the action to process *\/ }","","\/\/ Navigate to previous page with link in a default size","OUDSLink(text: \"Back\", indicator: .back, size: .default) { \/* the action to process *\/ }"],"type":"codeListing"},{"type":"heading","anchor":"Tab-bars","text":"Tab bars","level":3},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Orange_dark","type":"image"}]}],"title":"Orange (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_LiquidGlass_OrangeCompact_dark","type":"image"}]}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Sosh_dark","type":"image"}]}],"title":"Sosh (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_tabBar_LiquidGlass_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_LiquidGlass_Wireframe_dark","type":"image"}]}],"title":"Wireframe (Liquid Glass)"}],"type":"tabNavigator"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"identifier":"component_tabBar_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_tabBar_Orange_dark","type":"image"}],"type":"paragraph"}],"title":"Orange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_tabBar_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_tabBar_OrangeCompact_dark"}]}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"type":"image","identifier":"component_tabBar_Sosh_light"},{"type":"text","text":" "},{"identifier":"component_tabBar_Sosh_dark","type":"image"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"inlineContent":[{"identifier":"component_tabBar_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_tabBar_Wireframe_dark","type":"image"}],"type":"paragraph"}],"title":"Wireframe"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar","isActive":true},{"type":"text","text":" provides a native SwiftUI "},{"code":"TabView","type":"codeVoice"},{"type":"text","text":" with use of OUDS effects and styles."},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSTabBar"},{"text":" lets users define their own hierarchy of views associated to tab items.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Use the OUDS tab bar to wrap tab bar items and associated views.","\/\/ Declare a @State to hold the selected tab index, then pass it as a binding.","@State private var selectedTab = 0","","OUDSTabBar(selectedTab: $selectedTab, count: 3) {","        ","    \/\/ Add the views with the SwiftUI tab item and labels","    \/\/ No need to define colors, everything is done inside OUDSTabBar","    SomeView()","        .tabItem {","            Label(\"Label 1\", image: \"image_1\")","        }","        .tag(0)","    OtherView()","        .tabItem {","            Label(\"Label 2\", image: \"image_2\")","        }","        .tag(1)","    LastView()","        .tabItem {","            Label(\"Label 3\", image: \"image_3\")","        }","        .tag(2)","}"]},{"type":"heading","level":3,"anchor":"Toolbars","text":"Toolbars"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The toolbars components provide top and bottom navigation bars. They rely on SwiftUI toolbars and expose OUDS styles."},{"type":"text","text":" "},{"type":"text","text":"Top toolbars provide a title and optional subtitle, while bottom toolbars focus on actions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are different style depending to Liquid Glass (iOS 26+) or not (iOS 18 and older)."}]},{"text":"Top toolbar","anchor":"Top-toolbar","type":"heading","level":4},{"tabs":[{"content":[{"inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Orange_dark"}],"type":"paragraph"}],"title":"Orange (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_OrangeCompact_dark"}]}],"title":"Orange Compact (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_LiquidGlass_Sosh_dark"}]}],"title":"Sosh (Liquid Glass)"},{"title":"Wireframe (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_LiquidGlass_Wireframe_dark","type":"image"}]}]}],"type":"tabNavigator"},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_Orange_light","type":"image"},{"type":"text","text":" "},{"identifier":"component_toolBarTop_Orange_dark","type":"image"}]}]},{"title":"Orange Compact","content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarTop_OrangeCompact_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_OrangeCompact_dark","type":"image"}]}]},{"title":"Sosh","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarTop_Sosh_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarTop_Sosh_dark"}]}]},{"title":"Wireframe","content":[{"inlineContent":[{"identifier":"component_toolBarTop_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarTop_Wireframe_dark","type":"image"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Apply once on the root NavigationStack to style the system navigation bar","NavigationStack {","    SomeView()","        .toolBarTop(\"Title\",","                    leadingItems: {","                        \/\/ Back button — system dismiss is automatic, no closure needed","                        OUDSToolBarItem(navigation: .back())","                    },","                    trailingItems: {","                        OUDSToolBarItem(label: \"Label\") { \/* Action to process *\/ }","                        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","                    })","}",".oudsNavigationBarAppearance() \/\/ required — apply on the NavigationStack, not on the child view","","\/\/ Close button — .close takes NO closure, dismiss is handled automatically","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .close)","                })","","\/\/ Back button with a visible label (label text is ignored on iOS 26+ \/ Liquid Glass)","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Cancel\"))","                })","","\/\/ Back button with custom action executed before automatic dismiss","SomeView()","    .toolBarTop(\"Title\",","                leadingItems: {","                    OUDSToolBarItem(navigation: .back(label: \"Back\") { saveDraft() })","                })","","\/\/ On iOS ≤ 18, add on the root view to color the system back-button chevron correctly",".accentColor(theme.colors.contentDefault)"]},{"type":"heading","text":"Bottom toolbar","level":4,"anchor":"Bottom-toolbar"},{"type":"tabNavigator","tabs":[{"title":"Orange (Liquid Glass)","content":[{"inlineContent":[{"identifier":"component_toolBarBottom_LiquidGlass_Orange_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_LiquidGlass_Orange_dark","type":"image"}],"type":"paragraph"}]},{"title":"Orange Compact (Liquid Glass)","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_OrangeCompact_dark"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Sosh_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Sosh_dark"}]}],"title":"Sosh (Liquid Glass)"},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Wireframe_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_toolBarBottom_LiquidGlass_Wireframe_dark"}]}],"title":"Wireframe (Liquid Glass)"}]},{"type":"tabNavigator","tabs":[{"title":"Orange","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_Orange_light"},{"type":"text","text":" "},{"type":"image","identifier":"component_toolBarBottom_Orange_dark"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"component_toolBarBottom_OrangeCompact_light"},{"text":" ","type":"text"},{"type":"image","identifier":"component_toolBarBottom_OrangeCompact_dark"}]}],"title":"Orange Compact"},{"content":[{"inlineContent":[{"identifier":"component_toolBarBottom_Sosh_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_Sosh_dark","type":"image"}],"type":"paragraph"}],"title":"Sosh"},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"component_toolBarBottom_Wireframe_light","type":"image"},{"text":" ","type":"text"},{"identifier":"component_toolBarBottom_Wireframe_dark","type":"image"}]}],"title":"Wireframe"}]},{"code":["\/\/ Leading + trailing split — works on all supported OS versions","SomeView()","    .toolBarBottom(leadingItems: {","        OUDSToolBarItem(label: \"Some label\") { \/* Action to process *\/ }","    }, trailingItems: {","        OUDSToolBarItem(icon: Image(decorative: \"some_image\"), accessibilityLabel: \"Label\") { \/* Action to process *\/ }","    })","","\/\/ Grouped \/ centered — meaningful on iOS 26+ (Liquid Glass) only","\/\/ On earlier OS versions the system splits the items into leading\/trailing positions.","SomeView()","    .toolBarBottom(groupedItems: {","        OUDSToolBarItem(label: \"Save\") { \/* Action to process *\/ }","        OUDSToolBarItem(icon: Image(decorative: \"ic_delete\"), accessibilityLabel: \"Delete\") { \/* Action to process *\/ }","    })"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"references":{"component_toolBarBottom_Sosh_dark":{"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/component_toolBarBottom_Sosh_dark.png"}],"type":"image","alt":"A toolbar bottom component with Liquid Glass in dark mode with Sosh theme","identifier":"component_toolBarBottom_Sosh_dark"},"component_toolBarBottom_Wireframe_light":{"alt":"A toolbar bottom component with Liq