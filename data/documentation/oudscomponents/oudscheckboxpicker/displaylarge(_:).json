ckboxes and select some of them within the others."},{"type":"text","text":" "},{"type":"text","text":"Each checkbox contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen values using this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"kind":"symbol"},"doc://OUDSThemesContract/documentation/OUDSThemesContract/OUDSTheme":{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","role":"symbol","title":"OUDSTheme","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}],"abstract":[{"text":"This is a basic theme any theme must be a subclass off, or all themes must have as ancestor.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A Swift "},{"type":"codeVoice","code":"class"},{"type":"text","text":" has been used so as to allow to easily override some attributes and have inheritance, without having for developers"},{"type":"text","text":" "},{"type":"text","text":"to implement all tokens."},{"type":"text","text":" "},{"type":"text","text":"Any properties of an overridable theme should be defined so as to provide defaults values."},{"type":"text","text":" "},{"type":"text","text":"We allow this theme to be derivated and be overriden."},{"type":"text","text":" "},{"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme","isActive":true,"type":"reference"},{"type":"text","text":" can be seen as a kind of “abstract class” in "},{"inlineContent":[{"text":"object oriented paradigm","type":"text"}],"type":"emphasis"},{"type":"text","text":", or "},{"inlineContent":[{"text":"theme contract","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"inlineContent":[{"text":"final","type":"text"}],"type":"emphasis"},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"kind":"symbol"},"doc://OUDSComponents/documentation/OUDSComponents":{"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","url":"\/documentation\/oudscomponents","role":"collection","title":"Components","type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"images":[{"type":"icon","identifier":"ic_folder_categories.png"}],"kind":"symbol"},"ic_folder_categories.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/OUDSComponents\/ic_folder_categories.png","traits":["1x","light"]}],"identifier":"ic_folder_categories.png"}}}