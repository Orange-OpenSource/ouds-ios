idable theme should be defined so as to provide defaults values.","type":"text"},{"text":" ","type":"text"},{"text":"We allow this theme to be derivated and be overriden.","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OUDSThemesContract\/documentation\/OUDSThemesContract\/OUDSTheme"},{"text":" can be seen as a kind of “abstract class” in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"object oriented paradigm","type":"text"}]},{"text":", or ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme contract","type":"text"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"text":"final","type":"text"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":", that is the reason why this conformity is unchecked."}],"role":"symbol","title":"OUDSTheme"},"doc://OUDSComponents/documentation/OUDSComponents":{"images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"url":"\/documentation\/oudscomponents","kind":"symbol","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"type":"topic","title":"Components","role":"collection"}}}