,"text":"."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" is not a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"final"}]},{"type":"text","text":" class, its type cannot be seen as "},{"type":"codeVoice","code":"Sendable"},{"text":", that is the reason why this conformity is unchecked.","type":"text"}],"kind":"symbol","role":"symbol","title":"OUDSTheme","url":"\/documentation\/oudsthemescontract\/oudstheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSTheme","kind":"identifier"}]},"doc://OUDSComponents/documentation/OUDSComponents":{"role":"collection","kind":"symbol","type":"topic","images":[{"identifier":"ic_folder_categories.png","type":"icon"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"url":"\/documentation\/oudscomponents","title":"Components"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem":{"role":"symbol","navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","title":"OUDSCheckboxItem","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"type":"text","text":" proposes layouts to add in your views some checkboxes components with labels and icons."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with only an indicator prefer instead "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true},{"type":"text","text":"."}],"url":"\/documentation\/oudscomponents\/oudscheckboxitem","kind":"symbol","type":"topic"},"doc://OUDSComponents/documentation/OUDSComponents/OUDSCheckboxPicker":{"abstract":[{"type":"text","text":"A picker allowing to expose several checkboxes and select some of them within the others."},{"type":"text","text":" "},{"type":"text","text":"Each checkbox contains a “tag”, i.e. a supposed to be unique value."},{"type":"text","text":" "},{"type":"text","text":"The picker will expose the choosen values using this “tag”."},{"type":"text","text":" "},{"type":"text","text":"It has also some configuration elements which will override the one applied to nested "},{"type":"reference","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"type":"text","text":" (divider, read only and error mode, layout and outlined)"}],"url":"\/documentation\/oudscomponents\/oudscheckboxpicker","kind":"symbol","role":"symbol","type":"topic","title":"OUDSCheckboxPicker","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxPicker","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxPicker","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSCheckboxPicker","kind":"identifier"}]},"ic_folder_categories.png":{"identifier":"ic_folder_categories.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/OUDSComponents\/ic_folder_categories.png"}],"type":"image"}}}