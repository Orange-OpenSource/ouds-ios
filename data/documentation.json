{"topicSections":[{"identifiers":["doc:\/\/OUDS\/documentation\/OUDS","doc:\/\/OUDSComponents\/documentation\/OUDSComponents","doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","doc:\/\/OUDSModules\/documentation\/OUDSModules","doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse","doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent","doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw","doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]}],"metadata":{"roleHeading":"Package","role":"collection","title":"OUDS"},"sections":[],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDS\/documentation"},"references":{"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange":{"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"role":"collection","url":"\/documentation\/oudsthemesorange","type":"topic","title":"OUDSThemesOrange","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","kind":"symbol"},"doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse":{"abstract":[{"text":"This theme overrides the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Orange theme","type":"text"}]},{"text":" for some colors so as to bring an “inverse”-colored experience.","type":"text"}],"role":"collection","url":"\/documentation\/oudsthemesinverse","type":"topic","title":"OUDSThemesInverse","identifier":"doc:\/\/OUDSThemesInverse\/documentation\/OUDSThemesInverse","kind":"symbol"},"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent":{"title":"OUDSTokensComponent","type":"topic","abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"type":"text","text":" are defined for components and refer to semantic tokens or raw tokens."},{"type":"text","text":" "},{"type":"text","text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit."}],"role":"collection","identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent","kind":"symbol","url":"\/documentation\/oudstokenscomponent"},"doc:\/\/OUDSComponents\/documentation\/OUDSComponents":{"url":"\/documentation\/oudscomponents","type":"topic","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"kind":"symbol","title":"OUDSComponents","role":"collection","identifier":"doc:\/\/OUDSComponents\/documentation\/OUDSComponents"},"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw":{"abstract":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Raw tokens"}]},{"type":"text","text":" are smallest "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" possible. They are associated to raw values and will be finaly the values assigned to the "},{"type":"emphasis","inlineContent":[{"text":"components","type":"text"}]},{"type":"text","text":" properties."}],"role":"collection","url":"\/documentation\/oudstokensraw","type":"topic","title":"OUDSTokensRaw","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw","kind":"symbol"},"doc:\/\/OUDSModules\/documentation\/OUDSModules":{"abstract":[{"text":"The catalog of all modules provided by OUDS.","type":"text"},{"text":" ","type":"text"},{"text":"A module can be seen as a set of features with some dedicated components.","type":"text"}],"role":"collection","url":"\/documentation\/oudsmodules","type":"topic","title":"OUDSModules","identifier":"doc:\/\/OUDSModules\/documentation\/OUDSModules","kind":"symbol"},"doc:\/\/OUDS\/documentation\/OUDS":{"abstract":[{"text":"The iOS library of ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange Unified Design System"}]},{"text":", the new design system unified and cohesive across all platforms to build Orange mobile applications for everyone everywhere.","type":"text"}],"role":"collection","url":"\/documentation\/ouds","type":"topic","title":"OUDS","identifier":"doc:\/\/OUDS\/documentation\/OUDS","kind":"symbol"},"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic":{"identifier":"doc:\/\/OUDSTokensSemantic\/documentation\/OUDSTokensSemantic","abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" can be used mainly for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" to apply some style and configuration values ; today "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"components"}]},{"type":"text","text":" are not defined yet."},{"type":"text","text":" "},{"type":"text","text":"They can be seen as an high level of usage with functional meanings."}],"role":"collection","kind":"symbol","url":"\/documentation\/oudstokenssemantic","title":"OUDSTokensSemantic","type":"topic"},"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations":{"url":"\/documentation\/oudsfoundations","abstract":[{"type":"text","text":"Contains a set of helpers shared for higher level targets."}],"title":"OUDSFoundations","kind":"symbol","identifier":"doc:\/\/OUDSFoundations\/documentation\/OUDSFoundations","type":"topic","role":"collection"}},"topicSectionsStyle":"detailedGrid","schemaVersion":{"major":0,"minor":3,"patch":0}}