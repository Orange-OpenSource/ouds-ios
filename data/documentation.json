{"sections":[],"references":{"doc:\/\/OUDSModules\/documentation\/OUDSModules":{"kind":"symbol","abstract":[{"type":"text","text":"The catalog of all modules provided by OUDS."},{"type":"text","text":" "},{"type":"text","text":"A module can be seen as a set of features with some dedicated components."}],"title":"OUDSModules","role":"collection","type":"topic","identifier":"doc:\/\/OUDSModules\/documentation\/OUDSModules","url":"\/documentation\/oudsmodules"},"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"type":"topic","role":"collection","identifier":"doc:\/\/OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"OUDSThemesOrange","kind":"symbol"},"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent":{"title":"OUDSTokensComponent","role":"collection","kind":"symbol","url":"\/documentation\/oudstokenscomponent","identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent","type":"topic","abstract":[{"type":"text","text":"These "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" are defined for components and refer to semantic tokens or raw tokens."},{"type":"text","text":" "},{"type":"text","text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit."}]},"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw":{"kind":"symbol","url":"\/documentation\/oudstokensraw","role":"collection","abstract":[{"type":"emphasis","inlineContent":[{"text":"Raw tokens","type":"text"}]},{"type":"text","text":" are smallest "},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"type":"text","text":" possible. They are associa