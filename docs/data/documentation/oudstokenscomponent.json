{"hierarchy":{"paths":[[]]},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"codeListing","code":["🧱 Tokens version: 0.6.1"],"syntax":null},{"inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"inlineContent":[{"type":"text","text":"background color"}],"type":"emphasis"},{"type":"text","text":", and if a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"text":" is used for it, then only the value of this ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"type":"text","text":" should be changed without any modification on the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component"}]},{"type":"text","text":" definition."},{"type":"text","text":" "},{"inlineContent":[{"text":"Components","type":"text"}],"type":"emphasis"},{"type":"text","text":" use "},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"type":"text","text":" exposed through the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" thanks to token providers to get their style values."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"text":" so as to be exposed then through implementation of ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"protocols"}]},{"text":" and defined in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"extensions","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"That is the reason why tokens are exposed as "},{"code":"@objc open","type":"codeVoice"},{"type":"text","text":" to be available and overridable anywhere."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens"},{"type":"text","text":":"}]},{"syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var buttonSizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var buttonSpacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var buttonSizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens.dimension600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.borderWidthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.borderRadiusMedium }","    @objc open var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.colorRepositoryOpacityBlackHigher }","    @objc open var buttonSpacePaddingBlock: SpaceSemanticToken { spaces.spacePaddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"type":"codeListing"},{"type":"heading","text":"How to use component tokens","anchor":"How-to-use-component-tokens","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact, the component tokens are declared and gathered in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Because "},{"inlineContent":[{"text":"component tokens","type":"text"}],"type":"emphasis"},{"text":" have for values ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"text":"semantic tokens","type":"text"}]},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"type":"emphasis","inlineContent":[{"type":"text","text":"type aliases"}]},{"type":"text","text":" refering all together, you can handle a "},{"inlineContent":[{"text":"component token","type":"text"}],"type":"emphasis"},{"type":"text","text":" directly in your view because the final value will be used."},{"type":"text","text":" "},{"type":"text","text":"Thus, get the theme and call the needed property with some helpers."}]},{"type":"codeListing","syntax":"swift","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.buttonSpacePaddingInlineArrowStart)","        .padding(.trailing, theme.button.buttonSpacePaddingInlineArrowEnd)","        .background(theme.button.buttonColorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"buttonColorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"buttonSpacePaddingInlineArrowStart\" and \"buttonSpacePaddingInlineArrowEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"]}],"kind":"content"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"type":"text","text":" are defined for components and refer to semantic tokens or raw tokens."},{"type":"text","text":" "},{"type":"text","text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit."}],"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BreadcrumbComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckboxComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ControlItemComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTextComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ListItemComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens"],"anchor":"Group","title":"Group"}],"metadata":{"symbolKind":"module","role":"collection","roleHeading":"Framework","externalID":"OUDSTokensComponent","modules":[{"name":"OUDSTokensComponent"}],"title":"OUDSTokensComponent"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"references":{"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/CheckboxComponentTokens":{"abstract":[{"text":"Declares all component tokens for radio button and checkboxes components like ","type":"text"},{"code":"OUDSRadioButton","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"type":"codeVoice","code":"OrangeThemeCheckboxComponentTokensProvider"},{"text":".","type":"text"}],"identifier":"doc:\/\/ouds-ios.OUDSTokensCompone