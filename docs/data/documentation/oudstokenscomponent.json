{"hierarchy":{"paths":[[]]},"sections":[],"topicSections":[{"title":"Group","anchor":"Group","identifiers":["doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens"]},{"anchor":"Type-Aliases","identifiers":["doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/AllButtonComponentTokensProvider"],"generated":true,"title":"Type Aliases"}],"abstract":[{"text":"These ","type":"text"},{"inlineContent":[{"text":"tokens","type":"text"}],"type":"emphasis"},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"type":"emphasis","inlineContent":[{"type":"text","text":"background color"}]},{"type":"text","text":", and if a "},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"type":"text","text":" is used for it, then only the value of this "},{"inlineContent":[{"type":"text","text":"token"}],"type":"emphasis"},{"type":"text","text":" should be changed without any modification on the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component"}]},{"type":"text","text":" definition."},{"type":"text","text":" "},{"inlineContent":[{"text":"Components","type":"text"}],"type":"emphasis"},{"text":" use ","type":"text"},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"text":" exposed through the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" thanks to token providers to get their style values."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"inlineContent":[{"text":"Swift protocol","type":"text"}],"type":"emphasis"},{"type":"text","text":" so as to be exposed then through implementation of "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" thanks to dedicated tokens providers."},{"type":"text","text":" "},{"type":"text","text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"protocols"}]},{"type":"text","text":" and defined in "},{"inlineContent":[{"text":"extensions","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"That is the reason why tokens are exposed as "},{"type":"codeVoice","code":"@objc open"},{"text":" to be available and overridable anywhere.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example with "},{"identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","type":"reference","isActive":true},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var buttonSizeMaxHeight: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var buttonSpacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var buttonSizeMaxHeight: SizeSemanticToken { DimensionRawTokens.dimension600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.borderWidthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.borderRadiusMedium }","    @objc open var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.colorRepositoryOpacityBlackHigher }","    @objc open var buttonSpacePaddingBlock: SpaceSemanticToken { spaces.spacePaddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"]},{"text":"Component tokens management","level":2,"type":"heading","anchor":"Component-tokens-management"},{"anchor":"How-to-add-component-tokens","type":"heading","level":3,"text":"How to add component tokens"},{"type":"paragraph","inlineContent":[{"type":"text","text":"First, you need to define which from family this semantic comes, such tokens are strongly related to components."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your token is not from one of the existing groups, maybe you should redesign your token or create a new family."},{"type":"text","text":" "},{"text":"To do that, you will have to create a dedicated Swift ","type":"text"},{"code":"protocol","type":"codeVoice"},{"text":", with a useful name, and declare as a ","type":"text"},{"type":"codeVoice","code":"var"},{"type":"text","text":" the component token."},{"text":" ","type":"text"},{"text":"If you already know the family, just update the matching files.","type":"text"}]},{"type":"heading","level":3,"text":"How to update or remove component tokens","anchor":"How-to-update-or-remove-component-tokens"},{"type":"paragraph","inlineContent":[{"text":"Quite simple, find the component token you want to update or remove, and update or remove it.","type":"text"}]},{"inlineContent":[{"text":"But beware, if you change the name of the property or if you move it from a ","type":"text"},{"code":"protocol","type":"codeVoice"},{"type":"text","text":" to another, or if you remove the token, you must keep retrocompatibility as much as possible so as to avoid to break any public API. Keep also the CHANGELOG and\/or the release updated with some BREAKING CHANGE notification, and also the Git history clean."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you update the value, keep also the CHANGELOG and\/or RELEASE NOTE updated so as to let your users know the variables have been changed."}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"About-tests-of-tokens","text":"About tests of tokens"},{"inlineContent":[{"type":"text","text":"When component tokens have been added, removed or renamed, unit tests must be updated."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"We do not test the component tokens values as they are, because these values will be generated and keeping up to date the unit tests may be time wasting."},{"text":" ","type":"text"},{"type":"text","text":"But for each component tokens we check if a subtheme can override the token using derived tokens providers."}],"type":"paragraph"},{"text":"How to use component tokens","type":"heading","anchor":"How-to-use-component-tokens","level":2},{"inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"type":"text","text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers."},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"inlineContent":[{"text":"component tokens","type":"text"}],"type":"emphasis"},{"text":" have for values ","type":"text"},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"semantic tokens"}],"type":"emphasis"},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"inlineContent":[{"text":"type aliases","type":"text"}],"type":"emphasis"},{"type":"text","text":" refering all together, you can handle a "},{"type":"emphasis","inlineContent":[{"text":"component token","type":"text"}]},{"text":" directly in your view because the final value will be used.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Thus, get the theme and call the needed property with some helpers."}],"type":"paragraph"},{"syntax":"swift","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.buttonSpacePaddingInlineArrowStart)","        .padding(.trailing, theme.button.buttonSpacePaddingInlineArrowEnd)","        .background(theme.button.buttonColorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"buttonColorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"buttonSpacePaddingInlineArrowStart\" and \"buttonSpacePaddingInlineArrowEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct Showcase: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"roleHeading":"Framework","role":"collection","modules":[{"name":"OUDSTokensComponent"}],"title":"OUDSTokensComponent","symbolKind":"module","externalID":"OUDSTokensComponent"},"references":{"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent":{"kind":"symbol","abstract":[{"text":"These ","type":"text"},{"inlineContent":[{"type":"text","text":"tokens"}],"type":"emphasis"},{"type":"text","text":" are defined for components and refer to semantic tokens or raw tokens."},{"type":"text","text":" "},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"title":"OUDSTokensComponent","url":"\/documentation\/oudstokenscomponent","type":"topic","role":"collection","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/ButtonComponentTokens":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Declares all component tokens for buttons components like "},{"code":"OUDSButton","type":"codeVoice"},{"text":" ","type":"text"},{"text":"Use for tokens providers like ","type":"text"},{"type":"codeVoice","code":"OrangeThemeButtonComponentTokensProvider"},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"ButtonComponentTokens","kind":"identifier"}],"navigatorTitle":[{"text":"ButtonComponentTokens","kind":"identifier"}],"url":"\/documentation\/oudstokenscomponent\/buttoncomponenttokens","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","title":"ButtonComponentTokens","type":"topic"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/AllButtonComponentTokensProvider":{"kind":"symbol","abstract":[{"type":"text","text":"A type alias only for "},{"identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","type":"reference","isActive":true},{"type":"text","text":" so as to keep consistency with other type aliases"},{"text":" ","type":"text"},{"type":"text","text":"merging several protocols."},{"type":"text","text":" "},{"type":"text","text":"For example "},{"code":"OrangeThemeButtonComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" matches this type alias."}],"role":"symbol","navigatorTitle":[{"text":"AllButtonComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudstokenscomponent\/allbuttoncomponenttokensprovider","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"AllButtonComponentTokensProvider","kind":"identifier"}],"title":"AllButtonComponentTokensProvider","type":"topic","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/AllButtonComponentTokensProvider"}}}