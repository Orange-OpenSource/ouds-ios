{"kind":"symbol","topicSections":[{"title":"Group","anchor":"Group","identifiers":["doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BreadcrumbComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTextComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ListItemComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens"]}],"abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" are defined for components and refer to semantic tokens or raw tokens."},{"type":"text","text":" "},{"type":"text","text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"hierarchy":{"paths":[[]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"type":"emphasis","inlineContent":[{"text":"background color","type":"text"}]},{"type":"text","text":", and if a "},{"inlineContent":[{"text":"component token","type":"text"}],"type":"emphasis"},{"type":"text","text":" is used for it, then only the value of this "},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"text":" should be changed without any modification on the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component","type":"text"}]},{"type":"text","text":" definition."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Components"}]},{"type":"text","text":" use "},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"text":" exposed through the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" thanks to token providers to get their style values."}]},{"inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"type":"emphasis","inlineContent":[{"text":"Swift protocol","type":"text"}]},{"type":"text","text":" so as to be exposed then through implementation of "},{"type":"codeVoice","code":"OUDSTheme"},{"text":" thanks to dedicated tokens providers.","type":"text"},{"type":"text","text":" "},{"text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in ","type":"text"},{"inlineContent":[{"text":"protocols","type":"text"}],"type":"emphasis"},{"type":"text","text":" and defined in "},{"type":"emphasis","inlineContent":[{"text":"extensions","type":"text"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"That is the reason why tokens are exposed as "},{"code":"@objc open","type":"codeVoice"},{"type":"text","text":" to be available and overridable anywhere."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Example with ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","isActive":true},{"type":"text","text":":"}]},{"code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var buttonSizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var buttonSpacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var buttonSizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens.dimension600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.borderWidthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.borderRadiusMedium }","    @objc open var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.colorRepositoryOpacityBlackHigher }","    @objc open var buttonSpacePaddingBlock: SpaceSemanticToken { spaces.spacePaddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"text":"Component tokens management","anchor":"Component-tokens-management"},{"anchor":"How-to-add-component-tokens","text":"How to add component tokens","level":3,"type":"heading"},{"inlineContent":[{"text":"First, you need to define which from family this semantic comes, such tokens are strongly related to components.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If your token is not from one of the existing groups, maybe you should redesign your token or create a new family."},{"type":"text","text":" "},{"type":"text","text":"To do that, you will have to create a dedicated Swift "},{"code":"protocol","type":"codeVoice"},{"type":"text","text":", with a useful name, and declare as a "},{"type":"codeVoice","code":"var"},{"text":" the component token.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If you already know the family, just update the matching files."}],"type":"paragraph"},{"anchor":"How-to-update-or-remove-component-tokens","type":"heading","text":"How to update or remove component tokens","level":3},{"inlineContent":[{"text":"Quite simple, find the component token you want to update or remove, and update or remove it.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"But beware, if you change the name of the property or if you move it from a ","type":"text"},{"type":"codeVoice","code":"protocol"},{"type":"text","text":" to another, or if you remove the token, you must keep retrocompatibility as much as possible so as to avoid to break any public API. Keep also the CHANGELOG and\/or the release updated with some BREAKING CHANGE notification, and also the Git history clean."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you update the value, keep also the CHANGELOG and\/or RELEASE NOTE updated so as to let your users know the variables have been changed."}]},{"type":"heading","text":"About tests of tokens","anchor":"About-tests-of-tokens","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"When component tokens have been added, removed or renamed, unit tests must be updated."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"We do not test the component tokens values as they are, because these values will be generated and keeping up to date the unit tests may be time wasting."},{"type":"text","text":" "},{"type":"text","text":"But for each component tokens we check if a subtheme can override the token using derived tokens providers."}]},{"text":"How to use component tokens","anchor":"How-to-use-component-tokens","type":"heading","level":2},{"inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"type":"text","text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers."},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"text":" have for values ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":" or "},{"inlineContent":[{"type":"text","text":"semantic tokens"}],"type":"emphasis"},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"type":"emphasis","inlineContent":[{"text":"type aliases","type":"text"}]},{"text":" refering all together, you can handle a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"type":"text","text":" directly in your view because the final value will be used."},{"type":"text","text":" "},{"type":"text","text":"Thus, get the theme and call the needed property with some helpers."}],"type":"paragraph"},{"code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.buttonSpacePaddingInlineArrowStart)","        .padding(.trailing, theme.button.buttonSpacePaddingInlineArrowEnd)","        .background(theme.button.buttonColorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"buttonColorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"buttonSpacePaddingInlineArrowStart\" and \"buttonSpacePaddingInlineArrowEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"metadata":{"symbolKind":"module","modules":[{"name":"OUDSTokensComponent"}],"roleHeading":"Framework","role":"collection","externalID":"OUDSTokensComponent","title":"OUDSTokensComponent"},"identifier":{"url":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent","interfaceLanguage":"swift"},"references":{"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/BreadcrumbComponentTokens":{"role":"symbol","title":"BreadcrumbComponentTokens","navigatorTitle":[{"text":"BreadcrumbComponentTokens","kind":"identifier"}],"identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BreadcrumbComponentTokens","kind":"symbol","abstract":[{"text":"Declares all component tokens for links components like ","type":"text"},{"type":"codeVoice","code":"OUDSBreadcrumb"},{"type":"text","text":" "},{"text":"Use for tokens providers like ","type":"text"},{"type":"codeVoice","code":"OrangeThemeBreadcrumbComponentTokensProvider"},{"type":"text","text":"."}],"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"BreadcrumbComponentTokens"}],"url":"\/documentation\/oudstokenscomponent\/breadcrumbcomponenttokens"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/SelectComponentTokens":{"navigatorTitle":[{"text":"SelectComponentTokens","kind":"identifier"}],"url":"\/documentation\/oudstokenscomponent\/selectcomponenttokens","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SelectComponentTokens"}],"identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectComponentTokens","title":"SelectComponentTokens","role":"symbol","abstract":[{"text":"Declares all component tokens for links components like ","type":"text"},{"code":"OUDSSelect","type":"codeVoice"},{"type":"text","text":" "},{"text":"Use for tokens providers like ","type":"text"},{"type":"codeVoice","code":"OrangeThemeSelectComponentTokensProvider"},{"type":"text","text":"."}]},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/TagComponentTokens":{"navigatorTitle":[{"kind":"identifier","text":"TagComponentTokens"}],"title":"TagComponentTokens","url":"\/documentation\/oudstokenscomponent\/tagcomponenttokens","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TagComponentTokens","kind":"identifier"}],"role":"symbol","abstract":[{"text":"Declares all component tokens for tags components like ","type":"text"},{"code":"OUDSTag","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"code":"OrangeThemeTagComponentTokensProvider","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/ListItemComponentTokens":{"title":"ListItemComponentTokens","navigatorTitle":[{"kind":"identifier","text":"ListItemComponentTokens"}],"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ListItemComponentTokens","url":"\/documentation\/oudstokenscomponent\/listitemcomponenttokens","kind":"symbol","abstract":[{"type":"text","text":"Declares all component tokens for list item components like "},{"type":"codeVoice","code":"OUDSListItem"},{"type":"text","text":" "},{"text":"Use for tokens providers like ","type":"text"},{"code":"OrangeThemeListItemComponentTokensProvider","type":"codeVoice"},{"type":"text","text":"."}],"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"ListItemComponentTokens","kind":"identifier"}]},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/InputTextComponentTokens":{"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTextComponentTokens","title":"InputTextComponentTokens","abstract":[{"type":"text","text":"Declares all component tokens for links components like "},{"type":"codeVoice","code":"OUDSInputText"},{"type":"text","text":" "},{"text":"Use for tokens providers like ","type":"text"},{"code":"OrangeThemeInputTextComponentTokensProvider","type":"codeVoice"},{"text":".","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InputTextComponentTokens","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"InputTextComponentTokens"}],"role":"symbol","kind":"symbol","url":"\/documentation\/oudstokenscomponent\/inputtextcomponenttoke