{"topicSections":[{"anchor":"Group","title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BreadcrumbComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckboxComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ControlItemComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTextComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ListItemComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/RadioButtonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"code":["🧱 Tokens version: 0.7.0"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"type":"emphasis","inlineContent":[{"text":"background color","type":"text"}]},{"text":", and if a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component token","type":"text"}]},{"type":"text","text":" is used for it, then only the value of this "},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"text":" should be changed without any modification on the ","type":"text"},{"inlineContent":[{"type":"text","text":"component"}],"type":"emphasis"},{"type":"text","text":" definition."},{"type":"text","text":" "},{"inlineContent":[{"text":"Components","type":"text"}],"type":"emphasis"},{"type":"text","text":" use "},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"text":" exposed through the ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"text":" thanks to token providers to get their style values.","type":"text"}]},{"inlineContent":[{"text":"Components tokens are defined and gathered inside ","type":"text"},{"inlineContent":[{"text":"Swift protocol","type":"text"}],"type":"emphasis"},{"type":"text","text":" so as to be exposed then through implementation of "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" thanks to dedicated tokens providers.","type":"text"},{"type":"text","text":" "},{"text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"protocols","type":"text"}]},{"type":"text","text":" and defined in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"extensions"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"That is the reason why tokens are exposed as ","type":"text"},{"type":"codeVoice","code":"@objc open"},{"type":"text","text":" to be available and overridable anywhere."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var buttonSizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var buttonSpacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var buttonSizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens.dimension600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.borderWidthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.borderRadiusMedium }","    @objc open var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.colorRepositoryOpacityBlackHigher }","    @objc open var buttonSpacePaddingBlock: SpaceSemanticToken { spaces.spacePaddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"How-to-use-component-tokens","level":2,"text":"How to use component tokens"},{"inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"type":"text","text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers."},{"text":" ","type":"text"},{"type":"text","text":"Because "},{"inlineContent":[{"type":"text","text":"component tokens"}],"type":"emphasis"},{"type":"text","text":" have for values "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"text":"semantic tokens","type":"text"}]},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"type":"emphasis","inlineContent":[{"type":"text","text":"type aliases"}]},{"type":"text","text":" refering all together, you can handle a "},{"type":"emphasis","inlineContent":[{"text":"component token","type":"text"}]},{"text":" directly in your view because the final value will be used.","type":"text"},{"type":"text","text":" "},{"text":"Thus, get the theme and call the needed property with some helpers.","type":"text"}],"type":"paragraph"},{"code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.buttonSpacePaddingInlineArrowStart)","        .padding(.trailing, theme.button.buttonSpacePaddingInlineArrowEnd)","        .background(theme.button.buttonColorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"buttonColorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"buttonSpacePaddingInlineArrowStart\" and \"buttonSpacePaddingInlineArrowEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[[]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"OUDSTokensComponent","modules":[{"name":"OUDSTokensComponent"}],"role":"collection","externalID":"OUDSTokensComponent","roleHeading":"Framework","symbolKind":"module"},"abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"type":"text","text":" are defined for components and refer to semantic tokens or raw tokens."},{"text":" ","type":"text"},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"references":{"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/LinkComponentTokens":{"title":"LinkComponentTokens","navigatorTitle":[{"text":"LinkComponentTokens","kind":"identifier"}],"url":"\/documentation\/oudstokenscomponent\/linkcomponenttokens","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","kind":"symbol","role":"symbol","type":"topic","abstract":[{"type":"text","text":"Declares all component tokens for links components like "},{"type":"codeVoice","code":"OUDSLink"},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"code":"OrangeThemeLinkComponentTokensProvider","type":"codeVoice"},{"type":"text","text":"."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"LinkComponentTokens"}]},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/InputTextComponentTokens":{"kind":"symbol","navigatorTitle":[{"text":"InputTextComponentTokens","kind":"identifier"}],"title":"InputTextComponentTokens","url":"\/documentation\/oudstokenscomponent\/inputtextcomponenttokens","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InputTextComponentTokens"}],"identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTextComponentTokens","abstract":[{"type":"text","text":"Declares all component tokens for links components like "},{"type":"codeVoice","code":"OUDSInputText"},{"text":" ","type":"text"},{"type":"text","text":"Use for tokens providers like "},{"code":"OrangeThemeInputTextComponentTokensProvider","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","role":"symbol"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/SkeletonComponentTokens":{"title":"SkeletonComponentTokens","navigatorTitle":[{"text":"SkeletonComponentTokens","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","type":"topic","url":"\/documentation\/oudstokenscomponent\/skeletoncomponenttokens","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SkeletonComponentTokens"}],"abstract":[{"text":"Declares all component tokens for links components like ","type":"text"},{"code":"OUDSSkeleton","type":"codeVoice"},{"type":"text","text":" "},{"t