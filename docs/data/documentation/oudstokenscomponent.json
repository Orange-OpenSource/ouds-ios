{"hierarchy":{"paths":[[]]},"kind":"symbol","sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"These "},{"inlineContent":[{"type":"text","text":"tokens"}],"type":"emphasis"},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit."}],"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BreadcrumbComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckboxComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ControlItemComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTextComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ListItemComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens"],"anchor":"Group","title":"Group"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"syntax":null,"type":"codeListing","code":["🧱 Tokens version: 0.6.2"]},{"type":"paragraph","inlineContent":[{"text":"Thus if a component need to change for example its ","type":"text"},{"inlineContent":[{"text":"background color","type":"text"}],"type":"emphasis"},{"text":", and if a ","type":"text"},{"inlineContent":[{"text":"component token","type":"text"}],"type":"emphasis"},{"text":" is used for it, then only the value of this ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"text":" should be changed without any modification on the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component"}]},{"type":"text","text":" definition."},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Components"}]},{"type":"text","text":" use "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"text":" exposed through the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" thanks to token providers to get their style values."}]},{"inlineContent":[{"type":"text","text":"Components tokens are defined and gathered inside "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift protocol"}]},{"text":" so as to be exposed then through implementation of ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" thanks to dedicated tokens providers."},{"text":" ","type":"text"},{"text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"protocols"}]},{"type":"text","text":" and defined in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"extensions"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"That is the reason why tokens are exposed as ","type":"text"},{"type":"codeVoice","code":"@objc open"},{"type":"text","text":" to be available and overridable anywhere."}],"type":"paragraph"},{"inlineContent":[{"text":"Example with ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var buttonSizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var buttonSpacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var buttonSizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens.dimension600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.borderWidthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.borderRadiusMedium }","    @objc open var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.colorRepositoryOpacityBlackHigher }","    @objc open var buttonSpacePaddingBlock: SpaceSemanticToken { spaces.spacePaddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"]},{"type":"heading","level":2,"text":"How to use component tokens","anchor":"How-to-use-component-tokens"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact, the component tokens are declared and gathered in "},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers.","type":"text"},{"type":"text","text":" "},{"text":"Because ","type":"text"},{"inlineContent":[{"text":"component tokens","type":"text"}],"type":"emphasis"},{"text":" have for values ","type":"text"},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" or "},{"inlineContent":[{"type":"text","text":"semantic tokens"}],"type":"emphasis"},{"type":"text","text":", and in the end for values primitive types, and all these tokens are declared with "},{"inlineContent":[{"type":"text","text":"type aliases"}],"type":"emphasis"},{"type":"text","text":" refering all together, you can handle a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"text":" directly in your view because the final value will be used.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Thus, get the theme and call the needed property with some helpers."}]},{"type":"codeListing","code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.buttonSpacePaddingInlineArrowStart)","        .padding(.trailing, theme.button.buttonSpacePaddingInlineArrowEnd)","        .background(theme.button.buttonColorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"buttonColorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"buttonSpacePaddingInlineArrowStart\" and \"buttonSpacePaddingInlineArrowEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"syntax":"swift"}]}],"metadata":{"title":"OUDSTokensComponent","role":"collection","modules":[{"name":"OUDSTokensComponent"}],"symbolKind":"module","roleHeading":"Framework","externalID":"OUDSTokensComponent"},"variants":[{"paths":["\/documentation\/oudstokenscomponent"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/LinkComponentTokens":{"identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","kind":"symbol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"LinkComponentTokens","kind":"identifier"}],"navigatorTitle":[{"text":"LinkComponentTokens","kind":"identifier"}],"abstract":[{"type":"text","text":"Declares all component tokens for links components like "},{"type":"codeVoice","code":"OUDSLink"},{"text":" ","type":"text"},{"type":"text","text":"Use for tokens providers like "},{"code":"OrangeThemeLinkComponentTokensProvider","type":"codeVoice"},{"type":"text","text":"."}],"url":"\/documentation\/oudstokenscomponent\/linkcomponenttokens","type":"topic","title":"LinkComponentTokens"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/ChipComponentTokens":{"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ChipComponentTokens"}],"url":"\/documentation\/oudstokenscomponent\/chipcomponenttokens","type":"topic","abstract":[{"text":"Declares all component tokens for tags components like ","type":"text"},{"type":"codeVoice","code":"OUDSChip"},{"type":"text","text":" "},{"text":"Use for tokens providers like ","type":"text"},{"type":"codeVoice","code":"OrangeThemeChipComponentTokensProvider"},{"text":".","type":"text"}],"kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","navigatorTitle":[{"text":"ChipComponentTokens","kind":"identifier"}],"title":"ChipComponentTokens","role":"symbol"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/SwitchComponentTokens":{"title":"SwitchComponentTokens","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SwitchComponentTokens"}],"navigatorTitle":[{"text":"SwitchComponentTokens","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudstokenscomponent\/switchcomponenttokens","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","abstract":[{"text":"Declares all component tokens for switch components like ","type":"text"},{"type":"codeVoice","code":"OUDSSwitch"},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"code":"OrangeThemeSwitchComponentTokensProvider","type":"codeVoice"},{"type":"text","text":"."}]},"doc