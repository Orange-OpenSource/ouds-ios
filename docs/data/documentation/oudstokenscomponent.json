{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"These ","type":"text"},{"inlineContent":[{"type":"text","text":"tokens"}],"type":"emphasis"},{"type":"text","text":" can be used to apply some style and configuration values to "},{"inlineContent":[{"type":"text","text":"components"}],"type":"emphasis"},{"type":"text","text":"."}],"sections":[],"identifier":{"url":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent","interfaceLanguage":"swift"},"metadata":{"title":"OUDSTokensComponent","modules":[{"name":"OUDSTokensComponent"}],"externalID":"OUDSTokensComponent","symbolKind":"module","roleHeading":"Framework","role":"collection"},"hierarchy":{"paths":[[]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"topicSections":[{"title":"Group","identifiers":["doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/FormsTextInputComponentToken"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Thus if a component need to change for example its "},{"inlineContent":[{"text":"background color","type":"text"}],"type":"emphasis"},{"text":", and if a ","type":"text"},{"inlineContent":[{"type":"text","text":"component token"}],"type":"emphasis"},{"type":"text","text":" is used for it, then only the value of this "},{"inlineContent":[{"type":"text","text":"token"}],"type":"emphasis"},{"text":" should be changed without any modification on the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component","type":"text"}]},{"type":"text","text":" definition."},{"text":" ","type":"text"},{"inlineContent":[{"text":"Components","type":"text"}],"type":"emphasis"},{"text":" use ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" exposed through the "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" to get their style values."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example with a fake component named "},{"type":"codeVoice","code":"FormsTextInputComponent"},{"text":" using component tokens in ","type":"text"},{"type":"codeVoice","code":"FormsTextInputComponentToken"},{"text":":","type":"text"}]},{"code":["\/\/ Declare component tokens","public protocol FormsTextInputComponentToken {","    var ftiTitleFontWeight: TypographyFontWeightSemanticToken { get }","    var ftiTitleFontSize: TypographyFontSizeSemanticToken { get }","    var ftiTitleColor: ColorSemanticToken { get }","    ","    var ftiBorderColor: ColorSemanticToken { get }","    var ftiBorderStyle: BorderStyleSemanticToken { get }","    var ftiBorderWidth: BorderWidthSemanticToken { get }","}","","\/\/ Define the component tokens","extension OUDSTheme: FormsTextInputComponentToken {","    private static let defaultBlack: ColorSemanticToken = ColorRawTokens.colorFunctionalBlack","    private static let defaultWhite: ColorSemanticToken = ColorRawTokens.colorFunctionalWhite","","    @objc open var ftiTitleFontWeight: TypographyFontWeightSemanticToken { fontWeightHeading }","    @objc open var ftiTitleFontSize: TypographyFontSizeSemanticToken { fontSizeLabelLarge }","    @objc open var ftiTitleColor: ColorSemanticToken { colorContentBrandPrimaryLight ?? Self.defaultBlack }","    ","    @objc open var ftiBorderColor: ColorSemanticToken { colorBorderEmphasisLight ?? Self.defaultBlack }","    @objc open var ftiBorderStyle: BorderStyleSemanticToken { borderStyleDefault }","    @objc open var ftiBorderWidth: BorderWidthSemanticToken { borderWidthThin }","}","","\/\/ In the implementation of the component, the theme will be retrieved to get these component tokens","\/\/ The View","","struct OUDSFormsTextInput: View {","","    \/\/ ...","    @Environment(\\.theme) var theme","","    public var body: some View {","        VStack(spacing: theme.spacePaddingBlockComponentTall) {","            Label(","                title: {","                    Text(\"Example of OUDSFormsTextInput\")","                        .fontWeight(theme.ftiTitleFontWeight.fontWeight)","                        .font(.system(size: theme.ftiTitleFontSize))","                        .foregroundColor(theme.ftiTitleColor.color)","                },","                icon: { \/*@START_MENU_TOKEN@*\/Image(systemName: \"42.circle\")\/*@END_MENU_TOKEN@*\/ }","            )","            Text(\"Write bellow some awesome text!\")","                .fontWeight(theme.ftiSubtitleFontWeight.fontWeight)","                .font(.system(size: theme.ftiSubtitleFontSize))","                .foregroundColor(theme.ftiSubtitleColor.color)","            TextField(placeholder, text: $value)","        }","        .padding(theme.spacePaddingBlockComponentTall)","        .background(colorScheme == .light ? theme.ftiBackgroundColorLight.color : theme.ftiBackgroundColorDark.color)","        .border(theme.ftiBorderColor.color, width: theme.ftiBorderWidth)","    }","}"],"syntax":"swift","type":"codeListing"}]}],"kind":"symbol","references":{"doc://OUDSTokensComponent/documentation/OUDSTokensComponent":{"url":"\/documentation\/oudstokenscomponent","abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"text":" can be used to apply some style and configuration values to ","type":"text"},{"inlineContent":[{"type":"text","text":"components"}],"type":"emphasis"},{"type":"text","text":"."}],"title":"OUDSTokensComponent","kind":"symbol","type":"topic","identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent","role":"collection"},"doc://OUDSTokensComponent/documentation/OUDSTokensComponent/FormsTextInputComponentToken":{"url":"\/documentation\/oudstokenscomponent\/formstextinputcomponenttoken","abstract":[{"type":"text","text":"This is a component token for a text input in formulars."},{"text":" ","type":"text"},{"type":"text","text":"**Warning: This is a draft component **"}],"navigatorTitle":[{"text":"FormsTextInputComponentToken","kind":"identifier"}],"title":"FormsTextInputComponentToken","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"FormsTextInputComponentToken","kind":"identifier"}],"identifier":"doc:\/\/OUDSTokensComponent\/documentation\/OUDSTokensComponent\/FormsTextInputComponentToken","type":"topic","kind":"symbol"}}}