e "},{"type":"codeVoice","code":"OUDSButton"},{"type":"text","text":" "},{"text":"Use for tokens providers like ","type":"text"},{"type":"codeVoice","code":"OrangeThemeButtonComponentTokensProvider"},{"type":"text","text":"."}],"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","kind":"symbol","title":"ButtonComponentTokens","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ButtonComponentTokens"}],"url":"\/documentation\/oudstokenscomponent\/buttoncomponenttokens","navigatorTitle":[{"kind":"identifier","text":"ButtonComponentTokens"}]},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/SwitchComponentTokens":{"abstract":[{"text":"Declares all component tokens for switch components like ","type":"text"},{"code":"OUDSSwitch","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"Use for tokens providers like "},{"type":"codeVoice","code":"OrangeThemeSwitchComponentTokensProvider"},{"text":".","type":"text"}],"navigatorTitle":[{"text":"SwitchComponentTokens","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"SwitchComponentTokens","kind":"identifier"}],"title":"SwitchComponentTokens","kind":"symbol","url":"\/documentation\/oudstokenscomponent\/switchcomponenttokens","role":"symbol"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent":{"kind":"symbol","title":"OUDSTokensComponent","url":"\/documentation\/oudstokenscomponent","type":"topic","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent","abstract":[{"type":"text","text":"These "},{"inlineContent":[{"type":"text","text":"tokens"}],"type":"emphasis"},{"type":"text","text":" are defined for components and refer to semantic tokens or raw tokens."},{"type":"text","text":" "},{"text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit.","type":"text"}],"role":"collection"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/LinkComponentTokens":{"url":"\/documentation\/oudstokenscomponent\/linkcomponenttokens","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LinkComponentTokens","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","navigatorTitle":[{"kind":"identifier","text":"LinkComponentTokens"}],"abstract":[{"type":"text","text":"Declares all component tokens for links components like "},{"type":"codeVoice","code":"OUDSLink"},{"text":" ","type":"text"},{"text":"Use for tokens providers like ","type":"text"},{"type":"codeVoice","code":"OrangeThemeLinkComponentTokensProvider"},{"type":"text","text":"."}],"title":"LinkComponentTokens","kind":"symbol","role":"symbol"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/ChipComponentTokens":{"navigatorTitle":[{"kind":"identifier","text":"ChipComponentTokens"}],"type":"topic","kind":"symbol","title":"ChipComponentTokens","abstract":[{"type":"text","text":"Declares all component tokens for tags components like "},{"type":"codeVoice","code":"OUDSChip"},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"type":"codeVoice","code":"OrangeThemeChipComponentTokensProvider"},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ChipComponentTokens"}],"url":"\/documentation\/oudstokenscomponent\/chipcomponenttokens","role":"symbol","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens"}}}