{"identifier":{"url":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent","interfaceLanguage":"swift"},"abstract":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"text":" are defined for components and refer to semantic tokens or raw tokens.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"They can be seen as a kind of bridge between components and in the end primitive values of the design kit."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenscomponent"]}],"topicSections":[{"title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BadgeComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BreadcrumbComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/CheckRadioComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ChipComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/InputTextComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/LinkComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ListItemComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SelectComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SkeletonComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens"],"anchor":"Group"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[[]]},"metadata":{"title":"OUDSTokensComponent","role":"collection","symbolKind":"module","externalID":"OUDSTokensComponent","roleHeading":"Framework","modules":[{"name":"OUDSTokensComponent"}]},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Thus if a component need to change for example its ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"background color"}]},{"type":"text","text":", and if a "},{"inlineContent":[{"text":"component token","type":"text"}],"type":"emphasis"},{"text":" is used for it, then only the value of this ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"type":"text","text":" should be changed without any modification on the "},{"inlineContent":[{"text":"component","type":"text"}],"type":"emphasis"},{"type":"text","text":" definition."},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Components"}],"type":"emphasis"},{"text":" use ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" exposed through the "},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" thanks to token providers to get their style values."}]},{"type":"paragraph","inlineContent":[{"text":"Components tokens are defined and gathered inside ","type":"text"},{"inlineContent":[{"text":"Swift protocol","type":"text"}],"type":"emphasis"},{"text":" so as to be exposed then through implementation of ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" thanks to dedicated tokens providers.","type":"text"},{"text":" ","type":"text"},{"text":"Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes or providers to override properties declared in ","type":"text"},{"inlineContent":[{"type":"text","text":"protocols"}],"type":"emphasis"},{"text":" and defined in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"extensions","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"That is the reason why tokens are exposed as "},{"type":"codeVoice","code":"@objc open"},{"type":"text","text":" to be available and overridable anywhere."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example with "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/ButtonComponentTokens","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Declare some component tokens for buttons with properties they must apply","public protocol ButtonComponentTokens {","    var buttonSizeMaxHeightIconOnly: SizeSemanticToken { get }","    var buttonBorderWidthDefault: BorderWidthSemanticToken { get }","    var buttonBorderRadius: BorderRadiusSemanticToken { get }","    var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { get }","    var buttonSpacePaddingBlock: SpaceSemanticToken { get }","}","","\/\/ There is an existing provider for such tokens","open class OrangeThemeButtonComponentTokensProvider { }","","\/\/ Define the components tokens exposed through the theme thanks to provider","extension OrangeThemeButtonComponentTokensProvider: ButtonComponentTokens {","","    \/\/ Raw tokens can be used","","    @objc open var buttonSizeMaxHeightIconOnly: SizeSemanticToken { DimensionRawTokens.dimension600 }","    ","    \/\/ And also semantic tokens","","    @objc open var buttonBorderWidthDefault: BorderWidthSemanticToken { borders.borderWidthThicker }","    @objc open var buttonBorderRadius: BorderRadiusSemanticToken { borders.borderRadiusMedium }","    @objc open var buttonColorBgDefaultPressedMono: MultipleColorSemanticTokens { colors.colorRepositoryOpacityBlackHigher }","    @objc open var buttonSpacePaddingBlock: SpaceSemanticToken { spaces.spacePaddingInlineSpacious }","}","","\/\/ This provider is then exposed through OUDSTheme as an AllButtonComponentTokensProvider"]},{"type":"heading","anchor":"How-to-use-component-tokens","text":"How to use component tokens","level":2},{"inlineContent":[{"text":"In fact, the component tokens are declared and gathered in ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"type":"text","text":" so as to force any theme to implement them, and also to allow any theme to expose such properties whathever the implementation of the theme is, across providers."},{"type":"text","text":" "},{"type":"text","text":"Because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" have for values "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"semantic tokens"}]},{"text":", and in the end for values primitive types, and all these tokens are declared with ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"type aliases","type":"text"}]},{"type":"text","text":" refering all together, you can handle a "},{"type":"emphasis","inlineContent":[{"text":"component token","type":"text"}]},{"text":" directly in your view because the final value will be used.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Thus, get the theme and call the needed property with some helpers."}],"type":"paragraph"},{"code":["struct SomeView: View {","","    @Environment(\\.theme) private var theme \/\/ Supposed you used in your root view the `OUDSThemeableView` to register the theme","    @Environment(\\.colorScheme) private var colorScheme","","    var body: some View {","        Button {","            \/\/ Some action","        } label: {","            Text(\"Some label\")","                .cornerRadius(theme.button.buttonBorderRadius)","        }","        .padding(.leading, theme.button.buttonSpacePaddingInlineArrowStart)","        .padding(.trailing, theme.button.buttonSpacePaddingInlineArrowEnd)","        .background(theme.button.buttonColorBgStrongEnabledMono)","        .overlay(","            RoundedRectangle(cornerRadius: theme.button.buttonBorderRadius)","                .stroke(Color.blue, lineWidth: theme.button.buttonBorderWidthDefault)","        )","    }","\/*","    - The theme provides border semantic tokens \"buttonBorderRadius\" and \"buttonBorderWidthDefault\"","    - The theme provides a color semantic token \"buttonColorBgStrongEnabledMono\"","    - The theme provides spaces semantic token \"buttonSpacePaddingInlineArrowStart\" and \"buttonSpacePaddingInlineArrowEnd\"","*\/","}","","\/\/ Do not forget in your app to use the `OUDSThemeableView` for your theme, e.g. `OrangeTheme`","@main","struct DesignToolbox: App {","","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","                ...","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"references":{"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/SwitchComponentTokens":{"abstract":[{"text":"Declares all component tokens for switch components like ","type":"text"},{"code":"OUDSSwitch","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"Use for tokens providers like "},{"type":"codeVoice","code":"OrangeThemeSwitchComponentTokensProvider"},{"type":"text","text":"."}],"navigatorTitle":[{"text":"SwitchComponentTokens","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudstokenscomponent\/switchcomponenttokens","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SwitchComponentTokens","kind":"identifier"}],"identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/SwitchComponentTokens","kind":"symbol","title":"SwitchComponentTokens","role":"symbol"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/TagComponentTokens":{"title":"TagComponentTokens","abstract":[{"type":"text","text":"Declares all component tokens for tags components like "},{"code":"OUDSTag","type":"codeVoice"},{"type":"text","text":" "},{"text":"Use for tokens providers like ","type":"text"},{"code":"OrangeThemeTagComponentTokensProvider","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","navigatorTitle":[{"text":"TagComponentTokens","kind":"identifier"}],"identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/TagComponentTokens","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TagComponentTokens","kind":"identifier"}],"kind":"symbol","role":"symbol","url":"\/documentation\/oudstokenscomponent\/tagcomponenttokens"},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent/BulletListComponentTokens":{"title":"BulletListComponentTokens","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BulletListComponentTokens","kind":"identifier"}],"url":"\/documentation\/oudstokenscomponent\/bulletlistcomponenttokens","abstract":[{"type":"text","text":"Declares all component tokens for links components like "},{"type":"codeVoice","code":"OUDSBulletList"},{"text":" ","type":"text"},{"text":"Use for tokens providers like ","type":"text"},{"type":"codeVoice","code":"OrangeThemeBulletListComponentTokensProvider"},{"type":"text","text":"."}],"type":"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/ouds-ios.OUDSTokensComponent\/documentation\/OUDSTokensComponent\/BulletListComponentTokens","navigatorTitle":[{"kind":"identifier","text":"BulletListComponentTokens"}]},"doc://ouds-ios.OUDSTokensComponent/documentation/OUDSTokensComponent":{"abstract":[{"type":"text","text":"These "},{"inlineContent":[{"t