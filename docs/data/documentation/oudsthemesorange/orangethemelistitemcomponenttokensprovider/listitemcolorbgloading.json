":"text","text":" implementation to use."},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider","isActive":true,"type":"reference"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"ListItemComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"text":"list item","type":"text"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"List item","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":") and sizes ("},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")."}],"kind":"symbol","navigatorTitle":[{"text":"OrangeThemeListItemComponentTokensProvider","kind":"identifier"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider","title":"OrangeThemeListItemComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeListItemComponentTokensProvider/ListItemComponentTokens-Implementations":{"title":"ListItemComponentTokens Implementations","kind":"article","url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider\/listitemcomponenttokens-implementations","typ