":"text"},{"inlineContent":[{"type":"text","text":"List item"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpacesSemanticTokensProvider"},{"text":") and sizes (","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":").","type":"text"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeListItemComponentTokensProvider"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OrangeThemeListItemComponentTokensProvider"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"type":"topic","title":"OUDSThemesOrange","role":"collection","url":"\/documentation\/oudsthemesorange","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeListItemComponentTokensProvider/ListItemComponentTokens-Implementations":{"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeListItemComponentTokensProvider\/ListItemComponentTokens-Implementations","url":"\/documentation\/oudsthemesorange\/orangethemelistitemcomponenttokensprovider\/listitemcomponenttokens-implementations","kind":"article",