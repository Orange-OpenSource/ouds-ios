":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"text":" ","type":"text"},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider","isActive":true,"type":"reference"},{"type":"text","text":" and apply the provider they need."},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ButtonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for buttons through any "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Button components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders"},{"type":"text","text":" "},{"type":"text","text":"(from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":"), colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") and"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"navigatorTitle":[{"text":"OrangeThemeButtonComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}],"kind":"symbol"}}}