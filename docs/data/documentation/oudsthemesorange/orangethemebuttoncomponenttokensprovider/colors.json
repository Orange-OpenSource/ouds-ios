ier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider\/colors","kind":"symbol","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"colors","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:18OUDSTokensSemantic08AllColorB14TokensProvidera","text":"AllColorSemanticTokensProvider","kind":"typeIdentifier"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeButtonComponentTokensProvider":{"title":"OrangeThemeButtonComponentTokensProvider","type":"topic","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider","abstract":[{"text":"A class which wraps all ","type":"text"},{"type":"strong","inlineContent":[{"text":"component  tokens of buttons","type":"text"}]},{"type":"text","text":" for button objects like "},{"type":"codeVoice","code":"OUDSButton"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"text":"This provider should be integrated as a ","type":"text"},{"type":"codeVoice","code":"AllButtonComponentTokensProvider"},{"text":" implementation inside ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" so as to provide","type":"text"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"text":" ","type":"text"},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeButtonComponentTokensProvider","isActive":true,"type":"reference"},{"type":"text","text":" and apply the provider they need."},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"ButtonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for buttons through any "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Button components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), borders"},{"type":"text","text":" "},{"type":"text","text":"(from "},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"type":"text","text":"), colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") and"},{"text":" ","type":"text"},{"text":"spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"navigatorTitle":[{"text":"OrangeThemeButtonComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemebuttoncomponenttokensprovider","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeButtonComponentTokensProvider"}],"kind":"symbol"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"type":"topic","url":"\/documentation\/oudsthemesorange","kind":"symbol","role":"collection","title":"OUDSThemesOrange","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}]}}}