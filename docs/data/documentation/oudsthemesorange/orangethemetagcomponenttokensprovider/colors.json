umentation\/OUDSThemesOrange","title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","type":"topic","role":"collection"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTagComponentTokensProvider/colors":{"abstract":[{"type":"text","text":"Provider of color semantic tokens to use for link colors"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider\/colors","url":"\/documentation\/oudsthemesorange\/orangethemetagcomponenttokensprovider\/colors","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"colors"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP","kind":"typeIdentifier","text":"AllColorSemanticTokensProvider"}],"title":"colors","type":"topic","kind":"symbol","role":"symbol"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeTagComponentTokensProvider":{"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeThemeTagComponentTokensProvider","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeThemeTagComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemetagcomponenttokensprovider","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeTagComponentTokensProvider","kind":"symbol","abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"type":"text","text":"component  tokens of tag"}],"type":"strong"},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tag"}]},{"type":"text","text":" objects like "},{"type":"codeVoice","code":"OUDSTag"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"type":"text","text