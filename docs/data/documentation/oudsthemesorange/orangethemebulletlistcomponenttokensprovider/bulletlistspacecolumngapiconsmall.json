ent tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"bullet list"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Bullet list"}]},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"text":") and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"OrangeThemeBulletListComponentTokensProvider","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeBulletListComponentTokensProvider"}],"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider/bulletListSpaceColumnGapIconSmall":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider\/bulletListSpaceColumnGapIconSmall","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider\/bulletlistspacecolumngapiconsmall","abstract":[],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"bulletListSpaceColumnGapIconSmall","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena","text":"SpaceSemanticToken"}],"type":"topic","title":"bulletListSpaceColumnGapIconSmall"},"doc://ouds-ios.OUDSTheme