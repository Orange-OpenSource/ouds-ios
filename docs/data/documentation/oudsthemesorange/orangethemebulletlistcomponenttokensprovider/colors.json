rride some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"BulletListComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"type":"text","text":"bullet list"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Bullet list","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"colors (from "},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":") and spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","type":"topic","role":"collection"}}}