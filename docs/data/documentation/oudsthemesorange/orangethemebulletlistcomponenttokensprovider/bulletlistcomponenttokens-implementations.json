{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"text":" ","type":"text"},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllBulletListComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"text":" so as to provide","type":"text"},{"type":"text","text":" "},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" implementation to use.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"code":"BulletListComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"bullet list"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Bullet list","type":"text"}]},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"text":" ","type":"text"},{"text":"colors (from ","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"text":") and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":").","type":"text"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider/bulletListSpacePaddingInlineStartIconMedium":{"kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider\/bulletListSpacePaddingInlineStartIconMedium","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider\/bulletlistspacepaddinginlinestarticonmedium","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"bulletListSpacePaddingInlineStartIconMedium"},{"text":": ","kind":"text"},{"text":"SpaceSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic05SpaceB5Tokena"}],"role":"symbol","title":"bulletListSpacePaddingInlineStartIconMedium","abstract":[]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider/bulletListSizeMinHeightSmall":{"title":"bulletListSizeMinHeightSmall","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider\/bulletlistsizeminheightsmall","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"bulletListSizeMinHeightSmall"},{"kind":"text","text":": "},{"text":"SizeSemanticToken","kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic04SizeB5Tokena"}],"kind":"symbol","type":"topic","abstract":[],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBulletListComponentTokensProvider\/bulletListSizeMinHeightSmall","role":"symbol"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBulletListComponentTokensProvider/bulletListSizeIconMedium":{"title":"bulletListSizeIconMedium","url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider\/bulletlistsizeiconmedium","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"