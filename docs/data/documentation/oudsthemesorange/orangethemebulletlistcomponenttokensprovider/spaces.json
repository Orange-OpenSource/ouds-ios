","text":" and apply the provider they need."},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"code":"BulletListComponentTokens","type":"codeVoice"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"bullet list","type":"text"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Bullet list"}],"type":"emphasis"},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"type":"text","text":" "},{"text":"colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":") and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"type":"topic","title":"OrangeThemeBulletListComponentTokensProvider","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeThemeBulletListComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemebulletlistcomponenttokensprovider","navigatorTitle":[{"text":"OrangeThemeBulletListComponentTokensProvider","kind":"identifier"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"type":"topic","url":"\/documentation\/oudsthemesorange","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"title":"OUDSThemesOrange","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","role":"collection"}}}