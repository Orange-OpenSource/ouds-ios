izes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") and spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"role":"symbol","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemelinkcomponenttokensprovider","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeLinkComponentTokensProvider","kind":"identifier"}],"navigatorTitle":[{"text":"OrangeThemeLinkComponentTokensProvider","kind":"identifier"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider","type":"topic"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"url":"\/documentation\/oudsthemesorange","role":"collection","title":"OUDSThemesOrange","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","kind":"symbol","type":"topic","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeLinkComponentTokensProvider/linkSpaceColumnGapArrowSmall":{"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeLinkComponentTokensProvider\/linkSpaceColumnGapArrowSmall","title":"linkSpaceColumnGapArrowSmall","abstract":[],"url":"\/documentation\/oudsthemesorange\/orangethemelinkcomponenttokensprovider\/linkspacecolumngaparrowsmall","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"linkSpaceColumnGapArrowSmall"},{"kind":"text","text"