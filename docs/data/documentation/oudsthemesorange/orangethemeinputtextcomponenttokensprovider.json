}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeInputTextComponentTokensProvider","kind":"identifier"}]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Define your own provider for input text component tokens","    \/\/ by inheriting from existing provider","    class CustomInpuTextComponentTokensProvider: OrangeThemeInpuTextComponentTokensProvider {","","        \/\/ Then override the input text component tokens you want.","","        override var inputTextSizeMaxWidth: SizeSemanticToken { DimensionRawTokens.dimension3000 }","","        override var inputTextSpacePaddingBlock: SpaceSemanticToken { spaces.spacePaddingInlineShort }","","        override  var inputTextColorBgDefaultFocus: MultipleColorSemanticTokens { colors.colorRepositoryOpacityBlackHigher }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomInpuTextComponentTokensProvider: InpuTextComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can give this "},{"code":"CustomInpuTextComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" to your own theme implementation:"}]},{"type":"codeListing","code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(inputText: CustomInputTextComponentTokensProvider())","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"or to an already existing theme for example:"}]},{"type":"codeListing","syntax":"swift","code":["    OrangeTheme(inputText: CustomInputTextComponentTokensProvider())"]},{"inline