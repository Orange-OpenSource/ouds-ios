{"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"text":"component  tokens of breadcrumb","type":"text"}],"type":"strong"},{"type":"text","text":" for "},{"type":"emphasis","inlineContent":[{"text":"breadcrumb","type":"text"}]},{"text":" objects like ","type":"text"},{"type":"codeVoice","code":"OUDSBreadcrumb"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"text":" ","type":"text"},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllBreadcrumbComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"text":" ","type":"text"},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBreadcrumbComponentTokensProvider","isActive":true},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"BreadcrumbComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"breadcrumb","type":"text"}]},{"text":" through any ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Breadcrumb"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":")  and spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeThemeBreadcrumbComponentTokensProvider","kind":"identifier"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Define your own provider for breadcrumb component tokens","    \/\/ by inheriting from existing provider","    class CustomBreadcrumbComponentTokensProvider: OrangeThemeBreadcrumbComponentTokensProvider {","","        \/\/ Then override the breadcrumb component tokens you want.","","        override var breadcrumbSizeArrow: SizeSemanticToken { DimensionRawTokens.dimension550 }","","        override var breadcrumbSpaceColumnGapArrow: SpaceSemanticToken { spaces.spaceColumnGapShorter }","","        \/\/ ...","    }","","    \/\/ Or define your own provider from scratch","    class CustomBreadcrumbComponentTokensProvider: BreadcrumbComponentTokens {","","        \/\/ And implement hunders of tokens.","        \/\/ You are allowed to give semantic tokens providers if you want to define values.","    }"]},{"type":"paragraph","inlineContent":[{"text":"Then, you can give this ","type":"text"},{"code":"CustomLinkComponentTokensProvider","type":"codeVoice"},{"text":" to your own theme implementation:","type":"text"}]},{"code":["class LocalTheme: OrangeTheme {","","    override init() {","        super.init(breadcrumb: CustomBreadcrumbComponentTokensProvider())","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"or to an already existing theme for example:",