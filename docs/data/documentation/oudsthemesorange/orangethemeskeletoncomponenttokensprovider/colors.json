{"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"colors","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP","text":"AllColorSemanticTokensProvider"}],"languages":["swift"]}]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider\/colors","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Provider of color semantic tokens to use for link colors"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangethemeskeletoncomponenttokensprovider\/colors"]}],"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider"]]},"metadata":{"roleHeading":"Instance Property","symbolKind":"property","title":"colors","externalID":"s:16OUDSThemesOrange0B36ThemeSkeletonComponentTokensProviderC6colors4OUDS016AllColorSemanticfG0_pvp","modules":[{"name":"OUDSThemesOrange"}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"colors"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP","kind":"typeIdentifier","text":"AllColorSemanticTokensProvider"}],"role":"symbol"},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"references":{"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSkeletonComponentTokensProvider":{"title":"OrangeThemeSkeletonComponentTokensProvider","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeSkeletonComponentTokensProvider"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"OrangeThemeSkeletonComponentTokensProvider","kind":"identifier"}],"url":"\/documentation\/oudsthemesorange\/orangethemeskeletoncomponenttokensprovider","abstract":[{"text":"A class which wraps all ","type":"text"},{"type":"strong","inlineContent":[{"text":"component  tokens of skeleton","type":"text"}]},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"skeleton"}],"type":"emphasis"},{"text":" objects like ","type":"text"},{"code":"OUDSSkeleton","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllSkeletonComponentTokensProvider","type":"codeVoice"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" implementation to use.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider","isActive":true,"type":"reference"},{"type":"text","text":" and apply the provider they need."},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"SkeletonComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"skeleton"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Skeleton"}]},{"type":"text","text":" components tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":")."}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider","role":"symbol","type":"topic","kind":"symbol"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","type":"topic","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"role":"collection"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSkeletonComponentTokensProvider/colors":{"url":"\/documentation\/oudsthemesorange\/orangethemeskeletoncomponenttokensprovider\/colors","title":"colors","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSkeletonComponentTokensProvider\/colors","abstract":[{"type":"text","text":"Provider of color semantic tokens to use for link colors"}],"role":"symbol","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"colors"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP","text":"AllColorSemanticTokensProvider","kind":"typeIdentifier"}]}}}