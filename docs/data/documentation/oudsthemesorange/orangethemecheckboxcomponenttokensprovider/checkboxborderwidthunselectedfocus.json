":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"checkboxes"}]},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"code":"SizeSemanticToken","type":"codeVoice"},{"text":"), opacities (","type":"text"},{"code":"OpacitySemanticToken","type":"codeVoice"},{"text":"),","type":"text"},{"type":"text","text":" "},{"text":"borders (","type":"text"},{"type":"codeVoice","code":"BorderRadiusSemanticToken"},{"text":", ","type":"text"},{"type":"codeVoice","code":"BorderWidthSemanticToken"},{"text":") and colors (","type":"text"},{"type":"codeVoice","code":"MultipleColorSemanticTokens"},{"text":").","type":"text"},{"type":"text","text":" "},{"text":"These components share the same type of tokens which are all gather edhere.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OrangeThemeCheckboxComponentTokensProvider"}],"url":"\/documentation\/oudsthemesorange\/orangethemecheckboxcomponenttokensprovider","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeCheckboxComponentTokensProvider","type":"topic","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeCheckboxComponentTokensProvider"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"OUDSThemesOrange","type":"topic","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"url":"\/documentation\/oudsthemesorange"}}}