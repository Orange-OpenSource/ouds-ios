 to the users.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"text":" ","type":"text"},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeCheckboxComponentTokensProvider","type":"reference"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"CheckboxComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radio button"}]},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"checkboxes"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Radio button","type":"text"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"checkboxes"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"SizeSemanticToken"},{"type":"text","text":"), opacities ("},{"type":"codeVoice","code":"OpacitySemanticToken"},{"type":"text","text":"),"},{"type":"text","text":" "},{"text":"borders (","type":"text"},{"code":"BorderRadiusSemanticToken","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"BorderWidthSemanticToken"},{"text":") and colors (","type":"text"},{"code":"MultipleColorSemanticTokens","type":"codeVoice"},{"type":"text","text":")."},{"text":" ","type":"text"},{"text":"These components share the same type of tokens which are all gather edhere.","type":"text"}],"role":"symbol"},"doc:/