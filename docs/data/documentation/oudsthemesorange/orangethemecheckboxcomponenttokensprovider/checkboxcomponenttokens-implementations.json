" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radio button"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"checkboxes"}]},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"Radio button","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"text":"checkboxes","type":"text"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"SizeSemanticToken"},{"text":"), opacities (","type":"text"},{"type":"codeVoice","code":"OpacitySemanticToken"},{"text":"),","type":"text"},{"type":"text","text":" "},{"text":"borders (","type":"text"},{"type":"codeVoice","code":"BorderRadiusSemanticToken"},{"text":", ","type":"text"},{"code":"BorderWidthSemanticToken","type":"codeVoice"},{"text":") and colors (","type":"text"},{"type":"codeVoice","code":"MultipleColorSemanticTokens"},{"type":"text","text":")."},{"type":"text","text":" "},{"type":"text","text":"These components share the same type of tokens which are all gather edhere."}],"url":"\/documentation\/oudsthemesorange\/orangethemecheckboxcomponenttokensprovider","role":"symbol","title":"OrangeThemeCheckboxComponentTokensProvider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeThemeCheckboxComponentTokensProvider"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeCheckboxComponentTokensProvider","type":"topic","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeThemeCheckboxComponentTokensProvider"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeCheckboxComponentTokensProvider/checkboxBorderRadius":{"type":"topic","role":"symbol","title":"checkboxBo