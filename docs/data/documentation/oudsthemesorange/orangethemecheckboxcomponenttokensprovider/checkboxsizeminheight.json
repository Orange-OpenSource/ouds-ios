entTokensProvider","abstract":[{"type":"text","text":"A class which wraps all "},{"inlineContent":[{"text":"component  tokens of checkbox and radio button","type":"text"}],"type":"strong"},{"text":" for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"radio button"}]},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"checkboxes"}],"type":"emphasis"},{"type":"text","text":" objects"},{"type":"text","text":" "},{"type":"text","text":"like "},{"type":"codeVoice","code":"OUDSRadioButton"},{"text":", ","type":"text"},{"type":"codeVoice","code":"OUDSCheckbox"},{"type":"text","text":" and "},{"type":"codeVoice","code":"OUDSCheckboxItem"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllCheckboxComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" so as to provide all tokens to the users.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"text":" ","type":"text"},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeCheckboxComponentTokensProvider","type":"reference"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"CheckboxComponentTokens"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radio button"}]},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"checkboxes"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"Radio button","type":"text"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"checkboxes"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"SizeSemanticToken"},{"type":"text","text":"), opacities ("},{"type":"codeVoice","code":"OpacitySemanticToken"},{"type":"text","text":"),"},{"type":"text","text":" "},{"text":"borders (","type":"text"},{"code":"BorderRadiusSemanticToken","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"BorderWidthSemanticToken"},{"text":") and colors (","type":"text"},{"code":"MultipleColorSemanticTokens","type":"codeVoice"},{"type":"text","text":")."},{"text":" ","type":"text"},{"text":"These components share the same type of tokens which are all gather edhere.","type":"text"}],"role":"symbol"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","url":"\/documentation\/oudsthemesorange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"OUDSThemesOrange","type":"topic","kind":"symbol"}}}