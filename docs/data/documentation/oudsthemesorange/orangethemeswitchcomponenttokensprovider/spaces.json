nents tokens are defined with semantic tokens of colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"spaces (from "},{"type":"codeVoice","code":"AllSpacesSemanticTokensProvider"},{"type":"text","text":") and sizes ("},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider","type":"topic"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeSwitchComponentTokensProvider/spaces":{"role":"symbol","kind":"symbol","title":"spaces","type":"topic","abstract":[{"type":"text","text":"Provider of spaces semantic tokens to use for button spaces"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSwitchComponentTokensProvider\/spaces","url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider\/spaces","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"spaces"},{"kind":"text","text":": "},{"text":"AllSpaceSemanticTokensProvider","kind":"typeIdentifier","preciseIdentifier":"s:4OUDS30AllSpaceSemanticTokensProviderP"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"type":"topic","title":"OUDSThemesOrange","role":"collection","url":"\/documentation\/oudsthemesorange","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}]}}}