t tokens for "},{"type":"emphasis","inlineContent":[{"text":"switch \/ toggle","type":"text"}]},{"text":" through any ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"Switch","type":"text"}],"type":"emphasis"},{"text":" components tokens are defined with semantic tokens of colors (from ","type":"text"},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"type":"text","text":" "},{"text":"spaces (from ","type":"text"},{"code":"AllSpacesSemanticTokensProvider","type":"codeVoice"},{"text":") and sizes (","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":")."}],"kind":"symbol","role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemeswitchcomponenttokensprovider","title":"OrangeThemeSwitchComponentTokensProvider"}}}