deVoice","code":"OUDSRadioButton"},{"type":"text","text":" and "},{"code":"OUDSCheckboItem","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"text":" ","type":"text"},{"type":"text","text":"This provider should be integrated as a "},{"code":"AllControlItemComponentTokensProvider","type":"codeVoice"},{"text":" implementation inside ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"text":" ","type":"text"},{"type":"text","text":"Custom themes can use subclass of "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeControlItemComponentTokensProvider","isActive":true,"type":"reference"},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"text":"It implements also the protocol ","type":"text"},{"type":"codeVoice","code":"ControlItemComponentTokens"},{"type":"text","text":" so as to expose the component tokens for control-item-layout-basded components through any "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Such components tokens are defined with raw and semantic tokens of sizes (from "},{"code":"SizeSemanticTokensProvider","type":"codeVoice"},{"text":"),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":")  and spaces (from "},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"text":")?","type":"text"}],"url":"\/documentation\/oudsthemesorange\/oran