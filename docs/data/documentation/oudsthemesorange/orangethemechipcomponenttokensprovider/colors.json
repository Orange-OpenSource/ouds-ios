ide","type":"text"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider"},{"type":"text","text":" and apply the provider they need."},{"text":" ","type":"text"},{"text":"It implements also the protocol ","type":"text"},{"code":"ChipComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"chip"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Chip","type":"text"}]},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":"),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") , spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"text":"and border  (from ","type":"text"},{"type":"codeVoice","code":"AllBorderSemanticTokensProvider"},{"text":").","type":"text"}],"url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider","navigatorTitle":[{"text":"OrangeThemeChipComponentTokensProvider","kind":"identifier"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider"}}}