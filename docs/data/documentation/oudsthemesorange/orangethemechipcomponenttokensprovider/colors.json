{"abstract":[{"text":"Provider of color semantic tokens to use for chip colors","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"colors","kind":"identifier"},{"kind":"text","text":": "},{"text":"AllColorSemanticTokensProvider","preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP","kind":"typeIdentifier"}],"platforms":["iOS"],"languages":["swift"]}]}],"metadata":{"externalID":"s:16OUDSThemesOrange0B32ThemeChipComponentTokensProviderC6colors4OUDS016AllColorSemanticfG0_pvp","symbolKind":"property","modules":[{"name":"OUDSThemesOrange"}],"fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"colors"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"AllColorSemanticTokensProvider","preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP"}],"title":"colors","role":"symbol","roleHeading":"Instance Property"},"identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider\/colors","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider\/colors"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","sections":[],"references":{"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeChipComponentTokensProvider/colors":{"title":"colors","kind":"symbol","type":"topic","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"colors","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"AllColorSemanticTokensProvider","preciseIdentifier":"s:4OUDS30AllColorSemanticTokensProviderP"}],"abstract":[{"type":"text","text":"Provider of color semantic tokens to use for chip colors"}],"role":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider\/colors","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider\/colors"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeChipComponentTokensProvider":{"role":"symbol","title":"OrangeThemeChipComponentTokensProvider","type":"topic","abstract":[{"text":"A class which wraps all ","type":"text"},{"inlineContent":[{"text":"component  tokens of chip","type":"text"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"chip"}],"type":"emphasis"},{"text":" objects like ","type":"text"},{"type":"codeVoice","code":"OUDSChip"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllChipComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"code":"ChipComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"chip"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Chip","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"),"},{"text":" ","type":"text"},{"type":"text","text":"colors (from "},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":") , spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")"},{"text":" ","type":"text"},{"text":"and border  (from ","type":"text"},{"code":"AllBorderSemanticTokensProvider","type":"codeVoice"},{"text":").","type":"text"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeChipComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemechipcomponenttokensprovider","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeThemeChipComponentTokensProvider","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeChipComponentTokensProvider"}],"kind":"symbol"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","type":"topic","role":"collection"}}}