,"},{"text":" ","type":"text"},{"text":"and sizes (from ","type":"text"},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":").","type":"text"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider","kind":"symbol","role":"symbol","type":"topic","navigatorTitle":[{"text":"OrangeThemeBadgeComponentTokensProvider","kind":"identifier"}]},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeThemeBadgeComponentTokensProvider/spaces":{"url":"\/documentation\/oudsthemesorange\/orangethemebadgecomponenttokensprovider\/spaces","type":"topic","abstract":[{"type":"text","text":"Provider of spaces semantic tokens to use for badge spaces"}],"role":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider\/spaces","kind":"symbol","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"spaces","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"AllSpaceSemanticTokensProvider","preciseIdentifier":"s:4OUDS30AllSpaceSemanticTokensProviderP"}],"title":"spaces"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"role":"collection","url":"\/documentation\/oudsthemesorange","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"OUDSThemesOrange","type":"topic","kind":"symbol"}}}