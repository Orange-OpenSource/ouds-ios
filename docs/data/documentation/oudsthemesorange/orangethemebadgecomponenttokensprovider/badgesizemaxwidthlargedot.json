aw and semantic tokens of dimensions ("},{"type":"codeVoice","code":"DimensionRawToken"},{"type":"text","text":"),"},{"text":" ","type":"text"},{"type":"text","text":"and sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"text":").","type":"text"}],"type":"topic","kind":"symbol","url":"\/documentation\/oudsthemesorange\/orangethemebadgecomponenttokensprovider","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"OrangeThemeBadgeComponentTokensProvider","kind":"identifier"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeBadgeComponentTokensProvider","title":"OrangeThemeBadgeComponentTokensProvider"}}}