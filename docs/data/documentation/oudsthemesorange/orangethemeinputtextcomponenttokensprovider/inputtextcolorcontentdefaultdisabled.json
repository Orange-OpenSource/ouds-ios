omponenttokensprovider","role":"symbol","type":"topic","abstract":[{"type":"text","text":"A class which wraps all "},{"type":"strong","inlineContent":[{"type":"text","text":"component  tokens of input text"}]},{"text":" for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"input text","type":"text"}]},{"type":"text","text":" objects like "},{"code":"OUDSInputText","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"text":"This provider should be integrated as a ","type":"text"},{"code":"AllInputTextComponentTokensProvider","type":"codeVoice"},{"text":" implementation inside ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" implementation to use.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTextComponentTokensProvider","type":"reference"},{"type":"text","text":" and apply the provider they need."},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"InouttextComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"type":"text","text":"input text"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Inout text"}],"type":"emphasis"},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":"), colors (","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"and spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"navigatorTitle":[{"text":"OrangeThemeInputTextComponentTokensProvider","kind":"identifier"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeThemeInputTextComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeInputTextComponentTokensProvider"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","title":"OUDSThemesOrange","role":"collection","abstract":[{"text":"The Orange theme overrides some tokens from the basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example.","type":"text"}],"url":"\/documentation\/oudsthemesorange","type":"topic","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange"}}}