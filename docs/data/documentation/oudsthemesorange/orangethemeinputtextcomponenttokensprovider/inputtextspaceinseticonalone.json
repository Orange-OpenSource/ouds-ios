type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllInputTextComponentTokensProvider"},{"text":" implementation inside ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"type":"text","text":"all tokens to the users. It helps users to override some of the tokens and assign them to an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" implementation to use."},{"text":" ","type":"text"},{"text":"Custom themes can use subclass of ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTextComponentTokensProvider","isActive":true,"type":"reference"},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"code":"InouttextComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"text":"input text","type":"text"}],"type":"emphasis"},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Inout text","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"), colors ("},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"text":"and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":").","type":"text"}],"kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTextComponentTokensProvider","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeInput