,"kind":"text"},{"text":"OrangeThemeInputTextComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeInputTextComponentTokensProvider","abstract":[{"text":"A class which wraps all ","type":"text"},{"inlineContent":[{"type":"text","text":"component  tokens of input text"}],"type":"strong"},{"type":"text","text":" for "},{"inlineContent":[{"type":"text","text":"input text"}],"type":"emphasis"},{"text":" objects like ","type":"text"},{"code":"OUDSInputText","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Contains also references to semantic tokens providers so as to be able to use them to define the component tokens."},{"type":"text","text":" "},{"type":"text","text":"This provider should be integrated as a "},{"type":"codeVoice","code":"AllInputTextComponentTokensProvider"},{"type":"text","text":" implementation inside "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"text":" ","type":"text"},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."},{"type":"text","text":" "},{"text":"Custom themes can use subclass of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTextComponentTokensProvider"},{"text":" and apply the provider they need.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It implements also the protocol "},{"code":"InouttextComponentTokens","type":"codeVoice"},{"type":"text","text":" so as to expose the component tokens for "},{"inlineContent":[{"type":"text","text":"input text"}],"type":"emphasis"},{"text":" through any ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Inout text","type":"text"}]},{"text":" components tokens are defined with raw and semantic tokens of sizes (from ","type":"text"},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"text":"), colors (","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"and spaces (from "},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"text":").","type":"text"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTextComponentTokensProvider"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","type":"topic","role":"collection"}}}