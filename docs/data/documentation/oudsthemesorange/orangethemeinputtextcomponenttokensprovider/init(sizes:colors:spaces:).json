xt"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"text":" implementation to use.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Custom themes can use subclass of "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTextComponentTokensProvider","isActive":true},{"type":"text","text":" and apply the provider they need."},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"type":"codeVoice","code":"InouttextComponentTokens"},{"text":" so as to expose the component tokens for ","type":"text"},{"inlineContent":[{"text":"input text","type":"text"}],"type":"emphasis"},{"type":"text","text":" through any "},{"type":"codeVoice","code":"OUDSTheme"},{"text":".","type":"text"},{"type":"text","text":" "},{"inlineContent":[{"text":"Inout text","type":"text"}],"type":"emphasis"},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"code":"AllSizeSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":"), colors ("},{"code":"AllColorSemanticTokensProvider","type":"codeVoice"},{"text":")","type":"text"},{"type":"text","text":" "},{"text":"and spaces (from ","type":"text"},{"code":"AllSpaceSemanticTokensProvider","type":"codeVoice"},{"type":"text","text":")."}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OrangeThemeInputTextComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeInputTextComponentTokensProvider","url":"\/documentation\/oudsthemesorange\/orangethemeinputtextcomponenttokensprovider","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeInputTextCompon