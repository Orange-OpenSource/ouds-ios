ass of "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSelectComponentTokensProvider","type":"reference"},{"text":" and apply the provider they need.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It implements also the protocol "},{"code":"SelectComponentTokens","type":"codeVoice"},{"text":" so as to expose the component tokens for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"select"}]},{"type":"text","text":" through any "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Select","type":"text"}]},{"type":"text","text":" components tokens are defined with raw and semantic tokens of sizes (from "},{"type":"codeVoice","code":"AllSizeSemanticTokensProvider"},{"type":"text","text":"),"},{"text":" ","type":"text"},{"text":"colors (from ","type":"text"},{"type":"codeVoice","code":"AllColorSemanticTokensProvider"},{"text":") and spaces (from ","type":"text"},{"type":"codeVoice","code":"AllSpaceSemanticTokensProvider"},{"type":"text","text":")."}],"type":"topic","navigatorTitle":[{"text":"OrangeThemeSelectComponentTokensProvider","kind":"identifier"}],"title":"OrangeThemeSelectComponentTokensProvider","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeThemeSelectComponentTokensProvider"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange":{"kind":"symbol","title":"OUDSThemesOrange","url":"\/documentation\/oudsthemesorange","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange","type":"topic","abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"role":"collection"}}}