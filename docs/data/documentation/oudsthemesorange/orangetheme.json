        \/\/ Do not miss any of them as it will crash","","        OrangeThemeElevationSemanticTokensProvider(),","        OrangeThemeFontSemanticTokensProvider(),","        colors,","        borders,","        sizes,","        spaces,","        OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces),","","        \/\/ Etc.","   ]","","   let yourOwnOrangeTheme = OrangeTheme(tokensProviders: allTheNeededTokensProviders)",""],"type":"codeListing"},{"inlineContent":[{"text":"Then get it:","type":"text"}],"type":"paragraph"},{"code":["    import OUDS","","    @Environment(\\.theme) var theme"],"type":"codeListing","syntax":"swift"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"name":"Since"}]}],"metadata":{"modules":[{"name":"OUDSThemesOrange"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeTheme","kind":"identifier"}],"externalID":"s:16OUDSThemesOrange0B5ThemeC","title":"OrangeTheme","navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"roleHeading":"Class","symbolKind":"class","role":"symbol"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(colors:fontFamily:)","doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(fontFamily:)","doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme\/init(tokensProviders:fontFamily:)"],"generated":true,"anchor":"Initializers","title":"Initializers"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange\/orangetheme"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange"]]},"abstract":[{"type":"text","text":"This 