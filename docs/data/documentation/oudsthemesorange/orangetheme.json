eme, inject it to your view using "},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" and get it through environement variable.","type":"text"}]},{"syntax":"swift","code":["    import OUDS                 \/\/ To get OUDSThemeableView","    import OUDSThemeOrange      \/\/ To get OrangeTheme","    import SwiftUI","","    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":")."},{"type":"text","text":" "},{"text":"For example:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["","   \/\/ Use some already defined providers","   let borders = OrangeThemeBorderSemanticTokensProvider()","   let sizes = OrangeThemeSizeSemanticTokensProvider()","   let spaces = OrangeThemeSpaceSemanticTokensProvider()","","   \/\/ For example, use your own provider of color semantic tokens","   \/\/ It must inherit from OrangeThemeBorderSemanticTokensProvider (which is instance of AllColorSemanticTokensProvider) or directly from AllColorSemanticTokensProvider","   let colors = YourOwnColorSemanticTokensProvider()","","   let allTheNeededTokensProviders: TokensProviders = [","        \/\/ List all the needed tokens providers","        \/\/ Do not miss any of them as it will crash","","        OrangeThemeElevationSemanticTokensProvider(),","        OrangeThemeFontSemanticTokensProvider(),","        colors,","        borders,","        sizes,","        spaces,","        OrangeThemeButtonComponentTokensProvider(sizes: sizes, borders: borders, colors: colors, spaces: spaces),","","        \/\/ Etc.","   ]","","   let yourOwnOrangeTheme = OrangeTheme(tokensProviders: allTheNeededTokensProviders)",""]},{"inlineContent":[{"type":"text","text":"Then get it:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["    import OUDS","","    @Environment(\\.theme) var theme"]},{"type":"aside","name":"Since","style":"note","content":[{"inlineContent":[{"text":"0.8.0","type":"text"}],"type":"paragraph"}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"This is an override of the default basic "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It can override any properties from its superclass, and can be derived too."},{"text":" ","type":"text"},{"type":"text","text":"The "},{"code":"InverseTheme","type":"codeVoice"},{"text":" inherits from this ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":"."}],"references":{"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme/init(tokensProviders:fontFamily:)":{"role":"symbol","abstract":[{"type":"text","text":"Initializes the "},{"code":"OrangeTheme","type":"codeVoice"},{"text":" and lets children classes to user their own tokens implementations","type":"text"}],"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"tokensProviders","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4OUDS15TokensProvidersa","text":"TokensProviders"},{"text":", ","kind":"text"},{"text":"fontFamily","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:18OUDSTokensSemantic010FontFa