{"abstract":[{"text":"This is an override of the default basic ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It can override any properties from its superclass, and can be derived too."},{"type":"text","text":" "},{"text":"The ","type":"text"},{"code":"InverseTheme","type":"codeVoice"},{"type":"text","text":" inherits from this "},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":"."}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OrangeTheme"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"To use this theme, inject it to your view using ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" and get it through environement variable.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["    import OUDS                 \/\/ To get OUDSThemeableView","    import OUDSThemeOrange      \/\/ To get OrangeTheme","    import SwiftUI","","    @main","    struct YourApp: App {","        var body: some Scene {","            WindowGroup {","                OUDSThemeableView(theme: OrangeTheme()) {","                    \/\/ Your root view","                }","            }","        }","    }"]},{"inlineContent":[{"type":"text","text":"You can also use some tokens providers defined in your side, but they must match the same type as the one used on the themes (see "},{"code":"OUDSTheme","type":"codeVoice"