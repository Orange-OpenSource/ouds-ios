{"topicSections":[{"anchor":"Group","title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"]},{"title":"Enumerations","anchor":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable"],"generated":true},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"title":"Extended Modules","generated":true,"anchor":"Extended-Modules"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[[]]},"sections":[],"variants":[{"paths":["\/documentation\/oudscomponents"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"heading","text":"Buttons","anchor":"Buttons","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true,"type":"reference"},{"text":" propose layout with text only, icon only or text and icon.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Four hierarchies are proposed for all layouts: "},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"text":"strong","type":"text"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"text":"minimal","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"text":"negative","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Two style are available: ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"loading"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"If button is placed on colored surface using ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Hierarchy.Negative","type":"codeVoice"},{"text":" hierarchy is not allowed as a direct or indirect child of an ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["     \/\/ Icon only with default hierarchy","     OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) {}","","     \/\/ Text only with negative hierarchy","     OUDSButton(hierarchy: .negative, text: \"Delete\") {}","","     \/\/ Text and icon with strong hierarchy","     OUDSButton(hierarchy: .strong, icon: Image(\"ic_heart\"), text: \"Validate\") {}"],"type":"codeListing"},{"level":2,"text":"Customize components","anchor":"Customize-components","type":"heading"},{"type":"heading","level":3,"anchor":"Apply-a-specific-shadow-effect-elevation-tokens","text":"Apply a specific shadow effect (elevation tokens)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The unified design system implemented by OUDS iOS library allows to apply "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation effets"}]},{"type":"text","text":" on a "},{"type":"codeVoice","code":"View"},{"text":", i.e. a shadow under the component.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Because the design tool in use is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"text":" which defines such shadow with a ","type":"text"},{"inlineContent":[{"text":"blur","type":"text"}],"type":"emphasis"},{"text":" and a ","type":"text"},{"inlineContent":[{"text":"spread","type":"text"}],"type":"emphasis"},{"type":"text","text":" radiuses, and because "},{"type":"emphasis","inlineContent":[{"text":"SwiftUI","type":"text"}]},{"type":"text","text":" uses only its own "},{"inlineContent":[{"text":"radius","type":"text"}],"type":"emphasis"},{"text":" definition, an extension of ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" has been implemented to let users apply some effect using an ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken"},{"type":"text","text":" from the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true,"type":"reference"},{"text":" library thanks to the method ","type":"text"},{"code":"shadow(elevation: ElevationCompositeSemanticToken)","type":"codeVoice"},{"text":".","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"]},{"level":3,"text":"Apply a specific typography (font tokens)","anchor":"Apply-a-specific-typography-font-tokens","type":"heading"},{"inlineContent":[{"type":"text","text":"Your application identity can be strongly based on the "},{"type":"emphasis","inlineContent":[{"text":"typography","type":"text"}]},{"text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact mode"}]},{"text":" or in ","type":"text"},{"inlineContent":[{"type":"text","text":"regular mode"}],"type":"emphasis"},{"text":", and is defined with a ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","type":"reference","isActive":true},{"type":"text","text":". defined in the "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" contains lots of "},{"type":"codeVoice","code":"MultipleFontCompositeRawTokens"},{"text":" listing all the combinations of typography you can apply, and these ","type":"text"},{"inlineContent":[{"type":"text","text":"composite semantic tokens"}],"type":"emphasis"},{"type":"text","text":" use "},{"inlineContent":[{"text":"composite raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":". For example:"}]},{"syntax":"swift","code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However the "},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" must know which "},{"inlineContent":[{"text":"font family","type":"text"}],"type":"emphasis"},{"text":" to apply, and this font family can be a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"custom one"}]},{"text":" or the ","type":"text"},{"inlineContent":[{"type":"text","text":"system one"}],"type":"emphasis"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Thus, we let the users define the font family they want by overriding the "},{"code":"fontFamily","type":"codeVoice"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}]},{"inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"code":"View","type":"codeVoice"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"type":"codeListing"},{"level":3,"anchor":"Apply-a-specific-border-border-tokens","type":"heading","text":"Apply a specific border (border tokens)"},{"inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"type":"codeVoice","code":"oudsBorder(style:width:radius:color)"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"type":"text","text":" "},{"type":"text","text":"The helper is available through "},{"type":"codeVoice","code":"View"},{"type":"text","text":", and tokens through the provider of the theme."}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"},"metadata":{"modules":[{"name":"OUDSComponents"}],"role":"collection","symbolKind":"module","externalID":"OUDSComponents","title":"OUDSComponents","roleHeading":"Framework"},"references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents":{"role":"collection","kind":"symbol","url":"\/documentation\/oudscomponents","title":"OUDSComponents","type":"topic","abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/elevationcompositesemantictoken":{"title":"ElevationCompositeSemanticToken","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"link","titleInlineContent":[{"code":"ElevationCompositeSemanticToken","type":"codeVoice"}],"url":"https:\/