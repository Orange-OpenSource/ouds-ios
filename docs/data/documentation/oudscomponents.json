{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"OUDSComponents","role":"collection","externalID":"OUDSComponents","roleHeading":"Framework","symbolKind":"module","modules":[{"name":"OUDSComponents"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"},"kind":"symbol","hierarchy":{"paths":[[]]},"sections":[],"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Actions","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Navigation","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Input"],"anchor":"Components-categories","title":"Components categories"},{"generated":true,"anchor":"Structures","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/DividerModifier","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"],"title":"Structures"},{"title":"Enumerations","anchor":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndicatorState"],"generated":true},{"anchor":"Extended-Modules","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Foundation","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Swift","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"generated":true,"title":"Extended Modules"}],"abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Customize components","level":2,"anchor":"Customize-components"},{"anchor":"Apply-a-specific-shadow-effect-elevation-tokens","level":3,"type":"heading","text":"Apply a specific shadow effect (elevation tokens)"},{"inlineContent":[{"type":"text","text":"The unified design system implemented by OUDS iOS library allows to apply "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation effets"}]},{"text":" on a ","type":"text"},{"type":"codeVoice","code":"View"},{"type":"text","text":", i.e. a shadow under the component."},{"type":"text","text":" "},{"type":"text","text":"Because the design tool in use is "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" which defines such shadow with a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"blur","type":"text"}]},{"text":" and a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"spread","type":"text"}]},{"type":"text","text":" radiuses, and because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"text":" uses only its own ","type":"text"},{"inlineContent":[{"text":"radius","type":"text"}],"type":"emphasis"},{"type":"text","text":" definition, an extension of "},{"code":"View","type":"codeVoice"},{"type":"text","text":" has been implemented to let users apply some effect using an "},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken"},{"type":"text","text":" from the "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true},{"type":"text","text":" library thanks to the method "},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"type":"text","text":"."}],"type":"paragraph"},{"code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Apply-a-specific-typography-font-tokens","level":3,"text":"Apply a specific typography (font tokens)"},{"type":"paragraph","inlineContent":[{"text":"Your application identity can be strongly based on the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"typography","type":"text"}]},{"text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight.","type":"text"}]},{"inlineContent":[{"text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact mode"}]},{"type":"text","text":" or in "},{"inlineContent":[{"type":"text","text":"regular mode"}],"type":"emphasis"},{"text":", and is defined with a ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens"},{"text":". defined in the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"type":"text","text":" contains lots of "},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"type":"text","text":" listing all the combinations of typography you can apply, and these "},{"inlineContent":[{"text":"composite semantic tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" use "},{"inlineContent":[{"type":"text","text":"composite raw tokens"}],"type":"emphasis"},{"type":"text","text":". For example:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"]},{"type":"paragraph","inlineContent":[{"text":"However the ","type":"text"},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"text":" must know which ","type":"text"},{"inlineContent":[{"type":"text","text":"font family"}],"type":"emphasis"},{"type":"text","text":" to apply, and this font family can be a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"custom one"}]},{"type":"text","text":" or the "},{"inlineContent":[{"type":"text","text":"system one"}],"type":"emphasis"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Thus, we let the users define the font family they want by overriding the "},{"code":"fontFamily","type":"codeVoice"},{"text":" property. This value will be used to compute the typography, if not defined the systme font will be used.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"code":"View","type":"codeVoice"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"type":"codeListing"},{"type":"heading","level":3,"anchor":"Apply-a-specific-border-border-tokens","text":"Apply a specific border (border tokens)"},{"type":"paragraph","inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"type":"codeVoice","code":"oudsBorder(style:width:radius:color)"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"text":" ","type":"text"},{"type":"text","text":"The helper is available through "},{"type":"codeVoice","code":"View"},{"type":"text","text":", and tokens through the provider of the theme."}]},{"code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing","syntax":"swift"}]}],"references":{"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/elevationcompositesemantictoken":{"title":"ElevationCompositeSemanticToken","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"link","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","titleInlineContent":[{"code":"ElevationCompositeSemanticToken","type":"codeVoice"}]},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/DividerModifier":{"kind":"symbol","abstract":[{"type":"text","text":"A "},{"code":"ViewModifier","type":"codeVoice"},{"type":"text","text":" which will apply a specific divider under a "},{"type":"codeVoice","code":"View"},{"text":" using color semantic token.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DividerModifier","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DividerModifier"}],"title":"DividerModifier","type":"topic","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/DividerModifier","url":"\/documentation\/oudscomponents\/dividermodifier"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSLink":{"url":"\/documentation\/oudscomponents\/oudslink","role":"symbol","type":"topic","title":"OUDSLink","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSLink"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"type":"text","text":" proposes layout with text only or text with icon."},{"text":" ","type":"text"},{"type":"text","text":"It also proposes layout to navigate forward or backward. The link can be displ