{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[[]]},"metadata":{"modules":[{"name":"OUDSComponents"}],"title":"OUDSComponents","roleHeading":"Framework","role":"collection","externalID":"OUDSComponents","symbolKind":"module"},"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable"],"anchor":"Enumerations","title":"Enumerations"},{"anchor":"Extended-Modules","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"generated":true,"title":"Extended Modules"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"❗More details coming soon.❗"}]},{"type":"heading","text":"Customize components","level":2,"anchor":"Customize-components"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some helpers are provided through this module."}]},{"anchor":"Apply-a-specific-shadow-effect-elevation-tokens","text":"Apply a specific shadow effect (elevation tokens)","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"The unified design system implemented by OUDS iOS library allows to apply "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation effets"}]},{"type":"text","text":" on a "},{"code":"View","type":"codeVoice"},{"text":", i.e. a shadow under the component.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Because the design tool in use is "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"text":" which defines such shadow with a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"blur"}]},{"type":"text","text":" and a "},{"type":"emphasis","inlineContent":[{"text":"spread","type":"text"}]},{"type":"text","text":" radiuses, and because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"type":"text","text":" uses only its own "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radius"}]},{"text":" definition, an extension of ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" has been implemented to let users apply some effect using an ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"reference","isActive":true},{"text":" from the ","type":"text"},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true},{"type":"text","text":" library thanks to the method "},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"text":"Apply a specific typography (font tokens)","anchor":"Apply-a-specific-typography-font-tokens"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your application identity can be strongly based on the "},{"inlineContent":[{"text":"typography","type":"text"}],"type":"emphasis"},{"type":"text","text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact mode"}]},{"type":"text","text":" or in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"regular mode"}]},{"text":", and is defined with a ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens"},{"text":". defined in the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","type":"reference","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"text":" contains lots of ","type":"text"},{"type":"codeVoice","code":"MultipleFontCompositeRawTokens"},{"type":"text","text":" listing all the combinations of typography you can apply, and these "},{"type":"emphasis","inlineContent":[{"text":"composite semantic tokens","type":"text"}]},{"text":" use ","type":"text"},{"inlineContent":[{"text":"composite raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":". For example:"}]},{"syntax":"swift","code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However the "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" must know which "},{"type":"emphasis","inlineContent":[{"text":"font family","type":"text"}]},{"text":" to apply, and this font family can be a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"custom one"}]},{"text":" or the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"system one"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Thus, we let the users define the font family they want by overriding the ","type":"text"},{"code":"fontFamily","type":"codeVoice"},{"text":" property. This value will be used to compute the typography, if not defined the systme font will be used.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Thus, if you want to apply a specific typography to a ","type":"text"},{"type":"codeVoice","code":"View"},{"type":"text","text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):"}]},{"syntax":"swift","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"type":"codeListing"},{"text":"Apply a specific border (border tokens)","anchor":"Apply-a-specific-border-border-tokens","level":3,"type":"heading"},{"inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"type":"codeVoice","code":"oudsBorder(style:width:radius:color)"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"text":" ","type":"text"},{"text":"The helper is available through ","type":"text"},{"type":"codeVoice","code":"View"},{"type":"text","text":", and tokens through the provider of the theme."}],"type":"paragraph"},{"type":"codeListing","code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"syntax":"swift"}]}],"sections":[],"variants":[{"paths":["\/documentation\/oudscomponents"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/elevationcompositesemantictoken":{"titleInlineContent":[{"code":"ElevationCompositeSemanticToken","type":"codeVoice"}],"type":"link","title":"ElevationCompositeSemanticToken","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken"},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/":{"titleInlineContent":[{"text":"OUDSTokensSemantic","type":"text"}],"type":"link","title":"OUDSTokensSemantic","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/"},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/multiplefontcompositerawtoke