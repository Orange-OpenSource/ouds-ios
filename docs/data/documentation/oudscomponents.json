{"metadata":{"symbolKind":"module","roleHeading":"Framework","modules":[{"name":"OUDSComponents"}],"role":"collection","title":"OUDSComponents","externalID":"OUDSComponents"},"abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"topicSections":[{"anchor":"Group","title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"]},{"generated":true,"anchor":"Structures","title":"Structures","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/DividerModifier"]},{"generated":true,"title":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxSelectorState"],"anchor":"Enumerations"},{"anchor":"Extended-Modules","title":"Extended Modules","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Foundation","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Swift","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"generated":true}],"variants":[{"paths":["\/documentation\/oudscomponents"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"anchor":"Buttons","level":3,"type":"heading","text":"Buttons"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" propose layout with text only, icon only or text and icon."},{"text":" ","type":"text"},{"type":"text","text":"Four hierarchies are proposed for all layouts: "},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"strong"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"minimal"}]},{"type":"text","text":" and "},{"inlineContent":[{"text":"negative","type":"text"}],"type":"emphasis"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Two style are available: "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"loading"}],"type":"emphasis"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If button is placed on colored surface using "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."},{"type":"text","text":" "},{"text":"A button with ","type":"text"},{"type":"codeVoice","code":"OUDSButton.Hierarchy.Negative"},{"text":" hierarchy is not allowed as a direct or indirect child of an ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":".","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["     \/\/ Icon only with default hierarchy","     OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) {}","","     \/\/ Text only with negative hierarchy","     OUDSButton(hierarchy: .negative, text: \"Delete\") {}"]},{"type":"heading","text":"Links","anchor":"Links","level":3},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference"},{"type":"text","text":" proposes layout with text only or text with icon."},{"text":" ","type":"text"},{"text":"It also proposes layout to navigate forward or backward.","type":"text"},{"text":" ","type":"text"},{"text":"The link can be displayed in ","type":"text"},{"type":"codeVoice","code":"small"},{"type":"text","text":" or "},{"type":"codeVoice","code":"medium"},{"type":"text","text":" size."}],"type":"paragraph"},{"syntax":"swift","code":["    \/\/ Text only in small size","    OUDSLink(text: \"Feedback\", size: .small) { \/* the action to process *\/ }","","    \/\/ Text and icon in medium size","    OUDSLink(text: \"Feedback\", icon: Image(\"ic_heart\"), size: .medium) { \/* the action to process *\/ }","","    \/\/ Navigate to previous page with link in a medium size","    OUDSLink(text: \"Back\", arrow: .back, size: .medium) { \/* the action to process *\/ }"],"type":"codeListing"},{"text":"Checkbox","level":3,"anchor":"Checkbox","type":"heading"},{"inlineContent":[{"type":"text","text":"The library proposes layout to add in your views some checkboxes components, even if this type of component is not iOS-native one."}],"type":"paragraph"},{"type":"codeListing","code":["     \/\/ A simple checkbox, with only a selector","     OUDSCheckbox(state: $state)","","     \/\/ A leading checkbox with a label","     OUDSCheckboxItem(state: $state, label: \"Hello world\")","","     \/\/ A trailing checkbox with a label, an helper text, an icon, a divider and is about an error","     \/\/ with an inverse layout","     OUDSCheckboxItem(state: $state,","                      labelText: \"We live in a fabled world\",","                      helperText: \"Of dreaming boys and wide-eyed girls\",","                      icon: Image(decorative: \"ic_heart\"),","                      isInversed: true,","                      isError: true,","                      hasDivider: true)"],"syntax":"swift"},{"text":"Customize components","anchor":"Customize-components","level":2,"type":"heading"},{"level":3,"text":"Apply a specific shadow effect (elevation tokens)","anchor":"Apply-a-specific-shadow-effect-elevation-tokens","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The unified design system implemented by OUDS iOS library allows to apply ","type":"text"},{"inlineContent":[{"text":"elevation effets","type":"text"}],"type":"emphasis"},{"type":"text","text":" on a "},{"type":"codeVoice","code":"View"},{"type":"text","text":", i.e. a shadow under the component."},{"type":"text","text":" "},{"text":"Because the design tool in use is ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" which defines such shadow with a "},{"type":"emphasis","inlineContent":[{"text":"blur","type":"text"}]},{"text":" and a ","type":"text"},{"inlineContent":[{"type":"text","text":"spread"}],"type":"emphasis"},{"text":" radiuses, and because ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"SwiftUI","type":"text"}]},{"type":"text","text":" uses only its own "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radius"}]},{"type":"text","text":" definition, an extension of "},{"type":"codeVoice","code":"View"},{"type":"text","text":" has been implemented to let users apply some effect using an "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"reference","isActive":true},{"text":" from the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/"},{"type":"text","text":" library thanks to the method "},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"text":".","type":"text"}]},{"type":"codeListing","code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"],"syntax":"swift"},{"type":"heading","level":3,"anchor":"Apply-a-specific-typography-font-tokens","text":"Apply a specific typography (font tokens)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your application identity can be strongly based on the "},{"inlineContent":[{"text":"typography","type":"text"}],"type":"emphasis"},{"type":"text","text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight."}]},{"inlineContent":[{"text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact mode"}]},{"text":" or in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"regular mode"}]},{"type":"text","text":", and is defined with a "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens"},{"type":"text","text":". defined in the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"type":"text","text":" contains lots of "},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"text":" listing all the combinations of typography you can apply, and these ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite semantic tokens"}]},{"type":"text","text":" use "},{"inlineContent":[{"type":"text","text":"composite raw tokens"}],"type":"emphasis"},{"type":"text","text":". For example:"}],"type":"paragraph"},{"code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"However the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"text":" must know which ","type":"text"},{"inlineContent":[{"text":"font family","type":"text"}],"type":"emphasis"},{"type":"text","text":" to apply, and this font family can be a "},{"inlineContent":[{"text":"custom one","type":"text"}],"type":"emphasis"},{"type":"text","text":" or the "},{"inlineContent":[{"type":"text","text":"system one"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Thus, we let the users define the font family they want by overriding the "},{"type":"codeVoice","code":"fontFamily"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}]},{"inlineContent":[{"text":"Thus, if you want to apply a specific typography to a ","type":"text"},{"type":"codeVoice","code":"View"},{"type":"text","text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"syntax":"swift"},{"text":"Apply a specific border (border tokens)","level":3,"type":"heading","anchor":"Apply-a-specific-border-border-tokens"},{"inlineContent":[{"type":"text","text":"This module exposes the helper "},{"code":"oudsBorder(style:width:radius:color)","type":"codeVoice"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"text":" ","type":"text"},{"type":"text","text":"The helper is available through "},{"type":"codeVoice","code":"View"},{"text":", and tokens through the provider of the theme.","type":"text"}],"type":"paragraph"},{"code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing","syntax":"swift"}]}],"hierarchy":{"paths":[[]]},"references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/Foundation":{"url":"\/documentation\/oudscomponents\/foundation","abstract":[],"title":"Foundation","role":"collection","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Foundation","type":"topic","kind":"symbol"},"doc://ouds-io