nents/documentation/OUDSComponents/OUDSCheckboxItem":{"abstract":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"text":" proposes layouts to add in your views some checkboxes components.","type":"text"}],"title":"OUDSCheckboxItem","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"type":"topic","url":"\/documentation\/oudscomponents\/oudscheckboxitem","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/SwiftUICore":{"role":"collection","title":"SwiftUICore","url":"\/documentation\/oudscomponents\/swiftuicore","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore","kind":"symbol","type":"topic","abstract":[]},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/DividerModifier":{"type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DividerModifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DividerModifier","kind":"identifier"}],"title":"DividerModifier","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/DividerModifier","url":"\/documentation\/oudscomponents\/dividermodifier","kind":"symbol","abstract":[]},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSCheckbox":{"kind":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true},{"text":" proposes layout to add in your views a lonely checkbox, without labels, texts nor icons checkboxes components","type":"text"},{"text":" ","type":"text"},{"text":"If you want