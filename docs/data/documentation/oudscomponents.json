{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/oudscomponents"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"anchor":"Components-categories","title":"Components categories","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Actions","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Navigations","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Inputs","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Layouts"]},{"anchor":"Structures","title":"Structures","generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/DividerModifier","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurface","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSColoredSurfaceModifier","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"]},{"anchor":"Enumerations","title":"Enumerations","generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndicatorState"]},{"anchor":"Extended-Modules","title":"Extended Modules","generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Foundation","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Swift","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"]}],"abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Customize components","anchor":"Customize-components"},{"type":"heading","level":3,"text":"Apply a specific shadow effect (elevation tokens)","anchor":"Apply-a-specific-shadow-effect-elevation-tokens"},{"type":"paragraph","inlineContent":[{"text":"The unified design system implemented by OUDS iOS library allows to apply ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"elevation effets","type":"text"}]},{"text":" on a ","type":"text"},{"type":"codeVoice","code":"View"},{"text":", i.e. a shadow under the component.","type":"text"},{"text":" ","type":"text"},{"text":"Because the design tool in use is ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"text":" which defines such shadow with a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"blur","type":"text"}]},{"text":" and a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"spread","type":"text"}]},{"text":" radiuses, and because ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"text":" uses only its own ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"radius","type":"text"}]},{"text":" definition, an extension of ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" has been implemented to let users apply some effect using an ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken"},{"text":" from the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/"},{"text":" library thanks to the method ","type":"text"},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"text":".","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ For example, apply the elevation effect \"elevationDrag\" from your theme:","myView.oudsShadow(theme.elevations.elevationDrag)","","\/\/ And in the theme this \"elevationDrag\" has been defined for example like:","@objc open var elevationDrag: ElevationCompositeSemanticToken { ElevationCompositeSemanticToken(ElevationRawTokens.elevationBottom_3_500) }","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: elevationX0, y: elevationY300, blur: elevationBlur400, color: ColorRawTokens.colorOpacityBlack320)","","\/\/ Blur will be used to compute the radius value"]},{"type":"heading","level":3,"text":"Apply a specific typography (font tokens)","anchor":"Apply-a-specific-typography-font-tokens"},{"type":"paragraph","inlineContent":[{"text":"Your application identity can be strongly based on the ","type":"text"},{"inlineContent":[{"type":"text","text":"typography"}],"type":"emphasis"},{"text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"compact mode","type":"text"}]},{"text":" or in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"regular mode","type":"text"}]},{"text":", and is defined with a ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens"},{"text":". defined in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"text":" contains lots of ","type":"text"},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"text":" listing all the combinations of typography you can apply, and these ","type":"text"},{"inlineContent":[{"type":"text","text":"composite semantic tokens"}],"type":"emphasis"},{"text":" use ","type":"text"},{"inlineContent":[{"text":"composite raw tokens","type":"text"}],"type":"emphasis"},{"text":". For example:","type":"text"}]},{"code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"However the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"text":" must know which ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"font family","type":"text"}]},{"text":" to apply, and this font family can be a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"custom one"}]},{"text":" or the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"system one","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Thus, we let the users define the font family they want by overriding the ","type":"text"},{"type":"codeVoice","code":"fontFamily"},{"text":" property. This value will be used to compute the typography, if not defined the systme font will be used.","type":"text"}]},{"inlineContent":[{"text":"Thus, if you want to apply a specific typography to a ","type":"text"},{"code":"View","type":"codeVoice"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}],"type":"paragraph"},{"code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"type":"codeListing","syntax":"swift"},{"level":3,"anchor":"Apply-a-specific-border-border-tokens","text":"Apply a specific border (border tokens)","type":"heading"},{"inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"code":"oudsBorder(style:width:radius:color)","type":"codeVoice"},{"text":" so as to apply border semantic tokens on a view in order to define a border effect.","type":"text"},{"text":" ","type":"text"},{"text":"The helper is available through ","type":"text"},{"code":"View","type":"codeVoice"},{"text":", and tokens through the provider of the theme.","type":"text"}],"type":"paragraph"},{"code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing","syntax":"swift"},{"level":3,"anchor":"Apply-specific-colors","text":"Apply specific colors","type":"heading"},{"inlineContent":[{"text":"Colors can be applied on view for background and foreground colors, foreground style or also accent color.","type":"text"},{"text":" ","type":"text"},{"text":"Some helpers are available in the OUDS API to avoid to use the ","type":"text"},{"code":"color(for:ColorScheme)","type":"codeVoice"},{"text":" method.","type":"text"}],"type":"paragraph"},{"code":["    \/\/ Given a color at theme.colors.colorBgPrimary","    \/\/ This token can have light and dark declinations ","","    @Environment(\\.theme) private var theme","","    \/\/ Apply a foreground style","    someView.oudsForegroundStyle(theme.colors.colorBgPrimary)","","    \/\/ Apply a foreground color","    someView.oudsForegroundColor(theme.colors.colorBgPrimary)","","    \/\/ Apply a background","    someView.oudsBackground(theme.colors.colorBgPrimary)","","    \/\/ Apply an accent color","    someView.oudsAccentColor(theme.colors.colorBgPrimary)"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[[]]},"sections":[],"metadata":{"role":"collection","roleHeading":"Framework","externalID":"OUDSComponents","modules":[{"name":"OUDSComponents"}],"symbolKind":"module","title":"OUDSComponents"},"kind":"symbol","references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/Inputs":{"title":"Input","role":"article","abstract":[{"text":"Some components can be used for ","type":"text"},{"inlineContent":[{"type":"text","text":"inputs"}],"type":"strong"},{"text":".","type":"text"}],"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Inputs","kind":"article","url":"\/documentation\/oudscomponents\/inputs"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSColoredSurfaceModifier":{"navigatorTitle":[{"text":"OUDSCol