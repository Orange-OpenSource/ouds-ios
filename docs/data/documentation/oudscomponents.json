{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"text":"Buttons","level":3,"anchor":"Buttons","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"type":"text","text":" propose layout with text only, icon only or text and icon."},{"text":" ","type":"text"},{"type":"text","text":"Four hierarchies are proposed for all layouts: "},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"text":", ","type":"text"},{"inlineContent":[{"text":"strong","type":"text"}],"type":"emphasis"},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"text":"minimal","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"negative"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Two style are available: "},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"loading"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If button is placed on colored surface using "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."},{"type":"text","text":" "},{"text":"A button with ","type":"text"},{"type":"codeVoice","code":"OUDSButton.Hierarchy.Negative"},{"text":" hierarchy is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]},{"syntax":"swift","code":["     \/\/ Icon only with default hierarchy","     OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) {}","","     \/\/ Text only with negative hierarchy","     OUDSButton(hierarchy: .negative, text: \"Delete\") {}","","     \/\/ Text and icon with strong hierarchy","     OUDSButton(hierarchy: .strong, icon: Image(\"ic_heart\"), text: \"Validate\") {}"],"type":"codeListing"},{"text":"Customize components","type":"heading","level":2,"anchor":"Customize-components"},{"anchor":"Apply-a-specific-shadow-effect-elevation-tokens","type":"heading","text":"Apply a specific shadow effect (elevation tokens)","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The unified design system implemented by OUDS iOS library allows to apply "},{"inlineContent":[{"type":"text","text":"elevation effets"}],"type":"emphasis"},{"text":" on a ","type":"text"},{"code":"View","type":"codeVoice"},{"type":"text","text":", i.e. a shadow under the component."},{"text":" ","type":"text"},{"text":"Because the design tool in use is ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" which defines such shadow with a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"blur"}]},{"type":"text","text":" and a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"spread"}]},{"text":" radiuses, and because ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"SwiftUI","type":"text"}]},{"type":"text","text":" uses only its own "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radius"}]},{"type":"text","text":" definition, an extension of "},{"code":"View","type":"codeVoice"},{"type":"text","text":" has been implemented to let users apply some effect using an "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"reference","isActive":true},{"text":" from the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true,"type":"reference"},{"text":" library thanks to the method ","type":"text"},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"text":".","type":"text"}]},{"code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"],"syntax":"swift","type":"codeListing"},{"text":"Apply a specific typography (font tokens)","anchor":"Apply-a-specific-typography-font-tokens","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Your application identity can be strongly based on the ","type":"text"},{"inlineContent":[{"text":"typography","type":"text"}],"type":"emphasis"},{"type":"text","text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact mode"}]},{"type":"text","text":" or in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"regular mode"}]},{"text":", and is defined with a ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","type":"reference"},{"type":"text","text":". defined in the "},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" contains lots of "},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"text":" listing all the combinations of typography you can apply, and these ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite semantic tokens"}]},{"text":" use ","type":"text"},{"inlineContent":[{"text":"composite raw tokens","type":"text"}],"type":"emphasis"},{"text":". For example:","type":"text"}]},{"code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" must know which "},{"type":"emphasis","inlineContent":[{"text":"font family","type":"text"}]},{"text":" to apply, and this font family can be a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"custom one"}]},{"type":"text","text":" or the "},{"inlineContent":[{"type":"text","text":"system one"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Thus, we let the users define the font family they want by overriding the "},{"type":"codeVoice","code":"fontFamily"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"code":"View","type":"codeVoice"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}]},{"code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"syntax":"swift","type":"codeListing"},{"anchor":"Apply-a-specific-border-border-tokens","level":3,"type":"heading","text":"Apply a specific border (border tokens)"},{"inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"code":"oudsBorder(style:width:radius:color)","type":"codeVoice"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"text":" ","type":"text"},{"type":"text","text":"The helper is available through "},{"type":"codeVoice","code":"View"},{"type":"text","text":", and tokens through the provider of the theme."}],"type":"paragraph"},{"code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"paths":["\/documentation\/oudscomponents"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"OUDSComponents"}],"externalID":"OUDSComponents","roleHeading":"Framework","symbolKind":"module","title":"OUDSComponents","role":"collection"},"schem