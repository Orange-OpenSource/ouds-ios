{"topicSections":[{"title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"],"anchor":"Group"},{"anchor":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable"],"title":"Enumerations","generated":true},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"generated":true,"anchor":"Extended-Modules","title":"Extended Modules"}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"text":"Buttons","level":3,"anchor":"Buttons","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference"},{"text":" propose layout with text only, icon only or text and icon.","type":"text"},{"text":" ","type":"text"},{"text":"Four hierarchies are proposed for all layouts: ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"strong"}]},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"minimal"}],"type":"emphasis"},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"negative","type":"text"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Two style are available: ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"loading","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"If button is placed on colored surface using ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Hierarchy.Negative","type":"codeVoice"},{"type":"text","text":" hierarchy is not allowed as a direct or indirect child of an "},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":".","type":"text"}]},{"syntax":"swift","code":["     \/\/ Icon only with default hierarchy","     OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) {}","","     \/\/ Text only with negative hierarchy","     OUDSButton(hierarchy: .negative, text: \"Delete\") {}","","     \/\/ Text and icon with strong hierarchy","     OUDSButton(hierarchy: .strong, icon: Image(\"ic_heart\"), text: \"Validate\") {}"],"type":"codeListing"},{"text":"Customize components","type":"heading","level":2,"anchor":"Customize-components"},{"text":"Apply a specific shadow effect (elevation tokens)","anchor":"Apply-a-specific-shadow-effect-elevation-tokens","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The unified design system implemented by OUDS iOS library allows to apply ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation effets"}]},{"type":"text","text":" on a "},{"type":"codeVoice","code":"View"},{"text":", i.e. a shadow under the component.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Because the design tool in use is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" which defines such shadow with a "},{"inlineContent":[{"text":"blur","type":"text"}],"type":"emphasis"},{"type":"text","text":" and a "},{"inlineContent":[{"text":"spread","type":"text"}],"type":"emphasis"},{"text":" radiuses, and because ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"SwiftUI","type":"text"}]},{"type":"text","text":" uses only its own "},{"type":"emphasis","inlineContent":[{"text":"radius","type":"text"}]},{"text":" definition, an extension of ","type":"text"},{"code":"View","type":"codeVoice"},{"type":"text","text":" has been implemented to let users apply some effect using an "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken"},{"type":"text","text":" from the "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/"},{"type":"text","text":" library thanks to the method "},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"]},{"anchor":"Apply-a-specific-typography-font-tokens","type":"heading","level":3,"text":"Apply a specific typography (font tokens)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your application identity can be strongly based on the "},{"inlineContent":[{"text":"typography","type":"text"}],"type":"emphasis"},{"text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight.","type":"text"}]},{"inlineContent":[{"text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact mode"}]},{"text":" or in ","type":"text"},{"inlineContent":[{"type":"text","text":"regular mode"}],"type":"emphasis"},{"type":"text","text":", and is defined with a "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","type":"reference","isActive":true},{"type":"text","text":". defined in the "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" contains lots of "},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"type":"text","text":" listing all the combinations of typography you can apply, and these "},{"type":"emphasis","inlineContent":[{"text":"composite semantic tokens","type":"text"}]},{"text":" use ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite raw tokens"}]},{"type":"text","text":". For example:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"]},{"inlineContent":[{"type":"text","text":"However the "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" must know which "},{"type":"emphasis","inlineContent":[{"text":"font family","type":"text"}]},{"type":"text","text":" to apply, and this font family can be a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"custom one"}]},{"text":" or the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"system one"}]},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Thus, we let the users define the font family they want by overriding the ","type":"text"},{"type":"codeVoice","code":"fontFamily"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Thus, if you want to apply a specific typography to a ","type":"text"},{"code":"View","type":"codeVoice"},{"type":"text","text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):"}]},{"code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"type":"codeListing","syntax":"swift"},{"anchor":"Apply-a-specific-border-border-tokens","text":"Apply a specific border (border tokens)","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"type":"codeVoice","code":"oudsBorder(style:width:radius:color)"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"text":" ","type":"text"},{"type":"text","text":"The helper is available through "},{"type":"codeVoice","code":"View"},{"type":"text","text":", and tokens through the provider of the theme."}]},{"code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/oudscomponents"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[[]]},"metadata":{"title":"OUDSComponents","externalID":"OUDSComponents","modules":[{"name":"OUDSComponents"}],"roleHeading":"Framework","symbolKind":"module","role":"collection"},"identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","references":{"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/fontsemantictokens/":{"title":"OUDSTkensSemantic FontSemanticTokens","type":"link","titleInlineContent":[{"type":"codeVoice","code":"OUDSTkensSemantic"},{"text":" ","type":"text"},{"type":"codeVoice","code":"FontSemanticTokens"}],"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSButton":{"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSButton"}],"title":"OUDSButton","role":"symbol","url":"\/documentation\/oudscomponents\/oudsbutton","abstract":[{"type":"text","te