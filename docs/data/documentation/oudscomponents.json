{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Customize-components","text":"Customize components","type":"heading","level":2},{"level":3,"type":"heading","anchor":"Apply-a-specific-shadow-effect-elevation-tokens","text":"Apply a specific shadow effect (elevation tokens)"},{"inlineContent":[{"type":"text","text":"The unified design system implemented by OUDS iOS library allows to apply "},{"type":"emphasis","inlineContent":[{"text":"elevation effets","type":"text"}]},{"type":"text","text":" on a "},{"type":"codeVoice","code":"View"},{"type":"text","text":", i.e. a shadow under the component."},{"text":" ","type":"text"},{"type":"text","text":"Because the design tool in use is "},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" which defines such shadow with a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"blur"}]},{"type":"text","text":" and a "},{"inlineContent":[{"type":"text","text":"spread"}],"type":"emphasis"},{"text":" radiuses, and because ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"type":"text","text":" uses only its own "},{"type":"emphasis","inlineContent":[{"text":"radius","type":"text"}]},{"type":"text","text":" definition, an extension of "},{"type":"codeVoice","code":"View"},{"text":" has been implemented to let users apply some effect using an ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","isActive":true,"type":"reference"},{"text":" from the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/"},{"type":"text","text":" library thanks to the method "},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"],"type":"codeListing"},{"anchor":"Apply-a-specific-typography-font-tokens","text":"Apply a specific typography (font tokens)","level":3,"type":"heading"},{"inlineContent":[{"text":"Your application identity can be strongly based on the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"typography"}]},{"text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in ","type":"text"},{"inlineContent":[{"text":"compact mode","type":"text"}],"type":"emphasis"},{"text":" or in ","type":"text"},{"inlineContent":[{"text":"regular mode","type":"text"}],"type":"emphasis"},{"type":"text","text":", and is defined with a "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens"},{"type":"text","text":". defined in the "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true},{"text":".","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"text":" contains lots of ","type":"text"},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"text":" listing all the combinations of typography you can apply, and these ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"composite semantic tokens","type":"text"}]},{"text":" use ","type":"text"},{"inlineContent":[{"text":"composite raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":". For example:"}],"type":"paragraph"},{"code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"However the ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" must know which "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font family"}]},{"text":" to apply, and this font family can be a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"custom one","type":"text"}]},{"text":" or the ","type":"text"},{"inlineContent":[{"text":"system one","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Thus, we let the users define the font family they want by overriding the ","type":"text"},{"type":"codeVoice","code":"fontFamily"},{"text":" property. This value will be used to compute the typography, if not defined the systme font will be used.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"type":"codeVoice","code":"View"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"type":"codeListing"},{"type":"heading","anchor":"Apply-a-specific-border-border-tokens","text":"Apply a specific border (border tokens)","level":3},{"inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"code":"oudsBorder(style:width:radius:color)","type":"codeVoice"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"type":"text","text":" "},{"type":"text","text":"The helper is available through "},{"code":"View","type":"codeVoice"},{"text":", and tokens through the provider of the theme.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing"}]}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"topicSections":[{"anchor":"Components-categories","title":"Components categories","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/d