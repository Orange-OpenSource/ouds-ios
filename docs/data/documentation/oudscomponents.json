{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"symbolKind":"module","title":"OUDSComponents","role":"collection","roleHeading":"Framework","modules":[{"name":"OUDSComponents"}],"externalID":"OUDSComponents"},"hierarchy":{"paths":[[]]},"kind":"symbol","topicSections":[{"generated":true,"title":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable"],"anchor":"Enumerations"},{"generated":true,"anchor":"Extended-Modules","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"title":"Extended Modules"}],"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"❗More details coming soon.❗","type":"text"}]},{"anchor":"Customize-components","level":2,"type":"heading","text":"Customize components"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some helpers are provided through this module."}]},{"type":"heading","text":"Apply a specific shadow effect (elevation tokens)","level":3,"anchor":"Apply-a-specific-shadow-effect-elevation-tokens"},{"type":"paragraph","inlineContent":[{"text":"The unified design system implemented by OUDS iOS library allows to apply ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"elevation effets","type":"text"}]},{"text":" on a ","type":"text"},{"code":"View","type":"codeVoice"},{"text":", i.e. a shadow under the component.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Because the design tool in use is "},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" which defines such shadow with a "},{"inlineContent":[{"text":"blur","type":"text"}],"type":"emphasis"},{"text":" and a ","type":"text"},{"inlineContent":[{"type":"text","text":"spread"}],"type":"emphasis"},{"type":"text","text":" radiuses, and because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"type":"text","text":" uses only its own "},{"type":"emphasis","inlineContent":[{"type":"text","text":"radius"}]},{"text":" definition, an extension of ","type":"text"},{"code":"View","type":"codeVoice"},{"type":"text","text":" has been implemented to let users apply some effect using an "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"reference","isActive":true},{"type":"text","text":" from the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","type":"reference","isActive":true},{"text":" library thanks to the method ","type":"text"},{"code":"shadow(elevation: ElevationCompositeSemanticToken)","type":"codeVoice"},{"type":"text","text":"."}]},{"syntax":"swift","type":"codeListing","code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"]},{"type":"heading","level":3,"text":"Apply a specific typography (font tokens)","anchor":"Apply-a-specific-typography-font-tokens"},{"type":"paragraph","inlineContent":[{"text":"Your application identity can be strongly based on the ","type":"text"},{"inlineContent":[{"type":"text","text":"typography"}],"type":"emphasis"},{"type":"text","text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight."}]},{"inlineContent":[{"type":"text","text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"compact mode"}]},{"text":" or in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"regular mode","type":"text"}]},{"text":", and is defined with a ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","isActive":true,"type":"reference"},{"type":"text","text":". defined in the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"text":" contains lots of ","type":"text"},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"type":"text","text":" listing all the combinations of typography you can apply, and these "},{"type":"emphasis","inlineContent":[{"text":"composite semantic tokens","type":"text"}]},{"text":" use ","type":"text"},{"inlineContent":[{"type":"text","text":"composite raw tokens"}],"type":"emphasis"},{"type":"text","text":". For example:"}]},{"code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"However the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" must know which "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font family"}]},{"type":"text","text":" to apply, and this font family can be a "},{"inlineContent":[{"type":"text","text":"custom one"}],"type":"emphasis"},{"text":" or the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"system one","type":"text"}]},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Thus, we let the users define the font family they want by overriding the "},{"type":"codeVoice","code":"fontFamily"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}]},{"inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"code":"View","type":"codeVoice"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}],"type":"paragraph"},{"code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"type":"codeListing","syntax":"swift"},{"text":"Apply a specific border (border tokens)","level":3,"anchor":"Apply-a-specific-border-border-tokens","type":"heading"},{"inlineContent":[{"type":"text","text":"This module exposes the helper "},{"type":"codeVoice","code":"oudsBorder(style:width:radius:color)"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"type":"text","text":" "},{"type":"text","text":"The helper is available through "},{"code":"View","type":"codeVoice"},{"text":", and tokens through the provider of the theme.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents"]}],"references":{"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/elevationcompositesemantictoken":{"title":"ElevationCompositeSemanticToken","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"link","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","titleInlineContent":[{"code":"ElevationCompositeSemanticToken","type":"codeVoice"}]},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/SwiftUICore":{"kind":"symbol","role":"collection","abstract":[],"url":"\/documentation\/oudscomponents\/swiftuicore","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore","title":"SwiftUICore","type":"topic"},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/fontsemantictokens/":{"title":"OUDSTkensSemantic FontSemanticTokens","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","type":"link","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","titleInlineContent":[{"code":"OUDSTkensSemantic","type":"codeVoice"},{"type":"text","text":" "},{"code":"FontSemanticTokens","type":"codeVoice"}]},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/":{"title":"OUDSTokensSemantic","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","type":"link","titleInlineContent":[{"text":"OUDSTokensSemantic","type":"text"}],"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/AccessibilityFocusable":{"url":"\/documentation\/oudscomponents\/accessibilityfocusable","navigatorTitle":[{"text":"AccessibilityFocusable","kind":"identifier"}],"abstract":[{"type":"text","text":"Value to use as a "},{"code":"AccessibilityFocusState","type":"codeVoice"},{"type":"text","text":" to request focus."}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AccessibilityFocusable","kind":"identifier"}],"title":"AccessibilityFocusable","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable","type":"topic","role":"symbol","kind":"symbol"},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/multiplefontcompositerawtokens":{"title":"MultipleFontCompositeRawTokens","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","type":"link","titleInlineContent":[{"type":"codeVoice","code":"MultipleFontCompositeRawTokens"}],"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents":{"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"type":"text","text":" extensions and "},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"type":"topic","kind":"symbol","role":"collection","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents","title":"OUDSComponents","url":"\/documentation\/oudscomponents"}}}