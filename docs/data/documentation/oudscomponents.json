{"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"text":"Buttons","type":"heading","level":3,"anchor":"Buttons"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"type":"text","text":" propose layout with text only, icon only or text and icon."},{"type":"text","text":" "},{"text":"Four hierarchies are proposed for all layouts: ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"strong","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"minimal"}]},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"negative"}],"type":"emphasis"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Two style are available: "},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"loading"}]},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"If button is placed on colored surface using ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."},{"type":"text","text":" "},{"text":"A button with ","type":"text"},{"type":"codeVoice","code":"OUDSButton.Hierarchy.Negative"},{"text":" hierarchy is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["     \/\/ Icon only with default hierarchy","     OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) {}","","     \/\/ Text only with negative hierarchy","     OUDSButton(hierarchy: .negative, text: \"Delete\") {}"]},{"text":"Links","level":3,"type":"heading","anchor":"Links"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"},{"type":"text","text":" proposes layout with text only or text with icon."},{"type":"text","text":" "},{"text":"It also proposes layout to navigate forward or backward.","type":"text"},{"type":"text","text":" "},{"text":"The link can be displayed in ","type":"text"},{"code":"small","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"medium"},{"type":"text","text":" size."}]},{"type":"codeListing","syntax":"swift","code":["    \/\/ Text only in small size","    OUDSLink(text: \"Feedback\", size: .small) { \/* the action to process *\/ }","","    \/\/ Text and icon in medium size","    OUDSLink(text: \"Feedback\", icon: Image(\"ic_heart\"), size: .medium) { \/* the action to process *\/ }","","    \/\/ Navigate to previous page with link in a medium size","    OUDSLink(text: \"Back\", arrow: .back, size: .medium) { \/* the action to process *\/ }"]},{"type":"heading","level":3,"anchor":"Checkbox","text":"Checkbox"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The library proposes layout to add in your views some checkboxes components, even if this type of component is not iOS-native one."}]},{"code":["     \/\/ A simple checkbox, with only a selector","     OUDSCheckbox(state: $state)","","     \/\/ A leading checkbox with a label","     OUDSCheckboxItem(state: $state, label: \"Hello world\")","","     \/\/ A trailing checkbox with a label, an helper text, an icon, a divider and is about an error","     \/\/ with an inverse layout","     OUDSCheckboxItem(state: $state,","                      labelText: \"We live in a fabled world\",","                      helperText: \"Of dreaming boys and wide-eyed girls\",","                      icon: Image(decorative: \"ic_heart\"),","                      isInversed: true,","                      isError: true,","                      hasDivider: true)"],"syntax":"swift","type":"codeListing"},{"type":"heading","text":"Customize components","level":2,"anchor":"Customize-components"},{"type":"heading","level":3,"text":"Apply a specific shadow effect (elevation tokens)","anchor":"Apply-a-specific-shadow-effect-elevation-tokens"},{"inlineContent":[{"type":"text","text":"The unified design system implemented by OUDS iOS library allows to apply "},{"type":"emphasis","inlineContent":[{"text":"elevation effets","type":"text"}]},{"type":"text","text":" on a "},{"code":"View","type":"codeVoice"},{"type":"text","text":", i.e. a shadow under the component."},{"type":"text","text":" "},{"text":"Because the design tool in use is ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" which defines such shadow with a ","type":"text"},{"inlineContent":[{"type":"text","text":"blur"}],"type":"emphasis"},{"type":"text","text":" and a "},{"inlineContent":[{"type":"text","text":"spread"}],"type":"emphasis"},{"text":" radiuses, and because ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"text":" uses only its own ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"radius"}]},{"type":"text","text":" definition, an extension of "},{"code":"View","type":"codeVoice"},{"text":" has been implemented to let users apply some effect using an ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"reference"},{"text":" from the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/"},{"text":" library thanks to the method ","type":"text"},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"]},{"anchor":"Apply-a-specific-typography-font-tokens","text":"Apply a specific typography (font tokens)","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your application identity can be strongly based on the "},{"type":"emphasis","inlineContent":[{"text":"typography","type":"text"}]},{"type":"text","text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight."}]},{"type":"paragraph","inlineContent":[{"text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in ","type":"text"},{"inlineContent":[{"text":"compact mode","type":"text"}],"type":"emphasis"},{"type":"text","text":" or in "},{"inlineContent":[{"type":"text","text":"regular mode"}],"type":"emphasis"},{"text":", and is defined with a ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens"},{"text":". defined in the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" contains lots of "},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"type":"text","text":" listing all the combinations of typography you can apply, and these "},{"type":"emphasis","inlineContent":[{"text":"composite semantic tokens","type":"text"}]},{"text":" use ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite raw tokens"}]},{"text":". For example:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"However the ","type":"text"},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"type":"text","text":" must know which "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font family"}]},{"text":" to apply, and this font family can be a ","type":"text"},{"inlineContent":[{"type":"text","text":"custom one"}],"type":"emphasis"},{"type":"text","text":" or the "},{"type":"emphasis","inlineContent":[{"text":"system one","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Thus, we let the users define the font family they want by overriding the "},{"code":"fontFamily","type":"codeVoice"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}]},{"inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"type":"codeVoice","code":"View"},{"type":"text","text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"syntax":"swift"},{"text":"Apply a specific border (border tokens)","level":3,"type":"heading","anchor":"Apply-a-specific-border-border-tokens"},{"type":"paragraph","inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"code":"oudsBorder(style:width:radius:color)","type":"codeVoice"},{"text":" so as to apply border semantic tokens on a view in order to define a border effect.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The helper is available through "},{"code":"View","type":"codeVoice"},{"type":"text","text":", and tokens through the provider of the theme."}]},{"syntax":"swift","code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"},"topicSections":[{"anchor":"Group","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","doc:\/\/ouds-ios.OUD