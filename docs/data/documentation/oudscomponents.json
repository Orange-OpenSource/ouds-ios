{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents"]}],"hierarchy":{"paths":[[]]},"kind":"symbol","primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"heading","level":3,"anchor":"Buttons","text":"Buttons"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},{"type":"text","text":" propose layout with text only, icon only or text and icon."},{"text":" ","type":"text"},{"text":"Four hierarchies are proposed for all layouts: ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":", "},{"inlineContent":[{"text":"strong","type":"text"}],"type":"emphasis"},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"minimal"}]},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"negative"}],"type":"emphasis"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Two style are available: "},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"loading"}],"type":"emphasis"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"If button is placed on colored surface using ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."},{"text":" ","type":"text"},{"type":"text","text":"A button with "},{"code":"OUDSButton.Hierarchy.Negative","type":"codeVoice"},{"text":" hierarchy is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":".","type":"text"}]},{"code":["     \/\/ Icon only with default hierarchy","     OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) {}","","     \/\/ Text only with negative hierarchy","     OUDSButton(hierarchy: .negative, text: \"Delete\") {}"],"syntax":"swift","type":"codeListing"},{"type":"heading","level":3,"text":"Links","anchor":"Links"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink","type":"reference","isActive":true},{"type":"text","text":" proposes layout with text only or text with icon."},{"type":"text","text":" "},{"text":"It also proposes layout to navigate forward or backward.","type":"text"},{"type":"text","text":" "},{"text":"The link can be displayed in ","type":"text"},{"code":"small","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"medium","type":"codeVoice"},{"text":" size.","type":"text"}],"type":"paragraph"},{"code":["    \/\/ Text only in small size","    OUDSLink(text: \"Feedback\", size: .small) { \/* the action to process *\/ }","","    \/\/ Text and icon in medium size","    OUDSLink(text: \"Feedback\", icon: Image(\"ic_heart\"), size: .medium) { \/* the action to process *\/ }","","    \/\/ Navigate to previous page with link in a medium size","    OUDSLink(text: \"Back\", arrow: .back, size: .medium) { \/* the action to process *\/ }"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Customize components","type":"heading","anchor":"Customize-components"},{"type":"heading","text":"Apply a specific shadow effect (elevation tokens)","anchor":"Apply-a-specific-shadow-effect-elevation-tokens","level":3},{"inlineContent":[{"text":"The unified design system implemented by OUDS iOS library allows to apply ","type":"text"},{"inlineContent":[{"type":"text","text":"elevation effets"}],"type":"emphasis"},{"text":" on a ","type":"text"},{"code":"View","type":"codeVoice"},{"type":"text","text":", i.e. a shadow under the component."},{"type":"text","text":" "},{"type":"text","text":"Because the design tool in use is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" which defines such shadow with a "},{"inlineContent":[{"type":"text","text":"blur"}],"type":"emphasis"},{"type":"text","text":" and a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"spread"}]},{"type":"text","text":" radiuses, and because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"type":"text","text":" uses only its own "},{"inlineContent":[{"type":"text","text":"radius"}],"type":"emphasis"},{"type":"text","text":" definition, an extension of "},{"code":"View","type":"codeVoice"},{"type":"text","text":" has been implemented to let users apply some effect using an "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"reference","isActive":true},{"text":" from the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true,"type":"reference"},{"type":"text","text":" library thanks to the method "},{"code":"shadow(elevation: ElevationCompositeSemanticToken)","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"]},{"level":3,"anchor":"Apply-a-specific-typography-font-tokens","type":"heading","text":"Apply a specific typography (font tokens)"},{"inlineContent":[{"type":"text","text":"Your application identity can be strongly based on the "},{"inlineContent":[{"type":"text","text":"typography"}],"type":"emphasis"},{"type":"text","text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in "},{"inlineContent":[{"type":"text","text":"compact mode"}],"type":"emphasis"},{"type":"text","text":" or in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"regular mode"}]},{"type":"text","text":", and is defined with a "},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens"},{"type":"text","text":". defined in the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" contains lots of "},{"code":"MultipleFontCompositeRawTokens","type":"codeVoice"},{"text":" listing all the combinations of typography you can apply, and these ","type":"text"},{"inlineContent":[{"text":"composite semantic tokens","type":"text"}],"type":"emphasis"},{"text":" use ","type":"text"},{"inlineContent":[{"type":"text","text":"composite raw tokens"}],"type":"emphasis"},{"text":". For example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"]},{"inlineContent":[{"type":"text","text":"However the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" must know which "},{"type":"emphasis","inlineContent":[{"type":"text","text":"font family"}]},{"text":" to apply, and this font family can be a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"custom one"}]},{"type":"text","text":" or the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"system one"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Thus, we let the users define the font family they want by overriding the ","type":"text"},{"code":"fontFamily","type":"codeVoice"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"type":"codeVoice","code":"View"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."]},{"type":"heading","text":"Apply a specific border (border tokens)","anchor":"Apply-a-specific-border-border-tokens","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"This module exposes the helper "},{"code":"oudsBorder(style:width:radius:color)","type":"codeVoice"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"type":"text","text":" "},{"text":"The helper is available through ","type":"text"},{"type":"codeVoice","code":"View"},{"type":"text","text":", and tokens through the provider of the theme."}]},{"code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing","syntax":"swift"}]}],"topicSections":[{"anchor":"Group","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"],"title":"Group"},{"anchor":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable"],"generated":true,"title":"Enumerations"},{"title":"Extended Modules","anchor":"Extended-Modules","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Foundation","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"generated":true}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents","interfaceLanguage":"swift"},"sections":[],"metadata":{"role":"collection","externalID":"OUDSComponents","modules":[{"name":"OUDSComponents"}],"symbolKind":"module","roleHeading":"Framework","title":"OUDSComponents"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"code":"View","type":"codeVoice"},{"type":"text","text":" extensions and "},{"type":"codeVoice","code":"ViewModifiers"},{"text":" to apply tokens and styles on components and higher-level views.","type":"text"}],"references":{"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/multiplefontcompositerawtokens":{"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","title":"MultipleFontCompositeRawTokens","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","titleInlineContent":[{"type":"codeVoice","code":"MultipleFontCompositeRawTokens"}],"type":"link"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSButton":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSButton","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","type":"reference","isActive":true},{"type":"text","text":" proposes layout with text only, icon only or text with icon."}],"navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"url":"\/documentation\/oudscomponents\/oudsbutton","title":"OUDSButton","role":"symbol"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/Foundation":{"type":"topic","kind":"symbol","role":"collection","title":"Foundation","url":"\/documentation\/oudscomponents\/foundation","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Foundation","abstract":[]},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/AccessibilityFocusable":{"url":"\/documentation\/oudscomponents\/accessibilityfocusable","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AccessibilityFocusable","kind":"identifier"}],"identifier":"doc: