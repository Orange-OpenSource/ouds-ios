{"identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents","interfaceLanguage":"swift"},"hierarchy":{"paths":[[]]},"sections":[],"kind":"symbol","metadata":{"modules":[{"name":"OUDSComponents"}],"roleHeading":"Framework","role":"collection","title":"OUDSComponents","externalID":"OUDSComponents","symbolKind":"module"},"abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"topicSections":[{"anchor":"Enumerations","title":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable"],"generated":true},{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"anchor":"Extended-Modules","title":"Extended Modules"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"❗More details coming soon.❗"}]},{"anchor":"Customize-components","text":"Customize components","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Some helpers are provided through this module.","type":"text"}]},{"type":"heading","text":"Apply a specific shadow effect (elevation tokens)","anchor":"Apply-a-specific-shadow-effect-elevation-tokens","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The unified design system implemented by OUDS iOS library allows to apply "},{"type":"emphasis","inlineContent":[{"type":"text","text":"elevation effets"}]},{"text":" on a ","type":"text"},{"code":"View","type":"codeVoice"},{"type":"text","text":", i.e. a shadow under the component."},{"type":"text","text":" "},{"text":"Because the design tool in use is ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"type":"text","text":" which defines such shadow with a "},{"inlineContent":[{"type":"text","text":"blur"}],"type":"emphasis"},{"text":" and a ","type":"text"},{"inlineContent":[{"text":"spread","type":"text"}],"type":"emphasis"},{"text":" radiuses, and because ","type":"text"},{"inlineContent":[{"type":"text","text":"SwiftUI"}],"type":"emphasis"},{"text":" uses only its own ","type":"text"},{"inlineContent":[{"text":"radius","type":"text"}],"type":"emphasis"},{"text":" definition, an extension of ","type":"text"},{"code":"View","type":"codeVoice"},{"text":" has been implemented to let users apply some effect using an ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken"},{"type":"text","text":" from the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true,"type":"reference"},{"type":"text","text":" library thanks to the method "},{"code":"shadow(elevation: ElevationCompositeSemanticToken)","type":"codeVoice"},{"type":"text","text":"."}]},{"syntax":"swift","type":"codeListing","code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"]},{"type":"heading","level":3,"anchor":"Apply-a-specific-typography-font-tokens","text":"Apply a specific typography (font tokens)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your application identity can be strongly based on the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"typography"}]},{"type":"text","text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight."}]},{"inlineContent":[{"text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in ","type":"text"},{"inlineContent":[{"text":"compact mode","type":"text"}],"type":"emphasis"},{"type":"text","text":" or in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"regular mode"}]},{"type":"text","text":", and is defined with a "},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","isActive":true},{"type":"text","text":". defined in the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" contains lots of "},{"type":"codeVoice","code":"MultipleFontCompositeRawTokens"},{"text":" listing all the combinations of typography you can apply, and these ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite semantic tokens"}]},{"type":"text","text":" use "},{"inlineContent":[{"type":"text","text":"composite raw tokens"}],"type":"emphasis"},{"type":"text","text":". For example:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"]},{"inlineContent":[{"type":"text","text":"However the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" must know which "},{"inlineContent":[{"type":"text","text":"font family"}],"type":"emphasis"},{"type":"text","text":" to apply, and this font family can be a "},{"inlineContent":[{"text":"custom one","type":"text"}],"type":"emphasis"},{"text":" or the ","type":"text"},{"inlineContent":[{"type":"text","text":"system one"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Thus, we let the users define the font family they want by overriding the ","type":"text"},{"code":"fontFamily","type":"codeVoice"},{"text":" property. This value will be used to compute the typography, if not defined the systme font will be used.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"type":"codeVoice","code":"View"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."]},{"text":"Apply a specific border (border tokens)","anchor":"Apply-a-specific-border-border-tokens","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"This module exposes the helper "},{"code":"oudsBorder(style:width:radius:color)","type":"codeVoice"},{"type":"text","text":" so as to apply border semantic tokens on a view in order to define a border effect."},{"type":"text","text":" "},{"type":"text","text":"The helper is available through "},{"code":"View","type":"codeVoice"},{"type":"text","text":", and tokens through the provider of the theme."}],"type":"paragraph"},{"syntax":"swift","code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"],"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents"]}],"references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/SwiftUICore":{"url":"\/documentation\/oudscomponents\/swiftuicore","kind":"symbol","type":"topic","title":"SwiftUICore","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore","role":"collection","abstract":[]},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/AccessibilityFocusable":{"navigatorTitle":[{"kind":"identifier","text":"AccessibilityFocusable"}],"url":"\/documentation\/oudscomponents\/accessibilityfocusable","kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable","title":"AccessibilityFocusable","abstract":[{"text":"Value to use as a ","type":"text"},{"type":"codeVoice","code":"AccessibilityFocusState"},{"text":" to request focus.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"AccessibilityFocusable"}],"type":"topic"},"doc: