{"hierarchy":{"paths":[[]]},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Customize components","anchor":"Customize-components"},{"anchor":"Apply-a-specific-shadow-effect-elevation-tokens","text":"Apply a specific shadow effect (elevation tokens)","level":3,"type":"heading"},{"inlineContent":[{"text":"The unified design system implemented by OUDS iOS library allows to apply ","type":"text"},{"inlineContent":[{"text":"elevation effets","type":"text"}],"type":"emphasis"},{"type":"text","text":" on a "},{"code":"View","type":"codeVoice"},{"text":", i.e. a shadow under the component.","type":"text"},{"type":"text","text":" "},{"text":"Because the design tool in use is ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"text":" which defines such shadow with a ","type":"text"},{"inlineContent":[{"text":"blur","type":"text"}],"type":"emphasis"},{"type":"text","text":" and a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"spread"}]},{"type":"text","text":" radiuses, and because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"type":"text","text":" uses only its own "},{"inlineContent":[{"text":"radius","type":"text"}],"type":"emphasis"},{"type":"text","text":" definition, an extension of "},{"code":"View","type":"codeVoice"},{"text":" has been implemented to let users apply some effect using an ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/elevationcompositesemantictoken","type":"reference","isActive":true},{"text":" from the ","type":"text"},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true},{"type":"text","text":" library thanks to the method "},{"type":"codeVoice","code":"shadow(elevation: ElevationCompositeSemanticToken)"},{"type":"text","text":"."}],"type":"paragraph"},{"code":["\/\/ For example, apply the elevation effect \"elevationDragLight\" from your theme:","myView.shadow(elevation: theme.elevationDragLight)","","\/\/ And in the theme this \"elevationDragLight\" has been defined for example like:","@objc open var elevationDragLight: ElevationCompositeSemanticToken { ElevationRawTokens.elevationBottom_3_500 }","ColorRawTokens.colorOpacityBlack400)","","\/\/ And if you look deeper, the raw token \"elevationBottom_3_500\" can be like:","public static let elevationBottom_3_500 = ElevationCompositeRawToken(x: 0, y: 4, blur: 4, color: ColorRawTokens.colorOpacityBlack500)","","\/\/ Blur will be used to compute the radius value"],"syntax":"swift","type":"codeListing"},{"type":"heading","text":"Apply a specific typography (font tokens)","level":3,"anchor":"Apply-a-specific-typography-font-tokens"},{"type":"paragraph","inlineContent":[{"text":"Your application identity can be strongly based on the ","type":"text"},{"inlineContent":[{"type":"text","text":"typography"}],"type":"emphasis"},{"text":" you use, i.e. the font family you choose and other configuration details like the font size or the font weight.","type":"text"}]},{"inlineContent":[{"text":"With OUDS, typography depends to the class size, i.e. wether or not the application is in ","type":"text"},{"inlineContent":[{"text":"compact mode","type":"text"}],"type":"emphasis"},{"type":"text","text":" or in "},{"inlineContent":[{"type":"text","text":"regular mode"}],"type":"emphasis"},{"text":", and is defined with a ","type":"text"},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens","isActive":true},{"text":". defined in the ","type":"text"},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/fontsemantictokens\/","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"type":"text","text":" contains lots of "},{"type":"codeVoice","code":"MultipleFontCompositeRawTokens"},{"type":"text","text":" listing all the combinations of typography you can apply, and these "},{"inlineContent":[{"text":"composite semantic tokens","type":"text"}],"type":"emphasis"},{"text":" use ","type":"text"},{"inlineContent":[{"type":"text","text":"composite raw tokens"}],"type":"emphasis"},{"text":". For example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Here is a definition of a semantic token inside the theme for typography \"typeDisplayMedium\":","@objc open var typeDisplayMedium: MultipleFontCompositeRawTokens { ","MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold750, regular: FontRawTokens.typeBold1050) ","}","","\/\/ And here are the raw tokebs definitions:","public static let typeBold750 = FontCompositeRawToken(size: fontSize750, lineHeight: fontLineHeight850, weight: fontWeightBold)","","public static let typeBold1050 = FontCompositeRawToken(size: fontSize1050, lineHeight: fontLineHeight1150, weight: fontWeightBold)"]},{"inlineContent":[{"text":"However the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" must know which "},{"inlineContent":[{"type":"text","text":"font family"}],"type":"emphasis"},{"text":" to apply, and this font family can be a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"custom one"}]},{"type":"text","text":" or the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"system one"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Thus, we let the users define the font family they want by overriding the ","type":"text"},{"code":"fontFamily","type":"codeVoice"},{"type":"text","text":" property. This value will be used to compute the typography, if not defined the systme font will be used."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Thus, if you want to apply a specific typography to a "},{"type":"codeVoice","code":"View"},{"text":", supposing you defined previously the semantic tokens, just call the method you want and gives as parameter the theme (to get the custom font if defined):","type":"text"}],"type":"paragraph"},{"code":["\/\/ Apply typography \"type body default small\"","myView.typeBodyDefaultSmall(theme)","","\/\/ Apply typography \"type label strong X large\"","myView.typeLabelStrongXLarge(theme)","","\/\/ Etc."],"type":"codeListing","syntax":"swift"},{"anchor":"Apply-a-specific-border-border-tokens","text":"Apply a specific border (border tokens)","type":"heading","level":3},{"inlineContent":[{"text":"This module exposes the helper ","type":"text"},{"code":"oudsBorder(style:width:radius:color)","type":"codeVoice"},{"text":" so as to apply border semantic tokens on a view in order to define a border effect.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The helper is available through "},{"code":"View","type":"codeVoice"},{"type":"text","text":", and tokens through the provider of the theme."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["    @Environment(\\.theme) private var theme","","    var body: some View {","        SomeView()","        .oudsBorder(","             style: theme.borders.borderStyleDefault,","             width: theme.borders.borderWidthThin,","             radius: theme.borders.borderRadiusNone,","             color: theme.colors.colorBorderDefault)","     }"]}],"kind":"content"}],"abstract":[{"text":"The catalog of all components provided by OUDS. It contains also ","type":"text"},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"code":"ViewModifiers","type":"codeVoice"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"metadata":{"modules":[{"name":"OUDSComponents"}],"title":"OUDSComponents","externalID":"OUDSComponents","symbolKind":"module","role":"collection","roleHeading":"Framework"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Actions","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Navigation","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Input"],"anchor":"Components-categories","title":"Components categories"},{"title":"Structures","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/DividerModifier","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"],"generated":true,"anchor":"Structures"},{"title":"Enumerations","generated":true,"anchor":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/AccessibilityFocusable","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxSelectorState"]},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Foundation","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/Swift","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/SwiftUICore"],"generated":true,"anchor":"Extended-Modules","title":"Extended Modules"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents"]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents","interfaceLanguage":"swift"},"references":{"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/fontsemantictokens/":{"type":"link","title":"OUDSTkensSemantic FontSemanticTokens","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstoken