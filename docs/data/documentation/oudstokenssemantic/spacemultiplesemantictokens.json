{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens"},"metadata":{"navigatorTitle":[{"text":"SpaceMultipleSemanticTokens","kind":"identifier"}],"symbolKind":"protocol","title":"SpaceMultipleSemanticTokens","role":"symbol","modules":[{"name":"OUDSTokensSemantic"}],"roleHeading":"Protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SpaceMultipleSemanticTokens"}],"externalID":"s:18OUDSTokensSemantic013SpaceMultipleB6TokensP"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"abstract":[{"text":"This is a group of semantic tokens for ","type":"text"},{"inlineContent":[{"text":"spacings","type":"text"}],"type":"strong"},{"type":"text","text":" but using "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSpaceSemanticTokens","isActive":true},{"type":"text","text":"."}],"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"topicSections":[{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledMedium","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledNone","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledShort","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledShorter","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledShortest","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledSmash","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledSpacious","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledTall","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledTaller","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledTallest"],"anchor":"Instance-Properties"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"SpaceMultipleSemanticTokens","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"inlineContent":[{"text":"In fact the ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSpaceSemanticTokens","isActive":true},{"text":" class will help users (i.e. developers) to handle one semantic token for spacing containing values for compact (mobile) or regular (tablet) size classes.","type":"text"},{"text":" ","type":"text"},{"text":"Because ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Figma","type":"text"}]},{"text":" is not able to manage pair of values for one token, and its produced JSON does not reflect this mecanism, the ","type":"text"},{"inlineContent":[{"text":"tokenator","type":"text"}],"type":"emphasis"},{"text":" cannot provide such ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSpaceSemanticTokens"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Thus the “real” color semantic tokens are declared in "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceSemanticTokens","isActive":true},{"text":" protocol and defined inside ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" (to be overridable then by subthemes)."},{"type":"text","text":" "},{"type":"text","text":"These tokens are updated by the "},{"inlineContent":[{"text":"tokenator","type":"text"}],"type":"emphasis"},{"type":"text","text":". Then they are gathered and wrapped so as to be used easily thanks to this "},{"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens","isActive":true,"type":"reference"},{"text":" which must be updated manually.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In few words:","type":"text"}]},{"type":"codeListing","code":["        \/\/ Some spacing raw tokens, defined by the tokenator (in DimensionRawTokens+Values.swift)","        public static let dimension0: DimensionRawToken = 0","        public static let dimension25: DimensionRawToken = 2","","        \/\/ The spacing semantic tokens using them,","        \/\/ declared (in SpaceSemanticTokens.swift) and defined (in OUDSTheme+SpaceSemanticTokens.swift) by the tokenator","        var spaceScaledNoneMobile: SpaceSemanticToken { DimensionRawTokens.dimension0 }","        var spaceScaledNoneTablet: SpaceSemanticToken { DimensionRawTokens.dimension25 }","","        \/\/ The 'higher level' spacing semantic tokens wrapping them and exposed to users,","        \/\/ declared (in SpaceMultipleSemanticTokens.swift) and defined (in OUDSTheme+SpaceMultipleSemanticTokens.swift) manualy","        var spaceScaledNone: MultipleSpaceSemanticTokens { MultipleSpaceSemanticTokens(compact: spaceScaledNoneMobile, regular: spaceScaledNoneTablet) }","","        \/\/ Thus users can in their components use spaceScaledNone as defined in their design system","        \/\/ (even if they are still able to use 'lower level' semantic tokens but it is more error-prone)"],"syntax":"swift"}]}],"variants":[{"traits":[{"inte