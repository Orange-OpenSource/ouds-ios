{"topicSections":[{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledMedium","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledNone","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledShort","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledShorter","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledShortest","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledSmash","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledSpacious","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledTall","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledTaller","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens\/spaceScaledTallest"],"anchor":"Instance-Properties"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SpaceMultipleSemanticTokens"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"inlineContent":[{"text":"In fact the ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSpaceSemanticTokens","isActive":true,"type":"reference"},{"type":"text","text":" class will help users (i.e. developers) to handle one semantic token for spacing containing values for compact (mobile) or regular (tablet) size classes."},{"text":" ","type":"text"},{"type":"text","text":"Because "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"text":" is not able to manage pair of values for one token, and its produced JSON does not reflect this mecanism, the ","type":"text"},{"inlineContent":[{"text":"tokenator","type":"text"}],"type":"emphasis"},{"type":"text","text":" cannot provide such "},{"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSpaceSemanticTokens","type":"reference","isActive":true},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Thus the “real” color semantic tokens are declared in ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceSemanticTokens"},{"type":"text","text":" protocol and defined inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" (to be overridable then by subthemes)."},{"type":"text","text":" "},{"type":"text","text":"These tokens are updated by the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokenator"}]},{"type":"text","text":". Then they are gathered and wrapped so as to be used easily thanks to this "},{"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens","isActive":true,"type":"reference"},{"text":" which must be updated manually.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each token declared in this protocol must have its version "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Mobile"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Tablet"}]},{"type":"text","text":" declared in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceSemanticTokens"},{"type":"text","text":" protocol in order to define "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSpaceSemanticTokens","type":"reference"},{"text":" for each pair of them.","type":"text"}]},{"inlineContent":[{"text":"In few words:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["        \/\/ Some spacing raw tokens, defined by the tokenator (in DimensionRawTokens+Values.swift)","        public static let dimension0: DimensionRawToken = 0","        public static let dimension25: DimensionRawToken = 2","","        \/\/ The spacing semantic tokens using them,","        \/\/ declared (in SpaceSemanticTokens.swift) and defined (in OUDSTheme+SpaceSemanticTokens.swift) by the tokenator","        var spaceScaledNoneMobile: SpaceSemanticToken { DimensionRawTokens.dimension0 }","        var spaceScaledNoneTablet: SpaceSemanticToken { DimensionRawTokens.dimension25 }","","        \/\/ The 'higher level' spacing semantic tokens wrapping them and exposed to users,","        \/\/ declared (in SpaceMultipleSemanticTokens.swift) and defined (in OUDSTheme+SpaceMultipleSemanticTokens.swift) manualy","        var spaceScaledNone: MultipleSpaceSemanticTokens { MultipleSpaceSemanticTokens(compact: spaceScaledNoneMobile, regular: spaceScaledNoneTablet) }","","        \/\/ Thus users can in their components use spaceScaledNone as defined in their design system","        \/\/ (even if they are still able to use 'lower level' semantic tokens but it is more error-prone)"]}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"This is a group of semantic tokens for "},{"type":"strong","inlineContent":[{"text":"spacings","type":"text"}]},{"text":" but using ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleSpaceSemanticTokens"},{"type":"text","text":"."}],"metadata":{"modules":[{"name":"OUDSTokensSemantic"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SpaceMultipleSemanticTokens","kind":"identifier"}],"navigatorTitle":[{"text":"SpaceMultipleSemanticTokens","kind":"identifier"}],"title":"SpaceMultipleSemanticTokens","role":"symbol","externalID":"s:18OUDSTokensSemantic013SpaceMultipleB6TokensP","roleHeading":"Protocol","symbolKind":"protocol"},"identifier":{"url":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceMultipleSemanticTokens","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/oudstokenssemantic\/spacemultiplesemantictokens"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://ouds-ios.OUDSTokensSemantic/documentation/OUDSTokensSemantic/SpaceSemanticTokens":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SpaceSemanticTokens"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"SpaceSemanticTokens"}],"url":"\/documentation\/oudstokenssemantic\/spacesemantictokens","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"This is a group of semantic tokens for "},{"type":"strong","inlineContent":[{"type":"text","text":"spacing"}]},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"It defines all ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceSemanticToken","isActive":true},{"text":" a theme must have.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Any space semantic token must be declared there."}],"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/SpaceSemanticTokens","title":"SpaceSemanticTokens"},"doc://ouds-ios.OUDSTokensSemantic/documentation/OUDSTokensSemantic/SpaceMulti