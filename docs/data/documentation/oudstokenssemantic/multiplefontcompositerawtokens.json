ld650) }","","        \/\/ The theme exposes both generated elevation semantic tokens and \"crafted\" higher level elevation semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"inlineContent":[{"type":"text","text":"The case of this "},{"identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens","isActive":true,"type":"reference"},{"text":" is quite particular because in fact it contains ","type":"text"},{"code":"FontCompositeRawToken","type":"codeVoice"},{"type":"text","text":" "},{"text":"(i.e. raw tokens) instead of semantic tokens.","type":"text"},{"text":" ","type":"text"},{"text":"In fact there is not “font composite semantic tokens” defined in the ","type":"text"},{"inlineContent":[{"text":"Figma","type":"text"}],"type":"emphasis"},{"type":"text","text":" kit."}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.8.0"}]}],"style":"note","name":"Since"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudstokenssemantic\/multiplefontcompositerawtokens"]}],"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"kind":"symbol","relationshipsSections":[{"title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/objc(cs)NSObject"],"kind":"relationships"},{"title":"Conforms To","type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/objc(pl)NSObject","doc:\/\/ouds-ios.OUDSTokensSemantic\/s7CVarArgP","doc:\/\/ouds-ios.OUDSTokensSemantic\/s28CustomDebugStringConvertibleP","doc:\/\/ouds-ios.OUDSTokensSemantic\/s23CustomStringConvertibleP","doc:\/\/ouds-ios.OUDSTokensSemantic\/SQ","doc:\/\/ouds-ios.OUDSTokensSemantic\/SH","doc:\/\/ouds-ios.OUDSTokensSemantic\/s8SendableP"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"d