{"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens\/init(_:)","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens\/init(compact:regular:)"],"generated":true,"title":"Initializers"},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens\/compact","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens\/regular"]},{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens\/fontToken(for:)","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens\/isEqual(_:)"],"anchor":"Instance-Methods","title":"Instance Methods"}],"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipleFontCompositeRawTokens"}]}]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"codeListing","code":["        \/\/ Assuming in Figma with have a font semantic token typeDisplayLarge,","        \/\/ with values depending to size class. These values are defined as font composite raw tokens.","        let typeBold850 = FontCompositeRawToken(size: fontSize850, lineHeight: fontLineHeight1050, weight: fontWeight700, letterSpacing: fontLetterSpacing850)","        let typeBold1450 = FontCompositeRawToken(size: fontSize1450, lineHeight: fontLineHeight1850, weight: fontWeight700, letterSpacing: fontLetterSpacing1450)","","        \/\/ Then the develoment team declares an \"higher\" level font semantic token","        \/\/ inside FontCompositeSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+FontCompositeSemanticTokens extension","        var typeDisplayLarge: MultipleFontCompositeRawTokens {","            MultipleFontCompositeRawTokens(compact: FontRawTokens.typeBold850, regular: FontRawTokens.typeBold1450)","        }","","        \/\/ If the same font is used whatever the size class is","        var typeDisplayLarge: MultipleFontCompositeRawTokens { MultipleFontCompositeRawTokens(FontRawTokens.typeBold650) }","","        \/\/ The theme exposes both generated elevation semantic tokens and \"crafted\" higher level elevation semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."],"syntax":"swift"},{"inlineContent":[{"text":"The case of this ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens","isActive":true},{"text":" is quite particular because in fact it contains ","type":"text"},{"code":"FontCompositeRawToken","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"(i.e. raw tokens) instead of semantic tokens."},{"type":"text","text":" "},{"text":"In fact there is not “font composite semantic tokens” defined in the ","type":"text"},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" kit."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"0.8.0","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Since"}]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleFontCompositeRawTokens","interfaceLanguage":"swift"},"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/objc(cs)NSObject"],"type