{"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/objc(cs)NSObject"],"title":"Inherits From"},{"kind":"relationships","identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/objc(pl)NSObject","doc:\/\/ouds-ios.OUDSTokensSemantic\/s7CVarArgP","doc:\/\/ouds-ios.OUDSTokensSemantic\/s28CustomDebugStringConvertibleP","doc:\/\/ouds-ios.OUDSTokensSemantic\/s23CustomStringConvertibleP","doc:\/\/ouds-ios.OUDSTokensSemantic\/SQ","doc:\/\/ouds-ios.OUDSTokensSemantic\/SH","doc:\/\/ouds-ios.OUDSTokensSemantic\/s8SendableP"],"title":"Conforms To","type":"conformsTo"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/oudstokenssemantic\/multipleelevationcompositerawtokens"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MultipleElevationCompositeRawTokens","kind":"identifier"}],"languages":["swift"],"platforms":["iOS"]}]},{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"type":"codeListing","syntax":"swift","code":["        \/\/ Assuming in Figma with have a elevation semantic token elevationNone,","        \/\/ with values depending to color scheme. These values are defined as elevation raw tokens.","        let elevationBottom_0 = ElevationCompositeRawToken(x: elevationX0, y: elevationY0, blur: elevationBlur0, color: ColorRawTokens.colorOpacityBlack0)","        let elevationBottom_1_100 = ElevationCompositeRawToken(x: elevationX0, y: elevationY100, blur: elevationBlur200, color: ColorRawTokens.colorOpacityBlack100)","","        \/\/ Then the develoment team declares an \"higher\" level elevation semantic token","        \/\/ inside ElevationCompositeSemanticTokens protocol,","        \/\/ and defined inside OUDSTheme+ElevationCompositeSemanticTokens extension","        \/\/ ElevationCompositeSemanticToken is a typealias for MultipleElevationCompositeRawTokens to keep same grammar as dsign kit","        var elevationNone: ElevationCompositeSemanticToken {","            ElevationCompositeSemanticToken(light: elevationBottom_0, dark: elevationBottom_1_100)","        }","","        \/\/ If the same elevation is used whatever the color scheme is","        var elevationNone: ElevationCompositeSemanticToken {","            ElevationCompositeSemanticToken(elevationBottom_0)","        }","","        \/\/ The theme exposes both generated elevation semantic tokens and \"crafted\" higher level elevation semantic tokens.","        \/\/ It is recommended to use the higher level version as it is less error-prone."]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The case of this "},{"code":"MultipleElevationCompositeRawTokens","type":"codeVoice"},{"text":" is quite particular because in fact it contains ","type":"text"},{"code":"MultipleElevationCompositeRawTokens","type":"codeVoice"},{"type":"text","text":" (i.e. raw tokens) instead of semantic tokens."},{"text":" ","type":"text"},{"type":"text","text":"In fact only the "},{"inlineContent":[{"text":"color","type":"text"}],"type":"emphasis"},{"text":" of the elevation effect vary depending to the color scheme,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"but in the "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":" kit this is composite raw tokens which are defined for ligh and dark mode as only one token."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic"]]},"abstract":[{"type":"text","text":"Semantic tokens which will wrap a combination of "},{"code":"ElevationCompositeRawToken","type":"codeVoice"},{"type":"text","text":" depending to color scheme (i.e. light mode or dark mode)"},{"type":"text","text":" "},{"type":"text","text":"Kind of composite token with multiple values, but not named “composite” because this word is already used in the design system."},{"type":"text","text":" "},{"type":"text","text":"Allows to gather the multiple-value tokens from "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Figma"}]},{"type":"text","text":" inside one object."},{"type":"text","text":" "},{"type":"text","text":"If an elevation token exists with its value depending to the color scheme, it must be packed in such ``MultipleElevationCompositeRawTokens`"}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens\/init(_:)","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens\/init(light:dark:)"],"title":"Initializers","generated":true},{"anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens\/dark","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens\/light"],"title":"Instance Properties"},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens\/elevation(for:)","doc:\/\/ouds-ios.OUDSTokensSemantic\/documentation\/OUDSTokensSemantic\/MultipleElevationCompositeRawTokens\/isEqual(_:)"]}],"sections":[],"metadata":{"modules":[{"name":"OUDSTokensSemantic"}],"role":"symbol","title":"MultipleElevationCompositeRawTokens","roleHeading":"Class","externalID":"c:@M@OUDSTokensSemantic@objc(cs)MultipleElevationCompositeRawTokens","fragments":[{"kind":"k