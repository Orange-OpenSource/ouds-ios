{"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"]]},"abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"text":" proposes layouts to add in your views some checkboxes components with labels and icons.","type":"text"},{"text":" ","type":"text"},{"text":"If you want to use a checkbox with only an indicator prefer instead ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox"},{"text":".","type":"text"}],"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}],"modules":[{"name":"OUDSComponents"}],"title":"OUDSCheckboxItem","roleHeading":"Structure","role":"symbol","navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"symbolKind":"struct","externalID":"s:14OUDSComponents16OUDSCheckboxItemV"},"identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","interfaceLanguage":"swift"},"kind":"symbol","topicSections":[{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:labelText:helperText:icon:isInversed:isError:isReadOnly:hasDivider:)"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"],"title":"Instance Properties","anchor":"Instance-Properties"},{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Layouts","anchor":"Layouts","type":"heading"},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"inverse","type":"text"}],"type":"strong"},{"type":"text","text":": like the "},{"inlineContent":[{"text":"default","type":"text"}],"type":"emphasis"},{"type":"text","text":" layout but with a trailing checkbox indicator and a leading optional image"}]}]}],"type":"unorderedList"},{"level":2,"text":"Indicator states","anchor":"Indicator-states","type":"heading"},{"inlineContent":[{"text":"The checkbox indicator has three available states:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"If you are looking for a checkbox component with three states, use instead ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},{"type":"text","text":"."}]},{"type":"heading","text":"Particular cases","anchor":"Particular-cases","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In addition, the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."}]},{"type":"heading","text":"Accessibility considerations","anchor":"Accessibility-considerations","level":2},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait."}]},{"type":"heading","text":"Forbidden by design","anchor":"Forbidden-by-design","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}]}]},{"type":"heading","text":"Code samples","anchor":"Code-samples","level":2},{"type":"codeListing","code":["    \/\/ Supposing we have an unselected checkbox","    @Published var isOn: Bool = false","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, labelText: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, labelText: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, labelText: \"Bazinga!\", helperText: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItem(isOn: $isOn,","                     labelText: \"We live in a fabled world\",","                     helperText: \"Of dreaming boys and wide-eyed girls\",","                     isInversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing checkbox with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItem(isOn: $isOn,","                     labelText: \"Rescue from this world!\",","                     helperText: \"Put your hand in mine\",","                     icon: Image(decorative: \"ic_heart\"),","                     isInversed: true,","                     isError: true,","                     divider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(isOn: $isOn, labelText: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(isOn: $isOn, labelText: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(isOn: $isOn, labelText: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"type":"heading","text":"Design documentation","anchor":"Design-documentation","level":2},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox"}]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}],"name":"Since"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"]}],"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/init(isOn:labelText:helperText:icon:isInversed:isError:isReadOnly:hasDivider:)":{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(isOn:labelText:helperText:icon:isInversed:isError:isReadOnly:hasDivider:)","url":"\/documentation\/oudscomponents\/oudscheckboxitem\/init(ison:labeltext:helpertext:icon:isinversed:iserror:isreadonly:hasdivider:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"isOn"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Binding","pre