{"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"]}],"metadata":{"modules":[{"name":"OUDSComponents"}],"role":"symbol","title":"OUDSCheckboxItem","externalID":"s:14OUDSComponents16OUDSCheckboxItemV","symbolKind":"struct","roleHeading":"Structure","navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(state:labelText:helperText:icon:isInversed:isError:isReadOnly:hasDivider:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"]},{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"]}],"seeAlsoSections":[{"generated":true,"title":"Group","anchor":"Group","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSLink"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItem","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"Layouts","text":"Layouts","level":2},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":": the component has a leading selector, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"inverse"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing checkbox seelctor and a leading optional image"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to use a checkbox with only the selector, prefer instead "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"level":2,"text":"Selector states","anchor":"Selector-states","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox selector has three available states:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"unselected"}]},{"text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"undeterminate"}],"type":"strong"},{"text":": mike a prefilled or preticked checkbox, the user did not do anything on it yet","type":"text"}]}]}],"type":"unorderedList"},{"text":"Particular cases","type":"heading","level":2,"anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"},{"type":"text","text":" "},{"text":"In addition, the ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference","isActive":true},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as disabled."}]},{"type":"heading","anchor":"Forbidden-by-design","text":"Forbidden by design","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"},{"type":"text","text":" "},{"inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}],"type":"strong"}]},{"text":"Code samples","type":"heading","level":2,"anchor":"Code-samples"},{"code":["    \/\/ Supposing we have an undeterminate state checkbox","    @Published var state: OUDSCheckboxSelectorState  = .undeterminate","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(state: $state, labelText: \"Bazinga!\", helperText: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItem(state: $state,","                     labelText: \"We live in a fabled world\",","                     helperText: \"Of dreaming boys and wide-eyed girls\",","                     isInversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing checkbox with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItem(state: $state,","                     labelText: \"Rescue from this world!\",","                     helperText: \"Put your hand in mine\",","                     icon: Image(decorative: \"ic_heart\"),","                     isInversed: true,","                     isError: true,","                     divider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"type":"codeListing","syntax":"swift"},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox"}]},{"type":"aside","name":"Since","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}]}]}],"sections":[],"abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"type":"text","text":" proposes layouts to add in your views some checkboxes components."}],"references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents":{"role":"collection","abstract":[{"type":"text","text":"The catalog of all components provided by OUDS. It contains also "},{"type":"codeVoice","code":"View"},{"text":" extensions and ","type":"text"},{"type":"codeVoice","code":"ViewModifiers"},{"type":"text","text":" to apply tokens and styles on components and higher-level views."}],"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents","kind":"symbol","title":"OUDSComponents","url":"\/documentation\/oudscomponents"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSCheckbox":{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","fragments":[{"t