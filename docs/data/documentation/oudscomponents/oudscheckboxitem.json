{"relationshipsSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"metadata":{"role":"symbol","symbolKind":"struct","navigatorTitle":[{"text":"OUDSCheckboxItem","kind":"identifier"}],"modules":[{"name":"OUDSComponents"}],"externalID":"s:14OUDSComponents16OUDSCheckboxItemV","title":"OUDSCheckboxItem","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSCheckboxItem"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},{"type":"text","text":" proposes layouts to add in your views some checkboxes components."},{"text":" ","type":"text"},{"type":"text","text":"If you want to use a checkbox with only a selector, prefer instead "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckbox","isActive":true,"type":"reference"},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudscheckboxitem"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem"},"schemaVersion":{"minor":3,"patch":0,"major":0},"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/init(state:labelText:helperText:icon:isInversed:isError:isReadOnly:hasDivider:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/body"],"anchor":"Instance-Properties"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem\/View-Implementations"],"title":"Default Implementations","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"text":" ","kind":"text"},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItem"}],"platforms":["iOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"Layouts","text":"Layouts","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"default","type":"text"}],"type":"strong"},{"text":": the component has a leading selector, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"inverse","type":"text"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":" layout but with a trailing checkbox seelctor and a leading optional image"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Selector-states","type":"heading","text":"Selector states"},{"type":"paragraph","inlineContent":[{"text":"The checkbox selector has three available states:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"undeterminate","type":"text"}]},{"text":": mike a prefilled or preticked checkbox, the user did not do anything on it yet","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Particular-cases","level":2,"type":"heading","text":"Particular cases"},{"inlineContent":[{"text":"An ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","type":"reference"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"text":" ","type":"text"},{"text":"In addition, the ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"type":"text","text":" "},{"text":"as disabled.","type":"text"}],"type":"paragraph"},{"text":"Forbidden by design","level":2,"anchor":"Forbidden-by-design","type":"heading"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}],"type":"strong"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}]},{"type":"text","text":" "},{"inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}],"type":"strong"}]},{"level":2,"text":"Code samples","type":"heading","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an undeterminate state checkbox","    @Published var state: OUDSCheckboxSelectorState  = .undeterminate","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(state: $state, labelText: \"Bazinga!\", helperText: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItem(state: $state,","                     labelText: \"We live in a fabled world\",","                     helperText: \"Of dreaming boys and wide-eyed girls\",","                     isInversed: true,","                     icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing checkbox with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItem(state: $state,","                     labelText: \"Rescue from this world!\",","                     helperText: \"Put your hand in mine\",","                     icon: Image(decorative: \"ic_heart\"),","                     isInversed: true,","                     isError: true,","                     divider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItem(state: $state, labelText: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"]},{"type":"heading","anchor":"Design-documentation","text":"Design documentation","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","isActive":true}]},{"type":"aside","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}],"style":"note"}]}],"references":{"doc://ouds-ios.OUDSComponents/s8SendableP":{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"https://unified-design-system.orange.com/472794e18/p/23f1c1-checkbox":{"type":"link","title":"unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox"}],"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItem/body":{"role":"symbol","url":"\/documentation\/oudscomponents\/oudscheckboxitem\/body","abstract":[],"title":"body","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"keyword","text":"some"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:7SwiftUI4ViewP","kind":"typeIdentifier"}],"type":