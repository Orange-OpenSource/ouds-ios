{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","interfaceLanguage":"swift"},"metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"OUDSRadioItem","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSRadioItem"}],"externalID":"s:14OUDSComponents13OUDSRadioItemV","title":"OUDSRadioItem","roleHeading":"Structure","modules":[{"name":"OUDSComponents"}],"symbolKind":"struct","role":"symbol"},"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"text":" proposes layouts to add in your views some radios components.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If you want to use a radio with only an indicator, prefer instead "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","type":"reference","isActive":true},{"text":".","type":"text"}],"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"]]},"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:labelText:additionalLabelText:helperText:icon:isOutlined:isInversed:isError:isReadOnly:hasDivider:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/body"],"anchor":"Instance-Properties","generated":true},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsradioitem"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSRadioItem"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"text":"Layouts","type":"heading","level":2,"anchor":"Layouts"},{"type":"paragraph","inlineContent":[{"text":"The component can be rendered as two different layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"inverse"}]},{"type":"text","text":": like the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":" layout but with a trailing radio indicator and a leading optional decorative icon"}]}]}]},{"type":"heading","anchor":"Indicator-states","text":"Indicator states","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The radio indicator has two available states:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the radio is filled with a filled circle, the user has made the action to select the radio"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the radio is empty, does not contain anything, the user has made the action to unselect or did not select yet the radio"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Particular-cases","level":2,"type":"heading","text":"Particular cases"},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"code":"isError","type":"codeVoice"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"text":"In addition, the ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The radio can be also outlined in some cases."}],"type":"paragraph"},{"level":2,"text":"Accessibility considerations","type":"heading","anchor":"Accessibility-considerations"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"type":"text","text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom radio trait."}],"type":"paragraph"},{"level":2,"anchor":"Forbidden-by-design","type":"heading","text":"Forbidden by design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}]},{"level":2,"text":"Code samples","anchor":"Code-samples","type":"heading"},{"syntax":"swift","type":"codeListing","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A leading radio with a label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\")","","    \/\/ A leading radio with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\", isReadOnly: true)","","    \/\/ A leading radio with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\", helperText: \"The Beatles\")","","    \/\/ A leading oulined radio with an additional label, an helper text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\", additionalLabelText: \"The Beatles\", helperText: \"1967\", outlined: true)","","    \/\/ A leading radio with an additional label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\", additionalLabelText: \"The Beatles\", helperText: \"1967\")","","    \/\/ A trailing radio with a label, an additonal label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSRadioItem(isOn: $selection,","                  labelText: \"Lucy in the Sky with Diamonds\",","                  additionalLabelText: \"The Beatles\",","                  helperText: \"1967\",","                  isInversed: true,","                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing radio with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSRadioItem(isOn: $selection,","                  labelText: \"Rescue from this world!\",","                  helperText: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isInversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ A leading radio with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Rescue from this world!\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related radio as it will crash","    \/\/ This is forbidden by design!","    OUDSRadioItem(isOn: $selection, labelText: \"Kaboom!\", isError: true).disabled(true) \/\/ fatal error","    OUDSRadioItem(isOn: $selection, labelText: \"Kaboom!\", isReadyOnly: true).disabled(true) \/\/ fatal error"]},{"type":"heading","text":"Design documentation","level":2,"anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/73c701-components","type":"reference","isActive":true}]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}],"name":"Since","type":"aside"}],"kind":"content"}],"references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSRadioItem/View-Implementations":{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","title":"View Implementations","kind":"article","url":"\/documentation\/oudsco