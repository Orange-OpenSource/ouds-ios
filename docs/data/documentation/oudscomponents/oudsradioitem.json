{"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},"metadata":{"title":"OUDSRadioItem","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSRadioItem"}],"navigatorTitle":[{"kind":"identifier","text":"OUDSRadioItem"}],"modules":[{"name":"OUDSComponents"}],"role":"symbol","externalID":"s:14OUDSComponents13OUDSRadioItemV","roleHeading":"Structure"},"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem","isActive":true},{"type":"text","text":" proposes layouts to add in your views some radios components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a radio with only an indicator, prefer instead "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","isActive":true},{"type":"text","text":"."}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"generated":true,"title":"Initializers","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/init(isOn:labelText:additionalLabelText:helperText:icon:isOutlined:isInversed:isError:isReadOnly:hasDivider:)"],"anchor":"Initializers"},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/body"],"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem\/View-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadioItem","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"Layouts","type":"heading","text":"Layouts","level":2},{"inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"inverse"}],"type":"strong"},{"text":": like the ","type":"text"},{"inlineContent":[{"type":"text","text":"default"}],"type":"emphasis"},{"text":" layout but with a trailing radio indicator and a leading optional decorative icon","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Indicator-states","type":"heading","text":"Indicator states","level":2},{"inlineContent":[{"text":"The radio indicator has two available states:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"type":"text","text":": the radio is filled with a filled circle, the user has made the action to select the radio"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"unselected"}],"type":"strong"},{"text":": the radio is empty, does not contain anything, the user has made the action to unselect or did not select yet the radio","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Particular-cases","type":"heading","text":"Particular cases","level":2},{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"type":"codeVoice","code":"isError"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In addition, the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadioItem"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."},{"type":"text","text":" "},{"type":"text","text":"The radio can be also outlined in some cases."}],"type":"paragraph"},{"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations","level":2},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom radio trait.","type":"text"}],"type":"paragraph"},{"anchor":"Forbidden-by-design","type":"heading","text":"Forbidden by design","level":2},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a read only component."}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}],"type":"paragraph"},{"anchor":"Code-samples","type":"heading","text":"Code samples","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A leading radio with a label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\")","","    \/\/ A leading radio with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\", isReadOnly: true)","","    \/\/ A leading radio with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\", helperText: \"The Beatles\")","","    \/\/ A leading oulined radio with an additional label, an helper text.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\", additionalLabelText: \"The Beatles\", helperText: \"1967\", outlined: true)","","    \/\/ A leading radio with an additional label.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Lucy in the Sky with Diamonds\", additionalLabelText: \"The Beatles\", helperText: \"1967\")","","    \/\/ A trailing radio with a label, an additonal label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSRadioItem(isOn: $selection,","                  labelText: \"Lucy in the Sky with Diamonds\",","                  additionalLabelText: \"The Beatles\",","                  helperText: \"1967\",","                  isInversed: true,","                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing radio with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSRadioItem(isOn: $selection,","                  labelText: \"Rescue from this world!\",","                  helperText: \"Put your hand in mine\",","                  icon: Image(decorative: \"ic_heart\"),","                  isInversed: true,","                  isError: true,","                  hasDivider: true)","","    \/\/ A leading radio with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSRadioItem(isOn: $selection, labelText: \"Rescue from this world!\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related radio as it will crash","    \/\/ This is forbidden by design!","    OUDSRadioItem(isOn: $selection, labelText: \"Kaboom!\", isError: true).disabled(true) \/\/ fatal error","    OUDSRadioItem(isOn: $selection, labelText: \"Kaboom!\", isReadyOnly: true).disabled(true) \/\/ fatal error"]},{"anchor":"Design-documentation","type":"heading","text":"Design documentation","level":2},{"inlineContent":[{"text":"See ","type":"text"},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/73c701-components","isActive":true,"type":"reference"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"0.12.0"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Since"}],"kind":"content"}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"],"type":"conformsTo","kind":"relationships"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsradioitem"]}],"references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSRadioItem/View-Implementations":{"kind":"article","role":"collectionGroup","title":"View Implementations","url":"\/documentation\/oudscomponents\/oudsradioitem\/view-implementations","type":"topic","identifier":"doc:\/\/ouds-i