{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"text":" proposes layout with text only, icon only or text with icon.","type":"text"}],"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:hierarchy:style:action:)","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:text:hierarchy:style:action:)","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:hierarchy:style:action:)"]},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"title":"Instance Properties","anchor":"Instance-Properties","generated":true},{"title":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Hierarchy","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"],"anchor":"Enumerations","generated":true},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations","generated":true}],"relationshipsSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Hierarchies","anchor":"Hierarchies"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Four hierarchies are proposed for all layouts:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"type":"text","text":": Default buttons are used for actions which are not mandatory or essential for the user."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"strong","type":"text"}],"type":"strong"},{"text":": The Strong “call for action” on the page should be singular and prominent, limited to one per view.","type":"text"},{"text":" ","type":"text"},{"text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"minimal","type":"text"}],"type":"strong"},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"negative"}]},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"text":" ","type":"text"},{"text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog.","type":"text"},{"type":"text","text":" "},{"text":"A button with ","type":"text"},{"code":"OUDSButton.Hierarchy.Negative","type":"codeVoice"},{"text":" hierarchy is not allowed as a direct or indirect child of an ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":"."}]}]}]},{"type":"heading","text":"Code samples","anchor":"Code-samples","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Icon only with default hierarchy","    OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) { \/* the action to process *\/ }","","    \/\/ Text only with negative hierarchy","    OUDSButton(hierarchy: .negative, text: \"Delete\") { \/* the action to process *\/ }","","    \/\/ Text and icon with strong hierarchy","    OUDSButton(hierarchy: .strong, icon: Image(\"ic_heart\"), text: \"Validate\") { \/* the action to process *\/ }"]},{"type":"heading","text":"Styles","level":2,"anchor":"Styles"},{"inlineContent":[{"text":"Two style are available:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for following states disabled, pressed, hovered or normal (i.e. enabled)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"loading"}]},{"type":"text","text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data."}]}]}]},{"text":"Colored Surface","type":"heading","anchor":"Colored-Surface","level":2},{"type":"paragraph","inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative button on a colored surface."}]}],"type":"paragraph"},{"text":"Design documentatio