{"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"]]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"modules":[{"name":"OUDSComponents"}],"externalID":"s:14OUDSComponents10OUDSButtonV","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"symbolKind":"struct","role":"symbol","navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"title":"OUDSButton"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Hierarchies","level":2,"anchor":"Hierarchies","type":"heading"},{"inlineContent":[{"text":"Four hierarchies are proposed for all layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"text":": Default buttons are used for actions which are not mandatory or essential for the user.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"strong","type":"text"}]},{"type":"text","text":": The Strong “call for action” on the page should be singular and prominent, limited to one per view."},{"text":" ","type":"text"},{"type":"text","text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"minimal"}],"type":"strong"},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"negative"}]},{"text":": Negative buttons should be used sparingly to warn of a destructive action,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Hierarchy.Negative","type":"codeVoice"},{"type":"text","text":" hierarchy is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"anchor":"Code-samples","level":2,"text":"Code samples","type":"heading"},{"code":["    \/\/ Icon only with default hierarchy","    OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) { \/* the action to process *\/ }","","    \/\/ Text only with negative hierarchy","    OUDSButton(hierarchy: .negative, text: \"Delete\") { \/* the action to process *\/ }","","    \/\/ Text and icon with strong hierarchy","    OUDSButton(hierarchy: .strong, icon: Image(\"ic_heart\"), text: \"Validate\") { \/* the action to process *\/ }"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Styles","level":2,"anchor":"Styles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two style are available:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for following states disabled, pressed, hovered or normal (i.e. enabled)"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"loading"}],"type":"strong"},{"type":"text","text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data."}],"type":"paragraph"}]}]},{"text":"Colored Surface","type":"heading","level":2,"anchor":"Colored-Surface"},{"inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative button on a colored surface."}]}],"type":"paragraph"},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/48a788-button","isActive":true}]},{"name":"Since","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.10.0"}]}],"type":"aside"}]}],"variants":[{"paths":["\/documentation\/oudscomponents\/oudsbutton"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},"topicSections":[{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:hierarchy:style:action:)","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:text:hierarchy:style:action:)","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:hierarchy:style:action:)"],"title":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"generated":true,"anchor":"Instance-Properties"},{"anchor":"Enumerations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Hierarchy","doc:\/\/oud