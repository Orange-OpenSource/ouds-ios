omponents\/documentation\/OUDSComponents\/OUDSLink"],"title":"Group"}],"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSButton"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"content","content":[{"anchor":"Hierarchies","text":"Hierarchies","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Four hierarchies are proposed for all layouts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":": Default buttons are used for actions which are not mandatory or essential for the user.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"strong"}],"type":"strong"},{"type":"text","text":": The Strong “call for action” on the page should be singular and prominent, limited to one per view."},{"type":"text","text":" "},{"type":"text","text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"minimal"}]},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"negative","type":"text"}],"type":"strong"},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"text":" ","type":"text"},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"type":"text","text":" "},{"tex