{"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","isActive":true},{"text":" proposes layout with text only, icon only or text with icon.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSButton"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Hierarchies","text":"Hierarchies"},{"inlineContent":[{"type":"text","text":"Four hierarchies are proposed for all layouts:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"default"}],"type":"strong"},{"text":": Default buttons are used for actions which are not mandatory or essential for the user.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"strong","type":"text"}]},{"text":": The Strong “call for action” on the page should be singular and prominent, limited to one per view.","type":"text"},{"text":" ","type":"text"},{"text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"minimal"}]},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"negative"}]},{"text":": Negative buttons should be used sparingly to warn of a destructive action,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"text":" ","type":"text"},{"type":"text","text":"A button with "},{"type":"codeVoice","code":"OUDSButton.Hierarchy.Negative"},{"text":" hierarchy is not allowed as a direct or indirect child of an ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"text":"Code samples","level":2,"type":"heading","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Icon only with default hierarchy","    OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) { \/* the action to process *\/ }","","    \/\/ Text only with negative hierarchy","    OUDSButton(hierarchy: .negative, text: \"Delete\") { \/* the action to process *\/ }","","    \/\/ Text and icon with strong hierarchy","    OUDSButton(hierarchy: .strong, icon: Image(\"ic_heart\"), text: \"Validate\") { \/* the action to process *\/ }"]},{"anchor":"Styles","level":2,"type":"heading","text":"Styles"},{"inlineContent":[{"type":"text","text":"Two style are available:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for following states disabled, pressed, hovered or normal (i.e. enabled)"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"loading","type":"text"}]},{"type":"text","text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Colored-Surface","text":"Colored Surface","level":2},{"inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Remark: Today it is not allowed to place a Negative button on a colored surface."}]}]},{"level":2,"text":"Design documentation","type":"heading","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/48a788-button"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"0.10.0","type":"text"}]}],"name":"Since","type":"aside","style":"note"}]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton","interfaceLanguage":"swift"},"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudsbutton"]}],"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:hierarchy:style:action:)","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:text:hierarchy:style:action:)","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:hierarchy:style:action:)"],"generated":true},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Hierarchy","doc:\/\/ouds-ios.OUDSCom