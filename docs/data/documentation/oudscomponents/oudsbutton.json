tons should be used sparingly to warn of a destructive action,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"type":"text","text":" "},{"type":"text","text":"A button with "},{"code":"OUDSButton.Hierarchy.Negative","type":"codeVoice"},{"type":"text","text":" hierarchy is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]}]},{"anchor":"Code-samples","text":"Code samples","type":"heading","level":2},{"syntax":"swift","code":["    \/\/ Icon only with default hierarchy","    OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) { \/* the action to process *\/ }","","    \/\/ Text only with negative hierarchy","    OUDSButton(hierarchy: .negative, text: \"Delete\") { \/* the action to process *\/ }","","    \/\/ Text and icon with strong hierarchy","    OUDSButton(hierarchy: .strong, icon: Image(\"ic_heart\"), text: \"Validate\") { \/* the action to process *\/ }"],"type":"codeListing"},{"text":"Styles","level":2,"type":"heading","anchor":"Styles"},{"type":"paragraph","inlineContent":[{"text":"Two style are available:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":": used in the normal usage of button. The aspect of the button changes for following states disabled, pressed, hovered or normal (i.e. enabled)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"loading"}]},{"type":"text","text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data."}]}]}],"type":"unorderedList"},{"text":"Colored Surface","type":"heading","anchor":"Colored-Surface","level":2},{"inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"type":"codeVoice","code":"OUDSColoredSurface"},{"type":"text","text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Remark: Today it is not allowed to place a Negative button on a colored surface.","type":"text"}]}],"type":"paragraph"},{"type":"heading","text":"Design documentation","level":2,"anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/48a788-button","type":"reference","isActive":true}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.10.0"}]}],"name":"Since","type":"aside"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton"},"variants":[{"paths":["\/documentation\/oudscomponents\/oudsbutton"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSButton/View-Implementations":{"url":"\/documentation\/oudscomponents\/oudsbutton\/view-implementations","abstract":[],"kind":"article","type":"topic","role":"collectionGroup","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/View-Implementations","title":"View Implementations"},"doc://ouds-ios.OUDSComponents/7SwiftUI4ViewP":{"type":"unresolvable","identifier":"doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP","title":"SwiftUICore.View"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSButton/init(text:hierarchy:style:action:)":{"kind":"symbol","title":"init(text:hierarchy:style:action:)","abstract":[{"type":"text","text":"Create a button with a text only."}],"role":"symbol","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:hierarchy:style:action:)","url":"\/documen