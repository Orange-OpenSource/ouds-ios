{"metadata":{"roleHeading":"Structure","role":"symbol","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSButton"}],"modules":[{"name":"OUDSComponents"}],"externalID":"s:14OUDSComponents10OUDSButtonV","navigatorTitle":[{"text":"OUDSButton","kind":"identifier"}],"title":"OUDSButton"},"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OUDSButton","kind":"identifier"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Hierarchies","anchor":"Hierarchies"},{"inlineContent":[{"text":"Four hierarchies are proposed for all layouts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"default"}]},{"text":": Default buttons are used for actions which are not mandatory or essential for the user.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"strong"}]},{"type":"text","text":": The Strong “call for action” on the page should be singular and prominent, limited to one per view."},{"type":"text","text":" "},{"text":"It should be reserved for the most critical action, such as “Next,” “Save,” “Submit,” etc.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"minimal","type":"text"}]},{"text":": Minimal buttons are commonly used for actions that are considered less crucial. They can be used independently or together with a strong button.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"negative","type":"text"}]},{"type":"text","text":": Negative buttons should be used sparingly to warn of a destructive action,"},{"type":"text","text":" "},{"type":"text","text":"for example, delete or remove, typically resulting in the opening of a confirmation dialog."},{"text":" ","type":"text"},{"type":"text","text":"A button with "},{"code":"OUDSButton.Hierarchy.Negative","type":"codeVoice"},{"type":"text","text":" hierarchy is not allowed as a direct or indirect child of an "},{"code":"OUDSColoredSurface","type":"codeVoice"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"type":"heading","text":"Code samples","anchor":"Code-samples","level":2},{"type":"codeListing","syntax":"swift","code":["    \/\/ Icon only with default hierarchy","    OUDSButton(hierarchy: .default, icon: Image(\"ic_heart\")) { \/* the action to process *\/ }","","    \/\/ Text only with negative hierarchy","    OUDSButton(hierarchy: .negative, text: \"Delete\") { \/* the action to process *\/ }","","    \/\/ Text and icon with strong hierarchy","    OUDSButton(hierarchy: .strong, icon: Image(\"ic_heart\"), text: \"Validate\") { \/* the action to process *\/ }"]},{"type":"heading","level":2,"anchor":"Styles","text":"Styles"},{"type":"paragraph","inlineContent":[{"text":"Two style are available:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":": used in the normal usage of button. The aspect of the button changes for following states disabled, pressed, hovered or normal (i.e. enabled)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"loading","type":"text"}],"type":"strong"},{"type":"text","text":": used after button was clicked and probably data are requested before navigate to a next screen or get updated data."}]}]}]},{"type":"heading","level":2,"text":"Colored Surface","anchor":"Colored-Surface"},{"type":"paragraph","inlineContent":[{"text":"If button is placed on colored surface using ","type":"text"},{"code":"OUDSColoredSurface","type":"codeVoice"},{"text":", the default colors (content, background and border) are automatically adjusted to switch to monochrom.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Remark: Today it is not allowed to place a Negative button on a colored surface.","type":"text"}],"type":"strong"}]},{"anchor":"Design-documentation","text":"Design documentation","type":"heading","level":2},{"inlineContent":[{"text":"See ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/48a788-button"}],"type":"paragraph"},{"name":"Since","content":[{"type":"paragraph","inlineContent":[{"text":"0.10.0","type":"text"}]}],"type":"aside","style":"note"}],"kind":"content"}],"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:hierarchy:style:action:)","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(icon:text:hierarchy:style:action:)","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/init(text:hierarchy:style:action:)"],"generated":true},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/body"],"generated":true},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Hierarchy","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSButton\/Style"],"anchor":"Enumerations","generated":true,"title":"Enumerations"},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSBu