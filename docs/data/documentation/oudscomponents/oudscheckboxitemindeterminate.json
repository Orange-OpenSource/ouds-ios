{"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},"metadata":{"externalID":"s:14OUDSComponents29OUDSCheckboxItemIndeterminateV","symbolKind":"struct","roleHeading":"Structure","title":"OUDSCheckboxItemIndeterminate","role":"symbol","navigatorTitle":[{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"modules":[{"name":"OUDSComponents"}]},"topicSections":[{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(selection:labelText:helperText:icon:isInversed:isError:isReadOnly:hasDivider:)"],"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/body"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations","doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"],"kind":"relationships","title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OUDSCheckboxItemIndeterminate"}],"platforms":["iOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Layouts","anchor":"Layouts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"inverse"}]},{"text":": like the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"default","type":"text"}]},{"text":" layout but with a trailing checkbox indicator and a leading optional image","type":"text"}]}]}]},{"type":"heading","level":2,"text":"Indicator states","anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"selected","type":"text"}]},{"type":"text","text":": the checkbox is filled with a tick, the user has made the action to select the checkbox"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"unselected","type":"text"}]},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"indeterminate","type":"text"}]},{"type":"text","text":": mike a prefilled or preticked checkbox, the user did not do anything on it yet"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"If you need a checkbox with only two states to manage use instead ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Particular cases","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look and feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."},{"type":"text","text":" "},{"type":"text","text":"In addition, the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},{"type":"text","text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered"},{"type":"text","text":" "},{"type":"text","text":"as disabled."}]},{"type":"heading","level":2,"text":"Accessibility considerations","anchor":"Accessibility-considerations"},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"}]},{"type":"heading","level":2,"text":"Forbidden by design","anchor":"Forbidden-by-design"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both a read only and a disabled component.","type":"text"}]}]},{"type":"heading","level":2,"text":"Code samples","anchor":"Code-samples"},{"type":"codeListing","syntax":"swift","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Bazinga!\", helperText: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection,","                                  labelText: \"We live in a fabled world\",","                                  helperText: \"Of dreaming boys and wide-eyed girls\",","                                  isInversed: true,","                                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing checkbox with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection,","                                  labelText: \"Rescue from this world!\",","                                  helperText: \"Put your hand in mine\",","                                  icon: Image(decorative: \"ic_heart\"),","                                  isInversed: true,","                                  isError: true,","                                 divider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"]},{"type":"heading","level":2,"text":"Design documentation","anchor":"Design-documentation"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox"}]},{"type":"aside","style":"note","name":"Since","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0.12.0"}]}]}]}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","type":"reference","isActive":true},{"type":"text","text":" proposes layouts to add in your views some checkboxes components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with only an indicator prefer instead "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate","type":"reference","isActive":true},{"type":"text","text":"."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxitemindeterminate"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItemIndeterminate/View-Implementations":{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations","title":"View Implementations","abstract":[],"kind":"article","role":"collectionGroup","url":"\/documentation\/oudscomponents\/oudscheckboxitemindeterminate\/view-implementations","type":"topic"},"doc://ouds-ios.OUDSComponents/7SwiftUI4ViewP":{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP","type":"unresolvable","title":"SwiftUICore.View"},"https://unified-design-system.orange.com/472794e18/p/23f1c1-checkbox":{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","url":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","type":"link","titleInlineContent":[{"type":"text","text":"unified-design-system.orange.com"}],"title":"unified-design-system.orange.com"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSCheckboxItemIndeterminate/body":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"body","kind":"identifier"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/body","title":"body","abstract":[],"kind":"symbol","role":"symbol","url":"\/documentation\/oudscomponents\/oudscheckboxitemindeterminate\/body","type":"topic"},"doc://ouds-ios.OUDSComponents/s8SendableP":{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"doc://ouds-ios.OUDSComponents/documentation/OUDSComponents/OUDSCheckboxIndeterminate":{"role":"symbol","kind":"symbol","url":"\/docume