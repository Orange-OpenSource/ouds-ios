{"metadata":{"symbolKind":"struct","externalID":"s:14OUDSComponents29OUDSCheckboxItemIndeterminateV","role":"symbol","title":"OUDSCheckboxItemIndeterminate","navigatorTitle":[{"text":"OUDSCheckboxItemIndeterminate","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSCheckboxItemIndeterminate"}],"modules":[{"name":"OUDSComponents"}],"roleHeading":"Structure"},"relationshipsSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/s8SendableP","doc:\/\/ouds-ios.OUDSComponents\/7SwiftUI4ViewP"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true,"type":"reference"},{"type":"text","text":" proposes layouts to add in your views some checkboxes components."},{"type":"text","text":" "},{"type":"text","text":"If you want to use a checkbox with only an indicator prefer instead "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxIndeterminate"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSCheckboxItemIndeterminate"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Layouts","anchor":"Layouts","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The component can be rendered as two different layouts:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"default","type":"text"}]},{"type":"text","text":": the component has a leading indicator, a label and optional helper texts, and an optional trailing decorative icon"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"inverse"}],"type":"strong"},{"text":": like the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"default"}]},{"text":" layout but with a trailing checkbox indicator and a leading optional image","type":"text"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Indicator states","anchor":"Indicator-states"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checkbox indicator has three available states:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"selected"}]},{"text":": the checkbox is filled with a tick, the user has made the action to select the checkbox","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"unselected","type":"text"}],"type":"strong"},{"type":"text","text":": the checkbox is empty, does not contain a tick, the user has made the action to unselect or did not select yet the checkbox"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"indeterminate","type":"text"}]},{"type":"text","text":": mike a prefilled or preticked checkbox, the user did not do anything on it yet"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need a checkbox with only two states to manage use instead "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItem","isActive":true},{"type":"text","text":"."}]},{"anchor":"Particular-cases","type":"heading","text":"Particular cases","level":2},{"inlineContent":[{"type":"text","text":"An "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","type":"reference"},{"text":" can be related to an error situation, for example troubles for a formular.","type":"text"},{"text":" ","type":"text"},{"text":"A dedicated look and feel is implemented for that if the ","type":"text"},{"type":"codeVoice","code":"isError"},{"text":" flag is risen.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"In addition, the "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate","isActive":true,"type":"reference"},{"text":" can be in read only mode, i.e. the user cannot interact with the component yet but this component must not be considered","type":"text"},{"text":" ","type":"text"},{"text":"as disabled.","type":"text"}],"type":"paragraph"},{"anchor":"Accessibility-considerations","type":"heading","level":2,"text":"Accessibility considerations"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Voice Over","type":"text"}]},{"text":" will use several elements to describe the component: if component disabled \/ read only, if error context, the label and helper texts and a custom checkbox trait.","type":"text"}],"type":"paragraph"},{"anchor":"Forbidden-by-design","level":2,"type":"heading","text":"Forbidden by design"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"The design system does not allow to have both an error situation and a read only component.","type":"text"}]},{"type":"text","text":" "},{"inlineContent":[{"text":"The design system does not allow to have both an error situation and a disabled component.","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"The design system does not allow to have both a read only and a disabled component."}],"type":"strong"}],"type":"paragraph"},{"text":"Code samples","anchor":"Code-samples","type":"heading","level":2},{"type":"codeListing","code":["    \/\/ Supposing we have an indeterminate state checkbox","    @Published var selection: OUDSCheckboxIndicatorState = .indeterminate","","    \/\/ A leading checkbox with a label.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\")","","    \/\/ A leading checkbox with a label, but in read only mode (user cannot interact yet, but not disabled).","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\", isReadOnly: true)","","    \/\/ A leading checkbox with a label, and an helper text.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Bazinga!\", helperText: \"Doll-Dagga Buzz-Buzz Ziggety-Zag\")","","    \/\/ A trailing checkbox with a label, an helper text and an icon.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection,","                                  labelText: \"We live in a fabled world\",","                                  helperText: \"Of dreaming boys and wide-eyed girls\",","                                  isInversed: true,","                                  icon: Image(decorative: \"ic_heart\"))","","    \/\/ A trailing checkbox with a label, an helper text, an icon, a divider and is about an error.","    \/\/ The inverse layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection,","                                  labelText: \"Rescue from this world!\",","                                  helperText: \"Put your hand in mine\",","                                  icon: Image(decorative: \"ic_heart\"),","                                  isInversed: true,","                                  isError: true,","                                 divider: true)","","    \/\/ A leading checkbox with a label, but disabled.","    \/\/ The default layout will be used here.","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\")","        .disabled(true)","","    \/\/ Never disable a read only or an error-related checkbox as it will crash","    \/\/ This is forbidden by design!","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\", isError: true).disabled(true) \/\/ fatal error","    OUDSCheckboxItemIndeterminate(selection: $selection, labelText: \"Hello world\", isReadyOnly: true).disabled(true) \/\/ fatal error"],"syntax":"swift"},{"anchor":"Design-documentation","level":2,"type":"heading","text":"Design documentation"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/23f1c1-checkbox","type":"reference"}]},{"name":"Since","type":"aside","style":"note","content":[{"inlineContent":[{"text":"0.12.0","type":"text"}],"type":"paragraph"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudscomponents\/oudscheckboxitemindeterminate"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/init(selection:labelText:helperText:icon:isInversed:isError:isReadOnly:hasDivider:)"]},{"identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/body"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"anchor":"Default-Implementations","generated":true,"title":"Default Implementations","identifiers":["doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSCheckboxItemIndeterminate\/View-Implementations","doc:\/\/ouds-ios.