{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio"},"sections":[],"metadata":{"modules":[{"name":"OUDSComponents"}],"navigatorTitle":[{"text":"OUDSRadio","kind":"identifier"}],"externalID":"s:14OUDSComponents9OUDSRadioV","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OUDSRadio","kind":"identifier"}],"role":"symbol","title":"OUDSRadio","symbolKind":"struct"},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSRadio"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Particular cases","type":"heading","anchor":"Particular-cases"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio"},{"type":"text","text":" can be related to an error situation, for example troubles for a formular."},{"type":"text","text":" "},{"type":"text","text":"A dedicated look-and-feel is implemented for that if the "},{"code":"isError","type":"codeVoice"},{"type":"text","text":" flag is risen."}]},{"level":2,"anchor":"Accessibility-considerations","type":"heading","text":"Accessibility considerations"},{"inlineContent":[{"type":"text","text":"Note also the component must be instanciated with a string parameter used as accessibility label."},{"type":"text","text":" "},{"text":"It is a good pratice (at least) to define a label for a component without text for accessibility reasons. This label will be vocalized by ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Voice Over"}]},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The vocalization tool will also use, after the label, a description of the component (if disabled, if error context), and a fake trait for radio."}],"type":"paragraph"},{"type":"heading","text":"Cases forbidden by design","level":2,"anchor":"Cases-forbidden-by-design"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"The design system does not allow to have both an error situation and a disabled component."}],"type":"strong"}]},{"level":2,"type":"heading","anchor":"Code-samples","text":"Code samples"},{"syntax":"swift","code":["    \/\/ Supposing we have an unselected state","    @Published var selection: Bool = false","","    \/\/ A simple radio, no error, not in read only mode","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\")","","    \/\/ A simple radio, but is an error context","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true)","","    \/\/ Never disable an error-related radio button as it will crash","    \/\/ This is forbidden by design!","    OUDSRadio(isOn: $selection, accessibilityLabel: \"The cake is a lie\", isError: true).disabled(true) \/\/ fatal error"],"type":"codeListing"},{"level":2,"type":"heading","text":"Design documentation","anchor":"Design-documentation"},{"inlineContent":[{"type":"text","text":"See "},{"identifier":"https:\/\/unified-design-system.orange.com\/472794e18\/p\/73c701-components","isActive":true,"type":"reference"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"0.12.0","type":"text"}]}],"style":"note","name":"Since","type":"aside"}],"kind":"content"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/ouds-ios.OUDSComponents\/documentation\/OUDSComponents\/OUDSRadio","isActive":true,"type":"reference"},{"text":" proposes layout to add in your views a lonely radio, without labels, texts nor icons radios components","type":"text"},{"text":" ","type":"text"},{