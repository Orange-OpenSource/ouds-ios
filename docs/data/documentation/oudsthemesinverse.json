{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse"},"hierarchy":{"paths":[[]]},"kind":"symbol","metadata":{"externalID":"OUDSThemesInverse","symbolKind":"module","roleHeading":"Framework","title":"OUDSThemesInverse","role":"collection","modules":[{"name":"OUDSThemesInverse"}]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"This is an override of the "},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"reference"},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"type":"text","text":" derivable."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode."}]},{"level":2,"text":"How to use the theme","anchor":"How-to-use-the-theme","type":"heading"},{"inlineContent":[{"text":"You can use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"text":" directly. You will have to use the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" for your root view and give it an instance of ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class objects"}]},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}],"type":"paragraph"},{"code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","syntax":"swift","code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"This theme overrides the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange theme"}]},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"anchor":"Group","title":"Group"}],"variants":[{"paths":["\/documentation\/oudsthemesinverse"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"title":"InverseTheme","ide