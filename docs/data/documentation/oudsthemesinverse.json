{"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"anchor":"Group","title":"Group"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesinverse"]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"text":"This theme overrides the ","type":"text"},{"inlineContent":[{"text":"Orange theme","type":"text"}],"type":"emphasis"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"hierarchy":{"paths":[[]]},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This is an override of the ","type":"text"},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","isActive":true},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","type":"reference"},{"type":"text","text":" derivable."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode."}]},{"text":"How to use the theme","anchor":"How-to-use-the-theme","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"text":" directly. You will have to use the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" for your root view and give it an instance of "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"type":"text","text":". Keep in mind the themes are "},{"inlineContent":[{"text":"Swift class objects","type":"text"}],"type":"emphasis"},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}]},{"code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""]}]}],"metadata":{"role":"collection","title":"OUDSThemesInverse","externalID":"OUDSThemesInverse","symbolKind":"module","modules":[{"name":"OUDSThemesInverse"}],"roleHeading":"Framework"},"references":{"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","title":"InverseTheme","navigatorTitle":[{"text":"InverseTheme","kind":"identifier"}],"role":"symbol","url":"\/documentation\/oudsthemesinverse\/inversetheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InverseTheme","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"This is an override of the default basic "},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":" with some inverted colors."},{"type":"text","text":" "},{"text":"It can overrides any properties from its superclass, but is not derivable.","type":"text"}]},"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","title":"Orange theme","type":"link","titleInlineContent":[{"text":"Orange theme","type":"text"}],"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/"},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse":{"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","title":"OUDSThemesInverse","role":"collection","url":"\/documentation\/oudsthemesinverse","kind":"symbol","abstract":[{"text":"This theme overrides the ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange theme"}],"type":"emphasis"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}]}}}