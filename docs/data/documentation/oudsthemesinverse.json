{"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"This is an override of the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"reference","isActive":true},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","type":"reference"},{"text":" derivable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode."}],"type":"paragraph"},{"text":"How to use the theme","type":"heading","anchor":"How-to-use-the-theme","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true},{"text":" directly. You will have to use the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","type":"reference","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"inlineContent":[{"text":"Swift class objects","type":"text"}],"type":"emphasis"},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"roleHeading":"Framework","role":"collection","externalID":"OUDSThemesInverse","modules":[{"name":"OUDSThemesInverse"}],"title":"OUDSThemesInverse","symbolKind":"module"},"hierarchy":{"paths":[[]]},"abstract":[{"type":"text","text":"This theme overrides the "},{"inlineContent":[{"type":"text","text":"Orange theme"}],"type":"emphasis"},{"text":" for some colors so as to bring an “inverse”-colored experience.","type":"text"}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"anchor":"Group","title":"Group"}],"variants":[{"paths":["\/documentation\/oudsthemesinverse"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","references":{"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse":{"title":"OUDSThemesInverse","kind":"symbol","type":"topic","abstract":[{"text":"This theme overrides the ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange theme"}],"type":"emphasis"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","url":"\/documentation\/oudsthemesinverse","role":"collection"},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","type":"topic","navigatorTitle":[{"kind":"identifier","text":"InverseTheme"}],"kind":"symbol","abstract":[{"text":"This is an override of the default basic ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"text":" with some inverted colors.","type":"text"},{"text":" ","type":"text"},{"text":"It can overrides any properties from its superclass, but is not derivable.","type":"text"}],"url":"\/documentation\/oudsthemesinverse\/inversetheme","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"InverseTheme","kind":"identifier"}],"title":"InverseTheme"},"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"type":"link","titleInlineContent":[{"text":"Orange theme","type":"text"}],"title":"Orange theme","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/"}}}