{"kind":"symbol","primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"This is an override of the "},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/"},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true},{"type":"text","text":" derivable."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode."}],"type":"paragraph"},{"text":"How to use the theme","level":2,"anchor":"How-to-use-the-theme","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"type":"text","text":" directly. You will have to use the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" for your root view and give it an instance of "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","type":"reference","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class objects"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"syntax":"swift","type":"codeListing","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""],"syntax":"swift","type":"codeListing"}]}],"metadata":{"title":"OUDSThemesInverse","symbolKind":"module","externalID":"OUDSThemesInverse","modules":[{"name":"OUDSThemesInverse"}],"role":"collection","roleHeading":"Framework"},"variants":[{"paths":["\/documentation\/oudsthemesinverse"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","interfaceLanguage":"swift"},"sections":[],"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"title":"Group","anchor":"Group"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[[]]},"abstract":[{"type":"text","text":"This theme overrides the "},{"inlineContent":[{"text":"Orange theme","type":"text"}],"type":"emphasis"},{"text":" for some colors so as to bring an “inverse”-colored experience.","type":"text"}],"references":{"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"InverseTheme"}],"title":"InverseTheme","type":"topic","navigatorTitle":[{"kind":"identifier","text":"InverseTheme"}],"url":"\/documentation\/oudsthemesinverse\/inversetheme","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","abstract":[{"type":"text","text":"This is an override of the default basic "},{"code":"OrangeTheme","type":"codeVoice"},{"text":" with some inverted colors.","type":"text"},{"text":" ","type":"text"},{"text":"It can overrides any properties from its superclass, but is not derivable.","type":"text"}],"kind":"symbol"},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse":{"abstract":[{"text":"This theme overrides the ","type":"text"},{"inlineContent":[{"text":"Orange theme","type":"text"}],"type":"emphasis"},{"text":" for some colors so as to bring an “inverse”-colored experience.","type":"text"}],"role":"collection","url":"\/documentation\/oudsthemesinverse","type":"topic","title":"OUDSThemesInverse","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","kind":"symbol"},"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","titleInlineContent":[{"text":"Orange theme","type":"text"}],"type":"link","title":"Orange theme"}}}