{"topicSections":[{"anchor":"Group","title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"]}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"variants":[{"paths":["\/documentation\/oudsthemesinverse"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[[]]},"identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"inlineContent":[{"text":"This is an override of the ","type":"text"},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"reference"},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"type":"text","text":" derivable."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode.","type":"text"}]},{"type":"heading","text":"How to use the theme","anchor":"How-to-use-the-theme","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true},{"text":" directly. You will have to use the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" for your root view and give it an instance of ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","type":"reference","isActive":true},{"text":". Keep in mind the themes are ","type":"text"},{"inlineContent":[{"text":"Swift class objects","type":"text"}],"type":"emphasis"},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}]},{"syntax":"swift","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""]}]}],"abstract":[{"text":"This theme overrides the ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange theme"}],"type":"emphasis"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"metadata":{"symbolKind":"module","modules":[{"name":"OUDSThemesInverse"}],"roleHeading":"Framework","role":"collection","title":"OUDSThemesInverse","externalID":"OUDSThemesInverse"},"references":{"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse":{"type":"topic","url":"\/documentation\/oudsthemesinverse","kind":"symbol","role":"collection","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","title":"OUDSThemesInverse","abstract":[{"text":"This theme overrides the ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange theme"}],"type":"emphasis"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}]},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"url":"\/documentation\/oudsthemesinverse\/inversetheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InverseTheme","kind":"identifier"}],"abstract":[{"text":"This is an override of the default basic ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":" with some inverted colors."},{"type":"text","text":" "},{"type":"text","text":"It can overrides any properties from its superclass, but is not derivable."}],"type":"topic","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","title":"InverseTheme","role":"symbol","navigatorTitle":[{"text":"InverseTheme","kind":"identifier"}],"kind":"symbol"},"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"titleInlineContent":[{"type":"text","text":"Orange theme"}],"title":"Orange theme","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"link"}}}