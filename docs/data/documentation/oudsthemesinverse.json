{"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"anchor":"Group","title":"Group"}],"primaryContentSections":[{"content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"This is an override of the "},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/"},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"text":" derivable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode.","type":"text"}],"type":"paragraph"},{"text":"How to use the theme","level":2,"anchor":"How-to-use-the-theme","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","type":"reference","isActive":true},{"type":"text","text":" directly. You will have to use the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"text":" for your root view and give it an instance of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class objects"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"syntax":"swift","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}]},{"code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesinverse"]}],"sections":[],"metadata":{"roleHeading":"Framework","modules":[{"name":"OUDSThemesInverse"}],"role":"collection","title":"OUDSThemesInverse","symbolKind":"module","externalID":"OUDSThemesInverse"},"hierarchy":{"paths":[[]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse"},"abstract":[{"text":"This theme overrides the ","type":"text"},{"inlineContent":[{"text":"Orange theme","type":"text"}],"type":"emphasis"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"type":"link","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","title":"Orange theme","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","titleInlineContent":[{"text":"Orange theme","type":"text"}]},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse":{"title":"OUDSThemesInverse","role":"collection","abstract":[{"type":"text","text":"This theme overrides the "},{"inlineContent":[{"text":"Orange theme","type":"text"}],"type":"emphasis"},{"text":" for some colors so as to bring an “inverse”-colored experience.","type":"text"}],"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","url":"\/documentation\/oudsthemesinverse","type":"topic","kind":"symbol"},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"title":"InverseTheme","kind":"symbol","url":"\/documentation\/oudsthemesinverse\/inversetheme","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InverseTheme"}],"abstract":[{"type":"text","text":"This is an override of the default basic "},{"code":"OrangeTheme","type":"codeVoice"},{"text":" with some inverted colors.","type":"text"},{"text":" ","type":"text"},{"text":"It can overrides any properties from its superclass, but is not derivable.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"InverseTheme"}],"role":"symbol","type":"topic"}}}