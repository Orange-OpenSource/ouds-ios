{"identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[[]]},"abstract":[{"type":"text","text":"This theme overrides the "},{"type":"emphasis","inlineContent":[{"text":"Orange theme","type":"text"}]},{"text":" for some colors so as to bring an “inverse”-colored experience.","type":"text"}],"topicSections":[{"title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"anchor":"Group"}],"metadata":{"symbolKind":"module","role":"collection","modules":[{"name":"OUDSThemesInverse"}],"roleHeading":"Framework","title":"OUDSThemesInverse","externalID":"OUDSThemesInverse"},"variants":[{"paths":["\/documentation\/oudsthemesinverse"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"This is an override of the "},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"reference"},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"text":" derivable.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode.","type":"text"}]},{"anchor":"How-to-use-the-theme","level":2,"type":"heading","text":"How to use the theme"},{"type":"paragraph","inlineContent":[{"text":"You can use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"type":"text","text":" directly. You will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"type":"text","text":". Keep in mind the themes are "},{"inlineContent":[{"text":"Swift class objects","type":"text"}],"type":"emphasis"},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"syntax":"swift","type":"codeListing","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}]},{"syntax":"swift","code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""],"type":"codeListing"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"title":"InverseTheme","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","role":"symbol","url":"\/documentation\/oudsthemesinverse\/inversetheme","navigatorTitle":[{"text":"InverseTheme","kind":"identifier"}],"abstract":[{"text":"This is an override of the default basic ","type":"text"},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":" with some inverted colors."},{"type":"text","text":" "},{"text":"It can overrides any properties from its superclass, but is not derivable.","type":"text"}],"kind":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InverseTheme","kind":"identifier"}]},"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"link","title":"Orange theme","titleInlineContent":[{"text":"Orange theme","type":"text"}],"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/"},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse":{"abstract":[{"text":"This theme overrides the ","type":"text"},{"inlineContent":[{"text":"Orange theme","type":"text"}],"type":"emphasis"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","title":"OUDSThemesInverse","type":"topic","url":"\/documentation\/oudsthemesinverse","kind":"symbol","role":"collection"}}}