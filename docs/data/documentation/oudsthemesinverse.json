{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse"},"abstract":[{"text":"This theme overrides the ","type":"text"},{"inlineContent":[{"type":"text","text":"Orange theme"}],"type":"emphasis"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"topicSections":[{"title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"anchor":"Group"}],"metadata":{"role":"collection","modules":[{"name":"OUDSThemesInverse"}],"roleHeading":"Framework","title":"OUDSThemesInverse","symbolKind":"module","externalID":"OUDSThemesInverse"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesinverse"]}],"hierarchy":{"paths":[[]]},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"This is an override of the "},{"isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"reference"},{"text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make ","type":"text"},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"type":"text","text":" derivable."}],"type":"paragraph"},{"inlineContent":[{"text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode.","type":"text"}],"type":"paragraph"},{"text":"How to use the theme","level":2,"anchor":"How-to-use-the-theme","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"You can use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"text":" directly. You will have to use the ","type":"text"},{"type":"codeVoice","code":"OUDSThemeableView"},{"text":" for your root view and give it an instance of ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true},{"text":". Keep in mind the themes are ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class objects"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""],"syntax":"swift"}]}],"references":{"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"identifier":"doc:\/\/ouds-