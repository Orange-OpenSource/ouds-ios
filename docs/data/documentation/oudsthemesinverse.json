{"kind":"symbol","variants":[{"paths":["\/documentation\/oudsthemesinverse"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse"},"metadata":{"externalID":"OUDSThemesInverse","role":"collection","symbolKind":"module","modules":[{"name":"OUDSThemesInverse"}],"roleHeading":"Framework","title":"OUDSThemesInverse"},"abstract":[{"type":"text","text":"This theme overrides the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange theme"}]},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"anchor":"Group","title":"Group"}],"hierarchy":{"paths":[[]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"This is an override of the "},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/"},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"text":" derivable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode.","type":"text"}],"type":"paragraph"},{"text":"How to use the theme","anchor":"How-to-use-the-theme","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","type":"reference"},{"type":"text","text":" directly. You will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"},{"text":". Keep in mind the themes are ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift class objects"}],"type":"emphasis"},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}]},{"syntax":"swift","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""]}],"kind":"content"}],"references":{"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse":{"kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","abstract":[{"type":"text","text":"This theme overrides the "},{"inlineContent":[{"type":"text","text":"Orange theme"}],"type":"emphasis"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"title":"OUDSThemesInverse","role":"collection","type":"topic","url":"\/documentation\/oudsthemesinverse"},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InverseTheme","kind":"identifier"}],"title":"InverseTheme","kind":"symbol","url":"\/documentation\/oudsthemesinverse\/inversetheme","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","role":"symbol","type":"topic","abstract":[{"type":"text","text":"This is an override of the default basic "},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":" with some inverted colors."},{"type":"text","text":" "},{"type":"text","text":"It can overrides any properties from its superclass, but is not derivable."}],"navigatorTitle":[{"text":"InverseTheme","kind":"identifier"}]},"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"type":"link","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","titleInlineContent":[{"type":"text","text":"Orange theme"}],"title":"Orange theme","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/"}}}