{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","interfaceLanguage":"swift"},"sections":[],"metadata":{"modules":[{"name":"OUDSThemesInverse"}],"roleHeading":"Framework","role":"collection","title":"OUDSThemesInverse","externalID":"OUDSThemesInverse","symbolKind":"module"},"abstract":[{"type":"text","text":"This theme overrides the "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"reference","isActive":true},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"topicSections":[{"anchor":"Group","identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"title":"Group"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This is an override of the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","isActive":true,"type":"reference"},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true,"type":"reference"},{"type":"text","text":" derivable."}]},{"type":"paragraph","inlineContent":[{"text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode.","type":"text"}]},{"anchor":"How-to-use-the-theme","level":2,"type":"heading","text":"How to use the theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true},{"text":" directly. You will have to use the ","type":"text"},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true},{"text":". Keep in mind the themes are ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"text":" and can be heavy, so you may use only as instance as singleton and not store any properties.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:"}]},{"type":"codeListing","syntax":"swift","code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""]}]}],"variants":[{"paths":["\/documentation\/oudsthemesinverse"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[[]]},"references":{"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"link","titleInlineContent":[{"text":"Orange theme","type":"text"}],"title":"Orange theme"},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"navigatorTitle":[{"kind":"identifier","text":"InverseTheme"}],"type":"topic","abstract":[{"text":"This is an override of the default basic ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":" with some inverted colors."},{"type":"text","text":" "},{"type":"text","text":"It can overrides any properties from its superclass, but is not derivable."}],"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"InverseTheme","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","url":"\/documentation\/oudsthemesinverse\/inversetheme","title":"InverseTheme"},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse":{"role":"collection","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","abstract":[{"text":"This theme overrides the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/"},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"title":"OUDSThemesInverse","url":"\/documentation\/oudsthemesinverse","type":"topic","kind":"symbol"}}}