{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This is an override of the ","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","isActive":true,"type":"reference"},{"type":"text","text":" with some inverted colors. It can override any properties from its superclass. We did not plan to make "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true},{"text":" derivable.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The aim of the theme is to provide a particular set of colors for dedicated applications and use cases, like for example B2B apps or teams needing eye comfort. It can be seen as an extended dark mode."}]},{"anchor":"How-to-use-the-theme","text":"How to use the theme","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","type":"reference","isActive":true},{"type":"text","text":" directly. You will have to use the "},{"type":"codeVoice","code":"OUDSThemeableView"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","isActive":true},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class objects"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"type":"codeListing","syntax":"swift","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeInverse \/\/ To get Inverseheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: InverseTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"roleHeading":"Framework","role":"collection","modules":[{"name":"OUDSThemesInverse"}],"title":"OUDSThemesInverse","externalID":"OUDSThemesInverse","symbolKind":"module"},"hierarchy":{"paths":[[]]},"topicSections":[{"title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme"],"anchor":"Group"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesinverse"]}],"sections":[],"abstract":[{"type":"text","text":"This theme overrides the "},{"type":"emphasis","inlineContent":[{"text":"Orange theme","type":"text"}]},{"text":" for some colors so as to bring an “inverse”-colored experience.","type":"text"}],"identifier":{"url":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","interfaceLanguage":"swift"},"references":{"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse":{"title":"OUDSThemesInverse","url":"\/documentation\/oudsthemesinverse","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse","kind":"symbol","abstract":[{"type":"text","text":"This theme overrides the "},{"type":"emphasis","inlineContent":[{"text":"Orange theme","type":"text"}]},{"type":"text","text":" for some colors so as to bring an “inverse”-colored experience."}],"type":"topic","role":"collection"},"https://ios.unified-design-system.orange.com/documentation/oudsthemesorange/":{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","type":"link","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","title":"Orange theme","titleInlineContent":[{"text":"Orange theme","type":"text"}]},"doc://ouds-ios.OUDSThemesInverse/documentation/OUDSThemesInverse/InverseTheme":{"abstract":[{"text":"This is an override of the default basic ","type":"text"},{"type":"codeVoice","code":"OrangeTheme"},{"text":" with some inverted colors.","type":"text"},{"text":" ","type":"text"},{"text":"It can overrides any properties from its superclass, but is not derivable.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/oudsthemesinverse\/inversetheme","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"InverseTheme","kind":"identifier"}],"role":"symbol","title":"InverseTheme","identifier":"doc:\/\/ouds-ios.OUDSThemesInverse\/documentation\/OUDSThemesInverse\/InverseTheme","navigatorTitle":[{"kind":"identifier","text":"InverseTheme"}]}}}