{"abstract":[{"type":"text","text":"The iOS library of "},{"inlineContent":[{"type":"text","text":"Orange Unified Design System Design System"}],"type":"emphasis"},{"text":", the new design system unified and cohesive across all platforms to build Orange mobile applications.","type":"text"}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/GettingStarted","doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/Tokens","doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/Themes","doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/Components","doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/Modules"],"anchor":"Essentials","title":"Essentials"},{"anchor":"Classes","generated":true,"title":"Classes","identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/OUDSTheme"]},{"anchor":"Structures","title":"Structures","identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/OUDSThemeableView"],"generated":true},{"anchor":"Enumerations","title":"Enumerations","generated":true,"identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/OUDSUserInterfaceSizeClass"]},{"title":"Extended Modules","generated":true,"anchor":"Extended-Modules","identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/SwiftUICore"]}],"metadata":{"symbolKind":"module","externalID":"OUDS","roleHeading":"Framework","title":"OUDS","role":"collection","modules":[{"name":"OUDS"}]},"identifier":{"url":"doc:\/\/ouds-ios.OUDS\/documentation\/OUDS","interfaceLanguage":"swift"},"hierarchy":{"paths":[[]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"Orange is providing a full design system to build Orange mobile aplications. The objective of ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange Unified Design System"}]},{"text":" (OUDS) is to propose a set of guidelines about how to apply the Orange brand on mobile applications. ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange Unified Design System"}]},{"type":"text","text":" also provides series of components and modules that show in details how to use this in the Orange apps."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Orange Unified Design System","type":"text"}],"type":"emphasis"},{"text":" has been implemented in a code library exposed as a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift Package"}]},{"type":"text","text":" that provides:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"a SwiftUI code library"}]}]},{"content":[{"inlineContent":[{"text":"a showcase application that can be launched to show the guidelines, components and modules","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"This demo app also shows how to use the library or to style existing components.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Using these resources will allow you to create Orange branded applications faster and will inherit all the work that was done to make sure that all presented codes are fully tested regarding the brand, the ecodesign, the open source and the accessibility compliances."}]},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System","type":"text"}]},{"text":" framework supports iOS 15 and later.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ouds"]}],"references":{"doc://ouds-ios.OUDS/documentation/OUDS/Themes":{"role":"article","kind":"article","type":"topic","url":"\/documentation\/ouds\/themes","abstract":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Themes"}]},{"type":"text","text":" are applications of specific values for "},{"inlineContent":[{"text":"components tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"semantic tokens"}]},{"text":" using in the end ","type":"text"},{"inlineContent":[{"text":"raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"A ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" contains any relevant "},{"type":"emphasis","inlineContent":[{"text":"semantic tokens","type":"text"}]},{"type":"text","text":" and "},{"inlineContent":[{"text":"component tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" which can be used for components rendering."},{"type":"text","text":" "},{"type":"text","text":"A "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"type":"text","text":" has also "},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":" associated to primitive types so as to give to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"components"}]},{"type":"text","text":", written with "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"type":"text","text":", the needed values in the suitable type. A "},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" can add for itself any new "},{"inlineContent":[{"text":"tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}],"identifier":"doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/Themes","title":"Themes"},"doc://ouds-ios.OUDS/documentation/OUDS/OUDSTheme":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"OUDSTheme"}],"title":"OUDSTheme","identifier":"doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/OUDSTheme","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OUDSTheme"}],"kind":"symbol","url":"\/documentation\/ouds\/oudstheme",