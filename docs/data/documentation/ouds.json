{"sections":[],"abstract":[{"text":"The iOS library of ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange Unified Design System Design System"}]},{"text":", the new design system unified and cohesive across all platforms to build Orange mobile applications for everyone everywhere.","type":"text"}],"hierarchy":{"paths":[[]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"symbolKind":"module","title":"OUDS","roleHeading":"Framework","role":"collection","modules":[{"name":"OUDS"}],"externalID":"OUDS"},"topicSections":[{"identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/GettingStarted","doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/Tokens","doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/Themes","doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/Components","doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/Modules"],"anchor":"Essentials","title":"Essentials"},{"title":"Classes","anchor":"Classes","identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/OUDSTheme"],"generated":true},{"generated":true,"anchor":"Structures","identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/OUDSThemeableView"],"title":"Structures"},{"title":"Enumerations","anchor":"Enumerations","generated":true,"identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/OUDSUserInterfaceSizeClass"]},{"generated":true,"anchor":"Extended-Modules","title":"Extended Modules","identifiers":["doc:\/\/ouds-ios.OUDS\/documentation\/OUDS\/SwiftUICore"]}],"kind":"symbol","primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"Orange is providing a full design system to build Orange mobile aplications. The objective of "},{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System","type":"text"}]},{"type":"text","text":" (OUDS) is to propose a set of guidelines about how to apply the Orange brand on mobile applications. "},{"inlineContent":[{"type":"text","text":"Orange Unified Design System"}],"type":"emphasis"},{"type":"text","text":" also provides series of components and modules that show in details how to use this in the Orange apps."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Orange Unified Design System","type":"text"}],"type":"emphasis"},{"text":" has been implemented in a code library exposed as a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift Package"}]},{"text":" that provides:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"a SwiftUI code library"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"a showcase application that can be launched to show the guidelines, components and modules (which will move outside the project in the future)"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"This demo app also shows how to use the library or to style existing components.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Using these resources will allow you to create Orange branded applications faster and will inherit all the work that was done to make sure that all presented codes are fully tested regarding the brand, the ecodesign, the open source and the accessibility compliances."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Orange Unified Design System"}],"type":"emphasis"},{"text":" framework supports iOS 15 and later.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can get details about the this design system in "},{"type":"reference","identifier":"https:\/\/unified-design-system.orange.com\/","isActive":true},{"text":".","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ouds"]}],"identifier":{"url":"doc:\/\/ouds-ios.OUDS\/documentation\/OUDS","interfaceLanguage":"swift"},"referenc