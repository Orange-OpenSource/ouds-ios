 wraps all "},{"type":"strong","inlineContent":[{"text":"font semantic tokens","type":"text"}]},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"multiple"}],"type":"emphasis"},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"composite"}],"type":"emphasis"},{"text":" or not, and expose them.","type":"text"},{"text":" ","type":"text"},{"text":"This provider should be integrated as a ","type":"text"},{"type":"codeVoice","code":"AllFontSemanticTokensProvider"},{"type":"text","text":" implementation inside "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" so as to provide"},{"type":"text","text":" "},{"text":"all tokens to the users. It helps users to override some of the tokens and assign them to an ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" implementation to use."}],"navigatorTitle":[{"kind":"identifier","text":"OrangeThemeFontSemanticTokensProvider"}],"url":"\/documentation\/oudsthemesorange\/orangethemefontsemantictokensprovider","kind":"symbol"},"doc://ouds-ios.OUDSThemesOrange/documentation/OUDSThemesOrange/OrangeTheme":{"title":"OrangeTheme","kind":"symbol","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"OrangeTheme"}],"abstract":[{"text":"This is an override of the default basic ","type":"text"},{"type":"codeVoice","code":"OUDSTheme"},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"must be seen as the default theme for the OUDS library"}]},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"It can override any properties from its superclass, and can be derived too.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"InverseTheme"},{"type":"text","text":" inherits from this "},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OrangeTheme","ki