{"kind":"symbol","sections":[],"metadata":{"roleHeading":"Framework","role":"collection","modules":[{"name":"OUDSThemesOrange"}],"title":"OUDSThemesOrange","externalID":"OUDSThemesOrange","symbolKind":"module"},"hierarchy":{"paths":[[]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"The Orange theme overrides some tokens from the basic "},{"type":"codeVoice","code":"OUDSTheme"},{"type":"text","text":" and should be seen as the default theme for the OUDS library with the Orange brand colors for example."}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"inlineContent":[{"text":"This is the default theme any app should use, and can be subclassed to define for example themes dedicated to countries. The ","type":"text"},{"type":"codeVoice","code":"InverseTheme"},{"type":"text","text":" is based on it."},{"type":"text","text":" "},{"text":"It embeds also in its target the brand colors which are not shared nor exposed in lower level targets or outside any module not depending to it.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In other words, this "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","isActive":true},{"text":" is based on the abstract ","type":"text"},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":", uses all the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Orange Unified Design System"}]},{"text":" kit and brings the Orange brand colors and assets.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"How-to-use-the-theme","type":"heading","text":"How to use the theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":" directly. To use the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":" without further modifications, you will have to use the "},{"code":"OUDSThemeableView","type":"codeVoice"},{"type":"text","text":" for your root view and give it an instance of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme"},{"type":"text","text":". Keep in mind the themes are "},{"type":"emphasis","inlineContent":[{"text":"Swift class objects","type":"text"}]},{"type":"text","text":" and can be heavy, so you may use only as instance as singleton and not store any properties."}]},{"type":"codeListing","syntax":"swift","code":["import OUDS \/\/ To get OUDSThemeableView","import OUDSThemeOrange \/\/ To get OrangeTheme","import SwiftUI","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","            }","        }","    }","}"]},{"inlineContent":[{"text":"Then, in your views, you can simply use the theme through an environment variable to get the tokens:","type":"text"}],"type":"paragraph"},{"code":["import OUDS \/\/ To get the theme environment variable","import SwiftUI","","struct SomeView: View {","","    \/\/ Get OUDS environment variable for theme thanks to themeable view","    @Environment(\\.theme) var theme","    ","    var body: some View {","        ","        \/\/ Use the theme to retrieve the tokens","        \/\/ For spaces: theme.spaces","        \/\/ For sizes: theme.sizes","        \/\/ For borders: theme.borders","        \/\/ For elevations: theme.elevations","        \/\/ For opacities: theme.opacities","        \/\/ For colors: theme.colors","    }","}",""],"type":"codeListing","syntax":"swift"},{"text":"How to enrich the theme","level":2,"anchor":"How-to-enrich-the-theme","type":"heading"},{"inlineContent":[{"type":"text","text":"You can enrich the "},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","isActive":true},{"text":" by subclassing it or by overriding some tokens.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"By subclassing","level":3,"anchor":"By-subclassing"},{"inlineContent":[{"type":"text","text":"You may want to define your own theme, thus you can override the "},{"identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","isActive":true,"type":"reference"},{"type":"text","text":" with your own class or just override the providers."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You will have to consider the tokens provider you need:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"spaces tokens are "},{"type":"codeVoice","code":"OrangeThemeSpaceSemanticTokensProvider"}]}]},{"content":[{"inlineContent":[{"text":"sizes tokens are in ","type":"text"},{"type":"codeVoice","code":"OrangeThemeSizeSemanticTokensProvider"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"colors tokens are all defined in ","type":"text"},{"type":"codeVoice","code":"OrangeThemeColorSemanticTokensProvider"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"borders tokens are in ","type":"text"},{"code":"OUDSBorderSemanticTokensProvider","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"elevations tokens are in "},{"type":"codeVoice","code":"OrangeThemeElevationSemanticTokensProvider"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"opacity tokens are in "},{"type":"codeVoice","code":"OrangeThemeOpacitySemanticTokensProvider"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"grid tokens are in ","type":"text"},{"code":"OrangeThemeGridSemanticTokensProvider","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"font tokens are in "},{"type":"codeVoice","code":"OrangeThemeFontSemanticTokensProvider"}]}]}],"type":"unorderedList"},{"code":["import OUDSTokensSemantic \/\/ To use semantic tokens if needed","import OUDSTokensRaw \/\/ To use raw tokens if needed","","\/\/ Token provider for spaces","","class YourAppThemeSpaceTokensProvider: OrangeThemeSpaceSemanticTokensProvider {","    override var spaceFixedMedium: SpaceSemanticToken {","        DimensionRawTokens.dimension400","    }","    override var spaceScaledShort: MultipleSpaceSemanticTokens {","        MultipleSpaceSemanticTokens(compact: spaceFixedJumbo, regular: spaceFixedJumbo)","    }","}","","\/\/ Token provider for sizes","","class YourAppThemeSizeTokensProvider: OrangeThemeSizeSemanticTokensProvider {","    override var sizeIconDecorative2xl: SizeSemanticToken {","        DimensionRawTokens.dimension300","    }","    override var sizeIconDecorativeMd: SizeSemanticToken {","        DimensionRawTokens.dimension900","    }","}","","\/\/ Token provider for colors","","class YourAppThemeColorTokensProvider: OrangeThemeColorSemanticTokensProvider {","    override var colorBgSecondary: MultipleColorSemanticTokens {","        MultipleColorSemanticTokens(light: ColorRawTokens.colorDecorativeAmber500, dark: OrangeBrandColorRawTokens.colorOrange900)","    }","    override var colorActionEnabled: MultipleColorSemanticTokens {","        MultipleColorSemanticTokens(light: ColorRawTokens.colorDecorativeShockingPink100, dark: ColorRawTokens.colorFunctionalScarlet600)","    }","}","","\/\/ Token provider for border","","class YourAppThemeBorderTokensProvider: OUDSBorderSemanticTokensProvider {","    override var borderStyleDefault: BorderStyleSemanticToken {","        BorderRawTokens.borderStyleDashed","    }","    override var borderWidthMedium: BorderWidthSemanticToken {","        BorderRawTokens.borderWidth100","    }","    override var borderRadiusTall: BorderRadiusSemanticToken {","        BorderRawTokens.borderRadius800","    }","}","","\/\/ Token provider for elevation","","class YourAppThemeElevationTokensProvider: OrangeThemeElevationSemanticTokensProvider {","    override var elevationStickyEmphasized: ElevationCompositeSemanticToken {","        ElevationCompositeSemanticToken(ElevationRawTokens.elevationBottom_4_600)","    }","}","","\/\/ Token provider for opacity","","class YourAppThemeOpacityTokensProvider: OrangeThemeOpacitySemanticTokensProvider {","    override var opacityStrong: OpacitySemanticToken {","        OpacityRawTokens.opacity920","    }","}","","\/\/ Token provider for grid","","class YourAppThemeGridTokensProvider: OrangeThemeGridSemanticTokensProvider {","    override var gridExtraCompactColumnGap: GridSemanticToken {","        GridRawTokens.gridColumnGap200","    }","    override var gridCompactColumnGap: GridSemanticToken {","        GridRawTokens.gridColumnGap200","    }","    override var gridRegularColumnGap: GridSemanticToken {","        GridRawTokens.gridColumnGap200","    }","}","","\/\/ Token provider for font","","class YourAppThemeFontTokensProvider: OrangeThemeFontSemanticTokensProvider {","    override var typeDisplayLarge: MultipleFontCompositeRawTokens {","        MultipleFontCompositeRawTokens(compact: FontRawTokens.typeRegular150, regular: FontRawTokens.typeRegular150)","    }","    override var typeCodeMedium: MultipleFontCompositeRawTokens {","        MultipleFontCompositeRawTokens(FontRawTokens.typeBold300)","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Then define your own theme class and assign the providers:"}],"type":"paragraph"},{"code":["import OUDSThemesOrange \/\/ To get OrangeTheme","","\/\/ Define your theme","class YourAppTheme: OrangeTheme {","    ","    override init() {","        super.init(colors: YourAppThemeColorTokensProvider(),","                   borders: YourAppThemeBorderTokensProvider(),","                   elevations: YourAppThemeElevationTokensProvider(),","                   fonts: YourAppThemeFontTokensProvider(),","                   grids: YourAppThemeGridTokensProvider(),","                   opacities: YourAppThemeOpacityTokensProvider(),","                   sizes: YourAppThemeSizeTokensProvider(),","                   spaces: YourAppThemeSpaceTokensProvider())","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Then add the theme:"}],"type":"paragraph"},{"code":["import OUDS  \/\/ To get OUDSThemeableView","import OUDSThemesOrange \/\/ To get OrangeTheme","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme()) {","                \/\/ Your root view","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"By overriding","type":"heading","anchor":"By-overriding","level":3},{"inlineContent":[{"text":"Quite simple and similar to the previous solution, but give only the provider to the ","type":"text"},{"type":"reference","identifier":"doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/OrangeTheme","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example for colors:"}]},{"type":"codeListing","syntax":"swift","code":["import OUDS \/\/ To get OUDSThemeableView","","@main","struct YourApp: App {","    var body: some Scene {","        WindowGroup {","            OUDSThemeableView(theme: OrangeTheme(colors: YourAppThemeColorTokensProvider())) {","                \/\/ Your root view","            }","        }","    }","}"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/oudsthemesorange"]}],"topicSections":[{"anchor":"Group","title":"Group","identifiers":["doc:\/\/ouds-ios.OUDSThemesOrange\/documentation\/OUDSThemesOrange\/O