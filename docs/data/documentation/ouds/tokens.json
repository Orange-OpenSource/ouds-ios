{"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/ouds\/tokens"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OUDS\/documentation\/OUDS"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDS\/documentation\/OUDS\/Tokens"},"sections":[],"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"About responsabilities:","type":"text"}]},{"type":"codeListing","syntax":"mermaid","code":["flowchart TD","    A(Raw token) --> |Contains primitive type SwiftUI value| B(Semantic token)","    B --> |Brings higher logic and functional meanings|C(Component token)","    C --> |Helps to make match between View and semantics|D(Component)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example:"}]},{"syntax":"mermaid","type":"codeListing","code":["flowchart TD","    A(colorFunctionalDodgerBlue500) --> |#26B2FF| B(sysColorBrandInformationDefault)","    B --> C(.informationIconbackgroundColor)","    C --> D(InformationModalView)"]},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"You can have the graphical rendering of this ","type":"text"},{"inlineContent":[{"type":"text","text":"Mermaid"}],"type":"emphasis"},{"text":" charts in the ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/blob\/develop\/OUDS\/README.md","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Frustrated? Boost ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/swiftlang\/swift-docc\/issues\/1026","isActive":true}]}],"type":"paragraph"},{"anchor":"Component-tokens","level":2,"text":"Component tokens","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"text":" (","type":"text"},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenscomponent\/","isActive":true},{"type":"text","text":") can be used to apply some style and configuration values to "},{"type":"emphasis","inlineContent":[{"text":"components","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Thus if a component needs to change for example its ","type":"text"},{"inlineContent":[{"text":"background color","type":"text"}],"type":"emphasis"},{"text":", and if a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"component token"}]},{"text":" is used for it, then only the value of this ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"token","type":"text"}]},{"type":"text","text":" should be changed without any modification on the "},{"inlineContent":[{"type":"text","text":"component"}],"type":"emphasis"},{"type":"text","text":" definition."},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Components"}],"type":"emphasis"},{"type":"text","text":" use "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" exposed through the "},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" to get their style values."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example with a fake component "},{"type":"codeVoice","code":"FormsTextInputComponentTokens"},{"type":"text","text":":"}]},{"syntax":"swift","code":["\/\/ Declare the component tokens","public protocol FormsTextInputComponentTokens {","    var ftiTitleFontWeight: TypographyFontWeightSemanticToken { get }","    var ftiTitleFontSize: TypographyFontSizeSemanticToken { get }","    var ftiTitleColor: ColorSemanticToken { get }","    ","    var ftiBorderColor: ColorSemanticToken { get }","    var ftiBorderStyle: BorderStyleSemanticToken { get }","    var ftiBorderWidth: BorderWidthSemanticToken { get }","}","","\/\/ Define the component tokens","extension OUDSTheme: FormsTextInputComponentTokens {","    private static let defaultBlack: ColorSemanticToken = ColorRawTokens.colorFunctionalBlack","    private static let defaultWhite: ColorSemanticToken = ColorRawTokens.colorFunctionalWhite","","    @objc open var ftiTitleFontWeight: TypographyFontWeightSemanticToken { fontWeightHeading }","    @objc open var ftiTitleFontSize: TypographyFontSizeSemanticToken { fontSizeLabelLarge }","    @objc open var ftiTitleColor: ColorSemanticToken { colorContentBrandPrimaryLight ?? Self.defaultBlack }","    ","    @objc open var ftiBorderColor: ColorSemanticToken { colorBorderEmphasizedLight ?? Self.defaultBlack }","    @objc open var ftiBorderStyle: BorderStyleSemanticToken { borderStyleDefault }","    @objc open var ftiBorderWidth: BorderWidthSemanticToken { borderWidthThin }","}","","\/\/ Then in the definition of the component FormsTextInput component, the theme will be called and the component tokens","\/\/ stored inside will be applied","\/\/ The View","","struct OUDSFormsTextInput: View {","","    \/\/ ...","    @Environment(\\.theme) var theme","","    public var body: some View {","        VStack(spacing: theme.spacePaddingBlockComponentTall) {","            Label(","                title: {","                    Text(\"Example of OUDSFormsTextInput\")","                        .fontWeight(theme.ftiTitleFontWeight.fontWeight)","                        .font(.system(size: theme.ftiTitleFontSize))","                        .foregroundColor(theme.ftiTitleColor.color)","                },","                icon: { \/*@START_MENU_TOKEN@*\/Image(systemName: \"42.circle\")\/*@END_MENU_TOKEN@*\/ }","            )","            Text(\"Write bellow some awesome text!\")","                .fontWeight(theme.ftiSubtitleFontWeight.fontWeight)","                .font(.system(size: theme.ftiSubtitleFontSize))","                .foregroundColor(theme.ftiSubtitleColor.color)","            TextField(placeholder, text: $value)","        }","        .padding(theme.spacePaddingBlockComponentTall)","        .background(colorScheme == .light ? theme.ftiBackgroundColorLight.color : theme.ftiBackgroundColorDark.color)","        .border(theme.ftiBorderColor.color, width: theme.ftiBorderWidth)","    }","}"],"type":"codeListing"},{"level":2,"text":"Semantic tokens","anchor":"Semantic-tokens","type":"heading"},{"inlineContent":[{"text":"These ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" ("},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","isActive":true,"type":"reference"},{"type":"text","text":") can be used mainly for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"type":"text","text":" to apply some style and configuration values."},{"text":" ","type":"text"},{"text":"They can be seen as an high level of usage with functional meanings.","type":"text"},{"type":"text","text":" "},{"text":"Thus if we need for example to change a warning color, supposing this color is defined as a ","type":"text"},{"inlineContent":[{"text":"semantic token","type":"text"}],"type":"emphasis"},{"type":"text","text":", we only have to change its assigned value and all components using the "},{"inlineContent":[{"text":"semantic token","type":"text"}],"type":"emphasis"},{"type":"text","text":" won’t be impacted in their definition."}],"type":"paragraph"},{"inlineContent":[{"text":"In addition, there are hundreds of ","type":"text"},{"inlineContent":[{"type":"text","text":"semantics tokens"}],"type":"emphasis"},{"type":"text","text":" and we needed to add them to the abstract root theme using extensions for clarity reasons to prevent to have a "},{"inlineContent":[{"text":"Swift class","type":"text"}],"type":"emphasis"},{"type":"text","text":" with thousands of lines. Each "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw token"}]},{"text":" “family” is then declared in its dedicated ","type":"text"},{"inlineContent":[{"type":"text","text":"Swift protocol"}],"type":"emphasis"},{"type":"text","text":" any root theme must implement. Because we choose to split responsabilities and objects into their own modules, we faced troubles to make possible for children themes to override properties declared in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"protocols"}]},{"text":" and defined in ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"extensions","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"That is the reason why tokens are exposed as "},{"code":"@objc open","type":"codeVoice"},{"text":" to be available and overridable anywhere.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To keep the same semantics as the ones used in our specifications, "},{"type":"emphasis","inlineContent":[{"text":"typealias","type":"text"}]},{"text":" are used to as to make the links to ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"primitive types"}]},{"text":" and our logic of ","type":"text"},{"inlineContent":[{"type":"text","text":"tokens"}],"type":"emphasis"},{"text":". These type aliases are available for those who want to make their own theme. It’s only syntaxic sugar to bring ","type":"text"},{"inlineContent":[{"type":"text","text":"design words"}],"type":"emphasis"},{"type":"text","text":" in our product."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example with "},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/colorsemantictokens","type":"reference","isActive":true},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Declare a semantic token for color","protocol ColorSemanticTokens {","    var sysColorBrandNeutralMutedWhite: ColorAliasSemanticToken? { get }","}","","\/\/ Define the semantic token","extension OUDSTheme: ColorSemanticTokens {","","    @objc open var sysColorBrandNeutralMutedWhite: ColorAliasSemanticToken? { ColorRawTokens.colorFunctionalWhite }","}","","\/\/ Then any component and view can use the theme and get the stored colors, only manipulating them by their variable names."]},{"type":"heading","text":"Raw tokens","level":2,"anchor":"Raw-tokens"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Raw tokens"}],"type":"emphasis"},{"text":" (","type":"text"},{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokensraw\/","isActive":true,"type":"reference"},{"text":") are smallest ","type":"text"},{"inlineContent":[{"type":"text","text":"tokens"}],"type":"emphasis"},{"type":"text","text":" possible. They are associated to raw values and will be finaly the values assigned to the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"components"}]},{"text":" properties.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In fact, we choose to use as most as possible primitive types for raw values, like "},{"type":"codeVoice","code":"Int"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Double"},{"type":"text","text":", "},{"type":"codeVoice","code":"CGFloat"},{"type":"text","text":" or "},{"code":"String","type":"codeVoice"},{"type":"text","text":" so as to handle the smallest types with few impacts on the memory for ecodesign principles. Indeed with hundreds of raw tokens, it will be more efficient to store primitive small types than "},{"type":"emphasis","inlineContent":[{"text":"structs","type":"text"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"classes"}]},{"type":"text","text":"."}]},{"inlineContent":[{"text":"So we expose also in higher level some properties so as to convert when needed some of these types to ","type":"text"},{"type":"codeVoice","code":"SwiftUI"},{"type":"text","text":" types (like "},{"type":"codeVoice","code":"Font.Weight"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Color"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To keep the same semantics as the ones used in our specifications, ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"typealias","type":"text"}]},{"type":"text","text":" are used to as to make the links to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"primitive types"}]},{"type":"text","text":" and our logic of "},{"inlineContent":[{"text":"tokens","type":"text"}],"type":"emphasis"},{"text":". These type aliases are available for those who want to make their own theme.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Using more simple and primitive types will help also to test the library. With also type aliases we force users to use our types and not higher level types like "},{"inlineContent":[{"text":"SwiftUI","type":"text"}],"type":"emphasis"},{"text":" types.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"We also choose to add in ","type":"text"},{"inlineContent":[{"text":"extension","type":"text"}],"type":"emphasis"},{"type":"text","text":" all the tokens values in a separated file so as to help the "},{"inlineContent":[{"type":"text","text":"Figma"}],"type":"emphasis"},{"type":"text","text":"-JSON-to-Swift parser to build files to copy and past easily in the project and keeping all the other objects."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example for "},{"isActive":true,"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokensraw\/colorrawtokens"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Define type alias for color raw tokens, we don't care in higher level their real type, just use aliases","public typealias ColorRawToken = String","","public enum ColorRawTokens { } ","","extension ColorRawTokens { \/\/ Gathers all color raw tokens, use enums for namespace optimization with static let","","    public static let colorFunctionalWhite: ColorRawToken = \"#FFFFFF\"","    public static let colorFunctionalScarlet400: ColorRawToken = \"#FF4D4E\"","    public static let colorTransparentBlack0: ColorRawToken = apply(opacity: OpacityRawTokens.opacity0, on: colorFunctionalBlack)","    ...","}","","extension String { \/\/ The OUDS library still exposes this comptuer property","    public var color: Color {","        Color(hexadecimalCode: self)","    }","}"]},{"text":"Add, edit or remove tokens","anchor":"Add-edit-or-remove-tokens","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to add, edit or remove tokens, you will have to follow some simple steps."},{"text":" ","type":"text"},{"type":"text","text":"You may need to "},{"type":"reference","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","isActive":true},{"text":" or ","type":"text"},{"identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/pulls","type":"reference","isActive":true},{"type":"text","text":" to submit the evolutions you want. Use for example the "},{"inlineContent":[{"text":"Token Update Request","type":"text"}],"type":"emphasis"},{"type":"text","text":" issue template."}]},{"text":"For raw tokens","level":3,"type":"heading","anchor":"For-raw-tokens"},{"type":"paragraph","inlineContent":[{"text":"You can refer to the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"OUDSTokensRaw"}]},{"type":"text","text":" documentation or "},{"type":"reference","overridingTitle":"get it online","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokensraw\/","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"get it online"}]}]},{"text":"For semantic tokens","level":3,"anchor":"For-semantic-tokens","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"You can refer to the ","type":"text"},{"inlineContent":[{"text":"OUDSTokensSemantic","type":"text"}],"type":"emphasis"},{"type":"text","text":" documentation or [get it online](https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/"}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Design tokens represent the small, repeated design decisions that make up a design system’s visual style. Tokens replace hard-coded static values, such as hexadecimal codes for color, with self-explanatory names."}],"seeAlsoSections":[{"identifiers":["doc:\/\/OUDS\/documentation\/OUDS\/GettingStarted","doc:\/\/OUDS\/documentation\/OUDS\/Themes","doc:\/\/OUDS\/documentation\/OUDS\/Components","doc:\/\/OUDS\/documentation\/OUDS\/Modules"],"title":"Essentials","generated":true}],"metadata":{"roleHeading":"Article","role":"article","title":"Tokens","modules":[{"name":"OUDS"}]},"references":{"doc://OUDS/documentation/OUDS/Components":{"role":"article","type":"topic","kind":"article","title":"Components","url":"\/documentation\/ouds\/components","abstract":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Components"}]},{"text":" are defined in the ","type":"text"},{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenscomponent\/","isActive":true},{"type":"text","text":" target and can be integrated in applications."}],"identifier":"doc:\/\/OUDS\/documentation\/OUDS\/Components"},"doc://OUDS/documentation/OUDS":{"abstract":[{"text":"The iOS library of ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Orange Unified Design System Design System","type":"text"}]},{"text":", the new design system unified and cohesive across all platforms to build Orange mobile applications.","type":"text"}],"kind":"symbol","title":"OUDS","type":"topic","identifier":"doc:\/\/OUDS\/documentation\/OUDS","url":"\/documentation\/ouds","role":"collection"},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/colorsemantictokens":{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/colorsemantictokens","titleInlineContent":[{"text":"OUDSTokensComponent\/ColorSemanticTokens","type":"text"}],"type":"link","title":"OUDSTokensComponent\/ColorSemanticTokens","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/colorsemantictokens"},"https://github.com/Orange-OpenSource/ouds-ios/blob/develop/OUDS/README.md":{"url":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/blob\/develop\/OUDS\/README.md","titleInlineContent":[{"type":"text","text":"README markdown"}],"title":"README markdown","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/blob\/develop\/OUDS\/README.md","type":"link"},"doc://OUDS/documentation/OUDS/Themes":{"role":"article","type":"topic","kind":"article","title":"Themes","url":"\/documentation\/ouds\/themes","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/Themes","abstract":[{"inlineContent":[{"type":"text","text":"Themes"}],"type":"emphasis"},{"text":" are applications of specific values for ","type":"text"},{"inlineContent":[{"type":"text","text":"components tokens"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"semantic tokens"}]},{"text":" using in the end ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"A "},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" contains any relevant "},{"inlineContent":[{"text":"semantic tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"component tokens"}]},{"text":" which can be used for components rendering.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"A "},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" has also "},{"inlineContent":[{"type":"text","text":"raw tokens"}],"type":"emphasis"},{"text":" associated to primitive types so as to give to ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"components"}]},{"text":", written with ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"SwiftUI","type":"text"}]},{"type":"text","text":", the needed values in the suitable type. A "},{"type":"emphasis","inlineContent":[{"text":"theme","type":"text"}]},{"text":" can add for itself any new ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"type":"text","text":"."}]},"doc://OUDS/documentation/OUDS/Modules":{"role":"article","type":"topic","kind":"article","title":"Modules","url":"\/documentation\/ouds\/modules","abstract":[{"type":"text","text":"A "},{"inlineContent":[{"text":"module","type":"text"}],"type":"emphasis"},{"text":" can be seen as a set of features and components to fill a need.","type":"text"},{"type":"text","text":" "},{"text":"There is not module yet.","type":"text"}],"identifier":"doc:\/\/OUDS\/documentation\/OUDS\/Modules"},"https://ios.unified-design-system.orange.com/documentation/oudstokensraw/colorrawtokens":{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokensraw\/colorrawtokens","titleInlineContent":[{"type":"text","text":"ColorRawTokens"}],"title":"ColorRawTokens","type":"link","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokensraw\/colorrawtokens"},"https://github.com/Orange-OpenSource/ouds-ios/issues":{"url":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","titleInlineContent":[{"text":"create an issue","type":"text"}],"type":"link","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/issues","title":"create an issue"},"https://github.com/swiftlang/swift-docc/issues/1026":{"identifier":"https:\/\/github.com\/swiftlang\/swift-docc\/issues\/1026","titleInlineContent":[{"type":"text","text":"the issue we submitted"}],"title":"the issue we submitted","type":"link","url":"https:\/\/github.com\/swiftlang\/swift-docc\/issues\/1026"},"https://github.com/Orange-OpenSource/ouds-ios/pulls":{"url":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/pulls","titleInlineContent":[{"text":"a pull request","type":"text"}],"type":"link","identifier":"https:\/\/github.com\/Orange-OpenSource\/ouds-ios\/pulls","title":"a pull request"},"doc://OUDS/documentation/OUDS/GettingStarted":{"role":"article","type":"topic","kind":"article","title":"Getting Started with OUDS","url":"\/documentation\/ouds\/gettingstarted","identifier":"doc:\/\/OUDS\/documentation\/OUDS\/GettingStarted","abstract":[{"text":"How to add the package as dependency, and import libraries","type":"text"}]},"https://ios.unified-design-system.orange.com/documentation/oudstokenssemantic/":{"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","titleInlineContent":[{"type":"text","text":"OUDSTokensSemantic"}],"title":"OUDSTokensSemantic","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenssemantic\/","type":"link"},"https://ios.unified-design-system.orange.com/documentation/oudstokenscomponent/":{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenscomponent\/","titleInlineContent":[{"text":"OUDSComponents","type":"text"}],"type":"link","title":"OUDSComponents","url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokenscomponent\/"},"https://ios.unified-design-system.orange.com/documentation/oudstokensraw/":{"url":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokensraw\/","titleInlineContent":[{"type":"text","text":"OUDSTokensRaw"}],"title":"OUDSTokensRaw","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudstokensraw\/","type":"link"}}}