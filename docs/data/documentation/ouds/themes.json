,"text":" to define. These tokens are overriden thanks to "},{"code":"@objc open","type":"codeVoice"},{"text":" combination so as to make possible to override these values in extensions (thanks to ","type":"text"},{"type":"codeVoice","code":"@objc"},{"type":"text","text":") and from objects outside the module (thanks to "},{"code":"open","type":"codeVoice"},{"text":"). Thus we can split values and responsabilities in different ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift Package Manager"}]},{"type":"text","text":" targets and keep overriding and inheritance possible."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Not that other brands like "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Parnasse"}]},{"text":" or ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Sosh"}]},{"text":" can be implemented in a dedicated insternal repository with their own assets.","type":"text"}],"type":"paragraph"},{"text":"Use themeable view","anchor":"Use-themeable-view","level":2,"type":"heading"},{"syntax":"swift","type":"codeListing","code":["\/\/ Make imports","import OUDS","import OUDSThemesOrange","","\/\/ Add themeable view to your root view","OUDSThemeableView(theme: OrangeTheme()) {","    YourRootView()","}"]},{"text":"Define a custom theme if needed","level":2,"anchor":"Define-a-custom-theme-if-needed","type":"heading"},{"code":["class YourCustomTheme: OrangeTheme { }","","extension YourCustomTheme {","","    \/\/ Override components tokens if needed","    override var ftiBorderStyle: BorderStyleSemanticToken { borderStyleDrag }","    override var ftiBorderWidth: BorderWidthSemanticToken { borderWidthThick }","    ","    \/\/ Override colors semantic tokens if needed","    override var colorBackgroundPrimary: ColorSemanticToken { ","        MultipleColorTokens(light: ColorRawTokens.ColorRawTokens.colorFunctionalSun500, dark: ColorRawTokens.ColorRawTokens.colorFunctionalSun800)","    }