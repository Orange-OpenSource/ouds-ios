esomeThemeExclusiveColor: MyThemeColorRawToken = \"#12345600\"","    ","}"]},{"inlineContent":[{"type":"text","text":"Then for your root view:"}],"type":"paragraph"},{"code":["import SwiftUI","import OUDS \/\/ To get ``OUDSThemeableView``","","struct MyAppRootView: View {","","    var body: some View {","        OUDSThemeableView(theme: OrangeCustomTheme()) {","            \/\/ ...","        }","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OUDS\/documentation\/OUDS"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OUDS\/documentation\/OUDS\/Themes"},"metadata":{"modules":[{"name":"OUDS"}],"roleHeading":"Article","title":"Themes","role":"article"},"sections":[],"kind":"article","abstract":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Themes"}]},{"text":" are applications of specific values for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"components tokens","type":"text"}]},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"semantic tokens"}],"type":"emphasis"},{"type":"text","text":" using in the end "},{"type":"emphasis","inlineContent":[{"type":"text","text":"raw tokens"}]},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"A ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"theme"}]},{"type":"text","text":" contains any relevant "},{"type":"emphasis","inlineContent":[{"text":"semantic tokens","type":"text"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"text":"component tokens","type":"text"}]},{"type":"text","text":" which can be used for components rendering."},{"type":"text","text":" "},{"text":"A ","type":"text"},{"inlineContent":[{"type":"text","text":"theme"}],"type":"emphasis"},{"type":"text","text":" has also "},{"inlineContent":[{"type":"text","text":"raw tokens"}],"type":"emphasis"},{"text":" associated to primitive types so as to give to ","type":"text"},{"inlineContent":[{