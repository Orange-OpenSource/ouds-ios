{"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"This library exposes today up to three themes:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesorange\/","isActive":true},{"type":"text","text":" which can be seen as the default "},{"inlineContent":[{"text":"theme","type":"text"}],"type":"emphasis"},{"text":" ;","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemessosh\/","isActive":true},{"text":" for ","type":"text"},{"inlineContent":[{"text":"Sosh","type":"text"}],"type":"emphasis"},{"type":"text","text":" ;"}]}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/ios.unified-design-system.orange.com\/documentation\/oudsthemesinverse\/","type":"reference","isActive":true},{"type":"text","text":" for other use cases."},{"type":"text","text":" "},{"type":"text","text":"They both are based on an "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" defining default values."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Themes"}],"type":"emphasis"},{"type":"text","text":" can be defined thanks to "},{"type":"codeVoice","code":"open class"},{"type":"text","text":" in Swift. It allows inheritance and derivation."}]},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"Themes","type":"text"}]},{"text":" have Swift ","type":"text"},{"inlineContent":[{"type":"text","text":"extensions"}],"type":"emphasis"},{"type":"text","text":" so as to get the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" to define. These tokens are overriden thanks to "},{"type":"codeVoice","code":"@objc open"},{"type":"text","text":" combination so as to make possible to override these values in extensions (thanks to "},{"type":"codeVoice","code":"@objc"},{"text":") and from objects outside the module (thanks to ","type":"text"},{"type":"codeVoice","code":"open"},{"text":"). Thus we can split values and responsabilities in different ","type":"text"},{"inlineContent":[{"text":"Swift Package Manager","type":"text"}],"type":"emphasis"},{"type":"text","text":" targets and keep overriding and inheritance possible."}],"type":"paragraph"},{"text":"Use themeable view","type":"heading","anchor":"Use-themeable-view","level":2},{"code":["\/\/ Make imports","import OUDS","import OUDSThemesOrange","","\/\/ Add themeable view to your root view","OUDSThemeableView(theme: OrangeTheme()) {","    YourRootView()","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"Define a custom theme if needed","anchor":"Define-a-custom-theme-if-needed"},{"type":"codeListing","syntax":"swift","code":["class YourCustomTheme: OrangeTheme { }","","extension YourCustomTheme {","","    \/\/ Override components tokens if needed","    override var ftiBorderStyle: BorderStyleSemanticToken { borderStyleDrag }","    override var ftiBorderWidth: BorderWidthSemanticToken { borderWidthThickest }","    ","    \/\/ Override colors semantic tokens if needed","    override var colorBackgroundDefaultPrimaryLight: ColorSemanticToken! { ColorRawTokens.colorFunctionalSun500 }","    override var colorBackgroundDefaultPrimaryDark: ColorSemanticToken! { ColorRawTokens.colorFunctionalSun800 }","    ","    \/\/ Etc.","}"]},{"level":2,"type":"heading","anchor":"How-to-create-your-own-theme","text":"How to create your own theme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is quite simple, you have to follow several steps."}]},{"type":"paragraph","inlineContent":[{"text":"First, create a ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift class"}]},{"type":"text","text":" which will inherit from "},{"code":"OrangeTheme","type":"codeVoice"},{"type":"text","text":" or "},{"code":"OUDSTheme","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You can see "},{"type":"codeVoice","code":"OrangeTheme"},{"type":"text","text":" as more specified and less abtract as "},{"code":"OUDSTheme","type":"codeVoice"},{"type":"text","text":" which is the base of all themes. We do not recommend to sue directly the "},{"type":"codeVoice","code":"OUDSTheme"},{"text":" as is.","type":"text"},{"text":" ","type":"text"},{"text":"Then, you should override the ","type":"text"},{"inlineContent":[{"type":"text","text":"semantic tokens"}],"type":"emphasis"},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"components tokens","type":"text"}]},{"type":"text","text":" you want ; we recommend to use "},{"inlineContent":[{"type":"text","text":"Swift extensions"}],"type":"emphasis"},{"type":"text","text":" for clarity reasons."},{"type":"text","text":" "},{"type":"text","text":"If your theme needs to define its own "},{"type":"emphasis","inlineContent":[{"text":"raw tokens","type":"text"}]},{"type":"text","text":", you can also define them using a "},{"code":"enum","type":"codeVoice"},{"text":" and the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"raw tokens types","type":"text"}]},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example:"}]},{"code":["import Foundation","import SwiftUI","import OUDSTokensRaw        \/\/ To get raw tokens","import OUDSTokensSemantic   \/\/ To get semantic tokens","import OUDSTokensComponent  \/\/ To get component tokens","import OUDSThemesOrange     \/\/ To override OrangeTheme (which is default theme)","","\/\/ Can be for example a country theme","class OrangeCustomTheme: OrangeTheme { }","","extension OrangeCustomTheme { \/\/ For FormsTextInputComponentToke