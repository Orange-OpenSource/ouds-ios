":"tokens"}]},{"type":"text","text":" possible. They are associated to raw values and will be finaly the values assigned to the "},{"type":"emphasis","inlineContent":[{"text":"components","type":"text"}]},{"type":"text","text":" properties."}],"title":"OUDSTokensRaw","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw","role":"collection","kind":"symbol","type":"topic"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/GridRawToken":{"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/GridRawToken","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"GridRawToken","kind":"identifier"}],"title":"GridRawToken","url":"\/documentation\/oudstokensraw\/gridrawtoken","abstract":[{"type":"text","text":"In the global design system tool, the notion of “raw tokens of grids” exist but refers always to dimension raw tokens."}],"navigatorTitle":[{"kind":"identifier","text":"GridRawToken"}]}}}