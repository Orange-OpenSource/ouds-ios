ct"},{"text":" so as to be shared through ","type":"text"},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" with extensions and protocols within modules."}],"navigatorTitle":[{"text":"ElevationCompositeRawToken","kind":"identifier"}]},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw":{"type":"topic","abstract":[{"inlineContent":[{"text":"Raw tokens","type":"text"}],"type":"emphasis"},{"type":"text","text":" are smallest "},{"type":"emphasis","inlineContent":[{"type":"text","text":"tokens"}]},{"type":"text","text":" possible. They are associated to raw values and will be finaly the values assigned to the "},{"inlineContent":[{"type":"text","text":"components"}],"type":"emphasis"},{"type":"text","text":" properties."}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw","kind":"symbol","title":"OUDSTokensRaw","url":"\/documentation\/oudstokensraw","role":"collection"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationRawTokens/elevationBottom_2_400":{"abstract":[],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawTokens\/elevationBottom_2_400","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"elevationBottom_2_400","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@M@OUDSTokensRaw@objc(cs)ElevationCompositeRawToken","text":"ElevationCompositeRawToken"}],"title":"elevationBottom_2_400","kind":"symbol","url":"\/documentation\/oudstokensraw\/elevationrawtokens\/elevationbottom_2_400"}}}