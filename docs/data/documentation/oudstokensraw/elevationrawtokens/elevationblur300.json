xt","text":"X offset"}]},{"type":"text","text":" and the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Y offset"}]},{"type":"text","text":", all of them being "},{"identifier":"doc:\/\/ouds-ios.OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawToken","type":"reference","isActive":true},{"type":"text","text":" type."},{"type":"text","text":" "},{"type":"text","text":"Combinations of these three values can be defined inside "},{"identifier":"doc:\/\/ouds-ios.OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationCompositeRawToken","type":"reference","isActive":true},{"type":"text","text":" i.e. "},{"type":"emphasis","inlineContent":[{"type":"text","text":"composite tokens"}]},{"type":"text","text":" defining a whil box shadow to use for elevation effect."}],"navigatorTitle":[{"kind":"identifier","text":"ElevationRawTokens"}],"url":"\/documentation\/oudstokensraw\/elevationrawtokens","title":"ElevationRawTokens"},"doc://ouds-ios.OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationRawToken":{"abstract":[{"type":"text","text":"Type aliases precising "},{"code":"CGFloat","type":"codeVoice"},{"type":"text","text":" values are used (because used in "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiftUI"}]},{"type":"text","text":" API) for each "},{"type":"strong","inlineContent":[{"type":"text","text":"elevation raw token"}]},{"type":"text","text":", to keep grammar clean and clear with design system grammar."}],"url":"\/documentation\/oudstokensraw\/elevationrawtoken","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ElevationRawToken"}],"identifier":"doc:\/\/ouds-ios.OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ElevationRawToken","type":"topic","kind":"symbol","title":"ElevationRawToken","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"ElevationRawToken"}]},"doc://ouds-ios.OUDSTokensRaw/documentation/OUDSTokensRaw/ElevationCompositeRawToken":{"title":"ElevationCompos