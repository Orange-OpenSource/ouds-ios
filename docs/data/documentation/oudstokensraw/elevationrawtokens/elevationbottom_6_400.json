"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Primitive types such as ","type":"text"},{"type":"codeVoice","code":"CGFloat"},{"type":"text","text":" must be used to as to allow to use "},{"code":"@objc","type":"codeVoice"},{"text":" keywords in extensions for overriding.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Such tokens are packed in a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Swift enum"}]},{"text":" so as to gather them in one object with the suitable namespace and avoid to have just constants in nothing else","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(i.e. publicly accessible from everywhere). More optimized than "},{"type":"emphasis","inlineContent":[{"text":"struct","type":"text"}]},{"text":".","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"ElevationRawTokens","kind":"identifier"}],"url":"\/documentation\/oudstokensraw\/elevationrawtokens","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ElevationRawTokens"}]},"doc://ouds-ios.OUDSTokensRaw/documentation/OUDSTokensRaw":{"role":"collection","abstract":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Raw tokens"}]},{"type":"text","text":" are smallest "},{"type":"emphasis","inlineContent":[{"text":"tokens","type":"text"}]},{"type":"text","text":" possible. They are associated to raw values and will be finaly the values assigned to the "},{"inlineContent":[{"text":"components","type":"text"}],"type":"emphasis"},{"type":"text","text":" properties."}],"type":"topic","kind":"symbol","title":"OUDSTokensRaw","url":"\/documentation\/oudstokensraw","identifier":"doc:\/\/ouds-ios.OUDSTokensRaw\/documentation\/OUDSTokensRaw"}}}