},{"type":"text","text":" are smallest "},{"inlineContent":[{"type":"text","text":"tokens"}],"type":"emphasis"},{"type":"text","text":" possible. They are associated to raw values and will be finaly the values assigned to the "},{"inlineContent":[{"text":"components","type":"text"}],"type":"emphasis"},{"type":"text","text":" properties."}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw","url":"\/documentation\/oudstokensraw","type":"topic","kind":"symbol"},"doc://OUDSTokensRaw/documentation/OUDSTokensRaw/ColorRawToken":{"title":"ColorRawToken","role":"symbol","abstract":[{"type":"text","text":"A color raw token is finaly a "},{"code":"String","type":"codeVoice"},{"text":" containing the hexadecimal code of the color, to keep grammar clean and clear with design system grammar.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"ColorRawToken"}],"identifier":"doc:\/\/OUDSTokensRaw\/documentation\/OUDSTokensRaw\/ColorRawToken","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"ColorRawToken","kind":"identifier"}],"url":"\/documentation\/oudstokensraw\/colorrawtoken","kind":"symbol","type":"topic"}}}